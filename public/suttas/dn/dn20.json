{
  "uid": "dn20",
  "title": "Mahāsamayasutta",
  "nikaya": "dn",
  "segments": [
    {
      "id": "dn20:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "dn20:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sakkesu viharati kapilavatthusmiṁ mahāvane mahatā bhikkhusaṅghena saddhiṁ pañcamattehi bhikkhusatehi sabbeheva arahantehi;"
    },
    {
      "id": "dn20:1.3",
      "pali": "dasahi ca lokadhātūhi devatā yebhuyyena sannipatitā honti bhagavantaṁ dassanāya bhikkhusaṅghañca."
    },
    {
      "id": "dn20:2.1",
      "pali": "Atha kho catunnaṁ suddhāvāsakāyikānaṁ devatānaṁ etadahosi:"
    },
    {
      "id": "dn20:2.2",
      "pali": "“ayaṁ kho bhagavā sakkesu viharati kapilavatthusmiṁ mahāvane mahatā bhikkhusaṅghena saddhiṁ pañcamattehi bhikkhusatehi sabbeheva arahantehi;"
    },
    {
      "id": "dn20:2.3",
      "pali": "dasahi ca lokadhātūhi devatā yebhuyyena sannipatitā honti bhagavantaṁ dassanāya bhikkhusaṅghañca."
    },
    {
      "id": "dn20:2.4",
      "pali": "Yannūna mayampi yena bhagavā tenupasaṅkameyyāma; upasaṅkamitvā bhagavato santike paccekaṁ gāthaṁ bhāseyyāmā”ti."
    },
    {
      "id": "dn20:3.1",
      "pali": "Atha kho tā devatā seyyathāpi nāma balavā puriso samiñjitaṁ vā bāhaṁ pasāreyya pasāritaṁ vā bāhaṁ samiñjeyya; evameva—suddhāvāsesu devesu antarahitā bhagavato purato pāturahesuṁ."
    },
    {
      "id": "dn20:3.2",
      "pali": "Atha kho tā devatā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "dn20:3.3",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "dn20:3.4",
      "pali": "“Mahāsamayo pavanasmiṁ,"
    },
    {
      "id": "dn20:3.5",
      "pali": "Devakāyā samāgatā;"
    },
    {
      "id": "dn20:3.6",
      "pali": "Āgatamha imaṁ dhammasamayaṁ,"
    },
    {
      "id": "dn20:3.7",
      "pali": "Dakkhitāye aparājitasaṅghan”ti."
    },
    {
      "id": "dn20:3.8",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "dn20:3.9",
      "pali": "“Tatra bhikkhavo samādahaṁsu,"
    },
    {
      "id": "dn20:3.10",
      "pali": "Cittamattano ujukaṁ akaṁsu;"
    },
    {
      "id": "dn20:3.11",
      "pali": "Sārathīva nettāni gahetvā,"
    },
    {
      "id": "dn20:3.12",
      "pali": "Indriyāni rakkhanti paṇḍitā”ti."
    },
    {
      "id": "dn20:3.13",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "dn20:3.14",
      "pali": "“Chetvā khīlaṁ chetvā palighaṁ,"
    },
    {
      "id": "dn20:3.15",
      "pali": "Indakhīlaṁ ūhacca manejā;"
    },
    {
      "id": "dn20:3.16",
      "pali": "Te caranti suddhā vimalā,"
    },
    {
      "id": "dn20:3.17",
      "pali": "Cakkhumatā sudantā susunāgā”ti."
    },
    {
      "id": "dn20:3.18",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "dn20:3.19",
      "pali": "“Ye keci buddhaṁ saraṇaṁ gatāse,"
    },
    {
      "id": "dn20:3.20",
      "pali": "Na te gamissanti apāyabhūmiṁ;"
    },
    {
      "id": "dn20:3.21",
      "pali": "Pahāya mānusaṁ dehaṁ,"
    },
    {
      "id": "dn20:3.22",
      "pali": "Devakāyaṁ paripūressantī”ti."
    },
    {
      "id": "dn20:4.1",
      "pali": "Atha kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "dn20:4.2",
      "pali": "“yebhuyyena, bhikkhave, dasasu lokadhātūsu devatā sannipatitā honti, tathāgataṁ dassanāya bhikkhusaṅghañca."
    },
    {
      "id": "dn20:4.3",
      "pali": "Yepi te, bhikkhave, ahesuṁ atītamaddhānaṁ arahanto sammāsambuddhā, tesampi bhagavantānaṁ etapparamāyeva devatā sannipatitā ahesuṁ seyyathāpi mayhaṁ etarahi."
    },
    {
      "id": "dn20:4.4",
      "pali": "Yepi te, bhikkhave, bhavissanti anāgatamaddhānaṁ arahanto sammāsambuddhā, tesampi bhagavantānaṁ etapparamāyeva devatā sannipatitā bhavissanti seyyathāpi mayhaṁ etarahi."
    },
    {
      "id": "dn20:4.5",
      "pali": "Ācikkhissāmi, bhikkhave, devakāyānaṁ nāmāni;"
    },
    {
      "id": "dn20:4.6",
      "pali": "kittayissāmi, bhikkhave, devakāyānaṁ nāmāni;"
    },
    {
      "id": "dn20:4.7",
      "pali": "desessāmi, bhikkhave, devakāyānaṁ nāmāni."
    },
    {
      "id": "dn20:4.8",
      "pali": "Taṁ suṇātha, sādhukaṁ manasikarotha, bhāsissāmī”ti."
    },
    {
      "id": "dn20:4.9",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "dn20:4.10",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "dn20:5.1",
      "pali": "“Silokamanukassāmi,"
    },
    {
      "id": "dn20:5.2",
      "pali": "yattha bhummā tadassitā;"
    },
    {
      "id": "dn20:5.3",
      "pali": "Ye sitā girigabbharaṁ,"
    },
    {
      "id": "dn20:5.4",
      "pali": "pahitattā samāhitā."
    },
    {
      "id": "dn20:5.5",
      "pali": "Puthūsīhāva sallīnā,"
    },
    {
      "id": "dn20:5.6",
      "pali": "lomahaṁsābhisambhuno;"
    },
    {
      "id": "dn20:5.7",
      "pali": "Odātamanasā suddhā,"
    },
    {
      "id": "dn20:5.8",
      "pali": "vippasannamanāvilā."
    },
    {
      "id": "dn20:5.9",
      "pali": "Bhiyyo pañcasate ñatvā,"
    },
    {
      "id": "dn20:5.10",
      "pali": "vane kāpilavatthave;"
    },
    {
      "id": "dn20:5.11",
      "pali": "Tato āmantayī satthā,"
    },
    {
      "id": "dn20:5.12",
      "pali": "sāvake sāsane rate."
    },
    {
      "id": "dn20:5.13",
      "pali": "‘Devakāyā abhikkantā,"
    },
    {
      "id": "dn20:5.14",
      "pali": "te vijānātha bhikkhavo’;"
    },
    {
      "id": "dn20:5.15",
      "pali": "Te ca ātappamakaruṁ,"
    },
    {
      "id": "dn20:5.16",
      "pali": "sutvā buddhassa sāsanaṁ."
    },
    {
      "id": "dn20:6.1",
      "pali": "Tesaṁ pāturahu ñāṇaṁ,"
    },
    {
      "id": "dn20:6.2",
      "pali": "amanussānadassanaṁ;"
    },
    {
      "id": "dn20:6.3",
      "pali": "Appeke satamaddakkhuṁ,"
    },
    {
      "id": "dn20:6.4",
      "pali": "sahassaṁ atha sattariṁ."
    },
    {
      "id": "dn20:6.5",
      "pali": "Sataṁ eke sahassānaṁ,"
    },
    {
      "id": "dn20:6.6",
      "pali": "amanussānamaddasuṁ;"
    },
    {
      "id": "dn20:6.7",
      "pali": "Appekenantamaddakkhuṁ,"
    },
    {
      "id": "dn20:6.8",
      "pali": "disā sabbā phuṭā ahuṁ."
    },
    {
      "id": "dn20:6.9",
      "pali": "Tañca sabbaṁ abhiññāya,"
    },
    {
      "id": "dn20:6.10",
      "pali": "vavatthitvāna cakkhumā;"
    },
    {
      "id": "dn20:6.11",
      "pali": "Tato āmantayī satthā,"
    },
    {
      "id": "dn20:6.12",
      "pali": "sāvake sāsane rate."
    },
    {
      "id": "dn20:6.13",
      "pali": "‘Devakāyā abhikkantā,"
    },
    {
      "id": "dn20:6.14",
      "pali": "te vijānātha bhikkhavo;"
    },
    {
      "id": "dn20:6.15",
      "pali": "Ye vohaṁ kittayissāmi,"
    },
    {
      "id": "dn20:6.16",
      "pali": "girāhi anupubbaso’."
    },
    {
      "id": "dn20:7.1",
      "pali": "Sattasahassā te yakkhā,"
    },
    {
      "id": "dn20:7.2",
      "pali": "bhummā kāpilavatthavā;"
    },
    {
      "id": "dn20:7.3",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:7.4",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:7.5",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:7.6",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:7.7",
      "pali": "Chasahassā hemavatā,"
    },
    {
      "id": "dn20:7.8",
      "pali": "yakkhā nānattavaṇṇino;"
    },
    {
      "id": "dn20:7.9",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:7.10",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:7.11",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:7.12",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:7.13",
      "pali": "Sātāgirā tisahassā,"
    },
    {
      "id": "dn20:7.14",
      "pali": "yakkhā nānattavaṇṇino;"
    },
    {
      "id": "dn20:7.15",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:7.16",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:7.17",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:7.18",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:7.19",
      "pali": "Iccete soḷasasahassā,"
    },
    {
      "id": "dn20:7.20",
      "pali": "yakkhā nānattavaṇṇino;"
    },
    {
      "id": "dn20:7.21",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:7.22",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:7.23",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:7.24",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:8.1",
      "pali": "Vessāmittā pañcasatā,"
    },
    {
      "id": "dn20:8.2",
      "pali": "yakkhā nānattavaṇṇino;"
    },
    {
      "id": "dn20:8.3",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:8.4",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:8.5",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:8.6",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:8.7",
      "pali": "Kumbhīro rājagahiko,"
    },
    {
      "id": "dn20:8.8",
      "pali": "vepullassa nivesanaṁ;"
    },
    {
      "id": "dn20:8.9",
      "pali": "Bhiyyo naṁ satasahassaṁ,"
    },
    {
      "id": "dn20:8.10",
      "pali": "yakkhānaṁ payirupāsati;"
    },
    {
      "id": "dn20:8.11",
      "pali": "Kumbhīro rājagahiko,"
    },
    {
      "id": "dn20:8.12",
      "pali": "sopāgā samitiṁ vanaṁ."
    },
    {
      "id": "dn20:9.1",
      "pali": "Purimañca disaṁ rājā,"
    },
    {
      "id": "dn20:9.2",
      "pali": "dhataraṭṭho pasāsati;"
    },
    {
      "id": "dn20:9.3",
      "pali": "Gandhabbānaṁ adhipati,"
    },
    {
      "id": "dn20:9.4",
      "pali": "mahārājā yasassiso."
    },
    {
      "id": "dn20:9.5",
      "pali": "Puttāpi tassa bahavo,"
    },
    {
      "id": "dn20:9.6",
      "pali": "indanāmā mahabbalā;"
    },
    {
      "id": "dn20:9.7",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:9.8",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:9.9",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:9.10",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:9.11",
      "pali": "Dakkhiṇañca disaṁ rājā,"
    },
    {
      "id": "dn20:9.12",
      "pali": "virūḷho taṁ pasāsati;"
    },
    {
      "id": "dn20:9.13",
      "pali": "Kumbhaṇḍānaṁ adhipati,"
    },
    {
      "id": "dn20:9.14",
      "pali": "mahārājā yasassiso."
    },
    {
      "id": "dn20:9.15",
      "pali": "Puttāpi tassa bahavo,"
    },
    {
      "id": "dn20:9.16",
      "pali": "indanāmā mahabbalā;"
    },
    {
      "id": "dn20:9.17",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:9.18",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:9.19",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:9.20",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:9.21",
      "pali": "Pacchimañca disaṁ rājā,"
    },
    {
      "id": "dn20:9.22",
      "pali": "virūpakkho pasāsati;"
    },
    {
      "id": "dn20:9.23",
      "pali": "Nāgānañca adhipati,"
    },
    {
      "id": "dn20:9.24",
      "pali": "mahārājā yasassiso."
    },
    {
      "id": "dn20:9.25",
      "pali": "Puttāpi tassa bahavo,"
    },
    {
      "id": "dn20:9.26",
      "pali": "indanāmā mahabbalā;"
    },
    {
      "id": "dn20:9.27",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:9.28",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:9.29",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:9.30",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:9.31",
      "pali": "Uttarañca disaṁ rājā,"
    },
    {
      "id": "dn20:9.32",
      "pali": "kuvero taṁ pasāsati;"
    },
    {
      "id": "dn20:9.33",
      "pali": "Yakkhānañca adhipati,"
    },
    {
      "id": "dn20:9.34",
      "pali": "mahārājā yasassiso."
    },
    {
      "id": "dn20:9.35",
      "pali": "Puttāpi tassa bahavo,"
    },
    {
      "id": "dn20:9.36",
      "pali": "indanāmā mahabbalā;"
    },
    {
      "id": "dn20:9.37",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:9.38",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:9.39",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:9.40",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:9.41",
      "pali": "Purimaṁ disaṁ dhataraṭṭho,"
    },
    {
      "id": "dn20:9.42",
      "pali": "dakkhiṇena virūḷhako;"
    },
    {
      "id": "dn20:9.43",
      "pali": "Pacchimena virūpakkho,"
    },
    {
      "id": "dn20:9.44",
      "pali": "kuvero uttaraṁ disaṁ."
    },
    {
      "id": "dn20:9.45",
      "pali": "Cattāro te mahārājā,"
    },
    {
      "id": "dn20:9.46",
      "pali": "samantā caturo disā;"
    },
    {
      "id": "dn20:9.47",
      "pali": "Daddallamānā aṭṭhaṁsu,"
    },
    {
      "id": "dn20:9.48",
      "pali": "vane kāpilavatthave."
    },
    {
      "id": "dn20:10.1",
      "pali": "Tesaṁ māyāvino dāsā,"
    },
    {
      "id": "dn20:10.2",
      "pali": "āguṁ vañcanikā saṭhā;"
    },
    {
      "id": "dn20:10.3",
      "pali": "Māyā kuṭeṇḍu viṭeṇḍu,"
    },
    {
      "id": "dn20:10.4",
      "pali": "viṭucca viṭuṭo saha."
    },
    {
      "id": "dn20:10.5",
      "pali": "Candano kāmaseṭṭho ca,"
    },
    {
      "id": "dn20:10.6",
      "pali": "kinnighaṇḍu nighaṇḍu ca;"
    },
    {
      "id": "dn20:10.7",
      "pali": "Panādo opamañño ca,"
    },
    {
      "id": "dn20:10.8",
      "pali": "devasūto ca mātali."
    },
    {
      "id": "dn20:10.9",
      "pali": "Cittaseno ca gandhabbo,"
    },
    {
      "id": "dn20:10.10",
      "pali": "naḷorājā janesabho;"
    },
    {
      "id": "dn20:10.11",
      "pali": "Āgā pañcasikho ceva,"
    },
    {
      "id": "dn20:10.12",
      "pali": "timbarū sūriyavacchasā."
    },
    {
      "id": "dn20:10.13",
      "pali": "Ete caññe ca rājāno,"
    },
    {
      "id": "dn20:10.14",
      "pali": "gandhabbā saha rājubhi;"
    },
    {
      "id": "dn20:10.15",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:10.16",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:11.1",
      "pali": "Athāguṁ nāgasā nāgā,"
    },
    {
      "id": "dn20:11.2",
      "pali": "vesālā sahatacchakā;"
    },
    {
      "id": "dn20:11.3",
      "pali": "Kambalassatarā āguṁ,"
    },
    {
      "id": "dn20:11.4",
      "pali": "pāyāgā saha ñātibhi."
    },
    {
      "id": "dn20:11.5",
      "pali": "Yāmunā dhataraṭṭhā ca,"
    },
    {
      "id": "dn20:11.6",
      "pali": "āgū nāgā yasassino;"
    },
    {
      "id": "dn20:11.7",
      "pali": "Erāvaṇo mahānāgo,"
    },
    {
      "id": "dn20:11.8",
      "pali": "sopāgā samitiṁ vanaṁ."
    },
    {
      "id": "dn20:11.9",
      "pali": "Ye nāgarāje sahasā haranti,"
    },
    {
      "id": "dn20:11.10",
      "pali": "Dibbā dijā pakkhi visuddhacakkhū;"
    },
    {
      "id": "dn20:11.11",
      "pali": "Vehāyasā te vanamajjhapattā,"
    },
    {
      "id": "dn20:11.12",
      "pali": "Citrā supaṇṇā iti tesa nāmaṁ."
    },
    {
      "id": "dn20:11.13",
      "pali": "Abhayaṁ tadā nāgarājānamāsi,"
    },
    {
      "id": "dn20:11.14",
      "pali": "Supaṇṇato khemamakāsi buddho;"
    },
    {
      "id": "dn20:11.15",
      "pali": "Saṇhāhi vācāhi upavhayantā,"
    },
    {
      "id": "dn20:11.16",
      "pali": "Nāgā supaṇṇā saraṇamakaṁsu buddhaṁ."
    },
    {
      "id": "dn20:12.1",
      "pali": "Jitā vajirahatthena,"
    },
    {
      "id": "dn20:12.2",
      "pali": "samuddaṁ asurāsitā;"
    },
    {
      "id": "dn20:12.3",
      "pali": "Bhātaro vāsavassete,"
    },
    {
      "id": "dn20:12.4",
      "pali": "iddhimanto yasassino."
    },
    {
      "id": "dn20:12.5",
      "pali": "Kālakañcā mahābhismā,"
    },
    {
      "id": "dn20:12.6",
      "pali": "asurā dānaveghasā;"
    },
    {
      "id": "dn20:12.7",
      "pali": "Vepacitti sucitti ca,"
    },
    {
      "id": "dn20:12.8",
      "pali": "pahārādo namucī saha."
    },
    {
      "id": "dn20:12.9",
      "pali": "Satañca baliputtānaṁ,"
    },
    {
      "id": "dn20:12.10",
      "pali": "sabbe verocanāmakā;"
    },
    {
      "id": "dn20:12.11",
      "pali": "Sannayhitvā balisenaṁ,"
    },
    {
      "id": "dn20:12.12",
      "pali": "rāhubhaddamupāgamuṁ;"
    },
    {
      "id": "dn20:12.13",
      "pali": "‘Samayo dāni bhaddante,"
    },
    {
      "id": "dn20:12.14",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ’."
    },
    {
      "id": "dn20:13.1",
      "pali": "Āpo ca devā pathavī,"
    },
    {
      "id": "dn20:13.2",
      "pali": "tejo vāyo tadāgamuṁ;"
    },
    {
      "id": "dn20:13.3",
      "pali": "Varuṇā vāraṇā devā,"
    },
    {
      "id": "dn20:13.4",
      "pali": "somo ca yasasā saha."
    },
    {
      "id": "dn20:13.5",
      "pali": "Mettā karuṇā kāyikā,"
    },
    {
      "id": "dn20:13.6",
      "pali": "āguṁ devā yasassino;"
    },
    {
      "id": "dn20:13.7",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:13.8",
      "pali": "sabbe nānattavaṇṇino."
    },
    {
      "id": "dn20:13.9",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:13.10",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:13.11",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:13.12",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:14.1",
      "pali": "Veṇḍudevā sahali ca,"
    },
    {
      "id": "dn20:14.2",
      "pali": "asamā ca duve yamā;"
    },
    {
      "id": "dn20:14.3",
      "pali": "Candassūpanisā devā,"
    },
    {
      "id": "dn20:14.4",
      "pali": "candamāguṁ purakkhatvā."
    },
    {
      "id": "dn20:14.5",
      "pali": "Sūriyassūpanisā devā,"
    },
    {
      "id": "dn20:14.6",
      "pali": "sūriyamāguṁ purakkhatvā;"
    },
    {
      "id": "dn20:14.7",
      "pali": "Nakkhattāni purakkhatvā,"
    },
    {
      "id": "dn20:14.8",
      "pali": "āguṁ mandavalāhakā."
    },
    {
      "id": "dn20:14.9",
      "pali": "Vasūnaṁ vāsavo seṭṭho,"
    },
    {
      "id": "dn20:14.10",
      "pali": "sakkopāgā purindado;"
    },
    {
      "id": "dn20:14.11",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:14.12",
      "pali": "sabbe nānattavaṇṇino."
    },
    {
      "id": "dn20:14.13",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:14.14",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:14.15",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:14.16",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:15.1",
      "pali": "Athāguṁ sahabhū devā,"
    },
    {
      "id": "dn20:15.2",
      "pali": "jalamaggi sikhāriva;"
    },
    {
      "id": "dn20:15.3",
      "pali": "Ariṭṭhakā ca rojā ca,"
    },
    {
      "id": "dn20:15.4",
      "pali": "umāpupphanibhāsino."
    },
    {
      "id": "dn20:15.5",
      "pali": "Varuṇā sahadhammā ca,"
    },
    {
      "id": "dn20:15.6",
      "pali": "accutā ca anejakā;"
    },
    {
      "id": "dn20:15.7",
      "pali": "Sūleyyarucirā āguṁ,"
    },
    {
      "id": "dn20:15.8",
      "pali": "āguṁ vāsavanesino;"
    },
    {
      "id": "dn20:15.9",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:15.10",
      "pali": "sabbe nānattavaṇṇino."
    },
    {
      "id": "dn20:15.11",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:15.12",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:15.13",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:15.14",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:16.1",
      "pali": "Samānā mahāsamanā,"
    },
    {
      "id": "dn20:16.2",
      "pali": "mānusā mānusuttamā;"
    },
    {
      "id": "dn20:16.3",
      "pali": "Khiḍḍāpadosikā āguṁ,"
    },
    {
      "id": "dn20:16.4",
      "pali": "āguṁ manopadosikā."
    },
    {
      "id": "dn20:16.5",
      "pali": "Athāguṁ harayo devā,"
    },
    {
      "id": "dn20:16.6",
      "pali": "ye ca lohitavāsino;"
    },
    {
      "id": "dn20:16.7",
      "pali": "Pāragā mahāpāragā,"
    },
    {
      "id": "dn20:16.8",
      "pali": "āguṁ devā yasassino;"
    },
    {
      "id": "dn20:16.9",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:16.10",
      "pali": "sabbe nānattavaṇṇino."
    },
    {
      "id": "dn20:16.11",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:16.12",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:16.13",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:16.14",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:17.1",
      "pali": "Sukkā karambhā aruṇā,"
    },
    {
      "id": "dn20:17.2",
      "pali": "āguṁ veghanasā saha;"
    },
    {
      "id": "dn20:17.3",
      "pali": "Odātagayhā pāmokkhā,"
    },
    {
      "id": "dn20:17.4",
      "pali": "āguṁ devā vicakkhaṇā."
    },
    {
      "id": "dn20:17.5",
      "pali": "Sadāmattā hāragajā,"
    },
    {
      "id": "dn20:17.6",
      "pali": "missakā ca yasassino;"
    },
    {
      "id": "dn20:17.7",
      "pali": "Thanayaṁ āga pajjunno,"
    },
    {
      "id": "dn20:17.8",
      "pali": "yo disā abhivassati."
    },
    {
      "id": "dn20:17.9",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:17.10",
      "pali": "sabbe nānattavaṇṇino;"
    },
    {
      "id": "dn20:17.11",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:17.12",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:17.13",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:17.14",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:18.1",
      "pali": "Khemiyā tusitā yāmā,"
    },
    {
      "id": "dn20:18.2",
      "pali": "kaṭṭhakā ca yasassino;"
    },
    {
      "id": "dn20:18.3",
      "pali": "Lambītakā lāmaseṭṭhā,"
    },
    {
      "id": "dn20:18.4",
      "pali": "jotināmā ca āsavā;"
    },
    {
      "id": "dn20:18.5",
      "pali": "Nimmānaratino āguṁ,"
    },
    {
      "id": "dn20:18.6",
      "pali": "athāguṁ paranimmitā."
    },
    {
      "id": "dn20:18.7",
      "pali": "Dasete dasadhā kāyā,"
    },
    {
      "id": "dn20:18.8",
      "pali": "sabbe nānattavaṇṇino;"
    },
    {
      "id": "dn20:18.9",
      "pali": "Iddhimanto jutimanto,"
    },
    {
      "id": "dn20:18.10",
      "pali": "vaṇṇavanto yasassino;"
    },
    {
      "id": "dn20:18.11",
      "pali": "Modamānā abhikkāmuṁ,"
    },
    {
      "id": "dn20:18.12",
      "pali": "bhikkhūnaṁ samitiṁ vanaṁ."
    },
    {
      "id": "dn20:19.1",
      "pali": "Saṭṭhete devanikāyā,"
    },
    {
      "id": "dn20:19.2",
      "pali": "sabbe nānattavaṇṇino;"
    },
    {
      "id": "dn20:19.3",
      "pali": "Nāmanvayena āgacchuṁ,"
    },
    {
      "id": "dn20:19.4",
      "pali": "ye caññe sadisā saha."
    },
    {
      "id": "dn20:19.5",
      "pali": "‘Pavuṭṭhajātimakhilaṁ,"
    },
    {
      "id": "dn20:19.6",
      "pali": "oghatiṇṇamanāsavaṁ;"
    },
    {
      "id": "dn20:19.7",
      "pali": "Dakkhemoghataraṁ nāgaṁ,"
    },
    {
      "id": "dn20:19.8",
      "pali": "candaṁva asitātigaṁ’."
    },
    {
      "id": "dn20:20.1",
      "pali": "Subrahmā paramatto ca,"
    },
    {
      "id": "dn20:20.2",
      "pali": "puttā iddhimato saha;"
    },
    {
      "id": "dn20:20.3",
      "pali": "Sanaṅkumāro tisso ca,"
    },
    {
      "id": "dn20:20.4",
      "pali": "sopāga samitiṁ vanaṁ."
    },
    {
      "id": "dn20:20.5",
      "pali": "Sahassaṁ brahmalokānaṁ,"
    },
    {
      "id": "dn20:20.6",
      "pali": "mahābrahmābhitiṭṭhati;"
    },
    {
      "id": "dn20:20.7",
      "pali": "Upapanno jutimanto,"
    },
    {
      "id": "dn20:20.8",
      "pali": "bhismākāyo yasassiso."
    },
    {
      "id": "dn20:20.9",
      "pali": "Dasettha issarā āguṁ,"
    },
    {
      "id": "dn20:20.10",
      "pali": "paccekavasavattino;"
    },
    {
      "id": "dn20:20.11",
      "pali": "Tesañca majjhato āga,"
    },
    {
      "id": "dn20:20.12",
      "pali": "hārito parivārito."
    },
    {
      "id": "dn20:21.1",
      "pali": "Te ca sabbe abhikkante,"
    },
    {
      "id": "dn20:21.2",
      "pali": "sainde deve sabrahmake;"
    },
    {
      "id": "dn20:21.3",
      "pali": "Mārasenā abhikkāmi,"
    },
    {
      "id": "dn20:21.4",
      "pali": "passa kaṇhassa mandiyaṁ."
    },
    {
      "id": "dn20:21.5",
      "pali": "‘Etha gaṇhatha bandhatha,"
    },
    {
      "id": "dn20:21.6",
      "pali": "rāgena baddhamatthu vo;"
    },
    {
      "id": "dn20:21.7",
      "pali": "Samantā parivāretha,"
    },
    {
      "id": "dn20:21.8",
      "pali": "mā vo muñcittha koci naṁ’."
    },
    {
      "id": "dn20:21.9",
      "pali": "Iti tattha mahāseno,"
    },
    {
      "id": "dn20:21.10",
      "pali": "kaṇho senaṁ apesayi;"
    },
    {
      "id": "dn20:21.11",
      "pali": "Pāṇinā talamāhacca,"
    },
    {
      "id": "dn20:21.12",
      "pali": "saraṁ katvāna bheravaṁ."
    },
    {
      "id": "dn20:21.13",
      "pali": "Yathā pāvussako megho,"
    },
    {
      "id": "dn20:21.14",
      "pali": "thanayanto savijjuko;"
    },
    {
      "id": "dn20:21.15",
      "pali": "Tadā so paccudāvatti,"
    },
    {
      "id": "dn20:21.16",
      "pali": "saṅkuddho asayaṁvase."
    },
    {
      "id": "dn20:22.1",
      "pali": "Tañca sabbaṁ abhiññāya,"
    },
    {
      "id": "dn20:22.2",
      "pali": "vavatthitvāna cakkhumā;"
    },
    {
      "id": "dn20:22.3",
      "pali": "Tato āmantayī satthā,"
    },
    {
      "id": "dn20:22.4",
      "pali": "sāvake sāsane rate."
    },
    {
      "id": "dn20:22.5",
      "pali": "‘Mārasenā abhikkantā,"
    },
    {
      "id": "dn20:22.6",
      "pali": "te vijānātha bhikkhavo’;"
    },
    {
      "id": "dn20:22.7",
      "pali": "Te ca ātappamakaruṁ,"
    },
    {
      "id": "dn20:22.8",
      "pali": "sutvā buddhassa sāsanaṁ;"
    },
    {
      "id": "dn20:22.9",
      "pali": "Vītarāgehi pakkāmuṁ,"
    },
    {
      "id": "dn20:22.10",
      "pali": "nesaṁ lomāpi iñjayuṁ."
    },
    {
      "id": "dn20:22.11",
      "pali": "‘Sabbe vijitasaṅgāmā,"
    },
    {
      "id": "dn20:22.12",
      "pali": "bhayātītā yasassino;"
    },
    {
      "id": "dn20:22.13",
      "pali": "Modanti saha bhūtehi,"
    },
    {
      "id": "dn20:22.14",
      "pali": "sāvakā te janesutā’”ti."
    },
    {
      "id": "dn20:22.15",
      "pali": "Mahāsamayasuttaṁ niṭṭhitaṁ sattamaṁ."
    }
  ]
}
