{
  "uid": "tha-ap133",
  "title": "Sobhitattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap133:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap133:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap133:1.3",
      "pali": "Mahato janakāyassa,"
    },
    {
      "id": "tha-ap133:1.4",
      "pali": "deseti amataṁ padaṁ."
    },
    {
      "id": "tha-ap133:2.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap133:2.2",
      "pali": "vācāsabhimudīritaṁ;"
    },
    {
      "id": "tha-ap133:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap133:2.4",
      "pali": "ekaggo āsahaṁ tadā."
    },
    {
      "id": "tha-ap133:3.1",
      "pali": "‘Yathā samuddo udadhīnamaggo,"
    },
    {
      "id": "tha-ap133:3.2",
      "pali": "Nerū nagānaṁ pavaro siluccayo;"
    },
    {
      "id": "tha-ap133:3.3",
      "pali": "Tatheva ye cittavasena vattare’,"
    },
    {
      "id": "tha-ap133:3.4",
      "pali": "Na buddhañāṇassa kalaṁ upenti te."
    },
    {
      "id": "tha-ap133:4.1",
      "pali": "Dhammavidhiṁ ṭhapetvāna,"
    },
    {
      "id": "tha-ap133:4.2",
      "pali": "buddho kāruṇiko isi;"
    },
    {
      "id": "tha-ap133:4.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap133:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap133:5.1",
      "pali": "‘Yo so ñāṇaṁ pakittesi,"
    },
    {
      "id": "tha-ap133:5.2",
      "pali": "buddhamhi lokanāyake;"
    },
    {
      "id": "tha-ap133:5.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap133:5.4",
      "pali": "duggatiṁ na gamissati."
    },
    {
      "id": "tha-ap133:6.1",
      "pali": "Kilese jhāpayitvāna,"
    },
    {
      "id": "tha-ap133:6.2",
      "pali": "ekaggo susamāhito;"
    },
    {
      "id": "tha-ap133:6.3",
      "pali": "Sobhito nāma nāmena,"
    },
    {
      "id": "tha-ap133:6.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap133:7.1",
      "pali": "Paññāse kappasahasse,"
    },
    {
      "id": "tha-ap133:7.2",
      "pali": "sattevāsuṁ yasuggatā;"
    },
    {
      "id": "tha-ap133:7.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap133:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap133:8.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap133:8.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap133:8.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap133:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap133:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap133:9.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap133:9.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap133:9.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap133:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā sobhito thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap133:11.1",
      "pali": "Sobhitattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
