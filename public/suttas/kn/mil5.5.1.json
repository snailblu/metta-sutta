{
  "uid": "mil5.5.1",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil5.5.1:1.1",
      "pali": "“Bhante nāgasena, bhāsitampetaṁ bhagavatā—"
    },
    {
      "id": "mil5.5.1:2.1",
      "pali": "‘Santhavato bhayaṁ jātaṁ,"
    },
    {
      "id": "mil5.5.1:2.2",
      "pali": "niketā jāyate rajo;"
    },
    {
      "id": "mil5.5.1:2.3",
      "pali": "Aniketamasanthavaṁ,"
    },
    {
      "id": "mil5.5.1:2.4",
      "pali": "etaṁ ve munidassanan’ti."
    },
    {
      "id": "mil5.5.1:3.1",
      "pali": "Puna ca bhagavatā bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:3.2",
      "pali": "‘vihāre kāraye ramme, vāsayettha bahussute’ti."
    },
    {
      "id": "mil5.5.1:3.3",
      "pali": "Yadi, bhante nāgasena, tathāgatena bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:3.4",
      "pali": "‘santhavato bhayaṁ jātaṁ, niketā jāyate rajo."
    },
    {
      "id": "mil5.5.1:3.5",
      "pali": "Aniketamasanthavaṁ, etaṁ ve munidassanan’ti, tena hi ‘vihāre kāraye ramme, vāsayettha bahussute’ti yaṁ vacanaṁ, taṁ micchā."
    },
    {
      "id": "mil5.5.1:3.6",
      "pali": "Yadi tathāgatena bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:3.7",
      "pali": "‘vihāre kāraye ramme, vāsayettha bahussute’ti, tena hi ‘santhavato bhayaṁ jātaṁ, niketā jāyate rajo."
    },
    {
      "id": "mil5.5.1:3.8",
      "pali": "Aniketamasanthavaṁ, etaṁ ve munidassanan’ti tampi vacanaṁ micchā."
    },
    {
      "id": "mil5.5.1:3.9",
      "pali": "Ayampi ubhato koṭiko pañho tavānuppatto, so tayā nibbāhitabbo”ti."
    },
    {
      "id": "mil5.5.1:4.1",
      "pali": "“Bhāsitampetaṁ, mahārāja, bhagavatā—"
    },
    {
      "id": "mil5.5.1:4.2",
      "pali": "‘santhavato bhayaṁ jātaṁ, niketā jāyate rajo."
    },
    {
      "id": "mil5.5.1:4.3",
      "pali": "Aniketamasanthavaṁ, etaṁ ve munidassanan’ti."
    },
    {
      "id": "mil5.5.1:4.4",
      "pali": "Bhaṇitañca—"
    },
    {
      "id": "mil5.5.1:4.5",
      "pali": "‘vihāre kāraye ramme, vāsayettha bahussute’ti."
    },
    {
      "id": "mil5.5.1:4.6",
      "pali": "Yaṁ, mahārāja, bhagavatā bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:4.7",
      "pali": "‘santhavato bhayaṁ jātaṁ, niketā jāyate rajo."
    },
    {
      "id": "mil5.5.1:4.8",
      "pali": "Aniketamasanthavaṁ, etaṁ ve munidassanan’ti, taṁ sabhāvavacanaṁ asesavacanaṁ nissesavacanaṁ nippariyāyavacanaṁ samaṇānucchavaṁ samaṇasāruppaṁ samaṇappatirūpaṁ samaṇārahaṁ samaṇagocaraṁ samaṇappaṭipadā samaṇappaṭipatti."
    },
    {
      "id": "mil5.5.1:4.9",
      "pali": "Yathā, mahārāja, āraññako migo araññe pavane caramāno nirālayo aniketo yathicchakaṁ sayati;"
    },
    {
      "id": "mil5.5.1:4.10",
      "pali": "evameva kho, mahārāja, bhikkhunā ‘santhavato bhayaṁ jātaṁ, niketā jāyate rajo."
    },
    {
      "id": "mil5.5.1:4.11",
      "pali": "Aniketamasanthavaṁ, etaṁ ve munidassanan’ti cintetabbaṁ."
    },
    {
      "id": "mil5.5.1:5.1",
      "pali": "Yaṁ pana, mahārāja, bhagavatā bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:5.2",
      "pali": "‘vihāre kāraye ramme, vāsayettha bahussute’ti, taṁ dve atthavase sampassamānena bhagavatā bhaṇitaṁ."
    },
    {
      "id": "mil5.5.1:5.3",
      "pali": "Katame dve?"
    },
    {
      "id": "mil5.5.1:5.4",
      "pali": "Vihāradānaṁ nāma sabbabuddhehi vaṇṇitaṁ anumataṁ thomitaṁ pasatthaṁ, taṁ te vihāradānaṁ datvā jātijarāmaraṇā parimuccissantīti."
    },
    {
      "id": "mil5.5.1:5.5",
      "pali": "Ayaṁ tāva paṭhamo ānisaṁso vihāradāne."
    },
    {
      "id": "mil5.5.1:6.1",
      "pali": "Puna caparaṁ vihāre vijjamāne bhikkhuniyo byattasaṅketā bhavissanti, sulabhaṁ dassanaṁ dassanakāmānaṁ, anikete duddassanā bhavissantīti."
    },
    {
      "id": "mil5.5.1:6.2",
      "pali": "Ayaṁ dutiyo ānisaṁso vihāradāne."
    },
    {
      "id": "mil5.5.1:6.3",
      "pali": "Ime dve atthavase sampassamānena bhagavatā bhaṇitaṁ—"
    },
    {
      "id": "mil5.5.1:6.4",
      "pali": "‘vihāre kāraye ramme, vāsayettha bahussute’ti, na tattha buddhaputtena ālayo karaṇīyo nikete”ti."
    },
    {
      "id": "mil5.5.1:6.5",
      "pali": "“Sādhu, bhante nāgasena, evametaṁ tathā sampaṭicchāmī”ti."
    },
    {
      "id": "mil5.5.1:7.1",
      "pali": "Santhavapañho paṭhamo."
    }
  ]
}
