{
  "uid": "tha-ap60",
  "title": "Dhajadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap60:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap60:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap60:1.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap60:1.4",
      "pali": "dhajamāropayiṁ ahaṁ."
    },
    {
      "id": "tha-ap60:2.1",
      "pali": "Patitapattāni gaṇhitvā,"
    },
    {
      "id": "tha-ap60:2.2",
      "pali": "bahiddhā chaḍḍayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap60:2.3",
      "pali": "Antosuddhaṁ bahisuddhaṁ,"
    },
    {
      "id": "tha-ap60:2.4",
      "pali": "adhimuttamanāsavaṁ."
    },
    {
      "id": "tha-ap60:3.1",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap60:3.2",
      "pali": "avandiṁ bodhimuttamaṁ;"
    },
    {
      "id": "tha-ap60:3.3",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap60:3.4",
      "pali": "āhutīnaṁ paṭiggaho."
    },
    {
      "id": "tha-ap60:4.1",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap60:4.2",
      "pali": "imā gāthā abhāsatha;"
    },
    {
      "id": "tha-ap60:4.3",
      "pali": "‘Iminā dhajadānena,"
    },
    {
      "id": "tha-ap60:4.4",
      "pali": "upaṭṭhānena cūbhayaṁ."
    },
    {
      "id": "tha-ap60:5.1",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap60:5.2",
      "pali": "duggatiṁ so na gacchati;"
    },
    {
      "id": "tha-ap60:5.3",
      "pali": "Devesu devasobhagyaṁ,"
    },
    {
      "id": "tha-ap60:5.4",
      "pali": "anubhossatinappakaṁ."
    },
    {
      "id": "tha-ap60:6.1",
      "pali": "Anekasatakkhattuñca,"
    },
    {
      "id": "tha-ap60:6.2",
      "pali": "rājā raṭṭhe bhavissati;"
    },
    {
      "id": "tha-ap60:6.3",
      "pali": "Uggato nāma nāmena,"
    },
    {
      "id": "tha-ap60:6.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap60:7.1",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "tha-ap60:7.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap60:7.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap60:7.4",
      "pali": "sāsanebhiramissati’."
    },
    {
      "id": "tha-ap60:8.1",
      "pali": "Padhānapahitattomhi,"
    },
    {
      "id": "tha-ap60:8.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap60:8.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap60:8.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap60:9.1",
      "pali": "Ekapaññāsasahasse,"
    },
    {
      "id": "tha-ap60:9.2",
      "pali": "kappe uggatasavhayo;"
    },
    {
      "id": "tha-ap60:9.3",
      "pali": "Paññāsasatasahasse,"
    },
    {
      "id": "tha-ap60:9.4",
      "pali": "khattiyo meghasavhayo."
    },
    {
      "id": "tha-ap60:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap60:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap60:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap60:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhajadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap60:12.1",
      "pali": "Dhajadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
