{
  "uid": "snp2.13",
  "title": "Sammāparibbājanīyasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.13:1.1",
      "pali": "“Pucchāmi muniṁ pahūtapaññaṁ,"
    },
    {
      "id": "snp2.13:1.2",
      "pali": "Tiṇṇaṁ pāraṅgataṁ parinibbutaṁ ṭhitattaṁ;"
    },
    {
      "id": "snp2.13:1.3",
      "pali": "Nikkhamma gharā panujja kāme,"
    },
    {
      "id": "snp2.13:1.4",
      "pali": "Kathaṁ bhikkhu sammā so loke paribbajeyya”."
    },
    {
      "id": "snp2.13:2.1",
      "pali": "“Yassa maṅgalā samūhatā,"
    },
    {
      "id": "snp2.13:2.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp2.13:2.3",
      "pali": "Uppātā supinā ca lakkhaṇā ca;"
    },
    {
      "id": "snp2.13:2.4",
      "pali": "So maṅgaladosavippahīno,"
    },
    {
      "id": "snp2.13:2.5",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:3.1",
      "pali": "Rāgaṁ vinayetha mānusesu,"
    },
    {
      "id": "snp2.13:3.2",
      "pali": "Dibbesu kāmesu cāpi bhikkhu;"
    },
    {
      "id": "snp2.13:3.3",
      "pali": "Atikkamma bhavaṁ samecca dhammaṁ,"
    },
    {
      "id": "snp2.13:3.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:4.1",
      "pali": "Vipiṭṭhikatvāna pesuṇāni,"
    },
    {
      "id": "snp2.13:4.2",
      "pali": "Kodhaṁ kadarīyaṁ jaheyya bhikkhu;"
    },
    {
      "id": "snp2.13:4.3",
      "pali": "Anurodhavirodhavippahīno,"
    },
    {
      "id": "snp2.13:4.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:5.1",
      "pali": "Hitvāna piyañca appiyañca,"
    },
    {
      "id": "snp2.13:5.2",
      "pali": "Anupādāya anissito kuhiñci;"
    },
    {
      "id": "snp2.13:5.3",
      "pali": "Saṁyojaniyehi vippamutto,"
    },
    {
      "id": "snp2.13:5.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:6.1",
      "pali": "Na so upadhīsu sārameti,"
    },
    {
      "id": "snp2.13:6.2",
      "pali": "Ādānesu vineyya chandarāgaṁ;"
    },
    {
      "id": "snp2.13:6.3",
      "pali": "So anissito anaññaneyyo,"
    },
    {
      "id": "snp2.13:6.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:7.1",
      "pali": "Vacasā manasā ca kammunā ca,"
    },
    {
      "id": "snp2.13:7.2",
      "pali": "Aviruddho sammā viditvā dhammaṁ;"
    },
    {
      "id": "snp2.13:7.3",
      "pali": "Nibbānapadābhipatthayāno,"
    },
    {
      "id": "snp2.13:7.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:8.1",
      "pali": "Yo vandati manti nunnameyya,"
    },
    {
      "id": "snp2.13:8.2",
      "pali": "Akkuṭṭhopi na sandhiyetha bhikkhu;"
    },
    {
      "id": "snp2.13:8.3",
      "pali": "Laddhā parabhojanaṁ na majje,"
    },
    {
      "id": "snp2.13:8.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:9.1",
      "pali": "Lobhañca bhavañca vippahāya,"
    },
    {
      "id": "snp2.13:9.2",
      "pali": "Virato chedanabandhanā ca bhikkhu;"
    },
    {
      "id": "snp2.13:9.3",
      "pali": "So tiṇṇakathaṅkatho visallo,"
    },
    {
      "id": "snp2.13:9.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:10.1",
      "pali": "Sāruppaṁ attano viditvā,"
    },
    {
      "id": "snp2.13:10.2",
      "pali": "No ca bhikkhu hiṁseyya kañci loke;"
    },
    {
      "id": "snp2.13:10.3",
      "pali": "Yathātathiyaṁ viditvā dhammaṁ,"
    },
    {
      "id": "snp2.13:10.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:11.1",
      "pali": "Yassānusayā na santi keci,"
    },
    {
      "id": "snp2.13:11.2",
      "pali": "Mūlā ca akusalā samūhatāse;"
    },
    {
      "id": "snp2.13:11.3",
      "pali": "So nirāso anāsisāno,"
    },
    {
      "id": "snp2.13:11.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:12.1",
      "pali": "Āsavakhīṇo pahīnamāno,"
    },
    {
      "id": "snp2.13:12.2",
      "pali": "Sabbaṁ rāgapathaṁ upātivatto;"
    },
    {
      "id": "snp2.13:12.3",
      "pali": "Danto parinibbuto ṭhitatto,"
    },
    {
      "id": "snp2.13:12.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:13.1",
      "pali": "Saddho sutavā niyāmadassī,"
    },
    {
      "id": "snp2.13:13.2",
      "pali": "Vaggagatesu na vaggasāri dhīro;"
    },
    {
      "id": "snp2.13:13.3",
      "pali": "Lobhaṁ dosaṁ vineyya paṭighaṁ,"
    },
    {
      "id": "snp2.13:13.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:14.1",
      "pali": "Saṁsuddhajino vivaṭṭacchado,"
    },
    {
      "id": "snp2.13:14.2",
      "pali": "Dhammesu vasī pāragū anejo;"
    },
    {
      "id": "snp2.13:14.3",
      "pali": "Saṅkhāranirodhañāṇakusalo,"
    },
    {
      "id": "snp2.13:14.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:15.1",
      "pali": "Atītesu anāgatesu cāpi,"
    },
    {
      "id": "snp2.13:15.2",
      "pali": "Kappātīto aticcasuddhipañño;"
    },
    {
      "id": "snp2.13:15.3",
      "pali": "Sabbāyatanehi vippamutto,"
    },
    {
      "id": "snp2.13:15.4",
      "pali": "Sammā so loke paribbajeyya."
    },
    {
      "id": "snp2.13:16.1",
      "pali": "Aññāya padaṁ samecca dhammaṁ,"
    },
    {
      "id": "snp2.13:16.2",
      "pali": "Vivaṭaṁ disvāna pahānamāsavānaṁ;"
    },
    {
      "id": "snp2.13:16.3",
      "pali": "Sabbupadhīnaṁ parikkhayāno,"
    },
    {
      "id": "snp2.13:16.4",
      "pali": "Sammā so loke paribbajeyya”."
    },
    {
      "id": "snp2.13:17.1",
      "pali": "“Addhā hi bhagavā tatheva etaṁ,"
    },
    {
      "id": "snp2.13:17.2",
      "pali": "Yo so evaṁvihārī danto bhikkhu;"
    },
    {
      "id": "snp2.13:17.3",
      "pali": "Sabbasaṁyojanayogavītivatto,"
    },
    {
      "id": "snp2.13:17.4",
      "pali": "Sammā so loke paribbajeyyā”ti."
    },
    {
      "id": "snp2.13:17.5",
      "pali": "Sammāparibbājanīyasuttaṁ terasamaṁ."
    }
  ]
}
