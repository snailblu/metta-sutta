{
  "uid": "ja277",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja277:1.1",
      "pali": "“Vassāni paññāsa samādhikāni,"
    },
    {
      "id": "ja277:1.2",
      "pali": "Vasimha selassa guhāya romaka;"
    },
    {
      "id": "ja277:1.3",
      "pali": "Asaṅkamānā abhinibbutattā,"
    },
    {
      "id": "ja277:1.4",
      "pali": "Hatthattamāyanti mamaṇḍajā pure."
    },
    {
      "id": "ja277:2.1",
      "pali": "Te dāni vakkaṅga kimatthamussukā,"
    },
    {
      "id": "ja277:2.2",
      "pali": "Bhajanti aññaṁ girikandaraṁ dijā;"
    },
    {
      "id": "ja277:2.3",
      "pali": "Na nūna maññanti mamaṁ yathā pure,"
    },
    {
      "id": "ja277:2.4",
      "pali": "Cirappavutthā atha vā na te ime”."
    },
    {
      "id": "ja277:3.1",
      "pali": "“Jānāma taṁ na mayaṁ sampamūḷhā,"
    },
    {
      "id": "ja277:3.2",
      "pali": "Soyeva tvaṁ te mayamasma nāññe;"
    },
    {
      "id": "ja277:3.3",
      "pali": "Cittañca te asmiṁ jane paduṭṭhaṁ,"
    },
    {
      "id": "ja277:3.4",
      "pali": "Ājīvikā tena tamuttasāmā”ti."
    },
    {
      "id": "ja277:4.1",
      "pali": "Romakajātakaṁ sattamaṁ."
    }
  ]
}
