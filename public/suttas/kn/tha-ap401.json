{
  "uid": "tha-ap401",
  "title": "Sabbadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap401:1.1",
      "pali": "“Mahāsamuddaṁ ogayha,"
    },
    {
      "id": "tha-ap401:1.2",
      "pali": "bhavanaṁ me sunimmitaṁ;"
    },
    {
      "id": "tha-ap401:1.3",
      "pali": "Sunimmitā pokkharaṇī,"
    },
    {
      "id": "tha-ap401:1.4",
      "pali": "cakkavākapakūjitā."
    },
    {
      "id": "tha-ap401:2.1",
      "pali": "Mandālakehi sañchannā,"
    },
    {
      "id": "tha-ap401:2.2",
      "pali": "padumuppalakehi ca;"
    },
    {
      "id": "tha-ap401:2.3",
      "pali": "Nadī ca sandate tattha,"
    },
    {
      "id": "tha-ap401:2.4",
      "pali": "supatitthā manoramā."
    },
    {
      "id": "tha-ap401:3.1",
      "pali": "Macchakacchapasañchannā,"
    },
    {
      "id": "tha-ap401:3.2",
      "pali": "nānādijasamotthatā;"
    },
    {
      "id": "tha-ap401:3.3",
      "pali": "Mayūrakoñcābhirudā,"
    },
    {
      "id": "tha-ap401:3.4",
      "pali": "kokilādīhi vagguhi."
    },
    {
      "id": "tha-ap401:4.1",
      "pali": "Pārevatā ravihaṁsā ca,"
    },
    {
      "id": "tha-ap401:4.2",
      "pali": "cakkavākā nadīcarā;"
    },
    {
      "id": "tha-ap401:4.3",
      "pali": "Dindibhā sāḷikā cettha,"
    },
    {
      "id": "tha-ap401:4.4",
      "pali": "pampakā jīvajīvakā."
    },
    {
      "id": "tha-ap401:5.1",
      "pali": "Haṁsā koñcāpi naditā,"
    },
    {
      "id": "tha-ap401:5.2",
      "pali": "kosiyā piṅgalā bahū;"
    },
    {
      "id": "tha-ap401:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap401:5.4",
      "pali": "maṇimuttikavālukā."
    },
    {
      "id": "tha-ap401:6.1",
      "pali": "Sabbasoṇṇamayā rukkhā,"
    },
    {
      "id": "tha-ap401:6.2",
      "pali": "nānāgandhasameritā;"
    },
    {
      "id": "tha-ap401:6.3",
      "pali": "Ujjotenti divārattiṁ,"
    },
    {
      "id": "tha-ap401:6.4",
      "pali": "bhavanaṁ sabbakālikaṁ."
    },
    {
      "id": "tha-ap401:7.1",
      "pali": "Saṭṭhi tūriyasahassāni,"
    },
    {
      "id": "tha-ap401:7.2",
      "pali": "sāyaṁ pāto pavajjare;"
    },
    {
      "id": "tha-ap401:7.3",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "tha-ap401:7.4",
      "pali": "parivārenti maṁ sadā."
    },
    {
      "id": "tha-ap401:8.1",
      "pali": "Abhinikkhamma bhavanā,"
    },
    {
      "id": "tha-ap401:8.2",
      "pali": "sumedhaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap401:8.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap401:8.4",
      "pali": "vandayiṁ taṁ mahāyasaṁ."
    },
    {
      "id": "tha-ap401:9.1",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap401:9.2",
      "pali": "sasaṅghaṁ taṁ nimantayiṁ;"
    },
    {
      "id": "tha-ap401:9.3",
      "pali": "Adhivāsesi so dhīro,"
    },
    {
      "id": "tha-ap401:9.4",
      "pali": "sumedho lokanāyako."
    },
    {
      "id": "tha-ap401:10.1",
      "pali": "Mama dhammakathaṁ katvā,"
    },
    {
      "id": "tha-ap401:10.2",
      "pali": "uyyojesi mahāmuni;"
    },
    {
      "id": "tha-ap401:10.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap401:10.4",
      "pali": "bhavanaṁ me upāgamiṁ."
    },
    {
      "id": "tha-ap401:11.1",
      "pali": "Āmantayiṁ parijanaṁ,"
    },
    {
      "id": "tha-ap401:11.2",
      "pali": "‘sabbe sannipatātha vo;"
    },
    {
      "id": "tha-ap401:11.3",
      "pali": "Pubbaṇhasamayaṁ buddho,"
    },
    {
      "id": "tha-ap401:11.4",
      "pali": "bhavanaṁ āgamissati."
    },
    {
      "id": "tha-ap401:12.1",
      "pali": "Lābhā amhaṁ suladdhaṁ no,"
    },
    {
      "id": "tha-ap401:12.2",
      "pali": "ye vasāma tavantike;"
    },
    {
      "id": "tha-ap401:12.3",
      "pali": "Mayampi buddhaseṭṭhassa,"
    },
    {
      "id": "tha-ap401:12.4",
      "pali": "pūjaṁ kassāma satthuno’."
    },
    {
      "id": "tha-ap401:13.1",
      "pali": "Annapānaṁ paṭṭhapetvā,"
    },
    {
      "id": "tha-ap401:13.2",
      "pali": "kālaṁ ārocayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap401:13.3",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap401:13.4",
      "pali": "upesi lokanāyako."
    },
    {
      "id": "tha-ap401:14.1",
      "pali": "Pañcaṅgikehi tūriyehi,"
    },
    {
      "id": "tha-ap401:14.2",
      "pali": "paccuggamanamakāsahaṁ;"
    },
    {
      "id": "tha-ap401:14.3",
      "pali": "Sabbasoṇṇamaye pīṭhe,"
    },
    {
      "id": "tha-ap401:14.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap401:15.1",
      "pali": "Uparicchadanaṁ āsi,"
    },
    {
      "id": "tha-ap401:15.2",
      "pali": "sabbasoṇṇamayaṁ tadā;"
    },
    {
      "id": "tha-ap401:15.3",
      "pali": "Bījaniyo pavāyanti,"
    },
    {
      "id": "tha-ap401:15.4",
      "pali": "bhikkhusaṅghassa antare."
    },
    {
      "id": "tha-ap401:16.1",
      "pali": "Pahūtenannapānena,"
    },
    {
      "id": "tha-ap401:16.2",
      "pali": "bhikkhusaṅghamatappayiṁ;"
    },
    {
      "id": "tha-ap401:16.3",
      "pali": "Paccekadussayugaḷe,"
    },
    {
      "id": "tha-ap401:16.4",
      "pali": "bhikkhusaṅghassadāsahaṁ."
    },
    {
      "id": "tha-ap401:17.1",
      "pali": "Yaṁ vadanti sumedhoti,"
    },
    {
      "id": "tha-ap401:17.2",
      "pali": "lokāhutipaṭiggahaṁ;"
    },
    {
      "id": "tha-ap401:17.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap401:17.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap401:18.1",
      "pali": "‘Yo me annena pānena,"
    },
    {
      "id": "tha-ap401:18.2",
      "pali": "sabbe ime ca tappayiṁ;"
    },
    {
      "id": "tha-ap401:18.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap401:18.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap401:19.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap401:19.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap401:19.3",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap401:19.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap401:20.1",
      "pali": "Upapajjati yaṁ yoniṁ,"
    },
    {
      "id": "tha-ap401:20.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap401:20.3",
      "pali": "Sabbadā sabbasovaṇṇaṁ,"
    },
    {
      "id": "tha-ap401:20.4",
      "pali": "chadanaṁ dhārayissati."
    },
    {
      "id": "tha-ap401:21.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap401:21.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap401:21.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap401:21.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap401:22.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap401:22.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap401:22.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap401:22.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap401:23.1",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap401:23.2",
      "pali": "sīhanādaṁ nadissati;"
    },
    {
      "id": "tha-ap401:23.3",
      "pali": "Citake chattaṁ dhārenti,"
    },
    {
      "id": "tha-ap401:23.4",
      "pali": "heṭṭhā chattamhi ḍayhatha’."
    },
    {
      "id": "tha-ap401:24.1",
      "pali": "Sāmaññaṁ me anuppattaṁ,"
    },
    {
      "id": "tha-ap401:24.2",
      "pali": "kilesā jhāpitā mayā;"
    },
    {
      "id": "tha-ap401:24.3",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "tha-ap401:24.4",
      "pali": "santāpo me na vijjati."
    },
    {
      "id": "tha-ap401:25.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap401:25.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap401:25.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap401:25.4",
      "pali": "sabbadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap401:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap401:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap401:26.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap401:27.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap401:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap401:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap401:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap401:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap401:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap401:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā sabbadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap401:30.1",
      "pali": "Sabbadāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
