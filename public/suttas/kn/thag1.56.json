{
  "uid": "thag1.56",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.56:1.1",
      "pali": "“Ko kuṭikāyaṁ bhikkhu kuṭikāyaṁ,"
    },
    {
      "id": "thag1.56:1.2",
      "pali": "Vītarāgo susamāhitacitto;"
    },
    {
      "id": "thag1.56:1.3",
      "pali": "Evaṁ jānāhi āvuso,"
    },
    {
      "id": "thag1.56:1.4",
      "pali": "Amoghā te kuṭikā katā”ti."
    },
    {
      "id": "thag1.56:1.5",
      "pali": "… Kuṭivihāritthero …."
    }
  ]
}
