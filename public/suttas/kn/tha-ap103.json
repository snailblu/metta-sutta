{
  "uid": "tha-ap103",
  "title": "1 Bhikkhadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap103:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap103:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap103:1.3",
      "pali": "Pavarā abhinikkhantaṁ,"
    },
    {
      "id": "tha-ap103:1.4",
      "pali": "Vanā nibbanamāgataṁ."
    },
    {
      "id": "tha-ap103:2.1",
      "pali": "Kaṭacchubhikkhaṁ pādāsiṁ,"
    },
    {
      "id": "tha-ap103:2.2",
      "pali": "siddhatthassa mahesino;"
    },
    {
      "id": "tha-ap103:2.3",
      "pali": "Paññāya upasantassa,"
    },
    {
      "id": "tha-ap103:2.4",
      "pali": "mahāvīrassa tādino."
    },
    {
      "id": "tha-ap103:3.1",
      "pali": "Padenānupadāyantaṁ,"
    },
    {
      "id": "tha-ap103:3.2",
      "pali": "nibbāpente mahājanaṁ;"
    },
    {
      "id": "tha-ap103:3.3",
      "pali": "Uḷārā vitti me jātā,"
    },
    {
      "id": "tha-ap103:3.4",
      "pali": "buddhe ādiccabandhune."
    },
    {
      "id": "tha-ap103:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap103:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap103:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap103:4.4",
      "pali": "bhikkhādānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap103:5.1",
      "pali": "Sattāsītimhito kappe,"
    },
    {
      "id": "tha-ap103:5.2",
      "pali": "mahāreṇu sanāmakā;"
    },
    {
      "id": "tha-ap103:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap103:5.4",
      "pali": "sattete cakkavattino."
    },
    {
      "id": "tha-ap103:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap103:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap103:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap103:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap103:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhikkhadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap103:8.1",
      "pali": "Bhikkhadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
