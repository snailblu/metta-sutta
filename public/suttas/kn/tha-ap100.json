{
  "uid": "tha-ap100",
  "title": "Senāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap100:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap100:1.2",
      "pali": "adāsiṁ paṇṇasantharaṁ;"
    },
    {
      "id": "tha-ap100:1.3",
      "pali": "Samantā upahārañca,"
    },
    {
      "id": "tha-ap100:1.4",
      "pali": "kusumaṁ okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap100:2.1",
      "pali": "Pāsādevaṁ guṇaṁ rammaṁ,"
    },
    {
      "id": "tha-ap100:2.2",
      "pali": "Anubhomi mahārahaṁ;"
    },
    {
      "id": "tha-ap100:2.3",
      "pali": "Mahagghāni ca pupphāni,"
    },
    {
      "id": "tha-ap100:2.4",
      "pali": "Sayanebhisavanti me."
    },
    {
      "id": "tha-ap100:3.1",
      "pali": "Sayanehaṁ tuvaṭṭāmi,"
    },
    {
      "id": "tha-ap100:3.2",
      "pali": "vicitte pupphasanthate;"
    },
    {
      "id": "tha-ap100:3.3",
      "pali": "Pupphavuṭṭhi ca sayane,"
    },
    {
      "id": "tha-ap100:3.4",
      "pali": "abhivassati tāvade."
    },
    {
      "id": "tha-ap100:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap100:4.2",
      "pali": "adāsiṁ paṇṇasantharaṁ;"
    },
    {
      "id": "tha-ap100:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap100:4.4",
      "pali": "santharassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap100:5.1",
      "pali": "Tiṇasantharakā nāma,"
    },
    {
      "id": "tha-ap100:5.2",
      "pali": "sattete cakkavattino;"
    },
    {
      "id": "tha-ap100:5.3",
      "pali": "Ito te pañcame kappe,"
    },
    {
      "id": "tha-ap100:5.4",
      "pali": "uppajjiṁsu janādhipā."
    },
    {
      "id": "tha-ap100:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap100:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap100:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap100:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā senāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap100:8.1",
      "pali": "Senāsanadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
