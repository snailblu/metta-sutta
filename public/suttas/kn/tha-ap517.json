{
  "uid": "tha-ap517",
  "title": "Nāgapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap517:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap517:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap517:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap517:1.4",
      "pali": "Nāgapupphaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap517:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap517:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap517:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap517:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap517:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap517:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap517:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap517:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap517:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap517:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap517:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap517:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap517:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap517:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāgapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap517:7.1",
      "pali": "Nāgapupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
