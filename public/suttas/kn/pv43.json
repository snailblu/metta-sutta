{
  "uid": "pv43",
  "title": "8. Gūthakhādakapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv43:1.1",
      "pali": "“Gūthakūpato uggantvā,"
    },
    {
      "id": "pv43:1.2",
      "pali": "ko nu dīno patiṭṭhasi;"
    },
    {
      "id": "pv43:1.3",
      "pali": "Nissaṁsayaṁ pāpakammanto,"
    },
    {
      "id": "pv43:1.4",
      "pali": "kiṁ nu saddahase tuvan”ti."
    },
    {
      "id": "pv43:2.1",
      "pali": "“Ahaṁ bhadante petomhi,"
    },
    {
      "id": "pv43:2.2",
      "pali": "duggato yamalokiko;"
    },
    {
      "id": "pv43:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv43:2.4",
      "pali": "petalokaṁ ito gato”."
    },
    {
      "id": "pv43:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv43:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv43:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv43:3.4",
      "pali": "idaṁ dukkhaṁ nigacchasī”ti."
    },
    {
      "id": "pv43:4.1",
      "pali": "“Ahu āvāsiko mayhaṁ,"
    },
    {
      "id": "pv43:4.2",
      "pali": "issukī kulamaccharī;"
    },
    {
      "id": "pv43:4.3",
      "pali": "Ajjhāsito mayhaṁ ghare,"
    },
    {
      "id": "pv43:4.4",
      "pali": "kadariyo paribhāsako."
    },
    {
      "id": "pv43:5.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "pv43:5.2",
      "pali": "bhikkhavo paribhāsisaṁ;"
    },
    {
      "id": "pv43:5.3",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv43:5.4",
      "pali": "petalokaṁ ito gato”ti."
    },
    {
      "id": "pv43:6.1",
      "pali": "“Amitto mittavaṇṇena,"
    },
    {
      "id": "pv43:6.2",
      "pali": "yo te āsi kulūpako;"
    },
    {
      "id": "pv43:6.3",
      "pali": "Kāyassa bhedā duppañño,"
    },
    {
      "id": "pv43:6.4",
      "pali": "kiṁ nu pecca gatiṁ gato”ti."
    },
    {
      "id": "pv43:7.1",
      "pali": "“Tassevāhaṁ pāpakammassa,"
    },
    {
      "id": "pv43:7.2",
      "pali": "sīse tiṭṭhāmi matthake;"
    },
    {
      "id": "pv43:7.3",
      "pali": "So ca paravisayaṁ patto,"
    },
    {
      "id": "pv43:7.4",
      "pali": "mameva paricārako."
    },
    {
      "id": "pv43:8.1",
      "pali": "Yaṁ bhadante hadantaññe,"
    },
    {
      "id": "pv43:8.2",
      "pali": "etaṁ me hoti bhojanaṁ;"
    },
    {
      "id": "pv43:8.3",
      "pali": "Ahañca kho yaṁ hadāmi,"
    },
    {
      "id": "pv43:8.4",
      "pali": "etaṁ so upajīvatī”ti."
    },
    {
      "id": "pv43:9.1",
      "pali": "Gūthakhādakapetavatthu aṭṭhamaṁ."
    }
  ]
}
