{
  "uid": "ja235",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja235:1.1",
      "pali": "“Sukhā gharā vacchanakha,"
    },
    {
      "id": "ja235:1.2",
      "pali": "sahiraññā sabhojanā;"
    },
    {
      "id": "ja235:1.3",
      "pali": "Yattha bhutvā pivitvā ca,"
    },
    {
      "id": "ja235:1.4",
      "pali": "sayeyyātha anussuko”."
    },
    {
      "id": "ja235:2.1",
      "pali": "“Gharā nānīhamānassa,"
    },
    {
      "id": "ja235:2.2",
      "pali": "Gharā nābhaṇato musā;"
    },
    {
      "id": "ja235:2.3",
      "pali": "Gharā nādinnadaṇḍassa,"
    },
    {
      "id": "ja235:2.4",
      "pali": "Paresaṁ anikubbato;"
    },
    {
      "id": "ja235:2.5",
      "pali": "Evaṁ chiddaṁ durabhisambhavaṁ,"
    },
    {
      "id": "ja235:2.6",
      "pali": "Ko gharaṁ paṭipajjatī”ti."
    },
    {
      "id": "ja235:3.1",
      "pali": "Vacchanakhajātakaṁ pañcamaṁ."
    }
  ]
}
