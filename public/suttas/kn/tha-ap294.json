{
  "uid": "tha-ap294",
  "title": "Pupphadhārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap294:1.1",
      "pali": "“Vākacīradharo āsiṁ,"
    },
    {
      "id": "tha-ap294:1.2",
      "pali": "ajinuttaravāsano;"
    },
    {
      "id": "tha-ap294:1.3",
      "pali": "Abhiññā pañca nibbattā,"
    },
    {
      "id": "tha-ap294:1.4",
      "pali": "candassa parimajjako."
    },
    {
      "id": "tha-ap294:2.1",
      "pali": "Vipassiṁ lokapajjotaṁ,"
    },
    {
      "id": "tha-ap294:2.2",
      "pali": "disvā abhigataṁ mamaṁ;"
    },
    {
      "id": "tha-ap294:2.3",
      "pali": "Pāricchattakapupphāni,"
    },
    {
      "id": "tha-ap294:2.4",
      "pali": "dhāresiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap294:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap294:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap294:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap294:3.4",
      "pali": "dhāraṇāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap294:4.1",
      "pali": "Sattāsītimhito kappe,"
    },
    {
      "id": "tha-ap294:4.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap294:4.3",
      "pali": "Samantadhāraṇo nāma,"
    },
    {
      "id": "tha-ap294:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap294:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap294:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap294:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap294:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphadhārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap294:7.1",
      "pali": "Pupphadhārakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
