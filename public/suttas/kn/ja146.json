{
  "uid": "ja146",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja146:1.1",
      "pali": "“Api nu hanukā santā,"
    },
    {
      "id": "ja146:1.2",
      "pali": "mukhañca parisussati;"
    },
    {
      "id": "ja146:1.3",
      "pali": "Oramāma na pārema,"
    },
    {
      "id": "ja146:1.4",
      "pali": "pūrateva mahodadhī”ti."
    },
    {
      "id": "ja146:2.1",
      "pali": "Samuddakākajātakaṁ chaṭṭhaṁ."
    }
  ]
}
