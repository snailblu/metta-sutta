{
  "uid": "tha-ap200",
  "title": "8 Muṭṭhipūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap200:1.1",
      "pali": "“Sumedho nāma bhagavā,"
    },
    {
      "id": "tha-ap200:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap200:1.3",
      "pali": "Pacchime anukampāya,"
    },
    {
      "id": "tha-ap200:1.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "tha-ap200:2.1",
      "pali": "Tassa caṅkamamānassa,"
    },
    {
      "id": "tha-ap200:2.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap200:2.3",
      "pali": "Girinelassa pupphānaṁ,"
    },
    {
      "id": "tha-ap200:2.4",
      "pali": "muṭṭhiṁ buddhassa ropayiṁ."
    },
    {
      "id": "tha-ap200:3.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap200:3.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap200:3.3",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap200:3.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap200:4.1",
      "pali": "Tevīsatikappasate,"
    },
    {
      "id": "tha-ap200:4.2",
      "pali": "sunelo nāma khattiyo;"
    },
    {
      "id": "tha-ap200:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap200:4.4",
      "pali": "eko āsiṁ mahabbalo."
    },
    {
      "id": "tha-ap200:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap200:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap200:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap200:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā muṭṭhipūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap200:7.1",
      "pali": "Muṭṭhipūjakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
