{
  "uid": "ja350",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja350:1.1",
      "pali": "“Hanti hatthehi pādehi,"
    },
    {
      "id": "ja350:1.2",
      "pali": "mukhañca parisumbhati;"
    },
    {
      "id": "ja350:1.3",
      "pali": "Sa ve rāja piyo hoti,"
    },
    {
      "id": "ja350:1.4",
      "pali": "kaṁ tena tvābhipassasi”."
    },
    {
      "id": "ja350:2.1",
      "pali": "“Akkosati yathākāmaṁ,"
    },
    {
      "id": "ja350:2.2",
      "pali": "āgamañcassa icchati;"
    },
    {
      "id": "ja350:2.3",
      "pali": "Sa ve rāja piyo hoti,"
    },
    {
      "id": "ja350:2.4",
      "pali": "kaṁ tena tvābhipassasi”."
    },
    {
      "id": "ja350:3.1",
      "pali": "“Abbhakkhāti abhūtena,"
    },
    {
      "id": "ja350:3.2",
      "pali": "alikenābhisāraye;"
    },
    {
      "id": "ja350:3.3",
      "pali": "Sa ve rāja piyo hoti,"
    },
    {
      "id": "ja350:3.4",
      "pali": "kaṁ tena tvābhipassasi”."
    },
    {
      "id": "ja350:4.1",
      "pali": "“Haraṁ annañca pānañca,"
    },
    {
      "id": "ja350:4.2",
      "pali": "Vatthasenāsanāni ca;"
    },
    {
      "id": "ja350:4.3",
      "pali": "Aññadatthuharā santā,"
    },
    {
      "id": "ja350:4.4",
      "pali": "Te ve rāja piyā honti;"
    },
    {
      "id": "ja350:4.5",
      "pali": "Kaṁ tena tvābhipassasī”ti."
    },
    {
      "id": "ja350:5.1",
      "pali": "Devatāpañhajātakaṁ dasamaṁ."
    },
    {
      "id": "ja350:5.2",
      "pali": "Cūḷakuṇālavaggo pañcamo."
    },
    {
      "id": "ja350:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja350:7.1",
      "pali": "Narānaṁ asakkhivasimhavaro,"
    },
    {
      "id": "ja350:7.2",
      "pali": "Nīliyamaggivarañca puna;"
    },
    {
      "id": "ja350:7.3",
      "pali": "Puna rasāyasakūṭavaro,"
    },
    {
      "id": "ja350:7.4",
      "pali": "Tathārañña sārathi hanti dasāti."
    },
    {
      "id": "ja350:8.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja350:9.1",
      "pali": "Kāliṅgaṁ pucimandañca,"
    },
    {
      "id": "ja350:9.2",
      "pali": "kuṭidūsaka kokilā;"
    },
    {
      "id": "ja350:9.3",
      "pali": "Cūḷakuṇālavaggo so,"
    },
    {
      "id": "ja350:9.4",
      "pali": "pañcamo suppakāsitoti."
    },
    {
      "id": "ja350:10.1",
      "pali": "Catukkanipātaṁ niṭṭhitaṁ."
    }
  ]
}
