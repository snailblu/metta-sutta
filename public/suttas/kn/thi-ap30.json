{
  "uid": "thi-ap30",
  "title": "10 Yasodharāpamukhaaṭṭhārasabhikkhunīsahassaapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap30:1.1",
      "pali": "Aṭṭhārasasahassāni,"
    },
    {
      "id": "thi-ap30:1.2",
      "pali": "bhikkhunī sakyasambhavā;"
    },
    {
      "id": "thi-ap30:1.3",
      "pali": "Yasodharāpamukhāni,"
    },
    {
      "id": "thi-ap30:1.4",
      "pali": "sambuddhaṁ upasaṅkamuṁ."
    },
    {
      "id": "thi-ap30:2.1",
      "pali": "Aṭṭhārasasahassāni,"
    },
    {
      "id": "thi-ap30:2.2",
      "pali": "sabbā honti mahiddhikā;"
    },
    {
      "id": "thi-ap30:2.3",
      "pali": "Vandantī munino pāde,"
    },
    {
      "id": "thi-ap30:2.4",
      "pali": "ārocenti yathābalaṁ."
    },
    {
      "id": "thi-ap30:3.1",
      "pali": "“Jāti khīṇā jarā byādhi,"
    },
    {
      "id": "thi-ap30:3.2",
      "pali": "maraṇañca mahāmuni;"
    },
    {
      "id": "thi-ap30:3.3",
      "pali": "Anāsavaṁ padaṁ santaṁ,"
    },
    {
      "id": "thi-ap30:3.4",
      "pali": "amataṁ yāma nāyaka."
    },
    {
      "id": "thi-ap30:4.1",
      "pali": "Khalitañce pure atthi,"
    },
    {
      "id": "thi-ap30:4.2",
      "pali": "sabbāsampi mahāmuni;"
    },
    {
      "id": "thi-ap30:4.3",
      "pali": "Aparādhamajānantī,"
    },
    {
      "id": "thi-ap30:4.4",
      "pali": "khama amhaṁ vināyaka”."
    },
    {
      "id": "thi-ap30:5.1",
      "pali": "“Iddhiñcāpi nidassetha,"
    },
    {
      "id": "thi-ap30:5.2",
      "pali": "mama sāsanakārikā;"
    },
    {
      "id": "thi-ap30:5.3",
      "pali": "Parisānañca sabbāsaṁ,"
    },
    {
      "id": "thi-ap30:5.4",
      "pali": "kaṅkhaṁ chindatha yāvatā”."
    },
    {
      "id": "thi-ap30:6.1",
      "pali": "“Yasodharā mahāvīra,"
    },
    {
      "id": "thi-ap30:6.2",
      "pali": "manāpā piyadassanā;"
    },
    {
      "id": "thi-ap30:6.3",
      "pali": "Sabbā tuyhaṁ mahāvīra,"
    },
    {
      "id": "thi-ap30:6.4",
      "pali": "agārasmiṁ pajāpati."
    },
    {
      "id": "thi-ap30:7.1",
      "pali": "Thīnaṁ satasahassānaṁ,"
    },
    {
      "id": "thi-ap30:7.2",
      "pali": "navutīnaṁ chaduttari;"
    },
    {
      "id": "thi-ap30:7.3",
      "pali": "Agāre te mayaṁ vīra,"
    },
    {
      "id": "thi-ap30:7.4",
      "pali": "pāmokkhā sabbā issarā."
    },
    {
      "id": "thi-ap30:8.1",
      "pali": "Rūpācāraguṇūpetā,"
    },
    {
      "id": "thi-ap30:8.2",
      "pali": "yobbanaṭṭhā piyaṁvadā;"
    },
    {
      "id": "thi-ap30:8.3",
      "pali": "Sabbā no apacāyanti,"
    },
    {
      "id": "thi-ap30:8.4",
      "pali": "devatā viya mānusā."
    },
    {
      "id": "thi-ap30:9.1",
      "pali": "Aṭṭhārasasahassāni,"
    },
    {
      "id": "thi-ap30:9.2",
      "pali": "sabbā sākiyasambhavā;"
    },
    {
      "id": "thi-ap30:9.3",
      "pali": "Yasodharāsahassāni,"
    },
    {
      "id": "thi-ap30:9.4",
      "pali": "pāmokkhā issarā tadā."
    },
    {
      "id": "thi-ap30:10.1",
      "pali": "Kāmadhātumatikkamma,"
    },
    {
      "id": "thi-ap30:10.2",
      "pali": "saṇṭhitā rūpadhātuyā;"
    },
    {
      "id": "thi-ap30:10.3",
      "pali": "Rūpena sadisā natthi,"
    },
    {
      "id": "thi-ap30:10.4",
      "pali": "sahassānaṁ mahāmuni”."
    },
    {
      "id": "thi-ap30:11.1",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "thi-ap30:11.2",
      "pali": "iddhiṁ dassaṁsu satthuno;"
    },
    {
      "id": "thi-ap30:11.3",
      "pali": "Nekā nānāvidhākārā,"
    },
    {
      "id": "thi-ap30:11.4",
      "pali": "mahāiddhīpi dassayuṁ."
    },
    {
      "id": "thi-ap30:12.1",
      "pali": "Cakkavāḷasamaṁ kāyaṁ,"
    },
    {
      "id": "thi-ap30:12.2",
      "pali": "sīsaṁ uttarato kuru;"
    },
    {
      "id": "thi-ap30:12.3",
      "pali": "Ubho pakkhā duve dīpā,"
    },
    {
      "id": "thi-ap30:12.4",
      "pali": "jambudīpaṁ sarīrato."
    },
    {
      "id": "thi-ap30:13.1",
      "pali": "Dakkhiṇañca saraṁ piñchaṁ,"
    },
    {
      "id": "thi-ap30:13.2",
      "pali": "nānāsākhā tu pattakā;"
    },
    {
      "id": "thi-ap30:13.3",
      "pali": "Candañca sūriyañcakkhi,"
    },
    {
      "id": "thi-ap30:13.4",
      "pali": "merupabbatato sikhaṁ."
    },
    {
      "id": "thi-ap30:14.1",
      "pali": "Cakkavāḷagiriṁ tuṇḍaṁ,"
    },
    {
      "id": "thi-ap30:14.2",
      "pali": "jamburukkhaṁ samūlakaṁ;"
    },
    {
      "id": "thi-ap30:14.3",
      "pali": "Bījamānā upāgantvā,"
    },
    {
      "id": "thi-ap30:14.4",
      "pali": "vandantī lokanāyakaṁ."
    },
    {
      "id": "thi-ap30:15.1",
      "pali": "Hatthivaṇṇaṁ tathevassaṁ,"
    },
    {
      "id": "thi-ap30:15.2",
      "pali": "pabbataṁ jaladhiṁ tathā;"
    },
    {
      "id": "thi-ap30:15.3",
      "pali": "Candañca sūriyaṁ meruṁ,"
    },
    {
      "id": "thi-ap30:15.4",
      "pali": "sakkavaṇṇañca dassayuṁ."
    },
    {
      "id": "thi-ap30:16.1",
      "pali": "“Yasodharā mayaṁ vīra,"
    },
    {
      "id": "thi-ap30:16.2",
      "pali": "pāde vandāma cakkhuma;"
    },
    {
      "id": "thi-ap30:16.3",
      "pali": "Tava cirapabhāvena,"
    },
    {
      "id": "thi-ap30:16.4",
      "pali": "nipphannā naranāyaka."
    },
    {
      "id": "thi-ap30:17.1",
      "pali": "Iddhīsu ca vasī homa,"
    },
    {
      "id": "thi-ap30:17.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap30:17.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap30:17.4",
      "pali": "vasī homa mahāmune."
    },
    {
      "id": "thi-ap30:18.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap30:18.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap30:18.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap30:18.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap30:19.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap30:19.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap30:19.3",
      "pali": "Ñāṇaṁ amhaṁ mahāvīra,"
    },
    {
      "id": "thi-ap30:19.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap30:20.1",
      "pali": "Pubbānaṁ lokanāthānaṁ,"
    },
    {
      "id": "thi-ap30:20.2",
      "pali": "saṅgamaṁ no nidassitaṁ;"
    },
    {
      "id": "thi-ap30:20.3",
      "pali": "Adhikārā bahū amhaṁ,"
    },
    {
      "id": "thi-ap30:20.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:21.1",
      "pali": "Yaṁ amhaṁ pūritaṁ kammaṁ,"
    },
    {
      "id": "thi-ap30:21.2",
      "pali": "kusalaṁ sarase mune;"
    },
    {
      "id": "thi-ap30:21.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap30:21.4",
      "pali": "puññānupacitāni no."
    },
    {
      "id": "thi-ap30:22.1",
      "pali": "Abhabbaṭṭhāne vajjetvā,"
    },
    {
      "id": "thi-ap30:22.2",
      "pali": "vārayimha anācaraṁ;"
    },
    {
      "id": "thi-ap30:22.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap30:22.4",
      "pali": "cattāni jīvitāni no."
    },
    {
      "id": "thi-ap30:23.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap30:23.2",
      "pali": "bhariyatthāyadāsi no;"
    },
    {
      "id": "thi-ap30:23.3",
      "pali": "Na tattha vimanā homa,"
    },
    {
      "id": "thi-ap30:23.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:24.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap30:24.2",
      "pali": "upakārāyadāsi no;"
    },
    {
      "id": "thi-ap30:24.3",
      "pali": "Na tattha vimanā homa,"
    },
    {
      "id": "thi-ap30:24.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:25.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap30:25.2",
      "pali": "bhojanatthāyadāsi no;"
    },
    {
      "id": "thi-ap30:25.3",
      "pali": "Na tattha vimanā homa,"
    },
    {
      "id": "thi-ap30:25.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:26.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap30:26.2",
      "pali": "jīvitāni cajimhase;"
    },
    {
      "id": "thi-ap30:26.3",
      "pali": "Bhayamokkhaṁ karissāma,"
    },
    {
      "id": "thi-ap30:26.4",
      "pali": "jīvitāni cajimhase."
    },
    {
      "id": "thi-ap30:27.1",
      "pali": "Aṅgagate alaṅkāre,"
    },
    {
      "id": "thi-ap30:27.2",
      "pali": "vatthe nānāvidhe bahū;"
    },
    {
      "id": "thi-ap30:27.3",
      "pali": "Itthibhaṇḍe na gūhāma,"
    },
    {
      "id": "thi-ap30:27.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:28.1",
      "pali": "Dhanadhaññapariccāgaṁ,"
    },
    {
      "id": "thi-ap30:28.2",
      "pali": "gāmāni nigamāni ca;"
    },
    {
      "id": "thi-ap30:28.3",
      "pali": "Khettaṁ puttā ca dhītā ca,"
    },
    {
      "id": "thi-ap30:28.4",
      "pali": "pariccattā mahāmune."
    },
    {
      "id": "thi-ap30:29.1",
      "pali": "Hatthī assā gavā cāpi,"
    },
    {
      "id": "thi-ap30:29.2",
      "pali": "dāsiyo paricārikā;"
    },
    {
      "id": "thi-ap30:29.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap30:29.4",
      "pali": "pariccattaṁ asaṅkhiyaṁ."
    },
    {
      "id": "thi-ap30:30.1",
      "pali": "Yaṁ amhe paṭimantesi,"
    },
    {
      "id": "thi-ap30:30.2",
      "pali": "‘dānaṁ dassāma yācake’;"
    },
    {
      "id": "thi-ap30:30.3",
      "pali": "Vimanaṁ no na passāma,"
    },
    {
      "id": "thi-ap30:30.4",
      "pali": "dadato dānamuttamaṁ."
    },
    {
      "id": "thi-ap30:31.1",
      "pali": "Nānāvidhaṁ bahuṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap30:31.2",
      "pali": "saṁsāre ca bahubbidhe;"
    },
    {
      "id": "thi-ap30:31.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap30:31.4",
      "pali": "anubhuttaṁ asaṅkhiyaṁ."
    },
    {
      "id": "thi-ap30:32.1",
      "pali": "Sukhappattānumodāma,"
    },
    {
      "id": "thi-ap30:32.2",
      "pali": "na ca dukkhesu dummanā;"
    },
    {
      "id": "thi-ap30:32.3",
      "pali": "Sabbattha tulitā homa,"
    },
    {
      "id": "thi-ap30:32.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap30:33.1",
      "pali": "Anumaggena sambuddho,"
    },
    {
      "id": "thi-ap30:33.2",
      "pali": "yaṁ dhammaṁ abhinīhari;"
    },
    {
      "id": "thi-ap30:33.3",
      "pali": "Anubhotvā sukhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap30:33.4",
      "pali": "patto bodhiṁ mahāmune."
    },
    {
      "id": "thi-ap30:34.1",
      "pali": "Brahmadevañca sambuddhaṁ,"
    },
    {
      "id": "thi-ap30:34.2",
      "pali": "gotamaṁ lokanāyakaṁ;"
    },
    {
      "id": "thi-ap30:34.3",
      "pali": "Aññesaṁ lokanāthānaṁ,"
    },
    {
      "id": "thi-ap30:34.4",
      "pali": "saṅgamaṁ tehi no bahū."
    },
    {
      "id": "thi-ap30:35.1",
      "pali": "Adhikāraṁ bahuṁ amhe,"
    },
    {
      "id": "thi-ap30:35.2",
      "pali": "tuyhatthāya mahāmune;"
    },
    {
      "id": "thi-ap30:35.3",
      "pali": "Gavesato buddhadhamme,"
    },
    {
      "id": "thi-ap30:35.4",
      "pali": "mayaṁ te paricārikā."
    },
    {
      "id": "thi-ap30:36.1",
      "pali": "Kappe ca satasahasse,"
    },
    {
      "id": "thi-ap30:36.2",
      "pali": "caturo ca asaṅkhiye;"
    },
    {
      "id": "thi-ap30:36.3",
      "pali": "Dīpaṅkaro mahāvīro,"
    },
    {
      "id": "thi-ap30:36.4",
      "pali": "uppajji lokanāyako."
    },
    {
      "id": "thi-ap30:37.1",
      "pali": "Paccantadesavisaye,"
    },
    {
      "id": "thi-ap30:37.2",
      "pali": "nimantetvā tathāgataṁ;"
    },
    {
      "id": "thi-ap30:37.3",
      "pali": "Tassa āgamanaṁ maggaṁ,"
    },
    {
      "id": "thi-ap30:37.4",
      "pali": "sodhenti tuṭṭhamānasā."
    },
    {
      "id": "thi-ap30:38.1",
      "pali": "Tena kālena so āsi,"
    },
    {
      "id": "thi-ap30:38.2",
      "pali": "sumedho nāma brāhmaṇo;"
    },
    {
      "id": "thi-ap30:38.3",
      "pali": "Maggañca paṭiyādesi,"
    },
    {
      "id": "thi-ap30:38.4",
      "pali": "āyato sabbadassino."
    },
    {
      "id": "thi-ap30:39.1",
      "pali": "Tena kālena ahumha,"
    },
    {
      "id": "thi-ap30:39.2",
      "pali": "sabbā brāhmaṇasambhavā;"
    },
    {
      "id": "thi-ap30:39.3",
      "pali": "Thalūdajāni pupphāni,"
    },
    {
      "id": "thi-ap30:39.4",
      "pali": "āharimha samāgamaṁ."
    },
    {
      "id": "thi-ap30:40.1",
      "pali": "Tasmiṁ so samaye buddho,"
    },
    {
      "id": "thi-ap30:40.2",
      "pali": "dīpaṅkaro mahāyaso;"
    },
    {
      "id": "thi-ap30:40.3",
      "pali": "Viyākāsi mahāvīro,"
    },
    {
      "id": "thi-ap30:40.4",
      "pali": "isimuggatamānasaṁ."
    },
    {
      "id": "thi-ap30:41.1",
      "pali": "Calatī ravatī puthavī,"
    },
    {
      "id": "thi-ap30:41.2",
      "pali": "saṅkampati sadevake;"
    },
    {
      "id": "thi-ap30:41.3",
      "pali": "Tassa kammaṁ pakittente,"
    },
    {
      "id": "thi-ap30:41.4",
      "pali": "isimuggatamānasaṁ."
    },
    {
      "id": "thi-ap30:42.1",
      "pali": "Devakaññā manussā ca,"
    },
    {
      "id": "thi-ap30:42.2",
      "pali": "mayañcāpi sadevakā;"
    },
    {
      "id": "thi-ap30:42.3",
      "pali": "Nānāpūjanīyaṁ bhaṇḍaṁ,"
    },
    {
      "id": "thi-ap30:42.4",
      "pali": "pūjayitvāna patthayuṁ."
    },
    {
      "id": "thi-ap30:43.1",
      "pali": "Tesaṁ buddho viyākāsi,"
    },
    {
      "id": "thi-ap30:43.2",
      "pali": "jotidīpa sanāmako;"
    },
    {
      "id": "thi-ap30:43.3",
      "pali": "‘Ajja ye patthitā atthi,"
    },
    {
      "id": "thi-ap30:43.4",
      "pali": "te bhavissanti sammukhā’."
    },
    {
      "id": "thi-ap30:44.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "thi-ap30:44.2",
      "pali": "yaṁ no buddho viyākari;"
    },
    {
      "id": "thi-ap30:44.3",
      "pali": "Taṁ vācamanumodentā,"
    },
    {
      "id": "thi-ap30:44.4",
      "pali": "evaṅkārī ahumha no."
    },
    {
      "id": "thi-ap30:45.1",
      "pali": "Tassa kammassa sukatassa,"
    },
    {
      "id": "thi-ap30:45.2",
      "pali": "tassa cittaṁ pasādayuṁ;"
    },
    {
      "id": "thi-ap30:45.3",
      "pali": "Devamānusikaṁ yoniṁ,"
    },
    {
      "id": "thi-ap30:45.4",
      "pali": "anubhotvā asaṅkhiyaṁ."
    },
    {
      "id": "thi-ap30:46.1",
      "pali": "Sukhadukkhenubhotvāna,"
    },
    {
      "id": "thi-ap30:46.2",
      "pali": "devesu mānusesu ca;"
    },
    {
      "id": "thi-ap30:46.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap30:46.4",
      "pali": "jātāmha sākiye kule."
    },
    {
      "id": "thi-ap30:47.1",
      "pali": "Rūpavatī bhogavatī,"
    },
    {
      "id": "thi-ap30:47.2",
      "pali": "yasasīlavatī tato;"
    },
    {
      "id": "thi-ap30:47.3",
      "pali": "Sabbaṅgasampadā homa,"
    },
    {
      "id": "thi-ap30:47.4",
      "pali": "kulesu abhisakkatā."
    },
    {
      "id": "thi-ap30:48.1",
      "pali": "Lābhaṁ silokaṁ sakkāraṁ,"
    },
    {
      "id": "thi-ap30:48.2",
      "pali": "lokadhammasamāgamaṁ;"
    },
    {
      "id": "thi-ap30:48.3",
      "pali": "Cittañca dukkhitaṁ natthi,"
    },
    {
      "id": "thi-ap30:48.4",
      "pali": "vasāma akutobhayā."
    },
    {
      "id": "thi-ap30:49.1",
      "pali": "Vuttañhetaṁ bhagavatā,"
    },
    {
      "id": "thi-ap30:49.2",
      "pali": "‘rañño antepure tadā;"
    },
    {
      "id": "thi-ap30:49.3",
      "pali": "Khattiyānaṁ pure vīra,"
    },
    {
      "id": "thi-ap30:49.4",
      "pali": "upakārañca niddisi."
    },
    {
      "id": "thi-ap30:50.1",
      "pali": "Upakārā ca yā nārī,"
    },
    {
      "id": "thi-ap30:50.2",
      "pali": "yā ca nārī sukhe dukhe;"
    },
    {
      "id": "thi-ap30:50.3",
      "pali": "Atthakkhāyī ca yā nārī,"
    },
    {
      "id": "thi-ap30:50.4",
      "pali": "yā ca nārīnukampikā."
    },
    {
      "id": "thi-ap30:51.1",
      "pali": "Dhammaṁ care sucaritaṁ,"
    },
    {
      "id": "thi-ap30:51.2",
      "pali": "na naṁ duccaritaṁ care;"
    },
    {
      "id": "thi-ap30:51.3",
      "pali": "Dhammacārī sukhaṁ seti,"
    },
    {
      "id": "thi-ap30:51.4",
      "pali": "asmiṁ loke paramhi ca’."
    },
    {
      "id": "thi-ap30:52.1",
      "pali": "Agāraṁ vijahitvāna,"
    },
    {
      "id": "thi-ap30:52.2",
      "pali": "pabbajimhanagāriyaṁ;"
    },
    {
      "id": "thi-ap30:52.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "thi-ap30:52.4",
      "pali": "catusaccaṁ phusimha no."
    },
    {
      "id": "thi-ap30:53.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap30:53.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap30:53.3",
      "pali": "Upanenti bahū amhe,"
    },
    {
      "id": "thi-ap30:53.4",
      "pali": "sāgarasseva ūmiyo."
    },
    {
      "id": "thi-ap30:54.1",
      "pali": "Kilesā jhāpitā amhaṁ,"
    },
    {
      "id": "thi-ap30:54.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap30:54.3",
      "pali": "Nāgīva bandhanaṁ chetvā,"
    },
    {
      "id": "thi-ap30:54.4",
      "pali": "viharāma anāsavā."
    },
    {
      "id": "thi-ap30:55.1",
      "pali": "Svāgataṁ vata no āsi,"
    },
    {
      "id": "thi-ap30:55.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "thi-ap30:55.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thi-ap30:55.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap30:56.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap30:56.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "thi-ap30:56.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thi-ap30:56.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap30:57.1",
      "pali": "Evaṁ bahuvidhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap30:57.2",
      "pali": "sampattī ca bahubbidhā;"
    },
    {
      "id": "thi-ap30:57.3",
      "pali": "Visuddhabhāvaṁ sampattā,"
    },
    {
      "id": "thi-ap30:57.4",
      "pali": "labhāma sabbasampadā."
    },
    {
      "id": "thi-ap30:58.1",
      "pali": "Yā dadanti sakattānaṁ,"
    },
    {
      "id": "thi-ap30:58.2",
      "pali": "puññatthāya mahesino;"
    },
    {
      "id": "thi-ap30:58.3",
      "pali": "Sahāyasampadā honti,"
    },
    {
      "id": "thi-ap30:58.4",
      "pali": "nibbānapadamasaṅkhataṁ."
    },
    {
      "id": "thi-ap30:59.1",
      "pali": "Parikkhīṇaṁ atītañca,"
    },
    {
      "id": "thi-ap30:59.2",
      "pali": "paccuppannaṁ anāgataṁ;"
    },
    {
      "id": "thi-ap30:59.3",
      "pali": "Sabbakammampi no khīṇaṁ,"
    },
    {
      "id": "thi-ap30:59.4",
      "pali": "pāde vandāma cakkhuma”."
    },
    {
      "id": "thi-ap30:60.1",
      "pali": "“Nibbānāya vadantīnaṁ,"
    },
    {
      "id": "thi-ap30:60.2",
      "pali": "Kiṁ vo vakkhāma uttari;"
    },
    {
      "id": "thi-ap30:60.3",
      "pali": "Santasaṅkhatadosañhi,"
    },
    {
      "id": "thi-ap30:60.4",
      "pali": "Pappotha amataṁ padaṁ”."
    },
    {
      "id": "thi-ap30:61.1",
      "pali": "Itthaṁ sudaṁ yasodharāpamukhāni aṭṭhārasabhikkhunīsahassāni bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap30:62.1",
      "pali": "Yasodharāpamukhaaṭṭhārasabhikkhunīsahassāpadānaṁ dasamaṁ."
    },
    {
      "id": "thi-ap30:63.1",
      "pali": "Kuṇḍalakesīvaggo tatiyo."
    },
    {
      "id": "thi-ap30:64.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "thi-ap30:65.1",
      "pali": "Kuṇḍalā gotamī ceva,"
    },
    {
      "id": "thi-ap30:65.2",
      "pali": "dhammadinnā ca sakulā;"
    },
    {
      "id": "thi-ap30:65.3",
      "pali": "Varanandā ca soṇā ca,"
    },
    {
      "id": "thi-ap30:65.4",
      "pali": "kāpilānī yasodharā."
    },
    {
      "id": "thi-ap30:66.1",
      "pali": "Dasasahassabhikkhunī,"
    },
    {
      "id": "thi-ap30:66.2",
      "pali": "aṭṭhārasasahassakā;"
    },
    {
      "id": "thi-ap30:66.3",
      "pali": "Gāthāsatāni cattāri,"
    },
    {
      "id": "thi-ap30:66.4",
      "pali": "cha ca sattatimeva ca."
    }
  ]
}
