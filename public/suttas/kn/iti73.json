{
  "uid": "iti73",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti73:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti73:2.1",
      "pali": "“Rūpehi, bhikkhave, arūpā santatarā, arūpehi nirodho santataro”ti."
    },
    {
      "id": "iti73:2.2",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti73:2.3",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti73:3.1",
      "pali": "“Ye ca rūpūpagā sattā,"
    },
    {
      "id": "iti73:3.2",
      "pali": "ye ca arūpaṭṭhāyino;"
    },
    {
      "id": "iti73:3.3",
      "pali": "Nirodhaṁ appajānantā,"
    },
    {
      "id": "iti73:3.4",
      "pali": "āgantāro punabbhavaṁ."
    },
    {
      "id": "iti73:4.1",
      "pali": "Ye ca rūpe pariññāya,"
    },
    {
      "id": "iti73:4.2",
      "pali": "arūpesu asaṇṭhitā;"
    },
    {
      "id": "iti73:4.3",
      "pali": "Nirodhe ye vimuccanti,"
    },
    {
      "id": "iti73:4.4",
      "pali": "te janā maccuhāyino."
    },
    {
      "id": "iti73:5.1",
      "pali": "Kāyena amatadhātuṁ,"
    },
    {
      "id": "iti73:5.2",
      "pali": "phusayitvā nirūpadhiṁ;"
    },
    {
      "id": "iti73:5.3",
      "pali": "Upadhippaṭinissaggaṁ,"
    },
    {
      "id": "iti73:5.4",
      "pali": "sacchikatvā anāsavo;"
    },
    {
      "id": "iti73:5.5",
      "pali": "Deseti sammāsambuddho,"
    },
    {
      "id": "iti73:5.6",
      "pali": "asokaṁ virajaṁ padan”ti."
    },
    {
      "id": "iti73:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti73:6.2",
      "pali": "Catutthaṁ."
    }
  ]
}
