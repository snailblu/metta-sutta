{
  "uid": "ja430",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja430:1.1",
      "pali": "“Santi rukkhā haripattā,"
    },
    {
      "id": "ja430:1.2",
      "pali": "dumā nekaphalā bahū;"
    },
    {
      "id": "ja430:1.3",
      "pali": "Kasmā nu sukkhe koḷāpe,"
    },
    {
      "id": "ja430:1.4",
      "pali": "suvassa nirato mano”."
    },
    {
      "id": "ja430:2.1",
      "pali": "“Phalassa upabhuñjimhā,"
    },
    {
      "id": "ja430:2.2",
      "pali": "nekavassagaṇe bahū;"
    },
    {
      "id": "ja430:2.3",
      "pali": "Aphalampi viditvāna,"
    },
    {
      "id": "ja430:2.4",
      "pali": "sāva metti yathā pure”."
    },
    {
      "id": "ja430:3.1",
      "pali": "“Sukkhañca rukkhaṁ koḷāpaṁ,"
    },
    {
      "id": "ja430:3.2",
      "pali": "opattamaphalaṁ dumaṁ;"
    },
    {
      "id": "ja430:3.3",
      "pali": "Ohāya sakuṇā yanti,"
    },
    {
      "id": "ja430:3.4",
      "pali": "kiṁ dosaṁ passase dija”."
    },
    {
      "id": "ja430:4.1",
      "pali": "“Ye phalatthā sambhajanti,"
    },
    {
      "id": "ja430:4.2",
      "pali": "aphaloti jahanti naṁ;"
    },
    {
      "id": "ja430:4.3",
      "pali": "Attatthapaññā dummedhā,"
    },
    {
      "id": "ja430:4.4",
      "pali": "te honti pakkhapātino”."
    },
    {
      "id": "ja430:5.1",
      "pali": "“Sādhu sakkhi kataṁ hoti,"
    },
    {
      "id": "ja430:5.2",
      "pali": "metti saṁsati santhavo;"
    },
    {
      "id": "ja430:5.3",
      "pali": "Sacetaṁ dhammaṁ rocesi,"
    },
    {
      "id": "ja430:5.4",
      "pali": "pāsaṁsosi vijānataṁ."
    },
    {
      "id": "ja430:6.1",
      "pali": "So te suva varaṁ dammi,"
    },
    {
      "id": "ja430:6.2",
      "pali": "pattayāna vihaṅgama;"
    },
    {
      "id": "ja430:6.3",
      "pali": "Varaṁ varassu vakkaṅga,"
    },
    {
      "id": "ja430:6.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja430:7.1",
      "pali": "“Api nāma naṁ passeyyaṁ,"
    },
    {
      "id": "ja430:7.2",
      "pali": "sapattaṁ saphalaṁ dumaṁ;"
    },
    {
      "id": "ja430:7.3",
      "pali": "Daliddova nidhiṁ laddhā,"
    },
    {
      "id": "ja430:7.4",
      "pali": "nandeyyāhaṁ punappunaṁ”."
    },
    {
      "id": "ja430:8.1",
      "pali": "“Tato amatamādāya,"
    },
    {
      "id": "ja430:8.2",
      "pali": "abhisiñci mahīruhaṁ;"
    },
    {
      "id": "ja430:8.3",
      "pali": "Tassa sākhā virūhiṁsu,"
    },
    {
      "id": "ja430:8.4",
      "pali": "sītacchāyā manoramā”."
    },
    {
      "id": "ja430:9.1",
      "pali": "“Evaṁ sakka sukhī hohi,"
    },
    {
      "id": "ja430:9.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja430:9.3",
      "pali": "Yathāhamajja sukhito,"
    },
    {
      "id": "ja430:9.4",
      "pali": "disvāna saphalaṁ dumaṁ."
    },
    {
      "id": "ja430:10.1",
      "pali": "Suvassa ca varaṁ datvā,"
    },
    {
      "id": "ja430:10.2",
      "pali": "katvāna saphalaṁ dumaṁ;"
    },
    {
      "id": "ja430:10.3",
      "pali": "Pakkāmi saha bhariyāya,"
    },
    {
      "id": "ja430:10.4",
      "pali": "devānaṁ nandanaṁ vanan”ti."
    },
    {
      "id": "ja430:11.1",
      "pali": "Cūḷasuvajātakaṁ catutthaṁ."
    }
  ]
}
