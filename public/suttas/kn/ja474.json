{
  "uid": "ja474",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja474:1.1",
      "pali": "“Ahāsi me ambaphalāni pubbe,"
    },
    {
      "id": "ja474:1.2",
      "pali": "Aṇūni thūlāni ca brahmacāri;"
    },
    {
      "id": "ja474:1.3",
      "pali": "Teheva mantehi na dāni tuyhaṁ,"
    },
    {
      "id": "ja474:1.4",
      "pali": "Dumapphalā pātubhavanti brahme”."
    },
    {
      "id": "ja474:2.1",
      "pali": "“Nakkhattayogaṁ paṭimānayāmi,"
    },
    {
      "id": "ja474:2.2",
      "pali": "Khaṇaṁ muhuttañca mante na passaṁ;"
    },
    {
      "id": "ja474:2.3",
      "pali": "Nakkhattayogañca khaṇañca laddhā,"
    },
    {
      "id": "ja474:2.4",
      "pali": "Addhāharissambaphalaṁ pahūtaṁ”."
    },
    {
      "id": "ja474:3.1",
      "pali": "“Nakkhattayogaṁ na pure abhāṇi,"
    },
    {
      "id": "ja474:3.2",
      "pali": "Khaṇaṁ muhuttaṁ na pure asaṁsi;"
    },
    {
      "id": "ja474:3.3",
      "pali": "Sayaṁ harī ambaphalaṁ pahūtaṁ,"
    },
    {
      "id": "ja474:3.4",
      "pali": "Vaṇṇena gandhena rasenupetaṁ."
    },
    {
      "id": "ja474:4.1",
      "pali": "Mantābhijappena pure hi tuyhaṁ,"
    },
    {
      "id": "ja474:4.2",
      "pali": "Dumapphalā pātubhavanti brahme;"
    },
    {
      "id": "ja474:4.3",
      "pali": "Svājja na pāresi jappampi mantaṁ,"
    },
    {
      "id": "ja474:4.4",
      "pali": "Ayaṁ so ko nāma tavajja dhammo”."
    },
    {
      "id": "ja474:5.1",
      "pali": "“Caṇḍālaputto mama sampadāsi,"
    },
    {
      "id": "ja474:5.2",
      "pali": "Dhammena mante pakatiñca saṁsi;"
    },
    {
      "id": "ja474:5.3",
      "pali": "Mā cassu me pucchito nāmagottaṁ,"
    },
    {
      "id": "ja474:5.4",
      "pali": "Guyhittho atthaṁ vijaheyya manto."
    },
    {
      "id": "ja474:6.1",
      "pali": "Sohaṁ janindena janamhi puṭṭho,"
    },
    {
      "id": "ja474:6.2",
      "pali": "Makkhābhibhūto alikaṁ abhāṇiṁ;"
    },
    {
      "id": "ja474:6.3",
      "pali": "‘Mantā ime brāhmaṇassā’ti micchā,"
    },
    {
      "id": "ja474:6.4",
      "pali": "Pahīnamanto kapaṇo rudāmi”."
    },
    {
      "id": "ja474:7.1",
      "pali": "“Eraṇḍā pucimandā vā,"
    },
    {
      "id": "ja474:7.2",
      "pali": "atha vā pālibhaddakā;"
    },
    {
      "id": "ja474:7.3",
      "pali": "Madhuṁ madhutthiko vinde,"
    },
    {
      "id": "ja474:7.4",
      "pali": "so hi tassa dumuttamo."
    },
    {
      "id": "ja474:8.1",
      "pali": "Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "ja474:8.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "ja474:8.3",
      "pali": "Yamhā dhammaṁ vijāneyya,"
    },
    {
      "id": "ja474:8.4",
      "pali": "so hi tassa naruttamo."
    },
    {
      "id": "ja474:9.1",
      "pali": "Imassa daṇḍañca vadhañca datvā,"
    },
    {
      "id": "ja474:9.2",
      "pali": "Gale gahetvā khalayātha jammaṁ;"
    },
    {
      "id": "ja474:9.3",
      "pali": "Yo uttamatthaṁ kasirena laddhaṁ,"
    },
    {
      "id": "ja474:9.4",
      "pali": "Mānātimānena vināsayittha”."
    },
    {
      "id": "ja474:10.1",
      "pali": "“Yathā samaṁ maññamāno pateyya,"
    },
    {
      "id": "ja474:10.2",
      "pali": "Sobbhaṁ guhaṁ narakaṁ pūtipādaṁ;"
    },
    {
      "id": "ja474:10.3",
      "pali": "Rajjūti vā akkame kaṇhasappaṁ,"
    },
    {
      "id": "ja474:10.4",
      "pali": "Andho yathā jotimadhiṭṭhaheyya;"
    },
    {
      "id": "ja474:10.5",
      "pali": "Evampi maṁ tvaṁ khalitaṁ sapañña,"
    },
    {
      "id": "ja474:10.6",
      "pali": "Pahīnamantassa punappadāhi”."
    },
    {
      "id": "ja474:11.1",
      "pali": "“Dhammena mantaṁ tava sampadāsiṁ,"
    },
    {
      "id": "ja474:11.2",
      "pali": "Tuvampi dhammena pariggahesi;"
    },
    {
      "id": "ja474:11.3",
      "pali": "Pakatimpi te attamano asaṁsiṁ,"
    },
    {
      "id": "ja474:11.4",
      "pali": "Dhamme ṭhitaṁ taṁ na jaheyya manto."
    },
    {
      "id": "ja474:12.1",
      "pali": "Yo bāla mantaṁ kasirena laddhaṁ,"
    },
    {
      "id": "ja474:12.2",
      "pali": "Yaṁ dullabhaṁ ajja manussaloke;"
    },
    {
      "id": "ja474:12.3",
      "pali": "Kiñcāpi laddhā jīvituṁ appapañño,"
    },
    {
      "id": "ja474:12.4",
      "pali": "Vināsayī alikaṁ bhāsamāno."
    },
    {
      "id": "ja474:13.1",
      "pali": "Bālassa mūḷhassa akataññuno ca,"
    },
    {
      "id": "ja474:13.2",
      "pali": "Musā bhaṇantassa asaññatassa;"
    },
    {
      "id": "ja474:13.3",
      "pali": "Mante mayaṁ tādisake na dema,"
    },
    {
      "id": "ja474:13.4",
      "pali": "Kuto mantā gaccha na mayha ruccasī”ti."
    },
    {
      "id": "ja474:14.1",
      "pali": "Ambajātakaṁ paṭhamaṁ."
    }
  ]
}
