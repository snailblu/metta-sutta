{
  "uid": "tha-ap81",
  "title": "Ṭhitañjaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap81:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap81:1.2",
      "pali": "Araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap81:1.3",
      "pali": "Tattha addasaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap81:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap81:2.1",
      "pali": "Tatthāhaṁ añjaliṁ katvā,"
    },
    {
      "id": "tha-ap81:2.2",
      "pali": "pakkāmiṁ pācināmukho;"
    },
    {
      "id": "tha-ap81:2.3",
      "pali": "Avidūre nisinnassa,"
    },
    {
      "id": "tha-ap81:2.4",
      "pali": "niyake paṇṇasanthare."
    },
    {
      "id": "tha-ap81:3.1",
      "pali": "Tato me asanīpāto,"
    },
    {
      "id": "tha-ap81:3.2",
      "pali": "matthake nipatī tadā;"
    },
    {
      "id": "tha-ap81:3.3",
      "pali": "Sohaṁ maraṇakālamhi,"
    },
    {
      "id": "tha-ap81:3.4",
      "pali": "akāsiṁ punarañjaliṁ."
    },
    {
      "id": "tha-ap81:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap81:4.2",
      "pali": "añjaliṁ akariṁ tadā;"
    },
    {
      "id": "tha-ap81:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap81:4.4",
      "pali": "añjalissa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap81:5.1",
      "pali": "Catupaṇṇāsakappamhi,"
    },
    {
      "id": "tha-ap81:5.2",
      "pali": "migaketusanāmako;"
    },
    {
      "id": "tha-ap81:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap81:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap81:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap81:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap81:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap81:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ṭhitañjaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap81:8.1",
      "pali": "Ṭhitañjaliyattherassāpadānaṁ navamaṁ."
    }
  ]
}
