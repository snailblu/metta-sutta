{
  "uid": "snp4.9",
  "title": "Māgaṇḍiyasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.9:1.1",
      "pali": "“Disvāna taṇhaṁ aratiṁ ragañca,"
    },
    {
      "id": "snp4.9:1.2",
      "pali": "Nāhosi chando api methunasmiṁ;"
    },
    {
      "id": "snp4.9:1.3",
      "pali": "Kimevidaṁ muttakarīsapuṇṇaṁ,"
    },
    {
      "id": "snp4.9:1.4",
      "pali": "Pādāpi naṁ samphusituṁ na icche”."
    },
    {
      "id": "snp4.9:2.1",
      "pali": "“Etādisañce ratanaṁ na icchasi,"
    },
    {
      "id": "snp4.9:2.2",
      "pali": "Nāriṁ narindehi bahūhi patthitaṁ;"
    },
    {
      "id": "snp4.9:2.3",
      "pali": "Diṭṭhigataṁ sīlavataṁ nu jīvitaṁ,"
    },
    {
      "id": "snp4.9:2.4",
      "pali": "Bhavūpapattiñca vadesi kīdisaṁ”."
    },
    {
      "id": "snp4.9:3.1",
      "pali": "“Idaṁ vadāmīti na tassa hoti,"
    },
    {
      "id": "snp4.9:3.2",
      "pali": "(māgaṇḍiyāti bhagavā)"
    },
    {
      "id": "snp4.9:3.3",
      "pali": "Dhammesu niccheyya samuggahītaṁ;"
    },
    {
      "id": "snp4.9:3.4",
      "pali": "Passañca diṭṭhīsu anuggahāya,"
    },
    {
      "id": "snp4.9:3.5",
      "pali": "Ajjhattasantiṁ pacinaṁ adassaṁ”."
    },
    {
      "id": "snp4.9:4.1",
      "pali": "“Vinicchayā yāni pakappitāni,"
    },
    {
      "id": "snp4.9:4.2",
      "pali": "(iti māgaṇḍiyo)"
    },
    {
      "id": "snp4.9:4.3",
      "pali": "Te ve munī brūsi anuggahāya;"
    },
    {
      "id": "snp4.9:4.4",
      "pali": "Ajjhattasantīti yametamatthaṁ,"
    },
    {
      "id": "snp4.9:4.5",
      "pali": "Kathaṁ nu dhīrehi paveditaṁ taṁ”."
    },
    {
      "id": "snp4.9:5.1",
      "pali": "“Na diṭṭhiyā na sutiyā na ñāṇena,"
    },
    {
      "id": "snp4.9:5.2",
      "pali": "(māgaṇḍiyāti bhagavā)"
    },
    {
      "id": "snp4.9:5.3",
      "pali": "Sīlabbatenāpi na suddhimāha;"
    },
    {
      "id": "snp4.9:5.4",
      "pali": "Adiṭṭhiyā assutiyā añāṇā,"
    },
    {
      "id": "snp4.9:5.5",
      "pali": "Asīlatā abbatā nopi tena;"
    },
    {
      "id": "snp4.9:5.6",
      "pali": "Ete ca nissajja anuggahāya,"
    },
    {
      "id": "snp4.9:5.7",
      "pali": "Santo anissāya bhavaṁ na jappe”."
    },
    {
      "id": "snp4.9:6.1",
      "pali": "“No ce kira diṭṭhiyā na sutiyā na ñāṇena,"
    },
    {
      "id": "snp4.9:6.2",
      "pali": "(iti māgaṇḍiyo)"
    },
    {
      "id": "snp4.9:6.3",
      "pali": "Sīlabbatenāpi na suddhimāha;"
    },
    {
      "id": "snp4.9:6.4",
      "pali": "Adiṭṭhiyā assutiyā añāṇā,"
    },
    {
      "id": "snp4.9:6.5",
      "pali": "Asīlatā abbatā nopi tena;"
    },
    {
      "id": "snp4.9:6.6",
      "pali": "Maññāmahaṁ momuhameva dhammaṁ,"
    },
    {
      "id": "snp4.9:6.7",
      "pali": "Diṭṭhiyā eke paccenti suddhiṁ”."
    },
    {
      "id": "snp4.9:7.1",
      "pali": "“Diṭṭhañca nissāya anupucchamāno,"
    },
    {
      "id": "snp4.9:7.2",
      "pali": "(māgaṇḍiyāti bhagavā)"
    },
    {
      "id": "snp4.9:7.3",
      "pali": "Samuggahītesu pamohamāgā;"
    },
    {
      "id": "snp4.9:7.4",
      "pali": "Ito ca nāddakkhi aṇumpi saññaṁ,"
    },
    {
      "id": "snp4.9:7.5",
      "pali": "Tasmā tuvaṁ momuhato dahāsi."
    },
    {
      "id": "snp4.9:8.1",
      "pali": "Samo visesī uda vā nihīno,"
    },
    {
      "id": "snp4.9:8.2",
      "pali": "Yo maññati so vivadetha tena;"
    },
    {
      "id": "snp4.9:8.3",
      "pali": "Tīsu vidhāsu avikampamāno,"
    },
    {
      "id": "snp4.9:8.4",
      "pali": "Samo visesīti na tassa hoti."
    },
    {
      "id": "snp4.9:9.1",
      "pali": "Saccanti so brāhmaṇo kiṁ vadeyya,"
    },
    {
      "id": "snp4.9:9.2",
      "pali": "Musāti vā so vivadetha kena;"
    },
    {
      "id": "snp4.9:9.3",
      "pali": "Yasmiṁ samaṁ visamaṁ vāpi natthi,"
    },
    {
      "id": "snp4.9:9.4",
      "pali": "Sa kena vādaṁ paṭisaṁyujeyya."
    },
    {
      "id": "snp4.9:10.1",
      "pali": "Okaṁ pahāya aniketasārī,"
    },
    {
      "id": "snp4.9:10.2",
      "pali": "Gāme akubbaṁ muni santhavāni;"
    },
    {
      "id": "snp4.9:10.3",
      "pali": "Kāmehi ritto apurakkharāno,"
    },
    {
      "id": "snp4.9:10.4",
      "pali": "Kathaṁ na viggayha janena kayirā."
    },
    {
      "id": "snp4.9:11.1",
      "pali": "Yehi vivitto vicareyya loke,"
    },
    {
      "id": "snp4.9:11.2",
      "pali": "Na tāni uggayha vadeyya nāgo;"
    },
    {
      "id": "snp4.9:11.3",
      "pali": "Jalambujaṁ kaṇḍakavārijaṁ yathā,"
    },
    {
      "id": "snp4.9:11.4",
      "pali": "Jalena paṅkena canūpalittaṁ;"
    },
    {
      "id": "snp4.9:11.5",
      "pali": "Evaṁ munī santivādo agiddho,"
    },
    {
      "id": "snp4.9:11.6",
      "pali": "Kāme ca loke ca anūpalitto."
    },
    {
      "id": "snp4.9:12.1",
      "pali": "Na vedagū diṭṭhiyāyako na mutiyā,"
    },
    {
      "id": "snp4.9:12.2",
      "pali": "Sa mānameti na hi tammayo so;"
    },
    {
      "id": "snp4.9:12.3",
      "pali": "Na kammunā nopi sutena neyyo,"
    },
    {
      "id": "snp4.9:12.4",
      "pali": "Anūpanīto sa nivesanesu."
    },
    {
      "id": "snp4.9:13.1",
      "pali": "Saññāvirattassa na santi ganthā,"
    },
    {
      "id": "snp4.9:13.2",
      "pali": "Paññāvimuttassa na santi mohā;"
    },
    {
      "id": "snp4.9:13.3",
      "pali": "Saññañca diṭṭhiñca ye aggahesuṁ,"
    },
    {
      "id": "snp4.9:13.4",
      "pali": "Te ghaṭṭayantā vicaranti loke”ti."
    },
    {
      "id": "snp4.9:13.5",
      "pali": "Māgaṇḍiyasuttaṁ navamaṁ."
    }
  ]
}
