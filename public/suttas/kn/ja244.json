{
  "uid": "ja244",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja244:1.1",
      "pali": "“Yaṁ passati na taṁ icchati,"
    },
    {
      "id": "ja244:1.2",
      "pali": "Yañca na passati taṁ kiricchati;"
    },
    {
      "id": "ja244:1.3",
      "pali": "Maññāmi ciraṁ carissati,"
    },
    {
      "id": "ja244:1.4",
      "pali": "Na hi taṁ lacchati yaṁ sa icchati."
    },
    {
      "id": "ja244:2.1",
      "pali": "Yaṁ labhati na tena tussati,"
    },
    {
      "id": "ja244:2.2",
      "pali": "Yañca pattheti laddhaṁ hīḷeti;"
    },
    {
      "id": "ja244:2.3",
      "pali": "Icchā hi anantagocarā,"
    },
    {
      "id": "ja244:2.4",
      "pali": "Vigaticchāna namo karomase”ti."
    },
    {
      "id": "ja244:3.1",
      "pali": "Vigaticchajātakaṁ catutthaṁ."
    }
  ]
}
