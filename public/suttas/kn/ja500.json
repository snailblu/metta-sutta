{
  "uid": "ja500",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja500:1.1",
      "pali": "“Paññāyupetaṁ siriyā vihīnaṁ,"
    },
    {
      "id": "ja500:1.2",
      "pali": "Yasassinaṁ vāpi apetapaññaṁ;"
    },
    {
      "id": "ja500:1.3",
      "pali": "Pucchāmi taṁ senaka etamatthaṁ,"
    },
    {
      "id": "ja500:1.4",
      "pali": "Kamettha seyyo kusalā vadanti”."
    },
    {
      "id": "ja500:2.1",
      "pali": "“Dhīrā ca bālā ca have janinda,"
    },
    {
      "id": "ja500:2.2",
      "pali": "Sippūpapannā ca asippino ca;"
    },
    {
      "id": "ja500:2.3",
      "pali": "Sujātimantopi ajātimassa,"
    },
    {
      "id": "ja500:2.4",
      "pali": "Yasassino pesakarā bhavanti;"
    },
    {
      "id": "ja500:2.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:2.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:3.1",
      "pali": "“Tuvampi pucchāmi anomapañña,"
    },
    {
      "id": "ja500:3.2",
      "pali": "Mahosadha kevaladhammadassi;"
    },
    {
      "id": "ja500:3.3",
      "pali": "Bālaṁ yasassiṁ paṇḍitaṁ appabhogaṁ,"
    },
    {
      "id": "ja500:3.4",
      "pali": "Kamettha seyyo kusalā vadanti”."
    },
    {
      "id": "ja500:4.1",
      "pali": "“Pāpāni kammāni karoti bālo,"
    },
    {
      "id": "ja500:4.2",
      "pali": "Idhameva seyyo iti maññamāno;"
    },
    {
      "id": "ja500:4.3",
      "pali": "Idhalokadassī paralokamadassī,"
    },
    {
      "id": "ja500:4.4",
      "pali": "Ubhayattha bālo kalimaggahesi;"
    },
    {
      "id": "ja500:4.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:4.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:5.1",
      "pali": "“Na sippametaṁ vidadhāti bhogaṁ,"
    },
    {
      "id": "ja500:5.2",
      "pali": "Na bandhuvā na sarīravaṇṇo yo;"
    },
    {
      "id": "ja500:5.3",
      "pali": "Passeḷamūgaṁ sukhamedhamānaṁ,"
    },
    {
      "id": "ja500:5.4",
      "pali": "Sirī hi naṁ bhajate goravindaṁ;"
    },
    {
      "id": "ja500:5.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:5.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:6.1",
      "pali": "“Laddhā sukhaṁ majjati appapañño,"
    },
    {
      "id": "ja500:6.2",
      "pali": "Dukkhena phuṭṭhopi pamohameti;"
    },
    {
      "id": "ja500:6.3",
      "pali": "Āgantunā dukkhasukhena phuṭṭho,"
    },
    {
      "id": "ja500:6.4",
      "pali": "Pavedhati vāricarova ghamme;"
    },
    {
      "id": "ja500:6.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:6.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:7.1",
      "pali": "“Dumaṁ yathā sāduphalaṁ araññe,"
    },
    {
      "id": "ja500:7.2",
      "pali": "Samantato samabhisaranti pakkhī;"
    },
    {
      "id": "ja500:7.3",
      "pali": "Evampi aḍḍhaṁ sadhanaṁ sabhogaṁ,"
    },
    {
      "id": "ja500:7.4",
      "pali": "Bahujjano bhajati atthahetu;"
    },
    {
      "id": "ja500:7.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:7.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:8.1",
      "pali": "“Na sādhu balavā bālo,"
    },
    {
      "id": "ja500:8.2",
      "pali": "Sāhasā vindate dhanaṁ;"
    },
    {
      "id": "ja500:8.3",
      "pali": "Kandantametaṁ dummedhaṁ,"
    },
    {
      "id": "ja500:8.4",
      "pali": "Kaḍḍhanti nirayaṁ bhusaṁ;"
    },
    {
      "id": "ja500:8.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:8.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:9.1",
      "pali": "“Yā kāci najjo gaṅgamabhissavanti,"
    },
    {
      "id": "ja500:9.2",
      "pali": "Sabbāva tā nāmagottaṁ jahanti;"
    },
    {
      "id": "ja500:9.3",
      "pali": "Gaṅgā samuddaṁ paṭipajjamānā,"
    },
    {
      "id": "ja500:9.4",
      "pali": "Na khāyate iddhiṁ paññopi loke;"
    },
    {
      "id": "ja500:9.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:9.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:10.1",
      "pali": "“Yametamakkhā udadhiṁ mahantaṁ,"
    },
    {
      "id": "ja500:10.2",
      "pali": "Savanti najjo sabbakālamasaṅkhyaṁ;"
    },
    {
      "id": "ja500:10.3",
      "pali": "So sāgaro niccamuḷāravego,"
    },
    {
      "id": "ja500:10.4",
      "pali": "Velaṁ na acceti mahāsamuddo."
    },
    {
      "id": "ja500:11.1",
      "pali": "Evampi bālassa pajappitāni,"
    },
    {
      "id": "ja500:11.2",
      "pali": "Paññaṁ na acceti sirī kadāci;"
    },
    {
      "id": "ja500:11.3",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:11.4",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:12.1",
      "pali": "“Asaññato cepi paresamatthaṁ,"
    },
    {
      "id": "ja500:12.2",
      "pali": "Bhaṇāti sandhānagato yasassī;"
    },
    {
      "id": "ja500:12.3",
      "pali": "Tasseva taṁ rūhati ñātimajjhe,"
    },
    {
      "id": "ja500:12.4",
      "pali": "Sirī hi naṁ kārayate na paññā;"
    },
    {
      "id": "ja500:12.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:12.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:13.1",
      "pali": "“Parassa vā attano vāpi hetu,"
    },
    {
      "id": "ja500:13.2",
      "pali": "Bālo musā bhāsati appapañño;"
    },
    {
      "id": "ja500:13.3",
      "pali": "So nindito hoti sabhāya majjhe,"
    },
    {
      "id": "ja500:13.4",
      "pali": "Pacchāpi so duggatigāmī hoti;"
    },
    {
      "id": "ja500:13.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:13.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:14.1",
      "pali": "“Atthampi ce bhāsati bhūripañño,"
    },
    {
      "id": "ja500:14.2",
      "pali": "Anāḷhiyo appadhano daliddo;"
    },
    {
      "id": "ja500:14.3",
      "pali": "Na tassa taṁ rūhati ñātimajjhe,"
    },
    {
      "id": "ja500:14.4",
      "pali": "Sirī ca paññāṇavato na hoti;"
    },
    {
      "id": "ja500:14.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:14.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:15.1",
      "pali": "“Parassa vā attano vāpi hetu,"
    },
    {
      "id": "ja500:15.2",
      "pali": "Na bhāsati alikaṁ bhūripañño;"
    },
    {
      "id": "ja500:15.3",
      "pali": "So pūjito hoti sabhāya majjhe,"
    },
    {
      "id": "ja500:15.4",
      "pali": "Pacchāpi so suggatigāmī hoti;"
    },
    {
      "id": "ja500:15.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:15.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:16.1",
      "pali": "“Hatthī gavassā maṇikuṇḍalā ca,"
    },
    {
      "id": "ja500:16.2",
      "pali": "Thiyo ca iddhesu kulesu jātā;"
    },
    {
      "id": "ja500:16.3",
      "pali": "Sabbāva tā upabhogā bhavanti,"
    },
    {
      "id": "ja500:16.4",
      "pali": "Iddhassa posassa aniddhimanto;"
    },
    {
      "id": "ja500:16.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:16.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:17.1",
      "pali": "“Asaṁvihitakammantaṁ,"
    },
    {
      "id": "ja500:17.2",
      "pali": "Bālaṁ dummedhamantinaṁ;"
    },
    {
      "id": "ja500:17.3",
      "pali": "Sirī jahati dummedhaṁ,"
    },
    {
      "id": "ja500:17.4",
      "pali": "Jiṇṇaṁva urago tacaṁ;"
    },
    {
      "id": "ja500:17.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:17.6",
      "pali": "Paññova seyyo na yasassi bālo”."
    },
    {
      "id": "ja500:18.1",
      "pali": "“Pañca paṇḍitā mayaṁ bhaddante,"
    },
    {
      "id": "ja500:18.2",
      "pali": "Sabbe pañjalikā upaṭṭhitā;"
    },
    {
      "id": "ja500:18.3",
      "pali": "Tvaṁ no abhibhuyya issarosi,"
    },
    {
      "id": "ja500:18.4",
      "pali": "Sakkova bhūtapati devarājā;"
    },
    {
      "id": "ja500:18.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:18.6",
      "pali": "Pañño nihīno sirīmāva seyyo”."
    },
    {
      "id": "ja500:19.1",
      "pali": "“Dāsova paññassa yasassi bālo,"
    },
    {
      "id": "ja500:19.2",
      "pali": "Atthesu jātesu tathāvidhesu;"
    },
    {
      "id": "ja500:19.3",
      "pali": "Yaṁ paṇḍito nipuṇaṁ saṁvidheti,"
    },
    {
      "id": "ja500:19.4",
      "pali": "Sammohamāpajjati tattha bālo;"
    },
    {
      "id": "ja500:19.5",
      "pali": "Etampi disvāna ahaṁ vadāmi,"
    },
    {
      "id": "ja500:19.6",
      "pali": "Paññova seyyo na yasassi bālo."
    },
    {
      "id": "ja500:20.1",
      "pali": "Addhā hi paññāva sataṁ pasatthā,"
    },
    {
      "id": "ja500:20.2",
      "pali": "Kantā sirī bhogaratā manussā;"
    },
    {
      "id": "ja500:20.3",
      "pali": "Ñāṇañca buddhānamatulyarūpaṁ,"
    },
    {
      "id": "ja500:20.4",
      "pali": "Paññaṁ na acceti sirī kadāci”."
    },
    {
      "id": "ja500:21.1",
      "pali": "“Yaṁ taṁ apucchimha akittayī no,"
    },
    {
      "id": "ja500:21.2",
      "pali": "Mahosadha kevaladhammadassī;"
    },
    {
      "id": "ja500:21.3",
      "pali": "Gavaṁ sahassaṁ usabhañca nāgaṁ,"
    },
    {
      "id": "ja500:21.4",
      "pali": "Ājaññayutte ca rathe dasa ime;"
    },
    {
      "id": "ja500:21.5",
      "pali": "Pañhassa veyyākaraṇena tuṭṭho,"
    },
    {
      "id": "ja500:21.6",
      "pali": "Dadāmi te gāmavarāni soḷasā”ti."
    },
    {
      "id": "ja500:22.1",
      "pali": "Sirīmantajātakaṁ catutthaṁ."
    }
  ]
}
