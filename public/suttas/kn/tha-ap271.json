{
  "uid": "tha-ap271",
  "title": "9 Upāgatāsayattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap271:1.1",
      "pali": "“Himavantassa vemajjhe,"
    },
    {
      "id": "tha-ap271:1.2",
      "pali": "saro āsi sunimmito;"
    },
    {
      "id": "tha-ap271:1.3",
      "pali": "Tatthāhaṁ rakkhaso āsiṁ,"
    },
    {
      "id": "tha-ap271:1.4",
      "pali": "heṭhasīlo bhayānako."
    },
    {
      "id": "tha-ap271:2.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap271:2.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "tha-ap271:2.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap271:2.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap271:3.1",
      "pali": "Upāgataṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap271:3.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap271:3.3",
      "pali": "Āsayā abhinikkhamma,"
    },
    {
      "id": "tha-ap271:3.4",
      "pali": "avandiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap271:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap271:4.2",
      "pali": "yaṁ vandiṁ purisuttamaṁ;"
    },
    {
      "id": "tha-ap271:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap271:4.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap271:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap271:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap271:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap271:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā upāgatāsayo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap271:7.1",
      "pali": "Upāgatāsayattherassāpadānaṁ navamaṁ."
    }
  ]
}
