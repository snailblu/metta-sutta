{
  "uid": "tha-ap121",
  "title": "Paccupaṭṭhānasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap121:1.1",
      "pali": "“Atthadassimhi sugate,"
    },
    {
      "id": "tha-ap121:1.2",
      "pali": "nibbute samanantarā;"
    },
    {
      "id": "tha-ap121:1.3",
      "pali": "Yakkhayoniṁ upapajjiṁ,"
    },
    {
      "id": "tha-ap121:1.4",
      "pali": "yasaṁ patto cahaṁ tadā."
    },
    {
      "id": "tha-ap121:2.1",
      "pali": "Dulladdhaṁ vata me āsi,"
    },
    {
      "id": "tha-ap121:2.2",
      "pali": "duppabhātaṁ duruṭṭhitaṁ;"
    },
    {
      "id": "tha-ap121:2.3",
      "pali": "Yaṁ me bhoge vijjamāne,"
    },
    {
      "id": "tha-ap121:2.4",
      "pali": "parinibbāyi cakkhumā."
    },
    {
      "id": "tha-ap121:3.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap121:3.2",
      "pali": "sāgaro nāma sāvako;"
    },
    {
      "id": "tha-ap121:3.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap121:3.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap121:4.1",
      "pali": "Kiṁ nu socasi mā bhāyi,"
    },
    {
      "id": "tha-ap121:4.2",
      "pali": "cara dhammaṁ sumedhasa;"
    },
    {
      "id": "tha-ap121:4.3",
      "pali": "Anuppadinnā buddhena,"
    },
    {
      "id": "tha-ap121:4.4",
      "pali": "sabbesaṁ bījasampadā."
    },
    {
      "id": "tha-ap121:5.1",
      "pali": "Yo ce pūjeyya sambuddhaṁ,"
    },
    {
      "id": "tha-ap121:5.2",
      "pali": "tiṭṭhantaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap121:5.3",
      "pali": "Dhātuṁ sāsapamattampi,"
    },
    {
      "id": "tha-ap121:5.4",
      "pali": "nibbutassāpi pūjaye."
    },
    {
      "id": "tha-ap121:6.1",
      "pali": "Same cittappasādamhi,"
    },
    {
      "id": "tha-ap121:6.2",
      "pali": "samaṁ puññaṁ mahaggataṁ;"
    },
    {
      "id": "tha-ap121:6.3",
      "pali": "Tasmā thūpaṁ karitvāna,"
    },
    {
      "id": "tha-ap121:6.4",
      "pali": "pūjehi jinadhātuyo."
    },
    {
      "id": "tha-ap121:7.1",
      "pali": "Sāgarassa vaco sutvā,"
    },
    {
      "id": "tha-ap121:7.2",
      "pali": "buddhathūpaṁ akāsahaṁ;"
    },
    {
      "id": "tha-ap121:7.3",
      "pali": "Pañcavasse paricariṁ,"
    },
    {
      "id": "tha-ap121:7.4",
      "pali": "munino thūpamuttamaṁ."
    },
    {
      "id": "tha-ap121:8.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap121:8.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap121:8.3",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "tha-ap121:8.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap121:9.1",
      "pali": "Bhūripaññā ca cattāro,"
    },
    {
      "id": "tha-ap121:9.2",
      "pali": "sattakappasate ito;"
    },
    {
      "id": "tha-ap121:9.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap121:9.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap121:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap121:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap121:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap121:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā paccupaṭṭhānasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap121:12.1",
      "pali": "Paccupaṭṭhānasaññakattherassāpadānaṁ navamaṁ."
    }
  ]
}
