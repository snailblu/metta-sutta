{
  "uid": "ja353",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja353:1.1",
      "pali": "“Nayidaṁ niccaṁ bhavitabbaṁ brahmadatta,"
    },
    {
      "id": "ja353:1.2",
      "pali": "Khemaṁ subhikkhaṁ sukhatā ca kāye;"
    },
    {
      "id": "ja353:1.3",
      "pali": "Atthaccaye mā ahu sampamūḷho,"
    },
    {
      "id": "ja353:1.4",
      "pali": "Bhinnaplavo sāgarasseva majjhe."
    },
    {
      "id": "ja353:2.1",
      "pali": "Yāni karoti puriso,"
    },
    {
      "id": "ja353:2.2",
      "pali": "tāni attani passati;"
    },
    {
      "id": "ja353:2.3",
      "pali": "Kalyāṇakārī kalyāṇaṁ,"
    },
    {
      "id": "ja353:2.4",
      "pali": "pāpakārī ca pāpakaṁ;"
    },
    {
      "id": "ja353:2.5",
      "pali": "Yādisaṁ vapate bījaṁ,"
    },
    {
      "id": "ja353:2.6",
      "pali": "tādisaṁ harate phalaṁ”."
    },
    {
      "id": "ja353:3.1",
      "pali": "“Idaṁ tadācariyavaco,"
    },
    {
      "id": "ja353:3.2",
      "pali": "pārāsariyo yadabravi;"
    },
    {
      "id": "ja353:3.3",
      "pali": "Mā su tvaṁ akari pāpaṁ,"
    },
    {
      "id": "ja353:3.4",
      "pali": "yaṁ tvaṁ pacchā kataṁ tape."
    },
    {
      "id": "ja353:4.1",
      "pali": "Ayameva so piṅgiya venasākho,"
    },
    {
      "id": "ja353:4.2",
      "pali": "Yamhi ghātayiṁ khattiyānaṁ sahassaṁ;"
    },
    {
      "id": "ja353:4.3",
      "pali": "Alaṅkate candanasārānulitte,"
    },
    {
      "id": "ja353:4.4",
      "pali": "Tameva dukkhaṁ paccāgataṁ mamaṁ."
    },
    {
      "id": "ja353:5.1",
      "pali": "Sāmā ca kho candanalittagattā,"
    },
    {
      "id": "ja353:5.2",
      "pali": "Laṭṭhīva sobhañjanakassa uggatā;"
    },
    {
      "id": "ja353:5.3",
      "pali": "Adisvā kālaṁ karissāmi ubbariṁ,"
    },
    {
      "id": "ja353:5.4",
      "pali": "Taṁ me ito dukkhataraṁ bhavissatī”ti."
    },
    {
      "id": "ja353:6.1",
      "pali": "Venasākhajātakaṁ tatiyaṁ."
    }
  ]
}
