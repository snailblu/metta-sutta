{
  "uid": "tha-ap336",
  "title": "Ekadussadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap336:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap336:1.2",
      "pali": "ahosiṁ tiṇahārako;"
    },
    {
      "id": "tha-ap336:1.3",
      "pali": "Tiṇahārena jīvāmi,"
    },
    {
      "id": "tha-ap336:1.4",
      "pali": "tena posemi dārake."
    },
    {
      "id": "tha-ap336:2.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap336:2.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap336:2.3",
      "pali": "Tamandhakāraṁ nāsetvā,"
    },
    {
      "id": "tha-ap336:2.4",
      "pali": "uppajji lokanāyako."
    },
    {
      "id": "tha-ap336:3.1",
      "pali": "Sake ghare nisīditvā,"
    },
    {
      "id": "tha-ap336:3.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "tha-ap336:3.3",
      "pali": "‘Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap336:3.4",
      "pali": "deyyadhammo ca natthi me."
    },
    {
      "id": "tha-ap336:4.1",
      "pali": "Idaṁ me sāṭakaṁ ekaṁ,"
    },
    {
      "id": "tha-ap336:4.2",
      "pali": "natthi me koci dāyako;"
    },
    {
      "id": "tha-ap336:4.3",
      "pali": "Dukkho nirayasamphasso,"
    },
    {
      "id": "tha-ap336:4.4",
      "pali": "ropayissāmi dakkhiṇaṁ’."
    },
    {
      "id": "tha-ap336:5.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "tha-ap336:5.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap336:5.3",
      "pali": "Ekaṁ dussaṁ gahetvāna,"
    },
    {
      "id": "tha-ap336:5.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap336:6.1",
      "pali": "Ekaṁ dussaṁ daditvāna,"
    },
    {
      "id": "tha-ap336:6.2",
      "pali": "ukkuṭṭhiṁ sampavattayiṁ;"
    },
    {
      "id": "tha-ap336:6.3",
      "pali": "Yadi buddho tuvaṁ vīra,"
    },
    {
      "id": "tha-ap336:6.4",
      "pali": "tārehi maṁ mahāmuni."
    },
    {
      "id": "tha-ap336:7.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap336:7.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap336:7.3",
      "pali": "Mama dānaṁ pakittento,"
    },
    {
      "id": "tha-ap336:7.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap336:8.1",
      "pali": "‘Iminā ekadussena,"
    },
    {
      "id": "tha-ap336:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap336:8.3",
      "pali": "Kappasatasahassāni,"
    },
    {
      "id": "tha-ap336:8.4",
      "pali": "vinipātaṁ na gacchati."
    },
    {
      "id": "tha-ap336:9.1",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap336:9.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap336:9.3",
      "pali": "Tettiṁsakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap336:9.4",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap336:9.5",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap336:9.6",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap336:10.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap336:10.2",
      "pali": "saṁsaranto tuvaṁ bhave;"
    },
    {
      "id": "tha-ap336:10.3",
      "pali": "Rūpavā guṇasampanno,"
    },
    {
      "id": "tha-ap336:10.4",
      "pali": "anavakkantadehavā;"
    },
    {
      "id": "tha-ap336:10.5",
      "pali": "Akkhobhaṁ amitaṁ dussaṁ,"
    },
    {
      "id": "tha-ap336:10.6",
      "pali": "labhissati yadicchakaṁ’."
    },
    {
      "id": "tha-ap336:11.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap336:11.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap336:11.3",
      "pali": "Nabhaṁ abbhuggamī dhīro,"
    },
    {
      "id": "tha-ap336:11.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap336:12.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap336:12.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap336:12.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap336:12.4",
      "pali": "ekadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap336:13.1",
      "pali": "Paduddhāre paduddhāre,"
    },
    {
      "id": "tha-ap336:13.2",
      "pali": "dussaṁ nibbattate mamaṁ;"
    },
    {
      "id": "tha-ap336:13.3",
      "pali": "Heṭṭhā dussamhi tiṭṭhāmi,"
    },
    {
      "id": "tha-ap336:13.4",
      "pali": "upari chadanaṁ mama."
    },
    {
      "id": "tha-ap336:14.1",
      "pali": "Cakkavāḷamupādāya,"
    },
    {
      "id": "tha-ap336:14.2",
      "pali": "sakānanaṁ sapabbataṁ;"
    },
    {
      "id": "tha-ap336:14.3",
      "pali": "Icchamāno cahaṁ ajja,"
    },
    {
      "id": "tha-ap336:14.4",
      "pali": "dussehi chādayeyyahaṁ."
    },
    {
      "id": "tha-ap336:15.1",
      "pali": "Teneva ekadussena,"
    },
    {
      "id": "tha-ap336:15.2",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "tha-ap336:15.3",
      "pali": "Suvaṇṇavaṇṇo hutvāna,"
    },
    {
      "id": "tha-ap336:15.4",
      "pali": "saṁsarāmi bhavābhave."
    },
    {
      "id": "tha-ap336:16.1",
      "pali": "Vipākaṁ ekadussassa,"
    },
    {
      "id": "tha-ap336:16.2",
      "pali": "najjhagaṁ katthacikkhayaṁ;"
    },
    {
      "id": "tha-ap336:16.3",
      "pali": "Ayaṁ me antimā jāti,"
    },
    {
      "id": "tha-ap336:16.4",
      "pali": "vipaccati idhāpi me."
    },
    {
      "id": "tha-ap336:17.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap336:17.2",
      "pali": "yaṁ dussamadadiṁ tadā;"
    },
    {
      "id": "tha-ap336:17.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap336:17.4",
      "pali": "ekadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap336:18.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap336:18.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap336:18.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap336:18.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap336:19.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap336:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap336:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap336:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekadussadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap336:21.1",
      "pali": "Ekadussadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
