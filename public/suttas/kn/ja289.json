{
  "uid": "ja289",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja289:1.1",
      "pali": "“Nānāchandā mahārāja,"
    },
    {
      "id": "ja289:1.2",
      "pali": "ekāgāre vasāmase;"
    },
    {
      "id": "ja289:1.3",
      "pali": "Ahaṁ gāmavaraṁ icche,"
    },
    {
      "id": "ja289:1.4",
      "pali": "brāhmaṇī ca gavaṁ sataṁ”."
    },
    {
      "id": "ja289:2.1",
      "pali": "Putto ca ājaññarathaṁ,"
    },
    {
      "id": "ja289:2.2",
      "pali": "kaññā ca maṇikuṇḍalaṁ;"
    },
    {
      "id": "ja289:2.3",
      "pali": "Yā cesā puṇṇikā jammī,"
    },
    {
      "id": "ja289:2.4",
      "pali": "udukkhalaṁbhikaṅkhati."
    },
    {
      "id": "ja289:3.1",
      "pali": "“Brāhmaṇassa gāmavaraṁ,"
    },
    {
      "id": "ja289:3.2",
      "pali": "brāhmaṇiyā gavaṁ sataṁ;"
    },
    {
      "id": "ja289:3.3",
      "pali": "Puttassa ājaññarathaṁ,"
    },
    {
      "id": "ja289:3.4",
      "pali": "kaññāya maṇikuṇḍalaṁ;"
    },
    {
      "id": "ja289:3.5",
      "pali": "Yañcetaṁ puṇṇikaṁ jammiṁ,"
    },
    {
      "id": "ja289:3.6",
      "pali": "paṭipādethudukkhalan”ti."
    },
    {
      "id": "ja289:4.1",
      "pali": "Nānāchandajātakaṁ navamaṁ."
    }
  ]
}
