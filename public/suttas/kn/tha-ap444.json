{
  "uid": "tha-ap444",
  "title": "Koladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap444:1.1",
      "pali": "“Ajinena nivatthohaṁ,"
    },
    {
      "id": "tha-ap444:1.2",
      "pali": "Vākacīradharo tadā;"
    },
    {
      "id": "tha-ap444:1.3",
      "pali": "Khāriyā pūrayitvāna,"
    },
    {
      "id": "tha-ap444:1.4",
      "pali": "Kolaṁhāsiṁ mamassamaṁ."
    },
    {
      "id": "tha-ap444:2.1",
      "pali": "Tamhi kāle sikhī buddho,"
    },
    {
      "id": "tha-ap444:2.2",
      "pali": "eko adutiyo ahu;"
    },
    {
      "id": "tha-ap444:2.3",
      "pali": "Mamassamaṁ upāgacchi,"
    },
    {
      "id": "tha-ap444:2.4",
      "pali": "jānanto sabbakālikaṁ."
    },
    {
      "id": "tha-ap444:3.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap444:3.2",
      "pali": "vanditvāna ca subbataṁ;"
    },
    {
      "id": "tha-ap444:3.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap444:3.4",
      "pali": "kolaṁ buddhassadāsahaṁ."
    },
    {
      "id": "tha-ap444:4.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap444:4.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap444:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap444:4.4",
      "pali": "koladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap444:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap444:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap444:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap444:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap444:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap444:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap444:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap444:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap444:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap444:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā koladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap444:9.1",
      "pali": "Koladāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
