{
  "uid": "thag1.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.4:1.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "thag1.4:1.2",
      "pali": "paṇḍitehatthadassibhi;"
    },
    {
      "id": "thag1.4:1.3",
      "pali": "Atthaṁ mahantaṁ gambhīraṁ,"
    },
    {
      "id": "thag1.4:1.4",
      "pali": "duddasaṁ nipuṇaṁ aṇuṁ;"
    },
    {
      "id": "thag1.4:1.5",
      "pali": "Dhīrā samadhigacchanti,"
    },
    {
      "id": "thag1.4:1.6",
      "pali": "appamattā vicakkhaṇā”ti."
    },
    {
      "id": "thag1.4:1.7",
      "pali": "Itthaṁ sudaṁ āyasmā puṇṇo mantāṇiputto thero gāthaṁ abhāsitthāti."
    }
  ]
}
