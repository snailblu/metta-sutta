{
  "uid": "tha-ap521",
  "title": "Sabbaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap521:1.1",
      "pali": "“Varuṇo nāma nāmena,"
    },
    {
      "id": "tha-ap521:1.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap521:1.3",
      "pali": "Chaḍḍetvā dasa puttāni,"
    },
    {
      "id": "tha-ap521:1.4",
      "pali": "vanamajjhogahiṁ tadā."
    },
    {
      "id": "tha-ap521:2.1",
      "pali": "Assamaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap521:2.2",
      "pali": "suvibhattaṁ manoramaṁ;"
    },
    {
      "id": "tha-ap521:2.3",
      "pali": "Paṇṇasālaṁ karitvāna,"
    },
    {
      "id": "tha-ap521:2.4",
      "pali": "vasāmi vipine ahaṁ."
    },
    {
      "id": "tha-ap521:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap521:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap521:3.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap521:3.4",
      "pali": "āgacchi mama assamaṁ."
    },
    {
      "id": "tha-ap521:4.1",
      "pali": "Yāvatā vanasaṇḍamhi,"
    },
    {
      "id": "tha-ap521:4.2",
      "pali": "obhāso vipulo ahu;"
    },
    {
      "id": "tha-ap521:4.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap521:4.4",
      "pali": "pajjalī vipinaṁ tadā."
    },
    {
      "id": "tha-ap521:5.1",
      "pali": "Disvāna taṁ pāṭihīraṁ,"
    },
    {
      "id": "tha-ap521:5.2",
      "pali": "buddhaseṭṭhassa tādino;"
    },
    {
      "id": "tha-ap521:5.3",
      "pali": "Pattapuṭaṁ gahetvāna,"
    },
    {
      "id": "tha-ap521:5.4",
      "pali": "phalena pūjayiṁ ahaṁ."
    },
    {
      "id": "tha-ap521:6.1",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap521:6.2",
      "pali": "sahakhārimadāsahaṁ;"
    },
    {
      "id": "tha-ap521:6.3",
      "pali": "Anukampāya me buddho,"
    },
    {
      "id": "tha-ap521:6.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "tha-ap521:7.1",
      "pali": "‘Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap521:7.2",
      "pali": "pacchato ehi me tuvaṁ;"
    },
    {
      "id": "tha-ap521:7.3",
      "pali": "Paribhutte ca saṅghamhi,"
    },
    {
      "id": "tha-ap521:7.4",
      "pali": "puññaṁ tava bhavissati’."
    },
    {
      "id": "tha-ap521:8.1",
      "pali": "Puṭakantaṁ gahetvāna,"
    },
    {
      "id": "tha-ap521:8.2",
      "pali": "bhikkhusaṅghassadāsahaṁ;"
    },
    {
      "id": "tha-ap521:8.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap521:8.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap521:9.1",
      "pali": "Tattha dibbehi naccehi,"
    },
    {
      "id": "tha-ap521:9.2",
      "pali": "gītehi vāditehi ca;"
    },
    {
      "id": "tha-ap521:9.3",
      "pali": "Puññakammena saṁyuttaṁ,"
    },
    {
      "id": "tha-ap521:9.4",
      "pali": "anubhomi sadā sukhaṁ."
    },
    {
      "id": "tha-ap521:10.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap521:10.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap521:10.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap521:10.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:11.1",
      "pali": "Yāvatā caturo dīpā,"
    },
    {
      "id": "tha-ap521:11.2",
      "pali": "sasamuddā sapabbatā;"
    },
    {
      "id": "tha-ap521:11.3",
      "pali": "Phalaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap521:11.4",
      "pali": "issaraṁ kārayāmahaṁ."
    },
    {
      "id": "tha-ap521:12.1",
      "pali": "Yāvatā me pakkhigaṇā,"
    },
    {
      "id": "tha-ap521:12.2",
      "pali": "ākāse uppatanti ce;"
    },
    {
      "id": "tha-ap521:12.3",
      "pali": "Tepi maṁ vasamanventi,"
    },
    {
      "id": "tha-ap521:12.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:13.1",
      "pali": "Yāvatā vanasaṇḍamhi,"
    },
    {
      "id": "tha-ap521:13.2",
      "pali": "yakkhā bhūtā ca rakkhasā;"
    },
    {
      "id": "tha-ap521:13.3",
      "pali": "Kumbhaṇḍā garuḷā cāpi,"
    },
    {
      "id": "tha-ap521:13.4",
      "pali": "pāricariyaṁ upenti me."
    },
    {
      "id": "tha-ap521:14.1",
      "pali": "Kummā soṇā madhukārā,"
    },
    {
      "id": "tha-ap521:14.2",
      "pali": "ḍaṁsā ca makasā ubho;"
    },
    {
      "id": "tha-ap521:14.3",
      "pali": "Tepi maṁ vasamanventi,"
    },
    {
      "id": "tha-ap521:14.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:15.1",
      "pali": "Supaṇṇā nāma sakuṇā,"
    },
    {
      "id": "tha-ap521:15.2",
      "pali": "pakkhijātā mahabbalā;"
    },
    {
      "id": "tha-ap521:15.3",
      "pali": "Tepi maṁ saraṇaṁ yanti,"
    },
    {
      "id": "tha-ap521:15.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:16.1",
      "pali": "Yepi dīghāyukā nāgā,"
    },
    {
      "id": "tha-ap521:16.2",
      "pali": "iddhimanto mahāyasā;"
    },
    {
      "id": "tha-ap521:16.3",
      "pali": "Tepi maṁ vasamanventi,"
    },
    {
      "id": "tha-ap521:16.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:17.1",
      "pali": "Sīhā byagghā ca dīpī ca,"
    },
    {
      "id": "tha-ap521:17.2",
      "pali": "acchakokataracchakā;"
    },
    {
      "id": "tha-ap521:17.3",
      "pali": "Tepi maṁ vasamanventi,"
    },
    {
      "id": "tha-ap521:17.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:18.1",
      "pali": "Osadhītiṇavāsī ca,"
    },
    {
      "id": "tha-ap521:18.2",
      "pali": "ye ca ākāsavāsino;"
    },
    {
      "id": "tha-ap521:18.3",
      "pali": "Sabbe maṁ saraṇaṁ yanti,"
    },
    {
      "id": "tha-ap521:18.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:19.1",
      "pali": "Sududdasaṁ sunipuṇaṁ,"
    },
    {
      "id": "tha-ap521:19.2",
      "pali": "gambhīraṁ suppakāsitaṁ;"
    },
    {
      "id": "tha-ap521:19.3",
      "pali": "Phassayitvā viharāmi,"
    },
    {
      "id": "tha-ap521:19.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:20.1",
      "pali": "Vimokkhe aṭṭha phusitvā,"
    },
    {
      "id": "tha-ap521:20.2",
      "pali": "viharāmi anāsavo;"
    },
    {
      "id": "tha-ap521:20.3",
      "pali": "Ātāpī nipako cāhaṁ,"
    },
    {
      "id": "tha-ap521:20.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:21.1",
      "pali": "Ye phalaṭṭhā buddhaputtā,"
    },
    {
      "id": "tha-ap521:21.2",
      "pali": "khīṇadosā mahāyasā;"
    },
    {
      "id": "tha-ap521:21.3",
      "pali": "Ahamaññataro tesaṁ,"
    },
    {
      "id": "tha-ap521:21.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:22.1",
      "pali": "Abhiññāpāramiṁ gantvā,"
    },
    {
      "id": "tha-ap521:22.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap521:22.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap521:22.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap521:23.1",
      "pali": "Tevijjā iddhipattā ca,"
    },
    {
      "id": "tha-ap521:23.2",
      "pali": "buddhaputtā mahāyasā;"
    },
    {
      "id": "tha-ap521:23.3",
      "pali": "Dibbasotasamāpannā,"
    },
    {
      "id": "tha-ap521:23.4",
      "pali": "tesaṁ aññataro ahaṁ."
    },
    {
      "id": "tha-ap521:24.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap521:24.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap521:24.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap521:24.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap521:25.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap521:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap521:25.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap521:26.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap521:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap521:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap521:27.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap521:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap521:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap521:28.1",
      "pali": "Itthaṁ sudaṁ āyasmā sabbaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap521:29.1",
      "pali": "Sabbaphaladāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
