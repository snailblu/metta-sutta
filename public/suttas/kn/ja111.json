{
  "uid": "ja111",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja111:1.1",
      "pali": "“Haṁci tuvaṁ evamaññasi seyyo,"
    },
    {
      "id": "ja111:1.2",
      "pali": "Puttena pitāti rājaseṭṭha;"
    },
    {
      "id": "ja111:1.3",
      "pali": "Handassatarassa te ayaṁ,"
    },
    {
      "id": "ja111:1.4",
      "pali": "Assatarassa hi gadrabho pitā”ti."
    },
    {
      "id": "ja111:2.1",
      "pali": "Gadrabhapañhajātakaṁ paṭhamaṁ."
    }
  ]
}
