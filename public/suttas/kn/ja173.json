{
  "uid": "ja173",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja173:1.1",
      "pali": "“Tāta māṇavako eso,"
    },
    {
      "id": "ja173:1.2",
      "pali": "tālamūlaṁ apassito;"
    },
    {
      "id": "ja173:1.3",
      "pali": "Agārakañcidaṁ atthi,"
    },
    {
      "id": "ja173:1.4",
      "pali": "handa demassagārakaṁ”."
    },
    {
      "id": "ja173:2.1",
      "pali": "“Mā kho tvaṁ tāta pakkosi,"
    },
    {
      "id": "ja173:2.2",
      "pali": "dūseyya no agārakaṁ;"
    },
    {
      "id": "ja173:2.3",
      "pali": "Netādisaṁ mukhaṁ hoti,"
    },
    {
      "id": "ja173:2.4",
      "pali": "brāhmaṇassa susīlino”ti."
    },
    {
      "id": "ja173:3.1",
      "pali": "Makkaṭajātakaṁ tatiyaṁ."
    }
  ]
}
