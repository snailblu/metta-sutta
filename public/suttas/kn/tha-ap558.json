{
  "uid": "tha-ap558",
  "title": "Uttarattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap558:1.1",
      "pali": "“Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap558:1.2",
      "pali": "bāttiṁsavaralakkhaṇo;"
    },
    {
      "id": "tha-ap558:1.3",
      "pali": "Vivekakāmo bhagavā,"
    },
    {
      "id": "tha-ap558:1.4",
      "pali": "himavantamupāgami."
    },
    {
      "id": "tha-ap558:2.1",
      "pali": "Ajjhogāhetvā himavantaṁ,"
    },
    {
      "id": "tha-ap558:2.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap558:2.3",
      "pali": "Pallaṅkaṁ ābhujitvāna,"
    },
    {
      "id": "tha-ap558:2.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap558:3.1",
      "pali": "Vijjādharo tadā āsiṁ,"
    },
    {
      "id": "tha-ap558:3.2",
      "pali": "antalikkhacaro ahaṁ;"
    },
    {
      "id": "tha-ap558:3.3",
      "pali": "Tisūlaṁ sukataṁ gayha,"
    },
    {
      "id": "tha-ap558:3.4",
      "pali": "gacchāmi ambare tadā."
    },
    {
      "id": "tha-ap558:4.1",
      "pali": "Pabbatagge yathā aggi,"
    },
    {
      "id": "tha-ap558:4.2",
      "pali": "puṇṇamāyeva candimā;"
    },
    {
      "id": "tha-ap558:4.3",
      "pali": "Vanaṁ obhāsate buddho,"
    },
    {
      "id": "tha-ap558:4.4",
      "pali": "sālarājāva phullito."
    },
    {
      "id": "tha-ap558:5.1",
      "pali": "Vanaggā nikkhamitvāna,"
    },
    {
      "id": "tha-ap558:5.2",
      "pali": "buddharaṁsībhidhāvare;"
    },
    {
      "id": "tha-ap558:5.3",
      "pali": "Naḷaggivaṇṇasaṅkāsā,"
    },
    {
      "id": "tha-ap558:5.4",
      "pali": "disvā cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap558:6.1",
      "pali": "Vicinaṁ addasaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap558:6.2",
      "pali": "kaṇikāraṁ devagandhikaṁ;"
    },
    {
      "id": "tha-ap558:6.3",
      "pali": "Tīṇi pupphāni ādāya,"
    },
    {
      "id": "tha-ap558:6.4",
      "pali": "buddhaseṭṭhamapūjayiṁ."
    },
    {
      "id": "tha-ap558:7.1",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap558:7.2",
      "pali": "tīṇi pupphāni me tadā;"
    },
    {
      "id": "tha-ap558:7.3",
      "pali": "Uddhaṁ vaṇṭā adhopattā,"
    },
    {
      "id": "tha-ap558:7.4",
      "pali": "chāyaṁ kubbanti satthuno."
    },
    {
      "id": "tha-ap558:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap558:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap558:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap558:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap558:9.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap558:9.2",
      "pali": "kaṇikārīti ñāyati;"
    },
    {
      "id": "tha-ap558:9.3",
      "pali": "Saṭṭhiyojanamubbedhaṁ,"
    },
    {
      "id": "tha-ap558:9.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "tha-ap558:10.1",
      "pali": "Sahassakaṇḍaṁ satabheṇḍu,"
    },
    {
      "id": "tha-ap558:10.2",
      "pali": "dhajālu haritāmayaṁ;"
    },
    {
      "id": "tha-ap558:10.3",
      "pali": "Satasahassaniyyūhā,"
    },
    {
      "id": "tha-ap558:10.4",
      "pali": "byamhe pātubhaviṁsu me."
    },
    {
      "id": "tha-ap558:11.1",
      "pali": "Soṇṇamayā maṇimayā,"
    },
    {
      "id": "tha-ap558:11.2",
      "pali": "lohitaṅkamayāpi ca;"
    },
    {
      "id": "tha-ap558:11.3",
      "pali": "Phalikāpi ca pallaṅkā,"
    },
    {
      "id": "tha-ap558:11.4",
      "pali": "yenicchakā yadicchakā."
    },
    {
      "id": "tha-ap558:12.1",
      "pali": "Mahārahañca sayanaṁ,"
    },
    {
      "id": "tha-ap558:12.2",
      "pali": "tūlikā vikatīyutaṁ;"
    },
    {
      "id": "tha-ap558:12.3",
      "pali": "Uddhalomiñca ekantaṁ,"
    },
    {
      "id": "tha-ap558:12.4",
      "pali": "bimbohanasamāyutaṁ."
    },
    {
      "id": "tha-ap558:13.1",
      "pali": "Bhavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap558:13.2",
      "pali": "caranto devacārikaṁ;"
    },
    {
      "id": "tha-ap558:13.3",
      "pali": "Yathā icchāmi gamanaṁ,"
    },
    {
      "id": "tha-ap558:13.4",
      "pali": "devasaṅghapurakkhato."
    },
    {
      "id": "tha-ap558:14.1",
      "pali": "Pupphassa heṭṭhā tiṭṭhāmi,"
    },
    {
      "id": "tha-ap558:14.2",
      "pali": "uparicchadanaṁ mama;"
    },
    {
      "id": "tha-ap558:14.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap558:14.4",
      "pali": "kaṇikārehi chāditaṁ."
    },
    {
      "id": "tha-ap558:15.1",
      "pali": "Saṭṭhituriyasahassāni,"
    },
    {
      "id": "tha-ap558:15.2",
      "pali": "sāyapātaṁ upaṭṭhahuṁ;"
    },
    {
      "id": "tha-ap558:15.3",
      "pali": "Parivārenti maṁ niccaṁ,"
    },
    {
      "id": "tha-ap558:15.4",
      "pali": "rattindivamatanditā."
    },
    {
      "id": "tha-ap558:16.1",
      "pali": "Tattha naccehi gītehi,"
    },
    {
      "id": "tha-ap558:16.2",
      "pali": "tālehi vāditehi ca;"
    },
    {
      "id": "tha-ap558:16.3",
      "pali": "Ramāmi khiḍḍā ratiyā,"
    },
    {
      "id": "tha-ap558:16.4",
      "pali": "modāmi kāmakāmahaṁ."
    },
    {
      "id": "tha-ap558:17.1",
      "pali": "Tattha bhutvā pivitvā ca,"
    },
    {
      "id": "tha-ap558:17.2",
      "pali": "modāmi tidase tadā;"
    },
    {
      "id": "tha-ap558:17.3",
      "pali": "Nārīgaṇehi sahito,"
    },
    {
      "id": "tha-ap558:17.4",
      "pali": "modāmi byamhamuttame."
    },
    {
      "id": "tha-ap558:18.1",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap558:18.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap558:18.3",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap558:18.4",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap558:18.5",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap558:18.6",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap558:19.1",
      "pali": "Bhave bhave saṁsaranto,"
    },
    {
      "id": "tha-ap558:19.2",
      "pali": "mahābhogaṁ labhāmahaṁ;"
    },
    {
      "id": "tha-ap558:19.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap558:19.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:20.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap558:20.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap558:20.3",
      "pali": "Aññaṁ gatiṁ na jānāmi,"
    },
    {
      "id": "tha-ap558:20.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:21.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap558:21.2",
      "pali": "khattiye cāpi brāhmaṇe;"
    },
    {
      "id": "tha-ap558:21.3",
      "pali": "Nīce kule na jānāmi,"
    },
    {
      "id": "tha-ap558:21.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:22.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap558:22.2",
      "pali": "sivikaṁ sandamānikaṁ;"
    },
    {
      "id": "tha-ap558:22.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap558:22.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:23.1",
      "pali": "Dāsīgaṇaṁ dāsagaṇaṁ,"
    },
    {
      "id": "tha-ap558:23.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap558:23.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap558:23.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:24.1",
      "pali": "Koseyyakambaliyāni,"
    },
    {
      "id": "tha-ap558:24.2",
      "pali": "khomakappāsikāni ca;"
    },
    {
      "id": "tha-ap558:24.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap558:24.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:25.1",
      "pali": "Navavatthaṁ navaphalaṁ,"
    },
    {
      "id": "tha-ap558:25.2",
      "pali": "navaggarasabhojanaṁ;"
    },
    {
      "id": "tha-ap558:25.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap558:25.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:26.1",
      "pali": "Imaṁ khāda imaṁ bhuñja,"
    },
    {
      "id": "tha-ap558:26.2",
      "pali": "imamhi sayane saya;"
    },
    {
      "id": "tha-ap558:26.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap558:26.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:27.1",
      "pali": "Sabbattha pūjito homi,"
    },
    {
      "id": "tha-ap558:27.2",
      "pali": "yaso accuggato mama;"
    },
    {
      "id": "tha-ap558:27.3",
      "pali": "Mahāpakkho sadā homi,"
    },
    {
      "id": "tha-ap558:27.4",
      "pali": "abhejjapariso sadā;"
    },
    {
      "id": "tha-ap558:27.5",
      "pali": "Ñātīnaṁ uttamo homi,"
    },
    {
      "id": "tha-ap558:27.6",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:28.1",
      "pali": "Sītaṁ uṇhaṁ na jānāmi,"
    },
    {
      "id": "tha-ap558:28.2",
      "pali": "pariḷāho na vijjati;"
    },
    {
      "id": "tha-ap558:28.3",
      "pali": "Atho cetasikaṁ dukkhaṁ,"
    },
    {
      "id": "tha-ap558:28.4",
      "pali": "hadaye me na vijjati."
    },
    {
      "id": "tha-ap558:29.1",
      "pali": "Suvaṇṇavaṇṇo hutvāna,"
    },
    {
      "id": "tha-ap558:29.2",
      "pali": "saṁsarāmi bhavābhave;"
    },
    {
      "id": "tha-ap558:29.3",
      "pali": "Vevaṇṇiyaṁ na jānāmi,"
    },
    {
      "id": "tha-ap558:29.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:30.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap558:30.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap558:30.3",
      "pali": "Sāvatthiyaṁ pure jāto,"
    },
    {
      "id": "tha-ap558:30.4",
      "pali": "mahāsālesu aḍḍhake."
    },
    {
      "id": "tha-ap558:31.1",
      "pali": "Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "tha-ap558:31.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap558:31.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap558:31.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap558:32.1",
      "pali": "Upasampadāyī buddho,"
    },
    {
      "id": "tha-ap558:32.2",
      "pali": "guṇamaññāya cakkhumā;"
    },
    {
      "id": "tha-ap558:32.3",
      "pali": "Taruṇo pūjanīyohaṁ,"
    },
    {
      "id": "tha-ap558:32.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:33.1",
      "pali": "Dibbacakkhuvisuddhaṁ me,"
    },
    {
      "id": "tha-ap558:33.2",
      "pali": "samādhikusalo ahaṁ;"
    },
    {
      "id": "tha-ap558:33.3",
      "pali": "Abhiññāpāramippatto,"
    },
    {
      "id": "tha-ap558:33.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:34.1",
      "pali": "Paṭisambhidā anuppatto,"
    },
    {
      "id": "tha-ap558:34.2",
      "pali": "iddhipādesu kovido;"
    },
    {
      "id": "tha-ap558:34.3",
      "pali": "Dhammesu pāramippatto,"
    },
    {
      "id": "tha-ap558:34.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:35.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap558:35.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap558:35.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap558:35.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap558:36.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap558:36.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap558:36.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap558:37.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap558:37.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap558:37.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap558:38.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap558:38.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap558:38.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap558:39.1",
      "pali": "Itthaṁ sudaṁ āyasmā uttaro thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap558:40.1",
      "pali": "Uttarattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
