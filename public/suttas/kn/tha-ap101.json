{
  "uid": "tha-ap101",
  "title": "Veyyāvaccakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap101:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap101:1.2",
      "pali": "mahāpūgagaṇo ahu;"
    },
    {
      "id": "tha-ap101:1.3",
      "pali": "Veyyāvaccakaro āsiṁ,"
    },
    {
      "id": "tha-ap101:1.4",
      "pali": "sabbakiccesu vāvaṭo."
    },
    {
      "id": "tha-ap101:2.1",
      "pali": "Deyyadhammo ca me natthi,"
    },
    {
      "id": "tha-ap101:2.2",
      "pali": "sugatassa mahesino;"
    },
    {
      "id": "tha-ap101:2.3",
      "pali": "Avandiṁ satthuno pāde,"
    },
    {
      "id": "tha-ap101:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap101:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap101:3.2",
      "pali": "veyyāvaccaṁ akāsahaṁ;"
    },
    {
      "id": "tha-ap101:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap101:3.4",
      "pali": "veyyāvaccassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap101:4.1",
      "pali": "Ito ca aṭṭhame kappe,"
    },
    {
      "id": "tha-ap101:4.2",
      "pali": "rājā āsiṁ sucintito;"
    },
    {
      "id": "tha-ap101:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap101:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap101:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap101:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap101:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap101:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā veyyāvaccako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap101:7.1",
      "pali": "Veyyāvaccakattherassāpadānaṁ navamaṁ."
    }
  ]
}
