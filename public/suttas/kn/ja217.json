{
  "uid": "ja217",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja217:1.1",
      "pali": "“Sabbo loko attamano ahosi,"
    },
    {
      "id": "ja217:1.2",
      "pali": "Akovidā gāmadhammassa seggu;"
    },
    {
      "id": "ja217:1.3",
      "pali": "Komāri ko nāma tavajja dhammo,"
    },
    {
      "id": "ja217:1.4",
      "pali": "Yaṁ tvaṁ gahitā pavane parodasi”."
    },
    {
      "id": "ja217:2.1",
      "pali": "“Yo dukkhaphuṭṭhāya bhaveyya tāṇaṁ,"
    },
    {
      "id": "ja217:2.2",
      "pali": "So me pitā dubbhi vane karoti;"
    },
    {
      "id": "ja217:2.3",
      "pali": "Sā kassa kandāmi vanassa majjhe,"
    },
    {
      "id": "ja217:2.4",
      "pali": "Yo tāyitā so sahasaṁ karotī”ti."
    },
    {
      "id": "ja217:3.1",
      "pali": "Seggujātakaṁ sattamaṁ."
    }
  ]
}
