{
  "uid": "iti51",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti51:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti51:2.1",
      "pali": "“Tisso imā, bhikkhave, dhātuyo."
    },
    {
      "id": "iti51:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti51:2.3",
      "pali": "Rūpadhātu, arūpadhātu, nirodhadhātu—"
    },
    {
      "id": "iti51:2.4",
      "pali": "imā kho, bhikkhave, tisso dhātuyo”ti."
    },
    {
      "id": "iti51:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti51:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti51:3.1",
      "pali": "“Rūpadhātuṁ pariññāya,"
    },
    {
      "id": "iti51:3.2",
      "pali": "āruppesu asaṇṭhitā;"
    },
    {
      "id": "iti51:3.3",
      "pali": "Nirodhe ye vimuccanti,"
    },
    {
      "id": "iti51:3.4",
      "pali": "te janā maccuhāyino."
    },
    {
      "id": "iti51:4.1",
      "pali": "Kāyena amataṁ dhātuṁ,"
    },
    {
      "id": "iti51:4.2",
      "pali": "phusayitvā nirūpadhiṁ;"
    },
    {
      "id": "iti51:4.3",
      "pali": "Upadhippaṭinissaggaṁ,"
    },
    {
      "id": "iti51:4.4",
      "pali": "sacchikatvā anāsavo;"
    },
    {
      "id": "iti51:4.5",
      "pali": "Deseti sammāsambuddho,"
    },
    {
      "id": "iti51:4.6",
      "pali": "asokaṁ virajaṁ padan”ti."
    },
    {
      "id": "iti51:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti51:5.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
