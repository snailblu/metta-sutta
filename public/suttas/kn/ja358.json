{
  "uid": "ja358",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja358:1.1",
      "pali": "“Ahameva dūsiyā bhūnahatā,"
    },
    {
      "id": "ja358:1.2",
      "pali": "Rañño mahāpatāpassa;"
    },
    {
      "id": "ja358:1.3",
      "pali": "Etaṁ muñcatu dhammapālaṁ,"
    },
    {
      "id": "ja358:1.4",
      "pali": "Hatthe me deva chedehi."
    },
    {
      "id": "ja358:2.1",
      "pali": "Ahameva dūsiyā bhūnahatā,"
    },
    {
      "id": "ja358:2.2",
      "pali": "Rañño mahāpatāpassa;"
    },
    {
      "id": "ja358:2.3",
      "pali": "Etaṁ muñcatu dhammapālaṁ,"
    },
    {
      "id": "ja358:2.4",
      "pali": "Pāde me deva chedehi."
    },
    {
      "id": "ja358:3.1",
      "pali": "Ahameva dūsiyā bhūnahatā,"
    },
    {
      "id": "ja358:3.2",
      "pali": "Rañño mahāpatāpassa;"
    },
    {
      "id": "ja358:3.3",
      "pali": "Etaṁ muñcatu dhammapālaṁ,"
    },
    {
      "id": "ja358:3.4",
      "pali": "Sīsaṁ me deva chedehi."
    },
    {
      "id": "ja358:4.1",
      "pali": "Na hi nūnimassa rañño,"
    },
    {
      "id": "ja358:4.2",
      "pali": "Mittāmaccā ca vijjare suhadā;"
    },
    {
      "id": "ja358:4.3",
      "pali": "Ye na vadanti rājānaṁ,"
    },
    {
      "id": "ja358:4.4",
      "pali": "Mā ghātayi orasaṁ puttaṁ."
    },
    {
      "id": "ja358:5.1",
      "pali": "Na hi nūnimassa rañño,"
    },
    {
      "id": "ja358:5.2",
      "pali": "Ñātī mittā ca vijjare suhadā;"
    },
    {
      "id": "ja358:5.3",
      "pali": "Ye na vadanti rājānaṁ,"
    },
    {
      "id": "ja358:5.4",
      "pali": "Mā ghātayi atrajaṁ puttaṁ."
    },
    {
      "id": "ja358:6.1",
      "pali": "Candanasārānulittā,"
    },
    {
      "id": "ja358:6.2",
      "pali": "Bāhā chijjanti dhammapālassa;"
    },
    {
      "id": "ja358:6.3",
      "pali": "Dāyādassa pathabyā,"
    },
    {
      "id": "ja358:6.4",
      "pali": "Pāṇā me deva rujjhantī”ti."
    },
    {
      "id": "ja358:7.1",
      "pali": "Cūḷadhammapālajātakaṁ aṭṭhamaṁ."
    }
  ]
}
