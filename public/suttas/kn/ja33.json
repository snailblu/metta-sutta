{
  "uid": "ja33",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja33:1.1",
      "pali": "“Sammodamānā gacchanti,"
    },
    {
      "id": "ja33:1.2",
      "pali": "jālamādāya pakkhino;"
    },
    {
      "id": "ja33:1.3",
      "pali": "Yadā te vivadissanti,"
    },
    {
      "id": "ja33:1.4",
      "pali": "tadā ehinti me vasan”ti."
    },
    {
      "id": "ja33:2.1",
      "pali": "Sammodamānajātakaṁ tatiyaṁ."
    }
  ]
}
