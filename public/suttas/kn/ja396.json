{
  "uid": "ja396",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja396:1.1",
      "pali": "“Diyaḍḍhakukkū udayena kaṇṇikā,"
    },
    {
      "id": "ja396:1.2",
      "pali": "Vidatthiyo aṭṭha parikkhipanti naṁ;"
    },
    {
      "id": "ja396:1.3",
      "pali": "Sā siṁsapā sāramayā apheggukā,"
    },
    {
      "id": "ja396:1.4",
      "pali": "Kuhiṁ ṭhitā upparito na dhaṁsati”."
    },
    {
      "id": "ja396:2.1",
      "pali": "“Yā tiṁsati sāramayā anujjukā,"
    },
    {
      "id": "ja396:2.2",
      "pali": "Parikiriya gopānasiyo samaṁ ṭhitā;"
    },
    {
      "id": "ja396:2.3",
      "pali": "Tāhi susaṅgahitā balasā pīḷitā,"
    },
    {
      "id": "ja396:2.4",
      "pali": "Samaṁ ṭhitā upparito na dhaṁsati."
    },
    {
      "id": "ja396:3.1",
      "pali": "Evampi mittehi daḷhehi paṇḍito,"
    },
    {
      "id": "ja396:3.2",
      "pali": "Abhejjarūpehi sucīhi mantibhi;"
    },
    {
      "id": "ja396:3.3",
      "pali": "Susaṅgahīto siriyā na dhaṁsati,"
    },
    {
      "id": "ja396:3.4",
      "pali": "Gopānasī bhāravahāva kaṇṇikā."
    },
    {
      "id": "ja396:4.1",
      "pali": "Kharattacaṁ bellaṁ yathāpi satthavā,"
    },
    {
      "id": "ja396:4.2",
      "pali": "Anāmasantopi karoti tittakaṁ;"
    },
    {
      "id": "ja396:4.3",
      "pali": "Samāharaṁ sāduṁ karoti patthiva,"
    },
    {
      "id": "ja396:4.4",
      "pali": "Asāduṁ kayirā tanubandhamuddharaṁ."
    },
    {
      "id": "ja396:5.1",
      "pali": "Evampi gāmanigamesu paṇḍito,"
    },
    {
      "id": "ja396:5.2",
      "pali": "Asāhasaṁ rājadhanāni saṅgharaṁ;"
    },
    {
      "id": "ja396:5.3",
      "pali": "Dhammānuvattī paṭipajjamāno,"
    },
    {
      "id": "ja396:5.4",
      "pali": "Sa phāti kayirā aviheṭhayaṁ paraṁ."
    },
    {
      "id": "ja396:6.1",
      "pali": "Odātamūlaṁ sucivārisambhavaṁ,"
    },
    {
      "id": "ja396:6.2",
      "pali": "Jātaṁ yathā pokkharaṇīsu ambujaṁ;"
    },
    {
      "id": "ja396:6.3",
      "pali": "Padumaṁ yathā agginikāsiphālimaṁ,"
    },
    {
      "id": "ja396:6.4",
      "pali": "Na kaddamo na rajo na vāri limpati."
    },
    {
      "id": "ja396:7.1",
      "pali": "Evampi vohārasuciṁ asāhasaṁ,"
    },
    {
      "id": "ja396:7.2",
      "pali": "Visuddhakammantamapetapāpakaṁ;"
    },
    {
      "id": "ja396:7.3",
      "pali": "Na limpati kammakilesa tādiso,"
    },
    {
      "id": "ja396:7.4",
      "pali": "Jātaṁ yathā pokkharaṇīsu ambujan”ti."
    },
    {
      "id": "ja396:8.1",
      "pali": "Kukkujātakaṁ paṭhamaṁ."
    }
  ]
}
