{
  "uid": "tha-ap116",
  "title": "Ekāsaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap116:1.1",
      "pali": "“Varuṇo nāma nāmena,"
    },
    {
      "id": "tha-ap116:1.2",
      "pali": "devarājā ahaṁ tadā;"
    },
    {
      "id": "tha-ap116:1.3",
      "pali": "Upaṭṭhahesiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap116:1.4",
      "pali": "sayoggabalavāhano."
    },
    {
      "id": "tha-ap116:2.1",
      "pali": "Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap116:2.2",
      "pali": "atthadassīnaruttame;"
    },
    {
      "id": "tha-ap116:2.3",
      "pali": "Tūriyaṁ sabbamādāya,"
    },
    {
      "id": "tha-ap116:2.4",
      "pali": "agamaṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap116:3.1",
      "pali": "Vāditena ca naccena,"
    },
    {
      "id": "tha-ap116:3.2",
      "pali": "sammatāḷasamāhito;"
    },
    {
      "id": "tha-ap116:3.3",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap116:3.4",
      "pali": "upaṭṭhiṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap116:4.1",
      "pali": "Upaṭṭhahitvā taṁ bodhiṁ,"
    },
    {
      "id": "tha-ap116:4.2",
      "pali": "dharaṇīruhapādapaṁ;"
    },
    {
      "id": "tha-ap116:4.3",
      "pali": "Pallaṅkaṁ ābhujitvāna,"
    },
    {
      "id": "tha-ap116:4.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap116:5.1",
      "pali": "Sakakammābhiraddhohaṁ,"
    },
    {
      "id": "tha-ap116:5.2",
      "pali": "pasanno bodhimuttame;"
    },
    {
      "id": "tha-ap116:5.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap116:5.4",
      "pali": "nimmānaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap116:6.1",
      "pali": "Saṭṭhitūriyasahassāni,"
    },
    {
      "id": "tha-ap116:6.2",
      "pali": "parivārenti maṁ sadā;"
    },
    {
      "id": "tha-ap116:6.3",
      "pali": "Manussesu ca devesu,"
    },
    {
      "id": "tha-ap116:6.4",
      "pali": "vattamānaṁ bhavābhave."
    },
    {
      "id": "tha-ap116:7.1",
      "pali": "Tividhaggī nibbutā mayhaṁ,"
    },
    {
      "id": "tha-ap116:7.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap116:7.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap116:7.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap116:8.1",
      "pali": "Subāhū nāma nāmena,"
    },
    {
      "id": "tha-ap116:8.2",
      "pali": "catuttiṁsāsu khattiyā;"
    },
    {
      "id": "tha-ap116:8.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap116:8.4",
      "pali": "pañcakappasate ito."
    },
    {
      "id": "tha-ap116:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap116:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap116:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap116:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekāsaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap116:11.1",
      "pali": "Ekāsaniyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
