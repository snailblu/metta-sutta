{
  "uid": "ja189",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja189:1.1",
      "pali": "“Netaṁ sīhassa naditaṁ,"
    },
    {
      "id": "ja189:1.2",
      "pali": "na byagghassa na dīpino;"
    },
    {
      "id": "ja189:1.3",
      "pali": "Pāruto sīhacammena,"
    },
    {
      "id": "ja189:1.4",
      "pali": "jammo nadati gadrabho”."
    },
    {
      "id": "ja189:2.1",
      "pali": "“Cirampi kho taṁ khādeyya,"
    },
    {
      "id": "ja189:2.2",
      "pali": "gadrabho haritaṁ yavaṁ;"
    },
    {
      "id": "ja189:2.3",
      "pali": "Pāruto sīhacammena,"
    },
    {
      "id": "ja189:2.4",
      "pali": "ravamānova dūsayī”ti."
    },
    {
      "id": "ja189:3.1",
      "pali": "Sīhacammajātakaṁ navamaṁ."
    }
  ]
}
