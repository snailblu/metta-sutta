{
  "uid": "ja283",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja283:1.1",
      "pali": "“Varaṁ varaṁ tvaṁ nihanaṁ pure cari,"
    },
    {
      "id": "ja283:1.2",
      "pali": "Asmiṁ padese abhibhuyya sūkare;"
    },
    {
      "id": "ja283:1.3",
      "pali": "So dāni eko byapagamma jhāyasi,"
    },
    {
      "id": "ja283:1.4",
      "pali": "Balaṁ nu te byaggha na cajja vijjati”."
    },
    {
      "id": "ja283:2.1",
      "pali": "“Ime sudaṁ yanti disodisaṁ pure,"
    },
    {
      "id": "ja283:2.2",
      "pali": "Bhayaṭṭitā leṇagavesino puthū;"
    },
    {
      "id": "ja283:2.3",
      "pali": "Te dāni saṅgamma vasanti ekato,"
    },
    {
      "id": "ja283:2.4",
      "pali": "Yatthaṭṭhitā duppasahajjame mayā”."
    },
    {
      "id": "ja283:3.1",
      "pali": "“Namatthu saṅghāna samāgatānaṁ,"
    },
    {
      "id": "ja283:3.2",
      "pali": "Disvā sayaṁ sakhya vadāmi abbhutaṁ;"
    },
    {
      "id": "ja283:3.3",
      "pali": "Byagghaṁ migā yattha jiniṁsu dāṭhino,"
    },
    {
      "id": "ja283:3.4",
      "pali": "Sāmaggiyā dāṭhabalesu muccare”ti."
    },
    {
      "id": "ja283:4.1",
      "pali": "Vaḍḍhakīsūkarajātakaṁ tatiyaṁ."
    }
  ]
}
