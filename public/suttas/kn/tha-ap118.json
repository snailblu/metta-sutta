{
  "uid": "tha-ap118",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap118:1.1",
      "pali": "“Vasāmi rājāyatane,"
    },
    {
      "id": "tha-ap118:1.2",
      "pali": "sāmacco saparijjano;"
    },
    {
      "id": "tha-ap118:1.3",
      "pali": "Parinibbute bhagavati,"
    },
    {
      "id": "tha-ap118:1.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap118:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap118:2.2",
      "pali": "citakaṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap118:2.3",
      "pali": "Tūriyaṁ tattha vādetvā,"
    },
    {
      "id": "tha-ap118:2.4",
      "pali": "gandhamālaṁ samokiriṁ."
    },
    {
      "id": "tha-ap118:3.1",
      "pali": "Citamhi pūjaṁ katvāna,"
    },
    {
      "id": "tha-ap118:3.2",
      "pali": "vanditvā citakaṁ ahaṁ;"
    },
    {
      "id": "tha-ap118:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap118:3.4",
      "pali": "sakaṁ bhavanupāgamiṁ."
    },
    {
      "id": "tha-ap118:4.1",
      "pali": "Bhavane upaviṭṭhohaṁ,"
    },
    {
      "id": "tha-ap118:4.2",
      "pali": "citapūjaṁ anussariṁ;"
    },
    {
      "id": "tha-ap118:4.3",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap118:4.4",
      "pali": "lokajeṭṭha narāsabha."
    },
    {
      "id": "tha-ap118:5.1",
      "pali": "Anubhotvāna sampattiṁ,"
    },
    {
      "id": "tha-ap118:5.2",
      "pali": "devesu mānusesu ca;"
    },
    {
      "id": "tha-ap118:5.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap118:5.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap118:6.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap118:6.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap118:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap118:6.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap118:7.1",
      "pali": "Ekūnatiṁsakappamhi,"
    },
    {
      "id": "tha-ap118:7.2",
      "pali": "ito soḷasa rājāno;"
    },
    {
      "id": "tha-ap118:7.3",
      "pali": "Uggatā nāma nāmena,"
    },
    {
      "id": "tha-ap118:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap118:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap118:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap118:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap118:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap118:10.1",
      "pali": "Citakapūjakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
