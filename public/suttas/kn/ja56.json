{
  "uid": "ja56",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja56:1.1",
      "pali": "“Yo pahaṭṭhena cittena,"
    },
    {
      "id": "ja56:1.2",
      "pali": "pahaṭṭhamanaso naro;"
    },
    {
      "id": "ja56:1.3",
      "pali": "Bhāveti kusalaṁ dhammaṁ,"
    },
    {
      "id": "ja56:1.4",
      "pali": "yogakkhemassa pattiyā;"
    },
    {
      "id": "ja56:1.5",
      "pali": "Pāpuṇe anupubbena,"
    },
    {
      "id": "ja56:1.6",
      "pali": "sabbasaṁyojanakkhayan”ti."
    },
    {
      "id": "ja56:2.1",
      "pali": "Kañcanakkhandhajātakaṁ chaṭṭhaṁ."
    }
  ]
}
