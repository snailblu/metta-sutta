{
  "uid": "ja408",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja408:1.1",
      "pali": "“Ambāhamaddaṁ vanamantarasmiṁ,"
    },
    {
      "id": "ja408:1.2",
      "pali": "Nīlobhāsaṁ phalitaṁ saṁvirūḷhaṁ;"
    },
    {
      "id": "ja408:1.3",
      "pali": "Tamaddasaṁ phalahetu vibhaggaṁ,"
    },
    {
      "id": "ja408:1.4",
      "pali": "Taṁ disvā bhikkhācariyaṁ carāmi."
    },
    {
      "id": "ja408:2.1",
      "pali": "Selaṁ sumaṭṭhaṁ naravīraniṭṭhitaṁ,"
    },
    {
      "id": "ja408:2.2",
      "pali": "Nārī yugaṁ dhārayi appasaddaṁ;"
    },
    {
      "id": "ja408:2.3",
      "pali": "Dutiyañca āgamma ahosi saddo,"
    },
    {
      "id": "ja408:2.4",
      "pali": "Taṁ disvā bhikkhācariyaṁ carāmi."
    },
    {
      "id": "ja408:3.1",
      "pali": "Dijā dijaṁ kuṇapamāharantaṁ,"
    },
    {
      "id": "ja408:3.2",
      "pali": "Ekaṁ samānaṁ bahukā samecca;"
    },
    {
      "id": "ja408:3.3",
      "pali": "Āhārahetū paripātayiṁsu,"
    },
    {
      "id": "ja408:3.4",
      "pali": "Taṁ disvā bhikkhācariyaṁ carāmi."
    },
    {
      "id": "ja408:4.1",
      "pali": "Usabhāhamaddaṁ yūthassa majjhe,"
    },
    {
      "id": "ja408:4.2",
      "pali": "Calakkakuṁ vaṇṇabalūpapannaṁ;"
    },
    {
      "id": "ja408:4.3",
      "pali": "Tamaddasaṁ kāmahetu vitunnaṁ,"
    },
    {
      "id": "ja408:4.4",
      "pali": "Taṁ disvā bhikkhācariyaṁ carāmi”."
    },
    {
      "id": "ja408:5.1",
      "pali": "“Karaṇḍako kaliṅgānaṁ,"
    },
    {
      "id": "ja408:5.2",
      "pali": "gandhārānañca naggaji;"
    },
    {
      "id": "ja408:5.3",
      "pali": "Nimirājā videhānaṁ,"
    },
    {
      "id": "ja408:5.4",
      "pali": "pañcālānañca dummukho;"
    },
    {
      "id": "ja408:5.5",
      "pali": "Ete raṭṭhāni hitvāna,"
    },
    {
      "id": "ja408:5.6",
      "pali": "pabbajiṁsu akiñcanā."
    },
    {
      "id": "ja408:6.1",
      "pali": "Sabbepime devasamā samāgatā,"
    },
    {
      "id": "ja408:6.2",
      "pali": "Aggī yathā pajjalito tathevime;"
    },
    {
      "id": "ja408:6.3",
      "pali": "Ahampi eko carissāmi bhaggavi,"
    },
    {
      "id": "ja408:6.4",
      "pali": "Hitvāna kāmāni yathodhikāni”."
    },
    {
      "id": "ja408:7.1",
      "pali": "“Ayameva kālo na hi añño atthi,"
    },
    {
      "id": "ja408:7.2",
      "pali": "Anusāsitā me na bhaveyya pacchā;"
    },
    {
      "id": "ja408:7.3",
      "pali": "Ahampi ekā carissāmi bhaggava,"
    },
    {
      "id": "ja408:7.4",
      "pali": "Sakuṇīva muttā purisassa hatthā”."
    },
    {
      "id": "ja408:8.1",
      "pali": "“Āmaṁ pakkañca jānanti,"
    },
    {
      "id": "ja408:8.2",
      "pali": "atho loṇaṁ aloṇakaṁ;"
    },
    {
      "id": "ja408:8.3",
      "pali": "Tamahaṁ disvāna pabbajiṁ,"
    },
    {
      "id": "ja408:8.4",
      "pali": "careva tvaṁ carāmahan”ti."
    },
    {
      "id": "ja408:9.1",
      "pali": "Kumbhakārajātakaṁ tatiyaṁ."
    }
  ]
}
