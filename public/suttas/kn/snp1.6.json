{
  "uid": "snp1.6",
  "title": "Parābhavasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp1.6:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp1.6:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "snp1.6:1.3",
      "pali": "Atha kho aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "snp1.6:1.4",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "snp1.6:2.1",
      "pali": "“Parābhavantaṁ purisaṁ,"
    },
    {
      "id": "snp1.6:2.2",
      "pali": "mayaṁ pucchāma gotama;"
    },
    {
      "id": "snp1.6:2.3",
      "pali": "Bhavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "snp1.6:2.4",
      "pali": "kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:3.1",
      "pali": "“Suvijāno bhavaṁ hoti,"
    },
    {
      "id": "snp1.6:3.2",
      "pali": "suvijāno parābhavo;"
    },
    {
      "id": "snp1.6:3.3",
      "pali": "Dhammakāmo bhavaṁ hoti,"
    },
    {
      "id": "snp1.6:3.4",
      "pali": "dhammadessī parābhavo”."
    },
    {
      "id": "snp1.6:4.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:4.2",
      "pali": "paṭhamo so parābhavo;"
    },
    {
      "id": "snp1.6:4.3",
      "pali": "Dutiyaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:4.4",
      "pali": "kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:5.1",
      "pali": "“Asantassa piyā honti,"
    },
    {
      "id": "snp1.6:5.2",
      "pali": "sante na kurute piyaṁ;"
    },
    {
      "id": "snp1.6:5.3",
      "pali": "Asataṁ dhammaṁ roceti,"
    },
    {
      "id": "snp1.6:5.4",
      "pali": "taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:6.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:6.2",
      "pali": "dutiyo so parābhavo;"
    },
    {
      "id": "snp1.6:6.3",
      "pali": "Tatiyaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:6.4",
      "pali": "kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:7.1",
      "pali": "“Niddāsīlī sabhāsīlī,"
    },
    {
      "id": "snp1.6:7.2",
      "pali": "anuṭṭhātā ca yo naro;"
    },
    {
      "id": "snp1.6:7.3",
      "pali": "Alaso kodhapaññāṇo,"
    },
    {
      "id": "snp1.6:7.4",
      "pali": "taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:8.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:8.2",
      "pali": "tatiyo so parābhavo;"
    },
    {
      "id": "snp1.6:8.3",
      "pali": "Catutthaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:8.4",
      "pali": "kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:9.1",
      "pali": "“Yo mātaraṁ pitaraṁ vā,"
    },
    {
      "id": "snp1.6:9.2",
      "pali": "jiṇṇakaṁ gatayobbanaṁ;"
    },
    {
      "id": "snp1.6:9.3",
      "pali": "Pahu santo na bharati,"
    },
    {
      "id": "snp1.6:9.4",
      "pali": "taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:10.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:10.2",
      "pali": "catuttho so parābhavo;"
    },
    {
      "id": "snp1.6:10.3",
      "pali": "Pañcamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:10.4",
      "pali": "kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:11.1",
      "pali": "“Yo brāhmaṇaṁ samaṇaṁ vā,"
    },
    {
      "id": "snp1.6:11.2",
      "pali": "Aññaṁ vāpi vanibbakaṁ;"
    },
    {
      "id": "snp1.6:11.3",
      "pali": "Musāvādena vañceti,"
    },
    {
      "id": "snp1.6:11.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:12.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:12.2",
      "pali": "Pañcamo so parābhavo;"
    },
    {
      "id": "snp1.6:12.3",
      "pali": "Chaṭṭhamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:12.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:13.1",
      "pali": "“Pahūtavitto puriso,"
    },
    {
      "id": "snp1.6:13.2",
      "pali": "Sahirañño sabhojano;"
    },
    {
      "id": "snp1.6:13.3",
      "pali": "Eko bhuñjati sādūni,"
    },
    {
      "id": "snp1.6:13.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:14.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:14.2",
      "pali": "Chaṭṭhamo so parābhavo;"
    },
    {
      "id": "snp1.6:14.3",
      "pali": "Sattamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:14.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:15.1",
      "pali": "“Jātitthaddho dhanatthaddho,"
    },
    {
      "id": "snp1.6:15.2",
      "pali": "Gottatthaddho ca yo naro;"
    },
    {
      "id": "snp1.6:15.3",
      "pali": "Saññātiṁ atimaññeti,"
    },
    {
      "id": "snp1.6:15.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:16.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:16.2",
      "pali": "Sattamo so parābhavo;"
    },
    {
      "id": "snp1.6:16.3",
      "pali": "Aṭṭhamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:16.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:17.1",
      "pali": "“Itthidhutto surādhutto,"
    },
    {
      "id": "snp1.6:17.2",
      "pali": "Akkhadhutto ca yo naro;"
    },
    {
      "id": "snp1.6:17.3",
      "pali": "Laddhaṁ laddhaṁ vināseti,"
    },
    {
      "id": "snp1.6:17.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:18.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:18.2",
      "pali": "Aṭṭhamo so parābhavo;"
    },
    {
      "id": "snp1.6:18.3",
      "pali": "Navamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:18.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:19.1",
      "pali": "“Sehi dārehi asantuṭṭho,"
    },
    {
      "id": "snp1.6:19.2",
      "pali": "Vesiyāsu padussati;"
    },
    {
      "id": "snp1.6:19.3",
      "pali": "Dussati paradāresu,"
    },
    {
      "id": "snp1.6:19.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:20.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:20.2",
      "pali": "Navamo so parābhavo;"
    },
    {
      "id": "snp1.6:20.3",
      "pali": "Dasamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:20.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:21.1",
      "pali": "“Atītayobbano poso,"
    },
    {
      "id": "snp1.6:21.2",
      "pali": "Āneti timbarutthaniṁ;"
    },
    {
      "id": "snp1.6:21.3",
      "pali": "Tassā issā na supati,"
    },
    {
      "id": "snp1.6:21.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:22.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:22.2",
      "pali": "Dasamo so parābhavo;"
    },
    {
      "id": "snp1.6:22.3",
      "pali": "Ekādasamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:22.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:23.1",
      "pali": "“Itthiṁ soṇḍiṁ vikiraṇiṁ,"
    },
    {
      "id": "snp1.6:23.2",
      "pali": "Purisaṁ vāpi tādisaṁ;"
    },
    {
      "id": "snp1.6:23.3",
      "pali": "Issariyasmiṁ ṭhapeti,"
    },
    {
      "id": "snp1.6:23.4",
      "pali": "Taṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:24.1",
      "pali": "“Iti hetaṁ vijānāma,"
    },
    {
      "id": "snp1.6:24.2",
      "pali": "Ekādasamo so parābhavo;"
    },
    {
      "id": "snp1.6:24.3",
      "pali": "Dvādasamaṁ bhagavā brūhi,"
    },
    {
      "id": "snp1.6:24.4",
      "pali": "Kiṁ parābhavato mukhaṁ”."
    },
    {
      "id": "snp1.6:25.1",
      "pali": "“Appabhogo mahātaṇho,"
    },
    {
      "id": "snp1.6:25.2",
      "pali": "Khattiye jāyate kule;"
    },
    {
      "id": "snp1.6:25.3",
      "pali": "So ca rajjaṁ patthayati,"
    },
    {
      "id": "snp1.6:25.4",
      "pali": "Taṁ parābhavato mukhaṁ."
    },
    {
      "id": "snp1.6:26.1",
      "pali": "Ete parābhave loke,"
    },
    {
      "id": "snp1.6:26.2",
      "pali": "Paṇḍito samavekkhiya;"
    },
    {
      "id": "snp1.6:26.3",
      "pali": "Ariyo dassanasampanno,"
    },
    {
      "id": "snp1.6:26.4",
      "pali": "Sa lokaṁ bhajate sivan”ti."
    },
    {
      "id": "snp1.6:26.5",
      "pali": "Parābhavasuttaṁ chaṭṭhaṁ."
    }
  ]
}
