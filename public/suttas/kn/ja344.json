{
  "uid": "ja344",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja344:1.1",
      "pali": "“Yo nīliyaṁ maṇḍayati,"
    },
    {
      "id": "ja344:1.2",
      "pali": "saṇḍāsena vihaññati;"
    },
    {
      "id": "ja344:1.3",
      "pali": "Tassa sā vasamanvetu,"
    },
    {
      "id": "ja344:1.4",
      "pali": "yā te ambe avāhari”."
    },
    {
      "id": "ja344:2.1",
      "pali": "“Vīsaṁ vā pañcavīsaṁ vā,"
    },
    {
      "id": "ja344:2.2",
      "pali": "ūnatiṁsaṁ va jātiyā;"
    },
    {
      "id": "ja344:2.3",
      "pali": "Tādisā pati mā laddhā,"
    },
    {
      "id": "ja344:2.4",
      "pali": "yā te ambe avāhari”."
    },
    {
      "id": "ja344:3.1",
      "pali": "“Dīghaṁ gacchatu addhānaṁ,"
    },
    {
      "id": "ja344:3.2",
      "pali": "ekikā abhisārikā;"
    },
    {
      "id": "ja344:3.3",
      "pali": "Saṅkete pati mā adda,"
    },
    {
      "id": "ja344:3.4",
      "pali": "yā te ambe avāhari”."
    },
    {
      "id": "ja344:4.1",
      "pali": "“Alaṅkatā suvasanā,"
    },
    {
      "id": "ja344:4.2",
      "pali": "mālinī candanussadā;"
    },
    {
      "id": "ja344:4.3",
      "pali": "Ekikā sayane setu,"
    },
    {
      "id": "ja344:4.4",
      "pali": "yā te ambe avāharī”ti."
    },
    {
      "id": "ja344:5.1",
      "pali": "Ambajātakaṁ catutthaṁ."
    }
  ]
}
