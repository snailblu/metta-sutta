{
  "uid": "thag2.22",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.22:1.1",
      "pali": "“Panādo nāma so rājā,"
    },
    {
      "id": "thag2.22:1.2",
      "pali": "yassa yūpo suvaṇṇayo;"
    },
    {
      "id": "thag2.22:1.3",
      "pali": "Tiriyaṁ soḷasubbedho,"
    },
    {
      "id": "thag2.22:1.4",
      "pali": "ubbhamāhu sahassadhā."
    },
    {
      "id": "thag2.22:2.1",
      "pali": "Sahassakaṇḍo satageṇḍu,"
    },
    {
      "id": "thag2.22:2.2",
      "pali": "dhajālu haritāmayo;"
    },
    {
      "id": "thag2.22:2.3",
      "pali": "Anaccuṁ tattha gandhabbā,"
    },
    {
      "id": "thag2.22:2.4",
      "pali": "chasahassāni sattadhā”ti."
    },
    {
      "id": "thag2.22:2.5",
      "pali": "… Bhaddajitthero …."
    }
  ]
}
