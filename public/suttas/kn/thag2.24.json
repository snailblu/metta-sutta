{
  "uid": "thag2.24",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.24:1.1",
      "pali": "“Yaṁ kiccaṁ daḷhavīriyena,"
    },
    {
      "id": "thag2.24:1.2",
      "pali": "yaṁ kiccaṁ boddhumicchatā;"
    },
    {
      "id": "thag2.24:1.3",
      "pali": "Karissaṁ nāvarajjhissaṁ,"
    },
    {
      "id": "thag2.24:1.4",
      "pali": "passa vīriyaṁ parakkamaṁ."
    },
    {
      "id": "thag2.24:2.1",
      "pali": "Tvañca me maggamakkhāhi,"
    },
    {
      "id": "thag2.24:2.2",
      "pali": "añjasaṁ amatogadhaṁ;"
    },
    {
      "id": "thag2.24:2.3",
      "pali": "Ahaṁ monena monissaṁ,"
    },
    {
      "id": "thag2.24:2.4",
      "pali": "gaṅgāsotova sāgaran”ti."
    },
    {
      "id": "thag2.24:2.5",
      "pali": "… Valliyo thero …."
    }
  ]
}
