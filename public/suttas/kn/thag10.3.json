{
  "uid": "thag10.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.3:1.1",
      "pali": "“Anāgataṁ yo paṭikacca passati,"
    },
    {
      "id": "thag10.3:1.2",
      "pali": "Hitañca atthaṁ ahitañca taṁ dvayaṁ;"
    },
    {
      "id": "thag10.3:1.3",
      "pali": "Viddesino tassa hitesino vā,"
    },
    {
      "id": "thag10.3:1.4",
      "pali": "Randhaṁ na passanti samekkhamānā."
    },
    {
      "id": "thag10.3:2.1",
      "pali": "Ānāpānasatī yassa,"
    },
    {
      "id": "thag10.3:2.2",
      "pali": "paripuṇṇā subhāvitā;"
    },
    {
      "id": "thag10.3:2.3",
      "pali": "Anupubbaṁ paricitā,"
    },
    {
      "id": "thag10.3:2.4",
      "pali": "yathā buddhena desitā;"
    },
    {
      "id": "thag10.3:2.5",
      "pali": "Somaṁ lokaṁ pabhāseti,"
    },
    {
      "id": "thag10.3:2.6",
      "pali": "abbhā muttova candimā."
    },
    {
      "id": "thag10.3:3.1",
      "pali": "Odātaṁ vata me cittaṁ,"
    },
    {
      "id": "thag10.3:3.2",
      "pali": "appamāṇaṁ subhāvitaṁ;"
    },
    {
      "id": "thag10.3:3.3",
      "pali": "Nibbiddhaṁ paggahītañca,"
    },
    {
      "id": "thag10.3:3.4",
      "pali": "sabbā obhāsate disā."
    },
    {
      "id": "thag10.3:4.1",
      "pali": "Jīvate vāpi sappañño,"
    },
    {
      "id": "thag10.3:4.2",
      "pali": "api vittaparikkhayo;"
    },
    {
      "id": "thag10.3:4.3",
      "pali": "Paññāya ca alābhena,"
    },
    {
      "id": "thag10.3:4.4",
      "pali": "vittavāpi na jīvati."
    },
    {
      "id": "thag10.3:5.1",
      "pali": "Paññā sutavinicchinī,"
    },
    {
      "id": "thag10.3:5.2",
      "pali": "Paññā kittisilokavaddhanī;"
    },
    {
      "id": "thag10.3:5.3",
      "pali": "Paññāsahito naro idha,"
    },
    {
      "id": "thag10.3:5.4",
      "pali": "Api dukkhesu sukhāni vindati."
    },
    {
      "id": "thag10.3:6.1",
      "pali": "Nāyaṁ ajjatano dhammo,"
    },
    {
      "id": "thag10.3:6.2",
      "pali": "nacchero napi abbhuto;"
    },
    {
      "id": "thag10.3:6.3",
      "pali": "Yattha jāyetha mīyetha,"
    },
    {
      "id": "thag10.3:6.4",
      "pali": "tattha kiṁ viya abbhutaṁ."
    },
    {
      "id": "thag10.3:7.1",
      "pali": "Anantaraṁ hi jātassa,"
    },
    {
      "id": "thag10.3:7.2",
      "pali": "jīvitā maraṇaṁ dhuvaṁ;"
    },
    {
      "id": "thag10.3:7.3",
      "pali": "Jātā jātā marantīdha,"
    },
    {
      "id": "thag10.3:7.4",
      "pali": "evaṁdhammā hi pāṇino."
    },
    {
      "id": "thag10.3:8.1",
      "pali": "Na hetadatthāya matassa hoti,"
    },
    {
      "id": "thag10.3:8.2",
      "pali": "Yaṁ jīvitatthaṁ paraporisānaṁ;"
    },
    {
      "id": "thag10.3:8.3",
      "pali": "Matamhi ruṇṇaṁ na yaso na lokyaṁ,"
    },
    {
      "id": "thag10.3:8.4",
      "pali": "Na vaṇṇitaṁ samaṇabrāhmaṇehi."
    },
    {
      "id": "thag10.3:9.1",
      "pali": "Cakkhuṁ sarīraṁ upahanti tena,"
    },
    {
      "id": "thag10.3:9.2",
      "pali": "Nihīyati vaṇṇabalaṁ matī ca;"
    },
    {
      "id": "thag10.3:9.3",
      "pali": "Ānandino tassa disā bhavanti,"
    },
    {
      "id": "thag10.3:9.4",
      "pali": "Hitesino nāssa sukhī bhavanti."
    },
    {
      "id": "thag10.3:10.1",
      "pali": "Tasmā hi iccheyya kule vasante,"
    },
    {
      "id": "thag10.3:10.2",
      "pali": "Medhāvino ceva bahussute ca;"
    },
    {
      "id": "thag10.3:10.3",
      "pali": "Yesaṁ hi paññāvibhavena kiccaṁ,"
    },
    {
      "id": "thag10.3:10.4",
      "pali": "Taranti nāvāya nadiṁva puṇṇan”ti."
    },
    {
      "id": "thag10.3:10.5",
      "pali": "… Mahākappino thero …."
    }
  ]
}
