{
  "uid": "cp31",
  "title": "Saccapāramī 5",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp31:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp31:1.2",
      "pali": "kaṇhadīpāyano isi;"
    },
    {
      "id": "cp31:1.3",
      "pali": "Paropaññāsavassāni,"
    },
    {
      "id": "cp31:1.4",
      "pali": "anabhiratocariṁ ahaṁ."
    },
    {
      "id": "cp31:2.1",
      "pali": "Na koci etaṁ jānāti,"
    },
    {
      "id": "cp31:2.2",
      "pali": "Anabhiratimanaṁ mama;"
    },
    {
      "id": "cp31:2.3",
      "pali": "Ahañhi kassaci nācikkhiṁ,"
    },
    {
      "id": "cp31:2.4",
      "pali": "Arati me carati mānase."
    },
    {
      "id": "cp31:3.1",
      "pali": "Sabrahmacārī maṇḍabyo,"
    },
    {
      "id": "cp31:3.2",
      "pali": "sahāyo me mahāisi;"
    },
    {
      "id": "cp31:3.3",
      "pali": "Pubbakammasamāyutto,"
    },
    {
      "id": "cp31:3.4",
      "pali": "sūlamāropanaṁ labhi."
    },
    {
      "id": "cp31:4.1",
      "pali": "Tamahaṁ upaṭṭhahitvāna,"
    },
    {
      "id": "cp31:4.2",
      "pali": "ārogyamanupāpayiṁ;"
    },
    {
      "id": "cp31:4.3",
      "pali": "Āpucchitvāna āgañchiṁ,"
    },
    {
      "id": "cp31:4.4",
      "pali": "yaṁ mayhaṁ sakamassamaṁ."
    },
    {
      "id": "cp31:5.1",
      "pali": "Sahāyo brāhmaṇo mayhaṁ,"
    },
    {
      "id": "cp31:5.2",
      "pali": "bhariyaṁ ādāya puttakaṁ;"
    },
    {
      "id": "cp31:5.3",
      "pali": "Tayo janā samāgantvā,"
    },
    {
      "id": "cp31:5.4",
      "pali": "āgañchuṁ pāhunāgataṁ."
    },
    {
      "id": "cp31:6.1",
      "pali": "Sammodamāno tehi saha,"
    },
    {
      "id": "cp31:6.2",
      "pali": "nisinno sakamassame;"
    },
    {
      "id": "cp31:6.3",
      "pali": "Dārako vaṭṭamanukkhipaṁ,"
    },
    {
      "id": "cp31:6.4",
      "pali": "āsīvisamakopayi."
    },
    {
      "id": "cp31:7.1",
      "pali": "Tato so vaṭṭagataṁ maggaṁ,"
    },
    {
      "id": "cp31:7.2",
      "pali": "anvesanto kumārako;"
    },
    {
      "id": "cp31:7.3",
      "pali": "Āsīvisassa hatthena,"
    },
    {
      "id": "cp31:7.4",
      "pali": "uttamaṅgaṁ parāmasi."
    },
    {
      "id": "cp31:8.1",
      "pali": "Tassa āmasane kuddho,"
    },
    {
      "id": "cp31:8.2",
      "pali": "sappo visabalassito;"
    },
    {
      "id": "cp31:8.3",
      "pali": "Kupito paramakopena,"
    },
    {
      "id": "cp31:8.4",
      "pali": "aḍaṁsi dārakaṁ khaṇe."
    },
    {
      "id": "cp31:9.1",
      "pali": "Sahadaṭṭho āsīvisena,"
    },
    {
      "id": "cp31:9.2",
      "pali": "dārako papati bhūmiyaṁ;"
    },
    {
      "id": "cp31:9.3",
      "pali": "Tenāhaṁ dukkhito āsiṁ,"
    },
    {
      "id": "cp31:9.4",
      "pali": "mama vāhasi taṁ dukkhaṁ."
    },
    {
      "id": "cp31:10.1",
      "pali": "Tyāhaṁ assāsayitvāna,"
    },
    {
      "id": "cp31:10.2",
      "pali": "dukkhite sokasallite;"
    },
    {
      "id": "cp31:10.3",
      "pali": "Paṭhamaṁ akāsiṁ kiriyaṁ,"
    },
    {
      "id": "cp31:10.4",
      "pali": "aggaṁ saccaṁ varuttamaṁ."
    },
    {
      "id": "cp31:11.1",
      "pali": "‘Sattāhamevāhaṁ pasannacitto,"
    },
    {
      "id": "cp31:11.2",
      "pali": "Puññatthiko acariṁ brahmacariyaṁ;"
    },
    {
      "id": "cp31:11.3",
      "pali": "Athāparaṁ yaṁ caritaṁ mamedaṁ,"
    },
    {
      "id": "cp31:11.4",
      "pali": "Vassāni paññāsasamādhikāni."
    },
    {
      "id": "cp31:12.1",
      "pali": "Akāmako vāhi ahaṁ carāmi,"
    },
    {
      "id": "cp31:12.2",
      "pali": "Etena saccena suvatthi hotu;"
    },
    {
      "id": "cp31:12.3",
      "pali": "Hataṁ visaṁ jīvatu yaññadatto’."
    },
    {
      "id": "cp31:13.1",
      "pali": "Saha sacce kate mayhaṁ,"
    },
    {
      "id": "cp31:13.2",
      "pali": "visavegena vedhito;"
    },
    {
      "id": "cp31:13.3",
      "pali": "Abujjhitvāna vuṭṭhāsi,"
    },
    {
      "id": "cp31:13.4",
      "pali": "arogo cāsi māṇavo;"
    },
    {
      "id": "cp31:13.5",
      "pali": "Saccena me samo natthi,"
    },
    {
      "id": "cp31:13.6",
      "pali": "esā me saccapāramī”ti."
    },
    {
      "id": "cp31:14.1",
      "pali": "Kaṇhadīpāyanacariyaṁ ekādasamaṁ."
    }
  ]
}
