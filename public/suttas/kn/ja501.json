{
  "uid": "ja501",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja501:1.1",
      "pali": "“Ete yūthā patiyanti,"
    },
    {
      "id": "ja501:1.2",
      "pali": "bhītā maraṇassa cittaka;"
    },
    {
      "id": "ja501:1.3",
      "pali": "Gaccha tuvampi mākaṅkhi,"
    },
    {
      "id": "ja501:1.4",
      "pali": "jīvissanti tayā saha”."
    },
    {
      "id": "ja501:2.1",
      "pali": "“Nāhaṁ rohaṇa gacchāmi,"
    },
    {
      "id": "ja501:2.2",
      "pali": "hadayaṁ me avakassati;"
    },
    {
      "id": "ja501:2.3",
      "pali": "Na taṁ ahaṁ jahissāmi,"
    },
    {
      "id": "ja501:2.4",
      "pali": "idha hissāmi jīvitaṁ”."
    },
    {
      "id": "ja501:3.1",
      "pali": "“Te hi nūna marissanti,"
    },
    {
      "id": "ja501:3.2",
      "pali": "andhā apariṇāyakā;"
    },
    {
      "id": "ja501:3.3",
      "pali": "Gaccha tuvampi mākaṅkhi,"
    },
    {
      "id": "ja501:3.4",
      "pali": "jīvissanti tayā saha”."
    },
    {
      "id": "ja501:4.1",
      "pali": "“Nāhaṁ rohaṇa gacchāmi,"
    },
    {
      "id": "ja501:4.2",
      "pali": "hadayaṁ me avakassati;"
    },
    {
      "id": "ja501:4.3",
      "pali": "Na taṁ baddhaṁ jahissāmi,"
    },
    {
      "id": "ja501:4.4",
      "pali": "idha hissāmi jīvitaṁ”."
    },
    {
      "id": "ja501:5.1",
      "pali": "“Gaccha bhīru palāyassu,"
    },
    {
      "id": "ja501:5.2",
      "pali": "kūṭe baddhosmi āyase;"
    },
    {
      "id": "ja501:5.3",
      "pali": "Gaccha tuvampi mākaṅkhi,"
    },
    {
      "id": "ja501:5.4",
      "pali": "jīvissanti tayā saha”."
    },
    {
      "id": "ja501:6.1",
      "pali": "“Nāhaṁ rohaṇa gacchāmi,"
    },
    {
      "id": "ja501:6.2",
      "pali": "hadayaṁ me avakassati;"
    },
    {
      "id": "ja501:6.3",
      "pali": "Na taṁ ahaṁ jahissāmi,"
    },
    {
      "id": "ja501:6.4",
      "pali": "idha hissāmi jīvitaṁ”."
    },
    {
      "id": "ja501:7.1",
      "pali": "“Te hi nūna marissanti,"
    },
    {
      "id": "ja501:7.2",
      "pali": "andhā apariṇāyakā;"
    },
    {
      "id": "ja501:7.3",
      "pali": "Gaccha tuvampi mākaṅkhi,"
    },
    {
      "id": "ja501:7.4",
      "pali": "jīvissanti tayā saha”."
    },
    {
      "id": "ja501:8.1",
      "pali": "“Nāhaṁ rohaṇa gacchāmi,"
    },
    {
      "id": "ja501:8.2",
      "pali": "hadayaṁ me avakassati;"
    },
    {
      "id": "ja501:8.3",
      "pali": "Na taṁ baddhaṁ jahissāmi,"
    },
    {
      "id": "ja501:8.4",
      "pali": "idha hissāmi jīvitaṁ”."
    },
    {
      "id": "ja501:9.1",
      "pali": "“Ayaṁ so luddako eti,"
    },
    {
      "id": "ja501:9.2",
      "pali": "luddarūpo sahāvudho;"
    },
    {
      "id": "ja501:9.3",
      "pali": "Yo no vadhissati ajja,"
    },
    {
      "id": "ja501:9.4",
      "pali": "usunā sattiyā api”."
    },
    {
      "id": "ja501:10.1",
      "pali": "“Sā muhuttaṁ palāyitvā,"
    },
    {
      "id": "ja501:10.2",
      "pali": "bhayaṭṭā bhayatajjitā;"
    },
    {
      "id": "ja501:10.3",
      "pali": "Sudukkaraṁ akarā bhīru,"
    },
    {
      "id": "ja501:10.4",
      "pali": "maraṇāyūpanivattatha”."
    },
    {
      "id": "ja501:11.1",
      "pali": "“Kiṁ nu teme migā honti,"
    },
    {
      "id": "ja501:11.2",
      "pali": "muttā baddhaṁ upāsare;"
    },
    {
      "id": "ja501:11.3",
      "pali": "Na taṁ cajitumicchanti,"
    },
    {
      "id": "ja501:11.4",
      "pali": "jīvitassapi kāraṇā”."
    },
    {
      "id": "ja501:12.1",
      "pali": "“Bhātaro honti me ludda,"
    },
    {
      "id": "ja501:12.2",
      "pali": "sodariyā ekamātukā;"
    },
    {
      "id": "ja501:12.3",
      "pali": "Na maṁ cajitumicchanti,"
    },
    {
      "id": "ja501:12.4",
      "pali": "jīvitassapi kāraṇā”."
    },
    {
      "id": "ja501:13.1",
      "pali": "“Te hi nūna marissanti,"
    },
    {
      "id": "ja501:13.2",
      "pali": "andhā apariṇāyakā;"
    },
    {
      "id": "ja501:13.3",
      "pali": "Pañcannaṁ jīvitaṁ dehi,"
    },
    {
      "id": "ja501:13.4",
      "pali": "bhātaraṁ muñca luddaka”."
    },
    {
      "id": "ja501:14.1",
      "pali": "“So vo ahaṁ pamokkhāmi,"
    },
    {
      "id": "ja501:14.2",
      "pali": "mātāpettibharaṁ migaṁ;"
    },
    {
      "id": "ja501:14.3",
      "pali": "Nandantu mātāpitaro,"
    },
    {
      "id": "ja501:14.4",
      "pali": "muttaṁ disvā mahāmigaṁ”."
    },
    {
      "id": "ja501:15.1",
      "pali": "“Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja501:15.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja501:15.3",
      "pali": "Yathāhamajja nandāmi,"
    },
    {
      "id": "ja501:15.4",
      "pali": "muttaṁ disvā mahāmigaṁ”."
    },
    {
      "id": "ja501:16.1",
      "pali": "“Kathaṁ tvaṁ pamokkho āsi,"
    },
    {
      "id": "ja501:16.2",
      "pali": "Upanītasmi jīvite;"
    },
    {
      "id": "ja501:16.3",
      "pali": "Kathaṁ putta amocesi,"
    },
    {
      "id": "ja501:16.4",
      "pali": "Kūṭapāsamha luddako”."
    },
    {
      "id": "ja501:17.1",
      "pali": "“Bhaṇaṁ kaṇṇasukhaṁ vācaṁ,"
    },
    {
      "id": "ja501:17.2",
      "pali": "hadayaṅgaṁ hadayassitaṁ;"
    },
    {
      "id": "ja501:17.3",
      "pali": "Subhāsitāhi vācāhi,"
    },
    {
      "id": "ja501:17.4",
      "pali": "cittako maṁ amocayi."
    },
    {
      "id": "ja501:18.1",
      "pali": "Bhaṇaṁ kaṇṇasukhaṁ vācaṁ,"
    },
    {
      "id": "ja501:18.2",
      "pali": "hadayaṅgaṁ hadayassitaṁ;"
    },
    {
      "id": "ja501:18.3",
      "pali": "Subhāsitāhi vācāhi,"
    },
    {
      "id": "ja501:18.4",
      "pali": "sutanā maṁ amocayi."
    },
    {
      "id": "ja501:19.1",
      "pali": "Sutvā kaṇṇasukhaṁ vācaṁ,"
    },
    {
      "id": "ja501:19.2",
      "pali": "hadayaṅgaṁ hadayassitaṁ;"
    },
    {
      "id": "ja501:19.3",
      "pali": "Subhāsitāni sutvāna,"
    },
    {
      "id": "ja501:19.4",
      "pali": "luddako maṁ amocayi”."
    },
    {
      "id": "ja501:20.1",
      "pali": "“Evaṁ ānandito hotu,"
    },
    {
      "id": "ja501:20.2",
      "pali": "saha dārehi luddako;"
    },
    {
      "id": "ja501:20.3",
      "pali": "Yathā mayajja nandāma,"
    },
    {
      "id": "ja501:20.4",
      "pali": "disvā rohaṇamāgataṁ”."
    },
    {
      "id": "ja501:21.1",
      "pali": "“Nanu tvaṁ avaca ludda,"
    },
    {
      "id": "ja501:21.2",
      "pali": "‘migacammāni āhariṁ’;"
    },
    {
      "id": "ja501:21.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja501:21.4",
      "pali": "migacammāni nāhari”."
    },
    {
      "id": "ja501:22.1",
      "pali": "“Āgamā ceva hatthatthaṁ,"
    },
    {
      "id": "ja501:22.2",
      "pali": "kūṭapāsañca so migo;"
    },
    {
      "id": "ja501:22.3",
      "pali": "Abajjhi taṁ migarājaṁ,"
    },
    {
      "id": "ja501:22.4",
      "pali": "tañca muttā upāsare."
    },
    {
      "id": "ja501:23.1",
      "pali": "Tassa me ahu saṁvego,"
    },
    {
      "id": "ja501:23.2",
      "pali": "abbhuto lomahaṁsano;"
    },
    {
      "id": "ja501:23.3",
      "pali": "Imañcāhaṁ migaṁ haññe,"
    },
    {
      "id": "ja501:23.4",
      "pali": "ajja hissāmi jīvitaṁ”."
    },
    {
      "id": "ja501:24.1",
      "pali": "“Kīdisā te migā ludda,"
    },
    {
      "id": "ja501:24.2",
      "pali": "kīdisā dhammikā migā;"
    },
    {
      "id": "ja501:24.3",
      "pali": "Kathaṁvaṇṇā kathaṁsīlā,"
    },
    {
      "id": "ja501:24.4",
      "pali": "bāḷhaṁ kho ne pasaṁsasi”."
    },
    {
      "id": "ja501:25.1",
      "pali": "“Odātasiṅgā sucivālā,"
    },
    {
      "id": "ja501:25.2",
      "pali": "jātarūpatacūpamā;"
    },
    {
      "id": "ja501:25.3",
      "pali": "Pādā lohitakā tesaṁ,"
    },
    {
      "id": "ja501:25.4",
      "pali": "añjitakkhā manoramā”."
    },
    {
      "id": "ja501:26.1",
      "pali": "“Edisā te migā deva,"
    },
    {
      "id": "ja501:26.2",
      "pali": "edisā dhammikā migā;"
    },
    {
      "id": "ja501:26.3",
      "pali": "Mātāpettibharā deva,"
    },
    {
      "id": "ja501:26.4",
      "pali": "na te so abhihārituṁ”."
    },
    {
      "id": "ja501:27.1",
      "pali": "“Dammi nikkhasataṁ ludda,"
    },
    {
      "id": "ja501:27.2",
      "pali": "thūlañca maṇikuṇḍalaṁ;"
    },
    {
      "id": "ja501:27.3",
      "pali": "Catussadañca pallaṅkaṁ,"
    },
    {
      "id": "ja501:27.4",
      "pali": "umāpupphasarinnibhaṁ."
    },
    {
      "id": "ja501:28.1",
      "pali": "Dve ca sādisiyo bhariyā,"
    },
    {
      "id": "ja501:28.2",
      "pali": "usabhañca gavaṁ sataṁ;"
    },
    {
      "id": "ja501:28.3",
      "pali": "Dhammena rajjaṁ kāressaṁ,"
    },
    {
      "id": "ja501:28.4",
      "pali": "bahukāro mesi luddaka."
    },
    {
      "id": "ja501:29.1",
      "pali": "Kasivāṇijjā iṇadānaṁ,"
    },
    {
      "id": "ja501:29.2",
      "pali": "uñchācariyā ca luddaka;"
    },
    {
      "id": "ja501:29.3",
      "pali": "Etena dāraṁ posehi,"
    },
    {
      "id": "ja501:29.4",
      "pali": "mā pāpaṁ akarī punāti”."
    },
    {
      "id": "ja501:30.1",
      "pali": "Rohaṇamigajātakaṁ pañcamaṁ."
    }
  ]
}
