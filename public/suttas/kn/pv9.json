{
  "uid": "pv9",
  "title": "9. Mahāpesakārapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv9:1.1",
      "pali": "“Gūthañca muttaṁ ruhirañca pubbaṁ,"
    },
    {
      "id": "pv9:1.2",
      "pali": "Paribhuñjati kissa ayaṁ vipāko;"
    },
    {
      "id": "pv9:1.3",
      "pali": "Ayaṁ nu kiṁ kammamakāsi nārī,"
    },
    {
      "id": "pv9:1.4",
      "pali": "Yā sabbadā lohitapubbabhakkhā."
    },
    {
      "id": "pv9:2.1",
      "pali": "Navāni vatthāni subhāni ceva,"
    },
    {
      "id": "pv9:2.2",
      "pali": "Mudūni suddhāni ca lomasāni;"
    },
    {
      "id": "pv9:2.3",
      "pali": "Dinnānimissā kitakā bhavanti,"
    },
    {
      "id": "pv9:2.4",
      "pali": "Ayaṁ nu kiṁ kammamakāsi nārī”ti."
    },
    {
      "id": "pv9:3.1",
      "pali": "“Bhariyā mamesā ahū bhadante,"
    },
    {
      "id": "pv9:3.2",
      "pali": "Adāyikā maccharinī kadariyā;"
    },
    {
      "id": "pv9:3.3",
      "pali": "Sā maṁ dadantaṁ samaṇabrāhmaṇānaṁ,"
    },
    {
      "id": "pv9:3.4",
      "pali": "Akkosati ca paribhāsati ca."
    },
    {
      "id": "pv9:4.1",
      "pali": "‘Gūthañca muttaṁ ruhirañca pubbaṁ,"
    },
    {
      "id": "pv9:4.2",
      "pali": "Paribhuñja tvaṁ asuciṁ sabbakālaṁ;"
    },
    {
      "id": "pv9:4.3",
      "pali": "Etaṁ te paralokasmiṁ hotu,"
    },
    {
      "id": "pv9:4.4",
      "pali": "Vatthā ca te kitakasamā bhavantu’;"
    },
    {
      "id": "pv9:4.5",
      "pali": "Etādisaṁ duccaritaṁ caritvā,"
    },
    {
      "id": "pv9:4.6",
      "pali": "Idhāgatā cirarattāya khādatī”ti."
    },
    {
      "id": "pv9:5.1",
      "pali": "Mahāpesakārapetivatthu navamaṁ."
    }
  ]
}
