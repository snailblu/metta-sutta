{
  "uid": "thig5.2",
  "title": "Vimalātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.2:1.1",
      "pali": "“Mattā vaṇṇena rūpena,"
    },
    {
      "id": "thig5.2:1.2",
      "pali": "sobhaggena yasena ca;"
    },
    {
      "id": "thig5.2:1.3",
      "pali": "Yobbanena cupatthaddhā,"
    },
    {
      "id": "thig5.2:1.4",
      "pali": "aññāsamatimaññihaṁ."
    },
    {
      "id": "thig5.2:2.1",
      "pali": "Vibhūsetvā imaṁ kāyaṁ,"
    },
    {
      "id": "thig5.2:2.2",
      "pali": "sucittaṁ bālalāpanaṁ;"
    },
    {
      "id": "thig5.2:2.3",
      "pali": "Aṭṭhāsiṁ vesidvāramhi,"
    },
    {
      "id": "thig5.2:2.4",
      "pali": "luddo pāsamivoḍḍiya."
    },
    {
      "id": "thig5.2:3.1",
      "pali": "Piḷandhanaṁ vidaṁsentī,"
    },
    {
      "id": "thig5.2:3.2",
      "pali": "guyhaṁ pakāsikaṁ bahuṁ;"
    },
    {
      "id": "thig5.2:3.3",
      "pali": "Akāsiṁ vividhaṁ māyaṁ,"
    },
    {
      "id": "thig5.2:3.4",
      "pali": "ujjagghantī bahuṁ janaṁ."
    },
    {
      "id": "thig5.2:4.1",
      "pali": "Sājja piṇḍaṁ caritvāna,"
    },
    {
      "id": "thig5.2:4.2",
      "pali": "muṇḍā saṅghāṭipārutā;"
    },
    {
      "id": "thig5.2:4.3",
      "pali": "Nisinnā rukkhamūlamhi,"
    },
    {
      "id": "thig5.2:4.4",
      "pali": "avitakkassa lābhinī."
    },
    {
      "id": "thig5.2:5.1",
      "pali": "Sabbe yogā samucchinnā,"
    },
    {
      "id": "thig5.2:5.2",
      "pali": "ye dibbā ye ca mānusā;"
    },
    {
      "id": "thig5.2:5.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thig5.2:5.4",
      "pali": "sītibhūtāmhi nibbutā”ti."
    },
    {
      "id": "thig5.2:6.1",
      "pali": "… Vimalā purāṇagaṇikā therī …."
    }
  ]
}
