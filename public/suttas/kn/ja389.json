{
  "uid": "ja389",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja389:1.1",
      "pali": "“Siṅgīmigo āyatacakkhunetto,"
    },
    {
      "id": "ja389:1.2",
      "pali": "Aṭṭhittaco vārisayo alomo;"
    },
    {
      "id": "ja389:1.3",
      "pali": "Tenābhibhūto kapaṇaṁ rudāmi,"
    },
    {
      "id": "ja389:1.4",
      "pali": "Hare sakhā kissa nu maṁ jahāsi”."
    },
    {
      "id": "ja389:2.1",
      "pali": "So passasanto mahatā phaṇena,"
    },
    {
      "id": "ja389:2.2",
      "pali": "Bhujaṅgamo kakkaṭamajjhapatto;"
    },
    {
      "id": "ja389:2.3",
      "pali": "Sakhā sakhāraṁ paritāyamāno,"
    },
    {
      "id": "ja389:2.4",
      "pali": "Bhujaṅgamaṁ kakkaṭako gahesi."
    },
    {
      "id": "ja389:3.1",
      "pali": "“Na vāyasaṁ no pana kaṇhasappaṁ,"
    },
    {
      "id": "ja389:3.2",
      "pali": "Ghāsatthiko kakkaṭako adeyya;"
    },
    {
      "id": "ja389:3.3",
      "pali": "Pucchāmi taṁ āyatacakkhunetta,"
    },
    {
      "id": "ja389:3.4",
      "pali": "Atha kissa hetumha ubho gahītā”."
    },
    {
      "id": "ja389:4.1",
      "pali": "“Ayaṁ puriso mama atthakāmo,"
    },
    {
      "id": "ja389:4.2",
      "pali": "Yo maṁ gahetvāna dakāya neti;"
    },
    {
      "id": "ja389:4.3",
      "pali": "Tasmiṁ mate dukkhamanappakaṁ me,"
    },
    {
      "id": "ja389:4.4",
      "pali": "Ahañca eso ca ubho na homa."
    },
    {
      "id": "ja389:5.1",
      "pali": "Mamañca disvāna pavaddhakāyaṁ,"
    },
    {
      "id": "ja389:5.2",
      "pali": "Sabbo jano hiṁsitumeva micche;"
    },
    {
      "id": "ja389:5.3",
      "pali": "Sāduñca thūlañca muduñca maṁsaṁ,"
    },
    {
      "id": "ja389:5.4",
      "pali": "Kākāpi maṁ disvāna viheṭhayeyyuṁ”."
    },
    {
      "id": "ja389:6.1",
      "pali": "“Sacetassa hetumha ubho gahītā,"
    },
    {
      "id": "ja389:6.2",
      "pali": "Uṭṭhātu poso visamāvamāmi;"
    },
    {
      "id": "ja389:6.3",
      "pali": "Mamañca kākañca pamuñca khippaṁ,"
    },
    {
      "id": "ja389:6.4",
      "pali": "Pure visaṁ gāḷhamupeti maccaṁ”."
    },
    {
      "id": "ja389:7.1",
      "pali": "“Sappaṁ pamokkhāmi na tāva kākaṁ,"
    },
    {
      "id": "ja389:7.2",
      "pali": "Paṭibandhako hohiti tāva kāko;"
    },
    {
      "id": "ja389:7.3",
      "pali": "Purisañca disvāna sukhiṁ arogaṁ,"
    },
    {
      "id": "ja389:7.4",
      "pali": "Kākaṁ pamokkhāmi yatheva sappaṁ”."
    },
    {
      "id": "ja389:8.1",
      "pali": "“Kāko tadā devadatto ahosi,"
    },
    {
      "id": "ja389:8.2",
      "pali": "Māro pana kaṇhasappo ahosi;"
    },
    {
      "id": "ja389:8.3",
      "pali": "Ānandabhaddo kakkaṭako ahosi,"
    },
    {
      "id": "ja389:8.4",
      "pali": "Ahaṁ tadā brāhmaṇo homi satthā”ti."
    },
    {
      "id": "ja389:9.1",
      "pali": "Suvaṇṇakakkaṭajātakaṁ catutthaṁ."
    }
  ]
}
