{
  "uid": "ja376",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja376:1.1",
      "pali": "“Māsu kujjha bhūmipati,"
    },
    {
      "id": "ja376:1.2",
      "pali": "māsu kujjha rathesabha;"
    },
    {
      "id": "ja376:1.3",
      "pali": "Kuddhaṁ appaṭikujjhanto,"
    },
    {
      "id": "ja376:1.4",
      "pali": "rājā raṭṭhassa pūjito."
    },
    {
      "id": "ja376:2.1",
      "pali": "Gāme vā yadi vāraññe,"
    },
    {
      "id": "ja376:2.2",
      "pali": "ninne vā yadi vā thale;"
    },
    {
      "id": "ja376:2.3",
      "pali": "Sabbattha anusāsāmi,"
    },
    {
      "id": "ja376:2.4",
      "pali": "māsu kujjha rathesabha”."
    },
    {
      "id": "ja376:3.1",
      "pali": "“Avāriyapitā nāma,"
    },
    {
      "id": "ja376:3.2",
      "pali": "ahu gaṅgāya nāviko;"
    },
    {
      "id": "ja376:3.3",
      "pali": "Pubbe janaṁ tāretvāna,"
    },
    {
      "id": "ja376:3.4",
      "pali": "pacchā yācati vetanaṁ;"
    },
    {
      "id": "ja376:3.5",
      "pali": "Tenassa bhaṇḍanaṁ hoti,"
    },
    {
      "id": "ja376:3.6",
      "pali": "na ca bhogehi vaḍḍhati”."
    },
    {
      "id": "ja376:4.1",
      "pali": "“Atiṇṇaṁyeva yācassu,"
    },
    {
      "id": "ja376:4.2",
      "pali": "apāraṁ tāta nāvika;"
    },
    {
      "id": "ja376:4.3",
      "pali": "Añño hi tiṇṇassa mano,"
    },
    {
      "id": "ja376:4.4",
      "pali": "añño hoti pāresino."
    },
    {
      "id": "ja376:5.1",
      "pali": "Gāme vā yadi vāraññe,"
    },
    {
      "id": "ja376:5.2",
      "pali": "ninne vā yadi vā thale;"
    },
    {
      "id": "ja376:5.3",
      "pali": "Sabbattha anusāsāmi,"
    },
    {
      "id": "ja376:5.4",
      "pali": "māsu kujjhittha nāvika”."
    },
    {
      "id": "ja376:6.1",
      "pali": "“Yāyevānusāsaniyā,"
    },
    {
      "id": "ja376:6.2",
      "pali": "rājā gāmavaraṁ adā;"
    },
    {
      "id": "ja376:6.3",
      "pali": "Tāyevānusāsaniyā,"
    },
    {
      "id": "ja376:6.4",
      "pali": "nāviko paharī mukhaṁ."
    },
    {
      "id": "ja376:7.1",
      "pali": "Bhattaṁ bhinnaṁ hatā bhariyā,"
    },
    {
      "id": "ja376:7.2",
      "pali": "Gabbho ca patito chamā;"
    },
    {
      "id": "ja376:7.3",
      "pali": "Migova jātarūpena,"
    },
    {
      "id": "ja376:7.4",
      "pali": "Na tenatthaṁ abandhi sū”ti."
    },
    {
      "id": "ja376:8.1",
      "pali": "Avāriyajātakaṁ paṭhamaṁ."
    }
  ]
}
