{
  "uid": "ja65",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja65:1.1",
      "pali": "“Yathā nadī ca pantho ca,"
    },
    {
      "id": "ja65:1.2",
      "pali": "pānāgāraṁ sabhā papā;"
    },
    {
      "id": "ja65:1.3",
      "pali": "Evaṁ lokitthiyo nāma,"
    },
    {
      "id": "ja65:1.4",
      "pali": "nāsaṁ kujjhanti paṇḍitā”ti."
    },
    {
      "id": "ja65:2.1",
      "pali": "Anabhiratijātakaṁ pañcamaṁ."
    }
  ]
}
