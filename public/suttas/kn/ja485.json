{
  "uid": "ja485",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja485:1.1",
      "pali": "“Upanīyatidaṁ maññe,"
    },
    {
      "id": "ja485:1.2",
      "pali": "cande lohitamaddane;"
    },
    {
      "id": "ja485:1.3",
      "pali": "Ajja jahāmi jīvitaṁ,"
    },
    {
      "id": "ja485:1.4",
      "pali": "pāṇā me cande nirujjhanti."
    },
    {
      "id": "ja485:2.1",
      "pali": "Osīdi me dukkhaṁ hadayaṁ,"
    },
    {
      "id": "ja485:2.2",
      "pali": "Me ḍayhate nitammāmi;"
    },
    {
      "id": "ja485:2.3",
      "pali": "Tava candiyā socantiyā,"
    },
    {
      "id": "ja485:2.4",
      "pali": "Na naṁ aññehi sokehi."
    },
    {
      "id": "ja485:3.1",
      "pali": "Tiṇamiva vanamiva milāyāmi,"
    },
    {
      "id": "ja485:3.2",
      "pali": "Nadī aparipuṇṇāva sussāmi;"
    },
    {
      "id": "ja485:3.3",
      "pali": "Tava candiyā socantiyā,"
    },
    {
      "id": "ja485:3.4",
      "pali": "Na naṁ aññehi sokehi."
    },
    {
      "id": "ja485:4.1",
      "pali": "Vassamiva sare pāde,"
    },
    {
      "id": "ja485:4.2",
      "pali": "Imāni assūni vattare mayhaṁ;"
    },
    {
      "id": "ja485:4.3",
      "pali": "Tava candiyā socantiyā,"
    },
    {
      "id": "ja485:4.4",
      "pali": "Na naṁ aññehi sokehi”."
    },
    {
      "id": "ja485:5.1",
      "pali": "“Pāpo khosi rājaputta,"
    },
    {
      "id": "ja485:5.2",
      "pali": "Yo me icchitaṁ patiṁ varākiyā;"
    },
    {
      "id": "ja485:5.3",
      "pali": "Vijjhasi vanamūlasmiṁ,"
    },
    {
      "id": "ja485:5.4",
      "pali": "Soyaṁ viddho chamā seti."
    },
    {
      "id": "ja485:6.1",
      "pali": "Imaṁ mayhaṁ hadayasokaṁ,"
    },
    {
      "id": "ja485:6.2",
      "pali": "Paṭimuñcatu rājaputta tava mātā;"
    },
    {
      "id": "ja485:6.3",
      "pali": "Yo mayhaṁ hadayasoko,"
    },
    {
      "id": "ja485:6.4",
      "pali": "Kimpurisaṁ avekkhamānāya."
    },
    {
      "id": "ja485:7.1",
      "pali": "Imaṁ mayhaṁ hadayasokaṁ,"
    },
    {
      "id": "ja485:7.2",
      "pali": "Paṭimuñcatu rājaputta tava jāyā;"
    },
    {
      "id": "ja485:7.3",
      "pali": "Yo mayhaṁ hadayasoko,"
    },
    {
      "id": "ja485:7.4",
      "pali": "Kimpurisaṁ avekkhamānāya."
    },
    {
      "id": "ja485:8.1",
      "pali": "Mā ca puttaṁ mā ca patiṁ,"
    },
    {
      "id": "ja485:8.2",
      "pali": "Addakkhi rājaputta tava mātā;"
    },
    {
      "id": "ja485:8.3",
      "pali": "Yo kimpurisaṁ avadhi,"
    },
    {
      "id": "ja485:8.4",
      "pali": "Adūsakaṁ mayha kāmā hi."
    },
    {
      "id": "ja485:9.1",
      "pali": "Mā ca puttaṁ mā ca patiṁ,"
    },
    {
      "id": "ja485:9.2",
      "pali": "Addakkhi rājaputta tava jāyā;"
    },
    {
      "id": "ja485:9.3",
      "pali": "Yo kimpurisaṁ avadhi,"
    },
    {
      "id": "ja485:9.4",
      "pali": "Adūsakaṁ mayha kāmā hi”."
    },
    {
      "id": "ja485:10.1",
      "pali": "“Mā tvaṁ cande rodi,"
    },
    {
      "id": "ja485:10.2",
      "pali": "Mā soci vanatimiramattakkhi;"
    },
    {
      "id": "ja485:10.3",
      "pali": "Mama tvaṁ hehisi bhariyā,"
    },
    {
      "id": "ja485:10.4",
      "pali": "Rājakule pūjitā nārībhi”."
    },
    {
      "id": "ja485:11.1",
      "pali": "“Api nūnahaṁ marissaṁ,"
    },
    {
      "id": "ja485:11.2",
      "pali": "Nāhaṁ rājaputta tava hessaṁ;"
    },
    {
      "id": "ja485:11.3",
      "pali": "Yo kimpurisaṁ avadhi,"
    },
    {
      "id": "ja485:11.4",
      "pali": "Adūsakaṁ mayha kāmā hi”."
    },
    {
      "id": "ja485:12.1",
      "pali": "“Api bhīruke api jīvitukāmike,"
    },
    {
      "id": "ja485:12.2",
      "pali": "Kimpurisi gaccha himavantaṁ;"
    },
    {
      "id": "ja485:12.3",
      "pali": "Tālīsatagarabhojanā,"
    },
    {
      "id": "ja485:12.4",
      "pali": "Aññe taṁ migā ramissanti”."
    },
    {
      "id": "ja485:13.1",
      "pali": "“Te pabbatā tā ca kandarā,"
    },
    {
      "id": "ja485:13.2",
      "pali": "Tā ca giriguhāyo tatheva tiṭṭhanti;"
    },
    {
      "id": "ja485:13.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:13.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:14.1",
      "pali": "Te paṇṇasanthatā ramaṇīyā,"
    },
    {
      "id": "ja485:14.2",
      "pali": "Vāḷamigehi anuciṇṇā;"
    },
    {
      "id": "ja485:14.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:14.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:15.1",
      "pali": "Te pupphasanthatā ramaṇīyā,"
    },
    {
      "id": "ja485:15.2",
      "pali": "Vāḷamigehi anuciṇṇā;"
    },
    {
      "id": "ja485:15.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:15.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:16.1",
      "pali": "Acchā savanti girivananadiyo,"
    },
    {
      "id": "ja485:16.2",
      "pali": "Kusumābhikiṇṇasotāyo;"
    },
    {
      "id": "ja485:16.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:16.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:17.1",
      "pali": "Nīlāni himavato pabbatassa,"
    },
    {
      "id": "ja485:17.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:17.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:17.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:18.1",
      "pali": "Pītāni himavato pabbatassa,"
    },
    {
      "id": "ja485:18.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:18.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:18.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:19.1",
      "pali": "Tambāni himavato pabbatassa,"
    },
    {
      "id": "ja485:19.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:19.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:19.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:20.1",
      "pali": "Tuṅgāni himavato pabbatassa,"
    },
    {
      "id": "ja485:20.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:20.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:20.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:21.1",
      "pali": "Setāni himavato pabbatassa,"
    },
    {
      "id": "ja485:21.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:21.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:21.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:22.1",
      "pali": "Citrāni himavato pabbatassa,"
    },
    {
      "id": "ja485:22.2",
      "pali": "Kūṭāni dassanīyāni;"
    },
    {
      "id": "ja485:22.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:22.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:23.1",
      "pali": "Yakkhagaṇasevite gandhamādane,"
    },
    {
      "id": "ja485:23.2",
      "pali": "Osadhebhi sañchanne;"
    },
    {
      "id": "ja485:23.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:23.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ."
    },
    {
      "id": "ja485:24.1",
      "pali": "Kimpurisasevite gandhamādane,"
    },
    {
      "id": "ja485:24.2",
      "pali": "Osadhebhi sañchanne;"
    },
    {
      "id": "ja485:24.3",
      "pali": "Tattheva taṁ apassantī,"
    },
    {
      "id": "ja485:24.4",
      "pali": "Kimpurisa kathaṁ ahaṁ kassaṁ”."
    },
    {
      "id": "ja485:25.1",
      "pali": "“Vande te ayirabrahme,"
    },
    {
      "id": "ja485:25.2",
      "pali": "Yo me icchitaṁ patiṁ varākiyā;"
    },
    {
      "id": "ja485:25.3",
      "pali": "Amatena abhisiñci,"
    },
    {
      "id": "ja485:25.4",
      "pali": "Samāgatāsmi piyatamena."
    },
    {
      "id": "ja485:26.1",
      "pali": "Vicarāma dāni girivana nadiyo,"
    },
    {
      "id": "ja485:26.2",
      "pali": "Kusumābhikiṇṇasotāyo;"
    },
    {
      "id": "ja485:26.3",
      "pali": "Nānādumavasanāyo,"
    },
    {
      "id": "ja485:26.4",
      "pali": "Piyaṁvadā aññamaññassā”ti."
    },
    {
      "id": "ja485:27.1",
      "pali": "Candakinnarījātakaṁ dutiyaṁ."
    }
  ]
}
