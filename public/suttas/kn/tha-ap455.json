{
  "uid": "tha-ap455",
  "title": "3 Sīhāsanabījiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap455:1.1",
      "pali": "“Tissassāhaṁ bhagavato,"
    },
    {
      "id": "tha-ap455:1.2",
      "pali": "bodhirukkhamavandiyaṁ;"
    },
    {
      "id": "tha-ap455:1.3",
      "pali": "Paggayha bījaniṁ tattha,"
    },
    {
      "id": "tha-ap455:1.4",
      "pali": "sīhāsanamabījahaṁ."
    },
    {
      "id": "tha-ap455:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap455:2.2",
      "pali": "sīhāsanamabījahaṁ;"
    },
    {
      "id": "tha-ap455:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap455:2.4",
      "pali": "bījanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap455:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap455:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap455:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap455:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap455:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap455:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap455:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap455:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap455:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap455:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sīhāsanabījiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap455:7.1",
      "pali": "Sīhāsanabījiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
