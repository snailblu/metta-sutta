{
  "uid": "ja151",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja151:1.1",
      "pali": "“Daḷhaṁ daḷhassa khipati,"
    },
    {
      "id": "ja151:1.2",
      "pali": "balliko mudunā muduṁ;"
    },
    {
      "id": "ja151:1.3",
      "pali": "Sādhumpi sādhunā jeti,"
    },
    {
      "id": "ja151:1.4",
      "pali": "asādhumpi asādhunā;"
    },
    {
      "id": "ja151:1.5",
      "pali": "Etādiso ayaṁ rājā,"
    },
    {
      "id": "ja151:1.6",
      "pali": "maggā uyyāhi sārathi”."
    },
    {
      "id": "ja151:2.1",
      "pali": "“Akkodhena jine kodhaṁ,"
    },
    {
      "id": "ja151:2.2",
      "pali": "asādhuṁ sādhunā jine;"
    },
    {
      "id": "ja151:2.3",
      "pali": "Jine kadariyaṁ dānena,"
    },
    {
      "id": "ja151:2.4",
      "pali": "saccenālikavādinaṁ;"
    },
    {
      "id": "ja151:2.5",
      "pali": "Etādiso ayaṁ rājā,"
    },
    {
      "id": "ja151:2.6",
      "pali": "maggā uyyāhi sārathī”ti."
    },
    {
      "id": "ja151:3.1",
      "pali": "Rājovādajātakaṁ paṭhamaṁ."
    }
  ]
}
