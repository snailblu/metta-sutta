{
  "uid": "thi-ap18",
  "title": "Khemātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap18:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap18:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "thi-ap18:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap18:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap18:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap18:2.2",
      "pali": "jātā seṭṭhikule ahuṁ;"
    },
    {
      "id": "thi-ap18:2.3",
      "pali": "Nānāratanapajjote,"
    },
    {
      "id": "thi-ap18:2.4",
      "pali": "mahāsukhasamappitā."
    },
    {
      "id": "thi-ap18:3.1",
      "pali": "Upetvā taṁ mahāvīraṁ,"
    },
    {
      "id": "thi-ap18:3.2",
      "pali": "assosiṁ dhammadesanaṁ;"
    },
    {
      "id": "thi-ap18:3.3",
      "pali": "Tato jātappasādāhaṁ,"
    },
    {
      "id": "thi-ap18:3.4",
      "pali": "upemi saraṇaṁ jinaṁ."
    },
    {
      "id": "thi-ap18:4.1",
      "pali": "Mātaraṁ pitarañcāhaṁ,"
    },
    {
      "id": "thi-ap18:4.2",
      "pali": "āyācitvā vināyakaṁ;"
    },
    {
      "id": "thi-ap18:4.3",
      "pali": "Nimantayitvā sattāhaṁ,"
    },
    {
      "id": "thi-ap18:4.4",
      "pali": "bhojayiṁ sahasāvakaṁ."
    },
    {
      "id": "thi-ap18:5.1",
      "pali": "Atikkante ca sattāhe,"
    },
    {
      "id": "thi-ap18:5.2",
      "pali": "mahāpaññānamuttamaṁ;"
    },
    {
      "id": "thi-ap18:5.3",
      "pali": "Bhikkhuniṁ etadaggamhi,"
    },
    {
      "id": "thi-ap18:5.4",
      "pali": "ṭhapesi narasārathi."
    },
    {
      "id": "thi-ap18:6.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap18:6.2",
      "pali": "puno tassa mahesino;"
    },
    {
      "id": "thi-ap18:6.3",
      "pali": "Kāraṁ katvāna taṁ ṭhānaṁ,"
    },
    {
      "id": "thi-ap18:6.4",
      "pali": "paṇipacca paṇīdahiṁ."
    },
    {
      "id": "thi-ap18:7.1",
      "pali": "Tato mama jino āha,"
    },
    {
      "id": "thi-ap18:7.2",
      "pali": "‘sijjhataṁ paṇidhī tava;"
    },
    {
      "id": "thi-ap18:7.3",
      "pali": "Sasaṅghe me kataṁ kāraṁ,"
    },
    {
      "id": "thi-ap18:7.4",
      "pali": "appameyyaphalaṁ tayā."
    },
    {
      "id": "thi-ap18:8.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap18:8.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap18:8.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap18:8.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap18:9.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap18:9.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap18:9.3",
      "pali": "Etadaggamanuppattā,"
    },
    {
      "id": "thi-ap18:9.4",
      "pali": "khemā nāma bhavissati’."
    },
    {
      "id": "thi-ap18:10.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap18:10.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap18:10.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap18:10.4",
      "pali": "tāvatiṁsūpagā ahaṁ."
    },
    {
      "id": "thi-ap18:11.1",
      "pali": "Tato cutā yāmamagaṁ,"
    },
    {
      "id": "thi-ap18:11.2",
      "pali": "tatohaṁ tusitaṁ gatā;"
    },
    {
      "id": "thi-ap18:11.3",
      "pali": "Tato ca nimmānaratiṁ,"
    },
    {
      "id": "thi-ap18:11.4",
      "pali": "vasavattipuraṁ tato."
    },
    {
      "id": "thi-ap18:12.1",
      "pali": "Yattha yatthūpapajjāmi,"
    },
    {
      "id": "thi-ap18:12.2",
      "pali": "tassa kammassa vāhasā;"
    },
    {
      "id": "thi-ap18:12.3",
      "pali": "Tattha tattheva rājūnaṁ,"
    },
    {
      "id": "thi-ap18:12.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap18:13.1",
      "pali": "Tato cutā manussatte,"
    },
    {
      "id": "thi-ap18:13.2",
      "pali": "rājūnaṁ cakkavattinaṁ;"
    },
    {
      "id": "thi-ap18:13.3",
      "pali": "Maṇḍalīnañca rājūnaṁ,"
    },
    {
      "id": "thi-ap18:13.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap18:14.1",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "thi-ap18:14.2",
      "pali": "devesu manujesu ca;"
    },
    {
      "id": "thi-ap18:14.3",
      "pali": "Sabbattha sukhitā hutvā,"
    },
    {
      "id": "thi-ap18:14.4",
      "pali": "nekakappesu saṁsariṁ."
    },
    {
      "id": "thi-ap18:15.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap18:15.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "thi-ap18:15.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "thi-ap18:15.4",
      "pali": "sabbadhammavipassako."
    },
    {
      "id": "thi-ap18:16.1",
      "pali": "Tamahaṁ lokanāyakaṁ,"
    },
    {
      "id": "thi-ap18:16.2",
      "pali": "upetvā narasārathiṁ;"
    },
    {
      "id": "thi-ap18:16.3",
      "pali": "Dhammaṁ bhaṇitaṁ sutvāna,"
    },
    {
      "id": "thi-ap18:16.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap18:17.1",
      "pali": "Dasavassasahassāni,"
    },
    {
      "id": "thi-ap18:17.2",
      "pali": "tassa vīrassa sāsane;"
    },
    {
      "id": "thi-ap18:17.3",
      "pali": "Brahmacariyaṁ caritvāna,"
    },
    {
      "id": "thi-ap18:17.4",
      "pali": "yuttayogā bahussutā."
    },
    {
      "id": "thi-ap18:18.1",
      "pali": "Paccayākārakusalā,"
    },
    {
      "id": "thi-ap18:18.2",
      "pali": "catusaccavisāradā;"
    },
    {
      "id": "thi-ap18:18.3",
      "pali": "Nipuṇā cittakathikā,"
    },
    {
      "id": "thi-ap18:18.4",
      "pali": "satthusāsanakārikā."
    },
    {
      "id": "thi-ap18:19.1",
      "pali": "Tato cutāhaṁ tusitaṁ,"
    },
    {
      "id": "thi-ap18:19.2",
      "pali": "upapannā yasassinī;"
    },
    {
      "id": "thi-ap18:19.3",
      "pali": "Abhibhomi tahiṁ aññe,"
    },
    {
      "id": "thi-ap18:19.4",
      "pali": "brahmacārīphalenahaṁ."
    },
    {
      "id": "thi-ap18:20.1",
      "pali": "Yattha yatthūpapannāhaṁ,"
    },
    {
      "id": "thi-ap18:20.2",
      "pali": "mahābhogā mahaddhanā;"
    },
    {
      "id": "thi-ap18:20.3",
      "pali": "Medhāvinī rūpavatī,"
    },
    {
      "id": "thi-ap18:20.4",
      "pali": "vinītaparisāpi ca."
    },
    {
      "id": "thi-ap18:21.1",
      "pali": "Bhavāmi tena kammena,"
    },
    {
      "id": "thi-ap18:21.2",
      "pali": "yogena jinasāsane;"
    },
    {
      "id": "thi-ap18:21.3",
      "pali": "Sabbā sampattiyo mayhaṁ,"
    },
    {
      "id": "thi-ap18:21.4",
      "pali": "sulabhā manaso piyā."
    },
    {
      "id": "thi-ap18:22.1",
      "pali": "Yopi me bhavate bhattā,"
    },
    {
      "id": "thi-ap18:22.2",
      "pali": "yattha yattha gatāyapi;"
    },
    {
      "id": "thi-ap18:22.3",
      "pali": "Vimāneti na maṁ koci,"
    },
    {
      "id": "thi-ap18:22.4",
      "pali": "paṭipattibalena me."
    },
    {
      "id": "thi-ap18:23.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap18:23.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap18:23.3",
      "pali": "Nāmena koṇāgamano,"
    },
    {
      "id": "thi-ap18:23.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap18:24.1",
      "pali": "Tadā hi bārāṇasiyaṁ,"
    },
    {
      "id": "thi-ap18:24.2",
      "pali": "susamiddhakulappajā;"
    },
    {
      "id": "thi-ap18:24.3",
      "pali": "Dhanañjānī sumedhā ca,"
    },
    {
      "id": "thi-ap18:24.4",
      "pali": "ahampi ca tayo janā."
    },
    {
      "id": "thi-ap18:25.1",
      "pali": "Saṅghārāmamadāsimha,"
    },
    {
      "id": "thi-ap18:25.2",
      "pali": "dānasahāyikā pure;"
    },
    {
      "id": "thi-ap18:25.3",
      "pali": "Saṅghassa ca vihārampi,"
    },
    {
      "id": "thi-ap18:25.4",
      "pali": "uddissa kārikā mayaṁ."
    },
    {
      "id": "thi-ap18:26.1",
      "pali": "Tato cutā mayaṁ sabbā,"
    },
    {
      "id": "thi-ap18:26.2",
      "pali": "tāvatiṁsūpagā ahuṁ;"
    },
    {
      "id": "thi-ap18:26.3",
      "pali": "Yasasā aggataṁ pattā,"
    },
    {
      "id": "thi-ap18:26.4",
      "pali": "manussesu tatheva ca."
    },
    {
      "id": "thi-ap18:27.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "thi-ap18:27.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap18:27.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap18:27.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap18:28.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap18:28.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap18:28.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap18:28.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap18:29.1",
      "pali": "Tassāsiṁ jeṭṭhikā dhītā,"
    },
    {
      "id": "thi-ap18:29.2",
      "pali": "samaṇī iti vissutā;"
    },
    {
      "id": "thi-ap18:29.3",
      "pali": "Dhammaṁ sutvā jinaggassa,"
    },
    {
      "id": "thi-ap18:29.4",
      "pali": "pabbajjaṁ samarocayiṁ."
    },
    {
      "id": "thi-ap18:30.1",
      "pali": "Anujāni na no tāto,"
    },
    {
      "id": "thi-ap18:30.2",
      "pali": "agāreva tadā mayaṁ;"
    },
    {
      "id": "thi-ap18:30.3",
      "pali": "Vīsavassasahassāni,"
    },
    {
      "id": "thi-ap18:30.4",
      "pali": "vicarimha atanditā."
    },
    {
      "id": "thi-ap18:31.1",
      "pali": "Komāribrahmacariyaṁ,"
    },
    {
      "id": "thi-ap18:31.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap18:31.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap18:31.4",
      "pali": "muditā satta dhītaro."
    },
    {
      "id": "thi-ap18:32.1",
      "pali": "Samaṇī samaṇaguttā ca,"
    },
    {
      "id": "thi-ap18:32.2",
      "pali": "bhikkhunī bhikkhudāyikā;"
    },
    {
      "id": "thi-ap18:32.3",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "thi-ap18:32.4",
      "pali": "sattamī saṅghadāyikā."
    },
    {
      "id": "thi-ap18:33.1",
      "pali": "Ahaṁ uppalavaṇṇā ca,"
    },
    {
      "id": "thi-ap18:33.2",
      "pali": "paṭācārā ca kuṇḍalā;"
    },
    {
      "id": "thi-ap18:33.3",
      "pali": "Kisāgotamī dhammadinnā,"
    },
    {
      "id": "thi-ap18:33.4",
      "pali": "visākhā hoti sattamī."
    },
    {
      "id": "thi-ap18:34.1",
      "pali": "Kadāci so narādicco,"
    },
    {
      "id": "thi-ap18:34.2",
      "pali": "dhammaṁ desesi abbhutaṁ;"
    },
    {
      "id": "thi-ap18:34.3",
      "pali": "Mahānidānasuttantaṁ,"
    },
    {
      "id": "thi-ap18:34.4",
      "pali": "sutvā taṁ pariyāpuṇiṁ."
    },
    {
      "id": "thi-ap18:35.1",
      "pali": "Tehi kammehi sukatehi,"
    },
    {
      "id": "thi-ap18:35.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap18:35.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap18:35.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap18:36.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap18:36.2",
      "pali": "sākalāya puruttame;"
    },
    {
      "id": "thi-ap18:36.3",
      "pali": "Rañño maddassa dhītāmhi,"
    },
    {
      "id": "thi-ap18:36.4",
      "pali": "manāpā dayitā piyā."
    },
    {
      "id": "thi-ap18:37.1",
      "pali": "Saha me jātamattamhi,"
    },
    {
      "id": "thi-ap18:37.2",
      "pali": "khemaṁ tamhi pure ahu;"
    },
    {
      "id": "thi-ap18:37.3",
      "pali": "Tato khemāti nāmaṁ me,"
    },
    {
      "id": "thi-ap18:37.4",
      "pali": "guṇato upapajjatha."
    },
    {
      "id": "thi-ap18:38.1",
      "pali": "Yadāhaṁ yobbanaṁ pattā,"
    },
    {
      "id": "thi-ap18:38.2",
      "pali": "rūpalāvaññabhūsitā;"
    },
    {
      "id": "thi-ap18:38.3",
      "pali": "Tadā adāsi maṁ tāto,"
    },
    {
      "id": "thi-ap18:38.4",
      "pali": "bimbisārassa rājino."
    },
    {
      "id": "thi-ap18:39.1",
      "pali": "Tassāhaṁ suppiyā āsiṁ,"
    },
    {
      "id": "thi-ap18:39.2",
      "pali": "rūpake lāyane ratā;"
    },
    {
      "id": "thi-ap18:39.3",
      "pali": "Rūpānaṁ dosavādīti,"
    },
    {
      "id": "thi-ap18:39.4",
      "pali": "na upesiṁ mahādayaṁ."
    },
    {
      "id": "thi-ap18:40.1",
      "pali": "Bimbisāro tadā rājā,"
    },
    {
      "id": "thi-ap18:40.2",
      "pali": "mamānuggahabuddhiyā;"
    },
    {
      "id": "thi-ap18:40.3",
      "pali": "Vaṇṇayitvā veḷuvanaṁ,"
    },
    {
      "id": "thi-ap18:40.4",
      "pali": "gāyake gāpayī mamaṁ."
    },
    {
      "id": "thi-ap18:41.1",
      "pali": "Rammaṁ veḷuvanaṁ yena,"
    },
    {
      "id": "thi-ap18:41.2",
      "pali": "na diṭṭhaṁ sugatālayaṁ;"
    },
    {
      "id": "thi-ap18:41.3",
      "pali": "Na tena nandanaṁ diṭṭhaṁ,"
    },
    {
      "id": "thi-ap18:41.4",
      "pali": "iti maññāmase mayaṁ."
    },
    {
      "id": "thi-ap18:42.1",
      "pali": "Yena veḷuvanaṁ diṭṭhaṁ,"
    },
    {
      "id": "thi-ap18:42.2",
      "pali": "naranandananandanaṁ;"
    },
    {
      "id": "thi-ap18:42.3",
      "pali": "Sudiṭṭhaṁ nandanaṁ tena,"
    },
    {
      "id": "thi-ap18:42.4",
      "pali": "amarindasunandanaṁ."
    },
    {
      "id": "thi-ap18:43.1",
      "pali": "Vihāya nandanaṁ devā,"
    },
    {
      "id": "thi-ap18:43.2",
      "pali": "otaritvā mahītalaṁ;"
    },
    {
      "id": "thi-ap18:43.3",
      "pali": "Rammaṁ veḷuvanaṁ disvā,"
    },
    {
      "id": "thi-ap18:43.4",
      "pali": "na tappanti suvimhitā."
    },
    {
      "id": "thi-ap18:44.1",
      "pali": "Rājapuññena nibbattaṁ,"
    },
    {
      "id": "thi-ap18:44.2",
      "pali": "buddhapuññena bhūsitaṁ;"
    },
    {
      "id": "thi-ap18:44.3",
      "pali": "Ko vattā tassa nissesaṁ,"
    },
    {
      "id": "thi-ap18:44.4",
      "pali": "vanassa guṇasañcayaṁ."
    },
    {
      "id": "thi-ap18:45.1",
      "pali": "Taṁ sutvā vanasamiddhaṁ,"
    },
    {
      "id": "thi-ap18:45.2",
      "pali": "mama sotamanoharaṁ;"
    },
    {
      "id": "thi-ap18:45.3",
      "pali": "Daṭṭhukāmā tamuyyānaṁ,"
    },
    {
      "id": "thi-ap18:45.4",
      "pali": "rañño ārocayiṁ tadā."
    },
    {
      "id": "thi-ap18:46.1",
      "pali": "Mahatā parivārena,"
    },
    {
      "id": "thi-ap18:46.2",
      "pali": "tadā ca so mahīpati;"
    },
    {
      "id": "thi-ap18:46.3",
      "pali": "Maṁ pesesi tamuyyānaṁ,"
    },
    {
      "id": "thi-ap18:46.4",
      "pali": "dassanāya samussukaṁ."
    },
    {
      "id": "thi-ap18:47.1",
      "pali": "‘Gaccha passa mahābhoge,"
    },
    {
      "id": "thi-ap18:47.2",
      "pali": "vanaṁ nettarasāyanaṁ;"
    },
    {
      "id": "thi-ap18:47.3",
      "pali": "Yaṁ sadā bhāti siriyā,"
    },
    {
      "id": "thi-ap18:47.4",
      "pali": "sugatābhānurañjitaṁ’."
    },
    {
      "id": "thi-ap18:48.1",
      "pali": "‘Yadā ca piṇḍāya muni,"
    },
    {
      "id": "thi-ap18:48.2",
      "pali": "giribbajapuruttamaṁ;"
    },
    {
      "id": "thi-ap18:48.3",
      "pali": "Paviṭṭhohaṁ tadāyeva,"
    },
    {
      "id": "thi-ap18:48.4",
      "pali": "vanaṁ daṭṭhumupāgamiṁ’."
    },
    {
      "id": "thi-ap18:49.1",
      "pali": "Tadā taṁ phullavipinaṁ,"
    },
    {
      "id": "thi-ap18:49.2",
      "pali": "nānābhamarakūjitaṁ;"
    },
    {
      "id": "thi-ap18:49.3",
      "pali": "Kokilāgītasahitaṁ,"
    },
    {
      "id": "thi-ap18:49.4",
      "pali": "mayūragaṇanaccitaṁ."
    },
    {
      "id": "thi-ap18:50.1",
      "pali": "Appasaddamanākiṇṇaṁ,"
    },
    {
      "id": "thi-ap18:50.2",
      "pali": "nānācaṅkamabhūsitaṁ;"
    },
    {
      "id": "thi-ap18:50.3",
      "pali": "Kuṭimaṇḍapasaṅkiṇṇaṁ,"
    },
    {
      "id": "thi-ap18:50.4",
      "pali": "yogīvaravirājitaṁ."
    },
    {
      "id": "thi-ap18:51.1",
      "pali": "Vicarantī amaññissaṁ,"
    },
    {
      "id": "thi-ap18:51.2",
      "pali": "‘saphalaṁ nayanaṁ mama’;"
    },
    {
      "id": "thi-ap18:51.3",
      "pali": "Tatthāpi taruṇaṁ bhikkhuṁ,"
    },
    {
      "id": "thi-ap18:51.4",
      "pali": "yuttaṁ disvā vicintayiṁ."
    },
    {
      "id": "thi-ap18:52.1",
      "pali": "‘Īdise vipine ramme,"
    },
    {
      "id": "thi-ap18:52.2",
      "pali": "ṭhitoyaṁ navayobbane;"
    },
    {
      "id": "thi-ap18:52.3",
      "pali": "Vasantamiva kantena,"
    },
    {
      "id": "thi-ap18:52.4",
      "pali": "rūpena ca samanvito."
    },
    {
      "id": "thi-ap18:53.1",
      "pali": "Nisinno rukkhamūlamhi,"
    },
    {
      "id": "thi-ap18:53.2",
      "pali": "muṇḍo saṅghāṭipāruto;"
    },
    {
      "id": "thi-ap18:53.3",
      "pali": "Jhāyate vatayaṁ bhikkhu,"
    },
    {
      "id": "thi-ap18:53.4",
      "pali": "hitvā visayajaṁ ratiṁ."
    },
    {
      "id": "thi-ap18:54.1",
      "pali": "Nanu nāma gahaṭṭhena,"
    },
    {
      "id": "thi-ap18:54.2",
      "pali": "kāmaṁ bhutvā yathāsukhaṁ;"
    },
    {
      "id": "thi-ap18:54.3",
      "pali": "Pacchā jiṇṇena dhammoyaṁ,"
    },
    {
      "id": "thi-ap18:54.4",
      "pali": "caritabbo subhaddako’."
    },
    {
      "id": "thi-ap18:55.1",
      "pali": "‘Suññakan’ti viditvāna,"
    },
    {
      "id": "thi-ap18:55.2",
      "pali": "‘gandhagehaṁ jinālayaṁ’;"
    },
    {
      "id": "thi-ap18:55.3",
      "pali": "Upetvā jinamaddakkhaṁ,"
    },
    {
      "id": "thi-ap18:55.4",
      "pali": "udayantaṁva bhākaraṁ."
    },
    {
      "id": "thi-ap18:56.1",
      "pali": "Ekakaṁ sukhamāsīnaṁ,"
    },
    {
      "id": "thi-ap18:56.2",
      "pali": "bījamānaṁ varitthiyā;"
    },
    {
      "id": "thi-ap18:56.3",
      "pali": "Disvānevaṁ vicintesiṁ,"
    },
    {
      "id": "thi-ap18:56.4",
      "pali": "‘nāyaṁ lūkho narāsabho."
    },
    {
      "id": "thi-ap18:57.1",
      "pali": "Sā kaññā kanakābhāsā,"
    },
    {
      "id": "thi-ap18:57.2",
      "pali": "padumānanalocanā;"
    },
    {
      "id": "thi-ap18:57.3",
      "pali": "Bimboṭṭhī kundadasanā,"
    },
    {
      "id": "thi-ap18:57.4",
      "pali": "manonettarasāyanā."
    },
    {
      "id": "thi-ap18:58.1",
      "pali": "Hemadolābhasavanā,"
    },
    {
      "id": "thi-ap18:58.2",
      "pali": "kalikākārasutthanī;"
    },
    {
      "id": "thi-ap18:58.3",
      "pali": "Vedimajjhāva sussoṇī,"
    },
    {
      "id": "thi-ap18:58.4",
      "pali": "rambhoru cārubhūsanā."
    },
    {
      "id": "thi-ap18:59.1",
      "pali": "Rattaṁsakupasambyānā,"
    },
    {
      "id": "thi-ap18:59.2",
      "pali": "nīlamaṭṭhanivāsanā;"
    },
    {
      "id": "thi-ap18:59.3",
      "pali": "Atappaneyyarūpena,"
    },
    {
      "id": "thi-ap18:59.4",
      "pali": "hāsabhāvasamanvitā’."
    },
    {
      "id": "thi-ap18:60.1",
      "pali": "Disvā tamevaṁ cintesiṁ,"
    },
    {
      "id": "thi-ap18:60.2",
      "pali": "‘ahoyamabhirūpinī;"
    },
    {
      "id": "thi-ap18:60.3",
      "pali": "Na mayānena nettena,"
    },
    {
      "id": "thi-ap18:60.4",
      "pali": "diṭṭhapubbā kudācanaṁ’."
    },
    {
      "id": "thi-ap18:61.1",
      "pali": "Tato jarābhibhūtā sā,"
    },
    {
      "id": "thi-ap18:61.2",
      "pali": "vivaṇṇā vikatānanā;"
    },
    {
      "id": "thi-ap18:61.3",
      "pali": "Bhinnadantā setasirā,"
    },
    {
      "id": "thi-ap18:61.4",
      "pali": "salālā vadanāsuci."
    },
    {
      "id": "thi-ap18:62.1",
      "pali": "Saṅkhittakaṇṇā setakkhī,"
    },
    {
      "id": "thi-ap18:62.2",
      "pali": "lambāsubhapayodharā;"
    },
    {
      "id": "thi-ap18:62.3",
      "pali": "Valivitatasabbaṅgī,"
    },
    {
      "id": "thi-ap18:62.4",
      "pali": "sirāvitatadehinī."
    },
    {
      "id": "thi-ap18:63.1",
      "pali": "Nataṅgā daṇḍadutiyā,"
    },
    {
      "id": "thi-ap18:63.2",
      "pali": "upphāsulikatā kisā;"
    },
    {
      "id": "thi-ap18:63.3",
      "pali": "Pavedhamānā patitā,"
    },
    {
      "id": "thi-ap18:63.4",
      "pali": "nissasantī muhuṁ muhuṁ."
    },
    {
      "id": "thi-ap18:64.1",
      "pali": "Tato me āsi saṁvego,"
    },
    {
      "id": "thi-ap18:64.2",
      "pali": "abbhuto lomahaṁsano;"
    },
    {
      "id": "thi-ap18:64.3",
      "pali": "‘Dhiratthu rūpaṁ asuciṁ,"
    },
    {
      "id": "thi-ap18:64.4",
      "pali": "ramante yattha bālisā’."
    },
    {
      "id": "thi-ap18:65.1",
      "pali": "Tadā mahākāruṇiko,"
    },
    {
      "id": "thi-ap18:65.2",
      "pali": "disvā saṁviggamānasaṁ;"
    },
    {
      "id": "thi-ap18:65.3",
      "pali": "Udaggacitto sugato,"
    },
    {
      "id": "thi-ap18:65.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "thi-ap18:66.1",
      "pali": "‘Āturaṁ asuciṁ pūtiṁ,"
    },
    {
      "id": "thi-ap18:66.2",
      "pali": "passa kheme samussayaṁ;"
    },
    {
      "id": "thi-ap18:66.3",
      "pali": "Uggharantaṁ paggharantaṁ,"
    },
    {
      "id": "thi-ap18:66.4",
      "pali": "bālānaṁ abhinanditaṁ."
    },
    {
      "id": "thi-ap18:67.1",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "thi-ap18:67.2",
      "pali": "ekaggaṁ susamāhitaṁ;"
    },
    {
      "id": "thi-ap18:67.3",
      "pali": "Sati kāyagatā tyatthu,"
    },
    {
      "id": "thi-ap18:67.4",
      "pali": "nibbidā bahulā bhava."
    },
    {
      "id": "thi-ap18:68.1",
      "pali": "Yathā idaṁ tathā etaṁ,"
    },
    {
      "id": "thi-ap18:68.2",
      "pali": "yathā etaṁ tathā idaṁ;"
    },
    {
      "id": "thi-ap18:68.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "thi-ap18:68.4",
      "pali": "kāye chandaṁ virājaya."
    },
    {
      "id": "thi-ap18:69.1",
      "pali": "Animittañca bhāvehi,"
    },
    {
      "id": "thi-ap18:69.2",
      "pali": "mānānusayamujjaha;"
    },
    {
      "id": "thi-ap18:69.3",
      "pali": "Tato mānābhisamayā,"
    },
    {
      "id": "thi-ap18:69.4",
      "pali": "upasantā carissasi."
    },
    {
      "id": "thi-ap18:70.1",
      "pali": "Ye rāgarattānupatanti sotaṁ,"
    },
    {
      "id": "thi-ap18:70.2",
      "pali": "Sayaṁ kataṁ makkaṭakova jālaṁ;"
    },
    {
      "id": "thi-ap18:70.3",
      "pali": "Etampi chetvāna paribbajanti,"
    },
    {
      "id": "thi-ap18:70.4",
      "pali": "Anapekkhino kāmasukhaṁ pahāya’."
    },
    {
      "id": "thi-ap18:71.1",
      "pali": "Tato kallitacittaṁ maṁ,"
    },
    {
      "id": "thi-ap18:71.2",
      "pali": "ñatvāna narasārathi;"
    },
    {
      "id": "thi-ap18:71.3",
      "pali": "Mahānidānaṁ desesi,"
    },
    {
      "id": "thi-ap18:71.4",
      "pali": "suttantaṁ vinayāya me."
    },
    {
      "id": "thi-ap18:72.1",
      "pali": "Sutvā suttantaseṭṭhaṁ taṁ,"
    },
    {
      "id": "thi-ap18:72.2",
      "pali": "pubbasaññamanussariṁ;"
    },
    {
      "id": "thi-ap18:72.3",
      "pali": "Tattha ṭhitāvahaṁ santī,"
    },
    {
      "id": "thi-ap18:72.4",
      "pali": "dhammacakkhuṁ visodhayiṁ."
    },
    {
      "id": "thi-ap18:73.1",
      "pali": "Nipatitvā mahesissa,"
    },
    {
      "id": "thi-ap18:73.2",
      "pali": "pādamūlamhi tāvade;"
    },
    {
      "id": "thi-ap18:73.3",
      "pali": "Accayaṁ desanatthāya,"
    },
    {
      "id": "thi-ap18:73.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "thi-ap18:74.1",
      "pali": "‘Namo te sabbadassāvī,"
    },
    {
      "id": "thi-ap18:74.2",
      "pali": "namo te karuṇākara;"
    },
    {
      "id": "thi-ap18:74.3",
      "pali": "Namo te tiṇṇasaṁsāra,"
    },
    {
      "id": "thi-ap18:74.4",
      "pali": "namo te amataṁdada."
    },
    {
      "id": "thi-ap18:75.1",
      "pali": "Diṭṭhigahanapakkhandā,"
    },
    {
      "id": "thi-ap18:75.2",
      "pali": "kāmarāgavimohitā;"
    },
    {
      "id": "thi-ap18:75.3",
      "pali": "Tayā sammā upāyena,"
    },
    {
      "id": "thi-ap18:75.4",
      "pali": "vinītā vinaye ratā."
    },
    {
      "id": "thi-ap18:76.1",
      "pali": "Adassanena vibhogā,"
    },
    {
      "id": "thi-ap18:76.2",
      "pali": "tādisānaṁ mahesinaṁ;"
    },
    {
      "id": "thi-ap18:76.3",
      "pali": "Anubhonti mahādukkhaṁ,"
    },
    {
      "id": "thi-ap18:76.4",
      "pali": "sattā saṁsārasāgare."
    },
    {
      "id": "thi-ap18:77.1",
      "pali": "Yadāhaṁ lokasaraṇaṁ,"
    },
    {
      "id": "thi-ap18:77.2",
      "pali": "araṇaṁ araṇantaguṁ;"
    },
    {
      "id": "thi-ap18:77.3",
      "pali": "Nāddasāmi adūraṭṭhaṁ,"
    },
    {
      "id": "thi-ap18:77.4",
      "pali": "desayāmi tamaccayaṁ."
    },
    {
      "id": "thi-ap18:78.1",
      "pali": "Mahāhitaṁ varadadaṁ,"
    },
    {
      "id": "thi-ap18:78.2",
      "pali": "ahitoti visaṅkitā;"
    },
    {
      "id": "thi-ap18:78.3",
      "pali": "Nopesiṁ rūpaniratā,"
    },
    {
      "id": "thi-ap18:78.4",
      "pali": "desayāmi tamaccayaṁ’."
    },
    {
      "id": "thi-ap18:79.1",
      "pali": "Tadā madhuranigghoso,"
    },
    {
      "id": "thi-ap18:79.2",
      "pali": "mahākāruṇiko jino;"
    },
    {
      "id": "thi-ap18:79.3",
      "pali": "Avoca tiṭṭha khemeti,"
    },
    {
      "id": "thi-ap18:79.4",
      "pali": "siñcanto amatena maṁ."
    },
    {
      "id": "thi-ap18:80.1",
      "pali": "Tadā paṇamya sirasā,"
    },
    {
      "id": "thi-ap18:80.2",
      "pali": "katvā ca naṁ padakkhiṇaṁ;"
    },
    {
      "id": "thi-ap18:80.3",
      "pali": "Gantvā disvā narapatiṁ,"
    },
    {
      "id": "thi-ap18:80.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "thi-ap18:81.1",
      "pali": "‘Aho sammā upāyo te,"
    },
    {
      "id": "thi-ap18:81.2",
      "pali": "cintitoyamarindama;"
    },
    {
      "id": "thi-ap18:81.3",
      "pali": "Vanadassanakāmāya,"
    },
    {
      "id": "thi-ap18:81.4",
      "pali": "diṭṭho nibbānato muni."
    },
    {
      "id": "thi-ap18:82.1",
      "pali": "Yadi te ruccate rāja,"
    },
    {
      "id": "thi-ap18:82.2",
      "pali": "sāsane tassa tādino;"
    },
    {
      "id": "thi-ap18:82.3",
      "pali": "Pabbajissāmi rūpehaṁ,"
    },
    {
      "id": "thi-ap18:82.4",
      "pali": "nibbinnā munivāṇinā’."
    },
    {
      "id": "thi-ap18:83.1",
      "pali": "Dutiyaṁ bhāṇavāraṁ."
    },
    {
      "id": "thi-ap18:84.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "thi-ap18:84.2",
      "pali": "tadāha sa mahīpati;"
    },
    {
      "id": "thi-ap18:84.3",
      "pali": "‘Anujānāmi te bhadde,"
    },
    {
      "id": "thi-ap18:84.4",
      "pali": "pabbajjā tava sijjhatu’."
    },
    {
      "id": "thi-ap18:85.1",
      "pali": "Pabbajitvā tadā cāhaṁ,"
    },
    {
      "id": "thi-ap18:85.2",
      "pali": "addhamāse upaṭṭhite;"
    },
    {
      "id": "thi-ap18:85.3",
      "pali": "Dīpodayañca bhedañca,"
    },
    {
      "id": "thi-ap18:85.4",
      "pali": "disvā saṁviggamānasā."
    },
    {
      "id": "thi-ap18:86.1",
      "pali": "Nibbinnā sabbasaṅkhāre,"
    },
    {
      "id": "thi-ap18:86.2",
      "pali": "paccayākārakovidā;"
    },
    {
      "id": "thi-ap18:86.3",
      "pali": "Caturoghe atikkamma,"
    },
    {
      "id": "thi-ap18:86.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap18:87.1",
      "pali": "Iddhīsu ca vasī āsiṁ,"
    },
    {
      "id": "thi-ap18:87.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap18:87.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap18:87.4",
      "pali": "vasī cāpi bhavāmahaṁ."
    },
    {
      "id": "thi-ap18:88.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap18:88.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap18:88.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap18:88.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap18:89.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap18:89.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap18:89.3",
      "pali": "Parisuddhaṁ mama ñāṇaṁ,"
    },
    {
      "id": "thi-ap18:89.4",
      "pali": "uppannaṁ buddhasāsane."
    },
    {
      "id": "thi-ap18:90.1",
      "pali": "Kusalāhaṁ visuddhīsu,"
    },
    {
      "id": "thi-ap18:90.2",
      "pali": "kathāvatthuvisāradā;"
    },
    {
      "id": "thi-ap18:90.3",
      "pali": "Abhidhammanayaññū ca,"
    },
    {
      "id": "thi-ap18:90.4",
      "pali": "vasippattāmhi sāsane."
    },
    {
      "id": "thi-ap18:91.1",
      "pali": "Tato toraṇavatthusmiṁ,"
    },
    {
      "id": "thi-ap18:91.2",
      "pali": "raññā kosalasāminā;"
    },
    {
      "id": "thi-ap18:91.3",
      "pali": "Pucchitā nipuṇe pañhe,"
    },
    {
      "id": "thi-ap18:91.4",
      "pali": "byākarontī yathātathaṁ."
    },
    {
      "id": "thi-ap18:92.1",
      "pali": "Tadā sa rājā sugataṁ,"
    },
    {
      "id": "thi-ap18:92.2",
      "pali": "upasaṅkamma pucchatha;"
    },
    {
      "id": "thi-ap18:92.3",
      "pali": "Tatheva buddho byākāsi,"
    },
    {
      "id": "thi-ap18:92.4",
      "pali": "yathā te byākatā mayā."
    },
    {
      "id": "thi-ap18:93.1",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "thi-ap18:93.2",
      "pali": "etadagge ṭhapesi maṁ;"
    },
    {
      "id": "thi-ap18:93.3",
      "pali": "Mahāpaññānamaggāti,"
    },
    {
      "id": "thi-ap18:93.4",
      "pali": "bhikkhunīnaṁ naruttamo."
    },
    {
      "id": "thi-ap18:94.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap18:94.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap18:94.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap18:95.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap18:95.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap18:95.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap18:96.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap18:96.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap18:96.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap18:97.1",
      "pali": "Itthaṁ sudaṁ khemā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap18:98.1",
      "pali": "Khemātheriyāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
