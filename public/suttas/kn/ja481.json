{
  "uid": "ja481",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja481:1.1",
      "pali": "“Ahameva dubbhāsitaṁ bhāsi bālo,"
    },
    {
      "id": "ja481:1.2",
      "pali": "Bhekovaraññe ahimavhāyamāno;"
    },
    {
      "id": "ja481:1.3",
      "pali": "Takkāriye sobbhamimaṁ patāmi,"
    },
    {
      "id": "ja481:1.4",
      "pali": "Na kireva sādhu ativelabhāṇī”."
    },
    {
      "id": "ja481:2.1",
      "pali": "“Pappoti macco ativelabhāṇī,"
    },
    {
      "id": "ja481:2.2",
      "pali": "Bandhaṁ vadhaṁ sokapariddavañca;"
    },
    {
      "id": "ja481:2.3",
      "pali": "Attānameva garahāsi ettha,"
    },
    {
      "id": "ja481:2.4",
      "pali": "Ācera yaṁ taṁ nikhaṇanti sobbhe”."
    },
    {
      "id": "ja481:3.1",
      "pali": "“Kimevahaṁ tuṇḍilamanupucchiṁ,"
    },
    {
      "id": "ja481:3.2",
      "pali": "Kareyya saṁ bhātaraṁ kāḷikāyaṁ;"
    },
    {
      "id": "ja481:3.3",
      "pali": "Naggovahaṁ vatthayugañca jīno,"
    },
    {
      "id": "ja481:3.4",
      "pali": "Ayampi attho bahutādisova”."
    },
    {
      "id": "ja481:4.1",
      "pali": "“Yo yujjhamānānamayujjhamāno,"
    },
    {
      "id": "ja481:4.2",
      "pali": "Meṇḍantaraṁ accupatī kuliṅgo;"
    },
    {
      "id": "ja481:4.3",
      "pali": "So piṁsito meṇḍasirehi tattha,"
    },
    {
      "id": "ja481:4.4",
      "pali": "Ayampi attho bahutādisova."
    },
    {
      "id": "ja481:5.1",
      "pali": "Caturo janā potthakamaggahesuṁ,"
    },
    {
      "id": "ja481:5.2",
      "pali": "Ekañca posaṁ anurakkhamānā;"
    },
    {
      "id": "ja481:5.3",
      "pali": "Sabbeva te bhinnasirā sayiṁsu,"
    },
    {
      "id": "ja481:5.4",
      "pali": "Ayampi attho bahutādisova."
    },
    {
      "id": "ja481:6.1",
      "pali": "Ajā yathā veḷugumbasmiṁ baddhā,"
    },
    {
      "id": "ja481:6.2",
      "pali": "Avakkhipantī asimajjhagacchi;"
    },
    {
      "id": "ja481:6.3",
      "pali": "Teneva tassā galakāvakantaṁ,"
    },
    {
      "id": "ja481:6.4",
      "pali": "Ayampi attho bahutādisova”."
    },
    {
      "id": "ja481:7.1",
      "pali": "“Ime na devā na gandhabbaputtā,"
    },
    {
      "id": "ja481:7.2",
      "pali": "Migā ime atthavasaṁ gatā me;"
    },
    {
      "id": "ja481:7.3",
      "pali": "Ekañca naṁ sāyamāse pacantu,"
    },
    {
      "id": "ja481:7.4",
      "pali": "Ekaṁ punappātarāse pacantu”."
    },
    {
      "id": "ja481:8.1",
      "pali": "“Sataṁ sahassāni dubhāsitāni,"
    },
    {
      "id": "ja481:8.2",
      "pali": "Kalampi nāgghanti subhāsitassa;"
    },
    {
      "id": "ja481:8.3",
      "pali": "Dubbhāsitaṁ saṅkamāno kileso,"
    },
    {
      "id": "ja481:8.4",
      "pali": "Tasmā tuṇhī kimpurisā na bālyā”."
    },
    {
      "id": "ja481:9.1",
      "pali": "“Yā mesā byāhāsi pamuñcathetaṁ,"
    },
    {
      "id": "ja481:9.2",
      "pali": "Giriñca naṁ himavantaṁ nayantu;"
    },
    {
      "id": "ja481:9.3",
      "pali": "Imañca kho dentu mahānasāya,"
    },
    {
      "id": "ja481:9.4",
      "pali": "Pātova naṁ pātarāse pacantu”."
    },
    {
      "id": "ja481:10.1",
      "pali": "“Pajjunnanāthā pasavo,"
    },
    {
      "id": "ja481:10.2",
      "pali": "pasunāthā ayaṁ pajā;"
    },
    {
      "id": "ja481:10.3",
      "pali": "Tvaṁ nāthosi mahārāja,"
    },
    {
      "id": "ja481:10.4",
      "pali": "nāthohaṁ bhariyāya me;"
    },
    {
      "id": "ja481:10.5",
      "pali": "Dvinnamaññataraṁ ñatvā,"
    },
    {
      "id": "ja481:10.6",
      "pali": "mutto gaccheyya pabbataṁ."
    },
    {
      "id": "ja481:11.1",
      "pali": "Na ve nindā suparivajjayetha,"
    },
    {
      "id": "ja481:11.2",
      "pali": "Nānā janā sevitabbā janinda;"
    },
    {
      "id": "ja481:11.3",
      "pali": "Yeneva eko labhate pasaṁsaṁ,"
    },
    {
      "id": "ja481:11.4",
      "pali": "Teneva añño labhate ninditāraṁ."
    },
    {
      "id": "ja481:12.1",
      "pali": "Sabbo loko paricitto aticitto,"
    },
    {
      "id": "ja481:12.2",
      "pali": "Sabbo loko cittavā samhi citte;"
    },
    {
      "id": "ja481:12.3",
      "pali": "Paccekacittā puthu sabbasattā,"
    },
    {
      "id": "ja481:12.4",
      "pali": "Kassīdha cittassa vasena vatte”."
    },
    {
      "id": "ja481:13.1",
      "pali": "“Tuṇhī ahū kimpuriso sabhariyo,"
    },
    {
      "id": "ja481:13.2",
      "pali": "Yo dāni byāhāsi bhayassa bhīto;"
    },
    {
      "id": "ja481:13.3",
      "pali": "So dāni mutto sukhito arogo,"
    },
    {
      "id": "ja481:13.4",
      "pali": "Vācākirevatthavatī narānan”ti."
    },
    {
      "id": "ja481:14.1",
      "pali": "Takkāriyajātakaṁ aṭṭhamaṁ."
    }
  ]
}
