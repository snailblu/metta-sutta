{
  "uid": "thag1.11",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.11:1.1",
      "pali": "“Pāmojjabahulo bhikkhu,"
    },
    {
      "id": "thag1.11:1.2",
      "pali": "dhamme buddhappavedite;"
    },
    {
      "id": "thag1.11:1.3",
      "pali": "Adhigacche padaṁ santaṁ,"
    },
    {
      "id": "thag1.11:1.4",
      "pali": "saṅkhārūpasamaṁ sukhan”ti."
    },
    {
      "id": "thag1.11:1.5",
      "pali": "… Cūḷavaccho thero …."
    }
  ]
}
