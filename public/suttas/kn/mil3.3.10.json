{
  "uid": "mil3.3.10",
  "title": "10. Saññālakkhaṇapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.3.10:1.1",
      "pali": "“Bhante nāgasena, kiṁlakkhaṇā saññā”ti?"
    },
    {
      "id": "mil3.3.10:1.2",
      "pali": "“Sañjānanalakkhaṇā, mahārāja, saññā."
    },
    {
      "id": "mil3.3.10:1.3",
      "pali": "Kiṁ sañjānāti?"
    },
    {
      "id": "mil3.3.10:1.4",
      "pali": "Nīlampi sañjānāti, pītampi sañjānāti, lohitampi sañjānāti, odātampi sañjānāti, mañjiṭṭhampi sañjānāti."
    },
    {
      "id": "mil3.3.10:1.5",
      "pali": "Evaṁ kho, mahārāja, sañjānanalakkhaṇā saññā”ti."
    },
    {
      "id": "mil3.3.10:2.1",
      "pali": "“Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.3.10:2.2",
      "pali": "“Yathā, mahārāja, rañño bhaṇḍāgāriko bhaṇḍāgāraṁ pavisitvā nīlapītalohitodātamañjiṭṭhāni rājabhogāni rūpāni passitvā sañjānāti."
    },
    {
      "id": "mil3.3.10:2.3",
      "pali": "Evaṁ kho, mahārāja, sañjānanalakkhaṇā saññā”ti."
    },
    {
      "id": "mil3.3.10:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.3.10:4.1",
      "pali": "Saññālakkhaṇapañho dasamo."
    }
  ]
}
