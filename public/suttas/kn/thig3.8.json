{
  "uid": "thig3.8",
  "title": "Somātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.8:1.1",
      "pali": "“Yaṁ taṁ isīhi pattabbaṁ,"
    },
    {
      "id": "thig3.8:1.2",
      "pali": "ṭhānaṁ durabhisambhavaṁ;"
    },
    {
      "id": "thig3.8:1.3",
      "pali": "Na taṁ dvaṅgulapaññāya,"
    },
    {
      "id": "thig3.8:1.4",
      "pali": "sakkā pappotumitthiyā”."
    },
    {
      "id": "thig3.8:2.1",
      "pali": "“Itthibhāvo no kiṁ kayirā,"
    },
    {
      "id": "thig3.8:2.2",
      "pali": "cittamhi susamāhite;"
    },
    {
      "id": "thig3.8:2.3",
      "pali": "Ñāṇamhi vattamānamhi,"
    },
    {
      "id": "thig3.8:2.4",
      "pali": "sammā dhammaṁ vipassato."
    },
    {
      "id": "thig3.8:3.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig3.8:3.2",
      "pali": "Tamokhandho padālito;"
    },
    {
      "id": "thig3.8:3.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig3.8:3.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "thig3.8:4.1",
      "pali": "… Somā therī …."
    },
    {
      "id": "thig3.8:5.1",
      "pali": "Tikanipāto niṭṭhito."
    }
  ]
}
