{
  "uid": "ja141",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja141:1.1",
      "pali": "“Na pāpajanasaṁsevī,"
    },
    {
      "id": "ja141:1.2",
      "pali": "accantasukhamedhati;"
    },
    {
      "id": "ja141:1.3",
      "pali": "Godhākulaṁ kakaṇṭāva,"
    },
    {
      "id": "ja141:1.4",
      "pali": "kaliṁ pāpeti attanan”ti."
    },
    {
      "id": "ja141:2.1",
      "pali": "Godhajātakaṁ paṭhamaṁ."
    }
  ]
}
