{
  "uid": "kp8",
  "title": "Nidhikaṇḍasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "kp8:1.1",
      "pali": "Nidhiṁ nidheti puriso,"
    },
    {
      "id": "kp8:1.2",
      "pali": "gambhīre odakantike;"
    },
    {
      "id": "kp8:1.3",
      "pali": "Atthe kicce samuppanne,"
    },
    {
      "id": "kp8:1.4",
      "pali": "atthāya me bhavissati."
    },
    {
      "id": "kp8:2.1",
      "pali": "Rājato vā duruttassa,"
    },
    {
      "id": "kp8:2.2",
      "pali": "corato pīḷitassa vā;"
    },
    {
      "id": "kp8:2.3",
      "pali": "Iṇassa vā pamokkhāya,"
    },
    {
      "id": "kp8:2.4",
      "pali": "dubbhikkhe āpadāsu vā;"
    },
    {
      "id": "kp8:2.5",
      "pali": "Etadatthāya lokasmiṁ,"
    },
    {
      "id": "kp8:2.6",
      "pali": "nidhi nāma nidhīyati."
    },
    {
      "id": "kp8:3.1",
      "pali": "Tāvassunihito santo,"
    },
    {
      "id": "kp8:3.2",
      "pali": "gambhīre odakantike;"
    },
    {
      "id": "kp8:3.3",
      "pali": "Na sabbo sabbadā eva,"
    },
    {
      "id": "kp8:3.4",
      "pali": "tassa taṁ upakappati."
    },
    {
      "id": "kp8:4.1",
      "pali": "Nidhi vā ṭhānā cavati,"
    },
    {
      "id": "kp8:4.2",
      "pali": "saññā vāssa vimuyhati;"
    },
    {
      "id": "kp8:4.3",
      "pali": "Nāgā vā apanāmenti,"
    },
    {
      "id": "kp8:4.4",
      "pali": "yakkhā vāpi haranti naṁ."
    },
    {
      "id": "kp8:5.1",
      "pali": "Appiyā vāpi dāyādā,"
    },
    {
      "id": "kp8:5.2",
      "pali": "uddharanti apassato;"
    },
    {
      "id": "kp8:5.3",
      "pali": "Yadā puññakkhayo hoti,"
    },
    {
      "id": "kp8:5.4",
      "pali": "sabbametaṁ vinassati."
    },
    {
      "id": "kp8:6.1",
      "pali": "Yassa dānena sīlena,"
    },
    {
      "id": "kp8:6.2",
      "pali": "saṁyamena damena ca;"
    },
    {
      "id": "kp8:6.3",
      "pali": "Nidhī sunihito hoti,"
    },
    {
      "id": "kp8:6.4",
      "pali": "itthiyā purisassa vā."
    },
    {
      "id": "kp8:7.1",
      "pali": "Cetiyamhi ca saṅghe vā,"
    },
    {
      "id": "kp8:7.2",
      "pali": "puggale atithīsu vā;"
    },
    {
      "id": "kp8:7.3",
      "pali": "Mātari pitari cāpi,"
    },
    {
      "id": "kp8:7.4",
      "pali": "atho jeṭṭhamhi bhātari."
    },
    {
      "id": "kp8:8.1",
      "pali": "Eso nidhi sunihito,"
    },
    {
      "id": "kp8:8.2",
      "pali": "ajeyyo anugāmiko;"
    },
    {
      "id": "kp8:8.3",
      "pali": "Pahāya gamanīyesu,"
    },
    {
      "id": "kp8:8.4",
      "pali": "etaṁ ādāya gacchati."
    },
    {
      "id": "kp8:9.1",
      "pali": "Asādhāraṇamaññesaṁ,"
    },
    {
      "id": "kp8:9.2",
      "pali": "acorāharaṇo nidhi;"
    },
    {
      "id": "kp8:9.3",
      "pali": "Kayirātha dhīro puññāni,"
    },
    {
      "id": "kp8:9.4",
      "pali": "yo nidhi anugāmiko."
    },
    {
      "id": "kp8:10.1",
      "pali": "Esa devamanussānaṁ,"
    },
    {
      "id": "kp8:10.2",
      "pali": "sabbakāmadado nidhi;"
    },
    {
      "id": "kp8:10.3",
      "pali": "Yaṁ yadevābhipatthenti,"
    },
    {
      "id": "kp8:10.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:11.1",
      "pali": "Suvaṇṇatā susaratā,"
    },
    {
      "id": "kp8:11.2",
      "pali": "susaṇṭhānā surūpatā;"
    },
    {
      "id": "kp8:11.3",
      "pali": "Ādhipaccaparivāro,"
    },
    {
      "id": "kp8:11.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:12.1",
      "pali": "Padesarajjaṁ issariyaṁ,"
    },
    {
      "id": "kp8:12.2",
      "pali": "cakkavattisukhaṁ piyaṁ;"
    },
    {
      "id": "kp8:12.3",
      "pali": "Devarajjampi dibbesu,"
    },
    {
      "id": "kp8:12.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:13.1",
      "pali": "Mānussikā ca sampatti,"
    },
    {
      "id": "kp8:13.2",
      "pali": "devaloke ca yā rati;"
    },
    {
      "id": "kp8:13.3",
      "pali": "Yā ca nibbānasampatti,"
    },
    {
      "id": "kp8:13.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:14.1",
      "pali": "Mittasampadamāgamma,"
    },
    {
      "id": "kp8:14.2",
      "pali": "yonisova payuñjato;"
    },
    {
      "id": "kp8:14.3",
      "pali": "Vijjāvimuttivasībhāvo,"
    },
    {
      "id": "kp8:14.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:15.1",
      "pali": "Paṭisambhidā vimokkhā ca,"
    },
    {
      "id": "kp8:15.2",
      "pali": "yā ca sāvakapāramī;"
    },
    {
      "id": "kp8:15.3",
      "pali": "Paccekabodhi buddhabhūmi,"
    },
    {
      "id": "kp8:15.4",
      "pali": "sabbametena labbhati."
    },
    {
      "id": "kp8:16.1",
      "pali": "Evaṁ mahatthikā esā,"
    },
    {
      "id": "kp8:16.2",
      "pali": "yadidaṁ puññasampadā;"
    },
    {
      "id": "kp8:16.3",
      "pali": "Tasmā dhīrā pasaṁsanti,"
    },
    {
      "id": "kp8:16.4",
      "pali": "paṇḍitā katapuññatanti."
    },
    {
      "id": "kp8:17.1",
      "pali": "Nidhikaṇḍasuttaṁ."
    }
  ]
}
