{
  "uid": "ja194",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja194:1.1",
      "pali": "“Na santi devā pavasanti nūna,"
    },
    {
      "id": "ja194:1.2",
      "pali": "Na hi nūna santi idha lokapālā;"
    },
    {
      "id": "ja194:1.3",
      "pali": "Sahasā karontānamasaññatānaṁ,"
    },
    {
      "id": "ja194:1.4",
      "pali": "Na hi nūna santī paṭisedhitāro”."
    },
    {
      "id": "ja194:2.1",
      "pali": "“Akāle vassatī tassa,"
    },
    {
      "id": "ja194:2.2",
      "pali": "kāle tassa na vassati;"
    },
    {
      "id": "ja194:2.3",
      "pali": "Saggā ca cavati ṭhānā,"
    },
    {
      "id": "ja194:2.4",
      "pali": "nanu so tāvatā hato”ti."
    },
    {
      "id": "ja194:3.1",
      "pali": "Maṇicorajātakaṁ catutthaṁ."
    }
  ]
}
