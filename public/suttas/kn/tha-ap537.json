{
  "uid": "tha-ap537",
  "title": "Kumārakassapattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap537:1.1",
      "pali": "“Ito satasahassamhi,"
    },
    {
      "id": "tha-ap537:1.2",
      "pali": "kappe uppajji nāyako;"
    },
    {
      "id": "tha-ap537:1.3",
      "pali": "Sabbalokahito vīro,"
    },
    {
      "id": "tha-ap537:1.4",
      "pali": "padumuttaranāmako."
    },
    {
      "id": "tha-ap537:2.1",
      "pali": "Tadāhaṁ brāhmaṇo hutvā,"
    },
    {
      "id": "tha-ap537:2.2",
      "pali": "vissuto vedapāragū;"
    },
    {
      "id": "tha-ap537:2.3",
      "pali": "Divāvihāraṁ vicaraṁ,"
    },
    {
      "id": "tha-ap537:2.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap537:3.1",
      "pali": "Catusaccaṁ pakāsentaṁ,"
    },
    {
      "id": "tha-ap537:3.2",
      "pali": "bodhayantaṁ sadevakaṁ;"
    },
    {
      "id": "tha-ap537:3.3",
      "pali": "Vicittakathikānaggaṁ,"
    },
    {
      "id": "tha-ap537:3.4",
      "pali": "vaṇṇayantaṁ mahājane."
    },
    {
      "id": "tha-ap537:4.1",
      "pali": "Tadā muditacittohaṁ,"
    },
    {
      "id": "tha-ap537:4.2",
      "pali": "nimantetvā tathāgataṁ;"
    },
    {
      "id": "tha-ap537:4.3",
      "pali": "Nānārattehi vatthehi,"
    },
    {
      "id": "tha-ap537:4.4",
      "pali": "alaṅkaritvāna maṇḍapaṁ."
    },
    {
      "id": "tha-ap537:5.1",
      "pali": "Nānāratanapajjotaṁ,"
    },
    {
      "id": "tha-ap537:5.2",
      "pali": "sasaṅghaṁ bhojayiṁ tahiṁ;"
    },
    {
      "id": "tha-ap537:5.3",
      "pali": "Bhojayitvāna sattāhaṁ,"
    },
    {
      "id": "tha-ap537:5.4",
      "pali": "nānaggarasabhojanaṁ."
    },
    {
      "id": "tha-ap537:6.1",
      "pali": "Nānācittehi pupphehi,"
    },
    {
      "id": "tha-ap537:6.2",
      "pali": "pūjayitvā sasāvakaṁ;"
    },
    {
      "id": "tha-ap537:6.3",
      "pali": "Nipacca pādamūlamhi,"
    },
    {
      "id": "tha-ap537:6.4",
      "pali": "taṁ ṭhānaṁ patthayiṁ ahaṁ."
    },
    {
      "id": "tha-ap537:7.1",
      "pali": "Tadā munivaro āha,"
    },
    {
      "id": "tha-ap537:7.2",
      "pali": "karuṇekarasāsayo;"
    },
    {
      "id": "tha-ap537:7.3",
      "pali": "‘Passathetaṁ dijavaraṁ,"
    },
    {
      "id": "tha-ap537:7.4",
      "pali": "padumānanalocanaṁ."
    },
    {
      "id": "tha-ap537:8.1",
      "pali": "Pītipāmojjabahulaṁ,"
    },
    {
      "id": "tha-ap537:8.2",
      "pali": "samuggatatanūruhaṁ;"
    },
    {
      "id": "tha-ap537:8.3",
      "pali": "Hāsamhitavisālakkhaṁ,"
    },
    {
      "id": "tha-ap537:8.4",
      "pali": "mama sāsanalālasaṁ."
    },
    {
      "id": "tha-ap537:9.1",
      "pali": "Patitaṁ pādamūle me,"
    },
    {
      "id": "tha-ap537:9.2",
      "pali": "ekāvatthasumānasaṁ;"
    },
    {
      "id": "tha-ap537:9.3",
      "pali": "Esa pattheti taṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap537:9.4",
      "pali": "vicittakathikattanaṁ."
    },
    {
      "id": "tha-ap537:10.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap537:10.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap537:10.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap537:10.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap537:11.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap537:11.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap537:11.3",
      "pali": "Kumārakassapo nāma,"
    },
    {
      "id": "tha-ap537:11.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap537:12.1",
      "pali": "Vicittapupphadussānaṁ,"
    },
    {
      "id": "tha-ap537:12.2",
      "pali": "ratanānañca vāhasā;"
    },
    {
      "id": "tha-ap537:12.3",
      "pali": "Vicittakathikānaṁ so,"
    },
    {
      "id": "tha-ap537:12.4",
      "pali": "aggataṁ pāpuṇissati’."
    },
    {
      "id": "tha-ap537:13.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap537:13.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap537:13.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap537:13.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap537:14.1",
      "pali": "Paribbhamaṁ bhavābhave,"
    },
    {
      "id": "tha-ap537:14.2",
      "pali": "raṅgamajjhe yathā naṭo;"
    },
    {
      "id": "tha-ap537:14.3",
      "pali": "Sākhamigatrajo hutvā,"
    },
    {
      "id": "tha-ap537:14.4",
      "pali": "migiyā kucchimokkamiṁ."
    },
    {
      "id": "tha-ap537:15.1",
      "pali": "Tadā mayi kucchigate,"
    },
    {
      "id": "tha-ap537:15.2",
      "pali": "vajjhavāro upaṭṭhito;"
    },
    {
      "id": "tha-ap537:15.3",
      "pali": "Sākhena cattā me mātā,"
    },
    {
      "id": "tha-ap537:15.4",
      "pali": "nigrodhaṁ saraṇaṁ gatā."
    },
    {
      "id": "tha-ap537:16.1",
      "pali": "Tena sā migarājena,"
    },
    {
      "id": "tha-ap537:16.2",
      "pali": "maraṇā parimocitā;"
    },
    {
      "id": "tha-ap537:16.3",
      "pali": "Pariccajitvā sapāṇaṁ,"
    },
    {
      "id": "tha-ap537:16.4",
      "pali": "mamevaṁ ovadī tadā."
    },
    {
      "id": "tha-ap537:17.1",
      "pali": "‘Nigrodhameva seveyya,"
    },
    {
      "id": "tha-ap537:17.2",
      "pali": "na sākhamupasaṁvase;"
    },
    {
      "id": "tha-ap537:17.3",
      "pali": "Nigrodhasmiṁ mataṁ seyyo,"
    },
    {
      "id": "tha-ap537:17.4",
      "pali": "yañce sākhamhi jīvitaṁ’."
    },
    {
      "id": "tha-ap537:18.1",
      "pali": "Tenānusiṭṭhā migayūthapena,"
    },
    {
      "id": "tha-ap537:18.2",
      "pali": "Ahañca mātā ca tathetare ca;"
    },
    {
      "id": "tha-ap537:18.3",
      "pali": "Āgamma rammaṁ tusitādhivāsaṁ,"
    },
    {
      "id": "tha-ap537:18.4",
      "pali": "Gatā pavāsaṁ sagharaṁ yatheva."
    },
    {
      "id": "tha-ap537:19.1",
      "pali": "Puno kassapavīrassa,"
    },
    {
      "id": "tha-ap537:19.2",
      "pali": "atthamentamhi sāsane;"
    },
    {
      "id": "tha-ap537:19.3",
      "pali": "Āruyha selasikharaṁ,"
    },
    {
      "id": "tha-ap537:19.4",
      "pali": "yuñjitvā jinasāsanaṁ."
    },
    {
      "id": "tha-ap537:20.1",
      "pali": "Idānāhaṁ rājagahe,"
    },
    {
      "id": "tha-ap537:20.2",
      "pali": "jāto seṭṭhikule ahuṁ;"
    },
    {
      "id": "tha-ap537:20.3",
      "pali": "Āpannasattā me mātā,"
    },
    {
      "id": "tha-ap537:20.4",
      "pali": "pabbaji anagāriyaṁ."
    },
    {
      "id": "tha-ap537:21.1",
      "pali": "Sagabbhaṁ taṁ viditvāna,"
    },
    {
      "id": "tha-ap537:21.2",
      "pali": "devadattamupānayuṁ;"
    },
    {
      "id": "tha-ap537:21.3",
      "pali": "So avoca ‘vināsetha,"
    },
    {
      "id": "tha-ap537:21.4",
      "pali": "pāpikaṁ bhikkhuniṁ imaṁ’."
    },
    {
      "id": "tha-ap537:22.1",
      "pali": "Idānipi munindena,"
    },
    {
      "id": "tha-ap537:22.2",
      "pali": "jinena anukampitā;"
    },
    {
      "id": "tha-ap537:22.3",
      "pali": "Sukhinī ajanī mayhaṁ,"
    },
    {
      "id": "tha-ap537:22.4",
      "pali": "mātā bhikkhunupassaye."
    },
    {
      "id": "tha-ap537:23.1",
      "pali": "Taṁ viditvā mahīpālo,"
    },
    {
      "id": "tha-ap537:23.2",
      "pali": "kosalo maṁ aposayi;"
    },
    {
      "id": "tha-ap537:23.3",
      "pali": "Kumāraparihārena,"
    },
    {
      "id": "tha-ap537:23.4",
      "pali": "nāmenāhañca kassapo."
    },
    {
      "id": "tha-ap537:24.1",
      "pali": "Mahākassapamāgamma,"
    },
    {
      "id": "tha-ap537:24.2",
      "pali": "ahaṁ kumārakassapo;"
    },
    {
      "id": "tha-ap537:24.3",
      "pali": "Vammikasadisaṁ kāyaṁ,"
    },
    {
      "id": "tha-ap537:24.4",
      "pali": "sutvā buddhena desitaṁ."
    },
    {
      "id": "tha-ap537:25.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "tha-ap537:25.2",
      "pali": "anupādāya sabbaso;"
    },
    {
      "id": "tha-ap537:25.3",
      "pali": "Pāyāsiṁ damayitvāhaṁ,"
    },
    {
      "id": "tha-ap537:25.4",
      "pali": "etadaggamapāpuṇiṁ."
    },
    {
      "id": "tha-ap537:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap537:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap537:26.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap537:27.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap537:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap537:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap537:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap537:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap537:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap537:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā kumārakassapo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap537:30.1",
      "pali": "Kumārakassapattherassāpadānaṁ pañcamaṁ."
    },
    {
      "id": "tha-ap537:30.2",
      "pali": "Catuvīsatimaṁ bhāṇavāraṁ."
    }
  ]
}
