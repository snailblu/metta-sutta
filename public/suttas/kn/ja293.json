{
  "uid": "ja293",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja293:1.1",
      "pali": "“Phuṭṭhassa me aññatarena byādhinā,"
    },
    {
      "id": "ja293:1.2",
      "pali": "Rogena bāḷhaṁ dukhitassa ruppato;"
    },
    {
      "id": "ja293:1.3",
      "pali": "Parisussati khippamidaṁ kaḷevaraṁ,"
    },
    {
      "id": "ja293:1.4",
      "pali": "Pupphaṁ yathā paṁsuni ātape kataṁ."
    },
    {
      "id": "ja293:2.1",
      "pali": "Ajaññaṁ jaññasaṅkhātaṁ,"
    },
    {
      "id": "ja293:2.2",
      "pali": "asuciṁ sucisammataṁ;"
    },
    {
      "id": "ja293:2.3",
      "pali": "Nānākuṇapaparipūraṁ,"
    },
    {
      "id": "ja293:2.4",
      "pali": "jaññarūpaṁ apassato."
    },
    {
      "id": "ja293:3.1",
      "pali": "Dhiratthumaṁ āturaṁ pūtikāyaṁ,"
    },
    {
      "id": "ja293:3.2",
      "pali": "Jegucchiyaṁ assuciṁ byādhidhammaṁ;"
    },
    {
      "id": "ja293:3.3",
      "pali": "Yatthappamattā adhimucchitā pajā,"
    },
    {
      "id": "ja293:3.4",
      "pali": "Hāpenti maggaṁ sugatūpapattiyā”ti."
    },
    {
      "id": "ja293:4.1",
      "pali": "Kāyanibbindajātakaṁ tatiyaṁ."
    }
  ]
}
