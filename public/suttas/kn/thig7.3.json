{
  "uid": "thig7.3",
  "title": "Upacālātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig7.3:1.1",
      "pali": "“Satimatī cakkhumatī,"
    },
    {
      "id": "thig7.3:1.2",
      "pali": "bhikkhunī bhāvitindriyā;"
    },
    {
      "id": "thig7.3:1.3",
      "pali": "Paṭivijjhi padaṁ santaṁ,"
    },
    {
      "id": "thig7.3:1.4",
      "pali": "akāpurisasevitaṁ”."
    },
    {
      "id": "thig7.3:2.1",
      "pali": "“Kiṁ nu jātiṁ na rocesi,"
    },
    {
      "id": "thig7.3:2.2",
      "pali": "jāto kāmāni bhuñjati;"
    },
    {
      "id": "thig7.3:2.3",
      "pali": "Bhuñjāhi kāmaratiyo,"
    },
    {
      "id": "thig7.3:2.4",
      "pali": "māhu pacchānutāpinī”."
    },
    {
      "id": "thig7.3:3.1",
      "pali": "“Jātassa maraṇaṁ hoti,"
    },
    {
      "id": "thig7.3:3.2",
      "pali": "hatthapādāna chedanaṁ;"
    },
    {
      "id": "thig7.3:3.3",
      "pali": "Vadhabandhapariklesaṁ,"
    },
    {
      "id": "thig7.3:3.4",
      "pali": "jāto dukkhaṁ nigacchati."
    },
    {
      "id": "thig7.3:4.1",
      "pali": "Atthi sakyakule jāto,"
    },
    {
      "id": "thig7.3:4.2",
      "pali": "sambuddho aparājito;"
    },
    {
      "id": "thig7.3:4.3",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thig7.3:4.4",
      "pali": "jātiyā samatikkamaṁ."
    },
    {
      "id": "thig7.3:5.1",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "thig7.3:5.2",
      "pali": "dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "thig7.3:5.3",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thig7.3:5.4",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "thig7.3:6.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig7.3:6.2",
      "pali": "vihariṁ sāsane ratā;"
    },
    {
      "id": "thig7.3:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig7.3:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig7.3:7.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig7.3:7.2",
      "pali": "tamokhandho padālito;"
    },
    {
      "id": "thig7.3:7.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig7.3:7.4",
      "pali": "nihato tvamasi antaka”."
    },
    {
      "id": "thig7.3:8.1",
      "pali": "… Upacālā therī …."
    },
    {
      "id": "thig7.3:9.1",
      "pali": "Sattakanipāto niṭṭhito."
    }
  ]
}
