{
  "uid": "cp18",
  "title": "Sīlapāramī 8",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp18:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp18:1.2",
      "pali": "mahāpakkho mahiddhiko;"
    },
    {
      "id": "cp18:1.3",
      "pali": "Dhammo nāma mahāyakkho,"
    },
    {
      "id": "cp18:1.4",
      "pali": "sabbalokānukampako."
    },
    {
      "id": "cp18:2.1",
      "pali": "Dasakusalakammapathe,"
    },
    {
      "id": "cp18:2.2",
      "pali": "samādapento mahājanaṁ;"
    },
    {
      "id": "cp18:2.3",
      "pali": "Carāmi gāmanigamaṁ,"
    },
    {
      "id": "cp18:2.4",
      "pali": "samitto saparijjano."
    },
    {
      "id": "cp18:3.1",
      "pali": "Pāpo kadariyo yakkho,"
    },
    {
      "id": "cp18:3.2",
      "pali": "dīpento dasa pāpake;"
    },
    {
      "id": "cp18:3.3",
      "pali": "Sopettha mahiyā carati,"
    },
    {
      "id": "cp18:3.4",
      "pali": "samitto saparijjano."
    },
    {
      "id": "cp18:4.1",
      "pali": "Dhammavādī adhammo ca,"
    },
    {
      "id": "cp18:4.2",
      "pali": "ubho paccanikā mayaṁ;"
    },
    {
      "id": "cp18:4.3",
      "pali": "Dhure dhuraṁ ghaṭṭayantā,"
    },
    {
      "id": "cp18:4.4",
      "pali": "samimhā paṭipathe ubho."
    },
    {
      "id": "cp18:5.1",
      "pali": "Kalaho vattatī bhesmā,"
    },
    {
      "id": "cp18:5.2",
      "pali": "kalyāṇapāpakassa ca;"
    },
    {
      "id": "cp18:5.3",
      "pali": "Maggā okkamanatthāya,"
    },
    {
      "id": "cp18:5.4",
      "pali": "mahāyuddho upaṭṭhito."
    },
    {
      "id": "cp18:6.1",
      "pali": "Yadihaṁ tassa kuppeyyaṁ,"
    },
    {
      "id": "cp18:6.2",
      "pali": "yadi bhinde tapoguṇaṁ;"
    },
    {
      "id": "cp18:6.3",
      "pali": "Sahaparijanaṁ tassa,"
    },
    {
      "id": "cp18:6.4",
      "pali": "rajabhūtaṁ kareyyahaṁ."
    },
    {
      "id": "cp18:7.1",
      "pali": "Api cāhaṁ sīlarakkhāya,"
    },
    {
      "id": "cp18:7.2",
      "pali": "nibbāpetvāna mānasaṁ;"
    },
    {
      "id": "cp18:7.3",
      "pali": "Saha janenokkamitvā,"
    },
    {
      "id": "cp18:7.4",
      "pali": "pathaṁ pāpassa dāsahaṁ."
    },
    {
      "id": "cp18:8.1",
      "pali": "Saha pathato okkante,"
    },
    {
      "id": "cp18:8.2",
      "pali": "katvā cittassa nibbutiṁ;"
    },
    {
      "id": "cp18:8.3",
      "pali": "Vivaraṁ adāsi pathavī,"
    },
    {
      "id": "cp18:8.4",
      "pali": "pāpayakkhassa tāvade”ti."
    },
    {
      "id": "cp18:9.1",
      "pali": "Dhammadevaputtacariyaṁ aṭṭhamaṁ."
    }
  ]
}
