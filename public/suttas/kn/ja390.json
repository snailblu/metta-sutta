{
  "uid": "ja390",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja390:1.1",
      "pali": "“Sakuṇo mayhako nāma,"
    },
    {
      "id": "ja390:1.2",
      "pali": "girisānudarīcaro;"
    },
    {
      "id": "ja390:1.3",
      "pali": "Pakkaṁ pipphalimāruyha,"
    },
    {
      "id": "ja390:1.4",
      "pali": "mayhaṁ mayhanti kandati."
    },
    {
      "id": "ja390:2.1",
      "pali": "Tassevaṁ vilapantassa,"
    },
    {
      "id": "ja390:2.2",
      "pali": "dijasaṅghā samāgatā;"
    },
    {
      "id": "ja390:2.3",
      "pali": "Bhutvāna pipphaliṁ yanti,"
    },
    {
      "id": "ja390:2.4",
      "pali": "vilapatveva so dijo."
    },
    {
      "id": "ja390:3.1",
      "pali": "Evameva idhekacco,"
    },
    {
      "id": "ja390:3.2",
      "pali": "saṅgharitvā bahuṁ dhanaṁ;"
    },
    {
      "id": "ja390:3.3",
      "pali": "Nevattano na ñātīnaṁ,"
    },
    {
      "id": "ja390:3.4",
      "pali": "yathodhiṁ paṭipajjati."
    },
    {
      "id": "ja390:4.1",
      "pali": "Na so acchādanaṁ bhattaṁ,"
    },
    {
      "id": "ja390:4.2",
      "pali": "na mālaṁ na vilepanaṁ;"
    },
    {
      "id": "ja390:4.3",
      "pali": "Anubhoti sakiṁ kiñci,"
    },
    {
      "id": "ja390:4.4",
      "pali": "na saṅgaṇhāti ñātake."
    },
    {
      "id": "ja390:5.1",
      "pali": "Tassevaṁ vilapantassa,"
    },
    {
      "id": "ja390:5.2",
      "pali": "mayhaṁ mayhanti rakkhato;"
    },
    {
      "id": "ja390:5.3",
      "pali": "Rājāno atha vā corā,"
    },
    {
      "id": "ja390:5.4",
      "pali": "dāyādā ye va appiyā;"
    },
    {
      "id": "ja390:5.5",
      "pali": "Dhanamādāya gacchanti,"
    },
    {
      "id": "ja390:5.6",
      "pali": "vilapatveva so naro."
    },
    {
      "id": "ja390:6.1",
      "pali": "Dhīro bhoge adhigamma,"
    },
    {
      "id": "ja390:6.2",
      "pali": "saṅgaṇhāti ca ñātake;"
    },
    {
      "id": "ja390:6.3",
      "pali": "Tena so kittiṁ pappoti,"
    },
    {
      "id": "ja390:6.4",
      "pali": "pecca sagge pamodatī”ti."
    },
    {
      "id": "ja390:7.1",
      "pali": "Mayhakajātakaṁ pañcamaṁ."
    }
  ]
}
