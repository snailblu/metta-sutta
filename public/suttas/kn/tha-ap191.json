{
  "uid": "tha-ap191",
  "title": "Ekacāriyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap191:1.1",
      "pali": "“Tāvatiṁsesu devesu,"
    },
    {
      "id": "tha-ap191:1.2",
      "pali": "mahāghoso tadā ahu;"
    },
    {
      "id": "tha-ap191:1.3",
      "pali": "Buddho ca loke nibbāti,"
    },
    {
      "id": "tha-ap191:1.4",
      "pali": "mayañcamha sarāgino."
    },
    {
      "id": "tha-ap191:2.1",
      "pali": "Tesaṁ saṁvegajātānaṁ,"
    },
    {
      "id": "tha-ap191:2.2",
      "pali": "sokasallasamaṅginaṁ;"
    },
    {
      "id": "tha-ap191:2.3",
      "pali": "Sabalena upatthaddho,"
    },
    {
      "id": "tha-ap191:2.4",
      "pali": "agamaṁ buddhasantikaṁ."
    },
    {
      "id": "tha-ap191:3.1",
      "pali": "Mandāravaṁ gahetvāna,"
    },
    {
      "id": "tha-ap191:3.2",
      "pali": "saṅgīti abhinimmitaṁ;"
    },
    {
      "id": "tha-ap191:3.3",
      "pali": "Parinibbutakālamhi,"
    },
    {
      "id": "tha-ap191:3.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap191:4.1",
      "pali": "Sabbe devānumodiṁsu,"
    },
    {
      "id": "tha-ap191:4.2",
      "pali": "accharāyo ca me tadā;"
    },
    {
      "id": "tha-ap191:4.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap191:4.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap191:5.1",
      "pali": "Saṭṭhikappasahassamhi,"
    },
    {
      "id": "tha-ap191:5.2",
      "pali": "ito soḷasa te janā;"
    },
    {
      "id": "tha-ap191:5.3",
      "pali": "Mahāmallajanā nāma,"
    },
    {
      "id": "tha-ap191:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap191:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap191:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap191:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap191:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekacāriyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap191:8.1",
      "pali": "Ekacāriyattherassāpadānaṁ navamaṁ."
    }
  ]
}
