{
  "uid": "tha-ap481",
  "title": "Pānadhidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap481:1.1",
      "pali": "“Anomadassī bhagavā,"
    },
    {
      "id": "tha-ap481:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap481:1.3",
      "pali": "Divāvihārā nikkhamma,"
    },
    {
      "id": "tha-ap481:1.4",
      "pali": "pathamāruhi cakkhumā."
    },
    {
      "id": "tha-ap481:2.1",
      "pali": "Pānadhiṁ sukataṁ gayha,"
    },
    {
      "id": "tha-ap481:2.2",
      "pali": "addhānaṁ paṭipajjahaṁ;"
    },
    {
      "id": "tha-ap481:2.3",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap481:2.4",
      "pali": "pattikaṁ cārudassanaṁ."
    },
    {
      "id": "tha-ap481:3.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap481:3.2",
      "pali": "nīharitvāna pānadhiṁ;"
    },
    {
      "id": "tha-ap481:3.3",
      "pali": "Pādamūle ṭhapetvāna,"
    },
    {
      "id": "tha-ap481:3.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap481:4.1",
      "pali": "‘Abhirūha mahāvīra,"
    },
    {
      "id": "tha-ap481:4.2",
      "pali": "sugatinda vināyaka;"
    },
    {
      "id": "tha-ap481:4.3",
      "pali": "Ito phalaṁ labhissāmi,"
    },
    {
      "id": "tha-ap481:4.4",
      "pali": "so me attho samijjhatu’."
    },
    {
      "id": "tha-ap481:5.1",
      "pali": "Anomadassī bhagavā,"
    },
    {
      "id": "tha-ap481:5.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap481:5.3",
      "pali": "Pānadhiṁ abhirūhitvā,"
    },
    {
      "id": "tha-ap481:5.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "tha-ap481:6.1",
      "pali": "‘Yo pānadhiṁ me adāsi,"
    },
    {
      "id": "tha-ap481:6.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap481:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap481:6.4",
      "pali": "suṇātha mama bhāsato’."
    },
    {
      "id": "tha-ap481:7.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap481:7.2",
      "pali": "sabbe devā samāgatā;"
    },
    {
      "id": "tha-ap481:7.3",
      "pali": "Udaggacittā sumanā,"
    },
    {
      "id": "tha-ap481:7.4",
      "pali": "vedajātā katañjalī."
    },
    {
      "id": "tha-ap481:8.1",
      "pali": "‘Pānadhīnaṁ padānena,"
    },
    {
      "id": "tha-ap481:8.2",
      "pali": "sukhitoyaṁ bhavissati;"
    },
    {
      "id": "tha-ap481:8.3",
      "pali": "Pañcapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap481:8.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap481:9.1",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap481:9.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap481:9.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap481:9.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap481:10.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap481:10.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap481:10.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap481:10.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap481:11.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap481:11.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap481:11.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap481:11.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap481:12.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap481:12.2",
      "pali": "nibbattissati puññavā;"
    },
    {
      "id": "tha-ap481:12.3",
      "pali": "Devayānapaṭibhāgaṁ,"
    },
    {
      "id": "tha-ap481:12.4",
      "pali": "yānaṁ paṭilabhissati’."
    },
    {
      "id": "tha-ap481:13.1",
      "pali": "Pāsādā sivikā vayhaṁ,"
    },
    {
      "id": "tha-ap481:13.2",
      "pali": "hatthino samalaṅkatā;"
    },
    {
      "id": "tha-ap481:13.3",
      "pali": "Rathā vājaññasaṁyuttā,"
    },
    {
      "id": "tha-ap481:13.4",
      "pali": "sadā pātubhavanti me."
    },
    {
      "id": "tha-ap481:14.1",
      "pali": "Agārā nikkhamantopi,"
    },
    {
      "id": "tha-ap481:14.2",
      "pali": "rathena nikkhamiṁ ahaṁ;"
    },
    {
      "id": "tha-ap481:14.3",
      "pali": "Kesesu chijjamānesu,"
    },
    {
      "id": "tha-ap481:14.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap481:15.1",
      "pali": "Lābhā mayhaṁ suladdhaṁ me,"
    },
    {
      "id": "tha-ap481:15.2",
      "pali": "vāṇijjaṁ suppayojitaṁ;"
    },
    {
      "id": "tha-ap481:15.3",
      "pali": "Datvāna pānadhiṁ ekaṁ,"
    },
    {
      "id": "tha-ap481:15.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap481:16.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap481:16.2",
      "pali": "yaṁ pānadhimadāsahaṁ;"
    },
    {
      "id": "tha-ap481:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap481:16.4",
      "pali": "pānadhissa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap481:17.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap481:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap481:17.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap481:18.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap481:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap481:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap481:19.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap481:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap481:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap481:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā pānadhidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap481:21.1",
      "pali": "Pānadhidāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
