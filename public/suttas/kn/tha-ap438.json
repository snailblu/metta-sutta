{
  "uid": "tha-ap438",
  "title": "6 Kaḷambadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap438:1.1",
      "pali": "“Romaso nāma sambuddho,"
    },
    {
      "id": "tha-ap438:1.2",
      "pali": "vasate pabbatantare;"
    },
    {
      "id": "tha-ap438:1.3",
      "pali": "Kaḷambaṁ tassa pādāsiṁ,"
    },
    {
      "id": "tha-ap438:1.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap438:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap438:2.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap438:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap438:2.4",
      "pali": "kaḷambassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap438:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap438:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap438:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap438:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap438:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap438:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap438:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap438:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap438:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap438:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kaḷambadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap438:7.1",
      "pali": "Kaḷambadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
