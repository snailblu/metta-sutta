{
  "uid": "ja272",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja272:1.1",
      "pali": "“Yena mittena saṁsaggā,"
    },
    {
      "id": "ja272:1.2",
      "pali": "yogakkhemo vihiyyati;"
    },
    {
      "id": "ja272:1.3",
      "pali": "Pubbevajjhābhavaṁ tassa,"
    },
    {
      "id": "ja272:1.4",
      "pali": "rukkhe akkhīva paṇḍito."
    },
    {
      "id": "ja272:2.1",
      "pali": "Yena mittena saṁsaggā,"
    },
    {
      "id": "ja272:2.2",
      "pali": "yogakkhemo pavaḍḍhati;"
    },
    {
      "id": "ja272:2.3",
      "pali": "Kareyyattasamaṁ vuttiṁ,"
    },
    {
      "id": "ja272:2.4",
      "pali": "sabbakiccesu paṇḍito”."
    },
    {
      "id": "ja272:3.1",
      "pali": "“Etha byagghā nivattavho,"
    },
    {
      "id": "ja272:3.2",
      "pali": "Paccupetha mahāvanaṁ;"
    },
    {
      "id": "ja272:3.3",
      "pali": "Mā vanaṁ chindi nibyagghaṁ,"
    },
    {
      "id": "ja272:3.4",
      "pali": "Byagghā māhesu nibbanā”ti."
    },
    {
      "id": "ja272:4.1",
      "pali": "Byagghajātakaṁ dutiyaṁ."
    }
  ]
}
