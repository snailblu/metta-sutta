{
  "uid": "ja196",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja196:1.1",
      "pali": "“Ye na kāhanti ovādaṁ,"
    },
    {
      "id": "ja196:1.2",
      "pali": "narā buddhena desitaṁ;"
    },
    {
      "id": "ja196:1.3",
      "pali": "Byasanaṁ te gamissanti,"
    },
    {
      "id": "ja196:1.4",
      "pali": "rakkhasīhiva vāṇijā."
    },
    {
      "id": "ja196:2.1",
      "pali": "Ye ca kāhanti ovādaṁ,"
    },
    {
      "id": "ja196:2.2",
      "pali": "narā buddhena desitaṁ;"
    },
    {
      "id": "ja196:2.3",
      "pali": "Sotthiṁ pāraṁ gamissanti,"
    },
    {
      "id": "ja196:2.4",
      "pali": "valāheneva vāṇijā”ti."
    },
    {
      "id": "ja196:3.1",
      "pali": "Valāhakassajātakaṁ chaṭṭhaṁ."
    }
  ]
}
