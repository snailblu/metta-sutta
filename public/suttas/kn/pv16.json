{
  "uid": "pv16",
  "title": "4. Nandāpetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv16:1.1",
      "pali": "“Kāḷī dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv16:1.2",
      "pali": "pharusā bhīrudassanā;"
    },
    {
      "id": "pv16:1.3",
      "pali": "Piṅgalāsi kaḷārāsi,"
    },
    {
      "id": "pv16:1.4",
      "pali": "na taṁ maññāmi mānusin”ti."
    },
    {
      "id": "pv16:2.1",
      "pali": "“Ahaṁ nandā nandisena,"
    },
    {
      "id": "pv16:2.2",
      "pali": "bhariyā te pure ahuṁ;"
    },
    {
      "id": "pv16:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv16:2.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv16:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv16:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv16:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv16:3.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv16:4.1",
      "pali": "“Caṇḍī ca pharusā cāsiṁ,"
    },
    {
      "id": "pv16:4.2",
      "pali": "tayi cāpi agāravā;"
    },
    {
      "id": "pv16:4.3",
      "pali": "Tāhaṁ duruttaṁ vatvāna,"
    },
    {
      "id": "pv16:4.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv16:5.1",
      "pali": "“Handuttarīyaṁ dadāmi te,"
    },
    {
      "id": "pv16:5.2",
      "pali": "imaṁ dussaṁ nivāsaya;"
    },
    {
      "id": "pv16:5.3",
      "pali": "Imaṁ dussaṁ nivāsetvā,"
    },
    {
      "id": "pv16:5.4",
      "pali": "ehi nessāmi taṁ gharaṁ."
    },
    {
      "id": "pv16:6.1",
      "pali": "Vatthañca annapānañca,"
    },
    {
      "id": "pv16:6.2",
      "pali": "lacchasi tvaṁ gharaṁ gatā;"
    },
    {
      "id": "pv16:6.3",
      "pali": "Putte ca te passissasi,"
    },
    {
      "id": "pv16:6.4",
      "pali": "suṇisāyo ca dakkhasī”ti."
    },
    {
      "id": "pv16:7.1",
      "pali": "“Hatthena hatthe te dinnaṁ,"
    },
    {
      "id": "pv16:7.2",
      "pali": "na mayhaṁ upakappati;"
    },
    {
      "id": "pv16:7.3",
      "pali": "Bhikkhū ca sīlasampanne,"
    },
    {
      "id": "pv16:7.4",
      "pali": "vītarāge bahussute."
    },
    {
      "id": "pv16:8.1",
      "pali": "Tappehi annapānena,"
    },
    {
      "id": "pv16:8.2",
      "pali": "mama dakkhiṇamādisa;"
    },
    {
      "id": "pv16:8.3",
      "pali": "Tadāhaṁ sukhitā hessaṁ,"
    },
    {
      "id": "pv16:8.4",
      "pali": "sabbakāmasamiddhinī”ti."
    },
    {
      "id": "pv16:9.1",
      "pali": "Sādhūti so paṭissutvā,"
    },
    {
      "id": "pv16:9.2",
      "pali": "dānaṁ vipulamākiri;"
    },
    {
      "id": "pv16:9.3",
      "pali": "Annaṁ pānaṁ khādanīyaṁ,"
    },
    {
      "id": "pv16:9.4",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "pv16:9.5",
      "pali": "Chattaṁ gandhañca mālañca,"
    },
    {
      "id": "pv16:9.6",
      "pali": "vividhā ca upāhanā."
    },
    {
      "id": "pv16:10.1",
      "pali": "Bhikkhū ca sīlasampanne,"
    },
    {
      "id": "pv16:10.2",
      "pali": "vītarāge bahussute;"
    },
    {
      "id": "pv16:10.3",
      "pali": "Tappetvā annapānena,"
    },
    {
      "id": "pv16:10.4",
      "pali": "tassā dakkhiṇamādisī."
    },
    {
      "id": "pv16:11.1",
      "pali": "Samanantarānuddiṭṭhe,"
    },
    {
      "id": "pv16:11.2",
      "pali": "vipāko udapajjatha;"
    },
    {
      "id": "pv16:11.3",
      "pali": "Bhojanacchādanapānīyaṁ,"
    },
    {
      "id": "pv16:11.4",
      "pali": "dakkhiṇāya idaṁ phalaṁ."
    },
    {
      "id": "pv16:12.1",
      "pali": "Tato suddhā sucivasanā,"
    },
    {
      "id": "pv16:12.2",
      "pali": "kāsikuttamadhārinī;"
    },
    {
      "id": "pv16:12.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "pv16:12.4",
      "pali": "sāmikaṁ upasaṅkami."
    },
    {
      "id": "pv16:13.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "pv16:13.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "pv16:13.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "pv16:13.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "pv16:14.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "pv16:14.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "pv16:14.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "pv16:14.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "pv16:15.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "pv16:15.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "pv16:15.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "pv16:15.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "pv16:16.1",
      "pali": "“Ahaṁ nandā nandisena,"
    },
    {
      "id": "pv16:16.2",
      "pali": "bhariyā te pure ahuṁ;"
    },
    {
      "id": "pv16:16.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv16:16.4",
      "pali": "petalokaṁ ito gatā."
    },
    {
      "id": "pv16:17.1",
      "pali": "Tava dinnena dānena,"
    },
    {
      "id": "pv16:17.2",
      "pali": "modāmi akutobhayā;"
    },
    {
      "id": "pv16:17.3",
      "pali": "Ciraṁ jīva gahapati,"
    },
    {
      "id": "pv16:17.4",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "pv16:17.5",
      "pali": "Asokaṁ virajaṁ khemaṁ,"
    },
    {
      "id": "pv16:17.6",
      "pali": "āvāsaṁ vasavattinaṁ."
    },
    {
      "id": "pv16:18.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "pv16:18.2",
      "pali": "Dānaṁ datvā gahapati;"
    },
    {
      "id": "pv16:18.3",
      "pali": "Vineyya maccheramalaṁ samūlaṁ,"
    },
    {
      "id": "pv16:18.4",
      "pali": "Anindito saggamupehi ṭhānan”ti."
    },
    {
      "id": "pv16:19.1",
      "pali": "Nandāpetivatthu catutthaṁ."
    }
  ]
}
