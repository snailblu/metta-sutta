{
  "uid": "tha-ap16",
  "title": "4 Cūḷapanthakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap16:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap16:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap16:1.3",
      "pali": "Gaṇamhā vūpakaṭṭho so,"
    },
    {
      "id": "tha-ap16:1.4",
      "pali": "himavante vasī tadā."
    },
    {
      "id": "tha-ap16:2.1",
      "pali": "Ahampi himavantamhi,"
    },
    {
      "id": "tha-ap16:2.2",
      "pali": "vasāmi assame tadā;"
    },
    {
      "id": "tha-ap16:2.3",
      "pali": "Acirāgataṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap16:2.4",
      "pali": "upesiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap16:3.1",
      "pali": "Pupphacchattaṁ gahetvāna,"
    },
    {
      "id": "tha-ap16:3.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap16:3.3",
      "pali": "Samādhiṁ samāpajjantaṁ,"
    },
    {
      "id": "tha-ap16:3.4",
      "pali": "antarāyamakāsahaṁ."
    },
    {
      "id": "tha-ap16:4.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap16:4.2",
      "pali": "pupphacchattaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap16:4.3",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap16:4.4",
      "pali": "padumuttaro mahāmuni."
    },
    {
      "id": "tha-ap16:5.1",
      "pali": "Sabbe devā attamanā,"
    },
    {
      "id": "tha-ap16:5.2",
      "pali": "himavantaṁ upenti te;"
    },
    {
      "id": "tha-ap16:5.3",
      "pali": "Sādhukāraṁ pavattesuṁ,"
    },
    {
      "id": "tha-ap16:5.4",
      "pali": "anumodissati cakkhumā."
    },
    {
      "id": "tha-ap16:6.1",
      "pali": "Idaṁ vatvāna te devā,"
    },
    {
      "id": "tha-ap16:6.2",
      "pali": "upagacchuṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap16:6.3",
      "pali": "Ākāse dhārayantassa,"
    },
    {
      "id": "tha-ap16:6.4",
      "pali": "padumacchattamuttamaṁ."
    },
    {
      "id": "tha-ap16:7.1",
      "pali": "Satapattachattaṁ paggayha,"
    },
    {
      "id": "tha-ap16:7.2",
      "pali": "adāsi tāpaso mama;"
    },
    {
      "id": "tha-ap16:7.3",
      "pali": "‘Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap16:7.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap16:8.1",
      "pali": "Pañcavīsatikappāni,"
    },
    {
      "id": "tha-ap16:8.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap16:8.3",
      "pali": "Catuttiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap16:8.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap16:9.1",
      "pali": "Yaṁ yaṁ yoniṁ saṁsarati,"
    },
    {
      "id": "tha-ap16:9.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap16:9.3",
      "pali": "Abbhokāse patiṭṭhantaṁ,"
    },
    {
      "id": "tha-ap16:9.4",
      "pali": "padumaṁ dhārayissati."
    },
    {
      "id": "tha-ap16:10.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap16:10.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap16:10.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap16:10.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap16:11.1",
      "pali": "Pakāsite pāvacane,"
    },
    {
      "id": "tha-ap16:11.2",
      "pali": "manussattaṁ labhissati;"
    },
    {
      "id": "tha-ap16:11.3",
      "pali": "Manomayamhi kāyamhi,"
    },
    {
      "id": "tha-ap16:11.4",
      "pali": "uttamo so bhavissati."
    },
    {
      "id": "tha-ap16:12.1",
      "pali": "Dve bhātaro bhavissanti,"
    },
    {
      "id": "tha-ap16:12.2",
      "pali": "ubhopi panthakavhayā;"
    },
    {
      "id": "tha-ap16:12.3",
      "pali": "Anubhotvā uttamatthaṁ,"
    },
    {
      "id": "tha-ap16:12.4",
      "pali": "jotayissanti sāsanaṁ’."
    },
    {
      "id": "tha-ap16:13.1",
      "pali": "Sohaṁ aṭṭhārasavasso,"
    },
    {
      "id": "tha-ap16:13.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap16:13.3",
      "pali": "Visesāhaṁ na vindāmi,"
    },
    {
      "id": "tha-ap16:13.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "tha-ap16:14.1",
      "pali": "Dandhā mayhaṁ gatī āsi,"
    },
    {
      "id": "tha-ap16:14.2",
      "pali": "paribhūto pure ahuṁ;"
    },
    {
      "id": "tha-ap16:14.3",
      "pali": "Bhātā ca maṁ paṇāmesi,"
    },
    {
      "id": "tha-ap16:14.4",
      "pali": "gaccha dāni sakaṁ gharaṁ."
    },
    {
      "id": "tha-ap16:15.1",
      "pali": "Sohaṁ paṇāmito santo,"
    },
    {
      "id": "tha-ap16:15.2",
      "pali": "saṅghārāmassa koṭṭhake;"
    },
    {
      "id": "tha-ap16:15.3",
      "pali": "Dummano tattha aṭṭhāsiṁ,"
    },
    {
      "id": "tha-ap16:15.4",
      "pali": "sāmaññasmiṁ apekkhavā."
    },
    {
      "id": "tha-ap16:16.1",
      "pali": "Bhagavā tattha āgacchi,"
    },
    {
      "id": "tha-ap16:16.2",
      "pali": "sīsaṁ mayhaṁ parāmasi;"
    },
    {
      "id": "tha-ap16:16.3",
      "pali": "Bāhāya maṁ gahetvāna,"
    },
    {
      "id": "tha-ap16:16.4",
      "pali": "saṅghārāmaṁ pavesayi."
    },
    {
      "id": "tha-ap16:17.1",
      "pali": "Anukampāya me satthā,"
    },
    {
      "id": "tha-ap16:17.2",
      "pali": "adāsi pādapuñchaniṁ;"
    },
    {
      "id": "tha-ap16:17.3",
      "pali": "Evaṁ suddhaṁ adhiṭṭhehi,"
    },
    {
      "id": "tha-ap16:17.4",
      "pali": "ekamantamadhiṭṭhahaṁ."
    },
    {
      "id": "tha-ap16:18.1",
      "pali": "Hatthehi tamahaṁ gayha,"
    },
    {
      "id": "tha-ap16:18.2",
      "pali": "sariṁ kokanadaṁ ahaṁ;"
    },
    {
      "id": "tha-ap16:18.3",
      "pali": "Tattha cittaṁ vimucci me,"
    },
    {
      "id": "tha-ap16:18.4",
      "pali": "arahattaṁ apāpuṇiṁ."
    },
    {
      "id": "tha-ap16:19.1",
      "pali": "Manomayesu kāyesu,"
    },
    {
      "id": "tha-ap16:19.2",
      "pali": "sabbattha pāramiṁ gato;"
    },
    {
      "id": "tha-ap16:19.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap16:19.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap16:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap16:20.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap16:20.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap16:20.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap16:21.1",
      "pali": "Itthaṁ sudaṁ āyasmā cūḷapanthako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap16:22.1",
      "pali": "Cūḷapanthakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
