{
  "uid": "ja292",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja292:1.1",
      "pali": "“Bārāṇasyaṁ mahārāja,"
    },
    {
      "id": "ja292:1.2",
      "pali": "kākarājā nivāsako;"
    },
    {
      "id": "ja292:1.3",
      "pali": "Asītiyā sahassehi,"
    },
    {
      "id": "ja292:1.4",
      "pali": "supatto parivārito."
    },
    {
      "id": "ja292:2.1",
      "pali": "Tassa dohaḷinī bhariyā,"
    },
    {
      "id": "ja292:2.2",
      "pali": "Suphassā bhakkhitumicchati;"
    },
    {
      "id": "ja292:2.3",
      "pali": "Rañño mahānase pakkaṁ,"
    },
    {
      "id": "ja292:2.4",
      "pali": "Paccagghaṁ rājabhojanaṁ."
    },
    {
      "id": "ja292:3.1",
      "pali": "Tesāhaṁ pahito dūto,"
    },
    {
      "id": "ja292:3.2",
      "pali": "rañño camhi idhāgato;"
    },
    {
      "id": "ja292:3.3",
      "pali": "Bhattu apacitiṁ kummi,"
    },
    {
      "id": "ja292:3.4",
      "pali": "nāsāyamakaraṁ vaṇan”ti."
    },
    {
      "id": "ja292:4.1",
      "pali": "Supattajātakaṁ dutiyaṁ."
    }
  ]
}
