{
  "uid": "thag2.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.9:1.1",
      "pali": "“Sukhaṁ supanti munayo,"
    },
    {
      "id": "thag2.9:1.2",
      "pali": "ye itthīsu na bajjhare;"
    },
    {
      "id": "thag2.9:1.3",
      "pali": "Sadā ve rakkhitabbāsu,"
    },
    {
      "id": "thag2.9:1.4",
      "pali": "yāsu saccaṁ sudullabhaṁ."
    },
    {
      "id": "thag2.9:2.1",
      "pali": "Vadhaṁ carimha te kāma,"
    },
    {
      "id": "thag2.9:2.2",
      "pali": "anaṇā dāni te mayaṁ;"
    },
    {
      "id": "thag2.9:2.3",
      "pali": "Gacchāma dāni nibbānaṁ,"
    },
    {
      "id": "thag2.9:2.4",
      "pali": "yattha gantvā na socatī”ti."
    },
    {
      "id": "thag2.9:2.5",
      "pali": "… Gotamo thero …."
    }
  ]
}
