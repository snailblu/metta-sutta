{
  "uid": "ja447",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja447:1.1",
      "pali": "“Kiṁ te vataṁ kiṁ pana brahmacariyaṁ,"
    },
    {
      "id": "ja447:1.2",
      "pali": "Kissa suciṇṇassa ayaṁ vipāko;"
    },
    {
      "id": "ja447:1.3",
      "pali": "Akkhāhi me brāhmaṇa etamatthaṁ,"
    },
    {
      "id": "ja447:1.4",
      "pali": "Kasmā nu tumhaṁ daharā na miyyare”."
    },
    {
      "id": "ja447:2.1",
      "pali": "“Dhammaṁ carāma na musā bhaṇāma,"
    },
    {
      "id": "ja447:2.2",
      "pali": "Pāpāni kammāni parivajjayāma;"
    },
    {
      "id": "ja447:2.3",
      "pali": "Anariyaṁ parivajjemu sabbaṁ,"
    },
    {
      "id": "ja447:2.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:3.1",
      "pali": "Suṇoma dhammaṁ asataṁ satañca,"
    },
    {
      "id": "ja447:3.2",
      "pali": "Na cāpi dhammaṁ asataṁ rocayāma;"
    },
    {
      "id": "ja447:3.3",
      "pali": "Hitvā asante na jahāma sante,"
    },
    {
      "id": "ja447:3.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:4.1",
      "pali": "Pubbeva dānā sumanā bhavāma,"
    },
    {
      "id": "ja447:4.2",
      "pali": "Dadampi ve attamanā bhavāma;"
    },
    {
      "id": "ja447:4.3",
      "pali": "Datvāpi ve nānutappāma pacchā,"
    },
    {
      "id": "ja447:4.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:5.1",
      "pali": "Samaṇe mayaṁ brāhmaṇe addhike ca,"
    },
    {
      "id": "ja447:5.2",
      "pali": "Vanibbake yācanake dalidde;"
    },
    {
      "id": "ja447:5.3",
      "pali": "Annena pānena abhitappayāma,"
    },
    {
      "id": "ja447:5.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:6.1",
      "pali": "Mayañca bhariyaṁ nātikkamāma,"
    },
    {
      "id": "ja447:6.2",
      "pali": "Amhe ca bhariyā nātikkamanti;"
    },
    {
      "id": "ja447:6.3",
      "pali": "Aññatra tāhi brahmacariyaṁ carāma,"
    },
    {
      "id": "ja447:6.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:7.1",
      "pali": "Pāṇātipātā viramāma sabbe,"
    },
    {
      "id": "ja447:7.2",
      "pali": "Loke adinnaṁ parivajjayāma;"
    },
    {
      "id": "ja447:7.3",
      "pali": "Amajjapā nopi musā bhaṇāma,"
    },
    {
      "id": "ja447:7.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:8.1",
      "pali": "Etāsu ve jāyare suttamāsu,"
    },
    {
      "id": "ja447:8.2",
      "pali": "Medhāvino honti pahūtapaññā;"
    },
    {
      "id": "ja447:8.3",
      "pali": "Bahussutā vedaguno ca honti,"
    },
    {
      "id": "ja447:8.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:9.1",
      "pali": "Mātā pitā ca bhaginī bhātaro ca,"
    },
    {
      "id": "ja447:9.2",
      "pali": "Puttā ca dārā ca mayañca sabbe;"
    },
    {
      "id": "ja447:9.3",
      "pali": "Dhammaṁ carāma paralokahetu,"
    },
    {
      "id": "ja447:9.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare."
    },
    {
      "id": "ja447:10.1",
      "pali": "Dāsā ca dāsyo anujīvino ca,"
    },
    {
      "id": "ja447:10.2",
      "pali": "Paricārakā kammakarā ca sabbe;"
    },
    {
      "id": "ja447:10.3",
      "pali": "Dhammaṁ caranti paralokahetu,"
    },
    {
      "id": "ja447:10.4",
      "pali": "Tasmā hi amhaṁ daharā na miyyare”."
    },
    {
      "id": "ja447:11.1",
      "pali": "“Dhammo have rakkhati dhammacāriṁ,"
    },
    {
      "id": "ja447:11.2",
      "pali": "Dhammo suciṇṇo sukhamāvahāti;"
    },
    {
      "id": "ja447:11.3",
      "pali": "Esānisaṁso dhamme suciṇṇe,"
    },
    {
      "id": "ja447:11.4",
      "pali": "Na duggatiṁ gacchati dhammacārī."
    },
    {
      "id": "ja447:12.1",
      "pali": "Dhammo have rakkhati dhammacāriṁ,"
    },
    {
      "id": "ja447:12.2",
      "pali": "Chattaṁ mahantaṁ viya vassakāle;"
    },
    {
      "id": "ja447:12.3",
      "pali": "Dhammena gutto mama dhammapālo,"
    },
    {
      "id": "ja447:12.4",
      "pali": "Aññassa aṭṭhīni sukhī kumāro”ti."
    },
    {
      "id": "ja447:13.1",
      "pali": "Mahādhammapālajātakaṁ navamaṁ."
    }
  ]
}
