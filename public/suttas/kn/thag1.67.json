{
  "uid": "thag1.67",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.67:1.1",
      "pali": "“Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thag1.67:1.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thag1.67:1.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag1.67:1.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag1.67:1.5",
      "pali": "… Ekadhammasavanīyo thero …."
    }
  ]
}
