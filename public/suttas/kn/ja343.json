{
  "uid": "ja343",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja343:1.1",
      "pali": "“Avasimha tavāgāre,"
    },
    {
      "id": "ja343:1.2",
      "pali": "niccaṁ sakkatapūjitā;"
    },
    {
      "id": "ja343:1.3",
      "pali": "Tvameva dānimakari,"
    },
    {
      "id": "ja343:1.4",
      "pali": "handa rāja vajāmahaṁ”."
    },
    {
      "id": "ja343:2.1",
      "pali": "“Yo ve kate paṭikate,"
    },
    {
      "id": "ja343:2.2",
      "pali": "kibbise paṭikibbise;"
    },
    {
      "id": "ja343:2.3",
      "pali": "Evaṁ taṁ sammatī veraṁ,"
    },
    {
      "id": "ja343:2.4",
      "pali": "vasa kuntini māgamā”."
    },
    {
      "id": "ja343:3.1",
      "pali": "“Na katassa ca kattā ca,"
    },
    {
      "id": "ja343:3.2",
      "pali": "metti sandhīyate puna;"
    },
    {
      "id": "ja343:3.3",
      "pali": "Hadayaṁ nānujānāti,"
    },
    {
      "id": "ja343:3.4",
      "pali": "gacchaññeva rathesabha”."
    },
    {
      "id": "ja343:4.1",
      "pali": "“Katassa ceva kattā ca,"
    },
    {
      "id": "ja343:4.2",
      "pali": "metti sandhīyate puna;"
    },
    {
      "id": "ja343:4.3",
      "pali": "Dhīrānaṁ no ca bālānaṁ,"
    },
    {
      "id": "ja343:4.4",
      "pali": "vasa kuntini māgamā”ti."
    },
    {
      "id": "ja343:5.1",
      "pali": "Kuntinījātakaṁ tatiyaṁ."
    }
  ]
}
