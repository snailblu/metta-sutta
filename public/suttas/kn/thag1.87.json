{
  "uid": "thag1.87",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.87:1.1",
      "pali": "“Khandhā diṭṭhā yathābhūtaṁ,"
    },
    {
      "id": "thag1.87:1.2",
      "pali": "bhavā sabbe padālitā;"
    },
    {
      "id": "thag1.87:1.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag1.87:1.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag1.87:1.5",
      "pali": "… Paviṭṭho thero …."
    }
  ]
}
