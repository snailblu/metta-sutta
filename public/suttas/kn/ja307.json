{
  "uid": "ja307",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja307:1.1",
      "pali": "“Acetanaṁ brāhmaṇa assuṇantaṁ,"
    },
    {
      "id": "ja307:1.2",
      "pali": "Jāno ajānantamimaṁ palāsaṁ;"
    },
    {
      "id": "ja307:1.3",
      "pali": "Āraddhaviriyo dhuvaṁ appamatto,"
    },
    {
      "id": "ja307:1.4",
      "pali": "Sukhaseyyaṁ pucchasi kissa hetu”."
    },
    {
      "id": "ja307:2.1",
      "pali": "“Dūre suto ceva brahā ca rukkho,"
    },
    {
      "id": "ja307:2.2",
      "pali": "Dese ṭhito bhūtanivāsarūpo;"
    },
    {
      "id": "ja307:2.3",
      "pali": "Tasmā namassāmi imaṁ palāsaṁ,"
    },
    {
      "id": "ja307:2.4",
      "pali": "Ye cettha bhūtā te dhanassa hetu”."
    },
    {
      "id": "ja307:3.1",
      "pali": "“So te karissāmi yathānubhāvaṁ,"
    },
    {
      "id": "ja307:3.2",
      "pali": "Kataññutaṁ brāhmaṇa pekkhamāno;"
    },
    {
      "id": "ja307:3.3",
      "pali": "Kathañhi āgamma sataṁ sakāse,"
    },
    {
      "id": "ja307:3.4",
      "pali": "Moghāni te assu pariphanditāni."
    },
    {
      "id": "ja307:4.1",
      "pali": "Yo tindukarukkhassa paro pilakkho,"
    },
    {
      "id": "ja307:4.2",
      "pali": "Parivārito pubbayañño uḷāro;"
    },
    {
      "id": "ja307:4.3",
      "pali": "Tassesa mūlasmiṁ nidhi nikhāto,"
    },
    {
      "id": "ja307:4.4",
      "pali": "Adāyādo gaccha taṁ uddharāhī”ti."
    },
    {
      "id": "ja307:5.1",
      "pali": "Palāsajātakaṁ sattamaṁ."
    }
  ]
}
