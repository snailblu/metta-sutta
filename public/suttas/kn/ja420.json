{
  "uid": "ja420",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja420:1.1",
      "pali": "“Bhusamhi kuddhoti avekkhiyāna,"
    },
    {
      "id": "ja420:1.2",
      "pali": "Na tāva daṇḍaṁ paṇayeyya issaro;"
    },
    {
      "id": "ja420:1.3",
      "pali": "Aṭṭhānaso appatirūpamattano,"
    },
    {
      "id": "ja420:1.4",
      "pali": "Parassa dukkhāni bhusaṁ udīraye."
    },
    {
      "id": "ja420:2.1",
      "pali": "Yato ca jāneyya pasādamattano,"
    },
    {
      "id": "ja420:2.2",
      "pali": "Atthaṁ niyuñjeyya parassa dukkaṭaṁ;"
    },
    {
      "id": "ja420:2.3",
      "pali": "Tadāyamatthoti sayaṁ avekkhiya,"
    },
    {
      "id": "ja420:2.4",
      "pali": "Athassa daṇḍaṁ sadisaṁ nivesaye."
    },
    {
      "id": "ja420:3.1",
      "pali": "Na cāpi jhāpeti paraṁ na attanaṁ,"
    },
    {
      "id": "ja420:3.2",
      "pali": "Amucchito yo nayate nayānayaṁ;"
    },
    {
      "id": "ja420:3.3",
      "pali": "Yo daṇḍadhāro bhavatīdha issaro,"
    },
    {
      "id": "ja420:3.4",
      "pali": "Sa vaṇṇagutto siriyā na dhaṁsati."
    },
    {
      "id": "ja420:4.1",
      "pali": "Ye khattiyā se anisammakārino,"
    },
    {
      "id": "ja420:4.2",
      "pali": "Paṇenti daṇḍaṁ sahasā pamucchitā;"
    },
    {
      "id": "ja420:4.3",
      "pali": "Avaṇṇasaṁyutā jahanti jīvitaṁ,"
    },
    {
      "id": "ja420:4.4",
      "pali": "Ito vimuttāpi ca yanti duggatiṁ."
    },
    {
      "id": "ja420:5.1",
      "pali": "Dhamme ca ye ariyappavedite ratā,"
    },
    {
      "id": "ja420:5.2",
      "pali": "Anuttarā te vacasā manasā kammunā ca;"
    },
    {
      "id": "ja420:5.3",
      "pali": "Te santisoraccasamādhisaṇṭhitā,"
    },
    {
      "id": "ja420:5.4",
      "pali": "Vajanti lokaṁ dubhayaṁ tathāvidhā."
    },
    {
      "id": "ja420:6.1",
      "pali": "Rājāhamasmi narapamadānamissaro,"
    },
    {
      "id": "ja420:6.2",
      "pali": "Sacepi kujjhāmi ṭhapemi attanaṁ;"
    },
    {
      "id": "ja420:6.3",
      "pali": "Nisedhayanto janataṁ tathāvidhaṁ,"
    },
    {
      "id": "ja420:6.4",
      "pali": "Paṇemi daṇḍaṁ anukampa yoniso”."
    },
    {
      "id": "ja420:7.1",
      "pali": "“Sirī ca lakkhī ca taveva khattiya,"
    },
    {
      "id": "ja420:7.2",
      "pali": "Janādhipa mā vijahi kudācanaṁ;"
    },
    {
      "id": "ja420:7.3",
      "pali": "Akkodhano niccapasannacitto,"
    },
    {
      "id": "ja420:7.4",
      "pali": "Anīgho tuvaṁ vassasatāni pālaya."
    },
    {
      "id": "ja420:8.1",
      "pali": "Guṇehi etehi upeta khattiya,"
    },
    {
      "id": "ja420:8.2",
      "pali": "Ṭhitamariyavattī suvaco akodhano;"
    },
    {
      "id": "ja420:8.3",
      "pali": "Sukhī anuppīḷa pasāsamediniṁ,"
    },
    {
      "id": "ja420:8.4",
      "pali": "Ito vimuttopi ca yāhi suggatiṁ."
    },
    {
      "id": "ja420:9.1",
      "pali": "Evaṁ sunītena subhāsitena,"
    },
    {
      "id": "ja420:9.2",
      "pali": "Dhammena ñāyena upāyaso nayaṁ;"
    },
    {
      "id": "ja420:9.3",
      "pali": "Nibbāpaye saṅkhubhitaṁ mahājanaṁ,"
    },
    {
      "id": "ja420:9.4",
      "pali": "Mahāva megho salilena medinin”ti."
    },
    {
      "id": "ja420:10.1",
      "pali": "Sumaṅgalajātakaṁ catutthaṁ."
    }
  ]
}
