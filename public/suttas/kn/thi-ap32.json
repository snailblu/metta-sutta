{
  "uid": "thi-ap32",
  "title": "2 Caturāsītibhikkhunīsahassaapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap32:1.1",
      "pali": "“Cullāsītisahassāni,"
    },
    {
      "id": "thi-ap32:1.2",
      "pali": "brāhmaññakulasambhavā;"
    },
    {
      "id": "thi-ap32:1.3",
      "pali": "Sukhumālahatthapādā,"
    },
    {
      "id": "thi-ap32:1.4",
      "pali": "pure tuyhaṁ mahāmune."
    },
    {
      "id": "thi-ap32:2.1",
      "pali": "Vessasuddakule jātā,"
    },
    {
      "id": "thi-ap32:2.2",
      "pali": "devā nāgā ca kinnarā;"
    },
    {
      "id": "thi-ap32:2.3",
      "pali": "Cātuddīpā bahū kaññā,"
    },
    {
      "id": "thi-ap32:2.4",
      "pali": "pure tuyhaṁ mahāmune."
    },
    {
      "id": "thi-ap32:3.1",
      "pali": "Kāci pabbajitā atthi,"
    },
    {
      "id": "thi-ap32:3.2",
      "pali": "sabbadassāvino bahū;"
    },
    {
      "id": "thi-ap32:3.3",
      "pali": "Devā ca kinnarā nāgā,"
    },
    {
      "id": "thi-ap32:3.4",
      "pali": "phusissanti anāgate."
    },
    {
      "id": "thi-ap32:4.1",
      "pali": "Anubhotvā yasaṁ sabbaṁ,"
    },
    {
      "id": "thi-ap32:4.2",
      "pali": "Patvāna sabbasampadā;"
    },
    {
      "id": "thi-ap32:4.3",
      "pali": "Tumhaṁ pasādaṁ paṭiladdhā,"
    },
    {
      "id": "thi-ap32:4.4",
      "pali": "Bujjhissanti anāgate."
    },
    {
      "id": "thi-ap32:5.1",
      "pali": "Amhe brāhmaṇadhītā tu,"
    },
    {
      "id": "thi-ap32:5.2",
      "pali": "brāhmaññakulasambhavā;"
    },
    {
      "id": "thi-ap32:5.3",
      "pali": "Pekkhato no mahāvīra,"
    },
    {
      "id": "thi-ap32:5.4",
      "pali": "pāde vandāma cakkhuma."
    },
    {
      "id": "thi-ap32:6.1",
      "pali": "Upāhatā bhavā sabbe,"
    },
    {
      "id": "thi-ap32:6.2",
      "pali": "mūlataṇhā samūhatā;"
    },
    {
      "id": "thi-ap32:6.3",
      "pali": "Samucchinnā anusayā,"
    },
    {
      "id": "thi-ap32:6.4",
      "pali": "puññasaṅkhāradālitā."
    },
    {
      "id": "thi-ap32:7.1",
      "pali": "Samādhigocarā sabbā,"
    },
    {
      "id": "thi-ap32:7.2",
      "pali": "samāpattivasī katā;"
    },
    {
      "id": "thi-ap32:7.3",
      "pali": "Jhānena dhammaratiyā,"
    },
    {
      "id": "thi-ap32:7.4",
      "pali": "viharissāma no sadā."
    },
    {
      "id": "thi-ap32:8.1",
      "pali": "Bhavanetti avijjā ca,"
    },
    {
      "id": "thi-ap32:8.2",
      "pali": "saṅkhārāpi ca khepitā;"
    },
    {
      "id": "thi-ap32:8.3",
      "pali": "Sududdasaṁ padaṁ gantvā,"
    },
    {
      "id": "thi-ap32:8.4",
      "pali": "anujānātha nāyaka”."
    },
    {
      "id": "thi-ap32:9.1",
      "pali": "“Upakārā mamaṁ tumhe,"
    },
    {
      "id": "thi-ap32:9.2",
      "pali": "dīgharattaṁ katāvino;"
    },
    {
      "id": "thi-ap32:9.3",
      "pali": "Catunnaṁ saṁsayaṁ chetvā,"
    },
    {
      "id": "thi-ap32:9.4",
      "pali": "sabbā gacchantu nibbutiṁ”."
    },
    {
      "id": "thi-ap32:10.1",
      "pali": "Vanditvā munino pāde,"
    },
    {
      "id": "thi-ap32:10.2",
      "pali": "katvā iddhivikubbanaṁ;"
    },
    {
      "id": "thi-ap32:10.3",
      "pali": "Kāci dassenti ālokaṁ,"
    },
    {
      "id": "thi-ap32:10.4",
      "pali": "andhakāramathāparā."
    },
    {
      "id": "thi-ap32:11.1",
      "pali": "Dassenti candasūriye,"
    },
    {
      "id": "thi-ap32:11.2",
      "pali": "sāgarañca samacchakaṁ;"
    },
    {
      "id": "thi-ap32:11.3",
      "pali": "Sineruṁ paribhaṇḍañca,"
    },
    {
      "id": "thi-ap32:11.4",
      "pali": "dassenti pārichattakaṁ."
    },
    {
      "id": "thi-ap32:12.1",
      "pali": "Tāvatiṁsañca bhavanaṁ,"
    },
    {
      "id": "thi-ap32:12.2",
      "pali": "yāmaṁ dassenti iddhiyā;"
    },
    {
      "id": "thi-ap32:12.3",
      "pali": "Tusitaṁ nimmite deve,"
    },
    {
      "id": "thi-ap32:12.4",
      "pali": "vasavattī mahissare."
    },
    {
      "id": "thi-ap32:13.1",
      "pali": "Brahmāno kāci dassenti,"
    },
    {
      "id": "thi-ap32:13.2",
      "pali": "caṅkamañca mahārahaṁ;"
    },
    {
      "id": "thi-ap32:13.3",
      "pali": "Brahmavaṇṇañca māpetvā,"
    },
    {
      "id": "thi-ap32:13.4",
      "pali": "dhammaṁ desenti suññataṁ."
    },
    {
      "id": "thi-ap32:14.1",
      "pali": "Nānāvikubbanaṁ katvā,"
    },
    {
      "id": "thi-ap32:14.2",
      "pali": "iddhiṁ dassiya satthuno;"
    },
    {
      "id": "thi-ap32:14.3",
      "pali": "Dassayiṁsu balaṁ sabbā,"
    },
    {
      "id": "thi-ap32:14.4",
      "pali": "pāde vandiṁsu satthuno."
    },
    {
      "id": "thi-ap32:15.1",
      "pali": "“Iddhīsu ca vasī homa,"
    },
    {
      "id": "thi-ap32:15.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap32:15.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap32:15.4",
      "pali": "vasī homa mahāmune."
    },
    {
      "id": "thi-ap32:16.1",
      "pali": "Pubbenivāsaṁ jānāma,"
    },
    {
      "id": "thi-ap32:16.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap32:16.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap32:16.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap32:17.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap32:17.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap32:17.3",
      "pali": "Ñāṇaṁ amhaṁ mahāvīra,"
    },
    {
      "id": "thi-ap32:17.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap32:18.1",
      "pali": "Pubbānaṁ lokanāthānaṁ,"
    },
    {
      "id": "thi-ap32:18.2",
      "pali": "saṅgamaṁ no nidassitaṁ;"
    },
    {
      "id": "thi-ap32:18.3",
      "pali": "Adhikāraṁ bahuṁ amhaṁ,"
    },
    {
      "id": "thi-ap32:18.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap32:19.1",
      "pali": "Yaṁ amhehi kataṁ kammaṁ,"
    },
    {
      "id": "thi-ap32:19.2",
      "pali": "kusalaṁ sara taṁ mune;"
    },
    {
      "id": "thi-ap32:19.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap32:19.4",
      "pali": "puññānupacitāni no."
    },
    {
      "id": "thi-ap32:20.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap32:20.2",
      "pali": "padumuttaro mahāmuni;"
    },
    {
      "id": "thi-ap32:20.3",
      "pali": "Puraṁ haṁsavatī nāma,"
    },
    {
      "id": "thi-ap32:20.4",
      "pali": "sambuddhassa kulāsayaṁ."
    },
    {
      "id": "thi-ap32:21.1",
      "pali": "Dvārena haṁsavatiyā,"
    },
    {
      "id": "thi-ap32:21.2",
      "pali": "gaṅgā sandati sabbadā;"
    },
    {
      "id": "thi-ap32:21.3",
      "pali": "Ubbāḷhā nadiyā bhikkhū,"
    },
    {
      "id": "thi-ap32:21.4",
      "pali": "gamanaṁ na labhanti te."
    },
    {
      "id": "thi-ap32:22.1",
      "pali": "Divasaṁ dve tayo ceva,"
    },
    {
      "id": "thi-ap32:22.2",
      "pali": "sattāhaṁ māsikaṁ tato;"
    },
    {
      "id": "thi-ap32:22.3",
      "pali": "Catumāsampi sampuṇṇaṁ,"
    },
    {
      "id": "thi-ap32:22.4",
      "pali": "gamanaṁ na labhanti te."
    },
    {
      "id": "thi-ap32:23.1",
      "pali": "Tadā ahu sattasāro,"
    },
    {
      "id": "thi-ap32:23.2",
      "pali": "jaṭilo nāma raṭṭhiko;"
    },
    {
      "id": "thi-ap32:23.3",
      "pali": "Oruddhe bhikkhavo disvā,"
    },
    {
      "id": "thi-ap32:23.4",
      "pali": "setuṁ gaṅgāya kārayi."
    },
    {
      "id": "thi-ap32:24.1",
      "pali": "Tadā satasahassehi,"
    },
    {
      "id": "thi-ap32:24.2",
      "pali": "setuṁ gaṅgāya kārayi;"
    },
    {
      "id": "thi-ap32:24.3",
      "pali": "Saṅghassa orime tīre,"
    },
    {
      "id": "thi-ap32:24.4",
      "pali": "vihārañca akārayi."
    },
    {
      "id": "thi-ap32:25.1",
      "pali": "Itthiyo purisā ceva,"
    },
    {
      "id": "thi-ap32:25.2",
      "pali": "uccanīcakulāni ca;"
    },
    {
      "id": "thi-ap32:25.3",
      "pali": "Tassa setuṁ vihārañca,"
    },
    {
      "id": "thi-ap32:25.4",
      "pali": "samabhāgaṁ akaṁsu te."
    },
    {
      "id": "thi-ap32:26.1",
      "pali": "Amhe aññe ca mānujā,"
    },
    {
      "id": "thi-ap32:26.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "thi-ap32:26.3",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap32:26.4",
      "pali": "nagare janapadesu ca."
    },
    {
      "id": "thi-ap32:27.1",
      "pali": "Itthī pumā kumārā ca,"
    },
    {
      "id": "thi-ap32:27.2",
      "pali": "bahū ceva kumārikā;"
    },
    {
      "id": "thi-ap32:27.3",
      "pali": "Setuno ca vihārassa,"
    },
    {
      "id": "thi-ap32:27.4",
      "pali": "vālukā ākiriṁsu te."
    },
    {
      "id": "thi-ap32:28.1",
      "pali": "Vīthiṁ sammajjanaṁ katvā,"
    },
    {
      "id": "thi-ap32:28.2",
      "pali": "kadalīpuṇṇaghaṭe dhaje;"
    },
    {
      "id": "thi-ap32:28.3",
      "pali": "Dhūpaṁ cuṇṇañca mālañca,"
    },
    {
      "id": "thi-ap32:28.4",
      "pali": "kāraṁ katvāna satthuno."
    },
    {
      "id": "thi-ap32:29.1",
      "pali": "Setuvihāre kāretvā,"
    },
    {
      "id": "thi-ap32:29.2",
      "pali": "nimantetvā vināyakaṁ;"
    },
    {
      "id": "thi-ap32:29.3",
      "pali": "Mahādānaṁ daditvāna,"
    },
    {
      "id": "thi-ap32:29.4",
      "pali": "sambodhiṁ abhipatthayiṁ."
    },
    {
      "id": "thi-ap32:30.1",
      "pali": "Padumuttaro mahāvīro,"
    },
    {
      "id": "thi-ap32:30.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "thi-ap32:30.3",
      "pali": "Anumodanīyaṅkāsi,"
    },
    {
      "id": "thi-ap32:30.4",
      "pali": "jaṭilassa mahāmuni."
    },
    {
      "id": "thi-ap32:31.1",
      "pali": "‘Satasahassātikkante,"
    },
    {
      "id": "thi-ap32:31.2",
      "pali": "kappo hessati bhaddako;"
    },
    {
      "id": "thi-ap32:31.3",
      "pali": "Bhavābhavenubhotvāna,"
    },
    {
      "id": "thi-ap32:31.4",
      "pali": "pāpuṇissati bodhiyaṁ."
    },
    {
      "id": "thi-ap32:32.1",
      "pali": "Kāci hatthaparikammaṁ,"
    },
    {
      "id": "thi-ap32:32.2",
      "pali": "katāvī naranāriyo;"
    },
    {
      "id": "thi-ap32:32.3",
      "pali": "Anāgatamhi addhāne,"
    },
    {
      "id": "thi-ap32:32.4",
      "pali": "sabbā hessanti sammukhā’."
    },
    {
      "id": "thi-ap32:33.1",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "thi-ap32:33.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap32:33.3",
      "pali": "Uppannā devabhavanaṁ,"
    },
    {
      "id": "thi-ap32:33.4",
      "pali": "tuyhaṁ tā paricārikā."
    },
    {
      "id": "thi-ap32:34.1",
      "pali": "Dibbasukhaṁ asaṅkhiyaṁ,"
    },
    {
      "id": "thi-ap32:34.2",
      "pali": "mānusañca asaṅkhiyaṁ;"
    },
    {
      "id": "thi-ap32:34.3",
      "pali": "Tuyhaṁ te paricārema,"
    },
    {
      "id": "thi-ap32:34.4",
      "pali": "saṁsarimha bhavābhave."
    },
    {
      "id": "thi-ap32:35.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap32:35.2",
      "pali": "sukataṁ kammasampadaṁ;"
    },
    {
      "id": "thi-ap32:35.3",
      "pali": "Sukhumālī manussānaṁ,"
    },
    {
      "id": "thi-ap32:35.4",
      "pali": "atho devapure vare."
    },
    {
      "id": "thi-ap32:36.1",
      "pali": "Rūpabhogayase ceva,"
    },
    {
      "id": "thi-ap32:36.2",
      "pali": "atho kittiñca sakkataṁ;"
    },
    {
      "id": "thi-ap32:36.3",
      "pali": "Labhāma satataṁ sabbaṁ,"
    },
    {
      "id": "thi-ap32:36.4",
      "pali": "sukataṁ kammasampadaṁ."
    },
    {
      "id": "thi-ap32:37.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap32:37.2",
      "pali": "jātāmha brāhmaṇe kule;"
    },
    {
      "id": "thi-ap32:37.3",
      "pali": "Sukhumālahatthapādā,"
    },
    {
      "id": "thi-ap32:37.4",
      "pali": "sakyaputtanivesane."
    },
    {
      "id": "thi-ap32:38.1",
      "pali": "Sabbakālampi pathaviṁ,"
    },
    {
      "id": "thi-ap32:38.2",
      "pali": "na passāma na laṅkataṁ;"
    },
    {
      "id": "thi-ap32:38.3",
      "pali": "Cikkhallabhūmimasuciṁ,"
    },
    {
      "id": "thi-ap32:38.4",
      "pali": "na passāma mahāmune."
    },
    {
      "id": "thi-ap32:39.1",
      "pali": "Agāraṁ vasante amhe,"
    },
    {
      "id": "thi-ap32:39.2",
      "pali": "sakkāraṁ sabbakālikaṁ;"
    },
    {
      "id": "thi-ap32:39.3",
      "pali": "Upanenti sadā sabbaṁ,"
    },
    {
      "id": "thi-ap32:39.4",
      "pali": "pubbakammaphalena no."
    },
    {
      "id": "thi-ap32:40.1",
      "pali": "Agāraṁ pajahitvāna,"
    },
    {
      "id": "thi-ap32:40.2",
      "pali": "pabbajitvānagāriyaṁ;"
    },
    {
      "id": "thi-ap32:40.3",
      "pali": "Saṁsārapathanitthiṇṇā,"
    },
    {
      "id": "thi-ap32:40.4",
      "pali": "vītarāgā bhavāmase."
    },
    {
      "id": "thi-ap32:41.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap32:41.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap32:41.3",
      "pali": "Upanenti sadā amhe,"
    },
    {
      "id": "thi-ap32:41.4",
      "pali": "sahassāni tato tato."
    },
    {
      "id": "thi-ap32:42.1",
      "pali": "Kilesā jhāpitā amhaṁ,"
    },
    {
      "id": "thi-ap32:42.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap32:42.3",
      "pali": "viharāma anāsavā."
    },
    {
      "id": "thi-ap32:43.1",
      "pali": "Svāgataṁ vata no āsi,"
    },
    {
      "id": "thi-ap32:43.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap32:43.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap32:44.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap32:44.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap32:44.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap32:45.1",
      "pali": "Itthaṁ sudaṁ caturāsītibrāhmaṇakaññābhikkhunīsahassāni bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap32:46.1",
      "pali": "Caturāsītibhikkhunīsahassāpadānaṁ dutiyaṁ."
    }
  ]
}
