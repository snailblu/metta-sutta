{
  "uid": "tha-ap554",
  "title": "Nadīkassapattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap554:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap554:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap554:1.3",
      "pali": "Piṇḍacāraṁ carantassa,"
    },
    {
      "id": "tha-ap554:1.4",
      "pali": "Vārato uttamaṁ yasaṁ;"
    },
    {
      "id": "tha-ap554:1.5",
      "pali": "Aggaphalaṁ gahetvāna,"
    },
    {
      "id": "tha-ap554:1.6",
      "pali": "Adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap554:2.1",
      "pali": "Tena kammena devindo,"
    },
    {
      "id": "tha-ap554:2.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap554:2.3",
      "pali": "Sampattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap554:2.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap554:3.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap554:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap554:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap554:3.4",
      "pali": "aggadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap554:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap554:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap554:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap554:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap554:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap554:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap554:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap554:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap554:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap554:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā nadīkassapo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap554:8.1",
      "pali": "Nadīkassapattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
