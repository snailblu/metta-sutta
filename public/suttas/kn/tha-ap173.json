{
  "uid": "tha-ap173",
  "title": "Kumudamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap173:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap173:1.2",
      "pali": "mahājātassaro ahu;"
    },
    {
      "id": "tha-ap173:1.3",
      "pali": "Tatthajo rakkhaso āsiṁ,"
    },
    {
      "id": "tha-ap173:1.4",
      "pali": "ghorarūpo mahabbalo."
    },
    {
      "id": "tha-ap173:2.1",
      "pali": "Kumudaṁ pupphate tattha,"
    },
    {
      "id": "tha-ap173:2.2",
      "pali": "cakkamattāni jāyare;"
    },
    {
      "id": "tha-ap173:2.3",
      "pali": "Ocināmi ca taṁ pupphaṁ,"
    },
    {
      "id": "tha-ap173:2.4",
      "pali": "balino samitiṁ tadā."
    },
    {
      "id": "tha-ap173:3.1",
      "pali": "Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap173:3.2",
      "pali": "dvipadindo narāsabho;"
    },
    {
      "id": "tha-ap173:3.3",
      "pali": "Pupphasaṅkocitaṁ disvā,"
    },
    {
      "id": "tha-ap173:3.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap173:4.1",
      "pali": "Upāgatañca sambuddhaṁ,"
    },
    {
      "id": "tha-ap173:4.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap173:4.3",
      "pali": "Sabbañca pupphaṁ paggayha,"
    },
    {
      "id": "tha-ap173:4.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap173:5.1",
      "pali": "Yāvatā himavantantā,"
    },
    {
      "id": "tha-ap173:5.2",
      "pali": "parisā sā tadā ahu;"
    },
    {
      "id": "tha-ap173:5.3",
      "pali": "Tāvacchadanasampanno,"
    },
    {
      "id": "tha-ap173:5.4",
      "pali": "agamāsi tathāgato."
    },
    {
      "id": "tha-ap173:6.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap173:6.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap173:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap173:6.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap173:7.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap173:7.2",
      "pali": "sattāhesuṁ janādhipā;"
    },
    {
      "id": "tha-ap173:7.3",
      "pali": "Sahassarathanāmā te,"
    },
    {
      "id": "tha-ap173:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap173:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap173:8.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap173:8.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap173:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap173:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā kumudamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap173:10.1",
      "pali": "Kumudamāliyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
