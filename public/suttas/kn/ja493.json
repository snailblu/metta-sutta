{
  "uid": "ja493",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja493:1.1",
      "pali": "Vāṇijā samitiṁ katvā,"
    },
    {
      "id": "ja493:1.2",
      "pali": "nānāraṭṭhato āgatā;"
    },
    {
      "id": "ja493:1.3",
      "pali": "Dhanāharā pakkamiṁsu,"
    },
    {
      "id": "ja493:1.4",
      "pali": "ekaṁ katvāna gāmaṇiṁ."
    },
    {
      "id": "ja493:2.1",
      "pali": "Te taṁ kantāramāgamma,"
    },
    {
      "id": "ja493:2.2",
      "pali": "appabhakkhaṁ anodakaṁ;"
    },
    {
      "id": "ja493:2.3",
      "pali": "Mahānigrodhamaddakkhuṁ,"
    },
    {
      "id": "ja493:2.4",
      "pali": "sītacchāyaṁ manoramaṁ."
    },
    {
      "id": "ja493:3.1",
      "pali": "Te ca tattha nisīditvā,"
    },
    {
      "id": "ja493:3.2",
      "pali": "tassa rukkhassa chāyayā;"
    },
    {
      "id": "ja493:3.3",
      "pali": "Vāṇijā samacintesuṁ,"
    },
    {
      "id": "ja493:3.4",
      "pali": "bālā mohena pārutā."
    },
    {
      "id": "ja493:4.1",
      "pali": "Allāyate ayaṁ rukkho,"
    },
    {
      "id": "ja493:4.2",
      "pali": "api vārīva sandati;"
    },
    {
      "id": "ja493:4.3",
      "pali": "Iṅghassa purimaṁ sākhaṁ,"
    },
    {
      "id": "ja493:4.4",
      "pali": "mayaṁ chindāma vāṇijā."
    },
    {
      "id": "ja493:5.1",
      "pali": "Sā ca chinnāva pagghari,"
    },
    {
      "id": "ja493:5.2",
      "pali": "acchaṁ vāriṁ anāvilaṁ;"
    },
    {
      "id": "ja493:5.3",
      "pali": "Te tattha nhatvā pivitvā,"
    },
    {
      "id": "ja493:5.4",
      "pali": "yāvaticchiṁsu vāṇijā."
    },
    {
      "id": "ja493:6.1",
      "pali": "Dutiyaṁ samacintesuṁ,"
    },
    {
      "id": "ja493:6.2",
      "pali": "bālā mohena pārutā;"
    },
    {
      "id": "ja493:6.3",
      "pali": "Iṅghassa dakkhiṇaṁ sākhaṁ,"
    },
    {
      "id": "ja493:6.4",
      "pali": "mayaṁ chindāma vāṇijā."
    },
    {
      "id": "ja493:7.1",
      "pali": "Sā ca chinnāva pagghari,"
    },
    {
      "id": "ja493:7.2",
      "pali": "sālimaṁsodanaṁ bahuṁ;"
    },
    {
      "id": "ja493:7.3",
      "pali": "Appodavaṇṇe kummāse,"
    },
    {
      "id": "ja493:7.4",
      "pali": "siṅgiṁ vidalasūpiyo."
    },
    {
      "id": "ja493:8.1",
      "pali": "Te tattha bhutvā khāditvā,"
    },
    {
      "id": "ja493:8.2",
      "pali": "yāvaticchiṁsu vāṇijā;"
    },
    {
      "id": "ja493:8.3",
      "pali": "Tatiyaṁ samacintesuṁ,"
    },
    {
      "id": "ja493:8.4",
      "pali": "bālā mohena pārutā;"
    },
    {
      "id": "ja493:8.5",
      "pali": "Iṅghassa pacchimaṁ sākhaṁ,"
    },
    {
      "id": "ja493:8.6",
      "pali": "mayaṁ chindāma vāṇijā."
    },
    {
      "id": "ja493:9.1",
      "pali": "Sā ca chinnāva pagghari,"
    },
    {
      "id": "ja493:9.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "ja493:9.3",
      "pali": "Vicitravatthābharaṇā,"
    },
    {
      "id": "ja493:9.4",
      "pali": "āmuttamaṇikuṇḍalā."
    },
    {
      "id": "ja493:10.1",
      "pali": "Api su vāṇijā ekā,"
    },
    {
      "id": "ja493:10.2",
      "pali": "nāriyo paṇṇavīsati;"
    },
    {
      "id": "ja493:10.3",
      "pali": "Samantā parivāriṁsu,"
    },
    {
      "id": "ja493:10.4",
      "pali": "tassa rukkhassa chāyayā."
    },
    {
      "id": "ja493:11.1",
      "pali": "Te tāhi paricāretvā,"
    },
    {
      "id": "ja493:11.2",
      "pali": "yāvaticchiṁsu vāṇijā;"
    },
    {
      "id": "ja493:11.3",
      "pali": "Catutthaṁ samacintesuṁ,"
    },
    {
      "id": "ja493:11.4",
      "pali": "bālā mohena pārutā;"
    },
    {
      "id": "ja493:11.5",
      "pali": "Iṅghassa uttaraṁ sākhaṁ,"
    },
    {
      "id": "ja493:11.6",
      "pali": "mayaṁ chindāma vāṇijā."
    },
    {
      "id": "ja493:12.1",
      "pali": "Sā ca chinnāva pagghari,"
    },
    {
      "id": "ja493:12.2",
      "pali": "muttā veḷuriyā bahū;"
    },
    {
      "id": "ja493:12.3",
      "pali": "Rajataṁ jātarūpañca,"
    },
    {
      "id": "ja493:12.4",
      "pali": "kuttiyo paṭiyāni ca."
    },
    {
      "id": "ja493:13.1",
      "pali": "Kāsikāni ca vatthāni,"
    },
    {
      "id": "ja493:13.2",
      "pali": "uddiyāni ca kambalā;"
    },
    {
      "id": "ja493:13.3",
      "pali": "Te tattha bhāre bandhitvā,"
    },
    {
      "id": "ja493:13.4",
      "pali": "yāvaticchiṁsu vāṇijā."
    },
    {
      "id": "ja493:14.1",
      "pali": "Pañcamaṁ samacintesuṁ,"
    },
    {
      "id": "ja493:14.2",
      "pali": "bālā mohena pārutā;"
    },
    {
      "id": "ja493:14.3",
      "pali": "Iṅghassa mūlaṁ chindāma,"
    },
    {
      "id": "ja493:14.4",
      "pali": "api bhiyyo labhāmase."
    },
    {
      "id": "ja493:15.1",
      "pali": "Athuṭṭhahi satthavāho,"
    },
    {
      "id": "ja493:15.2",
      "pali": "yācamāno katañjalī;"
    },
    {
      "id": "ja493:15.3",
      "pali": "Nigrodho kiṁ parajjhati,"
    },
    {
      "id": "ja493:15.4",
      "pali": "vāṇijā bhaddamatthu te."
    },
    {
      "id": "ja493:16.1",
      "pali": "Vāridā purimā sākhā,"
    },
    {
      "id": "ja493:16.2",
      "pali": "annapānañca dakkhiṇā;"
    },
    {
      "id": "ja493:16.3",
      "pali": "Nāridā pacchimā sākhā,"
    },
    {
      "id": "ja493:16.4",
      "pali": "sabbakāme ca uttarā;"
    },
    {
      "id": "ja493:16.5",
      "pali": "Nigrodho kiṁ parajjhati,"
    },
    {
      "id": "ja493:16.6",
      "pali": "vāṇijā bhaddamatthu te."
    },
    {
      "id": "ja493:17.1",
      "pali": "Yassa rukkhassa chāyāya,"
    },
    {
      "id": "ja493:17.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "ja493:17.3",
      "pali": "Na tassa sākhaṁ bhañjeyya,"
    },
    {
      "id": "ja493:17.4",
      "pali": "mittadubbho hi pāpako."
    },
    {
      "id": "ja493:18.1",
      "pali": "Te ca tassānādiyitvā,"
    },
    {
      "id": "ja493:18.2",
      "pali": "ekassa vacanaṁ bahū;"
    },
    {
      "id": "ja493:18.3",
      "pali": "Nisitāhi kuṭhārīhi,"
    },
    {
      "id": "ja493:18.4",
      "pali": "mūlato naṁ upakkamuṁ."
    },
    {
      "id": "ja493:19.1",
      "pali": "Tato nāgā nikkhamiṁsu,"
    },
    {
      "id": "ja493:19.2",
      "pali": "sannaddhā paṇṇavīsati;"
    },
    {
      "id": "ja493:19.3",
      "pali": "Dhanuggahānaṁ tisatā,"
    },
    {
      "id": "ja493:19.4",
      "pali": "chasahassā ca vammino."
    },
    {
      "id": "ja493:20.1",
      "pali": "“Ete hanatha bandhatha,"
    },
    {
      "id": "ja493:20.2",
      "pali": "Mā vo muñcittha jīvitaṁ;"
    },
    {
      "id": "ja493:20.3",
      "pali": "Ṭhapetvā satthavāhaṁva,"
    },
    {
      "id": "ja493:20.4",
      "pali": "Sabbe bhasmaṁ karotha ne”."
    },
    {
      "id": "ja493:21.1",
      "pali": "“Tasmā hi paṇḍito poso,"
    },
    {
      "id": "ja493:21.2",
      "pali": "sampassaṁ atthamattano;"
    },
    {
      "id": "ja493:21.3",
      "pali": "Lobhassa na vasaṁ gacche,"
    },
    {
      "id": "ja493:21.4",
      "pali": "haneyyārisakaṁ manaṁ."
    },
    {
      "id": "ja493:22.1",
      "pali": "Evamādīnavaṁ ñatvā,"
    },
    {
      "id": "ja493:22.2",
      "pali": "taṇhā dukkhassa sambhavaṁ;"
    },
    {
      "id": "ja493:22.3",
      "pali": "Vītataṇho anādāno,"
    },
    {
      "id": "ja493:22.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "ja493:23.1",
      "pali": "Mahāvāṇijajātakaṁ dasamaṁ."
    }
  ]
}
