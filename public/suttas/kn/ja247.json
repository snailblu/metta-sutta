{
  "uid": "ja247",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja247:1.1",
      "pali": "“Addhā pādañjalī sabbe,"
    },
    {
      "id": "ja247:1.2",
      "pali": "paññāya atirocati;"
    },
    {
      "id": "ja247:1.3",
      "pali": "Tathā hi oṭṭhaṁ bhañjati,"
    },
    {
      "id": "ja247:1.4",
      "pali": "uttariṁ nūna passati”."
    },
    {
      "id": "ja247:2.1",
      "pali": "“Nāyaṁ dhammaṁ adhammaṁ vā,"
    },
    {
      "id": "ja247:2.2",
      "pali": "Atthānatthañca bujjhati;"
    },
    {
      "id": "ja247:2.3",
      "pali": "Aññatra oṭṭhanibbhogā,"
    },
    {
      "id": "ja247:2.4",
      "pali": "Nāyaṁ jānāti kiñcanan”ti."
    },
    {
      "id": "ja247:3.1",
      "pali": "Pādañjalījātakaṁ sattamaṁ."
    }
  ]
}
