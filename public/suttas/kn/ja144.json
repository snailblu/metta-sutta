{
  "uid": "ja144",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja144:1.1",
      "pali": "“Bahumpetaṁ asabbhi jātaveda,"
    },
    {
      "id": "ja144:1.2",
      "pali": "Yaṁ taṁ vāladhinābhipūjayāma;"
    },
    {
      "id": "ja144:1.3",
      "pali": "Maṁsārahassa natthajja maṁsaṁ,"
    },
    {
      "id": "ja144:1.4",
      "pali": "Naṅguṭṭhampi bhavaṁ paṭiggahātū”ti."
    },
    {
      "id": "ja144:2.1",
      "pali": "Naṅguṭṭhajātakaṁ catutthaṁ."
    }
  ]
}
