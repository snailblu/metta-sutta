{
  "uid": "iti56",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti56:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti56:2.1",
      "pali": "“Tayome, bhikkhave, āsavā."
    },
    {
      "id": "iti56:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti56:2.3",
      "pali": "Kāmāsavo, bhavāsavo, avijjāsavo—"
    },
    {
      "id": "iti56:2.4",
      "pali": "ime kho, bhikkhave, tayo āsavā”ti."
    },
    {
      "id": "iti56:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti56:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti56:3.1",
      "pali": "“Samāhito sampajāno,"
    },
    {
      "id": "iti56:3.2",
      "pali": "sato buddhassa sāvako;"
    },
    {
      "id": "iti56:3.3",
      "pali": "Āsave ca pajānāti,"
    },
    {
      "id": "iti56:3.4",
      "pali": "āsavānañca sambhavaṁ."
    },
    {
      "id": "iti56:4.1",
      "pali": "Yattha cetā nirujjhanti,"
    },
    {
      "id": "iti56:4.2",
      "pali": "maggañca khayagāminaṁ;"
    },
    {
      "id": "iti56:4.3",
      "pali": "Āsavānaṁ khayā bhikkhu,"
    },
    {
      "id": "iti56:4.4",
      "pali": "nicchāto parinibbuto”ti."
    },
    {
      "id": "iti56:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti56:5.2",
      "pali": "Sattamaṁ."
    }
  ]
}
