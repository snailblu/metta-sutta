{
  "uid": "mil3.5.4",
  "title": "4. Dhammadiṭṭhapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.5.4:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.5.4:1.2",
      "pali": "“bhante nāgasena, dhammo tayā diṭṭho”ti."
    },
    {
      "id": "mil3.5.4:1.3",
      "pali": "“Buddhanettiyā kho, mahārāja, buddhapaññattiyā yāvajīvaṁ sāvakehi vattitabban”ti."
    },
    {
      "id": "mil3.5.4:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.5.4:3.1",
      "pali": "Dhammadiṭṭhapañho catuttho."
    }
  ]
}
