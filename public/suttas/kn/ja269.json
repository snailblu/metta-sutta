{
  "uid": "ja269",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja269:1.1",
      "pali": "“Na hi vaṇṇena sampannā,"
    },
    {
      "id": "ja269:1.2",
      "pali": "mañjukā piyadassanā;"
    },
    {
      "id": "ja269:1.3",
      "pali": "Kharavācā piyā hoti,"
    },
    {
      "id": "ja269:1.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "ja269:2.1",
      "pali": "Nanu passasimaṁ kāḷiṁ,"
    },
    {
      "id": "ja269:2.2",
      "pali": "dubbaṇṇaṁ tilakāhataṁ;"
    },
    {
      "id": "ja269:2.3",
      "pali": "Kokilaṁ saṇhavācena,"
    },
    {
      "id": "ja269:2.4",
      "pali": "bahūnaṁ pāṇinaṁ piyaṁ."
    },
    {
      "id": "ja269:3.1",
      "pali": "Tasmā sakhilavācassa,"
    },
    {
      "id": "ja269:3.2",
      "pali": "mantabhāṇī anuddhato;"
    },
    {
      "id": "ja269:3.3",
      "pali": "Atthaṁ dhammañca dīpeti,"
    },
    {
      "id": "ja269:3.4",
      "pali": "madhuraṁ tassa bhāsitan”ti."
    },
    {
      "id": "ja269:4.1",
      "pali": "Sujātajātakaṁ navamaṁ."
    }
  ]
}
