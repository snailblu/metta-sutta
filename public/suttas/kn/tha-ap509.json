{
  "uid": "tha-ap509",
  "title": "7 Ajeliphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap509:1.1",
      "pali": "“Ajjuno nāma sambuddho,"
    },
    {
      "id": "tha-ap509:1.2",
      "pali": "himavante vasī tadā;"
    },
    {
      "id": "tha-ap509:1.3",
      "pali": "Caraṇena ca sampanno,"
    },
    {
      "id": "tha-ap509:1.4",
      "pali": "samādhikusalo muni."
    },
    {
      "id": "tha-ap509:2.1",
      "pali": "Kumbhamattaṁ gahetvāna,"
    },
    {
      "id": "tha-ap509:2.2",
      "pali": "ajeliṁ jīvajīvakaṁ;"
    },
    {
      "id": "tha-ap509:2.3",
      "pali": "Chattapaṇṇaṁ gahetvāna,"
    },
    {
      "id": "tha-ap509:2.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap509:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap509:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap509:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap509:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap509:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap509:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap509:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap509:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap509:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap509:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap509:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap509:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap509:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap509:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ajeliphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap509:8.1",
      "pali": "Ajeliphaladāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
