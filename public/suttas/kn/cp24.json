{
  "uid": "cp24",
  "title": "Nekkhammapāramī 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp24:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp24:1.2",
      "pali": "kāsīnaṁ puravaruttame;"
    },
    {
      "id": "cp24:1.3",
      "pali": "Bhaginī ca bhātaro satta,"
    },
    {
      "id": "cp24:1.4",
      "pali": "nibbattā sotthiye kule."
    },
    {
      "id": "cp24:2.1",
      "pali": "Etesaṁ pubbajo āsiṁ,"
    },
    {
      "id": "cp24:2.2",
      "pali": "hirīsukkamupāgato;"
    },
    {
      "id": "cp24:2.3",
      "pali": "Bhavaṁ disvāna bhayato,"
    },
    {
      "id": "cp24:2.4",
      "pali": "nekkhammābhirato ahaṁ."
    },
    {
      "id": "cp24:3.1",
      "pali": "Mātāpitūhi pahitā,"
    },
    {
      "id": "cp24:3.2",
      "pali": "sahāyā ekamānasā;"
    },
    {
      "id": "cp24:3.3",
      "pali": "Kāmehi maṁ nimantenti,"
    },
    {
      "id": "cp24:3.4",
      "pali": "‘kulavaṁsaṁ dharehi’ti."
    },
    {
      "id": "cp24:4.1",
      "pali": "Yaṁ tesaṁ vacanaṁ vuttaṁ,"
    },
    {
      "id": "cp24:4.2",
      "pali": "gihīdhamme sukhāvahaṁ;"
    },
    {
      "id": "cp24:4.3",
      "pali": "Taṁ me ahosi kaṭhinaṁ,"
    },
    {
      "id": "cp24:4.4",
      "pali": "tattaphālasamaṁ viya."
    },
    {
      "id": "cp24:5.1",
      "pali": "Te maṁ tadā ukkhipantaṁ,"
    },
    {
      "id": "cp24:5.2",
      "pali": "pucchiṁsu patthitaṁ mama;"
    },
    {
      "id": "cp24:5.3",
      "pali": "‘Kiṁ tvaṁ patthayase samma,"
    },
    {
      "id": "cp24:5.4",
      "pali": "yadi kāme na bhuñjasi’."
    },
    {
      "id": "cp24:6.1",
      "pali": "Tesāhaṁ evamavacaṁ,"
    },
    {
      "id": "cp24:6.2",
      "pali": "atthakāmo hitesinaṁ;"
    },
    {
      "id": "cp24:6.3",
      "pali": "‘Nāhaṁ patthemi gihībhāvaṁ,"
    },
    {
      "id": "cp24:6.4",
      "pali": "nekkhammābhirato ahaṁ’."
    },
    {
      "id": "cp24:7.1",
      "pali": "Te mayhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp24:7.2",
      "pali": "pitu mātu ca sāvayuṁ;"
    },
    {
      "id": "cp24:7.3",
      "pali": "Mātāpitā evamāhu,"
    },
    {
      "id": "cp24:7.4",
      "pali": "‘sabbeva pabbajāma bho’."
    },
    {
      "id": "cp24:8.1",
      "pali": "Ubho mātāpitā mayhaṁ,"
    },
    {
      "id": "cp24:8.2",
      "pali": "bhaginī ca satta bhātaro;"
    },
    {
      "id": "cp24:8.3",
      "pali": "Amitadhanaṁ chaḍḍayitvā,"
    },
    {
      "id": "cp24:8.4",
      "pali": "pāvisimhā mahāvanan”ti."
    },
    {
      "id": "cp24:9.1",
      "pali": "Bhisacariyaṁ catutthaṁ."
    }
  ]
}
