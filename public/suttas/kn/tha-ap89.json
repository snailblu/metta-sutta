{
  "uid": "tha-ap89",
  "title": "Phaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap89:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap89:1.2",
      "pali": "kharājinadharo ahaṁ;"
    },
    {
      "id": "tha-ap89:1.3",
      "pali": "Phussaṁ jinavaraṁ disvā,"
    },
    {
      "id": "tha-ap89:1.4",
      "pali": "phalahattho phalaṁ adaṁ."
    },
    {
      "id": "tha-ap89:2.1",
      "pali": "Yamahaṁ phalamadāsiṁ,"
    },
    {
      "id": "tha-ap89:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap89:2.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap89:2.4",
      "pali": "phalaṁ nibbattate mama."
    },
    {
      "id": "tha-ap89:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap89:3.2",
      "pali": "yaṁ phalaṁ adadiṁ ahaṁ;"
    },
    {
      "id": "tha-ap89:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap89:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap89:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap89:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap89:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap89:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap89:6.1",
      "pali": "Phaladāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
