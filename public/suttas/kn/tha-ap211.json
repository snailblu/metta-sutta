{
  "uid": "tha-ap211",
  "title": "Ādhāradāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap211:1.1",
      "pali": "“Ādhārakaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap211:1.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap211:1.3",
      "pali": "Dhāremi pathaviṁ sabbaṁ,"
    },
    {
      "id": "tha-ap211:1.4",
      "pali": "kevalaṁ vasudhaṁ imaṁ."
    },
    {
      "id": "tha-ap211:2.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap211:2.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap211:2.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap211:2.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap211:3.1",
      "pali": "Sattavīse ito kappe,"
    },
    {
      "id": "tha-ap211:3.2",
      "pali": "ahesuṁ caturo janā;"
    },
    {
      "id": "tha-ap211:3.3",
      "pali": "Samantavaraṇā nāma,"
    },
    {
      "id": "tha-ap211:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap211:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap211:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap211:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap211:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ādhāradāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap211:6.1",
      "pali": "Ādhāradāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
