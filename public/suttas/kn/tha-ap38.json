{
  "uid": "tha-ap38",
  "title": "6 Adhimuttattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap38:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap38:1.2",
      "pali": "atthadassīnaruttame;"
    },
    {
      "id": "tha-ap38:1.3",
      "pali": "Upaṭṭhahiṁ bhikkhusaṅghaṁ,"
    },
    {
      "id": "tha-ap38:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap38:2.1",
      "pali": "Nimantetvā bhikkhusaṅghaṁ,"
    },
    {
      "id": "tha-ap38:2.2",
      "pali": "Ujubhūtaṁ samāhitaṁ;"
    },
    {
      "id": "tha-ap38:2.3",
      "pali": "Ucchunā maṇḍapaṁ katvā,"
    },
    {
      "id": "tha-ap38:2.4",
      "pali": "Bhojesiṁ saṅghamuttamaṁ."
    },
    {
      "id": "tha-ap38:3.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap38:3.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap38:3.3",
      "pali": "Sabbe satte abhibhomi,"
    },
    {
      "id": "tha-ap38:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap38:4.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap38:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap38:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap38:4.4",
      "pali": "ucchudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap38:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap38:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap38:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap38:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā adhimutto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap38:7.1",
      "pali": "Adhimuttattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
