{
  "uid": "thag1.83",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.83:1.1",
      "pali": "“Sīhappamatto vihara,"
    },
    {
      "id": "thag1.83:1.2",
      "pali": "rattindivamatandito;"
    },
    {
      "id": "thag1.83:1.3",
      "pali": "Bhāvehi kusalaṁ dhammaṁ,"
    },
    {
      "id": "thag1.83:1.4",
      "pali": "jaha sīghaṁ samussayan”ti."
    },
    {
      "id": "thag1.83:1.5",
      "pali": "… Sīho thero …."
    }
  ]
}
