{
  "uid": "tha-ap345",
  "title": "Dhajadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap345:1.1",
      "pali": "“Tisso nāma ahu satthā,"
    },
    {
      "id": "tha-ap345:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap345:1.3",
      "pali": "Tayopadhikkhaye disvā,"
    },
    {
      "id": "tha-ap345:1.4",
      "pali": "dhajaṁ āropitaṁ mayā."
    },
    {
      "id": "tha-ap345:2.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap345:2.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap345:2.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap345:2.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap345:3.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap345:3.2",
      "pali": "devarajjaṁ akārayiṁ;"
    },
    {
      "id": "tha-ap345:3.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap345:3.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap345:4.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap345:4.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap345:4.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap345:4.4",
      "pali": "pubbe sukatamattano."
    },
    {
      "id": "tha-ap345:5.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap345:5.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap345:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap345:5.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap345:6.1",
      "pali": "Icchamāno cahaṁ ajja,"
    },
    {
      "id": "tha-ap345:6.2",
      "pali": "sakānanaṁ sapabbataṁ;"
    },
    {
      "id": "tha-ap345:6.3",
      "pali": "Khomadussena chādeyyaṁ,"
    },
    {
      "id": "tha-ap345:6.4",
      "pali": "tadā mayhaṁ kate phalaṁ."
    },
    {
      "id": "tha-ap345:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap345:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap345:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap345:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhajadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap345:9.1",
      "pali": "Dhajadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
