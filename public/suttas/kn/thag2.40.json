{
  "uid": "thag2.40",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.40:1.1",
      "pali": "“Ayamiti kappaṭo kappaṭakuro,"
    },
    {
      "id": "thag2.40:1.2",
      "pali": "Acchāya atibharitāya;"
    },
    {
      "id": "thag2.40:1.3",
      "pali": "Amataghaṭikāyaṁ dhammakaṭamatto,"
    },
    {
      "id": "thag2.40:1.4",
      "pali": "Katapadaṁ jhānāni ocetuṁ."
    },
    {
      "id": "thag2.40:2.1",
      "pali": "Mā kho tvaṁ kappaṭa pacālesi,"
    },
    {
      "id": "thag2.40:2.2",
      "pali": "Mā tvaṁ upakaṇṇamhi tāḷessaṁ;"
    },
    {
      "id": "thag2.40:2.3",
      "pali": "Na hi tvaṁ kappaṭa mattamaññāsi,"
    },
    {
      "id": "thag2.40:2.4",
      "pali": "Saṅghamajjhamhi pacalāyamāno”ti."
    },
    {
      "id": "thag2.40:2.5",
      "pali": "… Kappaṭakuro thero …"
    },
    {
      "id": "thag2.40:2.6",
      "pali": "vaggo catuttho."
    },
    {
      "id": "thag2.40:3.1",
      "pali": "Migasiro sivako ca,"
    },
    {
      "id": "thag2.40:3.2",
      "pali": "upavāṇo ca paṇḍito;"
    },
    {
      "id": "thag2.40:3.3",
      "pali": "Isidinno ca kaccāno,"
    },
    {
      "id": "thag2.40:3.4",
      "pali": "nitako ca mahāvasī;"
    },
    {
      "id": "thag2.40:3.5",
      "pali": "Poṭiriyaputto nisabho,"
    },
    {
      "id": "thag2.40:3.6",
      "pali": "usabho kappaṭakuroti."
    }
  ]
}
