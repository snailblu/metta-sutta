{
  "uid": "ja50",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja50:1.1",
      "pali": "“Dummedhānaṁ sahassena,"
    },
    {
      "id": "ja50:1.2",
      "pali": "yañño me upayācito;"
    },
    {
      "id": "ja50:1.3",
      "pali": "Idāni khohaṁ yajissāmi,"
    },
    {
      "id": "ja50:1.4",
      "pali": "bahu adhammiko jano”ti."
    },
    {
      "id": "ja50:2.1",
      "pali": "Dummedhajātakaṁ dasamaṁ."
    },
    {
      "id": "ja50:2.2",
      "pali": "Atthakāmavaggo pañcamo."
    },
    {
      "id": "ja50:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja50:4.1",
      "pali": "Atha mittaka mātu kapotavaro,"
    },
    {
      "id": "ja50:4.2",
      "pali": "Tathā veḷuka eḷamūgo rohiṇī;"
    },
    {
      "id": "ja50:4.3",
      "pali": "Kapi vāruṇi cetacarā ca puna,"
    },
    {
      "id": "ja50:4.4",
      "pali": "Tathā tāraka yaññavarena dasāti."
    },
    {
      "id": "ja50:5.1",
      "pali": "Paṭhamo paṇṇāsako."
    }
  ]
}
