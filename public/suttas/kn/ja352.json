{
  "uid": "ja352",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja352:1.1",
      "pali": "“Kiṁ nu santaramānova,"
    },
    {
      "id": "ja352:1.2",
      "pali": "lāyitvā haritaṁ tiṇaṁ;"
    },
    {
      "id": "ja352:1.3",
      "pali": "Khāda khādāti lapasi,"
    },
    {
      "id": "ja352:1.4",
      "pali": "gatasattaṁ jaraggavaṁ."
    },
    {
      "id": "ja352:2.1",
      "pali": "Na hi annena pānena,"
    },
    {
      "id": "ja352:2.2",
      "pali": "mato goṇo samuṭṭhahe;"
    },
    {
      "id": "ja352:2.3",
      "pali": "Tvañca tucchaṁ vilapasi,"
    },
    {
      "id": "ja352:2.4",
      "pali": "yathā taṁ dummatī tathā”."
    },
    {
      "id": "ja352:3.1",
      "pali": "“Tatheva tiṭṭhati sīsaṁ,"
    },
    {
      "id": "ja352:3.2",
      "pali": "hatthapādā ca vāladhi;"
    },
    {
      "id": "ja352:3.3",
      "pali": "Sotā tatheva tiṭṭhanti,"
    },
    {
      "id": "ja352:3.4",
      "pali": "maññe goṇo samuṭṭhahe."
    },
    {
      "id": "ja352:4.1",
      "pali": "Nevayyakassa sīsañca,"
    },
    {
      "id": "ja352:4.2",
      "pali": "hatthapādā ca dissare;"
    },
    {
      "id": "ja352:4.3",
      "pali": "Rudaṁ mattikathūpasmiṁ,"
    },
    {
      "id": "ja352:4.4",
      "pali": "nanu tvaññeva dummati”."
    },
    {
      "id": "ja352:5.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "ja352:5.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "ja352:5.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "ja352:5.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "ja352:6.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "ja352:6.2",
      "pali": "yamāsi hadayassitaṁ;"
    },
    {
      "id": "ja352:6.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "ja352:6.4",
      "pali": "pitusokaṁ apānudi."
    },
    {
      "id": "ja352:7.1",
      "pali": "Sohaṁ abbūḷhasallosmi,"
    },
    {
      "id": "ja352:7.2",
      "pali": "vītasoko anāvilo;"
    },
    {
      "id": "ja352:7.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "ja352:7.4",
      "pali": "tava sutvāna māṇava."
    },
    {
      "id": "ja352:8.1",
      "pali": "Evaṁ karonti sappaññā,"
    },
    {
      "id": "ja352:8.2",
      "pali": "ye honti anukampakā;"
    },
    {
      "id": "ja352:8.3",
      "pali": "Vinivattenti sokamhā,"
    },
    {
      "id": "ja352:8.4",
      "pali": "sujāto pitaraṁ yathā”ti."
    },
    {
      "id": "ja352:9.1",
      "pali": "Sujātajātakaṁ dutiyaṁ."
    }
  ]
}
