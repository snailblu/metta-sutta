{
  "uid": "tha-ap147",
  "title": "5 Umāpupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap147:1.1",
      "pali": "“Nibbute lokamahite,"
    },
    {
      "id": "tha-ap147:1.2",
      "pali": "āhutīnaṁ paṭiggahe;"
    },
    {
      "id": "tha-ap147:1.3",
      "pali": "Siddhatthamhi bhagavati,"
    },
    {
      "id": "tha-ap147:1.4",
      "pali": "mahāthūpamaho ahu."
    },
    {
      "id": "tha-ap147:2.1",
      "pali": "Mahe pavattamānamhi,"
    },
    {
      "id": "tha-ap147:2.2",
      "pali": "siddhatthassa mahesino;"
    },
    {
      "id": "tha-ap147:2.3",
      "pali": "Umāpupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap147:2.4",
      "pali": "thūpamhi abhiropayiṁ."
    },
    {
      "id": "tha-ap147:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap147:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap147:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap147:3.4",
      "pali": "thūpapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap147:4.1",
      "pali": "Ito ca navame kappe,"
    },
    {
      "id": "tha-ap147:4.2",
      "pali": "somadevasanāmakā;"
    },
    {
      "id": "tha-ap147:4.3",
      "pali": "Pañcāsītisu rājāno,"
    },
    {
      "id": "tha-ap147:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap147:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap147:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap147:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap147:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā umāpupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap147:7.1",
      "pali": "Umāpupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
