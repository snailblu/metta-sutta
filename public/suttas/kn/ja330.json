{
  "uid": "ja330",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja330:1.1",
      "pali": "“Sīlaṁ kireva kalyāṇaṁ,"
    },
    {
      "id": "ja330:1.2",
      "pali": "sīlaṁ loke anuttaraṁ;"
    },
    {
      "id": "ja330:1.3",
      "pali": "Passa ghoraviso nāgo,"
    },
    {
      "id": "ja330:1.4",
      "pali": "sīlavāti na haññati”."
    },
    {
      "id": "ja330:2.1",
      "pali": "“Yāvadevassahū kiñci,"
    },
    {
      "id": "ja330:2.2",
      "pali": "tāvadeva akhādisuṁ;"
    },
    {
      "id": "ja330:2.3",
      "pali": "Saṅgamma kulalā loke,"
    },
    {
      "id": "ja330:2.4",
      "pali": "na hiṁsanti akiñcanaṁ."
    },
    {
      "id": "ja330:3.1",
      "pali": "Sukhaṁ nirāsā supati,"
    },
    {
      "id": "ja330:3.2",
      "pali": "āsā phalavatī sukhā;"
    },
    {
      "id": "ja330:3.3",
      "pali": "Āsaṁ nirāsaṁ katvāna,"
    },
    {
      "id": "ja330:3.4",
      "pali": "sukhaṁ supati piṅgalā."
    },
    {
      "id": "ja330:4.1",
      "pali": "Na samādhiparo atthi,"
    },
    {
      "id": "ja330:4.2",
      "pali": "asmiṁ loke paramhi ca;"
    },
    {
      "id": "ja330:4.3",
      "pali": "Na paraṁ nāpi attānaṁ,"
    },
    {
      "id": "ja330:4.4",
      "pali": "vihiṁsati samāhito”ti."
    },
    {
      "id": "ja330:5.1",
      "pali": "Sīlavīmaṁsajātakaṁ dasamaṁ."
    },
    {
      "id": "ja330:5.2",
      "pali": "Kuṭidūsakavaggo tatiyo."
    },
    {
      "id": "ja330:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja330:7.1",
      "pali": "Samanussa saduddubha yācanako,"
    },
    {
      "id": "ja330:7.2",
      "pali": "Atha meṇḍavaruttama godhavaro;"
    },
    {
      "id": "ja330:7.3",
      "pali": "Atha kāyasakepuka bhotīvaro,"
    },
    {
      "id": "ja330:7.4",
      "pali": "Atha rādhasusīlavarena dasāti."
    }
  ]
}
