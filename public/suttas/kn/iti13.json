{
  "uid": "iti13",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti13:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti13:2.1",
      "pali": "“Makkhaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti13:2.2",
      "pali": "Makkhañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti13:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti13:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti13:3.1",
      "pali": "“Yena makkhena makkhāse,"
    },
    {
      "id": "iti13:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti13:3.3",
      "pali": "Taṁ makkhaṁ sammadaññāya,"
    },
    {
      "id": "iti13:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti13:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti13:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti13:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti13:4.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
