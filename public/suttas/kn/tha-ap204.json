{
  "uid": "tha-ap204",
  "title": "Minelapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap204:1.1",
      "pali": "“Suvaṇṇavaṇṇo bhagavā,"
    },
    {
      "id": "tha-ap204:1.2",
      "pali": "sataraṁsī patāpavā;"
    },
    {
      "id": "tha-ap204:1.3",
      "pali": "Caṅkamanaṁ samārūḷho,"
    },
    {
      "id": "tha-ap204:1.4",
      "pali": "mettacitto sikhīsabho."
    },
    {
      "id": "tha-ap204:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap204:2.2",
      "pali": "vanditvā ñāṇamuttamaṁ;"
    },
    {
      "id": "tha-ap204:2.3",
      "pali": "Minelapupphaṁ paggayha,"
    },
    {
      "id": "tha-ap204:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap204:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap204:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap204:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap204:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap204:4.1",
      "pali": "Ekūnatiṁsakappamhi,"
    },
    {
      "id": "tha-ap204:4.2",
      "pali": "sumeghaghananāmako;"
    },
    {
      "id": "tha-ap204:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap204:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap204:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap204:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap204:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap204:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā minelapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap204:7.1",
      "pali": "Minelapupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
