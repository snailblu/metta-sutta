{
  "uid": "tha-ap359",
  "title": "7 Supuṭakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap359:1.1",
      "pali": "“Divāvihārā nikkhanto,"
    },
    {
      "id": "tha-ap359:1.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "tha-ap359:1.3",
      "pali": "Bhikkhāya vicaranto so,"
    },
    {
      "id": "tha-ap359:1.4",
      "pali": "mama santikupāgami."
    },
    {
      "id": "tha-ap359:2.1",
      "pali": "Tato patīto sumano,"
    },
    {
      "id": "tha-ap359:2.2",
      "pali": "buddhaseṭṭhassa tādino;"
    },
    {
      "id": "tha-ap359:2.3",
      "pali": "Loṇasupuṭakaṁ datvā,"
    },
    {
      "id": "tha-ap359:2.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap359:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap359:3.2",
      "pali": "yaṁ puṭakamadāsahaṁ;"
    },
    {
      "id": "tha-ap359:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap359:3.4",
      "pali": "puṭakassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap359:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap359:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap359:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap359:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā supuṭakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap359:6.1",
      "pali": "Supuṭakapūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
