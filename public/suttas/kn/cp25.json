{
  "uid": "cp25",
  "title": "Nekkhammapāramī 5",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp25:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp25:1.2",
      "pali": "nagare brahmavaḍḍhane;"
    },
    {
      "id": "cp25:1.3",
      "pali": "Tattha kulavare seṭṭhe,"
    },
    {
      "id": "cp25:1.4",
      "pali": "mahāsāle ajāyahaṁ."
    },
    {
      "id": "cp25:2.1",
      "pali": "Tadāpi lokaṁ disvāna,"
    },
    {
      "id": "cp25:2.2",
      "pali": "Andhībhūtaṁ tamotthaṭaṁ;"
    },
    {
      "id": "cp25:2.3",
      "pali": "Cittaṁ bhavato patikuṭati,"
    },
    {
      "id": "cp25:2.4",
      "pali": "Tuttavegahataṁ viya."
    },
    {
      "id": "cp25:3.1",
      "pali": "Disvāna vividhaṁ pāpaṁ,"
    },
    {
      "id": "cp25:3.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "cp25:3.3",
      "pali": "‘Kadāhaṁ gehā nikkhamma,"
    },
    {
      "id": "cp25:3.4",
      "pali": "pavisissāmi kānanaṁ’."
    },
    {
      "id": "cp25:4.1",
      "pali": "Tadāpi maṁ nimantesuṁ,"
    },
    {
      "id": "cp25:4.2",
      "pali": "kāmabhogehi ñātayo;"
    },
    {
      "id": "cp25:4.3",
      "pali": "Tesampi chandamācikkhiṁ,"
    },
    {
      "id": "cp25:4.4",
      "pali": "‘mā nimantetha tehi maṁ’."
    },
    {
      "id": "cp25:5.1",
      "pali": "Yo me kaniṭṭhako bhātā,"
    },
    {
      "id": "cp25:5.2",
      "pali": "nando nāmāsi paṇḍito;"
    },
    {
      "id": "cp25:5.3",
      "pali": "Sopi maṁ anusikkhanto,"
    },
    {
      "id": "cp25:5.4",
      "pali": "pabbajjaṁ samarocayi."
    },
    {
      "id": "cp25:6.1",
      "pali": "Ahaṁ soṇo ca nando ca,"
    },
    {
      "id": "cp25:6.2",
      "pali": "ubho mātāpitā mama;"
    },
    {
      "id": "cp25:6.3",
      "pali": "Tadāpi bhoge chaḍḍetvā,"
    },
    {
      "id": "cp25:6.4",
      "pali": "pāvisimhā mahāvanan”ti."
    },
    {
      "id": "cp25:7.1",
      "pali": "Soṇapaṇḍitacariyaṁ pañcamaṁ."
    }
  ]
}
