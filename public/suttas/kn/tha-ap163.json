{
  "uid": "tha-ap163",
  "title": "Supāricariyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap163:1.1",
      "pali": "“Padumo nāma nāmena,"
    },
    {
      "id": "tha-ap163:1.2",
      "pali": "dvipadindo narāsabho;"
    },
    {
      "id": "tha-ap163:1.3",
      "pali": "Pavanā abhinikkhamma,"
    },
    {
      "id": "tha-ap163:1.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap163:2.1",
      "pali": "Yakkhānaṁ samayo āsi,"
    },
    {
      "id": "tha-ap163:2.2",
      "pali": "avidūre mahesino;"
    },
    {
      "id": "tha-ap163:2.3",
      "pali": "Yena kiccena sampattā,"
    },
    {
      "id": "tha-ap163:2.4",
      "pali": "ajjhāpekkhiṁsu tāvade."
    },
    {
      "id": "tha-ap163:3.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap163:3.2",
      "pali": "amatassa ca desanaṁ;"
    },
    {
      "id": "tha-ap163:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap163:3.4",
      "pali": "apphoṭetvā upaṭṭhahiṁ."
    },
    {
      "id": "tha-ap163:4.1",
      "pali": "Suciṇṇassa phalaṁ passa,"
    },
    {
      "id": "tha-ap163:4.2",
      "pali": "upaṭṭhānassa satthuno;"
    },
    {
      "id": "tha-ap163:4.3",
      "pali": "Tiṁsakappasahassesu,"
    },
    {
      "id": "tha-ap163:4.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap163:5.1",
      "pali": "Ūnatiṁse kappasate,"
    },
    {
      "id": "tha-ap163:5.2",
      "pali": "samalaṅkatanāmako;"
    },
    {
      "id": "tha-ap163:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap163:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap163:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap163:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap163:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap163:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap163:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā supāricariyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap163:8.1",
      "pali": "Supāricariyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
