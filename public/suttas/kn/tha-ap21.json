{
  "uid": "tha-ap21",
  "title": "Sopākattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap21:1.1",
      "pali": "“Pabbhāraṁ sodhayantassa,"
    },
    {
      "id": "tha-ap21:1.2",
      "pali": "vipine pabbatuttame;"
    },
    {
      "id": "tha-ap21:1.3",
      "pali": "Siddhattho nāma bhagavā,"
    },
    {
      "id": "tha-ap21:1.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap21:2.1",
      "pali": "Buddhaṁ upagataṁ disvā,"
    },
    {
      "id": "tha-ap21:2.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap21:2.3",
      "pali": "Santharaṁ paññapetvāna,"
    },
    {
      "id": "tha-ap21:2.4",
      "pali": "pupphāsanamadāsahaṁ."
    },
    {
      "id": "tha-ap21:3.1",
      "pali": "Pupphāsane nisīditvā,"
    },
    {
      "id": "tha-ap21:3.2",
      "pali": "siddhattho lokanāyako;"
    },
    {
      "id": "tha-ap21:3.3",
      "pali": "Mamañca gatimaññāya,"
    },
    {
      "id": "tha-ap21:3.4",
      "pali": "aniccatamudāhari."
    },
    {
      "id": "tha-ap21:4.1",
      "pali": "‘Aniccā vata saṅkhārā,"
    },
    {
      "id": "tha-ap21:4.2",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "tha-ap21:4.3",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "tha-ap21:4.4",
      "pali": "tesaṁ vūpasamo sukho’."
    },
    {
      "id": "tha-ap21:5.1",
      "pali": "Idaṁ vatvāna sabbaññū,"
    },
    {
      "id": "tha-ap21:5.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap21:5.3",
      "pali": "Nabhaṁ abbhuggami vīro,"
    },
    {
      "id": "tha-ap21:5.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap21:6.1",
      "pali": "Sakaṁ diṭṭhiṁ jahitvāna,"
    },
    {
      "id": "tha-ap21:6.2",
      "pali": "bhāvayāniccasaññahaṁ;"
    },
    {
      "id": "tha-ap21:6.3",
      "pali": "Ekāhaṁ bhāvayitvāna,"
    },
    {
      "id": "tha-ap21:6.4",
      "pali": "tattha kālaṁ kato ahaṁ."
    },
    {
      "id": "tha-ap21:7.1",
      "pali": "Dve sampattī anubhotvā,"
    },
    {
      "id": "tha-ap21:7.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap21:7.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap21:7.4",
      "pali": "sapākayonupāgamiṁ."
    },
    {
      "id": "tha-ap21:8.1",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap21:8.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap21:8.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap21:8.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap21:9.1",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "tha-ap21:9.2",
      "pali": "Sīlesu susamāhito;"
    },
    {
      "id": "tha-ap21:9.3",
      "pali": "Tosetvāna mahānāgaṁ,"
    },
    {
      "id": "tha-ap21:9.4",
      "pali": "Alatthaṁ upasampadaṁ."
    },
    {
      "id": "tha-ap21:10.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap21:10.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap21:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap21:10.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap21:11.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap21:11.2",
      "pali": "yaṁ saññaṁ bhāvayiṁ tadā;"
    },
    {
      "id": "tha-ap21:11.3",
      "pali": "Taṁ saññaṁ bhāvayantassa,"
    },
    {
      "id": "tha-ap21:11.4",
      "pali": "patto me āsavakkhayo."
    },
    {
      "id": "tha-ap21:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap21:12.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap21:12.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap21:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap21:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā sopāko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap21:14.1",
      "pali": "Sopākattherassāpadānaṁ navamaṁ."
    }
  ]
}
