{
  "uid": "ja535",
  "title": "Cūḷahaṁsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja535:1.1",
      "pali": "“Neva kiṇāmi napi vikkiṇāmi,"
    },
    {
      "id": "ja535:1.2",
      "pali": "Na cāpi me sannicayo ca atthi;"
    },
    {
      "id": "ja535:1.3",
      "pali": "Sukiccharūpaṁ vatidaṁ parittaṁ,"
    },
    {
      "id": "ja535:1.4",
      "pali": "Patthodano nālamayaṁ duvinnaṁ”."
    },
    {
      "id": "ja535:2.1",
      "pali": "“Appamhā appakaṁ dajjā,"
    },
    {
      "id": "ja535:2.2",
      "pali": "anumajjhato majjhakaṁ;"
    },
    {
      "id": "ja535:2.3",
      "pali": "Bahumhā bahukaṁ dajjā,"
    },
    {
      "id": "ja535:2.4",
      "pali": "adānaṁ nupapajjati."
    },
    {
      "id": "ja535:3.1",
      "pali": "Taṁ taṁ vadāmi kosiya,"
    },
    {
      "id": "ja535:3.2",
      "pali": "dehi dānāni bhuñja ca;"
    },
    {
      "id": "ja535:3.3",
      "pali": "Ariyamaggaṁ samārūha,"
    },
    {
      "id": "ja535:3.4",
      "pali": "nekāsī labhate sukhaṁ”."
    },
    {
      "id": "ja535:4.1",
      "pali": "“Moghañcassa hutaṁ hoti,"
    },
    {
      "id": "ja535:4.2",
      "pali": "moghañcāpi samīhitaṁ;"
    },
    {
      "id": "ja535:4.3",
      "pali": "Atithismiṁ yo nisinnasmiṁ,"
    },
    {
      "id": "ja535:4.4",
      "pali": "eko bhuñjati bhojanaṁ."
    },
    {
      "id": "ja535:5.1",
      "pali": "Taṁ taṁ vadāmi kosiya,"
    },
    {
      "id": "ja535:5.2",
      "pali": "dehi dānāni bhuñja ca;"
    },
    {
      "id": "ja535:5.3",
      "pali": "Ariyamaggaṁ samārūha,"
    },
    {
      "id": "ja535:5.4",
      "pali": "nekāsī labhate sukhaṁ”."
    },
    {
      "id": "ja535:6.1",
      "pali": "“Saccañcassa hutaṁ hoti,"
    },
    {
      "id": "ja535:6.2",
      "pali": "saccañcāpi samīhitaṁ;"
    },
    {
      "id": "ja535:6.3",
      "pali": "Atithismiṁ yo nisinnasmiṁ,"
    },
    {
      "id": "ja535:6.4",
      "pali": "neko bhuñjati bhojanaṁ."
    },
    {
      "id": "ja535:7.1",
      "pali": "Taṁ taṁ vadāmi kosiya,"
    },
    {
      "id": "ja535:7.2",
      "pali": "dehi dānāni bhuñja ca;"
    },
    {
      "id": "ja535:7.3",
      "pali": "Ariyamaggaṁ samārūha,"
    },
    {
      "id": "ja535:7.4",
      "pali": "nekāsī labhate sukhaṁ”."
    },
    {
      "id": "ja535:8.1",
      "pali": "“Sarañca juhati poso,"
    },
    {
      "id": "ja535:8.2",
      "pali": "bahukāya gayāya ca;"
    },
    {
      "id": "ja535:8.3",
      "pali": "Doṇe timbarutitthasmiṁ,"
    },
    {
      "id": "ja535:8.4",
      "pali": "sīghasote mahāvahe."
    },
    {
      "id": "ja535:9.1",
      "pali": "Atra cassa hutaṁ hoti,"
    },
    {
      "id": "ja535:9.2",
      "pali": "atra cassa samīhitaṁ;"
    },
    {
      "id": "ja535:9.3",
      "pali": "Atithismiṁ yo nisinnasmiṁ,"
    },
    {
      "id": "ja535:9.4",
      "pali": "neko bhuñjati bhojanaṁ."
    },
    {
      "id": "ja535:10.1",
      "pali": "Taṁ taṁ vadāmi kosiya,"
    },
    {
      "id": "ja535:10.2",
      "pali": "dehi dānāni bhuñja ca;"
    },
    {
      "id": "ja535:10.3",
      "pali": "Ariyamaggaṁ samārūha,"
    },
    {
      "id": "ja535:10.4",
      "pali": "nekāsī labhate sukhaṁ”."
    },
    {
      "id": "ja535:11.1",
      "pali": "“Baḷisañhi so nigilati,"
    },
    {
      "id": "ja535:11.2",
      "pali": "dīghasuttaṁ sabandhanaṁ;"
    },
    {
      "id": "ja535:11.3",
      "pali": "Atithismiṁ yo nisinnasmiṁ,"
    },
    {
      "id": "ja535:11.4",
      "pali": "eko bhuñjati bhojanaṁ."
    },
    {
      "id": "ja535:12.1",
      "pali": "Taṁ taṁ vadāmi kosiya,"
    },
    {
      "id": "ja535:12.2",
      "pali": "dehi dānāni bhuñja ca;"
    },
    {
      "id": "ja535:12.3",
      "pali": "Ariyamaggaṁ samārūha,"
    },
    {
      "id": "ja535:12.4",
      "pali": "nekāsī labhate sukhaṁ”."
    },
    {
      "id": "ja535:13.1",
      "pali": "“Uḷāravaṇṇā vata brāhmaṇā ime,"
    },
    {
      "id": "ja535:13.2",
      "pali": "Ayañca vo sunakho kissa hetu;"
    },
    {
      "id": "ja535:13.3",
      "pali": "Uccāvacaṁ vaṇṇanibhaṁ vikubbati,"
    },
    {
      "id": "ja535:13.4",
      "pali": "Akkhātha no brāhmaṇā ke nu tumhe”."
    },
    {
      "id": "ja535:14.1",
      "pali": "“Cando ca suriyo ca ubho idhāgatā,"
    },
    {
      "id": "ja535:14.2",
      "pali": "Ayaṁ pana mātali devasārathi;"
    },
    {
      "id": "ja535:14.3",
      "pali": "Sakkohamasmi tidasānamindo,"
    },
    {
      "id": "ja535:14.4",
      "pali": "Eso ca kho pañcasikhoti vuccati."
    },
    {
      "id": "ja535:15.1",
      "pali": "Pāṇissarā mudiṅgā ca,"
    },
    {
      "id": "ja535:15.2",
      "pali": "murajālambarāni ca;"
    },
    {
      "id": "ja535:15.3",
      "pali": "Suttamenaṁ pabodhenti,"
    },
    {
      "id": "ja535:15.4",
      "pali": "paṭibuddho ca nandati."
    },
    {
      "id": "ja535:16.1",
      "pali": "Ye kecime maccharino kadariyā,"
    },
    {
      "id": "ja535:16.2",
      "pali": "Paribhāsakā samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "ja535:16.3",
      "pali": "Idheva nikkhippa sarīradehaṁ,"
    },
    {
      "id": "ja535:16.4",
      "pali": "Kāyassa bhedā nirayaṁ vajanti."
    },
    {
      "id": "ja535:17.1",
      "pali": "Ye kecime suggatimāsamānā,"
    },
    {
      "id": "ja535:17.2",
      "pali": "Dhamme ṭhitā saṁyame saṁvibhāge;"
    },
    {
      "id": "ja535:17.3",
      "pali": "Idheva nikkhippa sarīradehaṁ,"
    },
    {
      "id": "ja535:17.4",
      "pali": "Kāyassa bhedā sugatiṁ vajanti."
    },
    {
      "id": "ja535:18.1",
      "pali": "Tvaṁ nosi ñāti purimāsu jātisu,"
    },
    {
      "id": "ja535:18.2",
      "pali": "So maccharī rosako pāpadhammo;"
    },
    {
      "id": "ja535:18.3",
      "pali": "Taveva atthāya idhāgatamhā,"
    },
    {
      "id": "ja535:18.4",
      "pali": "Mā pāpadhammo nirayaṁ gamittha”."
    },
    {
      "id": "ja535:19.1",
      "pali": "“Addhā maṁ vo hitakāmā,"
    },
    {
      "id": "ja535:19.2",
      "pali": "yaṁ maṁ samanusāsatha;"
    },
    {
      "id": "ja535:19.3",
      "pali": "Sohaṁ tathā karissāmi,"
    },
    {
      "id": "ja535:19.4",
      "pali": "sabbaṁ vuttaṁ hitesibhi."
    },
    {
      "id": "ja535:20.1",
      "pali": "Esāhamajjeva upāramāmi,"
    },
    {
      "id": "ja535:20.2",
      "pali": "Na cāpihaṁ kiñci kareyya pāpaṁ;"
    },
    {
      "id": "ja535:20.3",
      "pali": "Na cāpi me kiñci adeyyamatthi,"
    },
    {
      "id": "ja535:20.4",
      "pali": "Na cāpidatvā udakaṁ pivāmi."
    },
    {
      "id": "ja535:21.1",
      "pali": "Evañca me dadato sabbakālaṁ,"
    },
    {
      "id": "ja535:21.2",
      "pali": "Bhogā ime vāsava khīyissanti;"
    },
    {
      "id": "ja535:21.3",
      "pali": "Tato ahaṁ pabbajissāmi sakka,"
    },
    {
      "id": "ja535:21.4",
      "pali": "Hitvāna kāmāni yathodhikāni”."
    },
    {
      "id": "ja535:22.1",
      "pali": "Naguttame girivare gandhamādane,"
    },
    {
      "id": "ja535:22.2",
      "pali": "Modanti tā devavarābhipālitā;"
    },
    {
      "id": "ja535:22.3",
      "pali": "Athāgamā isivaro sabbalokagū,"
    },
    {
      "id": "ja535:22.4",
      "pali": "Supupphitaṁ dumavarasākhamādiya."
    },
    {
      "id": "ja535:23.1",
      "pali": "Suciṁ sugandhaṁ tidasehi sakkataṁ,"
    },
    {
      "id": "ja535:23.2",
      "pali": "Pupphuttamaṁ amaravarehi sevitaṁ;"
    },
    {
      "id": "ja535:23.3",
      "pali": "Aladdha maccehi va dānavehi vā,"
    },
    {
      "id": "ja535:23.4",
      "pali": "Aññatra devehi tadārahaṁ hidaṁ."
    },
    {
      "id": "ja535:24.1",
      "pali": "Tato catasso kanakattacūpamā,"
    },
    {
      "id": "ja535:24.2",
      "pali": "Uṭṭhāya nāriyo pamadādhipā muniṁ;"
    },
    {
      "id": "ja535:24.3",
      "pali": "Āsā ca saddhā ca sirī tato hirī,"
    },
    {
      "id": "ja535:24.4",
      "pali": "Iccabravuṁ nāradadeva brāhmaṇaṁ."
    },
    {
      "id": "ja535:25.1",
      "pali": "“Sace anuddiṭṭhaṁ tayā mahāmuni,"
    },
    {
      "id": "ja535:25.2",
      "pali": "Pupphaṁ imaṁ pārichattassa brahme;"
    },
    {
      "id": "ja535:25.3",
      "pali": "Dadāhi no sabbā gati te ijjhatu,"
    },
    {
      "id": "ja535:25.4",
      "pali": "Tuvampi no hohi yatheva vāsavo”."
    },
    {
      "id": "ja535:26.1",
      "pali": "Taṁ yācamānābhisamekkha nārado,"
    },
    {
      "id": "ja535:26.2",
      "pali": "Iccabravī saṅkalahaṁ udīrayi;"
    },
    {
      "id": "ja535:26.3",
      "pali": "“Na mayhamatthatthi imehi koci naṁ,"
    },
    {
      "id": "ja535:26.4",
      "pali": "Yāyeva vo seyyasi sā piḷandhatha”."
    },
    {
      "id": "ja535:27.1",
      "pali": "“Tvaṁ nottamevābhisamekkha nārada,"
    },
    {
      "id": "ja535:27.2",
      "pali": "Yassicchasi tassā anuppavecchasu;"
    },
    {
      "id": "ja535:27.3",
      "pali": "Yassā hi no nārada tvaṁ padassasi,"
    },
    {
      "id": "ja535:27.4",
      "pali": "Sāyeva no hehiti seṭṭhasammatā”."
    },
    {
      "id": "ja535:28.1",
      "pali": "“Akallametaṁ vacanaṁ sugatte,"
    },
    {
      "id": "ja535:28.2",
      "pali": "Ko brāhmaṇo saṅkalahaṁ udīraye;"
    },
    {
      "id": "ja535:28.3",
      "pali": "Gantvāna bhūtādhipameva pucchatha,"
    },
    {
      "id": "ja535:28.4",
      "pali": "Sace na jānātha idhuttamādhamaṁ”."
    },
    {
      "id": "ja535:29.1",
      "pali": "Tā nāradena paramappakopitā,"
    },
    {
      "id": "ja535:29.2",
      "pali": "Udīritā vaṇṇamadena mattā;"
    },
    {
      "id": "ja535:29.3",
      "pali": "Sakāse gantvāna sahassacakkhuno,"
    },
    {
      "id": "ja535:29.4",
      "pali": "“Pucchiṁsu bhūtādhipaṁ kā nu seyyasi”."
    },
    {
      "id": "ja535:30.1",
      "pali": "Tā disvā āyattamanā purindado,"
    },
    {
      "id": "ja535:30.2",
      "pali": "Iccabravī devavaro katañjalī;"
    },
    {
      "id": "ja535:30.3",
      "pali": "“Sabbāva vo hotha sugatte sādisī,"
    },
    {
      "id": "ja535:30.4",
      "pali": "Ko neva bhadde kalahaṁ udīrayi”."
    },
    {
      "id": "ja535:31.1",
      "pali": "“Yo sabbalokaccarito mahāmuni,"
    },
    {
      "id": "ja535:31.2",
      "pali": "Dhamme ṭhito nārado saccanikkamo;"
    },
    {
      "id": "ja535:31.3",
      "pali": "So nobravi girivare gandhamādane,"
    },
    {
      "id": "ja535:31.4",
      "pali": "Gantvāna bhūtādhipameva pucchatha;"
    },
    {
      "id": "ja535:31.5",
      "pali": "Sace na jānātha idhuttamādhamaṁ”."
    },
    {
      "id": "ja535:32.1",
      "pali": "“Asu brahāraññacaro mahāmuni,"
    },
    {
      "id": "ja535:32.2",
      "pali": "Nādatvā bhattaṁ varagatte bhuñjati;"
    },
    {
      "id": "ja535:32.3",
      "pali": "Viceyya dānāni dadāti kosiyo,"
    },
    {
      "id": "ja535:32.4",
      "pali": "Yassā hi so dassati sāva seyyasi”."
    },
    {
      "id": "ja535:33.1",
      "pali": "“Asū hi yo sammati dakkhiṇaṁ disaṁ,"
    },
    {
      "id": "ja535:33.2",
      "pali": "Gaṅgāya tīre himavantapassani;"
    },
    {
      "id": "ja535:33.3",
      "pali": "Sa kosiyo dullabhapānabhojano,"
    },
    {
      "id": "ja535:33.4",
      "pali": "Tassa sudhaṁ pāpaya devasārathi”."
    },
    {
      "id": "ja535:34.1",
      "pali": "Sa mātalī devavarena pesito,"
    },
    {
      "id": "ja535:34.2",
      "pali": "Sahassayuttaṁ abhiruyha sandanaṁ;"
    },
    {
      "id": "ja535:34.3",
      "pali": "Sukhippameva upagamma assamaṁ,"
    },
    {
      "id": "ja535:34.4",
      "pali": "Adissamāno munino sudhaṁ adā."
    },
    {
      "id": "ja535:35.1",
      "pali": "“Udaggihuttaṁ upatiṭṭhato hi me,"
    },
    {
      "id": "ja535:35.2",
      "pali": "Pabhaṅkaraṁ lokatamonuduttamaṁ;"
    },
    {
      "id": "ja535:35.3",
      "pali": "Sabbāni bhūtāni adhicca vāsavo,"
    },
    {
      "id": "ja535:35.4",
      "pali": "Ko neva me pāṇisu kiṁ sudhodahi."
    },
    {
      "id": "ja535:36.1",
      "pali": "Saṅkhūpamaṁ setamatulyadassanaṁ,"
    },
    {
      "id": "ja535:36.2",
      "pali": "Suciṁ sugandhaṁ piyarūpamabbhutaṁ;"
    },
    {
      "id": "ja535:36.3",
      "pali": "Adiṭṭhapubbaṁ mama jātu cakkhubhi,"
    },
    {
      "id": "ja535:36.4",
      "pali": "Kā devatā pāṇisu kiṁ sudhodahi”."
    },
    {
      "id": "ja535:37.1",
      "pali": "“Ahaṁ mahindena mahesi pesito,"
    },
    {
      "id": "ja535:37.2",
      "pali": "Sudhābhihāsiṁ turito mahāmuni;"
    },
    {
      "id": "ja535:37.3",
      "pali": "Jānāsi maṁ mātali devasārathi,"
    },
    {
      "id": "ja535:37.4",
      "pali": "Bhuñjassu bhattuttama mābhivārayi."
    },
    {
      "id": "ja535:38.1",
      "pali": "Bhuttā ca sā dvādasa hanti pāpake,"
    },
    {
      "id": "ja535:38.2",
      "pali": "Khudaṁ pipāsaṁ aratiṁ daraklamaṁ;"
    },
    {
      "id": "ja535:38.3",
      "pali": "Kodhūpanāhañca vivādapesuṇaṁ,"
    },
    {
      "id": "ja535:38.4",
      "pali": "Sītuṇha tandiñca rasuttamaṁ idaṁ”."
    },
    {
      "id": "ja535:39.1",
      "pali": "“Na kappatī mātali mayha bhuñjituṁ,"
    },
    {
      "id": "ja535:39.2",
      "pali": "Pubbe adatvā iti me vatuttamaṁ;"
    },
    {
      "id": "ja535:39.3",
      "pali": "Na cāpi ekāsnamarīyapūjitaṁ,"
    },
    {
      "id": "ja535:39.4",
      "pali": "Asaṁvibhāgī ca sukhaṁ na vindati”."
    },
    {
      "id": "ja535:40.1",
      "pali": "“Thīghātakā ye cime pāradārikā,"
    },
    {
      "id": "ja535:40.2",
      "pali": "Mittadduno ye ca sapanti subbate;"
    },
    {
      "id": "ja535:40.3",
      "pali": "Sabbe ca te maccharipañcamādhamā,"
    },
    {
      "id": "ja535:40.4",
      "pali": "Tasmā adatvā udakampi nāsniye."
    },
    {
      "id": "ja535:41.1",
      "pali": "Sohitthiyā vā purisassa vā pana,"
    },
    {
      "id": "ja535:41.2",
      "pali": "Dassāmi dānaṁ vidusampavaṇṇitaṁ;"
    },
    {
      "id": "ja535:41.3",
      "pali": "Saddhā vadaññū idha vītamaccharā,"
    },
    {
      "id": "ja535:41.4",
      "pali": "Bhavanti hete sucisaccasammatā”."
    },
    {
      "id": "ja535:42.1",
      "pali": "Ato matā devavarena pesitā,"
    },
    {
      "id": "ja535:42.2",
      "pali": "Kaññā catasso kanakattacūpamā;"
    },
    {
      "id": "ja535:42.3",
      "pali": "Āsā ca saddhā ca sirī tato hirī,"
    },
    {
      "id": "ja535:42.4",
      "pali": "Taṁ assamaṁ āgamu yattha kosiyo."
    },
    {
      "id": "ja535:43.1",
      "pali": "Tā disvā sabbo paramappamodito,"
    },
    {
      "id": "ja535:43.2",
      "pali": "Subhena vaṇṇena sikhārivaggino;"
    },
    {
      "id": "ja535:43.3",
      "pali": "Kaññā catasso caturo catuddisā,"
    },
    {
      "id": "ja535:43.4",
      "pali": "Iccabravī mātalino ca sammukhā."
    },
    {
      "id": "ja535:44.1",
      "pali": "“Purimaṁ disaṁ kā tvaṁ pabhāsi devate,"
    },
    {
      "id": "ja535:44.2",
      "pali": "Alaṅkatā tāravarāva osadhī;"
    },
    {
      "id": "ja535:44.3",
      "pali": "Pucchāmi taṁ kañcanavelliviggahe,"
    },
    {
      "id": "ja535:44.4",
      "pali": "Ācikkha me tvaṁ katamāsi devatā”."
    },
    {
      "id": "ja535:45.1",
      "pali": "“Sirāha devī manujebhi pūjitā,"
    },
    {
      "id": "ja535:45.2",
      "pali": "Apāpasattūpanisevinī sadā;"
    },
    {
      "id": "ja535:45.3",
      "pali": "Sudhāvivādena tavantimāgatā,"
    },
    {
      "id": "ja535:45.4",
      "pali": "Taṁ maṁ sudhāya varapañña bhājaya."
    },
    {
      "id": "ja535:46.1",
      "pali": "Yassāhamicchāmi sudhaṁ mahāmuni,"
    },
    {
      "id": "ja535:46.2",
      "pali": "So sabbakāmehi naro pamodati;"
    },
    {
      "id": "ja535:46.3",
      "pali": "Sirīti maṁ jānahi jūhatuttama,"
    },
    {
      "id": "ja535:46.4",
      "pali": "Taṁ maṁ sudhāya varapañña bhājaya”."
    },
    {
      "id": "ja535:47.1",
      "pali": "“Sippena vijjācaraṇena buddhiyā,"
    },
    {
      "id": "ja535:47.2",
      "pali": "Narā upetā paguṇā sakammunā;"
    },
    {
      "id": "ja535:47.3",
      "pali": "Tayā vihīnā na labhanti kiñcanaṁ,"
    },
    {
      "id": "ja535:47.4",
      "pali": "Tayidaṁ na sādhu yadidaṁ tayā kataṁ."
    },
    {
      "id": "ja535:48.1",
      "pali": "Passāmi posaṁ alasaṁ mahagghasaṁ,"
    },
    {
      "id": "ja535:48.2",
      "pali": "Sudukkulīnampi arūpimaṁ naraṁ;"
    },
    {
      "id": "ja535:48.3",
      "pali": "Tayānugutto siri jātimāmapi,"
    },
    {
      "id": "ja535:48.4",
      "pali": "Peseti dāsaṁ viya bhogavā sukhī."
    },
    {
      "id": "ja535:49.1",
      "pali": "Taṁ taṁ asaccaṁ avibhajjaseviniṁ,"
    },
    {
      "id": "ja535:49.2",
      "pali": "Jānāmi mūḷhaṁ vidurānupātiniṁ;"
    },
    {
      "id": "ja535:49.3",
      "pali": "Na tādisī arahati āsanūdakaṁ,"
    },
    {
      "id": "ja535:49.4",
      "pali": "Kuto sudhā gaccha na mayha ruccasi”."
    },
    {
      "id": "ja535:50.1",
      "pali": "“Kā sukkadāṭhā paṭimukkakuṇḍalā,"
    },
    {
      "id": "ja535:50.2",
      "pali": "Cittaṅgadā kambuvimaṭṭhadhārinī;"
    },
    {
      "id": "ja535:50.3",
      "pali": "Osittavaṇṇaṁ paridayha sobhasi,"
    },
    {
      "id": "ja535:50.4",
      "pali": "Kusaggirattaṁ apiḷayha mañjariṁ."
    },
    {
      "id": "ja535:51.1",
      "pali": "Migīva bhantā saracāpadhārinā,"
    },
    {
      "id": "ja535:51.2",
      "pali": "Virādhitā mandamiva udikkhasi;"
    },
    {
      "id": "ja535:51.3",
      "pali": "Ko te dutīyo idha mandalocane,"
    },
    {
      "id": "ja535:51.4",
      "pali": "Na bhāyasi ekikā kānane vane”."
    },
    {
      "id": "ja535:52.1",
      "pali": "“Na me dutīyo idha matthi kosiya,"
    },
    {
      "id": "ja535:52.2",
      "pali": "Masakkasārappabhavamhi devatā;"
    },
    {
      "id": "ja535:52.3",
      "pali": "Āsā sudhāsāya tavantimāgatā,"
    },
    {
      "id": "ja535:52.4",
      "pali": "Taṁ maṁ sudhāya varapañña bhājaya”."
    },
    {
      "id": "ja535:53.1",
      "pali": "“Āsāya yanti vāṇijā dhanesino,"
    },
    {
      "id": "ja535:53.2",
      "pali": "Nāvaṁ samāruyha parenti aṇṇave;"
    },
    {
      "id": "ja535:53.3",
      "pali": "Te tattha sīdanti athopi ekadā,"
    },
    {
      "id": "ja535:53.4",
      "pali": "Jīnādhanā enti vinaṭṭhapābhatā."
    },
    {
      "id": "ja535:54.1",
      "pali": "Āsāya khettāni kasanti kassakā,"
    },
    {
      "id": "ja535:54.2",
      "pali": "Vapanti bījāni karontupāyaso;"
    },
    {
      "id": "ja535:54.3",
      "pali": "Ītīnipātena avuṭṭhitāya vā,"
    },
    {
      "id": "ja535:54.4",
      "pali": "Na kiñci vindanti tato phalāgamaṁ."
    },
    {
      "id": "ja535:55.1",
      "pali": "Athattakārāni karonti bhattusu,"
    },
    {
      "id": "ja535:55.2",
      "pali": "Āsaṁ purakkhatvā narā sukhesino;"
    },
    {
      "id": "ja535:55.3",
      "pali": "Te bhatturatthā atigāḷhitā puna,"
    },
    {
      "id": "ja535:55.4",
      "pali": "Disā panassanti aladdha kiñcanaṁ."
    },
    {
      "id": "ja535:56.1",
      "pali": "Hitvāna dhaññañca dhanañca ñātake,"
    },
    {
      "id": "ja535:56.2",
      "pali": "Āsāya saggādhimanā sukhesino;"
    },
    {
      "id": "ja535:56.3",
      "pali": "Tapanti lūkhampi tapaṁ cirantaraṁ,"
    },
    {
      "id": "ja535:56.4",
      "pali": "Kumaggamāruyha parenti duggatiṁ."
    },
    {
      "id": "ja535:57.1",
      "pali": "Āsā visaṁvādikasammatā ime,"
    },
    {
      "id": "ja535:57.2",
      "pali": "Āse sudhāsaṁ vinayassu attani;"
    },
    {
      "id": "ja535:57.3",
      "pali": "Na tādisī arahati āsanūdakaṁ,"
    },
    {
      "id": "ja535:57.4",
      "pali": "Kuto sudhā gaccha na mayha ruccasi”."
    },
    {
      "id": "ja535:58.1",
      "pali": "“Daddallamānā yasasā yasassinī,"
    },
    {
      "id": "ja535:58.2",
      "pali": "Jighaññanāmavhayanaṁ disaṁ pati;"
    },
    {
      "id": "ja535:58.3",
      "pali": "Pucchāmi taṁ kañcanavelliviggahe,"
    },
    {
      "id": "ja535:58.4",
      "pali": "Ācikkha me tvaṁ katamāsi devatā”."
    },
    {
      "id": "ja535:59.1",
      "pali": "“Saddhāha devī manujehi pūjitā,"
    },
    {
      "id": "ja535:59.2",
      "pali": "Apāpasattūpanisevinī sadā;"
    },
    {
      "id": "ja535:59.3",
      "pali": "Sudhāvivādena tavantimāgatā,"
    },
    {
      "id": "ja535:59.4",
      "pali": "Taṁ maṁ sudhāya varapañña bhājaya”."
    },
    {
      "id": "ja535:60.1",
      "pali": "“Dānaṁ damaṁ cāgamathopi saṁyamaṁ,"
    },
    {
      "id": "ja535:60.2",
      "pali": "Ādāya saddhāya karonti hekadā;"
    },
    {
      "id": "ja535:60.3",
      "pali": "Theyyaṁ musā kūṭamathopi pesuṇaṁ,"
    },
    {
      "id": "ja535:60.4",
      "pali": "Karonti heke puna viccutā tayā."
    },
    {
      "id": "ja535:61.1",
      "pali": "Bhariyāsu poso sadisīsu pekkhavā,"
    },
    {
      "id": "ja535:61.2",
      "pali": "Sīlūpapannāsu patibbatāsupi;"
    },
    {
      "id": "ja535:61.3",
      "pali": "Vinetvāna chandaṁ kulitthiyāsupi,"
    },
    {
      "id": "ja535:61.4",
      "pali": "Karoti saddhaṁ puna kumbhadāsiyā."
    },
    {
      "id": "ja535:62.1",
      "pali": "Tvameva saddhe paradārasevinī,"
    },
    {
      "id": "ja535:62.2",
      "pali": "Pāpaṁ karosi kusalampi riñcasi;"
    },
    {
      "id": "ja535:62.3",
      "pali": "Na tādisī arahati āsanūdakaṁ,"
    },
    {
      "id": "ja535:62.4",
      "pali": "Kuto sudhā gaccha na mayha ruccasi”."
    },
    {
      "id": "ja535:63.1",
      "pali": "“Jighaññarattiṁ aruṇasmimūhate,"
    },
    {
      "id": "ja535:63.2",
      "pali": "Yā dissati uttamarūpavaṇṇinī;"
    },
    {
      "id": "ja535:63.3",
      "pali": "Tathūpamā maṁ paṭibhāsi devate,"
    },
    {
      "id": "ja535:63.4",
      "pali": "Ācikkha me tvaṁ katamāsi accharā."
    },
    {
      "id": "ja535:64.1",
      "pali": "Kālā nidāgheriva aggijāriva,"
    },
    {
      "id": "ja535:64.2",
      "pali": "Anileritā lohitapattamālinī;"
    },
    {
      "id": "ja535:64.3",
      "pali": "Kā tiṭṭhasi mandamigāvalokayaṁ,"
    },
    {
      "id": "ja535:64.4",
      "pali": "Bhāsesamānāva giraṁ na muñcasi”."
    },
    {
      "id": "ja535:65.1",
      "pali": "“Hirāha devī manujehi pūjitā,"
    },
    {
      "id": "ja535:65.2",
      "pali": "Apāpasattūpanisevinī sadā;"
    },
    {
      "id": "ja535:65.3",
      "pali": "Sudhāvivādena tavantimāgatā,"
    },
    {
      "id": "ja535:65.4",
      "pali": "Sāhaṁ na sakkomi sudhampi yācituṁ;"
    },
    {
      "id": "ja535:65.5",
      "pali": "Kopīnarūpā viya yācanitthiyā”."
    },
    {
      "id": "ja535:66.1",
      "pali": "“Dhammena ñāyena sugatte lacchasi,"
    },
    {
      "id": "ja535:66.2",
      "pali": "Eso hi dhammo na hi yācanā sudhā;"
    },
    {
      "id": "ja535:66.3",
      "pali": "Taṁ taṁ ayācantimahaṁ nimantaye,"
    },
    {
      "id": "ja535:66.4",
      "pali": "Sudhāya yañcicchasi tampi dammi te."
    },
    {
      "id": "ja535:67.1",
      "pali": "Sā tvaṁ mayā ajja sakamhi assame,"
    },
    {
      "id": "ja535:67.2",
      "pali": "Nimantitā kañcanavelliviggahe;"
    },
    {
      "id": "ja535:67.3",
      "pali": "Tuvañhi me sabbarasehi pūjiyā,"
    },
    {
      "id": "ja535:67.4",
      "pali": "Taṁ pūjayitvāna sudhampi asniye”."
    },
    {
      "id": "ja535:68.1",
      "pali": "Sā kosiyenānumatā jutīmatā,"
    },
    {
      "id": "ja535:68.2",
      "pali": "Addhā hiri rammaṁ pāvisi yassamaṁ;"
    },
    {
      "id": "ja535:68.3",
      "pali": "Udakavantaṁ phalamariyapūjitaṁ,"
    },
    {
      "id": "ja535:68.4",
      "pali": "Apāpasattūpanisevitaṁ sadā."
    },
    {
      "id": "ja535:69.1",
      "pali": "Rukkhaggahānā bahukettha pupphitā,"
    },
    {
      "id": "ja535:69.2",
      "pali": "Ambā piyālā panasā ca kiṁsukā;"
    },
    {
      "id": "ja535:69.3",
      "pali": "Sobhañjanā loddamathopi padmakā,"
    },
    {
      "id": "ja535:69.4",
      "pali": "Kekā ca bhaṅgā tilakā supupphitā."
    },
    {
      "id": "ja535:70.1",
      "pali": "Sālā karerī bahukettha jambuyo,"
    },
    {
      "id": "ja535:70.2",
      "pali": "Assatthanigrodhamadhukavetasā;"
    },
    {
      "id": "ja535:70.3",
      "pali": "Uddālakā pāṭali sinduvārakā,"
    },
    {
      "id": "ja535:70.4",
      "pali": "Manuññagandhā mucalindaketakā."
    },
    {
      "id": "ja535:71.1",
      "pali": "Hareṇukā veḷukā keṇu tindukā,"
    },
    {
      "id": "ja535:71.2",
      "pali": "Sāmākanīvāramathopi cīnakā;"
    },
    {
      "id": "ja535:71.3",
      "pali": "Mocā kadalī bahukettha sāliyo,"
    },
    {
      "id": "ja535:71.4",
      "pali": "Pavīhayo ābhūjino ca taṇḍulā."
    },
    {
      "id": "ja535:72.1",
      "pali": "Tassevuttarapassena,"
    },
    {
      "id": "ja535:72.2",
      "pali": "jātā pokkharaṇī sivā;"
    },
    {
      "id": "ja535:72.3",
      "pali": "Akakkasā apabbhārā,"
    },
    {
      "id": "ja535:72.4",
      "pali": "sādhu appaṭigandhikā."
    },
    {
      "id": "ja535:73.1",
      "pali": "Tattha macchā sanniratā,"
    },
    {
      "id": "ja535:73.2",
      "pali": "khemino bahubhojanā;"
    },
    {
      "id": "ja535:73.3",
      "pali": "Siṅgū savaṅkā saṅkulā,"
    },
    {
      "id": "ja535:73.4",
      "pali": "satavaṅkā ca rohitā;"
    },
    {
      "id": "ja535:73.5",
      "pali": "Āḷigaggarakākiṇṇā,"
    },
    {
      "id": "ja535:73.6",
      "pali": "pāṭhīnā kākamacchakā."
    },
    {
      "id": "ja535:74.1",
      "pali": "Tattha pakkhī sanniratā,"
    },
    {
      "id": "ja535:74.2",
      "pali": "khemino bahubhojanā;"
    },
    {
      "id": "ja535:74.3",
      "pali": "Haṁsā koñcā mayūrā ca,"
    },
    {
      "id": "ja535:74.4",
      "pali": "cakkavākā ca kukkuhā;"
    },
    {
      "id": "ja535:74.5",
      "pali": "Kuṇālakā bahū citrā,"
    },
    {
      "id": "ja535:74.6",
      "pali": "sikhaṇḍī jīvajīvakā."
    },
    {
      "id": "ja535:75.1",
      "pali": "Tattha pānāya māyanti,"
    },
    {
      "id": "ja535:75.2",
      "pali": "nānā migagaṇā bahū;"
    },
    {
      "id": "ja535:75.3",
      "pali": "Sīhā byagghā varāhā ca,"
    },
    {
      "id": "ja535:75.4",
      "pali": "acchakokataracchayo."
    },
    {
      "id": "ja535:76.1",
      "pali": "Palāsādā gavajā ca,"
    },
    {
      "id": "ja535:76.2",
      "pali": "mahiṁsā rohitā rurū;"
    },
    {
      "id": "ja535:76.3",
      "pali": "Eṇeyyā ca varāhā ca,"
    },
    {
      "id": "ja535:76.4",
      "pali": "gaṇino nīkasūkarā;"
    },
    {
      "id": "ja535:76.5",
      "pali": "Kadalimigā bahukettha,"
    },
    {
      "id": "ja535:76.6",
      "pali": "biḷārā sasakaṇṇikā."
    },
    {
      "id": "ja535:77.1",
      "pali": "Chamāgirī pupphavicitrasanthatā,"
    },
    {
      "id": "ja535:77.2",
      "pali": "Dijābhighuṭṭhā dijasaṅghasevitā."
    },
    {
      "id": "ja535:78.1",
      "pali": "Sā suttacā nīladumābhilambitā,"
    },
    {
      "id": "ja535:78.2",
      "pali": "Vijju mahāmegharivānupajjatha;"
    },
    {
      "id": "ja535:78.3",
      "pali": "Tassā susambandhasiraṁ kusāmayaṁ,"
    },
    {
      "id": "ja535:78.4",
      "pali": "Suciṁ sugandhaṁ ajinūpasevitaṁ;"
    },
    {
      "id": "ja535:78.5",
      "pali": "Atricca kocchaṁ hirimetadabravi,"
    },
    {
      "id": "ja535:78.6",
      "pali": "“Nisīda kalyāṇi sukhayidamāsanaṁ”."
    },
    {
      "id": "ja535:79.1",
      "pali": "Tassā tadā kocchagatāya kosiyo,"
    },
    {
      "id": "ja535:79.2",
      "pali": "Yadicchamānāya jaṭājinandharo;"
    },
    {
      "id": "ja535:79.3",
      "pali": "Navehi pattehi sayaṁ sahūdakaṁ,"
    },
    {
      "id": "ja535:79.4",
      "pali": "Sudhābhihāsī turito mahāmuni."
    },
    {
      "id": "ja535:80.1",
      "pali": "Sā taṁ paṭiggayha ubhohi pāṇibhi,"
    },
    {
      "id": "ja535:80.2",
      "pali": "Iccabravi attamanā jaṭādharaṁ;"
    },
    {
      "id": "ja535:80.3",
      "pali": "“Handāhaṁ etarahi pūjitā tayā,"
    },
    {
      "id": "ja535:80.4",
      "pali": "Gaccheyyaṁ brahme tidivaṁ jitāvinī”."
    },
    {
      "id": "ja535:81.1",
      "pali": "Sā kosiyenānumatā jutīmatā,"
    },
    {
      "id": "ja535:81.2",
      "pali": "Udīritā vaṇṇamadena mattā;"
    },
    {
      "id": "ja535:81.3",
      "pali": "Sakāse gantvāna sahassacakkhuno,"
    },
    {
      "id": "ja535:81.4",
      "pali": "“Ayaṁ sudhā vāsava dehi me jayaṁ”."
    },
    {
      "id": "ja535:82.1",
      "pali": "Tamena sakkopi tadā apūjayi,"
    },
    {
      "id": "ja535:82.2",
      "pali": "Sahindadevā surakaññamuttamaṁ;"
    },
    {
      "id": "ja535:82.3",
      "pali": "Sā pañjalī devamanussapūjitā,"
    },
    {
      "id": "ja535:82.4",
      "pali": "Navamhi kocchamhi yadā upāvisi."
    },
    {
      "id": "ja535:83.1",
      "pali": "Tameva saṁsī punadeva mātaliṁ,"
    },
    {
      "id": "ja535:83.2",
      "pali": "Sahassanetto tidasānamindo;"
    },
    {
      "id": "ja535:83.3",
      "pali": "“Gantvāna vākyaṁ mama brūhi kosiyaṁ,"
    },
    {
      "id": "ja535:83.4",
      "pali": "‘Āsāya saddhā siriyā ca kosiya;"
    },
    {
      "id": "ja535:83.5",
      "pali": "Hirī sudhaṁ kena malattha hetunā’”."
    },
    {
      "id": "ja535:84.1",
      "pali": "Taṁ suplavatthaṁ udatārayī rathaṁ,"
    },
    {
      "id": "ja535:84.2",
      "pali": "Daddallamānaṁ upakāriyasādisaṁ;"
    },
    {
      "id": "ja535:84.3",
      "pali": "Jambonadīsaṁ tapaneyyasannibhaṁ,"
    },
    {
      "id": "ja535:84.4",
      "pali": "Alaṅkataṁ kañcanacittasannibhaṁ."
    },
    {
      "id": "ja535:85.1",
      "pali": "Suvaṇṇacandettha bahū nipātitā,"
    },
    {
      "id": "ja535:85.2",
      "pali": "Hatthī gavāssā kikibyagghadīpiyo;"
    },
    {
      "id": "ja535:85.3",
      "pali": "Eṇeyyakā laṅghamayettha pakkhino,"
    },
    {
      "id": "ja535:85.4",
      "pali": "Migettha veḷuriyamayā yudhā yutā."
    },
    {
      "id": "ja535:86.1",
      "pali": "Tatthassarājaharayo ayojayuṁ,"
    },
    {
      "id": "ja535:86.2",
      "pali": "Dasasatāni susunāgasādise;"
    },
    {
      "id": "ja535:86.3",
      "pali": "Alaṅkate kañcanajāluracchade,"
    },
    {
      "id": "ja535:86.4",
      "pali": "Āveḷine saddagame asaṅgite."
    },
    {
      "id": "ja535:87.1",
      "pali": "Taṁ yānaseṭṭhaṁ abhiruyha mātali,"
    },
    {
      "id": "ja535:87.2",
      "pali": "Disā imāyo abhinādayittha;"
    },
    {
      "id": "ja535:87.3",
      "pali": "Nabhañca selañca vanappatiniñca,"
    },
    {
      "id": "ja535:87.4",
      "pali": "Sasāgaraṁ pabyathayittha mediniṁ."
    },
    {
      "id": "ja535:88.1",
      "pali": "Sa khippameva upagamma assamaṁ,"
    },
    {
      "id": "ja535:88.2",
      "pali": "Pāvāramekaṁsakato katañjalī;"
    },
    {
      "id": "ja535:88.3",
      "pali": "Bahussutaṁ vuddhaṁ vinītavantaṁ,"
    },
    {
      "id": "ja535:88.4",
      "pali": "Iccabravī mātali devabrāhmaṇaṁ."
    },
    {
      "id": "ja535:89.1",
      "pali": "“Indassa vākyaṁ nisāmehi kosiya,"
    },
    {
      "id": "ja535:89.2",
      "pali": "Dūto ahaṁ pucchati taṁ purindado;"
    },
    {
      "id": "ja535:89.3",
      "pali": "‘Āsāya saddhā siriyā ca kosiya,"
    },
    {
      "id": "ja535:89.4",
      "pali": "Hirī sudhaṁ kena malattha hetunā’”."
    },
    {
      "id": "ja535:90.1",
      "pali": "“Andhā sirī maṁ paṭibhāti mātali,"
    },
    {
      "id": "ja535:90.2",
      "pali": "Saddhā aniccā pana devasārathi;"
    },
    {
      "id": "ja535:90.3",
      "pali": "Āsā visaṁvādikasammatā hi me,"
    },
    {
      "id": "ja535:90.4",
      "pali": "Hirī ca ariyamhi guṇe patiṭṭhitā”."
    },
    {
      "id": "ja535:91.1",
      "pali": "“Kumāriyo yācimā gottarakkhitā,"
    },
    {
      "id": "ja535:91.2",
      "pali": "Jiṇṇā ca yā yā ca sabhattuitthiyo;"
    },
    {
      "id": "ja535:91.3",
      "pali": "Tā chandarāgaṁ purisesu uggataṁ,"
    },
    {
      "id": "ja535:91.4",
      "pali": "Hiriyā nivārenti sacittamattano."
    },
    {
      "id": "ja535:92.1",
      "pali": "Saṅgāmasīse sarasattisaṁyute,"
    },
    {
      "id": "ja535:92.2",
      "pali": "Parājitānaṁ patataṁ palāyinaṁ;"
    },
    {
      "id": "ja535:92.3",
      "pali": "Hiriyā nivattanti jahitva jīvitaṁ,"
    },
    {
      "id": "ja535:92.4",
      "pali": "Te sampaṭicchanti punā hirīmanā."
    },
    {
      "id": "ja535:93.1",
      "pali": "Velā yathā sāgaravegavārinī,"
    },
    {
      "id": "ja535:93.2",
      "pali": "Hirāya hi pāpajanaṁ nivārinī;"
    },
    {
      "id": "ja535:93.3",
      "pali": "Taṁ sabbaloke hirimariyapūjitaṁ,"
    },
    {
      "id": "ja535:93.4",
      "pali": "Indassa taṁ vedaya devasārathi”."
    },
    {
      "id": "ja535:94.1",
      "pali": "“Ko te imaṁ kosiya diṭṭhimodahi,"
    },
    {
      "id": "ja535:94.2",
      "pali": "Brahmā mahindo atha vā pajāpati;"
    },
    {
      "id": "ja535:94.3",
      "pali": "Hirāya devesu hi seṭṭhasammatā,"
    },
    {
      "id": "ja535:94.4",
      "pali": "Dhītā mahindassa mahesi jāyatha”."
    },
    {
      "id": "ja535:95.1",
      "pali": "“Handehi dāni tidivaṁ apakkama,"
    },
    {
      "id": "ja535:95.2",
      "pali": "Rathaṁ samāruyha mamāyitaṁ imaṁ;"
    },
    {
      "id": "ja535:95.3",
      "pali": "Indo ca taṁ indasagotta kaṅkhati,"
    },
    {
      "id": "ja535:95.4",
      "pali": "Ajjeva tvaṁ indasahabyataṁ vaja”."
    },
    {
      "id": "ja535:96.1",
      "pali": "“Evaṁ visujjhanti apāpakammino,"
    },
    {
      "id": "ja535:96.2",
      "pali": "Atho suciṇṇassa phalaṁ na nassati;"
    },
    {
      "id": "ja535:96.3",
      "pali": "Ye keci maddakkhu sudhāya bhojanaṁ,"
    },
    {
      "id": "ja535:96.4",
      "pali": "Sabbeva te indasahabyataṁ gatā."
    },
    {
      "id": "ja535:97.1",
      "pali": "Hirī uppalavaṇṇāsi,"
    },
    {
      "id": "ja535:97.2",
      "pali": "kosiyo dānapati bhikkhu;"
    },
    {
      "id": "ja535:97.3",
      "pali": "Anuruddho pañcasikho,"
    },
    {
      "id": "ja535:97.4",
      "pali": "ānando āsi mātali."
    },
    {
      "id": "ja535:98.1",
      "pali": "Sūriyo kassapo bhikkhu,"
    },
    {
      "id": "ja535:98.2",
      "pali": "moggallānosi candimā;"
    },
    {
      "id": "ja535:98.3",
      "pali": "Nārado sāriputtosi,"
    },
    {
      "id": "ja535:98.4",
      "pali": "sambuddho āsi vāsavo”ti."
    },
    {
      "id": "ja535:99.1",
      "pali": "Sudhābhojanajātakaṁ tatiyaṁ."
    }
  ]
}
