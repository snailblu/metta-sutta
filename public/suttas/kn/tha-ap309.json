{
  "uid": "tha-ap309",
  "title": "Ārāmadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap309:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap309:1.2",
      "pali": "ārāmo ropito mayā;"
    },
    {
      "id": "tha-ap309:1.3",
      "pali": "Sandacchāyesu rukkhesu,"
    },
    {
      "id": "tha-ap309:1.4",
      "pali": "upāsantesu pakkhisu."
    },
    {
      "id": "tha-ap309:2.1",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap309:2.2",
      "pali": "āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap309:2.3",
      "pali": "Ārāmaṁ abhināmesiṁ,"
    },
    {
      "id": "tha-ap309:2.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap309:3.1",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap309:3.2",
      "pali": "phalaṁ pupphamadāsahaṁ;"
    },
    {
      "id": "tha-ap309:3.3",
      "pali": "Tato jātappasādova,"
    },
    {
      "id": "tha-ap309:3.4",
      "pali": "taṁ vanaṁ pariṇāmayiṁ."
    },
    {
      "id": "tha-ap309:4.1",
      "pali": "Buddhassa yamidaṁ dāsiṁ,"
    },
    {
      "id": "tha-ap309:4.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap309:4.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap309:4.4",
      "pali": "nibbattati phalaṁ mama."
    },
    {
      "id": "tha-ap309:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap309:5.2",
      "pali": "yaṁ ārāmamadaṁ tadā;"
    },
    {
      "id": "tha-ap309:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap309:5.4",
      "pali": "ārāmassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap309:6.1",
      "pali": "Sattatiṁse ito kappe,"
    },
    {
      "id": "tha-ap309:6.2",
      "pali": "sattāsuṁ mudusītalā;"
    },
    {
      "id": "tha-ap309:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap309:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap309:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap309:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap309:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap309:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā ārāmadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap309:9.1",
      "pali": "Ārāmadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
