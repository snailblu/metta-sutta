{
  "uid": "ja17",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja17:1.1",
      "pali": "“Kāḷe vā yadi vā juṇhe,"
    },
    {
      "id": "ja17:1.2",
      "pali": "yadā vāyati māluto;"
    },
    {
      "id": "ja17:1.3",
      "pali": "Vātajāni hi sītāni,"
    },
    {
      "id": "ja17:1.4",
      "pali": "ubhotthamaparājitā”ti."
    },
    {
      "id": "ja17:2.1",
      "pali": "Mālutajātakaṁ sattamaṁ."
    }
  ]
}
