{
  "uid": "vv78",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv78:1.1",
      "pali": "“Sovaṇṇamaye pabbatasmiṁ,"
    },
    {
      "id": "vv78:1.2",
      "pali": "vimānaṁ sabbatopabhaṁ;"
    },
    {
      "id": "vv78:1.3",
      "pali": "Hemajālapaṭicchannaṁ,"
    },
    {
      "id": "vv78:1.4",
      "pali": "kiṅkiṇijālakappitaṁ."
    },
    {
      "id": "vv78:2.1",
      "pali": "Aṭṭhaṁsā sukatā thambhā,"
    },
    {
      "id": "vv78:2.2",
      "pali": "sabbe veḷuriyāmayā;"
    },
    {
      "id": "vv78:2.3",
      "pali": "Ekamekāya aṁsiyā,"
    },
    {
      "id": "vv78:2.4",
      "pali": "ratanā satta nimmitā."
    },
    {
      "id": "vv78:3.1",
      "pali": "Veḷuriyasuvaṇṇassa,"
    },
    {
      "id": "vv78:3.2",
      "pali": "phalikā rūpiyassa ca;"
    },
    {
      "id": "vv78:3.3",
      "pali": "Masāragallamuttāhi,"
    },
    {
      "id": "vv78:3.4",
      "pali": "lohitaṅgamaṇīhi ca."
    },
    {
      "id": "vv78:4.1",
      "pali": "Citrā manoramā bhūmi,"
    },
    {
      "id": "vv78:4.2",
      "pali": "na tatthuddhaṁsatī rajo;"
    },
    {
      "id": "vv78:4.3",
      "pali": "Gopānasīgaṇā pītā,"
    },
    {
      "id": "vv78:4.4",
      "pali": "kūṭaṁ dhārenti nimmitā."
    },
    {
      "id": "vv78:5.1",
      "pali": "Sopānāni ca cattāri,"
    },
    {
      "id": "vv78:5.2",
      "pali": "nimmitā caturo disā;"
    },
    {
      "id": "vv78:5.3",
      "pali": "Nānāratanagabbhehi,"
    },
    {
      "id": "vv78:5.4",
      "pali": "ādiccova virocati."
    },
    {
      "id": "vv78:6.1",
      "pali": "Vediyā catasso tattha,"
    },
    {
      "id": "vv78:6.2",
      "pali": "vibhattā bhāgaso mitā;"
    },
    {
      "id": "vv78:6.3",
      "pali": "Daddallamānā ābhanti,"
    },
    {
      "id": "vv78:6.4",
      "pali": "samantā caturo disā."
    },
    {
      "id": "vv78:7.1",
      "pali": "Tasmiṁ vimāne pavare,"
    },
    {
      "id": "vv78:7.2",
      "pali": "devaputto mahappabho;"
    },
    {
      "id": "vv78:7.3",
      "pali": "Atirocasi vaṇṇena,"
    },
    {
      "id": "vv78:7.4",
      "pali": "udayantova bhāṇumā."
    },
    {
      "id": "vv78:8.1",
      "pali": "Dānassa te idaṁ phalaṁ,"
    },
    {
      "id": "vv78:8.2",
      "pali": "atho sīlassa vā pana;"
    },
    {
      "id": "vv78:8.3",
      "pali": "Atho añjalikammassa,"
    },
    {
      "id": "vv78:8.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "vv78:9.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv78:9.2",
      "pali": "…pe…"
    },
    {
      "id": "vv78:9.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv78:10.1",
      "pali": "“Ahaṁ andhakavindasmiṁ,"
    },
    {
      "id": "vv78:10.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "vv78:10.3",
      "pali": "Vihāraṁ satthu kāresiṁ,"
    },
    {
      "id": "vv78:10.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "vv78:11.1",
      "pali": "Tattha gandhañca mālañca,"
    },
    {
      "id": "vv78:11.2",
      "pali": "paccayañca vilepanaṁ;"
    },
    {
      "id": "vv78:11.3",
      "pali": "Vihāraṁ satthu adāsiṁ,"
    },
    {
      "id": "vv78:11.4",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "vv78:11.5",
      "pali": "Tena mayhaṁ idaṁ laddhaṁ,"
    },
    {
      "id": "vv78:11.6",
      "pali": "vasaṁ vattemi nandane."
    },
    {
      "id": "vv78:12.1",
      "pali": "Nandane ca vane ramme,"
    },
    {
      "id": "vv78:12.2",
      "pali": "nānādijagaṇāyute;"
    },
    {
      "id": "vv78:12.3",
      "pali": "Ramāmi naccagītehi,"
    },
    {
      "id": "vv78:12.4",
      "pali": "accharāhi purakkhato”ti."
    },
    {
      "id": "vv78:13.1",
      "pali": "Suvaṇṇavimānaṁ catutthaṁ."
    }
  ]
}
