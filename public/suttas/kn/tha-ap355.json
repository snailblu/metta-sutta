{
  "uid": "tha-ap355",
  "title": "Kiṁsukapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap355:1.1",
      "pali": "“Kiṁsukaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap355:1.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap355:1.3",
      "pali": "Buddhaṁ saritvā siddhatthaṁ,"
    },
    {
      "id": "tha-ap355:1.4",
      "pali": "ākāse abhipūjayiṁ."
    },
    {
      "id": "tha-ap355:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap355:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap355:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap355:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap355:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap355:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap355:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap355:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā kiṁsukapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap355:5.1",
      "pali": "Kiṁsukapūjakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
