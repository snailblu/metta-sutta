{
  "uid": "thig6.5",
  "title": "Anopamātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.5:1.1",
      "pali": "“Ucce kule ahaṁ jātā,"
    },
    {
      "id": "thig6.5:1.2",
      "pali": "bahuvitte mahaddhane;"
    },
    {
      "id": "thig6.5:1.3",
      "pali": "Vaṇṇarūpena sampannā,"
    },
    {
      "id": "thig6.5:1.4",
      "pali": "dhītā majjhassa atrajā."
    },
    {
      "id": "thig6.5:2.1",
      "pali": "Patthitā rājaputtehi,"
    },
    {
      "id": "thig6.5:2.2",
      "pali": "seṭṭhiputtehi gijjhitā;"
    },
    {
      "id": "thig6.5:2.3",
      "pali": "Pitu me pesayī dūtaṁ,"
    },
    {
      "id": "thig6.5:2.4",
      "pali": "detha mayhaṁ anopamaṁ."
    },
    {
      "id": "thig6.5:3.1",
      "pali": "Yattakaṁ tulitā esā,"
    },
    {
      "id": "thig6.5:3.2",
      "pali": "tuyhaṁ dhītā anopamā;"
    },
    {
      "id": "thig6.5:3.3",
      "pali": "Tato aṭṭhaguṇaṁ dassaṁ,"
    },
    {
      "id": "thig6.5:3.4",
      "pali": "hiraññaṁ ratanāni ca."
    },
    {
      "id": "thig6.5:4.1",
      "pali": "Sāhaṁ disvāna sambuddhaṁ,"
    },
    {
      "id": "thig6.5:4.2",
      "pali": "lokajeṭṭhaṁ anuttaraṁ;"
    },
    {
      "id": "thig6.5:4.3",
      "pali": "Tassa pādāni vanditvā,"
    },
    {
      "id": "thig6.5:4.4",
      "pali": "ekamantaṁ upāvisiṁ."
    },
    {
      "id": "thig6.5:5.1",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thig6.5:5.2",
      "pali": "anukampāya gotamo;"
    },
    {
      "id": "thig6.5:5.3",
      "pali": "Nisinnā āsane tasmiṁ,"
    },
    {
      "id": "thig6.5:5.4",
      "pali": "phusayiṁ tatiyaṁ phalaṁ."
    },
    {
      "id": "thig6.5:6.1",
      "pali": "Tato kesāni chetvāna,"
    },
    {
      "id": "thig6.5:6.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thig6.5:6.3",
      "pali": "Ajja me sattamī ratti,"
    },
    {
      "id": "thig6.5:6.4",
      "pali": "yato taṇhā visositā”ti."
    },
    {
      "id": "thig6.5:7.1",
      "pali": "… Anopamā therī …."
    }
  ]
}
