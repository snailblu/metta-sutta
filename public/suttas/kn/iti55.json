{
  "uid": "iti55",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti55:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti55:2.1",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "iti55:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti55:2.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "iti55:2.4",
      "pali": "imā kho, bhikkhave, tisso esanā”ti."
    },
    {
      "id": "iti55:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti55:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti55:3.1",
      "pali": "“Kāmesanā bhavesanā,"
    },
    {
      "id": "iti55:3.2",
      "pali": "brahmacariyesanā saha;"
    },
    {
      "id": "iti55:3.3",
      "pali": "Iti saccaparāmāso,"
    },
    {
      "id": "iti55:3.4",
      "pali": "diṭṭhiṭṭhānā samussayā."
    },
    {
      "id": "iti55:4.1",
      "pali": "Sabbarāgavirattassa,"
    },
    {
      "id": "iti55:4.2",
      "pali": "taṇhakkhayavimuttino;"
    },
    {
      "id": "iti55:4.3",
      "pali": "Esanā paṭinissaṭṭhā,"
    },
    {
      "id": "iti55:4.4",
      "pali": "diṭṭhiṭṭhānā samūhatā;"
    },
    {
      "id": "iti55:4.5",
      "pali": "Esanānaṁ khayā bhikkhu,"
    },
    {
      "id": "iti55:4.6",
      "pali": "nirāso akathaṅkathī”ti."
    },
    {
      "id": "iti55:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti55:5.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
