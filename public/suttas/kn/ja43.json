{
  "uid": "ja43",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja43:1.1",
      "pali": "“Yo atthakāmassa hitānukampino,"
    },
    {
      "id": "ja43:1.2",
      "pali": "Ovajjamāno na karoti sāsanaṁ;"
    },
    {
      "id": "ja43:1.3",
      "pali": "Evaṁ so nihato seti,"
    },
    {
      "id": "ja43:1.4",
      "pali": "Veḷukassa yathā pitā”ti."
    },
    {
      "id": "ja43:2.1",
      "pali": "Veḷukajātakaṁ tatiyaṁ."
    }
  ]
}
