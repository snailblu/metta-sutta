{
  "uid": "thi-ap21",
  "title": "1 Kuṇḍalakesātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap21:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap21:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap21:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap21:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap21:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap21:2.2",
      "pali": "jātā seṭṭhikule ahuṁ;"
    },
    {
      "id": "thi-ap21:2.3",
      "pali": "Nānāratanapajjote,"
    },
    {
      "id": "thi-ap21:2.4",
      "pali": "mahāsukhasamappitā."
    },
    {
      "id": "thi-ap21:3.1",
      "pali": "Upetvā taṁ mahāvīraṁ,"
    },
    {
      "id": "thi-ap21:3.2",
      "pali": "assosiṁ dhammadesanaṁ;"
    },
    {
      "id": "thi-ap21:3.3",
      "pali": "Tato jātappasādāhaṁ,"
    },
    {
      "id": "thi-ap21:3.4",
      "pali": "upesiṁ saraṇaṁ jinaṁ."
    },
    {
      "id": "thi-ap21:4.1",
      "pali": "Tadā mahākāruṇiko,"
    },
    {
      "id": "thi-ap21:4.2",
      "pali": "padumuttaranāmako;"
    },
    {
      "id": "thi-ap21:4.3",
      "pali": "Khippābhiññānamagganti,"
    },
    {
      "id": "thi-ap21:4.4",
      "pali": "ṭhapesi bhikkhuniṁ subhaṁ."
    },
    {
      "id": "thi-ap21:5.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap21:5.2",
      "pali": "dānaṁ datvā mahesino;"
    },
    {
      "id": "thi-ap21:5.3",
      "pali": "Nipacca sirasā pāde,"
    },
    {
      "id": "thi-ap21:5.4",
      "pali": "taṁ ṭhānamabhipatthayiṁ."
    },
    {
      "id": "thi-ap21:6.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "thi-ap21:6.2",
      "pali": "‘bhadde yaṁ tebhipatthitaṁ;"
    },
    {
      "id": "thi-ap21:6.3",
      "pali": "Samijjhissati taṁ sabbaṁ,"
    },
    {
      "id": "thi-ap21:6.4",
      "pali": "sukhinī hohi nibbutā."
    },
    {
      "id": "thi-ap21:7.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap21:7.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap21:7.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap21:7.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap21:8.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap21:8.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap21:8.3",
      "pali": "Bhaddākuṇḍalakesāti,"
    },
    {
      "id": "thi-ap21:8.4",
      "pali": "hessati satthu sāvikā’."
    },
    {
      "id": "thi-ap21:9.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap21:9.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap21:9.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap21:9.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap21:10.1",
      "pali": "Tato cutā yāmamagaṁ,"
    },
    {
      "id": "thi-ap21:10.2",
      "pali": "tatohaṁ tusitaṁ gatā;"
    },
    {
      "id": "thi-ap21:10.3",
      "pali": "Tato ca nimmānaratiṁ,"
    },
    {
      "id": "thi-ap21:10.4",
      "pali": "vasavattipuraṁ tato."
    },
    {
      "id": "thi-ap21:11.1",
      "pali": "Yattha yatthūpapajjāmi,"
    },
    {
      "id": "thi-ap21:11.2",
      "pali": "tassa kammassa vāhasā;"
    },
    {
      "id": "thi-ap21:11.3",
      "pali": "Tattha tattheva rājūnaṁ,"
    },
    {
      "id": "thi-ap21:11.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap21:12.1",
      "pali": "Tato cutā manussesu,"
    },
    {
      "id": "thi-ap21:12.2",
      "pali": "rājūnaṁ cakkavattinaṁ;"
    },
    {
      "id": "thi-ap21:12.3",
      "pali": "Maṇḍalīnañca rājūnaṁ,"
    },
    {
      "id": "thi-ap21:12.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap21:13.1",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "thi-ap21:13.2",
      "pali": "devesu mānusesu ca;"
    },
    {
      "id": "thi-ap21:13.3",
      "pali": "Sabbattha sukhitā hutvā,"
    },
    {
      "id": "thi-ap21:13.4",
      "pali": "nekakappesu saṁsariṁ."
    },
    {
      "id": "thi-ap21:14.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap21:14.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap21:14.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap21:14.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap21:15.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap21:15.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap21:15.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap21:15.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap21:16.1",
      "pali": "Tassa dhītā catutthāsiṁ,"
    },
    {
      "id": "thi-ap21:16.2",
      "pali": "bhikkhudāyīti vissutā;"
    },
    {
      "id": "thi-ap21:16.3",
      "pali": "Dhammaṁ sutvā jinaggassa,"
    },
    {
      "id": "thi-ap21:16.4",
      "pali": "pabbajjaṁ samarocayiṁ."
    },
    {
      "id": "thi-ap21:17.1",
      "pali": "Anujāni na no tāto,"
    },
    {
      "id": "thi-ap21:17.2",
      "pali": "agāreva tadā mayaṁ;"
    },
    {
      "id": "thi-ap21:17.3",
      "pali": "Vīsavassasahassāni,"
    },
    {
      "id": "thi-ap21:17.4",
      "pali": "vicarimha atanditā."
    },
    {
      "id": "thi-ap21:18.1",
      "pali": "Komāribrahmacariyaṁ,"
    },
    {
      "id": "thi-ap21:18.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap21:18.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap21:18.4",
      "pali": "muditā satta dhītaro."
    },
    {
      "id": "thi-ap21:19.1",
      "pali": "Samaṇī samaṇaguttā ca,"
    },
    {
      "id": "thi-ap21:19.2",
      "pali": "bhikkhunī bhikkhudāyikā;"
    },
    {
      "id": "thi-ap21:19.3",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "thi-ap21:19.4",
      "pali": "sattamī saṅghadāyikā."
    },
    {
      "id": "thi-ap21:20.1",
      "pali": "Khemā uppalavaṇṇā ca,"
    },
    {
      "id": "thi-ap21:20.2",
      "pali": "paṭācārā ahaṁ tadā;"
    },
    {
      "id": "thi-ap21:20.3",
      "pali": "Kisāgotamī dhammadinnā,"
    },
    {
      "id": "thi-ap21:20.4",
      "pali": "visākhā hoti sattamī."
    },
    {
      "id": "thi-ap21:21.1",
      "pali": "Tehi kammehi sukatehi,"
    },
    {
      "id": "thi-ap21:21.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap21:21.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap21:21.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap21:22.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap21:22.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "thi-ap21:22.3",
      "pali": "Jātā seṭṭhikule phīte,"
    },
    {
      "id": "thi-ap21:22.4",
      "pali": "yadāhaṁ yobbane ṭhitā."
    },
    {
      "id": "thi-ap21:23.1",
      "pali": "Coraṁ vadhatthaṁ nīyantaṁ,"
    },
    {
      "id": "thi-ap21:23.2",
      "pali": "disvā rattā tahiṁ ahaṁ;"
    },
    {
      "id": "thi-ap21:23.3",
      "pali": "Pitā me taṁ sahassena,"
    },
    {
      "id": "thi-ap21:23.4",
      "pali": "mocayitvā vadhā tato."
    },
    {
      "id": "thi-ap21:24.1",
      "pali": "Adāsi tassa maṁ tāto,"
    },
    {
      "id": "thi-ap21:24.2",
      "pali": "viditvāna manaṁ mama;"
    },
    {
      "id": "thi-ap21:24.3",
      "pali": "Tassāhamāsiṁ visaṭṭhā,"
    },
    {
      "id": "thi-ap21:24.4",
      "pali": "atīva dayitā hitā."
    },
    {
      "id": "thi-ap21:25.1",
      "pali": "So me bhūsanalobhena,"
    },
    {
      "id": "thi-ap21:25.2",
      "pali": "balimajjhāsayo diso;"
    },
    {
      "id": "thi-ap21:25.3",
      "pali": "Corappapātaṁ netvāna,"
    },
    {
      "id": "thi-ap21:25.4",
      "pali": "pabbataṁ cetayī vadhaṁ."
    },
    {
      "id": "thi-ap21:26.1",
      "pali": "Tadāhaṁ paṇamitvāna,"
    },
    {
      "id": "thi-ap21:26.2",
      "pali": "sattukaṁ sukatañjalī;"
    },
    {
      "id": "thi-ap21:26.3",
      "pali": "Rakkhantī attano pāṇaṁ,"
    },
    {
      "id": "thi-ap21:26.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "thi-ap21:27.1",
      "pali": "‘Idaṁ suvaṇṇakeyūraṁ,"
    },
    {
      "id": "thi-ap21:27.2",
      "pali": "muttā veḷuriyā bahū;"
    },
    {
      "id": "thi-ap21:27.3",
      "pali": "Sabbaṁ harassu bhaddante,"
    },
    {
      "id": "thi-ap21:27.4",
      "pali": "mañca dāsīti sāvaya’."
    },
    {
      "id": "thi-ap21:28.1",
      "pali": "‘Oropayassu kalyāṇī,"
    },
    {
      "id": "thi-ap21:28.2",
      "pali": "mā bāḷhaṁ paridevasi;"
    },
    {
      "id": "thi-ap21:28.3",
      "pali": "Na cāhaṁ abhijānāmi,"
    },
    {
      "id": "thi-ap21:28.4",
      "pali": "ahantvā dhanamābhataṁ’."
    },
    {
      "id": "thi-ap21:29.1",
      "pali": "‘Yato sarāmi attānaṁ,"
    },
    {
      "id": "thi-ap21:29.2",
      "pali": "yato pattosmi viññutaṁ;"
    },
    {
      "id": "thi-ap21:29.3",
      "pali": "Na cāhaṁ abhijānāmi,"
    },
    {
      "id": "thi-ap21:29.4",
      "pali": "aññaṁ piyataraṁ tayā."
    },
    {
      "id": "thi-ap21:30.1",
      "pali": "Ehi taṁ upagūhissaṁ,"
    },
    {
      "id": "thi-ap21:30.2",
      "pali": "katvāna taṁ padakkhiṇaṁ;"
    },
    {
      "id": "thi-ap21:30.3",
      "pali": "Na ca dāni puno atthi,"
    },
    {
      "id": "thi-ap21:30.4",
      "pali": "mama tuyhañca saṅgamo’."
    },
    {
      "id": "thi-ap21:31.1",
      "pali": "‘Na hi sabbesu ṭhānesu,"
    },
    {
      "id": "thi-ap21:31.2",
      "pali": "puriso hoti paṇḍito;"
    },
    {
      "id": "thi-ap21:31.3",
      "pali": "Itthīpi paṇḍitā hoti,"
    },
    {
      "id": "thi-ap21:31.4",
      "pali": "tattha tattha vicakkhaṇā."
    },
    {
      "id": "thi-ap21:32.1",
      "pali": "Na hi sabbesu ṭhānesu,"
    },
    {
      "id": "thi-ap21:32.2",
      "pali": "puriso hoti paṇḍito;"
    },
    {
      "id": "thi-ap21:32.3",
      "pali": "Itthīpi paṇḍitā hoti,"
    },
    {
      "id": "thi-ap21:32.4",
      "pali": "lahuṁ atthavicintikā’."
    },
    {
      "id": "thi-ap21:33.1",
      "pali": "Lahuñca vata khippañca,"
    },
    {
      "id": "thi-ap21:33.2",
      "pali": "nikaṭṭhe samacetayiṁ;"
    },
    {
      "id": "thi-ap21:33.3",
      "pali": "Migaṁ uṇṇā yathā evaṁ,"
    },
    {
      "id": "thi-ap21:33.4",
      "pali": "tadāhaṁ sattukaṁ vadhiṁ."
    },
    {
      "id": "thi-ap21:34.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "thi-ap21:34.2",
      "pali": "na khippamanubujjhati;"
    },
    {
      "id": "thi-ap21:34.3",
      "pali": "So haññate mandamati,"
    },
    {
      "id": "thi-ap21:34.4",
      "pali": "corova girigabbhare."
    },
    {
      "id": "thi-ap21:35.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "thi-ap21:35.2",
      "pali": "khippameva nibodhati;"
    },
    {
      "id": "thi-ap21:35.3",
      "pali": "Muccate sattusambādhā,"
    },
    {
      "id": "thi-ap21:35.4",
      "pali": "tadāhaṁ sattukā yathā."
    },
    {
      "id": "thi-ap21:36.1",
      "pali": "Tadāhaṁ pātayitvāna,"
    },
    {
      "id": "thi-ap21:36.2",
      "pali": "giriduggamhi sattukaṁ;"
    },
    {
      "id": "thi-ap21:36.3",
      "pali": "Santikaṁ setavatthānaṁ,"
    },
    {
      "id": "thi-ap21:36.4",
      "pali": "upetvā pabbajiṁ ahaṁ."
    },
    {
      "id": "thi-ap21:37.1",
      "pali": "Saṇḍāsena ca kese me,"
    },
    {
      "id": "thi-ap21:37.2",
      "pali": "luñcitvā sabbaso tadā;"
    },
    {
      "id": "thi-ap21:37.3",
      "pali": "Pabbajitvāna samayaṁ,"
    },
    {
      "id": "thi-ap21:37.4",
      "pali": "ācikkhiṁsu nirantaraṁ."
    },
    {
      "id": "thi-ap21:38.1",
      "pali": "Tato taṁ uggahetvāhaṁ,"
    },
    {
      "id": "thi-ap21:38.2",
      "pali": "nisīditvāna ekikā;"
    },
    {
      "id": "thi-ap21:38.3",
      "pali": "Samayaṁ taṁ vicintesiṁ,"
    },
    {
      "id": "thi-ap21:38.4",
      "pali": "suvāno mānusaṁ karaṁ."
    },
    {
      "id": "thi-ap21:39.1",
      "pali": "Chinnaṁ gayha samīpe me,"
    },
    {
      "id": "thi-ap21:39.2",
      "pali": "pātayitvā apakkami;"
    },
    {
      "id": "thi-ap21:39.3",
      "pali": "Disvā nimittamalabhiṁ,"
    },
    {
      "id": "thi-ap21:39.4",
      "pali": "hatthaṁ taṁ puḷavākulaṁ."
    },
    {
      "id": "thi-ap21:40.1",
      "pali": "Tato uṭṭhāya saṁviggā,"
    },
    {
      "id": "thi-ap21:40.2",
      "pali": "apucchiṁ sahadhammike;"
    },
    {
      "id": "thi-ap21:40.3",
      "pali": "Te avocuṁ ‘vijānanti,"
    },
    {
      "id": "thi-ap21:40.4",
      "pali": "taṁ atthaṁ sakyabhikkhavo’."
    },
    {
      "id": "thi-ap21:41.1",
      "pali": "Sāhaṁ tamatthaṁ pucchissaṁ,"
    },
    {
      "id": "thi-ap21:41.2",
      "pali": "upetvā buddhasāvake;"
    },
    {
      "id": "thi-ap21:41.3",
      "pali": "Te mamādāya gacchiṁsu,"
    },
    {
      "id": "thi-ap21:41.4",
      "pali": "buddhaseṭṭhassa santikaṁ."
    },
    {
      "id": "thi-ap21:42.1",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thi-ap21:42.2",
      "pali": "khandhāyatanadhātuyo;"
    },
    {
      "id": "thi-ap21:42.3",
      "pali": "Asubhāniccadukkhāti,"
    },
    {
      "id": "thi-ap21:42.4",
      "pali": "anattāti ca nāyako."
    },
    {
      "id": "thi-ap21:43.1",
      "pali": "Tassa dhammaṁ suṇitvāhaṁ,"
    },
    {
      "id": "thi-ap21:43.2",
      "pali": "dhammacakkhuṁ visodhayiṁ;"
    },
    {
      "id": "thi-ap21:43.3",
      "pali": "Tato viññātasaddhammā,"
    },
    {
      "id": "thi-ap21:43.4",
      "pali": "pabbajjaṁ upasampadaṁ."
    },
    {
      "id": "thi-ap21:44.1",
      "pali": "Āyācito tadā āha,"
    },
    {
      "id": "thi-ap21:44.2",
      "pali": "‘ehi bhadde’ti nāyako;"
    },
    {
      "id": "thi-ap21:44.3",
      "pali": "Tadāhaṁ upasampannā,"
    },
    {
      "id": "thi-ap21:44.4",
      "pali": "parittaṁ toyamaddasaṁ."
    },
    {
      "id": "thi-ap21:45.1",
      "pali": "Pādapakkhālanenāhaṁ,"
    },
    {
      "id": "thi-ap21:45.2",
      "pali": "ñatvā saudayabbayaṁ;"
    },
    {
      "id": "thi-ap21:45.3",
      "pali": "Tathā sabbepi saṅkhāre,"
    },
    {
      "id": "thi-ap21:45.4",
      "pali": "īdisaṁ cintayiṁ tadā."
    },
    {
      "id": "thi-ap21:46.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thi-ap21:46.2",
      "pali": "anupādāya sabbaso;"
    },
    {
      "id": "thi-ap21:46.3",
      "pali": "Khippābhiññānamaggaṁ me,"
    },
    {
      "id": "thi-ap21:46.4",
      "pali": "tadā paññāpayī jino."
    },
    {
      "id": "thi-ap21:47.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap21:47.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap21:47.3",
      "pali": "Paracittāni jānāmi,"
    },
    {
      "id": "thi-ap21:47.4",
      "pali": "satthusāsanakārikā."
    },
    {
      "id": "thi-ap21:48.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap21:48.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap21:48.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thi-ap21:48.4",
      "pali": "visuddhāsiṁ sunimmalā."
    },
    {
      "id": "thi-ap21:49.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thi-ap21:49.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thi-ap21:49.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thi-ap21:49.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thi-ap21:50.1",
      "pali": "Yassatthāya pabbajitā,"
    },
    {
      "id": "thi-ap21:50.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thi-ap21:50.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thi-ap21:50.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thi-ap21:51.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap21:51.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap21:51.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap21:51.4",
      "pali": "buddhaseṭṭhassa sāsane."
    },
    {
      "id": "thi-ap21:52.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap21:52.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap21:52.3",
      "pali": "Nāgīva bandhanaṁ chetvā,"
    },
    {
      "id": "thi-ap21:52.4",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap21:53.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap21:53.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "thi-ap21:53.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thi-ap21:53.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap21:54.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap21:54.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "thi-ap21:54.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thi-ap21:54.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap21:55.1",
      "pali": "Itthaṁ sudaṁ bhaddākuṇḍalakesā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap21:56.1",
      "pali": "Kuṇḍalakesātheriyāpadānaṁ paṭhamaṁ."
    }
  ]
}
