{
  "uid": "ja245",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja245:1.1",
      "pali": "“Kālo ghasati bhūtāni,"
    },
    {
      "id": "ja245:1.2",
      "pali": "sabbāneva sahattanā;"
    },
    {
      "id": "ja245:1.3",
      "pali": "Yo ca kālaghaso bhūto,"
    },
    {
      "id": "ja245:1.4",
      "pali": "sa bhūtapacaniṁ paci”."
    },
    {
      "id": "ja245:2.1",
      "pali": "“Bahūni narasīsāni,"
    },
    {
      "id": "ja245:2.2",
      "pali": "lomasāni brahāni ca;"
    },
    {
      "id": "ja245:2.3",
      "pali": "Gīvāsu paṭimukkāni,"
    },
    {
      "id": "ja245:2.4",
      "pali": "kocidevettha kaṇṇavā”ti."
    },
    {
      "id": "ja245:3.1",
      "pali": "Mūlapariyāyajātakaṁ pañcamaṁ."
    }
  ]
}
