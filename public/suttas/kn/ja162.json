{
  "uid": "ja162",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja162:1.1",
      "pali": "“Na santhavasmā paramatthi pāpiyo,"
    },
    {
      "id": "ja162:1.2",
      "pali": "Yo santhavo kāpurisena hoti;"
    },
    {
      "id": "ja162:1.3",
      "pali": "Santappito sappinā pāyasena,"
    },
    {
      "id": "ja162:1.4",
      "pali": "Kicchākataṁ paṇṇakuṭiṁ adayhi."
    },
    {
      "id": "ja162:2.1",
      "pali": "Na santhavasmā paramatthi seyyo,"
    },
    {
      "id": "ja162:2.2",
      "pali": "Yo santhavo sappurisena hoti;"
    },
    {
      "id": "ja162:2.3",
      "pali": "Sīhassa byagghassa ca dīpino ca,"
    },
    {
      "id": "ja162:2.4",
      "pali": "Sāmā mukhaṁ lehati santhavenā”ti."
    },
    {
      "id": "ja162:3.1",
      "pali": "Santhavajātakaṁ dutiyaṁ."
    }
  ]
}
