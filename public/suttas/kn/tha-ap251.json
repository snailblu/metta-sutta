{
  "uid": "tha-ap251",
  "title": "9 Bimbijāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap251:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap251:1.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap251:1.3",
      "pali": "Catusaccaṁ pakāseti,"
    },
    {
      "id": "tha-ap251:1.4",
      "pali": "dīpeti amataṁ padaṁ."
    },
    {
      "id": "tha-ap251:2.1",
      "pali": "Bimbijālakapupphāni,"
    },
    {
      "id": "tha-ap251:2.2",
      "pali": "puthu katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap251:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap251:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap251:3.1",
      "pali": "Aṭṭhasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap251:3.2",
      "pali": "caturo kiñjakesarā;"
    },
    {
      "id": "tha-ap251:3.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap251:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap251:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap251:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap251:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap251:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā bimbijāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap251:6.1",
      "pali": "Bimbijāliyattherassāpadānaṁ navamaṁ."
    }
  ]
}
