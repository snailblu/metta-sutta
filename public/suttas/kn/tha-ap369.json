{
  "uid": "tha-ap369",
  "title": "Uddālakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap369:1.1",
      "pali": "“Anomo nāma sambuddho,"
    },
    {
      "id": "tha-ap369:1.2",
      "pali": "gaṅgākūle vasī tadā;"
    },
    {
      "id": "tha-ap369:1.3",
      "pali": "Uddālakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap369:1.4",
      "pali": "pūjayiṁ aparājitaṁ."
    },
    {
      "id": "tha-ap369:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap369:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap369:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap369:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap369:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap369:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap369:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap369:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā uddālakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap369:5.1",
      "pali": "Uddālakapupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
