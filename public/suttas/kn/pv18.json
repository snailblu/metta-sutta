{
  "uid": "pv18",
  "title": "6. Kaṇhapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv18:1.1",
      "pali": "“Uṭṭhehi kaṇha kiṁ sesi,"
    },
    {
      "id": "pv18:1.2",
      "pali": "Ko attho supanena te;"
    },
    {
      "id": "pv18:1.3",
      "pali": "Yo ca tuyhaṁ sako bhātā,"
    },
    {
      "id": "pv18:1.4",
      "pali": "Hadayaṁ cakkhu ca dakkhiṇaṁ;"
    },
    {
      "id": "pv18:1.5",
      "pali": "Tassa vātā balīyanti,"
    },
    {
      "id": "pv18:1.6",
      "pali": "Sasaṁ jappati kesavā”ti."
    },
    {
      "id": "pv18:2.1",
      "pali": "“Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "pv18:2.2",
      "pali": "rohiṇeyyassa kesavo;"
    },
    {
      "id": "pv18:2.3",
      "pali": "Taramānarūpo vuṭṭhāsi,"
    },
    {
      "id": "pv18:2.4",
      "pali": "bhātusokena aṭṭito."
    },
    {
      "id": "pv18:3.1",
      "pali": "Kiṁ nu ummattarūpova,"
    },
    {
      "id": "pv18:3.2",
      "pali": "kevalaṁ dvārakaṁ imaṁ;"
    },
    {
      "id": "pv18:3.3",
      "pali": "Saso sasoti lapasi,"
    },
    {
      "id": "pv18:3.4",
      "pali": "kīdisaṁ sasamicchasi."
    },
    {
      "id": "pv18:4.1",
      "pali": "Sovaṇṇamayaṁ maṇimayaṁ,"
    },
    {
      "id": "pv18:4.2",
      "pali": "Lohamayaṁ atha rūpiyamayaṁ;"
    },
    {
      "id": "pv18:4.3",
      "pali": "Saṅkhasilāpavāḷamayaṁ,"
    },
    {
      "id": "pv18:4.4",
      "pali": "Kārayissāmi te sasaṁ."
    },
    {
      "id": "pv18:5.1",
      "pali": "Santi aññepi sasakā,"
    },
    {
      "id": "pv18:5.2",
      "pali": "araññavanagocarā;"
    },
    {
      "id": "pv18:5.3",
      "pali": "Tepi te ānayissāmi,"
    },
    {
      "id": "pv18:5.4",
      "pali": "kīdisaṁ sasamicchasī”ti."
    },
    {
      "id": "pv18:6.1",
      "pali": "“Nāhamete sase icche,"
    },
    {
      "id": "pv18:6.2",
      "pali": "ye sasā pathavissitā;"
    },
    {
      "id": "pv18:6.3",
      "pali": "Candato sasamicchāmi,"
    },
    {
      "id": "pv18:6.4",
      "pali": "taṁ me ohara kesavā”ti."
    },
    {
      "id": "pv18:7.1",
      "pali": "“So nūna madhuraṁ ñāti,"
    },
    {
      "id": "pv18:7.2",
      "pali": "jīvitaṁ vijahissasi;"
    },
    {
      "id": "pv18:7.3",
      "pali": "Apatthiyaṁ patthayasi,"
    },
    {
      "id": "pv18:7.4",
      "pali": "candato sasamicchasī”ti."
    },
    {
      "id": "pv18:8.1",
      "pali": "“Evañce kaṇha jānāsi,"
    },
    {
      "id": "pv18:8.2",
      "pali": "yathaññamanusāsasi;"
    },
    {
      "id": "pv18:8.3",
      "pali": "Kasmā pure mataṁ puttaṁ,"
    },
    {
      "id": "pv18:8.4",
      "pali": "ajjāpi manusocasi."
    },
    {
      "id": "pv18:9.1",
      "pali": "Na yaṁ labbhā manussena,"
    },
    {
      "id": "pv18:9.2",
      "pali": "amanussena vā pana;"
    },
    {
      "id": "pv18:9.3",
      "pali": "Jāto me mā mari putto,"
    },
    {
      "id": "pv18:9.4",
      "pali": "kuto labbhā alabbhiyaṁ."
    },
    {
      "id": "pv18:10.1",
      "pali": "Na mantā mūlabhesajjā,"
    },
    {
      "id": "pv18:10.2",
      "pali": "osadhehi dhanena vā;"
    },
    {
      "id": "pv18:10.3",
      "pali": "Sakkā ānayituṁ kaṇha,"
    },
    {
      "id": "pv18:10.4",
      "pali": "yaṁ petamanusocasi."
    },
    {
      "id": "pv18:11.1",
      "pali": "Mahaddhanā mahābhogā,"
    },
    {
      "id": "pv18:11.2",
      "pali": "raṭṭhavantopi khattiyā;"
    },
    {
      "id": "pv18:11.3",
      "pali": "Pahūtadhanadhaññāse,"
    },
    {
      "id": "pv18:11.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "pv18:12.1",
      "pali": "Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "pv18:12.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "pv18:12.3",
      "pali": "Ete caññe ca jātiyā,"
    },
    {
      "id": "pv18:12.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "pv18:13.1",
      "pali": "Ye mantaṁ parivattenti,"
    },
    {
      "id": "pv18:13.2",
      "pali": "chaḷaṅgaṁ brahmacintitaṁ;"
    },
    {
      "id": "pv18:13.3",
      "pali": "Ete caññe ca vijjāya,"
    },
    {
      "id": "pv18:13.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "pv18:14.1",
      "pali": "Isayo vāpi ye santā,"
    },
    {
      "id": "pv18:14.2",
      "pali": "saññatattā tapassino;"
    },
    {
      "id": "pv18:14.3",
      "pali": "Sarīraṁ tepi kālena,"
    },
    {
      "id": "pv18:14.4",
      "pali": "vijahanti tapassino."
    },
    {
      "id": "pv18:15.1",
      "pali": "Bhāvitattā arahanto,"
    },
    {
      "id": "pv18:15.2",
      "pali": "katakiccā anāsavā;"
    },
    {
      "id": "pv18:15.3",
      "pali": "Nikkhipanti imaṁ dehaṁ,"
    },
    {
      "id": "pv18:15.4",
      "pali": "puññapāpaparikkhayā”ti."
    },
    {
      "id": "pv18:16.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "pv18:16.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "pv18:16.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "pv18:16.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "pv18:17.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "pv18:17.2",
      "pali": "sokaṁ hadayanissitaṁ;"
    },
    {
      "id": "pv18:17.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "pv18:17.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "pv18:18.1",
      "pali": "Svāhaṁ abbūḷhasallosmi,"
    },
    {
      "id": "pv18:18.2",
      "pali": "sītibhūtosmi nibbuto;"
    },
    {
      "id": "pv18:18.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "pv18:18.4",
      "pali": "tava sutvāna bhātika”."
    },
    {
      "id": "pv18:19.1",
      "pali": "Evaṁ karonti sappaññā,"
    },
    {
      "id": "pv18:19.2",
      "pali": "ye honti anukampakā;"
    },
    {
      "id": "pv18:19.3",
      "pali": "Nivattayanti sokamhā,"
    },
    {
      "id": "pv18:19.4",
      "pali": "ghaṭo jeṭṭhaṁva bhātaraṁ."
    },
    {
      "id": "pv18:20.1",
      "pali": "Yassa etādisā honti,"
    },
    {
      "id": "pv18:20.2",
      "pali": "amaccā paricārakā;"
    },
    {
      "id": "pv18:20.3",
      "pali": "Subhāsitena anventi,"
    },
    {
      "id": "pv18:20.4",
      "pali": "ghaṭo jeṭṭhaṁva bhātaranti."
    },
    {
      "id": "pv18:21.1",
      "pali": "Kaṇhapetavatthu chaṭṭhaṁ."
    }
  ]
}
