{
  "uid": "tha-ap176",
  "title": "Udapānadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap176:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap176:1.2",
      "pali": "udapāno kato mayā;"
    },
    {
      "id": "tha-ap176:1.3",
      "pali": "Piṇḍapātañca datvāna,"
    },
    {
      "id": "tha-ap176:1.4",
      "pali": "niyyādesimahaṁ tadā."
    },
    {
      "id": "tha-ap176:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap176:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap176:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap176:2.4",
      "pali": "udapānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap176:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap176:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap176:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap176:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā udapānadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap176:5.1",
      "pali": "Udapānadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
