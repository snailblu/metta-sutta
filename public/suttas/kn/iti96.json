{
  "uid": "iti96",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti96:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti96:2.1",
      "pali": "“Kāmayogayutto, bhikkhave, bhavayogayutto āgāmī hoti āgantā itthattaṁ."
    },
    {
      "id": "iti96:2.2",
      "pali": "Kāmayogavisaṁyutto, bhikkhave, bhavayogayutto anāgāmī hoti anāgantā itthattaṁ."
    },
    {
      "id": "iti96:2.3",
      "pali": "Kāmayogavisaṁyutto, bhikkhave, bhavayogavisaṁyutto arahā hoti, khīṇāsavo”ti."
    },
    {
      "id": "iti96:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti96:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti96:3.1",
      "pali": "“Kāmayogena saṁyuttā,"
    },
    {
      "id": "iti96:3.2",
      "pali": "bhavayogena cūbhayaṁ;"
    },
    {
      "id": "iti96:3.3",
      "pali": "Sattā gacchanti saṁsāraṁ,"
    },
    {
      "id": "iti96:3.4",
      "pali": "jātimaraṇagāmino."
    },
    {
      "id": "iti96:4.1",
      "pali": "Ye ca kāme pahantvāna,"
    },
    {
      "id": "iti96:4.2",
      "pali": "appattā āsavakkhayaṁ;"
    },
    {
      "id": "iti96:4.3",
      "pali": "Bhavayogena saṁyuttā,"
    },
    {
      "id": "iti96:4.4",
      "pali": "anāgāmīti vuccare."
    },
    {
      "id": "iti96:5.1",
      "pali": "Ye ca kho chinnasaṁsayā,"
    },
    {
      "id": "iti96:5.2",
      "pali": "khīṇamānapunabbhavā;"
    },
    {
      "id": "iti96:5.3",
      "pali": "Te ve pāraṅgatā loke,"
    },
    {
      "id": "iti96:5.4",
      "pali": "ye pattā āsavakkhayan”ti."
    },
    {
      "id": "iti96:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti96:6.2",
      "pali": "Sattamaṁ."
    },
    {
      "id": "iti96:6.3",
      "pali": "Tatiyabhāṇavāraṁ."
    }
  ]
}
