{
  "uid": "ja461",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja461:1.1",
      "pali": "“Etha lakkhaṇa sītā ca,"
    },
    {
      "id": "ja461:1.2",
      "pali": "ubho otarathodakaṁ;"
    },
    {
      "id": "ja461:1.3",
      "pali": "Evāyaṁ bharato āha,"
    },
    {
      "id": "ja461:1.4",
      "pali": "‘rājā dasaratho mato’”."
    },
    {
      "id": "ja461:2.1",
      "pali": "“Kena rāmappabhāvena,"
    },
    {
      "id": "ja461:2.2",
      "pali": "socitabbaṁ na socasi;"
    },
    {
      "id": "ja461:2.3",
      "pali": "Pitaraṁ kālakataṁ sutvā,"
    },
    {
      "id": "ja461:2.4",
      "pali": "na taṁ pasahate dukhaṁ”."
    },
    {
      "id": "ja461:3.1",
      "pali": "“Yaṁ na sakkā nipāletuṁ,"
    },
    {
      "id": "ja461:3.2",
      "pali": "posena lapataṁ bahuṁ;"
    },
    {
      "id": "ja461:3.3",
      "pali": "Sa kissa viññū medhāvī,"
    },
    {
      "id": "ja461:3.4",
      "pali": "attānamupatāpaye."
    },
    {
      "id": "ja461:4.1",
      "pali": "Daharā ca hi vuddhā ca,"
    },
    {
      "id": "ja461:4.2",
      "pali": "ye bālā ye ca paṇḍitā;"
    },
    {
      "id": "ja461:4.3",
      "pali": "Aḍḍhā ceva daliddā ca,"
    },
    {
      "id": "ja461:4.4",
      "pali": "sabbe maccuparāyaṇā."
    },
    {
      "id": "ja461:5.1",
      "pali": "Phalānamiva pakkānaṁ,"
    },
    {
      "id": "ja461:5.2",
      "pali": "niccaṁ patanato bhayaṁ;"
    },
    {
      "id": "ja461:5.3",
      "pali": "Evaṁ jātāna maccānaṁ,"
    },
    {
      "id": "ja461:5.4",
      "pali": "nicca maraṇato bhayaṁ."
    },
    {
      "id": "ja461:6.1",
      "pali": "Sāyameke na dissanti,"
    },
    {
      "id": "ja461:6.2",
      "pali": "pāto diṭṭhā bahujjanā;"
    },
    {
      "id": "ja461:6.3",
      "pali": "Pāto eke na dissanti,"
    },
    {
      "id": "ja461:6.4",
      "pali": "sāyaṁ diṭṭhā bahujjanā."
    },
    {
      "id": "ja461:7.1",
      "pali": "Paridevayamāno ce,"
    },
    {
      "id": "ja461:7.2",
      "pali": "kiñcidatthaṁ udabbahe;"
    },
    {
      "id": "ja461:7.3",
      "pali": "Sammūḷho hiṁsamattānaṁ,"
    },
    {
      "id": "ja461:7.4",
      "pali": "kayirā taṁ vicakkhaṇo."
    },
    {
      "id": "ja461:8.1",
      "pali": "Kiso vivaṇṇo bhavati,"
    },
    {
      "id": "ja461:8.2",
      "pali": "hiṁsamattānamattano;"
    },
    {
      "id": "ja461:8.3",
      "pali": "Na tena petā pālenti,"
    },
    {
      "id": "ja461:8.4",
      "pali": "niratthā paridevanā."
    },
    {
      "id": "ja461:9.1",
      "pali": "Yathā saraṇamādittaṁ,"
    },
    {
      "id": "ja461:9.2",
      "pali": "vārinā parinibbaye;"
    },
    {
      "id": "ja461:9.3",
      "pali": "Evampi dhīro sutavā,"
    },
    {
      "id": "ja461:9.4",
      "pali": "medhāvī paṇḍito naro;"
    },
    {
      "id": "ja461:9.5",
      "pali": "Khippamuppatitaṁ sokaṁ,"
    },
    {
      "id": "ja461:9.6",
      "pali": "vāto tūlaṁva dhaṁsaye."
    },
    {
      "id": "ja461:10.1",
      "pali": "Macco ekova acceti,"
    },
    {
      "id": "ja461:10.2",
      "pali": "ekova jāyate kule;"
    },
    {
      "id": "ja461:10.3",
      "pali": "Saṁyogaparamā tveva,"
    },
    {
      "id": "ja461:10.4",
      "pali": "sambhogā sabbapāṇinaṁ."
    },
    {
      "id": "ja461:11.1",
      "pali": "Tasmā hi dhīrassa bahussutassa,"
    },
    {
      "id": "ja461:11.2",
      "pali": "Sampassato lokamimaṁ parañca;"
    },
    {
      "id": "ja461:11.3",
      "pali": "Aññāya dhammaṁ hadayaṁ manañca,"
    },
    {
      "id": "ja461:11.4",
      "pali": "Sokā mahantāpi na tāpayanti."
    },
    {
      "id": "ja461:12.1",
      "pali": "Sohaṁ dassañca bhokkhañca,"
    },
    {
      "id": "ja461:12.2",
      "pali": "bharissāmi ca ñātake;"
    },
    {
      "id": "ja461:12.3",
      "pali": "Sesañca pālayissāmi,"
    },
    {
      "id": "ja461:12.4",
      "pali": "kiccametaṁ vijānato."
    },
    {
      "id": "ja461:13.1",
      "pali": "Dasa vassasahassāni,"
    },
    {
      "id": "ja461:13.2",
      "pali": "saṭṭhi vassasatāni ca;"
    },
    {
      "id": "ja461:13.3",
      "pali": "Kambugīvo mahābāhu,"
    },
    {
      "id": "ja461:13.4",
      "pali": "rāmo rajjamakārayī”ti."
    },
    {
      "id": "ja461:14.1",
      "pali": "Dasarathajātakaṁ sattamaṁ."
    }
  ]
}
