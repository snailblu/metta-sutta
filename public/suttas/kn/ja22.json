{
  "uid": "ja22",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja22:1.1",
      "pali": "“Ye kukkurā rājakulamhi vaddhā,"
    },
    {
      "id": "ja22:1.2",
      "pali": "Koleyyakā vaṇṇabalūpapannā;"
    },
    {
      "id": "ja22:1.3",
      "pali": "Teme na vajjhā mayamasma vajjhā,"
    },
    {
      "id": "ja22:1.4",
      "pali": "Nāyaṁ saghaccā dubbalaghātikāyan”ti."
    },
    {
      "id": "ja22:2.1",
      "pali": "Kukkurajātakaṁ dutiyaṁ."
    }
  ]
}
