{
  "uid": "thag1.19",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.19:1.1",
      "pali": "“Udakañhi nayanti nettikā,"
    },
    {
      "id": "thag1.19:1.2",
      "pali": "Usukārā namayanti tejanaṁ;"
    },
    {
      "id": "thag1.19:1.3",
      "pali": "Dāruṁ namayanti tacchakā,"
    },
    {
      "id": "thag1.19:1.4",
      "pali": "Attānaṁ damayanti subbatā”ti."
    },
    {
      "id": "thag1.19:1.5",
      "pali": "… Kulo thero …."
    }
  ]
}
