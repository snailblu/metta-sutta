{
  "uid": "ja286",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja286:1.1",
      "pali": "“Mā sālūkassa pihayi,"
    },
    {
      "id": "ja286:1.2",
      "pali": "āturannāni bhuñjati;"
    },
    {
      "id": "ja286:1.3",
      "pali": "Appossukko bhusaṁ khāda,"
    },
    {
      "id": "ja286:1.4",
      "pali": "etaṁ dīghāyulakkhaṇaṁ."
    },
    {
      "id": "ja286:2.1",
      "pali": "Idāni so idhāgantvā,"
    },
    {
      "id": "ja286:2.2",
      "pali": "atithī yuttasevako;"
    },
    {
      "id": "ja286:2.3",
      "pali": "Atha dakkhasi sālūkaṁ,"
    },
    {
      "id": "ja286:2.4",
      "pali": "sayantaṁ musaluttaraṁ”."
    },
    {
      "id": "ja286:3.1",
      "pali": "Vikantaṁ sūkaraṁ disvā,"
    },
    {
      "id": "ja286:3.2",
      "pali": "sayantaṁ musaluttaraṁ;"
    },
    {
      "id": "ja286:3.3",
      "pali": "Jaraggavā vicintesuṁ,"
    },
    {
      "id": "ja286:3.4",
      "pali": "varamhākaṁ bhusāmivāti."
    },
    {
      "id": "ja286:4.1",
      "pali": "Sālūkajātakaṁ chaṭṭhaṁ."
    }
  ]
}
