{
  "uid": "thig2.3",
  "title": "Sumaṅgalamātātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.3:1.1",
      "pali": "“Sumuttikā sumuttikā,"
    },
    {
      "id": "thig2.3:1.2",
      "pali": "Sādhumuttikāmhi musalassa;"
    },
    {
      "id": "thig2.3:1.3",
      "pali": "Ahiriko me chattakaṁ vāpi,"
    },
    {
      "id": "thig2.3:1.4",
      "pali": "Ukkhalikā me deḍḍubhaṁ vāti."
    },
    {
      "id": "thig2.3:2.1",
      "pali": "Rāgañca ahaṁ dosañca,"
    },
    {
      "id": "thig2.3:2.2",
      "pali": "Cicciṭi cicciṭīti vihanāmi;"
    },
    {
      "id": "thig2.3:2.3",
      "pali": "Sā rukkhamūlamupagamma,"
    },
    {
      "id": "thig2.3:2.4",
      "pali": "Aho sukhanti sukhato jhāyāmī”ti."
    },
    {
      "id": "thig2.3:3.1",
      "pali": "… Sumaṅgalamātā therī …."
    }
  ]
}
