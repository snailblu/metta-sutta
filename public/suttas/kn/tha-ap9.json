{
  "uid": "tha-ap9",
  "title": "9 Aññāsikoṇḍaññattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap9:1.1",
      "pali": "“Padumuttarasambuddhaṁ,"
    },
    {
      "id": "tha-ap9:1.2",
      "pali": "lokajeṭṭhaṁ vināyakaṁ;"
    },
    {
      "id": "tha-ap9:1.3",
      "pali": "Buddhabhūmimanuppattaṁ,"
    },
    {
      "id": "tha-ap9:1.4",
      "pali": "paṭhamaṁ addasaṁ ahaṁ."
    },
    {
      "id": "tha-ap9:2.1",
      "pali": "Yāvatā bodhiyā mūle,"
    },
    {
      "id": "tha-ap9:2.2",
      "pali": "yakkhā sabbe samāgatā;"
    },
    {
      "id": "tha-ap9:2.3",
      "pali": "Sambuddhaṁ parivāretvā,"
    },
    {
      "id": "tha-ap9:2.4",
      "pali": "vandanti pañjalīkatā."
    },
    {
      "id": "tha-ap9:3.1",
      "pali": "Sabbe devā tuṭṭhamanā,"
    },
    {
      "id": "tha-ap9:3.2",
      "pali": "ākāse sañcaranti te;"
    },
    {
      "id": "tha-ap9:3.3",
      "pali": "Buddho ayaṁ anuppatto,"
    },
    {
      "id": "tha-ap9:3.4",
      "pali": "andhakāratamonudo."
    },
    {
      "id": "tha-ap9:4.1",
      "pali": "Tesaṁ hāsaparetānaṁ,"
    },
    {
      "id": "tha-ap9:4.2",
      "pali": "mahānādo avattatha;"
    },
    {
      "id": "tha-ap9:4.3",
      "pali": "Kilese jhāpayissāma,"
    },
    {
      "id": "tha-ap9:4.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap9:5.1",
      "pali": "Devānaṁ giramaññāya,"
    },
    {
      "id": "tha-ap9:5.2",
      "pali": "vācāsabhimudīrihaṁ;"
    },
    {
      "id": "tha-ap9:5.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap9:5.4",
      "pali": "ādibhikkhamadāsahaṁ."
    },
    {
      "id": "tha-ap9:6.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap9:6.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap9:6.3",
      "pali": "Devasaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap9:6.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap9:7.1",
      "pali": "Sattāhaṁ abhinikkhamma,"
    },
    {
      "id": "tha-ap9:7.2",
      "pali": "bodhiṁ ajjhagamaṁ ahaṁ;"
    },
    {
      "id": "tha-ap9:7.3",
      "pali": "Idaṁ me paṭhamaṁ bhattaṁ,"
    },
    {
      "id": "tha-ap9:7.4",
      "pali": "brahmacārissa yāpanaṁ."
    },
    {
      "id": "tha-ap9:8.1",
      "pali": "Tusitā hi idhāgantvā,"
    },
    {
      "id": "tha-ap9:8.2",
      "pali": "yo me bhikkhaṁ upānayi;"
    },
    {
      "id": "tha-ap9:8.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap9:8.4",
      "pali": "suṇotha mama bhāsato."
    },
    {
      "id": "tha-ap9:9.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap9:9.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap9:9.3",
      "pali": "Sabbe deve abhibhotvā,"
    },
    {
      "id": "tha-ap9:9.4",
      "pali": "tidivaṁ āvasissati."
    },
    {
      "id": "tha-ap9:10.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap9:10.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap9:10.3",
      "pali": "Sahassadhā cakkavattī,"
    },
    {
      "id": "tha-ap9:10.4",
      "pali": "tattha rajjaṁ karissati."
    },
    {
      "id": "tha-ap9:11.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap9:11.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap9:11.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap9:11.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap9:12.1",
      "pali": "Tidasā so cavitvāna,"
    },
    {
      "id": "tha-ap9:12.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap9:12.3",
      "pali": "Agārā pabbajitvāna,"
    },
    {
      "id": "tha-ap9:12.4",
      "pali": "chabbassāni vasissati."
    },
    {
      "id": "tha-ap9:13.1",
      "pali": "‘Tato sattamake vasse,"
    },
    {
      "id": "tha-ap9:13.2",
      "pali": "buddho saccaṁ kathessati;"
    },
    {
      "id": "tha-ap9:13.3",
      "pali": "Koṇḍañño nāma nāmena,"
    },
    {
      "id": "tha-ap9:13.4",
      "pali": "paṭhamaṁ sacchikāhiti’."
    },
    {
      "id": "tha-ap9:14.1",
      "pali": "Nikkhantenānupabbajiṁ,"
    },
    {
      "id": "tha-ap9:14.2",
      "pali": "padhānaṁ sukataṁ mayā;"
    },
    {
      "id": "tha-ap9:14.3",
      "pali": "Kilese jhāpanatthāya,"
    },
    {
      "id": "tha-ap9:14.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap9:15.1",
      "pali": "Abhigantvāna sabbaññū,"
    },
    {
      "id": "tha-ap9:15.2",
      "pali": "buddho loke sadevake;"
    },
    {
      "id": "tha-ap9:15.3",
      "pali": "Isināme migāraññe,"
    },
    {
      "id": "tha-ap9:15.4",
      "pali": "amatabherimāhani."
    },
    {
      "id": "tha-ap9:16.1",
      "pali": "So dāni patto amataṁ,"
    },
    {
      "id": "tha-ap9:16.2",
      "pali": "santipadamanuttaraṁ;"
    },
    {
      "id": "tha-ap9:16.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap9:16.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap9:17.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap9:17.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap9:17.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap9:17.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap9:18.1",
      "pali": "Itthaṁ sudaṁ āyasmā aññāsikoṇḍañño thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap9:19.1",
      "pali": "Aññāsikoṇḍaññattherassāpadānaṁ sattamaṁ."
    }
  ]
}
