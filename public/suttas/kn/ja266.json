{
  "uid": "ja266",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja266:1.1",
      "pali": "“Yenāsi kisiyā paṇḍu,"
    },
    {
      "id": "ja266:1.2",
      "pali": "yena bhattaṁ na ruccati;"
    },
    {
      "id": "ja266:1.3",
      "pali": "Ayaṁ so āgato bhattā,"
    },
    {
      "id": "ja266:1.4",
      "pali": "kasmā dāni palāyasi”."
    },
    {
      "id": "ja266:2.1",
      "pali": "“Sace panādikeneva,"
    },
    {
      "id": "ja266:2.2",
      "pali": "santhavo nāma jāyati;"
    },
    {
      "id": "ja266:2.3",
      "pali": "Yaso hāyati itthīnaṁ,"
    },
    {
      "id": "ja266:2.4",
      "pali": "tasmā tāta palāyahaṁ”."
    },
    {
      "id": "ja266:3.1",
      "pali": "Yasassinaṁ kule jātaṁ,"
    },
    {
      "id": "ja266:3.2",
      "pali": "āgataṁ yā na icchati;"
    },
    {
      "id": "ja266:3.3",
      "pali": "Socati cirarattāya,"
    },
    {
      "id": "ja266:3.4",
      "pali": "vātaggamiva bhaddalīti."
    },
    {
      "id": "ja266:4.1",
      "pali": "Vātaggasindhavajātakaṁ chaṭṭhaṁ."
    }
  ]
}
