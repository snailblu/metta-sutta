{
  "uid": "ja62",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja62:1.1",
      "pali": "“Yaṁ brāhmaṇo avādesi,"
    },
    {
      "id": "ja62:1.2",
      "pali": "vīṇaṁ samukhaveṭhito;"
    },
    {
      "id": "ja62:1.3",
      "pali": "Aṇḍabhūtā bhatā bhariyā,"
    },
    {
      "id": "ja62:1.4",
      "pali": "tāsu ko jātu vissase”ti."
    },
    {
      "id": "ja62:2.1",
      "pali": "Aṇḍabhūtajātakaṁ dutiyaṁ."
    }
  ]
}
