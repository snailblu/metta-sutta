{
  "uid": "tha-ap467",
  "title": "Sumanatālavaṇṭiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap467:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap467:1.2",
      "pali": "tālavaṇṭamadāsahaṁ;"
    },
    {
      "id": "tha-ap467:1.3",
      "pali": "Sumanehi paṭicchannaṁ,"
    },
    {
      "id": "tha-ap467:1.4",
      "pali": "dhārayāmi mahāyasaṁ."
    },
    {
      "id": "tha-ap467:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap467:2.2",
      "pali": "tālavaṇṭamadāsahaṁ;"
    },
    {
      "id": "tha-ap467:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap467:2.4",
      "pali": "tālavaṇṭassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap467:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap467:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap467:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap467:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap467:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap467:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap467:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap467:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap467:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap467:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumanatālavaṇṭiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap467:7.1",
      "pali": "Sumanatālavaṇṭiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
