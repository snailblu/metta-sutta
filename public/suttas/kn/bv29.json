{
  "uid": "bv29",
  "title": "29. Dhātubhājanīyakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv29:1.1",
      "pali": "Mahāgotamo jinavaro,"
    },
    {
      "id": "bv29:1.2",
      "pali": "kusināramhi nibbuto;"
    },
    {
      "id": "bv29:1.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv29:1.4",
      "pali": "tesu tesu padesato."
    },
    {
      "id": "bv29:2.1",
      "pali": "Eko ajātasattussa,"
    },
    {
      "id": "bv29:2.2",
      "pali": "eko vesāliyā pure;"
    },
    {
      "id": "bv29:2.3",
      "pali": "Eko kapilavatthusmiṁ,"
    },
    {
      "id": "bv29:2.4",
      "pali": "eko ca allakappake."
    },
    {
      "id": "bv29:3.1",
      "pali": "Eko ca rāmagāmamhi,"
    },
    {
      "id": "bv29:3.2",
      "pali": "eko ca veṭhadīpake;"
    },
    {
      "id": "bv29:3.3",
      "pali": "Eko pāveyyake malle,"
    },
    {
      "id": "bv29:3.4",
      "pali": "eko ca kosinārake."
    },
    {
      "id": "bv29:4.1",
      "pali": "Kumbhassa thūpaṁ kāresi,"
    },
    {
      "id": "bv29:4.2",
      "pali": "brāhmaṇo doṇasavhayo;"
    },
    {
      "id": "bv29:4.3",
      "pali": "Aṅgārathūpaṁ kāresuṁ,"
    },
    {
      "id": "bv29:4.4",
      "pali": "moriyā tuṭṭhamānasā."
    },
    {
      "id": "bv29:5.1",
      "pali": "Aṭṭha sārīrikā thūpā,"
    },
    {
      "id": "bv29:5.2",
      "pali": "navamo kumbhacetiyo;"
    },
    {
      "id": "bv29:5.3",
      "pali": "Aṅgārathūpo dasamo,"
    },
    {
      "id": "bv29:5.4",
      "pali": "tadāyeva patiṭṭhito."
    },
    {
      "id": "bv29:6.1",
      "pali": "Uṇhīsaṁ catasso dāṭhā,"
    },
    {
      "id": "bv29:6.2",
      "pali": "akkhakā dve ca dhātuyo;"
    },
    {
      "id": "bv29:6.3",
      "pali": "Asambhinnā imā satta,"
    },
    {
      "id": "bv29:6.4",
      "pali": "sesā bhinnāva dhātuyo."
    },
    {
      "id": "bv29:7.1",
      "pali": "Mahantā muggamattā ca,"
    },
    {
      "id": "bv29:7.2",
      "pali": "majjhimā bhinnataṇḍulā;"
    },
    {
      "id": "bv29:7.3",
      "pali": "Khuddakā sāsapamattā ca,"
    },
    {
      "id": "bv29:7.4",
      "pali": "nānāvaṇṇā ca dhātuyo."
    },
    {
      "id": "bv29:8.1",
      "pali": "Mahantā suvaṇṇavaṇṇā ca,"
    },
    {
      "id": "bv29:8.2",
      "pali": "muttavaṇṇā ca majjhimā;"
    },
    {
      "id": "bv29:8.3",
      "pali": "Khuddakā makulavaṇṇā ca,"
    },
    {
      "id": "bv29:8.4",
      "pali": "soḷasadoṇamattikā."
    },
    {
      "id": "bv29:9.1",
      "pali": "Mahantā pañca nāḷiyo,"
    },
    {
      "id": "bv29:9.2",
      "pali": "nāḷiyo pañca majjhimā;"
    },
    {
      "id": "bv29:9.3",
      "pali": "Khuddakā cha nāḷī ceva,"
    },
    {
      "id": "bv29:9.4",
      "pali": "etā sabbāpi dhātuyo."
    },
    {
      "id": "bv29:10.1",
      "pali": "Uṇhīsaṁ sīhaḷe dīpe,"
    },
    {
      "id": "bv29:10.2",
      "pali": "brahmaloke ca vāmakaṁ;"
    },
    {
      "id": "bv29:10.3",
      "pali": "Sīhaḷe dakkhiṇakkhañca,"
    },
    {
      "id": "bv29:10.4",
      "pali": "sabbāpetā patiṭṭhitā."
    },
    {
      "id": "bv29:11.1",
      "pali": "Ekā dāṭhā tidasapure,"
    },
    {
      "id": "bv29:11.2",
      "pali": "ekā nāgapure ahu;"
    },
    {
      "id": "bv29:11.3",
      "pali": "Ekā gandhāravisaye,"
    },
    {
      "id": "bv29:11.4",
      "pali": "ekā kaliṅgarājino."
    },
    {
      "id": "bv29:12.1",
      "pali": "Cattālīsasamā dantā,"
    },
    {
      "id": "bv29:12.2",
      "pali": "kesā lomā ca sabbaso;"
    },
    {
      "id": "bv29:12.3",
      "pali": "Devā hariṁsu ekekaṁ,"
    },
    {
      "id": "bv29:12.4",
      "pali": "cakkavāḷaparamparā."
    },
    {
      "id": "bv29:13.1",
      "pali": "Vajirāyaṁ bhagavato,"
    },
    {
      "id": "bv29:13.2",
      "pali": "Patto daṇḍañca cīvaraṁ;"
    },
    {
      "id": "bv29:13.3",
      "pali": "Nivāsanaṁ kulaghare,"
    },
    {
      "id": "bv29:13.4",
      "pali": "Paccattharaṇaṁ kapilavhaye."
    },
    {
      "id": "bv29:14.1",
      "pali": "Pāṭaliputtapuramhi,"
    },
    {
      "id": "bv29:14.2",
      "pali": "karaṇaṁ kāyabandhanaṁ;"
    },
    {
      "id": "bv29:14.3",
      "pali": "Campāyudakasāṭiyaṁ,"
    },
    {
      "id": "bv29:14.4",
      "pali": "uṇṇalomañca kosale."
    },
    {
      "id": "bv29:15.1",
      "pali": "Kāsāvaṁ brahmaloke ca,"
    },
    {
      "id": "bv29:15.2",
      "pali": "veṭhanaṁ tidase pure;"
    },
    {
      "id": "bv29:15.3",
      "pali": "Nisīdanaṁ avantīsu,"
    },
    {
      "id": "bv29:15.4",
      "pali": "raṭṭhe attharaṇaṁ tadā."
    },
    {
      "id": "bv29:16.1",
      "pali": "Araṇī ca mithilāyaṁ,"
    },
    {
      "id": "bv29:16.2",
      "pali": "videhe parisāvanaṁ;"
    },
    {
      "id": "bv29:16.3",
      "pali": "Vāsi sūcigharañcāpi,"
    },
    {
      "id": "bv29:16.4",
      "pali": "indapatthapure tadā."
    },
    {
      "id": "bv29:17.1",
      "pali": "Parikkhārā avasesā,"
    },
    {
      "id": "bv29:17.2",
      "pali": "janapade aparantake;"
    },
    {
      "id": "bv29:17.3",
      "pali": "Paribhuttāni muninā,"
    },
    {
      "id": "bv29:17.4",
      "pali": "akaṁsu manujā tadā."
    },
    {
      "id": "bv29:18.1",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv29:18.2",
      "pali": "Gotamassa mahesino;"
    },
    {
      "id": "bv29:18.3",
      "pali": "Pāṇīnaṁ anukampāya,"
    },
    {
      "id": "bv29:18.4",
      "pali": "Ahu porāṇikaṁ tadāti."
    }
  ]
}
