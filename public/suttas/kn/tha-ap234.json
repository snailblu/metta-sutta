{
  "uid": "tha-ap234",
  "title": "2 Bhājanapālakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap234:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap234:1.2",
      "pali": "kumbhakāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap234:1.3",
      "pali": "Bhājanaṁ anupālesiṁ,"
    },
    {
      "id": "tha-ap234:1.4",
      "pali": "bhikkhusaṅghassa tāvade."
    },
    {
      "id": "tha-ap234:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap234:2.2",
      "pali": "bhājanaṁ anupālayiṁ;"
    },
    {
      "id": "tha-ap234:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap234:2.4",
      "pali": "bhājanassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap234:3.1",
      "pali": "Tepaññāse ito kappe,"
    },
    {
      "id": "tha-ap234:3.2",
      "pali": "anantajālināmako;"
    },
    {
      "id": "tha-ap234:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap234:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap234:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap234:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap234:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap234:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhājanapālako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap234:6.1",
      "pali": "Bhājanapālakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
