{
  "uid": "tha-ap68",
  "title": "Sucintitattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap68:1.1",
      "pali": "“Giriduggacaro āsiṁ,"
    },
    {
      "id": "tha-ap68:1.2",
      "pali": "abhijātova kesarī;"
    },
    {
      "id": "tha-ap68:1.3",
      "pali": "Migasaṅghaṁ vadhitvāna,"
    },
    {
      "id": "tha-ap68:1.4",
      "pali": "jīvāmi pabbatantare."
    },
    {
      "id": "tha-ap68:2.1",
      "pali": "Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap68:2.2",
      "pali": "sabbaññū vadataṁ varo;"
    },
    {
      "id": "tha-ap68:2.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap68:2.4",
      "pali": "āgacchi pabbatuttamaṁ."
    },
    {
      "id": "tha-ap68:3.1",
      "pali": "Pasadañca migaṁ hantvā,"
    },
    {
      "id": "tha-ap68:3.2",
      "pali": "bhakkhituṁ samupāgamiṁ;"
    },
    {
      "id": "tha-ap68:3.3",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap68:3.4",
      "pali": "bhikkhamāno upāgami."
    },
    {
      "id": "tha-ap68:4.1",
      "pali": "Varamaṁsāni paggayha,"
    },
    {
      "id": "tha-ap68:4.2",
      "pali": "adāsiṁ tassa satthuno;"
    },
    {
      "id": "tha-ap68:4.3",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap68:4.4",
      "pali": "nibbāpento mamaṁ tadā."
    },
    {
      "id": "tha-ap68:5.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap68:5.2",
      "pali": "giriduggaṁ pavisiṁ ahaṁ;"
    },
    {
      "id": "tha-ap68:5.3",
      "pali": "Pītiṁ uppādayitvāna,"
    },
    {
      "id": "tha-ap68:5.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap68:6.1",
      "pali": "Etena maṁsadānena,"
    },
    {
      "id": "tha-ap68:6.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap68:6.3",
      "pali": "Pannarase kappasate,"
    },
    {
      "id": "tha-ap68:6.4",
      "pali": "devaloke ramiṁ ahaṁ."
    },
    {
      "id": "tha-ap68:7.1",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap68:7.2",
      "pali": "kusalaṁ cintitaṁ mayā;"
    },
    {
      "id": "tha-ap68:7.3",
      "pali": "Teneva maṁsadānena,"
    },
    {
      "id": "tha-ap68:7.4",
      "pali": "buddhānussaraṇena ca."
    },
    {
      "id": "tha-ap68:8.1",
      "pali": "Aṭṭhattiṁsamhi kappamhi,"
    },
    {
      "id": "tha-ap68:8.2",
      "pali": "aṭṭha dīghāyunāmakā;"
    },
    {
      "id": "tha-ap68:8.3",
      "pali": "Saṭṭhimhito kappasate,"
    },
    {
      "id": "tha-ap68:8.4",
      "pali": "duve varuṇanāmakā."
    },
    {
      "id": "tha-ap68:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap68:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap68:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap68:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā sucintito thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap68:11.1",
      "pali": "Sucintitattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
