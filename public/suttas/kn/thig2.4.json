{
  "uid": "thig2.4",
  "title": "Aḍḍhakāsitherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.4:1.1",
      "pali": "“Yāva kāsijanapado,"
    },
    {
      "id": "thig2.4:1.2",
      "pali": "suṅko me tatthako ahu;"
    },
    {
      "id": "thig2.4:1.3",
      "pali": "Taṁ katvā negamo agghaṁ,"
    },
    {
      "id": "thig2.4:1.4",
      "pali": "aḍḍhenagghaṁ ṭhapesi maṁ."
    },
    {
      "id": "thig2.4:2.1",
      "pali": "Atha nibbindahaṁ rūpe,"
    },
    {
      "id": "thig2.4:2.2",
      "pali": "nibbindañca virajjahaṁ;"
    },
    {
      "id": "thig2.4:2.3",
      "pali": "Mā puna jātisaṁsāraṁ,"
    },
    {
      "id": "thig2.4:2.4",
      "pali": "sandhāveyyaṁ punappunaṁ;"
    },
    {
      "id": "thig2.4:2.5",
      "pali": "Tisso vijjā sacchikatā,"
    },
    {
      "id": "thig2.4:2.6",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig2.4:3.1",
      "pali": "… Aḍḍhakāsi therī …."
    }
  ]
}
