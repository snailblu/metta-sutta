{
  "uid": "ja509",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja509:1.1",
      "pali": "“Cirassaṁ vata passāma,"
    },
    {
      "id": "ja509:1.2",
      "pali": "brāhmaṇaṁ devavaṇṇinaṁ;"
    },
    {
      "id": "ja509:1.3",
      "pali": "Mahājaṭaṁ khāridharaṁ,"
    },
    {
      "id": "ja509:1.4",
      "pali": "paṅkadantaṁ rajassiraṁ."
    },
    {
      "id": "ja509:2.1",
      "pali": "Cirassaṁ vata passāma,"
    },
    {
      "id": "ja509:2.2",
      "pali": "isiṁ dhammaguṇe rataṁ;"
    },
    {
      "id": "ja509:2.3",
      "pali": "Kāsāyavatthavasanaṁ,"
    },
    {
      "id": "ja509:2.4",
      "pali": "vākacīraṁ paṭicchadaṁ."
    },
    {
      "id": "ja509:3.1",
      "pali": "Āsanaṁ udakaṁ pajjaṁ,"
    },
    {
      "id": "ja509:3.2",
      "pali": "paṭigaṇhātu no bhavaṁ;"
    },
    {
      "id": "ja509:3.3",
      "pali": "Agghe bhavantaṁ pucchāma,"
    },
    {
      "id": "ja509:3.4",
      "pali": "agghaṁ kurutu no bhavaṁ”."
    },
    {
      "id": "ja509:4.1",
      "pali": "“Adhicca vede pariyesa vittaṁ,"
    },
    {
      "id": "ja509:4.2",
      "pali": "Putte gahe tāta patiṭṭhapetvā;"
    },
    {
      "id": "ja509:4.3",
      "pali": "Gandhe rase paccanubhuyya sabbaṁ,"
    },
    {
      "id": "ja509:4.4",
      "pali": "Araññaṁ sādhu muni so pasattho”."
    },
    {
      "id": "ja509:5.1",
      "pali": "“Vedā na saccā na ca vittalābho,"
    },
    {
      "id": "ja509:5.2",
      "pali": "Na puttalābhena jaraṁ vihanti;"
    },
    {
      "id": "ja509:5.3",
      "pali": "Gandhe rase muccanamāhu santo,"
    },
    {
      "id": "ja509:5.4",
      "pali": "Sakammunā hoti phalūpapatti”."
    },
    {
      "id": "ja509:6.1",
      "pali": "“Addhā hi saccaṁ vacanaṁ tavetaṁ,"
    },
    {
      "id": "ja509:6.2",
      "pali": "Sakammunā hoti phalūpapatti;"
    },
    {
      "id": "ja509:6.3",
      "pali": "Jiṇṇā ca mātāpitaro tavīme,"
    },
    {
      "id": "ja509:6.4",
      "pali": "Passeyyuṁ taṁ vassasataṁ arogaṁ”."
    },
    {
      "id": "ja509:7.1",
      "pali": "“Yassassa sakkhī maraṇena rāja,"
    },
    {
      "id": "ja509:7.2",
      "pali": "Jarāya mettī naravīraseṭṭha;"
    },
    {
      "id": "ja509:7.3",
      "pali": "Yo cāpi jaññā na marissaṁ kadāci,"
    },
    {
      "id": "ja509:7.4",
      "pali": "Passeyyuṁ taṁ vassasataṁ arogaṁ."
    },
    {
      "id": "ja509:8.1",
      "pali": "Yathāpi nāvaṁ puriso dakamhi,"
    },
    {
      "id": "ja509:8.2",
      "pali": "Ereti ce naṁ upaneti tīraṁ;"
    },
    {
      "id": "ja509:8.3",
      "pali": "Evampi byādhī satataṁ jarā ca,"
    },
    {
      "id": "ja509:8.4",
      "pali": "Upaneti maccaṁ vasamantakassa”."
    },
    {
      "id": "ja509:9.1",
      "pali": "“Paṅko ca kāmā palipo ca kāmā,"
    },
    {
      "id": "ja509:9.2",
      "pali": "Manoharā duttarā maccudheyyā;"
    },
    {
      "id": "ja509:9.3",
      "pali": "Etasmiṁ paṅke palipe byasannā,"
    },
    {
      "id": "ja509:9.4",
      "pali": "Hīnattarūpā na taranti pāraṁ."
    },
    {
      "id": "ja509:10.1",
      "pali": "Ayaṁ pure luddamakāsi kammaṁ,"
    },
    {
      "id": "ja509:10.2",
      "pali": "Svāyaṁ gahīto na hi mokkhito me;"
    },
    {
      "id": "ja509:10.3",
      "pali": "Orundhiyā naṁ parirakkhissāmi,"
    },
    {
      "id": "ja509:10.4",
      "pali": "Māyaṁ puna luddamakāsi kammaṁ”."
    },
    {
      "id": "ja509:11.1",
      "pali": "“Gavaṁva naṭṭhaṁ puriso yathā vane,"
    },
    {
      "id": "ja509:11.2",
      "pali": "Anvesatī rāja apassamāno;"
    },
    {
      "id": "ja509:11.3",
      "pali": "Evaṁ naṭṭho esukārī mamattho,"
    },
    {
      "id": "ja509:11.4",
      "pali": "Sohaṁ kathaṁ na gaveseyyaṁ rāja."
    },
    {
      "id": "ja509:12.1",
      "pali": "Hiyyoti hiyyati poso,"
    },
    {
      "id": "ja509:12.2",
      "pali": "Pareti parihāyati;"
    },
    {
      "id": "ja509:12.3",
      "pali": "Anāgataṁ netamatthīti ñatvā,"
    },
    {
      "id": "ja509:12.4",
      "pali": "Uppannachandaṁ ko panudeyya dhīro”."
    },
    {
      "id": "ja509:13.1",
      "pali": "“Passāmi vohaṁ daharaṁ kumāriṁ,"
    },
    {
      "id": "ja509:13.2",
      "pali": "Mattūpamaṁ ketakapupphanettaṁ;"
    },
    {
      "id": "ja509:13.3",
      "pali": "Abhuttabhoge paṭhame vayasmiṁ,"
    },
    {
      "id": "ja509:13.4",
      "pali": "Ādāya maccu vajate kumāriṁ."
    },
    {
      "id": "ja509:14.1",
      "pali": "Yuvā sujāto sumukho sudassano,"
    },
    {
      "id": "ja509:14.2",
      "pali": "Sāmo kusumbhaparikiṇṇamassu;"
    },
    {
      "id": "ja509:14.3",
      "pali": "Hitvāna kāme paṭikacca gehaṁ,"
    },
    {
      "id": "ja509:14.4",
      "pali": "Anujāna maṁ pabbajissāmi deva”."
    },
    {
      "id": "ja509:15.1",
      "pali": "“Sākhāhi rukkho labhate samaññaṁ,"
    },
    {
      "id": "ja509:15.2",
      "pali": "Pahīnasākhaṁ pana khāṇumāhu;"
    },
    {
      "id": "ja509:15.3",
      "pali": "Pahīnaputtassa mamajja bhoti,"
    },
    {
      "id": "ja509:15.4",
      "pali": "Vāseṭṭhi bhikkhācariyāya kālo”."
    },
    {
      "id": "ja509:16.1",
      "pali": "“Aghasmi koñcāva yathā himaccaye,"
    },
    {
      "id": "ja509:16.2",
      "pali": "Katāni jālāni padāliya haṁsā;"
    },
    {
      "id": "ja509:16.3",
      "pali": "Gacchanti puttā ca patī ca mayhaṁ,"
    },
    {
      "id": "ja509:16.4",
      "pali": "Sāhaṁ kathaṁ nānuvaje pajānaṁ”."
    },
    {
      "id": "ja509:17.1",
      "pali": "“Ete bhutvā vamitvā ca,"
    },
    {
      "id": "ja509:17.2",
      "pali": "pakkamanti vihaṅgamā;"
    },
    {
      "id": "ja509:17.3",
      "pali": "Ye ca bhutvāna vamiṁsu,"
    },
    {
      "id": "ja509:17.4",
      "pali": "te me hatthattamāgatā."
    },
    {
      "id": "ja509:18.1",
      "pali": "Avamī brāhmaṇo kāme,"
    },
    {
      "id": "ja509:18.2",
      "pali": "so tvaṁ paccāvamissasi;"
    },
    {
      "id": "ja509:18.3",
      "pali": "Vantādo puriso rāja,"
    },
    {
      "id": "ja509:18.4",
      "pali": "na so hoti pasaṁsiyo”."
    },
    {
      "id": "ja509:19.1",
      "pali": "“Paṅke ca posaṁ palipe byasannaṁ,"
    },
    {
      "id": "ja509:19.2",
      "pali": "Balī yathā dubbalamuddhareyya;"
    },
    {
      "id": "ja509:19.3",
      "pali": "Evampi maṁ tvaṁ udatāri bhoti,"
    },
    {
      "id": "ja509:19.4",
      "pali": "Pañcāli gāthāhi subhāsitāhi”."
    },
    {
      "id": "ja509:20.1",
      "pali": "Idaṁ vatvā mahārājā,"
    },
    {
      "id": "ja509:20.2",
      "pali": "esukārī disampati;"
    },
    {
      "id": "ja509:20.3",
      "pali": "Raṭṭhaṁ hitvāna pabbaji,"
    },
    {
      "id": "ja509:20.4",
      "pali": "nāgo chetvāva bandhanaṁ."
    },
    {
      "id": "ja509:21.1",
      "pali": "“Rājā ca pabbajjamarocayittha,"
    },
    {
      "id": "ja509:21.2",
      "pali": "Raṭṭhaṁ pahāya naravīraseṭṭho;"
    },
    {
      "id": "ja509:21.3",
      "pali": "Tuvampi no hohi yatheva rājā,"
    },
    {
      "id": "ja509:21.4",
      "pali": "Amhehi guttā anusāsa rajjaṁ”."
    },
    {
      "id": "ja509:22.1",
      "pali": "“Rājā ca pabbajjamarocayittha,"
    },
    {
      "id": "ja509:22.2",
      "pali": "Raṭṭhaṁ pahāya naravīraseṭṭho;"
    },
    {
      "id": "ja509:22.3",
      "pali": "Ahampi ekā carissāmi loke,"
    },
    {
      "id": "ja509:22.4",
      "pali": "Hitvāna kāmāni manoramāni."
    },
    {
      "id": "ja509:23.1",
      "pali": "Rājā ca pabbajjamarocayittha,"
    },
    {
      "id": "ja509:23.2",
      "pali": "Raṭṭhaṁ pahāya naravīraseṭṭho;"
    },
    {
      "id": "ja509:23.3",
      "pali": "Ahampi ekā carissāmi loke,"
    },
    {
      "id": "ja509:23.4",
      "pali": "Hitvāna kāmāni yathodhikāni."
    },
    {
      "id": "ja509:24.1",
      "pali": "Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "ja509:24.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "ja509:24.3",
      "pali": "Ahampi ekā carissāmi loke,"
    },
    {
      "id": "ja509:24.4",
      "pali": "Hitvāna kāmāni manoramāni."
    },
    {
      "id": "ja509:25.1",
      "pali": "Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "ja509:25.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "ja509:25.3",
      "pali": "Ahampi ekā carissāmi loke,"
    },
    {
      "id": "ja509:25.4",
      "pali": "Hitvāna kāmāni yathodhikāni."
    },
    {
      "id": "ja509:26.1",
      "pali": "Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "ja509:26.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "ja509:26.3",
      "pali": "Ahampi ekā carissāmi loke,"
    },
    {
      "id": "ja509:26.4",
      "pali": "Sītibhūtā sabbamaticca saṅgan”ti."
    },
    {
      "id": "ja509:27.1",
      "pali": "Hatthipālajātakaṁ terasamaṁ."
    }
  ]
}
