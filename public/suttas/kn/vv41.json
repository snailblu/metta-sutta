{
  "uid": "vv41",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv41:1.1",
      "pali": "“Alaṅkatā maṇikañcanācitaṁ,"
    },
    {
      "id": "vv41:1.2",
      "pali": "Sovaṇṇajālacitaṁ mahantaṁ;"
    },
    {
      "id": "vv41:1.3",
      "pali": "Abhiruyha gajavaraṁ sukappitaṁ,"
    },
    {
      "id": "vv41:1.4",
      "pali": "Idhāgamā vehāyasaṁ antalikkhe."
    },
    {
      "id": "vv41:2.1",
      "pali": "Nāgassa dantesu duvesu nimmitā,"
    },
    {
      "id": "vv41:2.2",
      "pali": "Acchodakā paduminiyo suphullā;"
    },
    {
      "id": "vv41:2.3",
      "pali": "Padumesu ca tūriyagaṇā pabhijjare,"
    },
    {
      "id": "vv41:2.4",
      "pali": "Imā ca naccanti manoharāyo."
    },
    {
      "id": "vv41:3.1",
      "pali": "Deviddhipattāsi mahānubhāve,"
    },
    {
      "id": "vv41:3.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv41:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv41:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv41:4.1",
      "pali": "“Bārāṇasiyaṁ upasaṅkamitvā,"
    },
    {
      "id": "vv41:4.2",
      "pali": "Buddhassahaṁ vatthayugaṁ adāsiṁ;"
    },
    {
      "id": "vv41:4.3",
      "pali": "Pādāni vanditvā chamā nisīdiṁ,"
    },
    {
      "id": "vv41:4.4",
      "pali": "Vittā cahaṁ añjalikaṁ akāsiṁ."
    },
    {
      "id": "vv41:5.1",
      "pali": "Buddho ca me kañcanasannibhattaco,"
    },
    {
      "id": "vv41:5.2",
      "pali": "Adesayi samudayadukkhaniccataṁ;"
    },
    {
      "id": "vv41:5.3",
      "pali": "Asaṅkhataṁ dukkhanirodhasassataṁ,"
    },
    {
      "id": "vv41:5.4",
      "pali": "Maggaṁ adesayi yato vijānisaṁ."
    },
    {
      "id": "vv41:6.1",
      "pali": "Appāyukī kālakatā tato cutā,"
    },
    {
      "id": "vv41:6.2",
      "pali": "Upapannā tidasagaṇaṁ yasassinī;"
    },
    {
      "id": "vv41:6.3",
      "pali": "Sakkassahaṁ aññatarā pajāpati,"
    },
    {
      "id": "vv41:6.4",
      "pali": "Yasuttarā nāma disāsu vissutā”ti."
    },
    {
      "id": "vv41:7.1",
      "pali": "Nāgavimānaṁ tatiyaṁ."
    }
  ]
}
