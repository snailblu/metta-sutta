{
  "uid": "tha-ap4",
  "title": "Mahāmoggallānattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap4:1.1",
      "pali": "“Anomadassī bhagavā,"
    },
    {
      "id": "tha-ap4:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap4:1.3",
      "pali": "Vihāsi himavantamhi,"
    },
    {
      "id": "tha-ap4:1.4",
      "pali": "devasaṅghapurakkhato."
    },
    {
      "id": "tha-ap4:2.1",
      "pali": "Varuṇo nāma nāmena,"
    },
    {
      "id": "tha-ap4:2.2",
      "pali": "nāgarājā ahaṁ tadā;"
    },
    {
      "id": "tha-ap4:2.3",
      "pali": "Kāmarūpī vikubbāmi,"
    },
    {
      "id": "tha-ap4:2.4",
      "pali": "mahodadhinivāsahaṁ."
    },
    {
      "id": "tha-ap4:3.1",
      "pali": "Saṅgaṇiyaṁ gaṇaṁ hitvā,"
    },
    {
      "id": "tha-ap4:3.2",
      "pali": "tūriyaṁ paṭṭhapesahaṁ;"
    },
    {
      "id": "tha-ap4:3.3",
      "pali": "Sambuddhaṁ parivāretvā,"
    },
    {
      "id": "tha-ap4:3.4",
      "pali": "vādesuṁ accharā tadā."
    },
    {
      "id": "tha-ap4:4.1",
      "pali": "Vajjamānesu tūresu,"
    },
    {
      "id": "tha-ap4:4.2",
      "pali": "devā tūrāni vajjayuṁ;"
    },
    {
      "id": "tha-ap4:4.3",
      "pali": "Ubhinnaṁ saddaṁ sutvāna,"
    },
    {
      "id": "tha-ap4:4.4",
      "pali": "buddhopi sampabujjhatha."
    },
    {
      "id": "tha-ap4:5.1",
      "pali": "Nimantetvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap4:5.2",
      "pali": "sakaṁ bhavanupāgamiṁ;"
    },
    {
      "id": "tha-ap4:5.3",
      "pali": "Āsanaṁ paññapetvāna,"
    },
    {
      "id": "tha-ap4:5.4",
      "pali": "kālamārocayiṁ ahaṁ."
    },
    {
      "id": "tha-ap4:6.1",
      "pali": "Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap4:6.2",
      "pali": "parivuto lokanāyako;"
    },
    {
      "id": "tha-ap4:6.3",
      "pali": "Obhāsento disā sabbā,"
    },
    {
      "id": "tha-ap4:6.4",
      "pali": "bhavanaṁ me upāgami."
    },
    {
      "id": "tha-ap4:7.1",
      "pali": "Upaviṭṭhaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap4:7.2",
      "pali": "Devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap4:7.3",
      "pali": "Sabhikkhusaṅghaṁ tappesiṁ,"
    },
    {
      "id": "tha-ap4:7.4",
      "pali": "Annapānenahaṁ tadā."
    },
    {
      "id": "tha-ap4:8.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap4:8.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap4:8.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap4:8.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap4:9.1",
      "pali": "Yo so saṅghaṁ apūjesi,"
    },
    {
      "id": "tha-ap4:9.2",
      "pali": "buddhañca lokanāyakaṁ;"
    },
    {
      "id": "tha-ap4:9.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap4:9.4",
      "pali": "devalokaṁ gamissati."
    },
    {
      "id": "tha-ap4:10.1",
      "pali": "Sattasattatikkhattuñca,"
    },
    {
      "id": "tha-ap4:10.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap4:10.3",
      "pali": "Pathabyā rajjaṁ aṭṭhasataṁ,"
    },
    {
      "id": "tha-ap4:10.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap4:11.1",
      "pali": "Pañcapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap4:11.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap4:11.3",
      "pali": "Bhogā asaṅkhiyā tassa,"
    },
    {
      "id": "tha-ap4:11.4",
      "pali": "uppajjissanti tāvade."
    },
    {
      "id": "tha-ap4:12.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap4:12.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap4:12.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap4:12.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap4:13.1",
      "pali": "Nirayā so cavitvāna,"
    },
    {
      "id": "tha-ap4:13.2",
      "pali": "manussataṁ gamissati;"
    },
    {
      "id": "tha-ap4:13.3",
      "pali": "Kolito nāma nāmena,"
    },
    {
      "id": "tha-ap4:13.4",
      "pali": "brahmabandhu bhavissati."
    },
    {
      "id": "tha-ap4:14.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap4:14.2",
      "pali": "kusalamūlena codito;"
    },
    {
      "id": "tha-ap4:14.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap4:14.4",
      "pali": "dutiyo hessati sāvako."
    },
    {
      "id": "tha-ap4:15.1",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "tha-ap4:15.2",
      "pali": "Iddhiyā pāramiṁ gato;"
    },
    {
      "id": "tha-ap4:15.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap4:15.4",
      "pali": "Nibbāyissatināsavo."
    },
    {
      "id": "tha-ap4:16.1",
      "pali": "Pāpamittopanissāya,"
    },
    {
      "id": "tha-ap4:16.2",
      "pali": "kāmarāgavasaṁ gato;"
    },
    {
      "id": "tha-ap4:16.3",
      "pali": "Mātaraṁ pitarañcāpi,"
    },
    {
      "id": "tha-ap4:16.4",
      "pali": "ghātayiṁ duṭṭhamānaso."
    },
    {
      "id": "tha-ap4:17.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap4:17.2",
      "pali": "nirayaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap4:17.3",
      "pali": "Pāpakammasamaṅgitā,"
    },
    {
      "id": "tha-ap4:17.4",
      "pali": "bhinnasīso marāmahaṁ."
    },
    {
      "id": "tha-ap4:18.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap4:18.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap4:18.3",
      "pali": "Idhāpi ediso mayhaṁ,"
    },
    {
      "id": "tha-ap4:18.4",
      "pali": "maraṇakāle bhavissati."
    },
    {
      "id": "tha-ap4:19.1",
      "pali": "Pavivekamanuyutto,"
    },
    {
      "id": "tha-ap4:19.2",
      "pali": "samādhibhāvanārato;"
    },
    {
      "id": "tha-ap4:19.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap4:19.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap4:20.1",
      "pali": "Dharaṇimpi sugambhīraṁ,"
    },
    {
      "id": "tha-ap4:20.2",
      "pali": "bahalaṁ duppadhaṁsiyaṁ;"
    },
    {
      "id": "tha-ap4:20.3",
      "pali": "Vāmaṅguṭṭhena khobheyyaṁ,"
    },
    {
      "id": "tha-ap4:20.4",
      "pali": "iddhiyā pāramiṁ gato."
    },
    {
      "id": "tha-ap4:21.1",
      "pali": "Asmimānaṁ na passāmi,"
    },
    {
      "id": "tha-ap4:21.2",
      "pali": "māno mayhaṁ na vijjati;"
    },
    {
      "id": "tha-ap4:21.3",
      "pali": "Sāmaṇere upādāya,"
    },
    {
      "id": "tha-ap4:21.4",
      "pali": "garucittaṁ karomahaṁ."
    },
    {
      "id": "tha-ap4:22.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap4:22.2",
      "pali": "yaṁ kammamabhinīhariṁ;"
    },
    {
      "id": "tha-ap4:22.3",
      "pali": "Tāhaṁ bhūmimanuppatto,"
    },
    {
      "id": "tha-ap4:22.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap4:23.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap4:23.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap4:23.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap4:23.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap4:24.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahāmoggallāno thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap4:25.1",
      "pali": "Mahāmoggallānattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
