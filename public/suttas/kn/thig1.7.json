{
  "uid": "thig1.7",
  "title": "Vīrātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.7:1.1",
      "pali": "“Vīrā vīrehi dhammehi,"
    },
    {
      "id": "thig1.7:1.2",
      "pali": "bhikkhunī bhāvitindriyā;"
    },
    {
      "id": "thig1.7:1.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "thig1.7:1.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "thig1.7:2.1",
      "pali": "… Vīrā therī …."
    }
  ]
}
