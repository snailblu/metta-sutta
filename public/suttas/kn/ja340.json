{
  "uid": "ja340",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja340:1.1",
      "pali": "“Adāsi dānāni pure visayha,"
    },
    {
      "id": "ja340:1.2",
      "pali": "Dadato ca te khayadhammo ahosi;"
    },
    {
      "id": "ja340:1.3",
      "pali": "Ito parañce na dadeyya dānaṁ,"
    },
    {
      "id": "ja340:1.4",
      "pali": "Tiṭṭheyyuṁ te saṁyamantassa bhogā”."
    },
    {
      "id": "ja340:2.1",
      "pali": "“Anariyamariyena sahassanetta,"
    },
    {
      "id": "ja340:2.2",
      "pali": "Suduggatenāpi akiccamāhu;"
    },
    {
      "id": "ja340:2.3",
      "pali": "Mā vo dhanaṁ taṁ ahu devarāja,"
    },
    {
      "id": "ja340:2.4",
      "pali": "Yaṁ bhogahetu vijahemu saddhaṁ."
    },
    {
      "id": "ja340:3.1",
      "pali": "Yena eko ratho yāti,"
    },
    {
      "id": "ja340:3.2",
      "pali": "yāti tenāparo ratho;"
    },
    {
      "id": "ja340:3.3",
      "pali": "Porāṇaṁ nihitaṁ vattaṁ,"
    },
    {
      "id": "ja340:3.4",
      "pali": "vattataññeva vāsava."
    },
    {
      "id": "ja340:4.1",
      "pali": "Yadi hessati dassāma,"
    },
    {
      "id": "ja340:4.2",
      "pali": "asante kiṁ dadāmase;"
    },
    {
      "id": "ja340:4.3",
      "pali": "Evaṁbhūtāpi dassāma,"
    },
    {
      "id": "ja340:4.4",
      "pali": "mā dānaṁ pamadamhase”ti."
    },
    {
      "id": "ja340:5.1",
      "pali": "Visayhajātakaṁ dasamaṁ."
    },
    {
      "id": "ja340:5.2",
      "pali": "Kokilavaggo catuttho."
    },
    {
      "id": "ja340:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja340:7.1",
      "pali": "Ativelapabhāsati jītavaro,"
    },
    {
      "id": "ja340:7.2",
      "pali": "Vanamajjha rathesabha jimhagamo;"
    },
    {
      "id": "ja340:7.3",
      "pali": "Atha jambu tiṇāsanapīṭhavaraṁ,"
    },
    {
      "id": "ja340:7.4",
      "pali": "Atha taṇḍula mora visayha dasāti."
    }
  ]
}
