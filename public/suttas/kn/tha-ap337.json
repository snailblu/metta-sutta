{
  "uid": "tha-ap337",
  "title": "5 Phusitakampiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap337:1.1",
      "pali": "“Vipassī nāma sambuddho,"
    },
    {
      "id": "tha-ap337:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap337:1.3",
      "pali": "Khīṇāsavehi sahito,"
    },
    {
      "id": "tha-ap337:1.4",
      "pali": "saṅghārāme vasī tadā."
    },
    {
      "id": "tha-ap337:2.1",
      "pali": "Ārāmadvārā nikkhamma,"
    },
    {
      "id": "tha-ap337:2.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "tha-ap337:2.3",
      "pali": "Saha satasahassehi,"
    },
    {
      "id": "tha-ap337:2.4",
      "pali": "aṭṭha khīṇāsavehi so."
    },
    {
      "id": "tha-ap337:3.1",
      "pali": "Ajinena nivatthohaṁ,"
    },
    {
      "id": "tha-ap337:3.2",
      "pali": "vākacīradharopi ca;"
    },
    {
      "id": "tha-ap337:3.3",
      "pali": "Kusumodakamādāya,"
    },
    {
      "id": "tha-ap337:3.4",
      "pali": "sambuddhaṁ upasaṅkamiṁ."
    },
    {
      "id": "tha-ap337:4.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap337:4.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap337:4.3",
      "pali": "Kusumodakamādāya,"
    },
    {
      "id": "tha-ap337:4.4",
      "pali": "buddhamabbhukkiriṁ ahaṁ."
    },
    {
      "id": "tha-ap337:5.1",
      "pali": "Tena kammena sambuddho,"
    },
    {
      "id": "tha-ap337:5.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap337:5.3",
      "pali": "Mama kammaṁ pakittetvā,"
    },
    {
      "id": "tha-ap337:5.4",
      "pali": "agamā yena patthitaṁ."
    },
    {
      "id": "tha-ap337:6.1",
      "pali": "Phusitā pañcasahassā,"
    },
    {
      "id": "tha-ap337:6.2",
      "pali": "yehi pūjesahaṁ jinaṁ;"
    },
    {
      "id": "tha-ap337:6.3",
      "pali": "Aḍḍhateyyasahassehi,"
    },
    {
      "id": "tha-ap337:6.4",
      "pali": "devarajjaṁ akārayiṁ."
    },
    {
      "id": "tha-ap337:7.1",
      "pali": "Aḍḍhateyyasahassehi,"
    },
    {
      "id": "tha-ap337:7.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap337:7.3",
      "pali": "Avasesena kammena,"
    },
    {
      "id": "tha-ap337:7.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap337:8.1",
      "pali": "Devarājā yadā homi,"
    },
    {
      "id": "tha-ap337:8.2",
      "pali": "manujādhipatī yadā;"
    },
    {
      "id": "tha-ap337:8.3",
      "pali": "Tameva nāmadheyyaṁ me,"
    },
    {
      "id": "tha-ap337:8.4",
      "pali": "phusito nāma homahaṁ."
    },
    {
      "id": "tha-ap337:9.1",
      "pali": "Devabhūtassa santassa,"
    },
    {
      "id": "tha-ap337:9.2",
      "pali": "athāpi mānusassa vā;"
    },
    {
      "id": "tha-ap337:9.3",
      "pali": "Samantā byāmato mayhaṁ,"
    },
    {
      "id": "tha-ap337:9.4",
      "pali": "phusitaṁva pavassati."
    },
    {
      "id": "tha-ap337:10.1",
      "pali": "Bhavā ugghāṭitā mayhaṁ,"
    },
    {
      "id": "tha-ap337:10.2",
      "pali": "kilesā jhāpitā mama;"
    },
    {
      "id": "tha-ap337:10.3",
      "pali": "Sabbāsavaparikkhīṇo,"
    },
    {
      "id": "tha-ap337:10.4",
      "pali": "phusitassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap337:11.1",
      "pali": "Candanasseva me kāyā,"
    },
    {
      "id": "tha-ap337:11.2",
      "pali": "tathā gandho pavāyati;"
    },
    {
      "id": "tha-ap337:11.3",
      "pali": "Sarīrato mama gandho,"
    },
    {
      "id": "tha-ap337:11.4",
      "pali": "aḍḍhakose pavāyati."
    },
    {
      "id": "tha-ap337:12.1",
      "pali": "Dibbagandhaṁ sampavantaṁ,"
    },
    {
      "id": "tha-ap337:12.2",
      "pali": "puññakammasamaṅginaṁ;"
    },
    {
      "id": "tha-ap337:12.3",
      "pali": "Gandhaṁ ghatvāna jānanti,"
    },
    {
      "id": "tha-ap337:12.4",
      "pali": "phusito āgato idha."
    },
    {
      "id": "tha-ap337:13.1",
      "pali": "Sākhāpalāsakaṭṭhāni,"
    },
    {
      "id": "tha-ap337:13.2",
      "pali": "tiṇānipi ca sabbaso;"
    },
    {
      "id": "tha-ap337:13.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap337:13.4",
      "pali": "gandho sampajjate khaṇe."
    },
    {
      "id": "tha-ap337:14.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap337:14.2",
      "pali": "candanaṁ abhipūjayiṁ;"
    },
    {
      "id": "tha-ap337:14.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap337:14.4",
      "pali": "phusitassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap337:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap337:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap337:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap337:16.1",
      "pali": "Itthaṁ sudaṁ āyasmā phusitakampiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap337:17.1",
      "pali": "Phusitakampiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
