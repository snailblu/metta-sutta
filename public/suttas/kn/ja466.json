{
  "uid": "ja466",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja466:1.1",
      "pali": "“Kasanti vapanti te janā,"
    },
    {
      "id": "ja466:1.2",
      "pali": "Manujā kammaphalūpajīvino;"
    },
    {
      "id": "ja466:1.3",
      "pali": "Nayimassa dīpakassa bhāgino,"
    },
    {
      "id": "ja466:1.4",
      "pali": "Jambudīpā idameva no varaṁ”."
    },
    {
      "id": "ja466:2.1",
      "pali": "“Tipañcarattūpagatamhi cande,"
    },
    {
      "id": "ja466:2.2",
      "pali": "Vego mahā hehiti sāgarassa;"
    },
    {
      "id": "ja466:2.3",
      "pali": "Uplavissaṁ dīpamimaṁ uḷāraṁ,"
    },
    {
      "id": "ja466:2.4",
      "pali": "Mā vo vadhī gacchatha leṇamaññaṁ”."
    },
    {
      "id": "ja466:3.1",
      "pali": "“Na jātuyaṁ sāgaravārivego,"
    },
    {
      "id": "ja466:3.2",
      "pali": "Uplavissaṁ dīpamimaṁ uḷāraṁ;"
    },
    {
      "id": "ja466:3.3",
      "pali": "Taṁ me nimittehi bahūhi diṭṭhaṁ,"
    },
    {
      "id": "ja466:3.4",
      "pali": "Mā bhetha kiṁ socatha modathavho."
    },
    {
      "id": "ja466:4.1",
      "pali": "Pahūtabhakkhaṁ bahuannapānaṁ,"
    },
    {
      "id": "ja466:4.2",
      "pali": "Pattattha āvāsamimaṁ uḷāraṁ;"
    },
    {
      "id": "ja466:4.3",
      "pali": "Na vo bhayaṁ paṭipassāmi kiñci,"
    },
    {
      "id": "ja466:4.4",
      "pali": "Āputtaputtehi pamodathavho”."
    },
    {
      "id": "ja466:5.1",
      "pali": "“Yo devoyaṁ dakkhiṇāyaṁ disāyaṁ,"
    },
    {
      "id": "ja466:5.2",
      "pali": "Khemanti pakkosati tassa saccaṁ;"
    },
    {
      "id": "ja466:5.3",
      "pali": "Na uttaro vedi bhayābhayassa,"
    },
    {
      "id": "ja466:5.4",
      "pali": "Mā bhetha kiṁ socatha modathavho”."
    },
    {
      "id": "ja466:6.1",
      "pali": "“Yathā ime vippavadanti yakkhā,"
    },
    {
      "id": "ja466:6.2",
      "pali": "Eko bhayaṁ saṁsati khemameko;"
    },
    {
      "id": "ja466:6.3",
      "pali": "Tadiṅgha mayhaṁ vacanaṁ suṇātha,"
    },
    {
      "id": "ja466:6.4",
      "pali": "Khippaṁ lahuṁ mā vinassimha sabbe."
    },
    {
      "id": "ja466:7.1",
      "pali": "Sabbe samāgamma karoma nāvaṁ,"
    },
    {
      "id": "ja466:7.2",
      "pali": "Doṇiṁ daḷhaṁ sabbayantūpapannaṁ;"
    },
    {
      "id": "ja466:7.3",
      "pali": "Sace ayaṁ dakkhiṇo saccamāha,"
    },
    {
      "id": "ja466:7.4",
      "pali": "Moghaṁ paṭikkosati uttaroyaṁ;"
    },
    {
      "id": "ja466:7.5",
      "pali": "Sā ceva no hehiti āpadatthā,"
    },
    {
      "id": "ja466:7.6",
      "pali": "Imañca dīpaṁ na pariccajema."
    },
    {
      "id": "ja466:8.1",
      "pali": "Sace ca kho uttaro saccamāha,"
    },
    {
      "id": "ja466:8.2",
      "pali": "Moghaṁ paṭikkosati dakkhiṇoyaṁ;"
    },
    {
      "id": "ja466:8.3",
      "pali": "Tameva nāvaṁ abhiruyha sabbe,"
    },
    {
      "id": "ja466:8.4",
      "pali": "Evaṁ mayaṁ sotthi taremu pāraṁ."
    },
    {
      "id": "ja466:9.1",
      "pali": "Na ve sugaṇhaṁ paṭhamena seṭṭhaṁ,"
    },
    {
      "id": "ja466:9.2",
      "pali": "Kaniṭṭhamāpāthagataṁ gahetvā;"
    },
    {
      "id": "ja466:9.3",
      "pali": "Yo cīdha tacchaṁ paviceyya gaṇhati,"
    },
    {
      "id": "ja466:9.4",
      "pali": "Sa ve naro seṭṭhamupeti ṭhānaṁ."
    },
    {
      "id": "ja466:10.1",
      "pali": "Yathāpi te sāgaravārimajjhe,"
    },
    {
      "id": "ja466:10.2",
      "pali": "Sakammunā sotthi vahiṁsu vāṇijā;"
    },
    {
      "id": "ja466:10.3",
      "pali": "Anāgatatthaṁ paṭivijjhiyāna,"
    },
    {
      "id": "ja466:10.4",
      "pali": "Appampi nācceti sa bhūripañño."
    },
    {
      "id": "ja466:11.1",
      "pali": "Bālā ca mohena rasānugiddhā,"
    },
    {
      "id": "ja466:11.2",
      "pali": "Anāgataṁ appaṭivijjhiyatthaṁ;"
    },
    {
      "id": "ja466:11.3",
      "pali": "Paccuppanne sīdanti atthajāte,"
    },
    {
      "id": "ja466:11.4",
      "pali": "Samuddamajjhe yathā te manussā."
    },
    {
      "id": "ja466:12.1",
      "pali": "Anāgataṁ paṭikayirātha kiccaṁ,"
    },
    {
      "id": "ja466:12.2",
      "pali": "‘Mā maṁ kiccaṁ kiccakāle byadhesi’;"
    },
    {
      "id": "ja466:12.3",
      "pali": "Taṁ tādisaṁ paṭikatakiccakāriṁ,"
    },
    {
      "id": "ja466:12.4",
      "pali": "Na taṁ kiccaṁ kiccakāle byadhetī”ti."
    },
    {
      "id": "ja466:13.1",
      "pali": "Samuddavāṇijajātakaṁ tatiyaṁ."
    }
  ]
}
