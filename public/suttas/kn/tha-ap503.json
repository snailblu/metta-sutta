{
  "uid": "tha-ap503",
  "title": "1 Tikaṇikārapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap503:1.1",
      "pali": "“Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap503:1.2",
      "pali": "bāttiṁsavaralakkhaṇo;"
    },
    {
      "id": "tha-ap503:1.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap503:1.4",
      "pali": "himavantamupāgamiṁ."
    },
    {
      "id": "tha-ap503:2.1",
      "pali": "Ajjhogayha himavantaṁ,"
    },
    {
      "id": "tha-ap503:2.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap503:2.3",
      "pali": "Pallaṅkamābhujitvāna,"
    },
    {
      "id": "tha-ap503:2.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap503:3.1",
      "pali": "Vijjādharo tadā āsiṁ,"
    },
    {
      "id": "tha-ap503:3.2",
      "pali": "antalikkhacaro ahaṁ;"
    },
    {
      "id": "tha-ap503:3.3",
      "pali": "Tisūlaṁ sukataṁ gayha,"
    },
    {
      "id": "tha-ap503:3.4",
      "pali": "gacchāmi ambare tadā."
    },
    {
      "id": "tha-ap503:4.1",
      "pali": "Pabbatagge yathā aggi,"
    },
    {
      "id": "tha-ap503:4.2",
      "pali": "puṇṇamāyeva candimā;"
    },
    {
      "id": "tha-ap503:4.3",
      "pali": "Vane obhāsate buddho,"
    },
    {
      "id": "tha-ap503:4.4",
      "pali": "sālarājāva phullito."
    },
    {
      "id": "tha-ap503:5.1",
      "pali": "Vanaggā nikkhamitvāna,"
    },
    {
      "id": "tha-ap503:5.2",
      "pali": "buddharaṁsībhidhāvare;"
    },
    {
      "id": "tha-ap503:5.3",
      "pali": "Naḷaggivaṇṇasaṅkāsā,"
    },
    {
      "id": "tha-ap503:5.4",
      "pali": "disvā cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap503:6.1",
      "pali": "Vicinaṁ addasaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap503:6.2",
      "pali": "kaṇikāraṁ devagandhikaṁ;"
    },
    {
      "id": "tha-ap503:6.3",
      "pali": "Tīṇi pupphāni ādāya,"
    },
    {
      "id": "tha-ap503:6.4",
      "pali": "buddhaseṭṭhamapūjayiṁ."
    },
    {
      "id": "tha-ap503:7.1",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap503:7.2",
      "pali": "tīṇi pupphāni me tadā;"
    },
    {
      "id": "tha-ap503:7.3",
      "pali": "Uddhaṁvaṇṭā adhopattā,"
    },
    {
      "id": "tha-ap503:7.4",
      "pali": "chāyaṁ kubbanti satthuno."
    },
    {
      "id": "tha-ap503:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap503:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap503:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap503:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap503:9.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap503:9.2",
      "pali": "kaṇikārīti ñāyati;"
    },
    {
      "id": "tha-ap503:9.3",
      "pali": "Saṭṭhiyojanamubbedhaṁ,"
    },
    {
      "id": "tha-ap503:9.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "tha-ap503:10.1",
      "pali": "Sahassakaṇḍaṁ satabheṇḍu,"
    },
    {
      "id": "tha-ap503:10.2",
      "pali": "dhajāluharitāmayaṁ;"
    },
    {
      "id": "tha-ap503:10.3",
      "pali": "Satasahassaniyyūhā,"
    },
    {
      "id": "tha-ap503:10.4",
      "pali": "byamhe pātubhaviṁsu me."
    },
    {
      "id": "tha-ap503:11.1",
      "pali": "Soṇṇamayā maṇimayā,"
    },
    {
      "id": "tha-ap503:11.2",
      "pali": "lohitaṅgamayāpi ca;"
    },
    {
      "id": "tha-ap503:11.3",
      "pali": "Phalikāpi ca pallaṅkā,"
    },
    {
      "id": "tha-ap503:11.4",
      "pali": "yenicchakā yadicchakā."
    },
    {
      "id": "tha-ap503:12.1",
      "pali": "Mahārahañca sayanaṁ,"
    },
    {
      "id": "tha-ap503:12.2",
      "pali": "tūlikāvikatīyutaṁ;"
    },
    {
      "id": "tha-ap503:12.3",
      "pali": "Uddhalomikaekantaṁ,"
    },
    {
      "id": "tha-ap503:12.4",
      "pali": "bibbohanasamāyutaṁ."
    },
    {
      "id": "tha-ap503:13.1",
      "pali": "Bhavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap503:13.2",
      "pali": "caranto devacārikaṁ;"
    },
    {
      "id": "tha-ap503:13.3",
      "pali": "Yadā icchāmi gamanaṁ,"
    },
    {
      "id": "tha-ap503:13.4",
      "pali": "devasaṅghapurakkhato."
    },
    {
      "id": "tha-ap503:14.1",
      "pali": "Pupphassa heṭṭhā tiṭṭhāmi,"
    },
    {
      "id": "tha-ap503:14.2",
      "pali": "uparicchadanaṁ mama;"
    },
    {
      "id": "tha-ap503:14.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap503:14.4",
      "pali": "kaṇikārehi chāditaṁ."
    },
    {
      "id": "tha-ap503:15.1",
      "pali": "Saṭṭhituriyasahassāni,"
    },
    {
      "id": "tha-ap503:15.2",
      "pali": "sāyaṁ pātamupaṭṭhahuṁ;"
    },
    {
      "id": "tha-ap503:15.3",
      "pali": "Parivārenti maṁ niccaṁ,"
    },
    {
      "id": "tha-ap503:15.4",
      "pali": "rattindivamatanditā."
    },
    {
      "id": "tha-ap503:16.1",
      "pali": "Tattha naccehi gītehi,"
    },
    {
      "id": "tha-ap503:16.2",
      "pali": "tāḷehi vāditehi ca;"
    },
    {
      "id": "tha-ap503:16.3",
      "pali": "Ramāmi khiḍḍāratiyā,"
    },
    {
      "id": "tha-ap503:16.4",
      "pali": "modāmi kāmakāmihaṁ."
    },
    {
      "id": "tha-ap503:17.1",
      "pali": "Tattha bhutvā pivitvā ca,"
    },
    {
      "id": "tha-ap503:17.2",
      "pali": "modāmi tidase tadā;"
    },
    {
      "id": "tha-ap503:17.3",
      "pali": "Nārīgaṇehi sahito,"
    },
    {
      "id": "tha-ap503:17.4",
      "pali": "modāmi byamhamuttame."
    },
    {
      "id": "tha-ap503:18.1",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap503:18.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap503:18.3",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap503:18.4",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap503:18.5",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap503:18.6",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap503:19.1",
      "pali": "Bhavābhave saṁsaranto,"
    },
    {
      "id": "tha-ap503:19.2",
      "pali": "mahābhogaṁ labhāmahaṁ;"
    },
    {
      "id": "tha-ap503:19.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap503:19.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:20.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap503:20.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap503:20.3",
      "pali": "Aññaṁ gatiṁ na jānāmi,"
    },
    {
      "id": "tha-ap503:20.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:21.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap503:21.2",
      "pali": "khattiye cāpi brāhmaṇe;"
    },
    {
      "id": "tha-ap503:21.3",
      "pali": "Nīce kule na jāyāmi,"
    },
    {
      "id": "tha-ap503:21.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:22.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap503:22.2",
      "pali": "sivikaṁ sandamānikaṁ;"
    },
    {
      "id": "tha-ap503:22.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap503:22.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:23.1",
      "pali": "Dāsīgaṇaṁ dāsagaṇaṁ,"
    },
    {
      "id": "tha-ap503:23.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap503:23.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap503:23.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:24.1",
      "pali": "Koseyyakambaliyāni,"
    },
    {
      "id": "tha-ap503:24.2",
      "pali": "khomakappāsikāni ca;"
    },
    {
      "id": "tha-ap503:24.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap503:24.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:25.1",
      "pali": "Navavatthaṁ navaphalaṁ,"
    },
    {
      "id": "tha-ap503:25.2",
      "pali": "navaggarasabhojanaṁ;"
    },
    {
      "id": "tha-ap503:25.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap503:25.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:26.1",
      "pali": "Imaṁ khāda imaṁ bhuñja,"
    },
    {
      "id": "tha-ap503:26.2",
      "pali": "imamhi sayane saya;"
    },
    {
      "id": "tha-ap503:26.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap503:26.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:27.1",
      "pali": "Sabbattha pūjito homi,"
    },
    {
      "id": "tha-ap503:27.2",
      "pali": "yaso abbhuggato mama;"
    },
    {
      "id": "tha-ap503:27.3",
      "pali": "Mahāpakkho sadā homi,"
    },
    {
      "id": "tha-ap503:27.4",
      "pali": "abhejjapariso sadā;"
    },
    {
      "id": "tha-ap503:27.5",
      "pali": "Ñātīnaṁ uttamo homi,"
    },
    {
      "id": "tha-ap503:27.6",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:28.1",
      "pali": "Sītaṁ uṇhaṁ na jānāmi,"
    },
    {
      "id": "tha-ap503:28.2",
      "pali": "pariḷāho na vijjati;"
    },
    {
      "id": "tha-ap503:28.3",
      "pali": "Atho cetasikaṁ dukkhaṁ,"
    },
    {
      "id": "tha-ap503:28.4",
      "pali": "hadaye me na vijjati."
    },
    {
      "id": "tha-ap503:29.1",
      "pali": "Suvaṇṇavaṇṇo hutvāna,"
    },
    {
      "id": "tha-ap503:29.2",
      "pali": "saṁsarāmi bhavābhave;"
    },
    {
      "id": "tha-ap503:29.3",
      "pali": "Vevaṇṇiyaṁ na jānāmi,"
    },
    {
      "id": "tha-ap503:29.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:30.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap503:30.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap503:30.3",
      "pali": "Sāvatthiyaṁ pure jāto,"
    },
    {
      "id": "tha-ap503:30.4",
      "pali": "mahāsāle suaḍḍhake."
    },
    {
      "id": "tha-ap503:31.1",
      "pali": "Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "tha-ap503:31.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap503:31.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap503:31.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap503:32.1",
      "pali": "Upasampādayī buddho,"
    },
    {
      "id": "tha-ap503:32.2",
      "pali": "guṇamaññāya cakkhumā;"
    },
    {
      "id": "tha-ap503:32.3",
      "pali": "Taruṇo pūjanīyohaṁ,"
    },
    {
      "id": "tha-ap503:32.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:33.1",
      "pali": "Dibbacakkhu visuddhaṁ me,"
    },
    {
      "id": "tha-ap503:33.2",
      "pali": "samādhikusalo ahaṁ;"
    },
    {
      "id": "tha-ap503:33.3",
      "pali": "Abhiññāpāramippatto,"
    },
    {
      "id": "tha-ap503:33.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:34.1",
      "pali": "Paṭisambhidā anuppatto,"
    },
    {
      "id": "tha-ap503:34.2",
      "pali": "iddhipādesu kovido;"
    },
    {
      "id": "tha-ap503:34.3",
      "pali": "Dhammesu pāramippatto,"
    },
    {
      "id": "tha-ap503:34.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:35.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap503:35.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap503:35.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap503:35.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap503:36.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap503:36.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap503:36.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap503:36.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap503:37.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap503:37.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap503:37.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap503:37.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap503:38.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap503:38.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap503:38.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap503:38.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap503:39.1",
      "pali": "Itthaṁ sudaṁ āyasmā tikaṇikārapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap503:40.1",
      "pali": "Tikaṇikārapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
