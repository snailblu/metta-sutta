{
  "uid": "ja449",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja449:1.1",
      "pali": "“Alaṅkato maṭṭhakuṇḍalī,"
    },
    {
      "id": "ja449:1.2",
      "pali": "Māladhārī haricandanussado;"
    },
    {
      "id": "ja449:1.3",
      "pali": "Bāhā paggayha kandasi,"
    },
    {
      "id": "ja449:1.4",
      "pali": "Vanamajjhe kiṁ dukkhito tuvaṁ”."
    },
    {
      "id": "ja449:2.1",
      "pali": "“Sovaṇṇamayo pabhassaro,"
    },
    {
      "id": "ja449:2.2",
      "pali": "Uppanno rathapañjaro mama;"
    },
    {
      "id": "ja449:2.3",
      "pali": "Tassa cakkayugaṁ na vindāmi,"
    },
    {
      "id": "ja449:2.4",
      "pali": "Tena dukkhena jahāmi jīvitaṁ”."
    },
    {
      "id": "ja449:3.1",
      "pali": "“Sovaṇṇamayaṁ maṇīmayaṁ,"
    },
    {
      "id": "ja449:3.2",
      "pali": "Lohamayaṁ atha rūpiyāmayaṁ;"
    },
    {
      "id": "ja449:3.3",
      "pali": "Pāvada rathaṁ karissāmi te,"
    },
    {
      "id": "ja449:3.4",
      "pali": "Cakkayugaṁ paṭipādayāmi taṁ”."
    },
    {
      "id": "ja449:4.1",
      "pali": "“So māṇavo tassa pāvadi,"
    },
    {
      "id": "ja449:4.2",
      "pali": "Candasūriyā ubhayettha bhātaro;"
    },
    {
      "id": "ja449:4.3",
      "pali": "Sovaṇṇamayo ratho mama,"
    },
    {
      "id": "ja449:4.4",
      "pali": "Tena cakkayugena sobhati”."
    },
    {
      "id": "ja449:5.1",
      "pali": "“Bālo kho tvaṁsi māṇava,"
    },
    {
      "id": "ja449:5.2",
      "pali": "Yo tvaṁ patthayase apatthiyaṁ;"
    },
    {
      "id": "ja449:5.3",
      "pali": "Maññāmi tuvaṁ marissasi,"
    },
    {
      "id": "ja449:5.4",
      "pali": "Na hi tvaṁ lacchasi candasūriye”."
    },
    {
      "id": "ja449:6.1",
      "pali": "“Gamanāgamanampi dissati,"
    },
    {
      "id": "ja449:6.2",
      "pali": "Vaṇṇadhātu ubhayettha vīthiyo;"
    },
    {
      "id": "ja449:6.3",
      "pali": "Peto pana neva dissati,"
    },
    {
      "id": "ja449:6.4",
      "pali": "Ko nu kho kandataṁ bālyataro”."
    },
    {
      "id": "ja449:7.1",
      "pali": "“Saccaṁ kho vadesi māṇava,"
    },
    {
      "id": "ja449:7.2",
      "pali": "Ahameva kandataṁ bālyataro;"
    },
    {
      "id": "ja449:7.3",
      "pali": "Candaṁ viya dārako rudaṁ,"
    },
    {
      "id": "ja449:7.4",
      "pali": "Petaṁ kālakatābhipatthaye."
    },
    {
      "id": "ja449:8.1",
      "pali": "Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "ja449:8.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "ja449:8.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "ja449:8.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "ja449:9.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "ja449:9.2",
      "pali": "yamāsi hadayassitaṁ;"
    },
    {
      "id": "ja449:9.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "ja449:9.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "ja449:10.1",
      "pali": "Sohaṁ abbūḷhasallosmi,"
    },
    {
      "id": "ja449:10.2",
      "pali": "vītasoko anāvilo;"
    },
    {
      "id": "ja449:10.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "ja449:10.4",
      "pali": "tava sutvāna māṇavā”ti."
    },
    {
      "id": "ja449:11.1",
      "pali": "Maṭṭhakuṇḍalījātakaṁ ekādasamaṁ."
    }
  ]
}
