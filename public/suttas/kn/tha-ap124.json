{
  "uid": "tha-ap124",
  "title": "Pupphathūpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap124:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap124:1.2",
      "pali": "kukkuro nāma pabbato;"
    },
    {
      "id": "tha-ap124:1.3",
      "pali": "Vemajjhe tassa vasati,"
    },
    {
      "id": "tha-ap124:1.4",
      "pali": "brāhmaṇo mantapāragū."
    },
    {
      "id": "tha-ap124:2.1",
      "pali": "Pañca sissasahassāni,"
    },
    {
      "id": "tha-ap124:2.2",
      "pali": "parivārenti maṁ sadā;"
    },
    {
      "id": "tha-ap124:2.3",
      "pali": "Pubbuṭṭhāyī ca te āsuṁ,"
    },
    {
      "id": "tha-ap124:2.4",
      "pali": "mantesu ca visāradā."
    },
    {
      "id": "tha-ap124:3.1",
      "pali": "Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap124:3.2",
      "pali": "taṁ vijānātha no bhavaṁ;"
    },
    {
      "id": "tha-ap124:3.3",
      "pali": "Asītibyañjanānassa,"
    },
    {
      "id": "tha-ap124:3.4",
      "pali": "bāttiṁsavaralakkhaṇā."
    },
    {
      "id": "tha-ap124:4.1",
      "pali": "Byāmappabho jinavaro,"
    },
    {
      "id": "tha-ap124:4.2",
      "pali": "ādiccova virocati;"
    },
    {
      "id": "tha-ap124:4.3",
      "pali": "Sissānaṁ vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap124:4.4",
      "pali": "brāhmaṇo mantapāragū."
    },
    {
      "id": "tha-ap124:5.1",
      "pali": "Assamā abhinikkhamma,"
    },
    {
      "id": "tha-ap124:5.2",
      "pali": "disaṁ pucchati sissake;"
    },
    {
      "id": "tha-ap124:5.3",
      "pali": "Yamhi dese mahāvīro,"
    },
    {
      "id": "tha-ap124:5.4",
      "pali": "vasati lokanāyako."
    },
    {
      "id": "tha-ap124:6.1",
      "pali": "Tāhaṁ disaṁ namassissaṁ,"
    },
    {
      "id": "tha-ap124:6.2",
      "pali": "jinaṁ appaṭipuggalaṁ;"
    },
    {
      "id": "tha-ap124:6.3",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap124:6.4",
      "pali": "pūjesiṁ taṁ tathāgataṁ."
    },
    {
      "id": "tha-ap124:7.1",
      "pali": "Etha sissā gamissāma,"
    },
    {
      "id": "tha-ap124:7.2",
      "pali": "dakkhissāma tathāgataṁ;"
    },
    {
      "id": "tha-ap124:7.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap124:7.4",
      "pali": "sossāma jinasāsanaṁ."
    },
    {
      "id": "tha-ap124:8.1",
      "pali": "Ekāhaṁ abhinikkhamma,"
    },
    {
      "id": "tha-ap124:8.2",
      "pali": "byādhiṁ paṭilabhiṁ ahaṁ;"
    },
    {
      "id": "tha-ap124:8.3",
      "pali": "Byādhinā pīḷito santo,"
    },
    {
      "id": "tha-ap124:8.4",
      "pali": "sālaṁ vāsayituṁ gamiṁ."
    },
    {
      "id": "tha-ap124:9.1",
      "pali": "Sabbe sisse samānetvā,"
    },
    {
      "id": "tha-ap124:9.2",
      "pali": "apucchiṁ te tathāgataṁ;"
    },
    {
      "id": "tha-ap124:9.3",
      "pali": "Kīdisaṁ lokanāthassa,"
    },
    {
      "id": "tha-ap124:9.4",
      "pali": "guṇaṁ paramabuddhino."
    },
    {
      "id": "tha-ap124:10.1",
      "pali": "Te me puṭṭhā viyākaṁsu,"
    },
    {
      "id": "tha-ap124:10.2",
      "pali": "Yathā dassāvino tathā;"
    },
    {
      "id": "tha-ap124:10.3",
      "pali": "Sakkaccaṁ buddhaseṭṭhaṁ taṁ,"
    },
    {
      "id": "tha-ap124:10.4",
      "pali": "Desesuṁ mama sammukhā."
    },
    {
      "id": "tha-ap124:11.1",
      "pali": "Tesāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap124:11.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap124:11.3",
      "pali": "Pupphehi thūpaṁ katvāna,"
    },
    {
      "id": "tha-ap124:11.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap124:12.1",
      "pali": "Te me sarīraṁ jhāpetvā,"
    },
    {
      "id": "tha-ap124:12.2",
      "pali": "agamuṁ buddhasantikaṁ;"
    },
    {
      "id": "tha-ap124:12.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap124:12.4",
      "pali": "satthāramabhivādayuṁ."
    },
    {
      "id": "tha-ap124:13.1",
      "pali": "Pupphehi thūpaṁ katvāna,"
    },
    {
      "id": "tha-ap124:13.2",
      "pali": "sugatassa mahesino;"
    },
    {
      "id": "tha-ap124:13.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap124:13.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap124:14.1",
      "pali": "Cattālīsasahassamhi,"
    },
    {
      "id": "tha-ap124:14.2",
      "pali": "kappe soḷasa khattiyā;"
    },
    {
      "id": "tha-ap124:14.3",
      "pali": "Nāmenaggisamā nāma,"
    },
    {
      "id": "tha-ap124:14.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap124:15.1",
      "pali": "Vīsakappasahassamhi,"
    },
    {
      "id": "tha-ap124:15.2",
      "pali": "rājāno cakkavattino;"
    },
    {
      "id": "tha-ap124:15.3",
      "pali": "Ghatāsanasanāmāva,"
    },
    {
      "id": "tha-ap124:15.4",
      "pali": "aṭṭhattiṁsa mahīpatī."
    },
    {
      "id": "tha-ap124:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap124:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap124:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap124:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphathūpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap124:18.1",
      "pali": "Pupphathūpiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
