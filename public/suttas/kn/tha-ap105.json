{
  "uid": "tha-ap105",
  "title": "Uppalahatthiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap105:1.1",
      "pali": "“Tivarāyaṁ nivāsīhaṁ,"
    },
    {
      "id": "tha-ap105:1.2",
      "pali": "ahosiṁ māliko tadā;"
    },
    {
      "id": "tha-ap105:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap105:1.4",
      "pali": "siddhatthaṁ lokapūjitaṁ."
    },
    {
      "id": "tha-ap105:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap105:2.2",
      "pali": "pupphahatthamadāsahaṁ;"
    },
    {
      "id": "tha-ap105:2.3",
      "pali": "Yattha yatthupapajjāmi,"
    },
    {
      "id": "tha-ap105:2.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap105:3.1",
      "pali": "Anubhomi phalaṁ iṭṭhaṁ,"
    },
    {
      "id": "tha-ap105:3.2",
      "pali": "pubbe sukatamattano;"
    },
    {
      "id": "tha-ap105:3.3",
      "pali": "Parikkhitto sumallehi,"
    },
    {
      "id": "tha-ap105:3.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap105:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap105:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap105:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap105:4.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap105:5.1",
      "pali": "Catunnavutupādāya,"
    },
    {
      "id": "tha-ap105:5.2",
      "pali": "ṭhapetvā vattamānakaṁ;"
    },
    {
      "id": "tha-ap105:5.3",
      "pali": "Pañcarājasatā tattha,"
    },
    {
      "id": "tha-ap105:5.4",
      "pali": "najjasamasanāmakā."
    },
    {
      "id": "tha-ap105:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap105:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap105:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap105:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā uppalahatthiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap105:8.1",
      "pali": "Uppalahatthiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
