{
  "uid": "ne34",
  "title": "Sampāta 15",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne34:1.1",
      "pali": "Tattha katamo parikkhāro hārasampāto?"
    },
    {
      "id": "ne34:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne34:2.2",
      "pali": "Ayaṁ samathavipassanāya parikkhāro."
    },
    {
      "id": "ne34:2.3",
      "pali": "Niyutto parikkhāro hārasampāto."
    }
  ]
}
