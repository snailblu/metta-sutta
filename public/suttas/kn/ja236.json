{
  "uid": "ja236",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja236:1.1",
      "pali": "“Bhaddako vatayaṁ pakkhī,"
    },
    {
      "id": "ja236:1.2",
      "pali": "dijo kumudasannibho;"
    },
    {
      "id": "ja236:1.3",
      "pali": "Vūpasantehi pakkhehi,"
    },
    {
      "id": "ja236:1.4",
      "pali": "mandamandova jhāyati”."
    },
    {
      "id": "ja236:2.1",
      "pali": "“Nāssa sīlaṁ vijānātha,"
    },
    {
      "id": "ja236:2.2",
      "pali": "anaññāya pasaṁsatha;"
    },
    {
      "id": "ja236:2.3",
      "pali": "Amhe dijo na pāleti,"
    },
    {
      "id": "ja236:2.4",
      "pali": "tena pakkhī na phandatī”ti."
    },
    {
      "id": "ja236:3.1",
      "pali": "Bakajātakaṁ chaṭṭhaṁ."
    }
  ]
}
