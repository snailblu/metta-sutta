{
  "uid": "pv19",
  "title": "7. Dhanapālaseṭṭhipetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv19:1.1",
      "pali": "“Naggo dubbaṇṇarūposi,"
    },
    {
      "id": "pv19:1.2",
      "pali": "kiso dhamanisanthato;"
    },
    {
      "id": "pv19:1.3",
      "pali": "Upphāsuliko kisiko,"
    },
    {
      "id": "pv19:1.4",
      "pali": "ko nu tvamasi mārisa”."
    },
    {
      "id": "pv19:2.1",
      "pali": "“Ahaṁ bhadante petomhi,"
    },
    {
      "id": "pv19:2.2",
      "pali": "duggato yamalokiko;"
    },
    {
      "id": "pv19:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv19:2.4",
      "pali": "petalokaṁ ito gato”."
    },
    {
      "id": "pv19:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv19:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv19:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv19:3.4",
      "pali": "petalokaṁ ito gato”."
    },
    {
      "id": "pv19:4.1",
      "pali": "“Nagaraṁ atthi paṇṇānaṁ,"
    },
    {
      "id": "pv19:4.2",
      "pali": "erakacchanti vissutaṁ;"
    },
    {
      "id": "pv19:4.3",
      "pali": "Tattha seṭṭhi pure āsiṁ,"
    },
    {
      "id": "pv19:4.4",
      "pali": "dhanapāloti maṁ vidū."
    },
    {
      "id": "pv19:5.1",
      "pali": "Asīti sakaṭavāhānaṁ,"
    },
    {
      "id": "pv19:5.2",
      "pali": "hiraññassa ahosi me;"
    },
    {
      "id": "pv19:5.3",
      "pali": "Pahūtaṁ me jātarūpaṁ,"
    },
    {
      "id": "pv19:5.4",
      "pali": "muttā veḷuriyā bahū."
    },
    {
      "id": "pv19:6.1",
      "pali": "Tāva mahaddhanassāpi,"
    },
    {
      "id": "pv19:6.2",
      "pali": "na me dātuṁ piyaṁ ahu;"
    },
    {
      "id": "pv19:6.3",
      "pali": "Pidahitvā dvāraṁ bhuñjiṁ,"
    },
    {
      "id": "pv19:6.4",
      "pali": "mā maṁ yācanakāddasuṁ."
    },
    {
      "id": "pv19:7.1",
      "pali": "Assaddho maccharī cāsiṁ,"
    },
    {
      "id": "pv19:7.2",
      "pali": "kadariyo paribhāsako;"
    },
    {
      "id": "pv19:7.3",
      "pali": "Dadantānaṁ karontānaṁ,"
    },
    {
      "id": "pv19:7.4",
      "pali": "vārayissaṁ bahū jane."
    },
    {
      "id": "pv19:8.1",
      "pali": "Vipāko natthi dānassa,"
    },
    {
      "id": "pv19:8.2",
      "pali": "saṁyamassa kuto phalaṁ;"
    },
    {
      "id": "pv19:8.3",
      "pali": "Pokkharaññodapānāni,"
    },
    {
      "id": "pv19:8.4",
      "pali": "ārāmāni ca ropite;"
    },
    {
      "id": "pv19:8.5",
      "pali": "Papāyo ca vināsesiṁ,"
    },
    {
      "id": "pv19:8.6",
      "pali": "dugge saṅkamanāni ca."
    },
    {
      "id": "pv19:9.1",
      "pali": "Svāhaṁ akatakalyāṇo,"
    },
    {
      "id": "pv19:9.2",
      "pali": "katapāpo tato cuto;"
    },
    {
      "id": "pv19:9.3",
      "pali": "Upapanno pettivisayaṁ,"
    },
    {
      "id": "pv19:9.4",
      "pali": "khuppipāsasamappito."
    },
    {
      "id": "pv19:10.1",
      "pali": "Pañcapaṇṇāsavassāni,"
    },
    {
      "id": "pv19:10.2",
      "pali": "yato kālaṅkato ahaṁ;"
    },
    {
      "id": "pv19:10.3",
      "pali": "Nābhijānāmi bhuttaṁ vā,"
    },
    {
      "id": "pv19:10.4",
      "pali": "pītaṁ vā pana pāniyaṁ."
    },
    {
      "id": "pv19:11.1",
      "pali": "Yo saṁyamo so vināso,"
    },
    {
      "id": "pv19:11.2",
      "pali": "yo vināso so saṁyamo;"
    },
    {
      "id": "pv19:11.3",
      "pali": "Petā hi kira jānanti,"
    },
    {
      "id": "pv19:11.4",
      "pali": "yo saṁyamo so vināso."
    },
    {
      "id": "pv19:12.1",
      "pali": "Ahaṁ pure saṁyamissaṁ,"
    },
    {
      "id": "pv19:12.2",
      "pali": "nādāsiṁ bahuke dhane;"
    },
    {
      "id": "pv19:12.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv19:12.4",
      "pali": "dīpaṁ nākāsimattano;"
    },
    {
      "id": "pv19:12.5",
      "pali": "Svāhaṁ pacchānutappāmi,"
    },
    {
      "id": "pv19:12.6",
      "pali": "attakammaphalūpago."
    },
    {
      "id": "pv19:13.1",
      "pali": "Uddhaṁ catūhi māsehi,"
    },
    {
      "id": "pv19:13.2",
      "pali": "kālaṅkiriyā bhavissati;"
    },
    {
      "id": "pv19:13.3",
      "pali": "Ekantakaṭukaṁ ghoraṁ,"
    },
    {
      "id": "pv19:13.4",
      "pali": "nirayaṁ papatissahaṁ."
    },
    {
      "id": "pv19:14.1",
      "pali": "Catukkaṇṇaṁ catudvāraṁ,"
    },
    {
      "id": "pv19:14.2",
      "pali": "vibhattaṁ bhāgaso mitaṁ;"
    },
    {
      "id": "pv19:14.3",
      "pali": "Ayopākārapariyantaṁ,"
    },
    {
      "id": "pv19:14.4",
      "pali": "ayasā paṭikujjitaṁ."
    },
    {
      "id": "pv19:15.1",
      "pali": "Tassa ayomayā bhūmi,"
    },
    {
      "id": "pv19:15.2",
      "pali": "jalitā tejasā yutā;"
    },
    {
      "id": "pv19:15.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "pv19:15.4",
      "pali": "pharitvā tiṭṭhati sabbadā."
    },
    {
      "id": "pv19:16.1",
      "pali": "Tatthāhaṁ dīghamaddhānaṁ,"
    },
    {
      "id": "pv19:16.2",
      "pali": "Dukkhaṁ vedissa vedanaṁ;"
    },
    {
      "id": "pv19:16.3",
      "pali": "Phalaṁ pāpassa kammassa,"
    },
    {
      "id": "pv19:16.4",
      "pali": "Tasmā socāmahaṁ bhusaṁ."
    },
    {
      "id": "pv19:17.1",
      "pali": "Taṁ vo vadāmi bhaddaṁ vo,"
    },
    {
      "id": "pv19:17.2",
      "pali": "yāvantettha samāgatā;"
    },
    {
      "id": "pv19:17.3",
      "pali": "Mākattha pāpakaṁ kammaṁ,"
    },
    {
      "id": "pv19:17.4",
      "pali": "āvi vā yadi vā raho."
    },
    {
      "id": "pv19:18.1",
      "pali": "Sace taṁ pāpakaṁ kammaṁ,"
    },
    {
      "id": "pv19:18.2",
      "pali": "karissatha karotha vā;"
    },
    {
      "id": "pv19:18.3",
      "pali": "Na vo dukkhā pamutyatthi,"
    },
    {
      "id": "pv19:18.4",
      "pali": "uppaccāpi palāyataṁ."
    },
    {
      "id": "pv19:19.1",
      "pali": "Matteyyā hotha petteyyā,"
    },
    {
      "id": "pv19:19.2",
      "pali": "kule jeṭṭhāpacāyikā;"
    },
    {
      "id": "pv19:19.3",
      "pali": "Sāmaññā hotha brahmaññā,"
    },
    {
      "id": "pv19:19.4",
      "pali": "evaṁ saggaṁ gamissathā”ti."
    },
    {
      "id": "pv19:20.1",
      "pali": "Dhanapālaseṭṭhipetavatthu sattamaṁ."
    }
  ]
}
