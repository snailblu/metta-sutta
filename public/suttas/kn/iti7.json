{
  "uid": "iti7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti7:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti7:2.1",
      "pali": "“Sabbaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti7:2.2",
      "pali": "Sabbañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti7:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti7:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti7:3.1",
      "pali": "“Yo sabbaṁ sabbato ñatvā,"
    },
    {
      "id": "iti7:3.2",
      "pali": "sabbatthesu na rajjati;"
    },
    {
      "id": "iti7:3.3",
      "pali": "Sa ve sabbapariññā so,"
    },
    {
      "id": "iti7:3.4",
      "pali": "sabbadukkhamupaccagā”ti."
    },
    {
      "id": "iti7:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti7:4.2",
      "pali": "Sattamaṁ."
    }
  ]
}
