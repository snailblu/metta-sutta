{
  "uid": "tha-ap139",
  "title": "Atthasandassakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap139:1.1",
      "pali": "“Visālamāḷe āsīno,"
    },
    {
      "id": "tha-ap139:1.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap139:1.3",
      "pali": "Khīṇāsavaṁ balappattaṁ,"
    },
    {
      "id": "tha-ap139:1.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap139:2.1",
      "pali": "Satasahassā tevijjā,"
    },
    {
      "id": "tha-ap139:2.2",
      "pali": "chaḷabhiññā mahiddhikā;"
    },
    {
      "id": "tha-ap139:2.3",
      "pali": "Parivārenti sambuddhaṁ,"
    },
    {
      "id": "tha-ap139:2.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap139:3.1",
      "pali": "Ñāṇe upanidhā yassa,"
    },
    {
      "id": "tha-ap139:3.2",
      "pali": "na vijjati sadevake;"
    },
    {
      "id": "tha-ap139:3.3",
      "pali": "Anantañāṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap139:3.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap139:4.1",
      "pali": "Dhammakāyañca dīpentaṁ,"
    },
    {
      "id": "tha-ap139:4.2",
      "pali": "kevalaṁ ratanākaraṁ;"
    },
    {
      "id": "tha-ap139:4.3",
      "pali": "Vikappetuṁ na sakkonti,"
    },
    {
      "id": "tha-ap139:4.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap139:5.1",
      "pali": "Imāhi tīhi gāthāhi,"
    },
    {
      "id": "tha-ap139:5.2",
      "pali": "nāradovhayavacchalo;"
    },
    {
      "id": "tha-ap139:5.3",
      "pali": "Padumuttaraṁ thavitvāna,"
    },
    {
      "id": "tha-ap139:5.4",
      "pali": "sambuddhaṁ aparājitaṁ."
    },
    {
      "id": "tha-ap139:6.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap139:6.2",
      "pali": "buddhasanthavanena ca;"
    },
    {
      "id": "tha-ap139:6.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap139:6.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap139:7.1",
      "pali": "Ito tiṁsakappasate,"
    },
    {
      "id": "tha-ap139:7.2",
      "pali": "sumitto nāma khattiyo;"
    },
    {
      "id": "tha-ap139:7.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap139:7.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap139:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap139:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap139:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap139:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā atthasandassako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap139:10.1",
      "pali": "Atthasandassakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
