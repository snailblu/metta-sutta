{
  "uid": "ja210",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja210:1.1",
      "pali": "“Ambho ko nāma yaṁ rukkho,"
    },
    {
      "id": "ja210:1.2",
      "pali": "sinnapatto sakaṇṭako;"
    },
    {
      "id": "ja210:1.3",
      "pali": "Yattha ekappahārena,"
    },
    {
      "id": "ja210:1.4",
      "pali": "uttamaṅgaṁ vibhijjitaṁ”."
    },
    {
      "id": "ja210:2.1",
      "pali": "“Acāri vatāyaṁ vitudaṁ vanāni,"
    },
    {
      "id": "ja210:2.2",
      "pali": "Kaṭṭhaṅgarukkhesu asārakesu;"
    },
    {
      "id": "ja210:2.3",
      "pali": "Athāsadā khadiraṁ jātasāraṁ,"
    },
    {
      "id": "ja210:2.4",
      "pali": "Yatthabbhidā garuḷo uttamaṅgan”ti."
    },
    {
      "id": "ja210:3.1",
      "pali": "Kandagalakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja210:3.2",
      "pali": "Nataṁdaḷhavaggo chaṭṭho."
    },
    {
      "id": "ja210:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja210:5.1",
      "pali": "Daḷhabandhana haṁsavaro ca puna,"
    },
    {
      "id": "ja210:5.2",
      "pali": "Virūpakkha saviṭṭhaka macchavaro;"
    },
    {
      "id": "ja210:5.3",
      "pali": "Sakuruṅga saassaka ambavaro,"
    },
    {
      "id": "ja210:5.4",
      "pali": "Puna kukkuṭako garuḷena dasāti."
    }
  ]
}
