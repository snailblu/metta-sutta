{
  "uid": "tha-ap351",
  "title": "Tindukaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap351:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap351:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap351:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap351:1.4",
      "pali": "oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap351:2.1",
      "pali": "Tindukaṁ saphalaṁ disvā,"
    },
    {
      "id": "tha-ap351:2.2",
      "pali": "bhinditvāna sakosakaṁ;"
    },
    {
      "id": "tha-ap351:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap351:2.4",
      "pali": "sayambhussa madāsahaṁ."
    },
    {
      "id": "tha-ap351:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap351:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap351:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap351:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap351:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap351:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap351:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap351:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā tindukaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap351:6.1",
      "pali": "Tindukaphaladāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
