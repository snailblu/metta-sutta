{
  "uid": "thag1.85",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.85:1.1",
      "pali": "“Cittanimittassa kovido,"
    },
    {
      "id": "thag1.85:1.2",
      "pali": "Pavivekarasaṁ vijāniya;"
    },
    {
      "id": "thag1.85:1.3",
      "pali": "Jhāyaṁ nipako patissato,"
    },
    {
      "id": "thag1.85:1.4",
      "pali": "Adhigaccheyya sukhaṁ nirāmisan”ti."
    },
    {
      "id": "thag1.85:1.5",
      "pali": "… Sunāgo thero …."
    }
  ]
}
