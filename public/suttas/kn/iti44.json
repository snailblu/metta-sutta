{
  "uid": "iti44",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti44:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti44:2.1",
      "pali": "“Dvemā, bhikkhave, nibbānadhātuyo."
    },
    {
      "id": "iti44:2.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "iti44:2.3",
      "pali": "Saupādisesā ca nibbānadhātu, anupādisesā ca nibbānadhātu."
    },
    {
      "id": "iti44:3.1",
      "pali": "Katamā ca, bhikkhave, saupādisesā nibbānadhātu?"
    },
    {
      "id": "iti44:3.2",
      "pali": "Idha, bhikkhave, bhikkhu arahaṁ hoti khīṇāsavo vusitavā katakaraṇīyo ohitabhāro anuppattasadattho parikkhīṇabhavasaṁyojano sammadaññāvimutto."
    },
    {
      "id": "iti44:3.3",
      "pali": "Tassa tiṭṭhanteva pañcindriyāni yesaṁ avighātattā manāpāmanāpaṁ paccanubhoti, sukhadukkhaṁ paṭisaṁvedeti."
    },
    {
      "id": "iti44:3.4",
      "pali": "Tassa yo rāgakkhayo, dosakkhayo, mohakkhayo—"
    },
    {
      "id": "iti44:3.5",
      "pali": "ayaṁ vuccati, bhikkhave, saupādisesā nibbānadhātu."
    },
    {
      "id": "iti44:4.1",
      "pali": "Katamā ca, bhikkhave, anupādisesā nibbānadhātu?"
    },
    {
      "id": "iti44:4.2",
      "pali": "Idha, bhikkhave, bhikkhu arahaṁ hoti khīṇāsavo vusitavā katakaraṇīyo ohitabhāro anuppattasadattho parikkhīṇabhavasaṁyojano sammadaññāvimutto."
    },
    {
      "id": "iti44:4.3",
      "pali": "Tassa idheva, bhikkhave, sabbavedayitāni anabhinanditāni sīti bhavissanti."
    },
    {
      "id": "iti44:4.4",
      "pali": "Ayaṁ vuccati, bhikkhave, anupādisesā nibbānadhātu."
    },
    {
      "id": "iti44:4.5",
      "pali": "Imā kho, bhikkhave, dve nibbānadhātuyo”ti."
    },
    {
      "id": "iti44:4.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti44:4.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti44:5.1",
      "pali": "“Duve imā cakkhumatā pakāsitā,"
    },
    {
      "id": "iti44:5.2",
      "pali": "Nibbānadhātū anissitena tādinā;"
    },
    {
      "id": "iti44:5.3",
      "pali": "Ekā hi dhātu idha diṭṭhadhammikā,"
    },
    {
      "id": "iti44:5.4",
      "pali": "Saupādisesā bhavanettisaṅkhayā;"
    },
    {
      "id": "iti44:5.5",
      "pali": "Anupādisesā pana samparāyikā,"
    },
    {
      "id": "iti44:5.6",
      "pali": "Yamhi nirujjhanti bhavāni sabbaso."
    },
    {
      "id": "iti44:6.1",
      "pali": "Ye etadaññāya padaṁ asaṅkhataṁ,"
    },
    {
      "id": "iti44:6.2",
      "pali": "Vimuttacittā bhavanettisaṅkhayā;"
    },
    {
      "id": "iti44:6.3",
      "pali": "Te dhammasārādhigamā khaye ratā,"
    },
    {
      "id": "iti44:6.4",
      "pali": "Pahaṁsu te sabbabhavāni tādino”ti."
    },
    {
      "id": "iti44:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti44:7.2",
      "pali": "Sattamaṁ."
    }
  ]
}
