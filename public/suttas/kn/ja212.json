{
  "uid": "ja212",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja212:1.1",
      "pali": "“Añño uparimo vaṇṇo,"
    },
    {
      "id": "ja212:1.2",
      "pali": "añño vaṇṇo ca heṭṭhimo;"
    },
    {
      "id": "ja212:1.3",
      "pali": "Brāhmaṇī tveva pucchāmi,"
    },
    {
      "id": "ja212:1.4",
      "pali": "kiṁ heṭṭhā kiñca uppari”."
    },
    {
      "id": "ja212:2.1",
      "pali": "“Ahaṁ naṭosmi bhaddante,"
    },
    {
      "id": "ja212:2.2",
      "pali": "bhikkhakosmi idhāgato;"
    },
    {
      "id": "ja212:2.3",
      "pali": "Ayañhi koṭṭhamotiṇṇo,"
    },
    {
      "id": "ja212:2.4",
      "pali": "ayaṁ so yaṁ gavesasī”ti."
    },
    {
      "id": "ja212:3.1",
      "pali": "Ucchiṭṭhabhattajātakaṁ dutiyaṁ."
    }
  ]
}
