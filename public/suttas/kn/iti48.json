{
  "uid": "iti48",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti48:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti48:2.1",
      "pali": "“Dveme, bhikkhave, āpāyikā nerayikā idamappahāya."
    },
    {
      "id": "iti48:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "iti48:2.3",
      "pali": "Yo ca abrahmacārī brahmacāripaṭiñño, yo ca paripuṇṇaṁ parisuddhaṁ brahmacariyaṁ carantaṁ amūlakena abrahmacariyena anuddhaṁseti."
    },
    {
      "id": "iti48:2.4",
      "pali": "Ime kho, bhikkhave, dve āpāyikā nerayikā idamappahāyā”ti."
    },
    {
      "id": "iti48:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti48:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti48:3.1",
      "pali": "“Abhūtavādī nirayaṁ upeti,"
    },
    {
      "id": "iti48:3.2",
      "pali": "Yo vāpi katvā na karomi cāha;"
    },
    {
      "id": "iti48:3.3",
      "pali": "Ubhopi te pecca samā bhavanti,"
    },
    {
      "id": "iti48:3.4",
      "pali": "Nihīnakammā manujā parattha."
    },
    {
      "id": "iti48:4.1",
      "pali": "Kāsāvakaṇṭhā bahavo,"
    },
    {
      "id": "iti48:4.2",
      "pali": "pāpadhammā asaññatā;"
    },
    {
      "id": "iti48:4.3",
      "pali": "Pāpā pāpehi kammehi,"
    },
    {
      "id": "iti48:4.4",
      "pali": "nirayaṁ te upapajjare."
    },
    {
      "id": "iti48:5.1",
      "pali": "Seyyo ayoguḷo bhutto,"
    },
    {
      "id": "iti48:5.2",
      "pali": "tatto aggisikhūpamo;"
    },
    {
      "id": "iti48:5.3",
      "pali": "Yañce bhuñjeyya dussīlo,"
    },
    {
      "id": "iti48:5.4",
      "pali": "raṭṭhapiṇḍamasaññato”ti."
    },
    {
      "id": "iti48:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti48:6.2",
      "pali": "Ekādasamaṁ."
    }
  ]
}
