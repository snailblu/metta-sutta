{
  "uid": "thag1.86",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.86:1.1",
      "pali": "“Ito bahiddhā puthu aññavādinaṁ,"
    },
    {
      "id": "thag1.86:1.2",
      "pali": "Maggo na nibbānagamo yathā ayaṁ;"
    },
    {
      "id": "thag1.86:1.3",
      "pali": "Itissu saṅghaṁ bhagavānusāsati,"
    },
    {
      "id": "thag1.86:1.4",
      "pali": "Satthā sayaṁ pāṇitaleva dassayan”ti."
    },
    {
      "id": "thag1.86:1.5",
      "pali": "… Nāgito thero …."
    }
  ]
}
