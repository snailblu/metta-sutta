{
  "uid": "ja121",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja121:1.1",
      "pali": "“Kare sarikkho atha vāpi seṭṭho,"
    },
    {
      "id": "ja121:1.2",
      "pali": "Nihīnako vāpi kareyya eko;"
    },
    {
      "id": "ja121:1.3",
      "pali": "Kareyyumete byasane uttamatthaṁ,"
    },
    {
      "id": "ja121:1.4",
      "pali": "Yathā ahaṁ kusanāḷi rucāyan”ti."
    },
    {
      "id": "ja121:2.1",
      "pali": "Kusanāḷijātakaṁ paṭhamaṁ."
    }
  ]
}
