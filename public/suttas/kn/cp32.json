{
  "uid": "cp32",
  "title": "Saccapāramī 6",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp32:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp32:1.2",
      "pali": "sutasomo mahīpati;"
    },
    {
      "id": "cp32:1.3",
      "pali": "Gahito porisādena,"
    },
    {
      "id": "cp32:1.4",
      "pali": "brāhmaṇe saṅgaraṁ sariṁ."
    },
    {
      "id": "cp32:2.1",
      "pali": "Khattiyānaṁ ekasataṁ,"
    },
    {
      "id": "cp32:2.2",
      "pali": "āvuṇitvā karattale;"
    },
    {
      "id": "cp32:2.3",
      "pali": "Etesaṁ pamilāpetvā,"
    },
    {
      "id": "cp32:2.4",
      "pali": "yaññatthe upanayī mamaṁ."
    },
    {
      "id": "cp32:3.1",
      "pali": "Apucchi maṁ porisādo,"
    },
    {
      "id": "cp32:3.2",
      "pali": "‘kiṁ tvaṁ icchasi nissajaṁ;"
    },
    {
      "id": "cp32:3.3",
      "pali": "Yathāmati te kāhāmi,"
    },
    {
      "id": "cp32:3.4",
      "pali": "yadi me tvaṁ punehisi’."
    },
    {
      "id": "cp32:4.1",
      "pali": "Tassa paṭissuṇitvāna,"
    },
    {
      "id": "cp32:4.2",
      "pali": "paṇhe āgamanaṁ mama;"
    },
    {
      "id": "cp32:4.3",
      "pali": "Upagantvā puraṁ rammaṁ,"
    },
    {
      "id": "cp32:4.4",
      "pali": "rajjaṁ niyyādayiṁ tadā."
    },
    {
      "id": "cp32:5.1",
      "pali": "Anussaritvā sataṁ dhammaṁ,"
    },
    {
      "id": "cp32:5.2",
      "pali": "pubbakaṁ jinasevitaṁ;"
    },
    {
      "id": "cp32:5.3",
      "pali": "Brāhmaṇassa dhanaṁ datvā,"
    },
    {
      "id": "cp32:5.4",
      "pali": "porisādaṁ upāgamiṁ."
    },
    {
      "id": "cp32:6.1",
      "pali": "Natthi me saṁsayo tattha,"
    },
    {
      "id": "cp32:6.2",
      "pali": "Ghātayissati vā na vā;"
    },
    {
      "id": "cp32:6.3",
      "pali": "Saccavācānurakkhanto,"
    },
    {
      "id": "cp32:6.4",
      "pali": "Jīvitaṁ cajitumupāgamiṁ;"
    },
    {
      "id": "cp32:6.5",
      "pali": "Saccena me samo natthi,"
    },
    {
      "id": "cp32:6.6",
      "pali": "Esā me saccapāramī”ti."
    },
    {
      "id": "cp32:7.1",
      "pali": "Sutasomacariyaṁ dvādasamaṁ."
    }
  ]
}
