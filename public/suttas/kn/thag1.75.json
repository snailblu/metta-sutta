{
  "uid": "thag1.75",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.75:1.1",
      "pali": "“Sādhu suvihitāna dassanaṁ,"
    },
    {
      "id": "thag1.75:1.2",
      "pali": "Kaṅkhā chijjati buddhi vaḍḍhati;"
    },
    {
      "id": "thag1.75:1.3",
      "pali": "Bālampi karonti paṇḍitaṁ,"
    },
    {
      "id": "thag1.75:1.4",
      "pali": "Tasmā sādhu sataṁ samāgamo”ti."
    },
    {
      "id": "thag1.75:1.5",
      "pali": "… Susārado thero …."
    }
  ]
}
