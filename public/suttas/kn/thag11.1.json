{
  "uid": "thag11.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag11.1:1.1",
      "pali": "“Kiṁ tavattho vane tāta,"
    },
    {
      "id": "thag11.1:1.2",
      "pali": "ujjuhānova pāvuse;"
    },
    {
      "id": "thag11.1:1.3",
      "pali": "Verambhā ramaṇīyā te,"
    },
    {
      "id": "thag11.1:1.4",
      "pali": "paviveko hi jhāyinaṁ”."
    },
    {
      "id": "thag11.1:2.1",
      "pali": "“Yathā abbhāni verambho,"
    },
    {
      "id": "thag11.1:2.2",
      "pali": "vāto nudati pāvuse;"
    },
    {
      "id": "thag11.1:2.3",
      "pali": "Saññā me abhikiranti,"
    },
    {
      "id": "thag11.1:2.4",
      "pali": "vivekapaṭisaññutā."
    },
    {
      "id": "thag11.1:3.1",
      "pali": "Apaṇḍaro aṇḍasambhavo,"
    },
    {
      "id": "thag11.1:3.2",
      "pali": "Sīvathikāya niketacāriko;"
    },
    {
      "id": "thag11.1:3.3",
      "pali": "Uppādayateva me satiṁ,"
    },
    {
      "id": "thag11.1:3.4",
      "pali": "Sandehasmiṁ virāganissitaṁ."
    },
    {
      "id": "thag11.1:4.1",
      "pali": "Yañca aññe na rakkhanti,"
    },
    {
      "id": "thag11.1:4.2",
      "pali": "yo ca aññe na rakkhati;"
    },
    {
      "id": "thag11.1:4.3",
      "pali": "Sa ve bhikkhu sukhaṁ seti,"
    },
    {
      "id": "thag11.1:4.4",
      "pali": "kāmesu anapekkhavā."
    },
    {
      "id": "thag11.1:5.1",
      "pali": "Acchodikā puthusilā,"
    },
    {
      "id": "thag11.1:5.2",
      "pali": "gonaṅgulamigāyutā;"
    },
    {
      "id": "thag11.1:5.3",
      "pali": "Ambusevālasañchannā,"
    },
    {
      "id": "thag11.1:5.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag11.1:6.1",
      "pali": "Vasitaṁ me araññesu,"
    },
    {
      "id": "thag11.1:6.2",
      "pali": "kandarāsu guhāsu ca;"
    },
    {
      "id": "thag11.1:6.3",
      "pali": "Senāsanesu pantesu,"
    },
    {
      "id": "thag11.1:6.4",
      "pali": "vāḷamiganisevite."
    },
    {
      "id": "thag11.1:7.1",
      "pali": "‘Ime haññantu vajjhantu,"
    },
    {
      "id": "thag11.1:7.2",
      "pali": "dukkhaṁ pappontu pāṇino’;"
    },
    {
      "id": "thag11.1:7.3",
      "pali": "Saṅkappaṁ nābhijānāmi,"
    },
    {
      "id": "thag11.1:7.4",
      "pali": "anariyaṁ dosasaṁhitaṁ."
    },
    {
      "id": "thag11.1:8.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag11.1:8.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thag11.1:8.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thag11.1:8.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag11.1:9.1",
      "pali": "Yassa catthāya pabbajito,"
    },
    {
      "id": "thag11.1:9.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag11.1:9.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag11.1:9.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thag11.1:10.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag11.1:10.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "thag11.1:10.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "thag11.1:10.4",
      "pali": "nibbisaṁ bhatako yathā."
    },
    {
      "id": "thag11.1:11.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag11.1:11.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "thag11.1:11.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "thag11.1:11.4",
      "pali": "sampajāno patissato”ti."
    },
    {
      "id": "thag11.1:11.5",
      "pali": "… Saṅkicco thero …"
    },
    {
      "id": "thag11.1:11.6",
      "pali": "Ekādasakanipāto niṭṭhito."
    },
    {
      "id": "thag11.1:12.1",
      "pali": "Saṅkiccathero ekova,"
    },
    {
      "id": "thag11.1:12.2",
      "pali": "katakicco anāsavo;"
    },
    {
      "id": "thag11.1:12.3",
      "pali": "Ekādasanipātamhi,"
    },
    {
      "id": "thag11.1:12.4",
      "pali": "gāthā ekādaseva cāti."
    }
  ]
}
