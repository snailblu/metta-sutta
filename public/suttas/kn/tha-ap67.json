{
  "uid": "tha-ap67",
  "title": "Bhisadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap67:1.1",
      "pali": "“Vessabhū nāma nāmena,"
    },
    {
      "id": "tha-ap67:1.2",
      "pali": "isīnaṁ tatiyo ahu;"
    },
    {
      "id": "tha-ap67:1.3",
      "pali": "Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap67:1.4",
      "pali": "vihāsi purisuttamo."
    },
    {
      "id": "tha-ap67:2.1",
      "pali": "Bhisamuḷālaṁ gaṇhitvā,"
    },
    {
      "id": "tha-ap67:2.2",
      "pali": "agamaṁ buddhasantikaṁ;"
    },
    {
      "id": "tha-ap67:2.3",
      "pali": "Tañca buddhassa pādāsiṁ,"
    },
    {
      "id": "tha-ap67:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap67:3.1",
      "pali": "Karena ca parāmaṭṭho,"
    },
    {
      "id": "tha-ap67:3.2",
      "pali": "vessabhūvarabuddhinā;"
    },
    {
      "id": "tha-ap67:3.3",
      "pali": "Sukhāhaṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap67:3.4",
      "pali": "samaṁ tena kutottariṁ."
    },
    {
      "id": "tha-ap67:4.1",
      "pali": "Carimo vattate mayhaṁ,"
    },
    {
      "id": "tha-ap67:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap67:4.3",
      "pali": "Hatthināgena santena,"
    },
    {
      "id": "tha-ap67:4.4",
      "pali": "kusalaṁ ropitaṁ mayā."
    },
    {
      "id": "tha-ap67:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap67:5.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap67:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap67:5.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap67:6.1",
      "pali": "Samodhānā ca rājāno,"
    },
    {
      "id": "tha-ap67:6.2",
      "pali": "soḷasa manujādhipā;"
    },
    {
      "id": "tha-ap67:6.3",
      "pali": "Kappamhi cuddase āsuṁ,"
    },
    {
      "id": "tha-ap67:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap67:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap67:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap67:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap67:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhisadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap67:9.1",
      "pali": "Bhisadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
