{
  "uid": "ja80",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja80:1.1",
      "pali": "“Yaṁ te pavikatthitaṁ pure,"
    },
    {
      "id": "ja80:1.2",
      "pali": "Atha te pūtisarā sajanti pacchā;"
    },
    {
      "id": "ja80:1.3",
      "pali": "Ubhayaṁ na sameti bhīmasena,"
    },
    {
      "id": "ja80:1.4",
      "pali": "Yuddhakathā ca idañca te vihaññan”ti."
    },
    {
      "id": "ja80:2.1",
      "pali": "Bhīmasenajātakaṁ dasamaṁ."
    },
    {
      "id": "ja80:2.2",
      "pali": "Varuṇavaggo aṭṭhamo."
    },
    {
      "id": "ja80:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja80:4.1",
      "pali": "Varuṇā akataññūvare tu saccavaraṁ,"
    },
    {
      "id": "ja80:4.2",
      "pali": "Savanappatinā ca abhitthanaya;"
    },
    {
      "id": "ja80:4.3",
      "pali": "Karuṇāya silāplava illisato,"
    },
    {
      "id": "ja80:4.4",
      "pali": "Puna ḍiṇḍimapūtisarena dasāti."
    }
  ]
}
