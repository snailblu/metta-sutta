{
  "uid": "vv9",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv9:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv9:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv9:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv9:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv9:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv9:2.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv9:2.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv9:2.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv9:3.1",
      "pali": "Kena tvaṁ vimalobhāsā,"
    },
    {
      "id": "vv9:3.2",
      "pali": "atirocasi devatā;"
    },
    {
      "id": "vv9:3.3",
      "pali": "Kena te sabbagattehi,"
    },
    {
      "id": "vv9:3.4",
      "pali": "sabbā obhāsate disā."
    },
    {
      "id": "vv9:4.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv9:4.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv9:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv9:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv9:5.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv9:5.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv9:5.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv9:5.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv9:6.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv9:6.2",
      "pali": "Purimāya jātiyā manussaloke;"
    },
    {
      "id": "vv9:6.3",
      "pali": "Tamandhakāramhi timīsikāyaṁ,"
    },
    {
      "id": "vv9:6.4",
      "pali": "Padīpakālamhi adāsi dīpaṁ."
    },
    {
      "id": "vv9:7.1",
      "pali": "Yo andhakāramhi timīsikāyaṁ,"
    },
    {
      "id": "vv9:7.2",
      "pali": "Padīpakālamhi dadāti dīpaṁ;"
    },
    {
      "id": "vv9:7.3",
      "pali": "Upapajjati jotirasaṁ vimānaṁ,"
    },
    {
      "id": "vv9:7.4",
      "pali": "Pahūtamalyaṁ bahupuṇḍarīkaṁ."
    },
    {
      "id": "vv9:8.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv9:8.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv9:8.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv9:8.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv9:9.1",
      "pali": "Tenāhaṁ vimalobhāsā,"
    },
    {
      "id": "vv9:9.2",
      "pali": "atirocāmi devatā;"
    },
    {
      "id": "vv9:9.3",
      "pali": "Tena me sabbagattehi,"
    },
    {
      "id": "vv9:9.4",
      "pali": "sabbā obhāsate disā."
    },
    {
      "id": "vv9:10.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv9:10.2",
      "pali": "Manussabhūtā yamakāsi puññaṁ;"
    },
    {
      "id": "vv9:10.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv9:10.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv9:11.1",
      "pali": "Dīpavimānaṁ navamaṁ."
    }
  ]
}
