{
  "uid": "snp4.16",
  "title": "Sāriputtasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.16:1.1",
      "pali": "“Na me diṭṭho ito pubbe,"
    },
    {
      "id": "snp4.16:1.2",
      "pali": "(iccāyasmā sāriputto)"
    },
    {
      "id": "snp4.16:1.3",
      "pali": "Na suto uda kassaci;"
    },
    {
      "id": "snp4.16:1.4",
      "pali": "Evaṁ vagguvado satthā,"
    },
    {
      "id": "snp4.16:1.5",
      "pali": "Tusitā gaṇimāgato."
    },
    {
      "id": "snp4.16:2.1",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "snp4.16:2.2",
      "pali": "yathā dissati cakkhumā;"
    },
    {
      "id": "snp4.16:2.3",
      "pali": "Sabbaṁ tamaṁ vinodetvā,"
    },
    {
      "id": "snp4.16:2.4",
      "pali": "ekova ratimajjhagā."
    },
    {
      "id": "snp4.16:3.1",
      "pali": "Taṁ buddhaṁ asitaṁ tādiṁ,"
    },
    {
      "id": "snp4.16:3.2",
      "pali": "akuhaṁ gaṇimāgataṁ;"
    },
    {
      "id": "snp4.16:3.3",
      "pali": "Bahūnamidha baddhānaṁ,"
    },
    {
      "id": "snp4.16:3.4",
      "pali": "atthi pañhena āgamaṁ."
    },
    {
      "id": "snp4.16:4.1",
      "pali": "Bhikkhuno vijigucchato,"
    },
    {
      "id": "snp4.16:4.2",
      "pali": "bhajato rittamāsanaṁ;"
    },
    {
      "id": "snp4.16:4.3",
      "pali": "Rukkhamūlaṁ susānaṁ vā,"
    },
    {
      "id": "snp4.16:4.4",
      "pali": "pabbatānaṁ guhāsu vā."
    },
    {
      "id": "snp4.16:5.1",
      "pali": "Uccāvacesu sayanesu,"
    },
    {
      "id": "snp4.16:5.2",
      "pali": "kīvanto tattha bheravā;"
    },
    {
      "id": "snp4.16:5.3",
      "pali": "Yehi bhikkhu na vedheyya,"
    },
    {
      "id": "snp4.16:5.4",
      "pali": "nigghose sayanāsane."
    },
    {
      "id": "snp4.16:6.1",
      "pali": "Katī parissayā loke,"
    },
    {
      "id": "snp4.16:6.2",
      "pali": "gacchato agataṁ disaṁ;"
    },
    {
      "id": "snp4.16:6.3",
      "pali": "Ye bhikkhu abhisambhave,"
    },
    {
      "id": "snp4.16:6.4",
      "pali": "pantamhi sayanāsane."
    },
    {
      "id": "snp4.16:7.1",
      "pali": "Kyāssa byappathayo assu,"
    },
    {
      "id": "snp4.16:7.2",
      "pali": "kyāssassu idha gocarā;"
    },
    {
      "id": "snp4.16:7.3",
      "pali": "Kāni sīlabbatānāssu,"
    },
    {
      "id": "snp4.16:7.4",
      "pali": "pahitattassa bhikkhuno."
    },
    {
      "id": "snp4.16:8.1",
      "pali": "Kaṁ so sikkhaṁ samādāya,"
    },
    {
      "id": "snp4.16:8.2",
      "pali": "ekodi nipako sato;"
    },
    {
      "id": "snp4.16:8.3",
      "pali": "Kammāro rajatasseva,"
    },
    {
      "id": "snp4.16:8.4",
      "pali": "niddhame malamattano”."
    },
    {
      "id": "snp4.16:9.1",
      "pali": "“Vijigucchamānassa yadidaṁ phāsu,"
    },
    {
      "id": "snp4.16:9.2",
      "pali": "(sāriputtāti bhagavā)"
    },
    {
      "id": "snp4.16:9.3",
      "pali": "Rittāsanaṁ sayanaṁ sevato ce;"
    },
    {
      "id": "snp4.16:9.4",
      "pali": "Sambodhikāmassa yathānudhammaṁ,"
    },
    {
      "id": "snp4.16:9.5",
      "pali": "Taṁ te pavakkhāmi yathā pajānaṁ."
    },
    {
      "id": "snp4.16:10.1",
      "pali": "Pañcannaṁ dhīro bhayānaṁ na bhāye,"
    },
    {
      "id": "snp4.16:10.2",
      "pali": "Bhikkhu sato sapariyantacārī;"
    },
    {
      "id": "snp4.16:10.3",
      "pali": "Ḍaṁsādhipātānaṁ sarīsapānaṁ,"
    },
    {
      "id": "snp4.16:10.4",
      "pali": "Manussaphassānaṁ catuppadānaṁ."
    },
    {
      "id": "snp4.16:11.1",
      "pali": "Paradhammikānampi na santaseyya,"
    },
    {
      "id": "snp4.16:11.2",
      "pali": "Disvāpi tesaṁ bahubheravāni;"
    },
    {
      "id": "snp4.16:11.3",
      "pali": "Athāparāni abhisambhaveyya,"
    },
    {
      "id": "snp4.16:11.4",
      "pali": "Parissayāni kusalānuesī."
    },
    {
      "id": "snp4.16:12.1",
      "pali": "Ātaṅkaphassena khudāya phuṭṭho,"
    },
    {
      "id": "snp4.16:12.2",
      "pali": "Sītaṁ athuṇhaṁ adhivāsayeyya;"
    },
    {
      "id": "snp4.16:12.3",
      "pali": "So tehi phuṭṭho bahudhā anoko,"
    },
    {
      "id": "snp4.16:12.4",
      "pali": "Viriyaṁ parakkammadaḷhaṁ kareyya."
    },
    {
      "id": "snp4.16:13.1",
      "pali": "Theyyaṁ na kāre na musā bhaṇeyya,"
    },
    {
      "id": "snp4.16:13.2",
      "pali": "Mettāya phasse tasathāvarāni;"
    },
    {
      "id": "snp4.16:13.3",
      "pali": "Yadāvilattaṁ manaso vijaññā,"
    },
    {
      "id": "snp4.16:13.4",
      "pali": "Kaṇhassa pakkhoti vinodayeyya."
    },
    {
      "id": "snp4.16:14.1",
      "pali": "Kodhātimānassa vasaṁ na gacche,"
    },
    {
      "id": "snp4.16:14.2",
      "pali": "Mūlampi tesaṁ palikhañña tiṭṭhe;"
    },
    {
      "id": "snp4.16:14.3",
      "pali": "Athappiyaṁ vā pana appiyaṁ vā,"
    },
    {
      "id": "snp4.16:14.4",
      "pali": "Addhā bhavanto abhisambhaveyya."
    },
    {
      "id": "snp4.16:15.1",
      "pali": "Paññaṁ purakkhatvā kalyāṇapīti,"
    },
    {
      "id": "snp4.16:15.2",
      "pali": "Vikkhambhaye tāni parissayāni;"
    },
    {
      "id": "snp4.16:15.3",
      "pali": "Aratiṁ sahetha sayanamhi pante,"
    },
    {
      "id": "snp4.16:15.4",
      "pali": "Caturo sahetha paridevadhamme."
    },
    {
      "id": "snp4.16:16.1",
      "pali": "Kiṁsū asissāmi kuva vā asissaṁ,"
    },
    {
      "id": "snp4.16:16.2",
      "pali": "Dukkhaṁ vata settha kvajja sessaṁ;"
    },
    {
      "id": "snp4.16:16.3",
      "pali": "Ete vitakke paridevaneyye,"
    },
    {
      "id": "snp4.16:16.4",
      "pali": "Vinayetha sekho aniketacārī."
    },
    {
      "id": "snp4.16:17.1",
      "pali": "Annañca laddhā vasanañca kāle,"
    },
    {
      "id": "snp4.16:17.2",
      "pali": "Mattaṁ so jaññā idha tosanatthaṁ;"
    },
    {
      "id": "snp4.16:17.3",
      "pali": "So tesu gutto yatacāri gāme,"
    },
    {
      "id": "snp4.16:17.4",
      "pali": "Rusitopi vācaṁ pharusaṁ na vajjā."
    },
    {
      "id": "snp4.16:18.1",
      "pali": "Okkhittacakkhu na ca pādalolo,"
    },
    {
      "id": "snp4.16:18.2",
      "pali": "Jhānānuyutto bahujāgarassa;"
    },
    {
      "id": "snp4.16:18.3",
      "pali": "Upekkhamārabbha samāhitatto,"
    },
    {
      "id": "snp4.16:18.4",
      "pali": "Takkāsayaṁ kukkucciyūpachinde."
    },
    {
      "id": "snp4.16:19.1",
      "pali": "Cudito vacībhi satimābhinande,"
    },
    {
      "id": "snp4.16:19.2",
      "pali": "Sabrahmacārīsu khilaṁ pabhinde;"
    },
    {
      "id": "snp4.16:19.3",
      "pali": "Vācaṁ pamuñce kusalaṁ nātivelaṁ,"
    },
    {
      "id": "snp4.16:19.4",
      "pali": "Janavādadhammāya na cetayeyya."
    },
    {
      "id": "snp4.16:20.1",
      "pali": "Athāparaṁ pañca rajāni loke,"
    },
    {
      "id": "snp4.16:20.2",
      "pali": "Yesaṁ satīmā vinayāya sikkhe;"
    },
    {
      "id": "snp4.16:20.3",
      "pali": "Rūpesu saddesu atho rasesu,"
    },
    {
      "id": "snp4.16:20.4",
      "pali": "Gandhesu phassesu sahetha rāgaṁ."
    },
    {
      "id": "snp4.16:21.1",
      "pali": "Etesu dhammesu vineyya chandaṁ,"
    },
    {
      "id": "snp4.16:21.2",
      "pali": "Bhikkhu satimā suvimuttacitto;"
    },
    {
      "id": "snp4.16:21.3",
      "pali": "Kālena so sammā dhammaṁ parivīmaṁsamāno,"
    },
    {
      "id": "snp4.16:21.4",
      "pali": "Ekodibhūto vihane tamaṁ so”ti."
    },
    {
      "id": "snp4.16:21.5",
      "pali": "Sāriputtasuttaṁ soḷasamaṁ."
    },
    {
      "id": "snp4.16:21.6",
      "pali": "Aṭṭhakavaggo catuttho."
    },
    {
      "id": "snp4.16:22.1",
      "pali": "Kāmaṁ guhañca duṭṭhā ca,"
    },
    {
      "id": "snp4.16:22.2",
      "pali": "suddhañca paramā jarā;"
    },
    {
      "id": "snp4.16:22.3",
      "pali": "Metteyyo ca pasūro ca,"
    },
    {
      "id": "snp4.16:22.4",
      "pali": "māgaṇḍi purābhedanaṁ."
    },
    {
      "id": "snp4.16:23.1",
      "pali": "Kalahaṁ dve ca byūhāni,"
    },
    {
      "id": "snp4.16:23.2",
      "pali": "punadeva tuvaṭṭakaṁ;"
    },
    {
      "id": "snp4.16:23.3",
      "pali": "Attadaṇḍavaraṁ suttaṁ,"
    },
    {
      "id": "snp4.16:23.4",
      "pali": "therapuṭṭhena soḷasa;"
    },
    {
      "id": "snp4.16:23.5",
      "pali": "Iti etāni suttāni,"
    },
    {
      "id": "snp4.16:23.6",
      "pali": "sabbānaṭṭhakavaggikāti."
    }
  ]
}
