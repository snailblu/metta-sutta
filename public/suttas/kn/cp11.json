{
  "uid": "cp11",
  "title": "Sīlapāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp11:1.1",
      "pali": "“Yadā ahosiṁ pavane,"
    },
    {
      "id": "cp11:1.2",
      "pali": "kuñjaro mātuposako;"
    },
    {
      "id": "cp11:1.3",
      "pali": "Na tadā atthi mahiyā,"
    },
    {
      "id": "cp11:1.4",
      "pali": "guṇena mama sādiso."
    },
    {
      "id": "cp11:2.1",
      "pali": "Pavane disvā vanacaro,"
    },
    {
      "id": "cp11:2.2",
      "pali": "rañño maṁ paṭivedayi;"
    },
    {
      "id": "cp11:2.3",
      "pali": "‘Tavānucchavo mahārāja,"
    },
    {
      "id": "cp11:2.4",
      "pali": "gajo vasati kānane."
    },
    {
      "id": "cp11:3.1",
      "pali": "Na tassa parikkhāyattho,"
    },
    {
      "id": "cp11:3.2",
      "pali": "napi āḷakakāsuyā;"
    },
    {
      "id": "cp11:3.3",
      "pali": "Saha gahite soṇḍāya,"
    },
    {
      "id": "cp11:3.4",
      "pali": "sayameva idhehi’ti."
    },
    {
      "id": "cp11:4.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp11:4.2",
      "pali": "rājāpi tuṭṭhamānaso;"
    },
    {
      "id": "cp11:4.3",
      "pali": "Pesesi hatthidamakaṁ,"
    },
    {
      "id": "cp11:4.4",
      "pali": "chekācariyaṁ susikkhitaṁ."
    },
    {
      "id": "cp11:5.1",
      "pali": "Gantvā so hatthidamako,"
    },
    {
      "id": "cp11:5.2",
      "pali": "addasa padumassare;"
    },
    {
      "id": "cp11:5.3",
      "pali": "Bhisamuḷālaṁ uddharantaṁ,"
    },
    {
      "id": "cp11:5.4",
      "pali": "yāpanatthāya mātuyā."
    },
    {
      "id": "cp11:6.1",
      "pali": "Viññāya me sīlaguṇaṁ,"
    },
    {
      "id": "cp11:6.2",
      "pali": "lakkhaṇaṁ upadhārayi;"
    },
    {
      "id": "cp11:6.3",
      "pali": "‘Ehi puttā’ti vatvāna,"
    },
    {
      "id": "cp11:6.4",
      "pali": "mama soṇḍāya aggahi."
    },
    {
      "id": "cp11:7.1",
      "pali": "Yaṁ me tadā pākatikaṁ,"
    },
    {
      "id": "cp11:7.2",
      "pali": "sarīrānugataṁ balaṁ;"
    },
    {
      "id": "cp11:7.3",
      "pali": "Ajja nāgasahassānaṁ,"
    },
    {
      "id": "cp11:7.4",
      "pali": "balena samasādisaṁ."
    },
    {
      "id": "cp11:8.1",
      "pali": "Yadihaṁ tesaṁ pakuppeyyaṁ,"
    },
    {
      "id": "cp11:8.2",
      "pali": "upetānaṁ gahaṇāya maṁ;"
    },
    {
      "id": "cp11:8.3",
      "pali": "Paṭibalo bhave tesaṁ,"
    },
    {
      "id": "cp11:8.4",
      "pali": "yāva rajjampi mānusaṁ."
    },
    {
      "id": "cp11:9.1",
      "pali": "Api cāhaṁ sīlarakkhāya,"
    },
    {
      "id": "cp11:9.2",
      "pali": "Sīlapāramipūriyā;"
    },
    {
      "id": "cp11:9.3",
      "pali": "Na karomi citte aññathattaṁ,"
    },
    {
      "id": "cp11:9.4",
      "pali": "Pakkhipantaṁ mamāḷake."
    },
    {
      "id": "cp11:10.1",
      "pali": "Yadi te maṁ tattha koṭṭeyyuṁ,"
    },
    {
      "id": "cp11:10.2",
      "pali": "pharasūhi tomarehi ca;"
    },
    {
      "id": "cp11:10.3",
      "pali": "Neva tesaṁ pakuppeyyaṁ,"
    },
    {
      "id": "cp11:10.4",
      "pali": "sīlakhaṇḍabhayā mamā”ti."
    },
    {
      "id": "cp11:11.1",
      "pali": "Mātuposakacariyaṁ paṭhamaṁ."
    }
  ]
}
