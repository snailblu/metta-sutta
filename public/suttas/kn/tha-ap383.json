{
  "uid": "tha-ap383",
  "title": "1 Avaṭaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap383:1.1",
      "pali": "“Sataraṁsi nāma bhagavā,"
    },
    {
      "id": "tha-ap383:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap383:1.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap383:1.4",
      "pali": "gocarāyābhinikkhami."
    },
    {
      "id": "tha-ap383:2.1",
      "pali": "Phalahattho ahaṁ disvā,"
    },
    {
      "id": "tha-ap383:2.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap383:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap383:2.4",
      "pali": "avaṭaṁ adadiṁ phalaṁ."
    },
    {
      "id": "tha-ap383:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap383:3.2",
      "pali": "yaṁ phalamadadiṁ ahaṁ;"
    },
    {
      "id": "tha-ap383:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap383:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap383:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap383:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap383:4.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap383:4.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap383:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap383:5.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap383:5.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap383:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap383:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap383:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap383:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap383:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap383:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā avaṭaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap383:8.1",
      "pali": "Avaṭaphaladāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
