{
  "uid": "ja250",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja250:1.1",
      "pali": "“Ayaṁ isī upasamasaṁyame rato,"
    },
    {
      "id": "ja250:1.2",
      "pali": "Sa tiṭṭhati sisirabhayena aṭṭito;"
    },
    {
      "id": "ja250:1.3",
      "pali": "Handa ayaṁ pavisatumaṁ agārakaṁ,"
    },
    {
      "id": "ja250:1.4",
      "pali": "Vinetu sītaṁ darathañca kevalaṁ”."
    },
    {
      "id": "ja250:2.1",
      "pali": "“Nāyaṁ isī upasamasaṁyame rato,"
    },
    {
      "id": "ja250:2.2",
      "pali": "Kapī ayaṁ dumavarasākhagocaro;"
    },
    {
      "id": "ja250:2.3",
      "pali": "So dūsako rosako cāpi jammo,"
    },
    {
      "id": "ja250:2.4",
      "pali": "Sacevajemampi dūseyyagāran”ti."
    },
    {
      "id": "ja250:3.1",
      "pali": "Kapijātakaṁ dasamaṁ."
    },
    {
      "id": "ja250:3.2",
      "pali": "Siṅgālavaggo dasamo."
    },
    {
      "id": "ja250:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja250:5.1",
      "pali": "Atha rājā siṅgālavaro sunakho,"
    },
    {
      "id": "ja250:5.2",
      "pali": "Tathā kosiya icchati kālaghaso;"
    },
    {
      "id": "ja250:5.3",
      "pali": "Atha dānavaroṭṭhapi sārathinā,"
    },
    {
      "id": "ja250:5.4",
      "pali": "Punambavanañca sisirakapi dasāti."
    },
    {
      "id": "ja250:6.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja250:7.1",
      "pali": "Daḷhañca vaggaṁ aparena santhavaṁ,"
    },
    {
      "id": "ja250:7.2",
      "pali": "Kalyāṇavaggāsadiso ca rūhakaṁ;"
    },
    {
      "id": "ja250:7.3",
      "pali": "Nataṁdaḷha bīraṇathambhakaṁ puna,"
    },
    {
      "id": "ja250:7.4",
      "pali": "Kāsāvupāhana siṅgālakena dasāti."
    },
    {
      "id": "ja250:8.1",
      "pali": "Dukanipātaṁ niṭṭhitaṁ."
    }
  ]
}
