{
  "uid": "ja34",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja34:1.1",
      "pali": "“Na maṁ sītaṁ na maṁ uṇhaṁ,"
    },
    {
      "id": "ja34:1.2",
      "pali": "na maṁ jālasmi bādhanaṁ;"
    },
    {
      "id": "ja34:1.3",
      "pali": "Yañca maṁ maññate macchī,"
    },
    {
      "id": "ja34:1.4",
      "pali": "aññaṁ so ratiyā gato”ti."
    },
    {
      "id": "ja34:2.1",
      "pali": "Macchajātakaṁ catutthaṁ."
    }
  ]
}
