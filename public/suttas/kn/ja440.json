{
  "uid": "ja440",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja440:1.1",
      "pali": "“Kaṇho vatāyaṁ puriso,"
    },
    {
      "id": "ja440:1.2",
      "pali": "kaṇhaṁ bhuñjati bhojanaṁ;"
    },
    {
      "id": "ja440:1.3",
      "pali": "Kaṇhe bhūmipadesasmiṁ,"
    },
    {
      "id": "ja440:1.4",
      "pali": "na mayhaṁ manaso piyo”."
    },
    {
      "id": "ja440:2.1",
      "pali": "“Na kaṇho tacasā hoti,"
    },
    {
      "id": "ja440:2.2",
      "pali": "antosāro hi brāhmaṇo;"
    },
    {
      "id": "ja440:2.3",
      "pali": "Yasmiṁ pāpāni kammāni,"
    },
    {
      "id": "ja440:2.4",
      "pali": "sa ve kaṇho sujampati”."
    },
    {
      "id": "ja440:3.1",
      "pali": "“Etasmiṁ te sulapite,"
    },
    {
      "id": "ja440:3.2",
      "pali": "patirūpe subhāsite;"
    },
    {
      "id": "ja440:3.3",
      "pali": "Varaṁ brāhmaṇa te dammi,"
    },
    {
      "id": "ja440:3.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja440:4.1",
      "pali": "“Varañce me ado sakka,"
    },
    {
      "id": "ja440:4.2",
      "pali": "sabbabhūtānamissara;"
    },
    {
      "id": "ja440:4.3",
      "pali": "Sunikkodhaṁ suniddosaṁ,"
    },
    {
      "id": "ja440:4.4",
      "pali": "nillobhaṁ vuttimattano;"
    },
    {
      "id": "ja440:4.5",
      "pali": "Nisnehamabhikaṅkhāmi,"
    },
    {
      "id": "ja440:4.6",
      "pali": "ete me caturo vare”."
    },
    {
      "id": "ja440:5.1",
      "pali": "“Kiṁ nu kodhe vā dose vā,"
    },
    {
      "id": "ja440:5.2",
      "pali": "lobhe snehe ca brāhmaṇa;"
    },
    {
      "id": "ja440:5.3",
      "pali": "Ādīnavaṁ tvaṁ passasi,"
    },
    {
      "id": "ja440:5.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja440:6.1",
      "pali": "“Appo hutvā bahu hoti,"
    },
    {
      "id": "ja440:6.2",
      "pali": "vaḍḍhate so akhantijo;"
    },
    {
      "id": "ja440:6.3",
      "pali": "Āsaṅgī bahupāyāso,"
    },
    {
      "id": "ja440:6.4",
      "pali": "tasmā kodhaṁ na rocaye."
    },
    {
      "id": "ja440:7.1",
      "pali": "Duṭṭhassa pharusā vācā,"
    },
    {
      "id": "ja440:7.2",
      "pali": "parāmāso anantarā;"
    },
    {
      "id": "ja440:7.3",
      "pali": "Tato pāṇi tato daṇḍo,"
    },
    {
      "id": "ja440:7.4",
      "pali": "satthassa paramā gati;"
    },
    {
      "id": "ja440:7.5",
      "pali": "Doso kodhasamuṭṭhāno,"
    },
    {
      "id": "ja440:7.6",
      "pali": "tasmā dosaṁ na rocaye."
    },
    {
      "id": "ja440:8.1",
      "pali": "Ālopa sāhasākārā,"
    },
    {
      "id": "ja440:8.2",
      "pali": "nikatī vañcanāni ca;"
    },
    {
      "id": "ja440:8.3",
      "pali": "Dissanti lobhadhammesu,"
    },
    {
      "id": "ja440:8.4",
      "pali": "tasmā lobhaṁ na rocaye."
    },
    {
      "id": "ja440:9.1",
      "pali": "Snehasaṅgathitā ganthā,"
    },
    {
      "id": "ja440:9.2",
      "pali": "senti manomayā puthū;"
    },
    {
      "id": "ja440:9.3",
      "pali": "Te bhusaṁ upatāpenti,"
    },
    {
      "id": "ja440:9.4",
      "pali": "tasmā snehaṁ na rocaye”."
    },
    {
      "id": "ja440:10.1",
      "pali": "“Etasmiṁ te sulapite,"
    },
    {
      "id": "ja440:10.2",
      "pali": "patirūpe subhāsite;"
    },
    {
      "id": "ja440:10.3",
      "pali": "Varaṁ brāhmaṇa te dammi,"
    },
    {
      "id": "ja440:10.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja440:11.1",
      "pali": "“Varañce me ado sakka,"
    },
    {
      "id": "ja440:11.2",
      "pali": "sabbabhūtānamissara;"
    },
    {
      "id": "ja440:11.3",
      "pali": "Araññe me viharato,"
    },
    {
      "id": "ja440:11.4",
      "pali": "niccaṁ ekavihārino;"
    },
    {
      "id": "ja440:11.5",
      "pali": "Ābādhā mā uppajjeyyuṁ,"
    },
    {
      "id": "ja440:11.6",
      "pali": "antarāyakarā bhusā”."
    },
    {
      "id": "ja440:12.1",
      "pali": "“Etasmiṁ te sulapite,"
    },
    {
      "id": "ja440:12.2",
      "pali": "patirūpe subhāsite;"
    },
    {
      "id": "ja440:12.3",
      "pali": "Varaṁ brāhmaṇa te dammi,"
    },
    {
      "id": "ja440:12.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja440:13.1",
      "pali": "“Varañce me ado sakka,"
    },
    {
      "id": "ja440:13.2",
      "pali": "sabbabhūtānamissara;"
    },
    {
      "id": "ja440:13.3",
      "pali": "Na mano vā sarīraṁ vā,"
    },
    {
      "id": "ja440:13.4",
      "pali": "maṁ-kate sakka kassaci;"
    },
    {
      "id": "ja440:13.5",
      "pali": "Kadāci upahaññetha,"
    },
    {
      "id": "ja440:13.6",
      "pali": "etaṁ sakka varaṁ vare”ti."
    },
    {
      "id": "ja440:14.1",
      "pali": "Kaṇhajātakaṁ dutiyaṁ."
    }
  ]
}
