{
  "uid": "thig1.13",
  "title": "Visākhātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.13:1.1",
      "pali": "“Karotha buddhasāsanaṁ,"
    },
    {
      "id": "thig1.13:1.2",
      "pali": "yaṁ katvā nānutappati;"
    },
    {
      "id": "thig1.13:1.3",
      "pali": "Khippaṁ pādāni dhovitvā,"
    },
    {
      "id": "thig1.13:1.4",
      "pali": "ekamante nisīdathā”ti."
    },
    {
      "id": "thig1.13:2.1",
      "pali": "… Visākhā therī …."
    }
  ]
}
