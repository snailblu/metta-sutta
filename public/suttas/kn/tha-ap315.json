{
  "uid": "tha-ap315",
  "title": "Gatasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap315:1.1",
      "pali": "“Ākāseva padaṁ natthi,"
    },
    {
      "id": "tha-ap315:1.2",
      "pali": "ambare anilañjase;"
    },
    {
      "id": "tha-ap315:1.3",
      "pali": "Siddhatthaṁ jinamaddakkhiṁ,"
    },
    {
      "id": "tha-ap315:1.4",
      "pali": "gacchantaṁ tidivaṅgaṇe."
    },
    {
      "id": "tha-ap315:2.1",
      "pali": "Anileneritaṁ disvā,"
    },
    {
      "id": "tha-ap315:2.2",
      "pali": "sammāsambuddhacīvaraṁ;"
    },
    {
      "id": "tha-ap315:2.3",
      "pali": "Vitti mamāhu tāvade,"
    },
    {
      "id": "tha-ap315:2.4",
      "pali": "disvāna gamanaṁ muniṁ."
    },
    {
      "id": "tha-ap315:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap315:3.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap315:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap315:3.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap315:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap315:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap315:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap315:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā gatasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap315:6.1",
      "pali": "Gatasaññakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
