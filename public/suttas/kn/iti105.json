{
  "uid": "iti105",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti105:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti105:2.1",
      "pali": "“Cattārome, bhikkhave, taṇhuppādā, yattha bhikkhuno taṇhā uppajjamānā uppajjati."
    },
    {
      "id": "iti105:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "iti105:2.3",
      "pali": "Cīvarahetu vā, bhikkhave, bhikkhuno taṇhā uppajjamānā uppajjati;"
    },
    {
      "id": "iti105:2.4",
      "pali": "piṇḍapātahetu vā, bhikkhave, bhikkhuno taṇhā uppajjamānā uppajjati;"
    },
    {
      "id": "iti105:2.5",
      "pali": "senāsanahetu vā, bhikkhave, bhikkhuno taṇhā uppajjamānā uppajjati;"
    },
    {
      "id": "iti105:2.6",
      "pali": "itibhavābhavahetu vā, bhikkhave, bhikkhuno taṇhā uppajjamānā uppajjati."
    },
    {
      "id": "iti105:2.7",
      "pali": "Ime kho, bhikkhave, cattāro taṇhuppādā yattha bhikkhuno taṇhā uppajjamānā uppajjatī”ti."
    },
    {
      "id": "iti105:2.8",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti105:2.9",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti105:3.1",
      "pali": "“Taṇhādutiyo puriso,"
    },
    {
      "id": "iti105:3.2",
      "pali": "dīghamaddhāna saṁsaraṁ;"
    },
    {
      "id": "iti105:3.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "iti105:3.4",
      "pali": "saṁsaraṁ nātivattati."
    },
    {
      "id": "iti105:4.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "iti105:4.2",
      "pali": "taṇhaṁ dukkhassa sambhavaṁ;"
    },
    {
      "id": "iti105:4.3",
      "pali": "Vītataṇho anādāno,"
    },
    {
      "id": "iti105:4.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "iti105:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti105:5.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
