{
  "uid": "ja298",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja298:1.1",
      "pali": "“Udumbarā cime pakkā,"
    },
    {
      "id": "ja298:1.2",
      "pali": "nigrodhā ca kapitthanā;"
    },
    {
      "id": "ja298:1.3",
      "pali": "Ehi nikkhama bhuñjassu,"
    },
    {
      "id": "ja298:1.4",
      "pali": "kiṁ jighacchāya miyyasi”."
    },
    {
      "id": "ja298:2.1",
      "pali": "“Evaṁ so suhito hoti,"
    },
    {
      "id": "ja298:2.2",
      "pali": "yo vuḍḍhamapacāyati;"
    },
    {
      "id": "ja298:2.3",
      "pali": "Yathāhamajja suhito,"
    },
    {
      "id": "ja298:2.4",
      "pali": "dumapakkāni māsito”."
    },
    {
      "id": "ja298:3.1",
      "pali": "“Yaṁ vanejo vanejassa,"
    },
    {
      "id": "ja298:3.2",
      "pali": "vañceyya kapino kapi;"
    },
    {
      "id": "ja298:3.3",
      "pali": "Daharo kapi saddheyya,"
    },
    {
      "id": "ja298:3.4",
      "pali": "na hi jiṇṇo jarākapī”ti."
    },
    {
      "id": "ja298:4.1",
      "pali": "Udumbarajātakaṁ aṭṭhamaṁ."
    }
  ]
}
