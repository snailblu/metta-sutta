{
  "uid": "ja349",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja349:1.1",
      "pali": "“Neva itthīsu sāmaññaṁ,"
    },
    {
      "id": "ja349:1.2",
      "pali": "nāpi bhakkhesu sārathi;"
    },
    {
      "id": "ja349:1.3",
      "pali": "Athassa sandhibhedassa,"
    },
    {
      "id": "ja349:1.4",
      "pali": "passa yāva sucintitaṁ."
    },
    {
      "id": "ja349:2.1",
      "pali": "Asi tikkhova maṁsamhi,"
    },
    {
      "id": "ja349:2.2",
      "pali": "pesuññaṁ parivattati;"
    },
    {
      "id": "ja349:2.3",
      "pali": "Yatthūsabhañca sīhañca,"
    },
    {
      "id": "ja349:2.4",
      "pali": "bhakkhayanti migādhamā."
    },
    {
      "id": "ja349:3.1",
      "pali": "Imaṁ so sayanaṁ seti,"
    },
    {
      "id": "ja349:3.2",
      "pali": "yamimaṁ passasi sārathi;"
    },
    {
      "id": "ja349:3.3",
      "pali": "Yo vācaṁ sandhibhedassa,"
    },
    {
      "id": "ja349:3.4",
      "pali": "pisuṇassa nibodhati."
    },
    {
      "id": "ja349:4.1",
      "pali": "Te janā sukhamedhanti,"
    },
    {
      "id": "ja349:4.2",
      "pali": "narā saggagatāriva;"
    },
    {
      "id": "ja349:4.3",
      "pali": "Ye vācaṁ sandhibhedassa,"
    },
    {
      "id": "ja349:4.4",
      "pali": "nāvabodhanti sārathī”ti."
    },
    {
      "id": "ja349:5.1",
      "pali": "Sandhibhedajātakaṁ navamaṁ."
    }
  ]
}
