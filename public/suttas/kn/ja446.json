{
  "uid": "ja446",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja446:1.1",
      "pali": "“Na takkalā santi na āluvāni,"
    },
    {
      "id": "ja446:1.2",
      "pali": "Na biḷāliyo na kaḷambāni tāta;"
    },
    {
      "id": "ja446:1.3",
      "pali": "Eko araññamhi susānamajjhe,"
    },
    {
      "id": "ja446:1.4",
      "pali": "Kimatthiko tāta khaṇāsi kāsuṁ”."
    },
    {
      "id": "ja446:2.1",
      "pali": "“Pitāmaho tāta sudubbalo te,"
    },
    {
      "id": "ja446:2.2",
      "pali": "Anekabyādhīhi dukhena phuṭṭho;"
    },
    {
      "id": "ja446:2.3",
      "pali": "Tamajjahaṁ nikhaṇissāmi sobbhe,"
    },
    {
      "id": "ja446:2.4",
      "pali": "Na hissa taṁ jīvitaṁ rocayāmi”."
    },
    {
      "id": "ja446:3.1",
      "pali": "“Saṅkappametaṁ paṭiladdha pāpakaṁ,"
    },
    {
      "id": "ja446:3.2",
      "pali": "Accāhitaṁ kamma karosi luddaṁ;"
    },
    {
      "id": "ja446:3.3",
      "pali": "Mayāpi tāta paṭilacchase tuvaṁ,"
    },
    {
      "id": "ja446:3.4",
      "pali": "Etādisaṁ kamma jarūpanīto;"
    },
    {
      "id": "ja446:3.5",
      "pali": "Taṁ kullavattaṁ anuvattamāno,"
    },
    {
      "id": "ja446:3.6",
      "pali": "Ahampi taṁ nikhaṇissāmi sobbhe”."
    },
    {
      "id": "ja446:4.1",
      "pali": "“Pharusāhi vācāhi pakubbamāno,"
    },
    {
      "id": "ja446:4.2",
      "pali": "Āsajja maṁ tvaṁ vadase kumāra;"
    },
    {
      "id": "ja446:4.3",
      "pali": "Putto mamaṁ orasako samāno,"
    },
    {
      "id": "ja446:4.4",
      "pali": "Ahitānukampī mama tvaṁsi putta”."
    },
    {
      "id": "ja446:5.1",
      "pali": "“Na tāhaṁ tāta ahitānukampī,"
    },
    {
      "id": "ja446:5.2",
      "pali": "Hitānukampī te ahampi tāta;"
    },
    {
      "id": "ja446:5.3",
      "pali": "Pāpañca taṁ kamma pakubbamānaṁ,"
    },
    {
      "id": "ja446:5.4",
      "pali": "Arahāmi no vārayituṁ tato”."
    },
    {
      "id": "ja446:6.1",
      "pali": "“Yo mātaraṁ vā pitaraṁ saviṭṭha,"
    },
    {
      "id": "ja446:6.2",
      "pali": "Adūsake hiṁsati pāpadhammo;"
    },
    {
      "id": "ja446:6.3",
      "pali": "Kāyassa bhedā abhisamparāyaṁ,"
    },
    {
      "id": "ja446:6.4",
      "pali": "Asaṁsayaṁ so nirayaṁ upeti."
    },
    {
      "id": "ja446:7.1",
      "pali": "Yo mātaraṁ vā pitaraṁ saviṭṭha,"
    },
    {
      "id": "ja446:7.2",
      "pali": "Annena pānena upaṭṭhahāti;"
    },
    {
      "id": "ja446:7.3",
      "pali": "Kāyassa bhedā abhisamparāyaṁ,"
    },
    {
      "id": "ja446:7.4",
      "pali": "Asaṁsayaṁ so sugatiṁ upeti."
    },
    {
      "id": "ja446:8.1",
      "pali": "Na me tvaṁ putta ahitānukampī,"
    },
    {
      "id": "ja446:8.2",
      "pali": "Hitānukampī me tvaṁsi putta;"
    },
    {
      "id": "ja446:8.3",
      "pali": "Ahañca taṁ mātarā vuccamāno,"
    },
    {
      "id": "ja446:8.4",
      "pali": "Etādisaṁ kamma karomi luddaṁ”."
    },
    {
      "id": "ja446:9.1",
      "pali": "“Yā te sā bhariyā anariyarūpā,"
    },
    {
      "id": "ja446:9.2",
      "pali": "Mātā mamesā sakiyā janetti;"
    },
    {
      "id": "ja446:9.3",
      "pali": "Niddhāpaye tañca sakā agārā,"
    },
    {
      "id": "ja446:9.4",
      "pali": "Aññampi te sā dukhamāvaheyya."
    },
    {
      "id": "ja446:10.1",
      "pali": "Yā te sā bhariyā anariyarūpā,"
    },
    {
      "id": "ja446:10.2",
      "pali": "Mātā mamesā sakiyā janetti;"
    },
    {
      "id": "ja446:10.3",
      "pali": "Dantā kareṇūva vasūpanītā,"
    },
    {
      "id": "ja446:10.4",
      "pali": "Sā pāpadhammā punarāvajātū”ti."
    },
    {
      "id": "ja446:11.1",
      "pali": "Takkalajātakaṁ aṭṭhamaṁ."
    }
  ]
}
