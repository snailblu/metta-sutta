{
  "uid": "iti85",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti85:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti85:2.1",
      "pali": "“Asubhānupassī, bhikkhave, kāyasmiṁ viharatha;"
    },
    {
      "id": "iti85:2.2",
      "pali": "ānāpānassati ca vo ajjhattaṁ parimukhaṁ sūpaṭṭhitā hotu;"
    },
    {
      "id": "iti85:2.3",
      "pali": "sabbasaṅkhāresu aniccānupassino viharatha."
    },
    {
      "id": "iti85:2.4",
      "pali": "Asubhānupassīnaṁ, bhikkhave, kāyasmiṁ viharataṁ yo subhāya dhātuyā rāgānusayo so pahīyati."
    },
    {
      "id": "iti85:2.5",
      "pali": "Ānāpānassatiyā ajjhattaṁ parimukhaṁ sūpaṭṭhititāya ye bāhirā vitakkāsayā vighātapakkhikā, te na honti."
    },
    {
      "id": "iti85:2.6",
      "pali": "Sabbasaṅkhāresu aniccānupassīnaṁ viharataṁ yā avijjā sā pahīyati, yā vijjā sā uppajjatī”ti."
    },
    {
      "id": "iti85:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti85:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti85:3.1",
      "pali": "“Asubhānupassī kāyasmiṁ,"
    },
    {
      "id": "iti85:3.2",
      "pali": "ānāpāne paṭissato;"
    },
    {
      "id": "iti85:3.3",
      "pali": "Sabbasaṅkhārasamathaṁ,"
    },
    {
      "id": "iti85:3.4",
      "pali": "passaṁ ātāpi sabbadā."
    },
    {
      "id": "iti85:4.1",
      "pali": "Sa ve sammaddaso bhikkhu,"
    },
    {
      "id": "iti85:4.2",
      "pali": "yato tattha vimuccati;"
    },
    {
      "id": "iti85:4.3",
      "pali": "Abhiññāvosito santo,"
    },
    {
      "id": "iti85:4.4",
      "pali": "sa ve yogātigo munī”ti."
    },
    {
      "id": "iti85:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti85:5.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
