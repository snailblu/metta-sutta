{
  "uid": "tha-ap114",
  "title": "Sumaṅgalattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap114:1.1",
      "pali": "“Atthadassī jinavaro,"
    },
    {
      "id": "tha-ap114:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap114:1.3",
      "pali": "Vihārā abhinikkhamma,"
    },
    {
      "id": "tha-ap114:1.4",
      "pali": "taḷākaṁ upasaṅkami."
    },
    {
      "id": "tha-ap114:2.1",
      "pali": "Nhatvā pitvā ca sambuddho,"
    },
    {
      "id": "tha-ap114:2.2",
      "pali": "uttaritvekacīvaro;"
    },
    {
      "id": "tha-ap114:2.3",
      "pali": "Aṭṭhāsi bhagavā tattha,"
    },
    {
      "id": "tha-ap114:2.4",
      "pali": "vilokento disodisaṁ."
    },
    {
      "id": "tha-ap114:3.1",
      "pali": "Bhavane upaviṭṭhohaṁ,"
    },
    {
      "id": "tha-ap114:3.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap114:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap114:3.4",
      "pali": "apphoṭesiṁ ahaṁ tadā."
    },
    {
      "id": "tha-ap114:4.1",
      "pali": "Sataraṁsiṁva jotantaṁ,"
    },
    {
      "id": "tha-ap114:4.2",
      "pali": "pabhāsantaṁva kañcanaṁ;"
    },
    {
      "id": "tha-ap114:4.3",
      "pali": "Naccagīte payuttohaṁ,"
    },
    {
      "id": "tha-ap114:4.4",
      "pali": "pañcaṅgatūriyamhi ca."
    },
    {
      "id": "tha-ap114:5.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap114:5.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap114:5.3",
      "pali": "Sabbe satte abhibhomi,"
    },
    {
      "id": "tha-ap114:5.4",
      "pali": "vipulo hoti me yaso."
    },
    {
      "id": "tha-ap114:6.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap114:6.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap114:6.3",
      "pali": "Attānaṁ tosayitvāna,"
    },
    {
      "id": "tha-ap114:6.4",
      "pali": "pare tosesi tvaṁ muni."
    },
    {
      "id": "tha-ap114:7.1",
      "pali": "Pariggahe nisīditvā,"
    },
    {
      "id": "tha-ap114:7.2",
      "pali": "hāsaṁ katvāna subbate;"
    },
    {
      "id": "tha-ap114:7.3",
      "pali": "Upaṭṭhahitvā sambuddhaṁ,"
    },
    {
      "id": "tha-ap114:7.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap114:8.1",
      "pali": "Soḷaseto kappasate,"
    },
    {
      "id": "tha-ap114:8.2",
      "pali": "dvinavaekacintitā;"
    },
    {
      "id": "tha-ap114:8.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap114:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap114:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap114:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap114:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap114:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumaṅgalo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap114:11.1",
      "pali": "Sumaṅgalattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
