{
  "uid": "bv23",
  "title": "23. Vessabhūbuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv23:1.1",
      "pali": "“Tattheva maṇḍakappamhi,"
    },
    {
      "id": "bv23:1.2",
      "pali": "asamo appaṭipuggalo;"
    },
    {
      "id": "bv23:1.3",
      "pali": "Vessabhū nāma nāmena,"
    },
    {
      "id": "bv23:1.4",
      "pali": "loke uppajji nāyako."
    },
    {
      "id": "bv23:2.1",
      "pali": "Ādittaṁ vata rāgaggi,"
    },
    {
      "id": "bv23:2.2",
      "pali": "taṇhānaṁ vijitaṁ tadā;"
    },
    {
      "id": "bv23:2.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "bv23:2.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "bv23:3.1",
      "pali": "Dhammacakkaṁ pavattente,"
    },
    {
      "id": "bv23:3.2",
      "pali": "vessabhūlokanāyake;"
    },
    {
      "id": "bv23:3.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv23:3.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv23:4.1",
      "pali": "Pakkante cārikaṁ raṭṭhe,"
    },
    {
      "id": "bv23:4.2",
      "pali": "lokajeṭṭhe narāsabhe;"
    },
    {
      "id": "bv23:4.3",
      "pali": "Sattatikoṭisahassānaṁ,"
    },
    {
      "id": "bv23:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv23:5.1",
      "pali": "Mahādiṭṭhiṁ vinodento,"
    },
    {
      "id": "bv23:5.2",
      "pali": "pāṭiheraṁ karoti so;"
    },
    {
      "id": "bv23:5.3",
      "pali": "Samāgatā naramarū,"
    },
    {
      "id": "bv23:5.4",
      "pali": "dasasahassī sadevake."
    },
    {
      "id": "bv23:6.1",
      "pali": "Mahāacchariyaṁ disvā,"
    },
    {
      "id": "bv23:6.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "bv23:6.3",
      "pali": "Devā ceva manussā ca,"
    },
    {
      "id": "bv23:6.4",
      "pali": "bujjhare saṭṭhikoṭiyo."
    },
    {
      "id": "bv23:7.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv23:7.2",
      "pali": "vessabhussa mahesino;"
    },
    {
      "id": "bv23:7.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv23:7.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv23:8.1",
      "pali": "Asītibhikkhusahassānaṁ,"
    },
    {
      "id": "bv23:8.2",
      "pali": "paṭhamo āsi samāgamo;"
    },
    {
      "id": "bv23:8.3",
      "pali": "Sattatibhikkhusahassānaṁ,"
    },
    {
      "id": "bv23:8.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv23:9.1",
      "pali": "Saṭṭhibhikkhusahassānaṁ,"
    },
    {
      "id": "bv23:9.2",
      "pali": "tatiyo āsi samāgamo;"
    },
    {
      "id": "bv23:9.3",
      "pali": "Jarādibhayabhītānaṁ,"
    },
    {
      "id": "bv23:9.4",
      "pali": "orasānaṁ mahesino."
    },
    {
      "id": "bv23:10.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv23:10.2",
      "pali": "sudassano nāma khattiyo;"
    },
    {
      "id": "bv23:10.3",
      "pali": "Nimantetvā mahāvīraṁ,"
    },
    {
      "id": "bv23:10.4",
      "pali": "dānaṁ datvā mahārahaṁ;"
    },
    {
      "id": "bv23:10.5",
      "pali": "Annapānena vatthena,"
    },
    {
      "id": "bv23:10.6",
      "pali": "sasaṅghaṁ jinapūjayiṁ."
    },
    {
      "id": "bv23:11.1",
      "pali": "Tassa buddhassa asamassa,"
    },
    {
      "id": "bv23:11.2",
      "pali": "cakkaṁ vattitamuttamaṁ;"
    },
    {
      "id": "bv23:11.3",
      "pali": "Sutvāna paṇitaṁ dhammaṁ,"
    },
    {
      "id": "bv23:11.4",
      "pali": "pabbajjamabhirocayiṁ."
    },
    {
      "id": "bv23:12.1",
      "pali": "Mahādānaṁ pavattetvā,"
    },
    {
      "id": "bv23:12.2",
      "pali": "rattindivamatandito;"
    },
    {
      "id": "bv23:12.3",
      "pali": "Pabbajjaṁ guṇasampannaṁ,"
    },
    {
      "id": "bv23:12.4",
      "pali": "pabbajiṁ jinasantike."
    },
    {
      "id": "bv23:13.1",
      "pali": "Ācāraguṇasampanno,"
    },
    {
      "id": "bv23:13.2",
      "pali": "vattasīlasamāhito;"
    },
    {
      "id": "bv23:13.3",
      "pali": "Sabbaññutaṁ gavesanto,"
    },
    {
      "id": "bv23:13.4",
      "pali": "ramāmi jinasāsane."
    },
    {
      "id": "bv23:14.1",
      "pali": "Saddhāpītiṁ upagantvā,"
    },
    {
      "id": "bv23:14.2",
      "pali": "buddhaṁ vandāmi sattharaṁ;"
    },
    {
      "id": "bv23:14.3",
      "pali": "Pīti uppajjati mayhaṁ,"
    },
    {
      "id": "bv23:14.4",
      "pali": "bodhiyāyeva kāraṇā."
    },
    {
      "id": "bv23:15.1",
      "pali": "Anivattamānasaṁ ñatvā,"
    },
    {
      "id": "bv23:15.2",
      "pali": "sambuddho etadabravi;"
    },
    {
      "id": "bv23:15.3",
      "pali": "‘Ekatiṁse ito kappe,"
    },
    {
      "id": "bv23:15.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv23:16.1",
      "pali": "Ahu kapilavhayā rammā,"
    },
    {
      "id": "bv23:16.2",
      "pali": "…pe…"
    },
    {
      "id": "bv23:16.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv23:17.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "bv23:17.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv23:17.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv23:17.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv23:18.1",
      "pali": "Anomaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv23:18.2",
      "pali": "suppatīto nāma khattiyo;"
    },
    {
      "id": "bv23:18.3",
      "pali": "Mātā yasavatī nāma,"
    },
    {
      "id": "bv23:18.4",
      "pali": "vessabhussa mahesino."
    },
    {
      "id": "bv23:19.1",
      "pali": "Cha ca vassasahassāni,"
    },
    {
      "id": "bv23:19.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv23:19.3",
      "pali": "Ruci suruci rativaḍḍhano,"
    },
    {
      "id": "bv23:19.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv23:20.1",
      "pali": "Anūnatiṁsasahassāni,"
    },
    {
      "id": "bv23:20.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv23:20.3",
      "pali": "Sucittā nāma sā nārī,"
    },
    {
      "id": "bv23:20.4",
      "pali": "suppabuddho nāma atrajo."
    },
    {
      "id": "bv23:21.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv23:21.2",
      "pali": "sivikāyābhinikkhami;"
    },
    {
      "id": "bv23:21.3",
      "pali": "Chamāsaṁ padhānacāraṁ,"
    },
    {
      "id": "bv23:21.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv23:22.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv23:22.2",
      "pali": "vessabhūlokanāyako;"
    },
    {
      "id": "bv23:22.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv23:22.4",
      "pali": "aruṇārāme naruttamo."
    },
    {
      "id": "bv23:23.1",
      "pali": "Soṇo ca uttaro ceva,"
    },
    {
      "id": "bv23:23.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv23:23.3",
      "pali": "Upasanto nāmupaṭṭhāko,"
    },
    {
      "id": "bv23:23.4",
      "pali": "vessabhussa mahesino."
    },
    {
      "id": "bv23:24.1",
      "pali": "Rāmā ceva samālā ca,"
    },
    {
      "id": "bv23:24.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv23:24.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv23:24.4",
      "pali": "mahāsāloti vuccati."
    },
    {
      "id": "bv23:25.1",
      "pali": "Sotthiko ceva rambho ca,"
    },
    {
      "id": "bv23:25.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv23:25.3",
      "pali": "Gotamī sirimā ceva,"
    },
    {
      "id": "bv23:25.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv23:26.1",
      "pali": "Saṭṭhiratanamubbedho,"
    },
    {
      "id": "bv23:26.2",
      "pali": "hemayūpasamūpamo;"
    },
    {
      "id": "bv23:26.3",
      "pali": "Kāyā niccharati rasmi,"
    },
    {
      "id": "bv23:26.4",
      "pali": "rattiṁva pabbate sikhī."
    },
    {
      "id": "bv23:27.1",
      "pali": "Saṭṭhivassasahassāni,"
    },
    {
      "id": "bv23:27.2",
      "pali": "āyu tassa mahesino;"
    },
    {
      "id": "bv23:27.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv23:27.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv23:28.1",
      "pali": "Dhammaṁ vitthārikaṁ katvā,"
    },
    {
      "id": "bv23:28.2",
      "pali": "vibhajitvā mahājanaṁ;"
    },
    {
      "id": "bv23:28.3",
      "pali": "Dhammanāvaṁ ṭhapetvāna,"
    },
    {
      "id": "bv23:28.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv23:29.1",
      "pali": "Dassaneyyaṁ sabbajanaṁ,"
    },
    {
      "id": "bv23:29.2",
      "pali": "vihāraṁ iriyāpathaṁ;"
    },
    {
      "id": "bv23:29.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv23:29.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv23:30.1",
      "pali": "Vessabhū jinavaro satthā,"
    },
    {
      "id": "bv23:30.2",
      "pali": "Khemārāmamhi nibbuto;"
    },
    {
      "id": "bv23:30.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv23:30.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv23:31.1",
      "pali": "Vessabhussa bhagavato vaṁso ekavīsatimo."
    }
  ]
}
