{
  "uid": "thag10.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.1:1.1",
      "pali": "“Aṅgārino dāni dumā bhadante,"
    },
    {
      "id": "thag10.1:1.2",
      "pali": "Phalesino chadanaṁ vippahāya;"
    },
    {
      "id": "thag10.1:1.3",
      "pali": "Te accimantova pabhāsayanti,"
    },
    {
      "id": "thag10.1:1.4",
      "pali": "Samayo mahāvīra bhāgī rasānaṁ."
    },
    {
      "id": "thag10.1:2.1",
      "pali": "Dumāni phullāni manoramāni,"
    },
    {
      "id": "thag10.1:2.2",
      "pali": "Samantato sabbadisā pavanti;"
    },
    {
      "id": "thag10.1:2.3",
      "pali": "Pattaṁ pahāya phalamāsasānā,"
    },
    {
      "id": "thag10.1:2.4",
      "pali": "Kālo ito pakkamanāya vīra."
    },
    {
      "id": "thag10.1:3.1",
      "pali": "Nevātisītaṁ na panātiuṇhaṁ,"
    },
    {
      "id": "thag10.1:3.2",
      "pali": "Sukhā utu addhaniyā bhadante;"
    },
    {
      "id": "thag10.1:3.3",
      "pali": "Passantu taṁ sākiyā koḷiyā ca,"
    },
    {
      "id": "thag10.1:3.4",
      "pali": "Pacchāmukhaṁ rohiniyaṁ tarantaṁ."
    },
    {
      "id": "thag10.1:4.1",
      "pali": "Āsāya kasate khettaṁ,"
    },
    {
      "id": "thag10.1:4.2",
      "pali": "bījaṁ āsāya vappati;"
    },
    {
      "id": "thag10.1:4.3",
      "pali": "Āsāya vāṇijā yanti,"
    },
    {
      "id": "thag10.1:4.4",
      "pali": "samuddaṁ dhanahārakā;"
    },
    {
      "id": "thag10.1:4.5",
      "pali": "Yāya āsāya tiṭṭhāmi,"
    },
    {
      "id": "thag10.1:4.6",
      "pali": "sā me āsā samijjhatu."
    },
    {
      "id": "thag10.1:5.1",
      "pali": "Punappunaṁ ceva vapanti bījaṁ,"
    },
    {
      "id": "thag10.1:5.2",
      "pali": "Punappunaṁ vassati devarājā;"
    },
    {
      "id": "thag10.1:5.3",
      "pali": "Punappunaṁ khettaṁ kasanti kassakā,"
    },
    {
      "id": "thag10.1:5.4",
      "pali": "Punappunaṁ dhaññamupeti raṭṭhaṁ."
    },
    {
      "id": "thag10.1:6.1",
      "pali": "Punappunaṁ yācanakā caranti,"
    },
    {
      "id": "thag10.1:6.2",
      "pali": "Punappunaṁ dānapatī dadanti;"
    },
    {
      "id": "thag10.1:6.3",
      "pali": "Punappunaṁ dānapatī daditvā,"
    },
    {
      "id": "thag10.1:6.4",
      "pali": "Punappunaṁ saggamupenti ṭhānaṁ."
    },
    {
      "id": "thag10.1:7.1",
      "pali": "Vīro have sattayugaṁ puneti,"
    },
    {
      "id": "thag10.1:7.2",
      "pali": "Yasmiṁ kule jāyati bhūripañño;"
    },
    {
      "id": "thag10.1:7.3",
      "pali": "Maññāmahaṁ sakkati devadevo,"
    },
    {
      "id": "thag10.1:7.4",
      "pali": "Tayā hi jāto muni saccanāmo."
    },
    {
      "id": "thag10.1:8.1",
      "pali": "Suddhodano nāma pitā mahesino,"
    },
    {
      "id": "thag10.1:8.2",
      "pali": "Buddhassa mātā pana māyanāmā;"
    },
    {
      "id": "thag10.1:8.3",
      "pali": "Yā bodhisattaṁ parihariya kucchinā,"
    },
    {
      "id": "thag10.1:8.4",
      "pali": "Kāyassa bhedā tidivamhi modati."
    },
    {
      "id": "thag10.1:9.1",
      "pali": "Sā gotamī kālakatā ito cutā,"
    },
    {
      "id": "thag10.1:9.2",
      "pali": "Dibbehi kāmehi samaṅgibhūtā;"
    },
    {
      "id": "thag10.1:9.3",
      "pali": "Sā modati kāmaguṇehi pañcahi,"
    },
    {
      "id": "thag10.1:9.4",
      "pali": "Parivāritā devagaṇehi tehi”."
    },
    {
      "id": "thag10.1:10.1",
      "pali": "“Buddhassa puttomhi asayhasāhino,"
    },
    {
      "id": "thag10.1:10.2",
      "pali": "Aṅgīrasassappaṭimassa tādino;"
    },
    {
      "id": "thag10.1:10.3",
      "pali": "Pitupitā mayhaṁ tuvaṁsi sakka,"
    },
    {
      "id": "thag10.1:10.4",
      "pali": "Dhammena me gotama ayyakosī”ti."
    },
    {
      "id": "thag10.1:10.5",
      "pali": "… Kāḷudāyī thero …."
    }
  ]
}
