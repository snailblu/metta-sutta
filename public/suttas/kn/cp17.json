{
  "uid": "cp17",
  "title": "Sīlapāramī 7",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp17:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp17:1.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "cp17:1.3",
      "pali": "Mātaṅgo nāma nāmena,"
    },
    {
      "id": "cp17:1.4",
      "pali": "sīlavā susamāhito."
    },
    {
      "id": "cp17:2.1",
      "pali": "Ahañca brāhmaṇo eko,"
    },
    {
      "id": "cp17:2.2",
      "pali": "gaṅgākūle vasāmubho;"
    },
    {
      "id": "cp17:2.3",
      "pali": "Ahaṁ vasāmi upari,"
    },
    {
      "id": "cp17:2.4",
      "pali": "heṭṭhā vasati brāhmaṇo."
    },
    {
      "id": "cp17:3.1",
      "pali": "Vicaranto anukūlamhi,"
    },
    {
      "id": "cp17:3.2",
      "pali": "uddhaṁ me assamaddasa;"
    },
    {
      "id": "cp17:3.3",
      "pali": "Tattha maṁ paribhāsetvā,"
    },
    {
      "id": "cp17:3.4",
      "pali": "abhisapi muddhaphālanaṁ."
    },
    {
      "id": "cp17:4.1",
      "pali": "Yadihaṁ tassa pakuppeyyaṁ,"
    },
    {
      "id": "cp17:4.2",
      "pali": "yadi sīlaṁ na gopaye;"
    },
    {
      "id": "cp17:4.3",
      "pali": "Oloketvānahaṁ tassa,"
    },
    {
      "id": "cp17:4.4",
      "pali": "kareyyaṁ chārikaṁ viya."
    },
    {
      "id": "cp17:5.1",
      "pali": "Yaṁ so tadā maṁ abhisapi,"
    },
    {
      "id": "cp17:5.2",
      "pali": "kupito duṭṭhamānaso;"
    },
    {
      "id": "cp17:5.3",
      "pali": "Tasseva matthake nipati,"
    },
    {
      "id": "cp17:5.4",
      "pali": "yogena taṁ pamocayiṁ."
    },
    {
      "id": "cp17:6.1",
      "pali": "Anurakkhiṁ mama sīlaṁ,"
    },
    {
      "id": "cp17:6.2",
      "pali": "nārakkhiṁ mama jīvitaṁ;"
    },
    {
      "id": "cp17:6.3",
      "pali": "Sīlavā hi tadā āsiṁ,"
    },
    {
      "id": "cp17:6.4",
      "pali": "bodhiyāyeva kāraṇā”ti."
    },
    {
      "id": "cp17:7.1",
      "pali": "Mātaṅgacariyaṁ sattamaṁ."
    }
  ]
}
