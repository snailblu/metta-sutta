{
  "uid": "tha-ap325",
  "title": "Hāsajanakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap325:1.1",
      "pali": "“Dumagge paṁsukūlakaṁ,"
    },
    {
      "id": "tha-ap325:1.2",
      "pali": "laggaṁ disvāna satthuno;"
    },
    {
      "id": "tha-ap325:1.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap325:1.4",
      "pali": "bhiyyo uccāritaṁ mayā."
    },
    {
      "id": "tha-ap325:2.1",
      "pali": "Dūrato pana disvāna,"
    },
    {
      "id": "tha-ap325:2.2",
      "pali": "hāso me udapajjatha;"
    },
    {
      "id": "tha-ap325:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap325:2.4",
      "pali": "bhiyyo cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap325:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap325:3.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap325:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap325:3.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap325:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap325:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap325:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap325:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā hāsajanako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap325:6.1",
      "pali": "Hāsajanakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
