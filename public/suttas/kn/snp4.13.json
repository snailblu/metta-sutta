{
  "uid": "snp4.13",
  "title": "Mahābyūhasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.13:1.1",
      "pali": "“Ye kecime diṭṭhiparibbasānā,"
    },
    {
      "id": "snp4.13:1.2",
      "pali": "Idameva saccanti vivādayanti;"
    },
    {
      "id": "snp4.13:1.3",
      "pali": "Sabbeva te nindamanvānayanti,"
    },
    {
      "id": "snp4.13:1.4",
      "pali": "Atho pasaṁsampi labhanti tattha”."
    },
    {
      "id": "snp4.13:2.1",
      "pali": "“Appañhi etaṁ na alaṁ samāya,"
    },
    {
      "id": "snp4.13:2.2",
      "pali": "Duve vivādassa phalāni brūmi;"
    },
    {
      "id": "snp4.13:2.3",
      "pali": "Etampi disvā na vivādayetha,"
    },
    {
      "id": "snp4.13:2.4",
      "pali": "Khemābhipassaṁ avivādabhūmiṁ”."
    },
    {
      "id": "snp4.13:3.1",
      "pali": "“Yā kācimā sammutiyo puthujjā,"
    },
    {
      "id": "snp4.13:3.2",
      "pali": "Sabbāva etā na upeti vidvā;"
    },
    {
      "id": "snp4.13:3.3",
      "pali": "Anūpayo so upayaṁ kimeyya,"
    },
    {
      "id": "snp4.13:3.4",
      "pali": "Diṭṭhe sute khantimakubbamāno”."
    },
    {
      "id": "snp4.13:4.1",
      "pali": "“Sīluttamā saññamenāhu suddhiṁ,"
    },
    {
      "id": "snp4.13:4.2",
      "pali": "Vataṁ samādāya upaṭṭhitāse;"
    },
    {
      "id": "snp4.13:4.3",
      "pali": "Idheva sikkhema athassa suddhiṁ,"
    },
    {
      "id": "snp4.13:4.4",
      "pali": "Bhavūpanītā kusalāvadānā."
    },
    {
      "id": "snp4.13:5.1",
      "pali": "Sace cuto sīlavatato hoti,"
    },
    {
      "id": "snp4.13:5.2",
      "pali": "Pavedhatī kamma virādhayitvā;"
    },
    {
      "id": "snp4.13:5.3",
      "pali": "Pajappatī patthayatī ca suddhiṁ,"
    },
    {
      "id": "snp4.13:5.4",
      "pali": "Satthāva hīno pavasaṁ gharamhā."
    },
    {
      "id": "snp4.13:6.1",
      "pali": "Sīlabbataṁ vāpi pahāya sabbaṁ,"
    },
    {
      "id": "snp4.13:6.2",
      "pali": "Kammañca sāvajjanavajjametaṁ;"
    },
    {
      "id": "snp4.13:6.3",
      "pali": "Suddhiṁ asuddhinti apatthayāno,"
    },
    {
      "id": "snp4.13:6.4",
      "pali": "Virato care santimanuggahāya."
    },
    {
      "id": "snp4.13:7.1",
      "pali": "Tamūpanissāya jigucchitaṁ vā,"
    },
    {
      "id": "snp4.13:7.2",
      "pali": "Atha vāpi diṭṭhaṁ va sutaṁ mutaṁ vā;"
    },
    {
      "id": "snp4.13:7.3",
      "pali": "Uddhaṁsarā suddhimanutthunanti,"
    },
    {
      "id": "snp4.13:7.4",
      "pali": "Avītataṇhāse bhavābhavesu."
    },
    {
      "id": "snp4.13:8.1",
      "pali": "Patthayamānassa hi jappitāni,"
    },
    {
      "id": "snp4.13:8.2",
      "pali": "Pavedhitaṁ vāpi pakappitesu;"
    },
    {
      "id": "snp4.13:8.3",
      "pali": "Cutūpapāto idha yassa natthi,"
    },
    {
      "id": "snp4.13:8.4",
      "pali": "Sa kena vedheyya kuhiṁ va jappe”."
    },
    {
      "id": "snp4.13:9.1",
      "pali": "“Yamāhu dhammaṁ paramanti eke,"
    },
    {
      "id": "snp4.13:9.2",
      "pali": "Tameva hīnanti panāhu aññe;"
    },
    {
      "id": "snp4.13:9.3",
      "pali": "Sacco nu vādo katamo imesaṁ,"
    },
    {
      "id": "snp4.13:9.4",
      "pali": "Sabbeva hīme kusalāvadānā”."
    },
    {
      "id": "snp4.13:10.1",
      "pali": "“Sakañhi dhammaṁ paripuṇṇamāhu,"
    },
    {
      "id": "snp4.13:10.2",
      "pali": "Aññassa dhammaṁ pana hīnamāhu;"
    },
    {
      "id": "snp4.13:10.3",
      "pali": "Evampi viggayha vivādayanti,"
    },
    {
      "id": "snp4.13:10.4",
      "pali": "Sakaṁ sakaṁ sammutimāhu saccaṁ."
    },
    {
      "id": "snp4.13:11.1",
      "pali": "Parassa ce vambhayitena hīno,"
    },
    {
      "id": "snp4.13:11.2",
      "pali": "Na koci dhammesu visesi assa;"
    },
    {
      "id": "snp4.13:11.3",
      "pali": "Puthū hi aññassa vadanti dhammaṁ,"
    },
    {
      "id": "snp4.13:11.4",
      "pali": "Nihīnato samhi daḷhaṁ vadānā."
    },
    {
      "id": "snp4.13:12.1",
      "pali": "Saddhammapūjāpi nesaṁ tatheva,"
    },
    {
      "id": "snp4.13:12.2",
      "pali": "Yathā pasaṁsanti sakāyanāni;"
    },
    {
      "id": "snp4.13:12.3",
      "pali": "Sabbeva vādā tathiyā bhaveyyuṁ,"
    },
    {
      "id": "snp4.13:12.4",
      "pali": "Suddhī hi nesaṁ paccattameva."
    },
    {
      "id": "snp4.13:13.1",
      "pali": "Na brāhmaṇassa paraneyyamatthi,"
    },
    {
      "id": "snp4.13:13.2",
      "pali": "Dhammesu niccheyya samuggahītaṁ;"
    },
    {
      "id": "snp4.13:13.3",
      "pali": "Tasmā vivādāni upātivatto,"
    },
    {
      "id": "snp4.13:13.4",
      "pali": "Na hi seṭṭhato passati dhammamaññaṁ."
    },
    {
      "id": "snp4.13:14.1",
      "pali": "Jānāmi passāmi tatheva etaṁ,"
    },
    {
      "id": "snp4.13:14.2",
      "pali": "Diṭṭhiyā eke paccenti suddhiṁ;"
    },
    {
      "id": "snp4.13:14.3",
      "pali": "Addakkhi ce kiñhi tumassa tena,"
    },
    {
      "id": "snp4.13:14.4",
      "pali": "Atisitvā aññena vadanti suddhiṁ."
    },
    {
      "id": "snp4.13:15.1",
      "pali": "Passaṁ naro dakkhati nāmarūpaṁ,"
    },
    {
      "id": "snp4.13:15.2",
      "pali": "Disvāna vā ñassati tānimeva;"
    },
    {
      "id": "snp4.13:15.3",
      "pali": "Kāmaṁ bahuṁ passatu appakaṁ vā,"
    },
    {
      "id": "snp4.13:15.4",
      "pali": "Na hi tena suddhiṁ kusalā vadanti."
    },
    {
      "id": "snp4.13:16.1",
      "pali": "Nivissavādī na hi subbināyo,"
    },
    {
      "id": "snp4.13:16.2",
      "pali": "Pakappitaṁ diṭṭhi purakkharāno;"
    },
    {
      "id": "snp4.13:16.3",
      "pali": "Yaṁ nissito tattha subhaṁ vadāno,"
    },
    {
      "id": "snp4.13:16.4",
      "pali": "Suddhiṁ vado tattha tathaddasā so."
    },
    {
      "id": "snp4.13:17.1",
      "pali": "Na brāhmaṇo kappamupeti saṅkhā,"
    },
    {
      "id": "snp4.13:17.2",
      "pali": "Na diṭṭhisārī napi ñāṇabandhu;"
    },
    {
      "id": "snp4.13:17.3",
      "pali": "Ñatvā ca so sammutiyo puthujjā,"
    },
    {
      "id": "snp4.13:17.4",
      "pali": "Upekkhatī uggahaṇanti maññe."
    },
    {
      "id": "snp4.13:18.1",
      "pali": "Vissajja ganthāni munīdha loke,"
    },
    {
      "id": "snp4.13:18.2",
      "pali": "Vivādajātesu na vaggasārī;"
    },
    {
      "id": "snp4.13:18.3",
      "pali": "Santo asantesu upekkhako so,"
    },
    {
      "id": "snp4.13:18.4",
      "pali": "Anuggaho uggahaṇanti maññe."
    },
    {
      "id": "snp4.13:19.1",
      "pali": "Pubbāsave hitvā nave akubbaṁ,"
    },
    {
      "id": "snp4.13:19.2",
      "pali": "Na chandagū nopi nivissavādī;"
    },
    {
      "id": "snp4.13:19.3",
      "pali": "Sa vippamutto diṭṭhigatehi dhīro,"
    },
    {
      "id": "snp4.13:19.4",
      "pali": "Na lippati loke anattagarahī."
    },
    {
      "id": "snp4.13:20.1",
      "pali": "Sa sabbadhammesu visenibhūto,"
    },
    {
      "id": "snp4.13:20.2",
      "pali": "Yaṁ kiñci diṭṭhaṁ va sutaṁ mutaṁ vā;"
    },
    {
      "id": "snp4.13:20.3",
      "pali": "Sa pannabhāro muni vippamutto,"
    },
    {
      "id": "snp4.13:20.4",
      "pali": "Na kappiyo nūparato na patthiyo”ti."
    },
    {
      "id": "snp4.13:20.5",
      "pali": "Mahābyūhasuttaṁ terasamaṁ."
    }
  ]
}
