{
  "uid": "thig2.9",
  "title": "Abhayātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.9:1.1",
      "pali": "“Abhaye bhiduro kāyo,"
    },
    {
      "id": "thig2.9:1.2",
      "pali": "yattha satā puthujjanā;"
    },
    {
      "id": "thig2.9:1.3",
      "pali": "Nikkhipissāmimaṁ dehaṁ,"
    },
    {
      "id": "thig2.9:1.4",
      "pali": "sampajānā satīmatī."
    },
    {
      "id": "thig2.9:2.1",
      "pali": "Bahūhi dukkhadhammehi,"
    },
    {
      "id": "thig2.9:2.2",
      "pali": "appamādaratāya me;"
    },
    {
      "id": "thig2.9:2.3",
      "pali": "Taṇhakkhayo anuppatto,"
    },
    {
      "id": "thig2.9:2.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig2.9:3.1",
      "pali": "… Abhayā therī …."
    }
  ]
}
