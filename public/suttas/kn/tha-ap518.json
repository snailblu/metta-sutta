{
  "uid": "tha-ap518",
  "title": "Ajjunapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap518:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap518:1.2",
      "pali": "ahosiṁ kinnaro tadā;"
    },
    {
      "id": "tha-ap518:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap518:1.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "tha-ap518:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap518:2.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap518:2.3",
      "pali": "Gahetvā ajjunaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap518:2.4",
      "pali": "sayambhuṁ abhipūjayiṁ."
    },
    {
      "id": "tha-ap518:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap518:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap518:3.3",
      "pali": "Jahitvā kinnaraṁ dehaṁ,"
    },
    {
      "id": "tha-ap518:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap518:4.1",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap518:4.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap518:4.3",
      "pali": "Dasakkhattuṁ cakkavattī,"
    },
    {
      "id": "tha-ap518:4.4",
      "pali": "mahārajjamakārayiṁ."
    },
    {
      "id": "tha-ap518:5.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap518:5.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap518:5.3",
      "pali": "Sukhette vappitaṁ bījaṁ,"
    },
    {
      "id": "tha-ap518:5.4",
      "pali": "sayambhumhi aho mama."
    },
    {
      "id": "tha-ap518:6.1",
      "pali": "Kusalaṁ vijjate mayhaṁ,"
    },
    {
      "id": "tha-ap518:6.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap518:6.3",
      "pali": "Pūjāraho ahaṁ ajja,"
    },
    {
      "id": "tha-ap518:6.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "tha-ap518:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap518:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap518:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap518:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap518:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap518:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap518:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap518:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap518:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap518:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā ajjunapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap518:11.1",
      "pali": "Ajjunapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
