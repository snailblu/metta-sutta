{
  "uid": "ja327",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja327:1.1",
      "pali": "“Vāti cāyaṁ tato gandho,"
    },
    {
      "id": "ja327:1.2",
      "pali": "yattha me vasatī piyā;"
    },
    {
      "id": "ja327:1.3",
      "pali": "Dūre ito hi kākavatī,"
    },
    {
      "id": "ja327:1.4",
      "pali": "yattha me nirato mano”."
    },
    {
      "id": "ja327:2.1",
      "pali": "“Kathaṁ samuddamatarī,"
    },
    {
      "id": "ja327:2.2",
      "pali": "kathaṁ atari kepukaṁ;"
    },
    {
      "id": "ja327:2.3",
      "pali": "Kathaṁ satta samuddāni,"
    },
    {
      "id": "ja327:2.4",
      "pali": "kathaṁ simbalimāruhi”."
    },
    {
      "id": "ja327:3.1",
      "pali": "“Tayā samuddamatariṁ,"
    },
    {
      "id": "ja327:3.2",
      "pali": "tayā atari kepukaṁ;"
    },
    {
      "id": "ja327:3.3",
      "pali": "Tayā satta samuddāni,"
    },
    {
      "id": "ja327:3.4",
      "pali": "tayā simbalimāruhiṁ”."
    },
    {
      "id": "ja327:4.1",
      "pali": "“Dhiratthumaṁ mahākāyaṁ,"
    },
    {
      "id": "ja327:4.2",
      "pali": "dhiratthumaṁ acetanaṁ;"
    },
    {
      "id": "ja327:4.3",
      "pali": "Yattha jāyāyahaṁ jāraṁ,"
    },
    {
      "id": "ja327:4.4",
      "pali": "āvahāmi vahāmi cā”ti."
    },
    {
      "id": "ja327:5.1",
      "pali": "Kākavatījātakaṁ sattamaṁ."
    }
  ]
}
