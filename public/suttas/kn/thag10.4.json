{
  "uid": "thag10.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.4:1.1",
      "pali": "“Dandhā mayhaṁ gatī āsi,"
    },
    {
      "id": "thag10.4:1.2",
      "pali": "paribhūto pure ahaṁ;"
    },
    {
      "id": "thag10.4:1.3",
      "pali": "Bhātā ca maṁ paṇāmesi,"
    },
    {
      "id": "thag10.4:1.4",
      "pali": "‘gaccha dāni tuvaṁ gharaṁ’."
    },
    {
      "id": "thag10.4:2.1",
      "pali": "Sohaṁ paṇāmito santo,"
    },
    {
      "id": "thag10.4:2.2",
      "pali": "saṅghārāmassa koṭṭhake;"
    },
    {
      "id": "thag10.4:2.3",
      "pali": "Dummano tattha aṭṭhāsiṁ,"
    },
    {
      "id": "thag10.4:2.4",
      "pali": "sāsanasmiṁ apekkhavā."
    },
    {
      "id": "thag10.4:3.1",
      "pali": "Bhagavā tattha āgacchi,"
    },
    {
      "id": "thag10.4:3.2",
      "pali": "sīsaṁ mayhaṁ parāmasi;"
    },
    {
      "id": "thag10.4:3.3",
      "pali": "Bāhāya maṁ gahetvāna,"
    },
    {
      "id": "thag10.4:3.4",
      "pali": "saṅghārāmaṁ pavesayi."
    },
    {
      "id": "thag10.4:4.1",
      "pali": "Anukampāya me satthā,"
    },
    {
      "id": "thag10.4:4.2",
      "pali": "pādāsi pādapuñchaniṁ;"
    },
    {
      "id": "thag10.4:4.3",
      "pali": "‘Etaṁ suddhaṁ adhiṭṭhehi,"
    },
    {
      "id": "thag10.4:4.4",
      "pali": "ekamantaṁ svadhiṭṭhitaṁ’."
    },
    {
      "id": "thag10.4:5.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thag10.4:5.2",
      "pali": "vihāsiṁ sāsane rato;"
    },
    {
      "id": "thag10.4:5.3",
      "pali": "Samādhiṁ paṭipādesiṁ,"
    },
    {
      "id": "thag10.4:5.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "thag10.4:6.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thag10.4:6.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thag10.4:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag10.4:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag10.4:7.1",
      "pali": "Sahassakkhattumattānaṁ,"
    },
    {
      "id": "thag10.4:7.2",
      "pali": "nimminitvāna panthako;"
    },
    {
      "id": "thag10.4:7.3",
      "pali": "Nisīdambavane ramme,"
    },
    {
      "id": "thag10.4:7.4",
      "pali": "yāva kālappavedanā."
    },
    {
      "id": "thag10.4:8.1",
      "pali": "Tato me satthā pāhesi,"
    },
    {
      "id": "thag10.4:8.2",
      "pali": "dūtaṁ kālappavedakaṁ;"
    },
    {
      "id": "thag10.4:8.3",
      "pali": "Paveditamhi kālamhi,"
    },
    {
      "id": "thag10.4:8.4",
      "pali": "vehāsādupasaṅkamiṁ."
    },
    {
      "id": "thag10.4:9.1",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "thag10.4:9.2",
      "pali": "ekamantaṁ nisīdahaṁ;"
    },
    {
      "id": "thag10.4:9.3",
      "pali": "Nisinnaṁ maṁ viditvāna,"
    },
    {
      "id": "thag10.4:9.4",
      "pali": "atha satthā paṭiggahi."
    },
    {
      "id": "thag10.4:10.1",
      "pali": "Āyāgo sabbalokassa,"
    },
    {
      "id": "thag10.4:10.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "thag10.4:10.3",
      "pali": "Puññakkhettaṁ manussānaṁ,"
    },
    {
      "id": "thag10.4:10.4",
      "pali": "paṭiggaṇhittha dakkhiṇan”ti."
    },
    {
      "id": "thag10.4:10.5",
      "pali": "… Cūḷapanthako thero …."
    }
  ]
}
