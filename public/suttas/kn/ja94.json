{
  "uid": "ja94",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja94:1.1",
      "pali": "Sotatto sosindo ceva,"
    },
    {
      "id": "ja94:1.2",
      "pali": "eko bhiṁsanake vane;"
    },
    {
      "id": "ja94:1.3",
      "pali": "Naggo na caggimāsīno,"
    },
    {
      "id": "ja94:1.4",
      "pali": "esanāpasuto munī”ti."
    },
    {
      "id": "ja94:2.1",
      "pali": "Lomahaṁsajātakaṁ catutthaṁ."
    }
  ]
}
