    },
    {
      "id": "thag16.5:19.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "thag16.5:19.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:20.1",
      "pali": "Yathāssa sāyarato rasaṁ,"
    },
    {
      "id": "thag16.5:20.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "thag16.5:20.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "thag16.5:20.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "thag16.5:20.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:20.6",
      "pali": "santike nibbāna vuccati."
    },
    {
      "id": "thag16.5:21.1",
      "pali": "Na so rajjati phassesu,"
    },
    {
      "id": "thag16.5:21.2",
