    {
      "id": "thag16.5:8.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "thag16.5:8.2",
      "pali": "anekā rasasambhavā;"
    },
    {
      "id": "thag16.5:8.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "thag16.5:8.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "thag16.5:8.5",
      "pali": "Evamācinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:8.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "thag16.5:9.1",
      "pali": "Phassaṁ phussa sati muṭṭhā,"
    },
    {
      "id": "thag16.5:9.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
