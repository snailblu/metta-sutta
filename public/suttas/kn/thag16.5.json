{
  "uid": "thag16.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.5:1.1",
      "pali": "“Rūpaṁ disvā sati muṭṭhā,"
    },
    {
      "id": "thag16.5:1.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "thag16.5:1.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag16.5:1.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:2.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "thag16.5:2.2",
      "pali": "anekā rūpasambhavā;"
    },
    {
      "id": "thag16.5:2.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "thag16.5:2.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "thag16.5:2.5",
      "pali": "Evamācinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:2.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "thag16.5:3.1",
      "pali": "Saddaṁ sutvā sati muṭṭhā,"
    },
    {
      "id": "thag16.5:3.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "thag16.5:3.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag16.5:3.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:4.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "thag16.5:4.2",
      "pali": "anekā saddasambhavā;"
    },
    {
      "id": "thag16.5:4.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "thag16.5:4.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "thag16.5:4.5",
      "pali": "Evamācinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:4.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "thag16.5:5.1",
      "pali": "Gandhaṁ ghatvā sati muṭṭhā,"
    },
    {
      "id": "thag16.5:5.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
