    },
    {
      "id": "thag16.5:21.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "thag16.5:21.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:22.1",
      "pali": "Yathāssa phusato phassaṁ,"
    },
    {
      "id": "thag16.5:22.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "thag16.5:22.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "thag16.5:22.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "thag16.5:22.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:22.6",
