    },
    {
      "id": "thag16.5:10.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "thag16.5:10.5",
      "pali": "Evamācinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:10.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "thag16.5:11.1",
      "pali": "Dhammaṁ ñatvā sati muṭṭhā,"
    },
    {
      "id": "thag16.5:11.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "thag16.5:11.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag16.5:11.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:12.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "thag16.5:12.2",
      "pali": "anekā dhammasambhavā;"
    },
    {
      "id": "thag16.5:12.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "thag16.5:12.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "thag16.5:12.5",
      "pali": "Evamācinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:12.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "thag16.5:13.1",
      "pali": "Na so rajjati rūpesu,"
    },
    {
      "id": "thag16.5:13.2",
      "pali": "rūpaṁ disvā patissato;"
    },
    {
      "id": "thag16.5:13.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "thag16.5:13.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:14.1",
      "pali": "Yathāssa passato rūpaṁ,"
    },
    {
      "id": "thag16.5:14.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "thag16.5:14.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "thag16.5:14.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "thag16.5:14.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:14.6",
      "pali": "santike nibbāna vuccati."
    },
    {
      "id": "thag16.5:15.1",
      "pali": "Na so rajjati saddesu,"
    },
    {
      "id": "thag16.5:15.2",
      "pali": "saddaṁ sutvā patissato;"
    },
    {
      "id": "thag16.5:15.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "thag16.5:15.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:16.1",
      "pali": "Yathāssa suṇato saddaṁ,"
    },
    {
      "id": "thag16.5:16.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "thag16.5:16.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "thag16.5:16.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "thag16.5:16.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:16.6",
      "pali": "santike nibbāna vuccati."
    },
    {
      "id": "thag16.5:17.1",
      "pali": "Na so rajjati gandhesu,"
    },
    {
      "id": "thag16.5:17.2",
      "pali": "gandhaṁ ghatvā patissato;"
    },
    {
      "id": "thag16.5:17.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "thag16.5:17.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:18.1",
      "pali": "Yathāssa ghāyato gandhaṁ,"
    },
    {
      "id": "thag16.5:18.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "thag16.5:18.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "thag16.5:18.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "thag16.5:18.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "thag16.5:18.6",
      "pali": "santike nibbāna vuccati."
    },
    {
      "id": "thag16.5:19.1",
      "pali": "Na so rajjati rasesu,"
    },
    {
      "id": "thag16.5:19.2",
