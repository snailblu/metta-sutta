      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag16.5:5.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "thag16.5:6.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "thag16.5:6.2",
      "pali": "anekā gandhasambhavā;"
    },
    {
      "id": "thag16.5:6.3",
