{
  "uid": "ja180",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja180:1.1",
      "pali": "“Duddadaṁ dadamānānaṁ,"
    },
    {
      "id": "ja180:1.2",
      "pali": "dukkaraṁ kamma kubbataṁ;"
    },
    {
      "id": "ja180:1.3",
      "pali": "Asanto nānukubbanti,"
    },
    {
      "id": "ja180:1.4",
      "pali": "sataṁ dhammo durannayo”."
    },
    {
      "id": "ja180:2.1",
      "pali": "“Tasmā satañca asataṁ,"
    },
    {
      "id": "ja180:2.2",
      "pali": "nānā hoti ito gati;"
    },
    {
      "id": "ja180:2.3",
      "pali": "Asanto nirayaṁ yanti,"
    },
    {
      "id": "ja180:2.4",
      "pali": "santo saggaparāyaṇāti."
    },
    {
      "id": "ja180:3.1",
      "pali": "Duddadajātakaṁ dasamaṁ."
    },
    {
      "id": "ja180:3.2",
      "pali": "Kalyāṇavaggo tatiyo."
    },
    {
      "id": "ja180:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja180:5.1",
      "pali": "Susamaññamigādhibhū māṇavako,"
    },
    {
      "id": "ja180:5.2",
      "pali": "Vāripahūtarūpādiccupaṭṭhānā;"
    },
    {
      "id": "ja180:5.3",
      "pali": "Sakaḷāyasatindukapaṅka puna,"
    },
    {
      "id": "ja180:5.4",
      "pali": "Satadhamma sududdadakena dasā”ti."
    }
  ]
}
