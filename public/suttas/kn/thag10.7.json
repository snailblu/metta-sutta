{
  "uid": "thag10.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.7:1.1",
      "pali": "“Vijāneyya sakaṁ atthaṁ,"
    },
    {
      "id": "thag10.7:1.2",
      "pali": "Avalokeyyātha pāvacanaṁ;"
    },
    {
      "id": "thag10.7:1.3",
      "pali": "Yañcettha assa patirūpaṁ,"
    },
    {
      "id": "thag10.7:1.4",
      "pali": "Sāmaññaṁ ajjhupagatassa."
    },
    {
      "id": "thag10.7:2.1",
      "pali": "Mittaṁ idha ca kalyāṇaṁ,"
    },
    {
      "id": "thag10.7:2.2",
      "pali": "Sikkhā vipulaṁ samādānaṁ;"
    },
    {
      "id": "thag10.7:2.3",
      "pali": "Sussūsā ca garūnaṁ,"
    },
    {
      "id": "thag10.7:2.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:3.1",
      "pali": "Buddhesu sagāravatā,"
    },
    {
      "id": "thag10.7:3.2",
      "pali": "Dhamme apaciti yathābhūtaṁ;"
    },
    {
      "id": "thag10.7:3.3",
      "pali": "Saṅghe ca cittikāro,"
    },
    {
      "id": "thag10.7:3.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:4.1",
      "pali": "Ācāragocare yutto,"
    },
    {
      "id": "thag10.7:4.2",
      "pali": "Ājīvo sodhito agārayho;"
    },
    {
      "id": "thag10.7:4.3",
      "pali": "Cittassa ca saṇṭhapanaṁ,"
    },
    {
      "id": "thag10.7:4.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:5.1",
      "pali": "Cārittaṁ atha vārittaṁ,"
    },
    {
      "id": "thag10.7:5.2",
      "pali": "Iriyāpathiyaṁ pasādaniyaṁ;"
    },
    {
      "id": "thag10.7:5.3",
      "pali": "Adhicitte ca āyogo,"
    },
    {
      "id": "thag10.7:5.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:6.1",
      "pali": "Āraññakāni senāsanāni,"
    },
    {
      "id": "thag10.7:6.2",
      "pali": "Pantāni appasaddāni;"
    },
    {
      "id": "thag10.7:6.3",
      "pali": "Bhajitabbāni muninā,"
    },
    {
      "id": "thag10.7:6.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:7.1",
      "pali": "Sīlañca bāhusaccañca,"
    },
    {
      "id": "thag10.7:7.2",
      "pali": "Dhammānaṁ pavicayo yathābhūtaṁ;"
    },
    {
      "id": "thag10.7:7.3",
      "pali": "Saccānaṁ abhisamayo,"
    },
    {
      "id": "thag10.7:7.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:8.1",
      "pali": "Bhāveyya ca aniccanti,"
    },
    {
      "id": "thag10.7:8.2",
      "pali": "Anattasaññaṁ asubhasaññañca;"
    },
    {
      "id": "thag10.7:8.3",
      "pali": "Lokamhi ca anabhiratiṁ,"
    },
    {
      "id": "thag10.7:8.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:9.1",
      "pali": "Bhāveyya ca bojjhaṅge,"
    },
    {
      "id": "thag10.7:9.2",
      "pali": "Iddhipādāni indriyāni balāni;"
    },
    {
      "id": "thag10.7:9.3",
      "pali": "Aṭṭhaṅgamaggamariyaṁ,"
    },
    {
      "id": "thag10.7:9.4",
      "pali": "Etaṁ samaṇassa patirūpaṁ."
    },
    {
      "id": "thag10.7:10.1",
      "pali": "Taṇhaṁ pajaheyya muni,"
    },
    {
      "id": "thag10.7:10.2",
      "pali": "Samūlake āsave padāleyya;"
    },
    {
      "id": "thag10.7:10.3",
      "pali": "Vihareyya vippamutto,"
    },
    {
      "id": "thag10.7:10.4",
      "pali": "Etaṁ samaṇassa patirūpan”ti."
    },
    {
      "id": "thag10.7:10.5",
      "pali": "… Gotamo thero …"
    },
    {
      "id": "thag10.7:10.6",
      "pali": "Dasakanipāto niṭṭhito."
    },
    {
      "id": "thag10.7:11.1",
      "pali": "Kāḷudāyī ca so thero,"
    },
    {
      "id": "thag10.7:11.2",
      "pali": "ekavihārī ca kappino;"
    },
    {
      "id": "thag10.7:11.3",
      "pali": "Cūḷapanthako kappo ca,"
    },
    {
      "id": "thag10.7:11.4",
      "pali": "upaseno ca gotamo;"
    },
    {
      "id": "thag10.7:11.5",
      "pali": "Sattime dasake therā,"
    },
    {
      "id": "thag10.7:11.6",
      "pali": "gāthāyo cettha sattatīti."
    }
  ]
}
