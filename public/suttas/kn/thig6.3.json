{
  "uid": "thig6.3",
  "title": "Khemātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.3:1.1",
      "pali": "“Daharā tvaṁ rūpavatī,"
    },
    {
      "id": "thig6.3:1.2",
      "pali": "ahampi daharo yuvā;"
    },
    {
      "id": "thig6.3:1.3",
      "pali": "Pañcaṅgikena turiyena,"
    },
    {
      "id": "thig6.3:1.4",
      "pali": "ehi kheme ramāmase”."
    },
    {
      "id": "thig6.3:2.1",
      "pali": "“Iminā pūtikāyena,"
    },
    {
      "id": "thig6.3:2.2",
      "pali": "āturena pabhaṅgunā;"
    },
    {
      "id": "thig6.3:2.3",
      "pali": "Aṭṭiyāmi harāyāmi,"
    },
    {
      "id": "thig6.3:2.4",
      "pali": "kāmataṇhā samūhatā."
    },
    {
      "id": "thig6.3:3.1",
      "pali": "Sattisūlūpamā kāmā,"
    },
    {
      "id": "thig6.3:3.2",
      "pali": "khandhāsaṁ adhikuṭṭanā;"
    },
    {
      "id": "thig6.3:3.3",
      "pali": "Yaṁ ‘tvaṁ kāmaratiṁ’ brūsi,"
    },
    {
      "id": "thig6.3:3.4",
      "pali": "‘aratī’ dāni sā mama."
    },
    {
      "id": "thig6.3:4.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig6.3:4.2",
      "pali": "tamokhandho padālito;"
    },
    {
      "id": "thig6.3:4.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig6.3:4.4",
      "pali": "nihato tvamasi antaka."
    },
    {
      "id": "thig6.3:5.1",
      "pali": "Nakkhattāni namassantā,"
    },
    {
      "id": "thig6.3:5.2",
      "pali": "aggiṁ paricaraṁ vane;"
    },
    {
      "id": "thig6.3:5.3",
      "pali": "Yathābhuccamajānantā,"
    },
    {
      "id": "thig6.3:5.4",
      "pali": "bālā suddhimamaññatha."
    },
    {
      "id": "thig6.3:6.1",
      "pali": "Ahañca kho namassantī,"
    },
    {
      "id": "thig6.3:6.2",
      "pali": "sambuddhaṁ purisuttamaṁ;"
    },
    {
      "id": "thig6.3:6.3",
      "pali": "Pamuttā sabbadukkhehi,"
    },
    {
      "id": "thig6.3:6.4",
      "pali": "satthusāsanakārikā”ti."
    },
    {
      "id": "thig6.3:7.1",
      "pali": "… Khemā therī …."
    }
  ]
}
