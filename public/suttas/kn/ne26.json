{
  "uid": "ne26",
  "title": "Sampāta 7",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne26:1.1",
      "pali": "Tattha katamo āvaṭṭo hārasampāto?"
    },
    {
      "id": "ne26:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne26:2.2",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti samatho."
    },
    {
      "id": "ne26:2.3",
      "pali": "“Sammādiṭṭhipurekkhāro”ti vipassanā."
    },
    {
      "id": "ne26:2.4",
      "pali": "“Ñatvāna udayabbayan”ti dukkhapariññā."
    },
    {
      "id": "ne26:2.5",
      "pali": "“Thinamiddhābhibhū bhikkhū”ti samudayapahānaṁ."
    },
    {
      "id": "ne26:2.6",
      "pali": "“Sabbā duggatiyo jahe”ti nirodho."
    },
    {
      "id": "ne26:2.7",
      "pali": "Imāni cattāri saccāni."
    },
    {
      "id": "ne26:2.8",
      "pali": "Niyutto āvaṭṭo hārasampāto."
    }
  ]
}
