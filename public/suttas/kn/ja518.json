{
  "uid": "ja518",
  "title": "Kiṁchandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja518:1.1",
      "pali": "“Vikiṇṇavācaṁ aniguyha mantaṁ,"
    },
    {
      "id": "ja518:1.2",
      "pali": "Asaññataṁ aparicakkhitāraṁ;"
    },
    {
      "id": "ja518:1.3",
      "pali": "Bhayaṁ tamanveti sayaṁ abodhaṁ,"
    },
    {
      "id": "ja518:1.4",
      "pali": "Nāgaṁ yathā paṇḍarakaṁ supaṇṇo."
    },
    {
      "id": "ja518:2.1",
      "pali": "Yo guyhamantaṁ parirakkhaṇeyyaṁ,"
    },
    {
      "id": "ja518:2.2",
      "pali": "Mohā naro saṁsati hāsamāno;"
    },
    {
      "id": "ja518:2.3",
      "pali": "Taṁ bhinnamantaṁ bhayamanveti khippaṁ,"
    },
    {
      "id": "ja518:2.4",
      "pali": "Nāgaṁ yathā paṇḍarakaṁ supaṇṇo."
    },
    {
      "id": "ja518:3.1",
      "pali": "Nānumitto garuṁ atthaṁ,"
    },
    {
      "id": "ja518:3.2",
      "pali": "guyhaṁ veditumarahati;"
    },
    {
      "id": "ja518:3.3",
      "pali": "Sumitto ca asambuddhaṁ,"
    },
    {
      "id": "ja518:3.4",
      "pali": "sambuddhaṁ vā anatthavā."
    },
    {
      "id": "ja518:4.1",
      "pali": "Vissāsamāpajjimahaṁ acelaṁ,"
    },
    {
      "id": "ja518:4.2",
      "pali": "Samaṇo ayaṁ sammato bhāvitatto;"
    },
    {
      "id": "ja518:4.3",
      "pali": "Tassāhamakkhiṁ vivariṁ guyhamatthaṁ,"
    },
    {
      "id": "ja518:4.4",
      "pali": "Atītamattho kapaṇaṁ rudāmi."
    },
    {
      "id": "ja518:5.1",
      "pali": "Tassāhaṁ paramaṁ brahme guyhaṁ,"
    },
    {
      "id": "ja518:5.2",
      "pali": "Vācañhi maṁ nāsakkhiṁ saṁyametuṁ;"
    },
    {
      "id": "ja518:5.3",
      "pali": "Tappakkhato hi bhayamāgataṁ mamaṁ,"
    },
    {
      "id": "ja518:5.4",
      "pali": "Atītamattho kapaṇaṁ rudāmi."
    },
    {
      "id": "ja518:6.1",
      "pali": "Yo ve naro suhadaṁ maññamāno,"
    },
    {
      "id": "ja518:6.2",
      "pali": "Guyhamatthaṁ saṁsati dukkulīne;"
    },
    {
      "id": "ja518:6.3",
      "pali": "Dosā bhayā athavā rāgarattā,"
    },
    {
      "id": "ja518:6.4",
      "pali": "Pallatthito bālo asaṁsayaṁ so."
    },
    {
      "id": "ja518:7.1",
      "pali": "Tirokkhavāco asataṁ paviṭṭho,"
    },
    {
      "id": "ja518:7.2",
      "pali": "Yo saṅgatīsu mudīreti vākyaṁ;"
    },
    {
      "id": "ja518:7.3",
      "pali": "Āsīviso dummukhotyāhu taṁ naraṁ,"
    },
    {
      "id": "ja518:7.4",
      "pali": "Ārā ārā saṁyame tādisamhā."
    },
    {
      "id": "ja518:8.1",
      "pali": "Annaṁ pānaṁ kāsikacandanañca,"
    },
    {
      "id": "ja518:8.2",
      "pali": "Manāpitthiyo mālamucchādanañca;"
    },
    {
      "id": "ja518:8.3",
      "pali": "Ohāya gacchāmase sabbakāme,"
    },
    {
      "id": "ja518:8.4",
      "pali": "Supaṇṇa pāṇūpagatāva tyamhā”."
    },
    {
      "id": "ja518:9.1",
      "pali": "“Ko nīdha tiṇṇaṁ garahaṁ upeti,"
    },
    {
      "id": "ja518:9.2",
      "pali": "Asmiṁdhaloke pāṇabhū nāgarāja;"
    },
    {
      "id": "ja518:9.3",
      "pali": "Samaṇo supaṇṇo athavā tvameva,"
    },
    {
      "id": "ja518:9.4",
      "pali": "Kiṁ kāraṇā paṇḍarakaggahīto”."
    },
    {
      "id": "ja518:10.1",
      "pali": "“Samaṇoti me sammatatto ahosi,"
    },
    {
      "id": "ja518:10.2",
      "pali": "Piyo ca me manasā bhāvitatto;"
    },
    {
      "id": "ja518:10.3",
      "pali": "Tassāhamakkhiṁ vivariṁ guyhamatthaṁ,"
    },
    {
      "id": "ja518:10.4",
      "pali": "Atītamattho kapaṇaṁ rudāmi”."
    },
    {
      "id": "ja518:11.1",
      "pali": "“Na catthi satto amaro pathabyā,"
    },
    {
      "id": "ja518:11.2",
      "pali": "Paññāvidhā natthi na ninditabbā;"
    },
    {
      "id": "ja518:11.3",
      "pali": "Saccena dhammena dhitiyā damena,"
    },
    {
      "id": "ja518:11.4",
      "pali": "Alabbhamabyāharatī naro idha."
    },
    {
      "id": "ja518:12.1",
      "pali": "Mātāpitā paramā bandhavānaṁ,"
    },
    {
      "id": "ja518:12.2",
      "pali": "Nāssa tatiyo anukampakatthi;"
    },
    {
      "id": "ja518:12.3",
      "pali": "Tesampi guyhaṁ paramaṁ na saṁse,"
    },
    {
      "id": "ja518:12.4",
      "pali": "Mantassa bhedaṁ parisaṅkamāno."
    },
    {
      "id": "ja518:13.1",
      "pali": "Mātāpitā bhaginī bhātaro ca,"
    },
    {
      "id": "ja518:13.2",
      "pali": "Sahāyā vā yassa honti sapakkhā;"
    },
    {
      "id": "ja518:13.3",
      "pali": "Tesampi guyhaṁ paramaṁ na saṁse,"
    },
    {
      "id": "ja518:13.4",
      "pali": "Mantassa bhedaṁ parisaṅkamāno."
    },
    {
      "id": "ja518:14.1",
      "pali": "Bhariyā ce purisaṁ vajjā,"
    },
    {
      "id": "ja518:14.2",
      "pali": "Komārī piyabhāṇinī;"
    },
    {
      "id": "ja518:14.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja518:14.4",
      "pali": "Ñātisaṅghapurakkhatā;"
    },
    {
      "id": "ja518:14.5",
      "pali": "Tassāpi guyhaṁ paramaṁ na saṁse,"
    },
    {
      "id": "ja518:14.6",
      "pali": "Mantassa bhedaṁ parisaṅkamāno."
    },
    {
      "id": "ja518:15.1",
      "pali": "Na guyhamatthaṁ vivareyya,"
    },
    {
      "id": "ja518:15.2",
      "pali": "Rakkheyya naṁ yathā nidhiṁ;"
    },
    {
      "id": "ja518:15.3",
      "pali": "Na hi pātukato sādhu,"
    },
    {
      "id": "ja518:15.4",
      "pali": "Guyho attho pajānatā."
    },
    {
      "id": "ja518:16.1",
      "pali": "Thiyā guyhaṁ na saṁseyya,"
    },
    {
      "id": "ja518:16.2",
      "pali": "amittassa ca paṇḍito;"
    },
    {
      "id": "ja518:16.3",
      "pali": "Yo cāmisena saṁhīro,"
    },
    {
      "id": "ja518:16.4",
      "pali": "hadayattheno ca yo naro."
    },
    {
      "id": "ja518:17.1",
      "pali": "Guyhamatthaṁ asambuddhaṁ,"
    },
    {
      "id": "ja518:17.2",
      "pali": "sambodhayati yo naro;"
    },
    {
      "id": "ja518:17.3",
      "pali": "Mantabhedabhayā tassa,"
    },
    {
      "id": "ja518:17.4",
      "pali": "dāsabhūto titikkhati."
    },
    {
      "id": "ja518:18.1",
      "pali": "Yāvanto purisassatthaṁ,"
    },
    {
      "id": "ja518:18.2",
      "pali": "guyhaṁ jānanti mantinaṁ;"
    },
    {
      "id": "ja518:18.3",
      "pali": "Tāvanto tassa ubbegā,"
    },
    {
      "id": "ja518:18.4",
      "pali": "tasmā guyhaṁ na vissaje."
    },
    {
      "id": "ja518:19.1",
      "pali": "Vivicca bhāseyya divā rahassaṁ,"
    },
    {
      "id": "ja518:19.2",
      "pali": "Rattiṁ giraṁ nātivelaṁ pamuñce;"
    },
    {
      "id": "ja518:19.3",
      "pali": "Upassutikā hi suṇanti mantaṁ,"
    },
    {
      "id": "ja518:19.4",
      "pali": "Tasmā manto khippamupeti bhedaṁ."
    },
    {
      "id": "ja518:20.1",
      "pali": "Yathāpi assa nagaraṁ mahantaṁ,"
    },
    {
      "id": "ja518:20.2",
      "pali": "Advārakaṁ āyasaṁ bhaddasālaṁ;"
    },
    {
      "id": "ja518:20.3",
      "pali": "Samantakhātāparikhāupetaṁ,"
    },
    {
      "id": "ja518:20.4",
      "pali": "Evampi me te idha guyhamantā."
    },
    {
      "id": "ja518:21.1",
      "pali": "Ye guyhamantā avikiṇṇavācā,"
    },
    {
      "id": "ja518:21.2",
      "pali": "Daḷhā sadatthesu narā dujivha;"
    },
    {
      "id": "ja518:21.3",
      "pali": "Ārā amittā byavajanti tehi,"
    },
    {
      "id": "ja518:21.4",
      "pali": "Āsīvisā vā riva sattusaṅghā”."
    },
    {
      "id": "ja518:22.1",
      "pali": "“Hitvā gharaṁ pabbajito acelo,"
    },
    {
      "id": "ja518:22.2",
      "pali": "Naggo muṇḍo carati ghāsahetu;"
    },
    {
      "id": "ja518:22.3",
      "pali": "Tamhi nu kho vivariṁ guyhamatthaṁ,"
    },
    {
      "id": "ja518:22.4",
      "pali": "Atthā ca dhammā ca apaggatamhā."
    },
    {
      "id": "ja518:23.1",
      "pali": "Kathaṅkaro hoti supaṇṇarāja,"
    },
    {
      "id": "ja518:23.2",
      "pali": "Kiṁsīlo kena vatena vattaṁ;"
    },
    {
      "id": "ja518:23.3",
      "pali": "Samaṇo caraṁ hitvā mamāyitāni,"
    },
    {
      "id": "ja518:23.4",
      "pali": "Kathaṅkaro saggamupeti ṭhānaṁ”."
    },
    {
      "id": "ja518:24.1",
      "pali": "“Hiriyā titikkhāya damenupeto,"
    },
    {
      "id": "ja518:24.2",
      "pali": "Akkodhano pesuṇiyaṁ pahāya;"
    },
    {
      "id": "ja518:24.3",
      "pali": "Samaṇo caraṁ hitvā mamāyitāni,"
    },
    {
      "id": "ja518:24.4",
      "pali": "Evaṅkaro saggamupeti ṭhānaṁ”."
    },
    {
      "id": "ja518:25.1",
      "pali": "“Mātāva puttaṁ taruṇaṁ tanujjaṁ,"
    },
    {
      "id": "ja518:25.2",
      "pali": "Samphassatā sabbagattaṁ phareti;"
    },
    {
      "id": "ja518:25.3",
      "pali": "Evampi me tvaṁ pāturahu dijinda,"
    },
    {
      "id": "ja518:25.4",
      "pali": "Mātāva puttaṁ anukampamāno”."
    },
    {
      "id": "ja518:26.1",
      "pali": "“Handajja tvaṁ muñca vadhā dujivha,"
    },
    {
      "id": "ja518:26.2",
      "pali": "Tayo hi puttā na hi añño atthi;"
    },
    {
      "id": "ja518:26.3",
      "pali": "Antevāsī dinnako atrajo ca,"
    },
    {
      "id": "ja518:26.4",
      "pali": "Rajjassu puttaññataro me ahosi”."
    },
    {
      "id": "ja518:27.1",
      "pali": "Icceva vākyaṁ visajjī supaṇṇo,"
    },
    {
      "id": "ja518:27.2",
      "pali": "Bhumyaṁ patiṭṭhāya dijo dujivhaṁ;"
    },
    {
      "id": "ja518:27.3",
      "pali": "“Muttajja tvaṁ sabbabhayātivatto,"
    },
    {
      "id": "ja518:27.4",
      "pali": "Thalūdake hohi mayābhigutto."
    },
    {
      "id": "ja518:28.1",
      "pali": "Ātaṅkinaṁ yathā kusalo bhisakko,"
    },
    {
      "id": "ja518:28.2",
      "pali": "Pipāsitānaṁ rahadova sīto;"
    },
    {
      "id": "ja518:28.3",
      "pali": "Vesmaṁ yathā himasītaṭṭitānaṁ,"
    },
    {
      "id": "ja518:28.4",
      "pali": "Evampi te saraṇamahaṁ bhavāmi”."
    },
    {
      "id": "ja518:29.1",
      "pali": "“Sandhiṁ katvā amittena,"
    },
    {
      "id": "ja518:29.2",
      "pali": "aṇḍajena jalābuja;"
    },
    {
      "id": "ja518:29.3",
      "pali": "Vivariya dāṭhaṁ sesi,"
    },
    {
      "id": "ja518:29.4",
      "pali": "kuto taṁ bhayamāgataṁ”."
    },
    {
      "id": "ja518:30.1",
      "pali": "“Saṅketheva amittasmiṁ,"
    },
    {
      "id": "ja518:30.2",
      "pali": "mittasmimpi na vissase;"
    },
    {
      "id": "ja518:30.3",
      "pali": "Abhayā bhayamuppannaṁ,"
    },
    {
      "id": "ja518:30.4",
      "pali": "api mūlāni kantati."
    },
    {
      "id": "ja518:31.1",
      "pali": "Kathaṁ nu vissase tyamhi,"
    },
    {
      "id": "ja518:31.2",
      "pali": "yenāsi kalaho kato;"
    },
    {
      "id": "ja518:31.3",
      "pali": "Niccayattena ṭhātabbaṁ,"
    },
    {
      "id": "ja518:31.4",
      "pali": "so disabbhi na rajjati."
    },
    {
      "id": "ja518:32.1",
      "pali": "Vissāsaye na ca taṁ vissayeyya,"
    },
    {
      "id": "ja518:32.2",
      "pali": "Asaṅkito saṅkito ca bhaveyya;"
    },
    {
      "id": "ja518:32.3",
      "pali": "Tathā tathā viññū parakkameyya,"
    },
    {
      "id": "ja518:32.4",
      "pali": "Yathā yathā bhāvaṁ paro na jaññā”."
    },
    {
      "id": "ja518:33.1",
      "pali": "Te devavaṇṇā sukhumālarūpā,"
    },
    {
      "id": "ja518:33.2",
      "pali": "Ubho samā sujayā puññakhandhā;"
    },
    {
      "id": "ja518:33.3",
      "pali": "Upāgamuṁ karampiyaṁ acelaṁ,"
    },
    {
      "id": "ja518:33.4",
      "pali": "Missībhūtā assavāhāva nāgā."
    },
    {
      "id": "ja518:34.1",
      "pali": "Tato have paṇḍarako acelaṁ,"
    },
    {
      "id": "ja518:34.2",
      "pali": "Sayamevupāgamma idaṁ avoca;"
    },
    {
      "id": "ja518:34.3",
      "pali": "“Muttajjahaṁ sabbabhayātivatto,"
    },
    {
      "id": "ja518:34.4",
      "pali": "Na hi nūna tuyhaṁ manaso piyamhā”."
    },
    {
      "id": "ja518:35.1",
      "pali": "“Piyo hi me āsi supaṇṇarājā,"
    },
    {
      "id": "ja518:35.2",
      "pali": "Asaṁsayaṁ paṇḍarakena saccaṁ;"
    },
    {
      "id": "ja518:35.3",
      "pali": "So rāgarattova akāsimetaṁ,"
    },
    {
      "id": "ja518:35.4",
      "pali": "Pāpakammaṁ sampajāno na mohā”."
    },
    {
      "id": "ja518:36.1",
      "pali": "“Na me piyaṁ appiyaṁ vāpi hoti,"
    },
    {
      "id": "ja518:36.2",
      "pali": "Sampassato lokamimaṁ parañca;"
    },
    {
      "id": "ja518:36.3",
      "pali": "Susaññatānañhi viyañjanena,"
    },
    {
      "id": "ja518:36.4",
      "pali": "Asaññato lokamimaṁ carāsi."
    },
    {
      "id": "ja518:37.1",
      "pali": "Ariyāvakāsosi anariyovāsi,"
    },
    {
      "id": "ja518:37.2",
      "pali": "Asaññato saññatasannikāso;"
    },
    {
      "id": "ja518:37.3",
      "pali": "Kaṇhābhijātikosi anariyarūpo,"
    },
    {
      "id": "ja518:37.4",
      "pali": "Pāpaṁ bahuṁ duccaritaṁ acāri."
    },
    {
      "id": "ja518:38.1",
      "pali": "Aduṭṭhassa tuvaṁ dubbhi,"
    },
    {
      "id": "ja518:38.2",
      "pali": "dubbhī ca pisuṇo casi;"
    },
    {
      "id": "ja518:38.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja518:38.4",
      "pali": "muddhā te phalatu sattadhā”."
    },
    {
      "id": "ja518:39.1",
      "pali": "“Tasmā hi mittānaṁ na dubbhitabbaṁ,"
    },
    {
      "id": "ja518:39.2",
      "pali": "Mittadubbhā pāpiyo natthi añño;"
    },
    {
      "id": "ja518:39.3",
      "pali": "Āsittasatto nihato pathabyā,"
    },
    {
      "id": "ja518:39.4",
      "pali": "Indassa vākyena hi saṁvaro hato”ti."
    },
    {
      "id": "ja518:40.1",
      "pali": "Paṇḍaranāgarājajātakaṁ aṭṭhamaṁ."
    }
  ]
}
