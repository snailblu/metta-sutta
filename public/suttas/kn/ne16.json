{
  "uid": "ne16",
  "title": "Vibhaṅga 13",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne16:1.1",
      "pali": "Tattha katamo sodhano hāro?"
    },
    {
      "id": "ne16:1.2",
      "pali": "“Vissajjitamhi pañhe”ti gāthā."
    },
    {
      "id": "ne16:1.3",
      "pali": "Yathā āyasmā ajito pārāyane bhagavantaṁ pañhaṁ pucchati—"
    },
    {
      "id": "ne16:2.1",
      "pali": "“Kenassu nivuto loko,"
    },
    {
      "id": "ne16:2.2",
      "pali": "kenassu nappakāsati;"
    },
    {
      "id": "ne16:2.3",
      "pali": "Kissābhilepanaṁ brūsi,"
    },
    {
      "id": "ne16:2.4",
      "pali": "kiṁsu tassa mahabbhayan”ti."
    },
    {
      "id": "ne16:3.1",
      "pali": "“Avijjāya nivuto loko,"
    },
    {
      "id": "ne16:3.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "ne16:3.3",
      "pali": "Vivicchā pamādā nappakāsati;"
    },
    {
      "id": "ne16:3.4",
      "pali": "Jappābhilepanaṁ brūmi,"
    },
    {
      "id": "ne16:3.5",
      "pali": "Dukkhamassa mahabbhayan”ti."
    },
    {
      "id": "ne16:4.1",
      "pali": "“Kenassu nivuto loko”ti pañhe “avijjāya nivuto loko”ti bhagavā padaṁ sodheti, no ca ārambhaṁ."
    },
    {
      "id": "ne16:4.2",
      "pali": "“Kenassu nappakāsatī”ti pañhe “vivicchā pamādā nappakāsatī”ti bhagavā padaṁ sodheti, no ca ārambhaṁ."
    },
    {
      "id": "ne16:4.3",
      "pali": "“Kissābhilepanaṁ brūsī”ti pañhe “jappābhilepanaṁ brūmī”ti bhagavā padaṁ sodheti, no ca ārambhaṁ."
    },
    {
      "id": "ne16:4.4",
      "pali": "“Kiṁsu tassa mahabbhayan”ti pañhe “dukkhamassa mahabbhayan”ti suddho ārambho."
    },
    {
      "id": "ne16:4.5",
      "pali": "Tenāha bhagavā “avijjāya nivuto loko”ti."
    },
    {
      "id": "ne16:5.1",
      "pali": "“Savanti sabbadhi sotā,"
    },
    {
      "id": "ne16:5.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "ne16:5.3",
      "pali": "Sotānaṁ kiṁ nivāraṇaṁ;"
    },
    {
      "id": "ne16:5.4",
      "pali": "Sotānaṁ saṁvaraṁ brūhi,"
    },
    {
      "id": "ne16:5.5",
      "pali": "Kena sotā pidhīyare”ti."
    },
    {
      "id": "ne16:6.1",
      "pali": "“Yāni sotāni lokasmiṁ,"
    },
    {
      "id": "ne16:6.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "ne16:6.3",
      "pali": "Sati tesaṁ nivāraṇaṁ;"
    },
    {
      "id": "ne16:6.4",
      "pali": "Sotānaṁ saṁvaraṁ brūmi,"
    },
    {
      "id": "ne16:6.5",
      "pali": "Paññāyete pidhīyare”ti."
    },
    {
      "id": "ne16:7.1",
      "pali": "“Savanti sabbadhi sotā, sotānaṁ kiṁ nivāraṇan”ti pañhe “yāni sotāni lokasmiṁ, sati tesaṁ nivāraṇan”ti bhagavā padaṁ sodheti, no ca ārambhaṁ."
    },
    {
      "id": "ne16:7.2",
      "pali": "“Sotānaṁ saṁvaraṁ brūhi, kena sotā pidhīyare”ti pañhe “sotānaṁ saṁvaraṁ brūmi, paññāyete pidhīyare”ti suddho ārambho."
    },
    {
      "id": "ne16:7.3",
      "pali": "Tenāha bhagavā “yāni sotāni lokasmin”ti."
    },
    {
      "id": "ne16:8.1",
      "pali": "“Paññā ceva sati ca,"
    },
    {
      "id": "ne16:8.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "ne16:8.3",
      "pali": "Nāmarūpañca mārisa;"
    },
    {
      "id": "ne16:8.4",
      "pali": "Etaṁ me puṭṭho pabrūhi,"
    },
    {
      "id": "ne16:8.5",
      "pali": "Katthetaṁ uparujjhatī”ti."
    },
    {
      "id": "ne16:9.1",
      "pali": "Pañhe—"
    },
    {
      "id": "ne16:10.1",
      "pali": "“Yametaṁ pañhaṁ apucchi,"
    },
    {
      "id": "ne16:10.2",
      "pali": "ajita taṁ vadāmi te;"
    },
    {
      "id": "ne16:10.3",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "ne16:10.4",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "ne16:10.5",
      "pali": "Viññāṇassa nirodhena,"
    },
    {
      "id": "ne16:10.6",
      "pali": "etthetaṁ uparujjhatī”ti."
    },
    {
      "id": "ne16:11.1",
      "pali": "Suddho ārambho."
    },
    {
      "id": "ne16:11.2",
      "pali": "Tenāha bhagavā “yametaṁ pañhaṁ apucchī”ti."
    },
    {
      "id": "ne16:11.3",
      "pali": "Yattha evaṁ suddho ārambho, so pañho visajjito bhavati."
    },
    {
      "id": "ne16:11.4",
      "pali": "Yattha pana ārambho asuddho, na tāva so pañho visajjito bhavati."
    },
    {
      "id": "ne16:11.5",
      "pali": "Tenāha āyasmā mahākaccāyano “vissajjitamhi pañhe”ti."
    },
    {
      "id": "ne16:11.6",
      "pali": "Niyutto sodhano hāro."
    }
  ]
}
