{
  "uid": "tha-ap386",
  "title": "4 Pilakkhaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap386:1.1",
      "pali": "“Vanantare buddhaṁ disvā,"
    },
    {
      "id": "tha-ap386:1.2",
      "pali": "atthadassiṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap386:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap386:1.4",
      "pali": "pilakkhassādadiṁ phalaṁ."
    },
    {
      "id": "tha-ap386:2.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap386:2.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap386:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap386:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap386:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap386:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap386:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap386:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap386:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap386:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap386:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap386:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap386:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap386:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pilakkhaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap386:7.1",
      "pali": "Pilakkhaphaladāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
