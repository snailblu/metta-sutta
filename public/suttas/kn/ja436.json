{
  "uid": "ja436",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja436:1.1",
      "pali": "“Kuto nu āgacchatha bho tayo janā,"
    },
    {
      "id": "ja436:1.2",
      "pali": "Svāgatā etha nisīdathāsane;"
    },
    {
      "id": "ja436:1.3",
      "pali": "Kaccittha bhonto kusalaṁ anāmayaṁ,"
    },
    {
      "id": "ja436:1.4",
      "pali": "Cirassamabbhāgamanaṁ hi vo idha”."
    },
    {
      "id": "ja436:2.1",
      "pali": "“Ahameva eko idha majja patto,"
    },
    {
      "id": "ja436:2.2",
      "pali": "Na cāpi me dutiyo koci vijjati;"
    },
    {
      "id": "ja436:2.3",
      "pali": "Kimeva sandhāya te bhāsitaṁ ise,"
    },
    {
      "id": "ja436:2.4",
      "pali": "‘Kuto nu āgacchatha bho tayo janā’”."
    },
    {
      "id": "ja436:3.1",
      "pali": "“Tuvañca eko bhariyā ca te piyā,"
    },
    {
      "id": "ja436:3.2",
      "pali": "Samuggapakkhittanikiṇṇamantare;"
    },
    {
      "id": "ja436:3.3",
      "pali": "Sā rakkhitā kucchigatāva te sadā,"
    },
    {
      "id": "ja436:3.4",
      "pali": "Vāyussa puttena sahā tahiṁ ratā”."
    },
    {
      "id": "ja436:4.1",
      "pali": "“Saṁviggarūpo isinā viyākato,"
    },
    {
      "id": "ja436:4.2",
      "pali": "So dānavo tattha samuggamuggili;"
    },
    {
      "id": "ja436:4.3",
      "pali": "Addakkhi bhariyaṁ suci māladhāriniṁ,"
    },
    {
      "id": "ja436:4.4",
      "pali": "Vāyussa puttena sahā tahiṁ rataṁ”."
    },
    {
      "id": "ja436:5.1",
      "pali": "“Sudiṭṭharūpamuggatapānuvattinā,"
    },
    {
      "id": "ja436:5.2",
      "pali": "Hīnā narā ye pamadāvasaṁ gatā;"
    },
    {
      "id": "ja436:5.3",
      "pali": "Yathā have pāṇarivettha rakkhitā,"
    },
    {
      "id": "ja436:5.4",
      "pali": "Duṭṭhā mayī aññamabhippamodayi."
    },
    {
      "id": "ja436:6.1",
      "pali": "Divā ca ratto ca mayā upaṭṭhitā,"
    },
    {
      "id": "ja436:6.2",
      "pali": "Tapassinā jotirivā vane vasaṁ;"
    },
    {
      "id": "ja436:6.3",
      "pali": "Sā dhammamukkamma adhammamācari,"
    },
    {
      "id": "ja436:6.4",
      "pali": "Akiriyarūpo pamadāhi santhavo."
    },
    {
      "id": "ja436:7.1",
      "pali": "Sarīramajjhamhi ṭhitātimaññahaṁ,"
    },
    {
      "id": "ja436:7.2",
      "pali": "Mayhaṁ ayanti asatiṁ asaññataṁ;"
    },
    {
      "id": "ja436:7.3",
      "pali": "Sā dhammamukkamma adhammamācari,"
    },
    {
      "id": "ja436:7.4",
      "pali": "Akiriyarūpo pamadāhi santhavo."
    },
    {
      "id": "ja436:8.1",
      "pali": "Surakkhitaṁ meti kathaṁ nu vissase,"
    },
    {
      "id": "ja436:8.2",
      "pali": "Anekacittāsu na hatthi rakkhaṇā;"
    },
    {
      "id": "ja436:8.3",
      "pali": "Etā hi pātālapapātasannibhā,"
    },
    {
      "id": "ja436:8.4",
      "pali": "Etthappamatto byasanaṁ nigaccha”ti."
    },
    {
      "id": "ja436:9.1",
      "pali": "“Tasmā hi te sukhino vītasokā,"
    },
    {
      "id": "ja436:9.2",
      "pali": "Ye mātugāmehi caranti nissaṭā;"
    },
    {
      "id": "ja436:9.3",
      "pali": "Etaṁ sivaṁ uttamamābhipatthayaṁ,"
    },
    {
      "id": "ja436:9.4",
      "pali": "Na mātugāmehi kareyya santhavanti”."
    },
    {
      "id": "ja436:10.1",
      "pali": "Samuggajātakaṁ dasamaṁ."
    }
  ]
}
