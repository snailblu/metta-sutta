{
  "uid": "ja454",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja454:1.1",
      "pali": "“Uṭṭhehi kaṇha kiṁ sesi,"
    },
    {
      "id": "ja454:1.2",
      "pali": "Ko attho supanena te;"
    },
    {
      "id": "ja454:1.3",
      "pali": "Yopi tuyhaṁ sako bhātā,"
    },
    {
      "id": "ja454:1.4",
      "pali": "Hadayaṁ cakkhu ca dakkhiṇaṁ;"
    },
    {
      "id": "ja454:1.5",
      "pali": "Tassa vātā balīyanti,"
    },
    {
      "id": "ja454:1.6",
      "pali": "Ghaṭo jappati kesava”."
    },
    {
      "id": "ja454:2.1",
      "pali": "“Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja454:2.2",
      "pali": "rohiṇeyyassa kesavo;"
    },
    {
      "id": "ja454:2.3",
      "pali": "Taramānarūpo vuṭṭhāsi,"
    },
    {
      "id": "ja454:2.4",
      "pali": "bhātusokena aṭṭito”."
    },
    {
      "id": "ja454:3.1",
      "pali": "“Kiṁ nu ummattarūpova,"
    },
    {
      "id": "ja454:3.2",
      "pali": "kevalaṁ dvārakaṁ imaṁ;"
    },
    {
      "id": "ja454:3.3",
      "pali": "Saso sasoti lapasi,"
    },
    {
      "id": "ja454:3.4",
      "pali": "ko nu te sasamāhari”."
    },
    {
      "id": "ja454:4.1",
      "pali": "“Sovaṇṇamayaṁ maṇīmayaṁ,"
    },
    {
      "id": "ja454:4.2",
      "pali": "Lohamayaṁ atha rūpiyāmayaṁ;"
    },
    {
      "id": "ja454:4.3",
      "pali": "Saṅkhasilāpavāḷamayaṁ,"
    },
    {
      "id": "ja454:4.4",
      "pali": "Kārayissāmi te sasaṁ”."
    },
    {
      "id": "ja454:5.1",
      "pali": "“Santi aññepi sasakā,"
    },
    {
      "id": "ja454:5.2",
      "pali": "araññe vanagocarā;"
    },
    {
      "id": "ja454:5.3",
      "pali": "Tepi te ānayissāmi,"
    },
    {
      "id": "ja454:5.4",
      "pali": "kīdisaṁ sasamicchasi”."
    },
    {
      "id": "ja454:6.1",
      "pali": "“Na cāhamete icchāmi,"
    },
    {
      "id": "ja454:6.2",
      "pali": "ye sasā pathavissitā;"
    },
    {
      "id": "ja454:6.3",
      "pali": "Candato sasamicchāmi,"
    },
    {
      "id": "ja454:6.4",
      "pali": "taṁ me ohara kesava”."
    },
    {
      "id": "ja454:7.1",
      "pali": "“So nūna madhuraṁ ñāti,"
    },
    {
      "id": "ja454:7.2",
      "pali": "jīvitaṁ vijahissasi;"
    },
    {
      "id": "ja454:7.3",
      "pali": "Apatthiyaṁ yo patthayasi,"
    },
    {
      "id": "ja454:7.4",
      "pali": "candato sasamicchasi”."
    },
    {
      "id": "ja454:8.1",
      "pali": "“Evañce kaṇha jānāsi,"
    },
    {
      "id": "ja454:8.2",
      "pali": "yadaññamanusāsasi;"
    },
    {
      "id": "ja454:8.3",
      "pali": "Kasmā pure mataṁ puttaṁ,"
    },
    {
      "id": "ja454:8.4",
      "pali": "ajjāpi manusocasi”."
    },
    {
      "id": "ja454:9.1",
      "pali": "“Yaṁ na labbhā manussena,"
    },
    {
      "id": "ja454:9.2",
      "pali": "amanussena vā puna;"
    },
    {
      "id": "ja454:9.3",
      "pali": "Jāto me mā marī putto,"
    },
    {
      "id": "ja454:9.4",
      "pali": "kuto labbhā alabbhiyaṁ."
    },
    {
      "id": "ja454:10.1",
      "pali": "Na mantā mūlabhesajjā,"
    },
    {
      "id": "ja454:10.2",
      "pali": "osadhehi dhanena vā;"
    },
    {
      "id": "ja454:10.3",
      "pali": "Sakkā ānayituṁ kaṇha,"
    },
    {
      "id": "ja454:10.4",
      "pali": "yaṁ petamanusocasi”."
    },
    {
      "id": "ja454:11.1",
      "pali": "“Yassa etādisā assu,"
    },
    {
      "id": "ja454:11.2",
      "pali": "amaccā purisapaṇḍitā;"
    },
    {
      "id": "ja454:11.3",
      "pali": "Yathā nijjhāpaye ajja,"
    },
    {
      "id": "ja454:11.4",
      "pali": "ghaṭo purisapaṇḍito."
    },
    {
      "id": "ja454:12.1",
      "pali": "Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "ja454:12.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "ja454:12.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "ja454:12.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "ja454:13.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "ja454:13.2",
      "pali": "yamāsi hadayassitaṁ;"
    },
    {
      "id": "ja454:13.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "ja454:13.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "ja454:14.1",
      "pali": "Sohaṁ abbūḷhasallosmi,"
    },
    {
      "id": "ja454:14.2",
      "pali": "vītasoko anāvilo;"
    },
    {
      "id": "ja454:14.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "ja454:14.4",
      "pali": "tava sutvāna māṇava”."
    },
    {
      "id": "ja454:15.1",
      "pali": "“Evaṁ karonti sappaññā,"
    },
    {
      "id": "ja454:15.2",
      "pali": "Ye honti anukampakā;"
    },
    {
      "id": "ja454:15.3",
      "pali": "Nivattayanti sokamhā,"
    },
    {
      "id": "ja454:15.4",
      "pali": "Ghaṭo jeṭṭhaṁva bhātaran”ti."
    },
    {
      "id": "ja454:16.1",
      "pali": "Ghaṭapaṇḍitajātakaṁ soḷasamaṁ."
    },
    {
      "id": "ja454:17.1",
      "pali": "Dasakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja454:18.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja454:19.1",
      "pali": "Daḷha kaṇha dhanañjaya saṅkhavaro,"
    },
    {
      "id": "ja454:19.2",
      "pali": "Raja sattaha kassa ca takkalinā;"
    },
    {
      "id": "ja454:19.3",
      "pali": "Dhammaṁ kukkuṭa kuṇḍali bhojanadā,"
    },
    {
      "id": "ja454:19.4",
      "pali": "Cakkavāka subhūrisa sotthi ghaṭoti."
    }
  ]
}
