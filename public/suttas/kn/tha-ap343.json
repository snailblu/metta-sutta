{
  "uid": "tha-ap343",
  "title": "Ekapadumiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap343:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap343:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap343:1.3",
      "pali": "Bhavābhave vibhāvento,"
    },
    {
      "id": "tha-ap343:1.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap343:2.1",
      "pali": "Haṁsarājā tadā homi,"
    },
    {
      "id": "tha-ap343:2.2",
      "pali": "dijānaṁ pavaro ahaṁ;"
    },
    {
      "id": "tha-ap343:2.3",
      "pali": "Jātassaraṁ samogayha,"
    },
    {
      "id": "tha-ap343:2.4",
      "pali": "kīḷāmi haṁsakīḷitaṁ."
    },
    {
      "id": "tha-ap343:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap343:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap343:3.3",
      "pali": "Jātassarassa upari,"
    },
    {
      "id": "tha-ap343:3.4",
      "pali": "āgacchi tāvade jino."
    },
    {
      "id": "tha-ap343:4.1",
      "pali": "Disvānahaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap343:4.2",
      "pali": "sayambhuṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap343:4.3",
      "pali": "Vaṇṭe chetvāna padumaṁ,"
    },
    {
      "id": "tha-ap343:4.4",
      "pali": "satapattaṁ manoramaṁ."
    },
    {
      "id": "tha-ap343:5.1",
      "pali": "Mukhatuṇḍena paggayha,"
    },
    {
      "id": "tha-ap343:5.2",
      "pali": "pasanno lokanāyake;"
    },
    {
      "id": "tha-ap343:5.3",
      "pali": "Ukkhipitvāna gagane,"
    },
    {
      "id": "tha-ap343:5.4",
      "pali": "buddhaseṭṭhaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap343:6.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap343:6.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap343:6.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap343:6.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap343:7.1",
      "pali": "‘Iminā ekapadumena,"
    },
    {
      "id": "tha-ap343:7.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap343:7.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap343:7.4",
      "pali": "vinipātaṁ na gacchasi’."
    },
    {
      "id": "tha-ap343:8.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap343:8.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap343:8.3",
      "pali": "Mama kammaṁ pakittetvā,"
    },
    {
      "id": "tha-ap343:8.4",
      "pali": "agamā yena patthitaṁ."
    },
    {
      "id": "tha-ap343:9.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap343:9.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap343:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap343:9.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap343:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap343:10.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap343:10.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap343:10.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap343:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekapadumiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap343:12.1",
      "pali": "Ekapadumiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
