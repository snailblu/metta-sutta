{
  "uid": "tha-ap357",
  "title": "Daṇḍadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap357:1.1",
      "pali": "“Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap357:1.2",
      "pali": "veḷuṁ chetvānahaṁ tadā;"
    },
    {
      "id": "tha-ap357:1.3",
      "pali": "Ālambanaṁ karitvāna,"
    },
    {
      "id": "tha-ap357:1.4",
      "pali": "saṅghassa adadaṁ ahaṁ."
    },
    {
      "id": "tha-ap357:2.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap357:2.2",
      "pali": "subbate abhivādiya;"
    },
    {
      "id": "tha-ap357:2.3",
      "pali": "Ālambanampi datvāna,"
    },
    {
      "id": "tha-ap357:2.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap357:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap357:3.2",
      "pali": "yaṁ daṇḍamadadiṁ tadā;"
    },
    {
      "id": "tha-ap357:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap357:3.4",
      "pali": "daṇḍadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap357:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap357:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap357:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap357:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā daṇḍadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap357:6.1",
      "pali": "Daṇḍadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
