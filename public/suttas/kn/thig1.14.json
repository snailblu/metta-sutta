{
  "uid": "thig1.14",
  "title": "Sumanātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.14:1.1",
      "pali": "“Dhātuyo dukkhato disvā,"
    },
    {
      "id": "thig1.14:1.2",
      "pali": "mā jātiṁ punarāgami;"
    },
    {
      "id": "thig1.14:1.3",
      "pali": "Bhave chandaṁ virājetvā,"
    },
    {
      "id": "thig1.14:1.4",
      "pali": "upasantā carissasī”ti."
    },
    {
      "id": "thig1.14:2.1",
      "pali": "… Sumanā therī …."
    }
  ]
}
