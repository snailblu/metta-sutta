{
  "uid": "ja164",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja164:1.1",
      "pali": "“Yannu gijjho yojanasataṁ,"
    },
    {
      "id": "ja164:1.2",
      "pali": "kuṇapāni avekkhati;"
    },
    {
      "id": "ja164:1.3",
      "pali": "Kasmā jālañca pāsañca,"
    },
    {
      "id": "ja164:1.4",
      "pali": "āsajjāpi na bujjhasi”."
    },
    {
      "id": "ja164:2.1",
      "pali": "“Yadā parābhavo hoti,"
    },
    {
      "id": "ja164:2.2",
      "pali": "poso jīvitasaṅkhaye;"
    },
    {
      "id": "ja164:2.3",
      "pali": "Atha jālañca pāsañca,"
    },
    {
      "id": "ja164:2.4",
      "pali": "āsajjāpi na bujjhatī”ti."
    },
    {
      "id": "ja164:3.1",
      "pali": "Gijjhajātakaṁ catutthaṁ."
    }
  ]
}
