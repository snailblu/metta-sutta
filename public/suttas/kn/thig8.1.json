{
  "uid": "thig8.1",
  "title": "Sīsūpacālātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig8.1:1.1",
      "pali": "“Bhikkhunī sīlasampannā,"
    },
    {
      "id": "thig8.1:1.2",
      "pali": "indriyesu susaṁvutā;"
    },
    {
      "id": "thig8.1:1.3",
      "pali": "Adhigacche padaṁ santaṁ,"
    },
    {
      "id": "thig8.1:1.4",
      "pali": "asecanakamojavaṁ”."
    },
    {
      "id": "thig8.1:2.1",
      "pali": "“Tāvatiṁsā ca yāmā ca,"
    },
    {
      "id": "thig8.1:2.2",
      "pali": "tusitā cāpi devatā;"
    },
    {
      "id": "thig8.1:2.3",
      "pali": "Nimmānaratino devā,"
    },
    {
      "id": "thig8.1:2.4",
      "pali": "ye devā vasavattino;"
    },
    {
      "id": "thig8.1:2.5",
      "pali": "Tattha cittaṁ paṇīdhehi,"
    },
    {
      "id": "thig8.1:2.6",
      "pali": "yattha te vusitaṁ pure”."
    },
    {
      "id": "thig8.1:3.1",
      "pali": "“Tāvatiṁsā ca yāmā ca,"
    },
    {
      "id": "thig8.1:3.2",
      "pali": "tusitā cāpi devatā;"
    },
    {
      "id": "thig8.1:3.3",
      "pali": "Nimmānaratino devā,"
    },
    {
      "id": "thig8.1:3.4",
      "pali": "ye devā vasavattino."
    },
    {
      "id": "thig8.1:4.1",
      "pali": "Kālaṁ kālaṁ bhavābhavaṁ,"
    },
    {
      "id": "thig8.1:4.2",
      "pali": "sakkāyasmiṁ purakkhatā;"
    },
    {
      "id": "thig8.1:4.3",
      "pali": "Avītivattā sakkāyaṁ,"
    },
    {
      "id": "thig8.1:4.4",
      "pali": "jātimaraṇasārino."
    },
    {
      "id": "thig8.1:5.1",
      "pali": "Sabbo ādīpito loko,"
    },
    {
      "id": "thig8.1:5.2",
      "pali": "sabbo loko padīpito;"
    },
    {
      "id": "thig8.1:5.3",
      "pali": "Sabbo pajjalito loko,"
    },
    {
      "id": "thig8.1:5.4",
      "pali": "sabbo loko pakampito."
    },
    {
      "id": "thig8.1:6.1",
      "pali": "Akampiyaṁ atuliyaṁ,"
    },
    {
      "id": "thig8.1:6.2",
      "pali": "aputhujjanasevitaṁ;"
    },
    {
      "id": "thig8.1:6.3",
      "pali": "Buddho dhammamadesesi,"
    },
    {
      "id": "thig8.1:6.4",
      "pali": "tattha me nirato mano."
    },
    {
      "id": "thig8.1:7.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig8.1:7.2",
      "pali": "vihariṁ sāsane ratā;"
    },
    {
      "id": "thig8.1:7.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig8.1:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig8.1:8.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig8.1:8.2",
      "pali": "tamokhandho padālito;"
    },
    {
      "id": "thig8.1:8.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig8.1:8.4",
      "pali": "nihato tvamasi antaka”."
    },
    {
      "id": "thig8.1:9.1",
      "pali": "… Sīsūpacālā therī …."
    },
    {
      "id": "thig8.1:10.1",
      "pali": "Aṭṭhakanipāto niṭṭhito."
    }
  ]
}
