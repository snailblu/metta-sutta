{
  "uid": "tha-ap225",
  "title": "3 Dverataniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap225:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap225:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap225:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap225:1.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap225:2.1",
      "pali": "Maṁsapesi mayā dinnā,"
    },
    {
      "id": "tha-ap225:2.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap225:2.3",
      "pali": "Sadevakasmiṁ lokasmiṁ,"
    },
    {
      "id": "tha-ap225:2.4",
      "pali": "issaraṁ kārayāmahaṁ."
    },
    {
      "id": "tha-ap225:3.1",
      "pali": "Iminā maṁsadānena,"
    },
    {
      "id": "tha-ap225:3.2",
      "pali": "ratanaṁ nibbattate mama;"
    },
    {
      "id": "tha-ap225:3.3",
      "pali": "Duveme ratanā loke,"
    },
    {
      "id": "tha-ap225:3.4",
      "pali": "diṭṭhadhammassa pattiyā."
    },
    {
      "id": "tha-ap225:4.1",
      "pali": "Tehaṁ sabbe anubhomi,"
    },
    {
      "id": "tha-ap225:4.2",
      "pali": "maṁsadānassa sattiyā;"
    },
    {
      "id": "tha-ap225:4.3",
      "pali": "Gattañca mudukaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap225:4.4",
      "pali": "paññā nipuṇavedanī."
    },
    {
      "id": "tha-ap225:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap225:5.2",
      "pali": "yaṁ maṁsamadadiṁ tadā;"
    },
    {
      "id": "tha-ap225:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap225:5.4",
      "pali": "maṁsadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap225:6.1",
      "pali": "Ito catutthake kappe,"
    },
    {
      "id": "tha-ap225:6.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap225:6.3",
      "pali": "Mahārohitanāmo so,"
    },
    {
      "id": "tha-ap225:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap225:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap225:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap225:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap225:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā dverataniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap225:9.1",
      "pali": "Dverataniyattherassāpadānaṁ tatiyaṁ."
    },
    {
      "id": "tha-ap225:9.2",
      "pali": "Dasamaṁ bhāṇavāraṁ."
    }
  ]
}
