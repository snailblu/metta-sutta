{
  "uid": "ja42",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja42:1.1",
      "pali": "“Yo atthakāmassa hitānukampino,"
    },
    {
      "id": "ja42:1.2",
      "pali": "Ovajjamāno na karoti sāsanaṁ;"
    },
    {
      "id": "ja42:1.3",
      "pali": "Kapotakassa vacanaṁ akatvā,"
    },
    {
      "id": "ja42:1.4",
      "pali": "Amittahatthatthagatova setī”ti."
    },
    {
      "id": "ja42:2.1",
      "pali": "Kapotajātakaṁ dutiyaṁ."
    }
  ]
}
