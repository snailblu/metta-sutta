{
  "uid": "ja315",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja315:1.1",
      "pali": "“Pharusā vata te vācā,"
    },
    {
      "id": "ja315:1.2",
      "pali": "maṁsaṁ yācanako asi;"
    },
    {
      "id": "ja315:1.3",
      "pali": "Kilomasadisī vācā,"
    },
    {
      "id": "ja315:1.4",
      "pali": "kilomaṁ samma dammi te”."
    },
    {
      "id": "ja315:2.1",
      "pali": "“Aṅgametaṁ manussānaṁ,"
    },
    {
      "id": "ja315:2.2",
      "pali": "bhātā loke pavuccati;"
    },
    {
      "id": "ja315:2.3",
      "pali": "Aṅgassa sadisī vācā,"
    },
    {
      "id": "ja315:2.4",
      "pali": "aṅgaṁ samma dadāmi te”."
    },
    {
      "id": "ja315:3.1",
      "pali": "“Tātāti putto vadamāno,"
    },
    {
      "id": "ja315:3.2",
      "pali": "kampeti hadayaṁ pitu;"
    },
    {
      "id": "ja315:3.3",
      "pali": "Hadayassa sadisī vācā,"
    },
    {
      "id": "ja315:3.4",
      "pali": "hadayaṁ samma dammi te”."
    },
    {
      "id": "ja315:4.1",
      "pali": "“Yassa gāme sakhā natthi,"
    },
    {
      "id": "ja315:4.2",
      "pali": "yathāraññaṁ tatheva taṁ;"
    },
    {
      "id": "ja315:4.3",
      "pali": "Sabbassa sadisī vācā,"
    },
    {
      "id": "ja315:4.4",
      "pali": "sabbaṁ samma dadāmi te”ti."
    },
    {
      "id": "ja315:5.1",
      "pali": "Sabbamaṁsalābhajātakaṁ pañcamaṁ."
    }
  ]
}
