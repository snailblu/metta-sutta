{
  "uid": "tha-ap152",
  "title": "Pallaṅkadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap152:1.1",
      "pali": "“Sumedhassa bhagavato,"
    },
    {
      "id": "tha-ap152:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap152:1.3",
      "pali": "Pallaṅko hi mayā dinno,"
    },
    {
      "id": "tha-ap152:1.4",
      "pali": "sauttarasapacchado."
    },
    {
      "id": "tha-ap152:2.1",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap152:2.2",
      "pali": "pallaṅko āsi so tadā;"
    },
    {
      "id": "tha-ap152:2.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap152:2.4",
      "pali": "nibbattati sadā mama."
    },
    {
      "id": "tha-ap152:3.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap152:3.2",
      "pali": "pallaṅkamadadiṁ tadā;"
    },
    {
      "id": "tha-ap152:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap152:3.4",
      "pali": "pallaṅkassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap152:4.1",
      "pali": "Vīsakappasahassamhi,"
    },
    {
      "id": "tha-ap152:4.2",
      "pali": "suvaṇṇābhā tayo janā;"
    },
    {
      "id": "tha-ap152:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap152:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap152:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap152:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap152:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap152:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pallaṅkadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap152:7.1",
      "pali": "Pallaṅkadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap152:8.1",
      "pali": "Chattavaggo pannarasamo."
    },
    {
      "id": "tha-ap152:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap152:10.1",
      "pali": "Chattaṁ thambho ca vedi ca,"
    },
    {
      "id": "tha-ap152:10.2",
      "pali": "parivārumapupphiyo;"
    },
    {
      "id": "tha-ap152:10.3",
      "pali": "Anulepo ca maggo ca,"
    },
    {
      "id": "tha-ap152:10.4",
      "pali": "phalako ca vaṭaṁsako;"
    },
    {
      "id": "tha-ap152:10.5",
      "pali": "Pallaṅkadāyī ca gāthāyo,"
    },
    {
      "id": "tha-ap152:10.6",
      "pali": "chappaññāsa pakittitāti."
    }
  ]
}
