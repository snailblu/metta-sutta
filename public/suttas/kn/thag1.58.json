{
  "uid": "thag1.58",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.58:1.1",
      "pali": "“Ramaṇīyā me kuṭikā,"
    },
    {
      "id": "thag1.58:1.2",
      "pali": "Saddhādeyyā manoramā;"
    },
    {
      "id": "thag1.58:1.3",
      "pali": "Na me attho kumārīhi,"
    },
    {
      "id": "thag1.58:1.4",
      "pali": "Yesaṁ attho tahiṁ gacchatha nāriyo”ti."
    },
    {
      "id": "thag1.58:1.5",
      "pali": "… Ramaṇīyakuṭiko thero …."
    }
  ]
}
