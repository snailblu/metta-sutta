{
  "uid": "thag1.74",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.74:1.1",
      "pali": "“Kāmacchando ca byāpādo,"
    },
    {
      "id": "thag1.74:1.2",
      "pali": "Thinamiddhañca bhikkhuno;"
    },
    {
      "id": "thag1.74:1.3",
      "pali": "Uddhaccaṁ vicikicchā ca,"
    },
    {
      "id": "thag1.74:1.4",
      "pali": "Sabbasova na vijjatī”ti."
    },
    {
      "id": "thag1.74:1.5",
      "pali": "… Suyāmano thero …."
    }
  ]
}
