{
  "uid": "ja96",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja96:1.1",
      "pali": "“Samatittikaṁ anavasekaṁ,"
    },
    {
      "id": "ja96:1.2",
      "pali": "Telapattaṁ yathā parihareyya;"
    },
    {
      "id": "ja96:1.3",
      "pali": "Evaṁ sacittamanurakkhe,"
    },
    {
      "id": "ja96:1.4",
      "pali": "Patthayāno disaṁ agatapubban”ti."
    },
    {
      "id": "ja96:2.1",
      "pali": "Telapattajātakaṁ chaṭṭhaṁ."
    }
  ]
}
