{
  "uid": "ja116",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja116:1.1",
      "pali": "Atikaramakarācariya,"
    },
    {
      "id": "ja116:1.2",
      "pali": "Mayhampetaṁ na ruccati;"
    },
    {
      "id": "ja116:1.3",
      "pali": "Catutthe laṅghayitvāna,"
    },
    {
      "id": "ja116:1.4",
      "pali": "Pañcamāyasi āvuto”ti."
    },
    {
      "id": "ja116:2.1",
      "pali": "Dubbacajātakaṁ chaṭṭhaṁ."
    }
  ]
}
