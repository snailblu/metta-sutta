{
  "uid": "thag16.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.7:1.1",
      "pali": "“Yātaṁ me hatthigīvāya,"
    },
    {
      "id": "thag16.7:1.2",
      "pali": "sukhumā vatthā padhāritā;"
    },
    {
      "id": "thag16.7:1.3",
      "pali": "Sālīnaṁ odano bhutto,"
    },
    {
      "id": "thag16.7:1.4",
      "pali": "sucimaṁsūpasecano."
    },
    {
      "id": "thag16.7:2.1",
      "pali": "Sojja bhaddo sātatiko,"
    },
    {
      "id": "thag16.7:2.2",
      "pali": "uñchāpattāgate rato;"
    },
    {
      "id": "thag16.7:2.3",
      "pali": "Jhāyati anupādāno,"
    },
    {
      "id": "thag16.7:2.4",
      "pali": "putto godhāya bhaddiyo."
    },
    {
      "id": "thag16.7:3.1",
      "pali": "Paṁsukūlī sātatiko,"
    },
    {
      "id": "thag16.7:3.2",
      "pali": "uñchāpattāgate rato;"
    },
    {
      "id": "thag16.7:3.3",
      "pali": "Jhāyati anupādāno,"
    },
    {
      "id": "thag16.7:3.4",
      "pali": "putto godhāya bhaddiyo."
    },
    {
      "id": "thag16.7:4.1",
      "pali": "Piṇḍapātī sātatiko,"
    },
    {
      "id": "thag16.7:4.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:4.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:4.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:5.1",
      "pali": "Tecīvarī sātatiko,"
    },
    {
      "id": "thag16.7:5.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:5.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:5.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:6.1",
      "pali": "Sapadānacārī sātatiko,"
    },
    {
      "id": "thag16.7:6.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:6.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:6.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:7.1",
      "pali": "Ekāsanī sātatiko,"
    },
    {
      "id": "thag16.7:7.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:7.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:7.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:8.1",
      "pali": "Pattapiṇḍī sātatiko,"
    },
    {
      "id": "thag16.7:8.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:8.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:8.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:9.1",
      "pali": "Khalupacchābhattī sātatiko,"
    },
    {
      "id": "thag16.7:9.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:9.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:9.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:10.1",
      "pali": "Āraññiko sātatiko,"
    },
    {
      "id": "thag16.7:10.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:10.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:10.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:11.1",
      "pali": "Rukkhamūliko sātatiko,"
    },
    {
      "id": "thag16.7:11.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:11.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:11.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:12.1",
      "pali": "Abbhokāsī sātatiko,"
    },
    {
      "id": "thag16.7:12.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:12.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:12.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:13.1",
      "pali": "Sosāniko sātatiko,"
    },
    {
      "id": "thag16.7:13.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:13.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:13.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:14.1",
      "pali": "Yathāsanthatiko sātatiko,"
    },
    {
      "id": "thag16.7:14.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:14.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:14.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:15.1",
      "pali": "Nesajjiko sātatiko,"
    },
    {
      "id": "thag16.7:15.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:15.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:15.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:16.1",
      "pali": "Appiccho sātatiko,"
    },
    {
      "id": "thag16.7:16.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:16.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:16.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:17.1",
      "pali": "Santuṭṭho sātatiko,"
    },
    {
      "id": "thag16.7:17.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:17.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:17.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:18.1",
      "pali": "Pavivitto sātatiko,"
    },
    {
      "id": "thag16.7:18.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:18.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:18.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:19.1",
      "pali": "Asaṁsaṭṭho sātatiko,"
    },
    {
      "id": "thag16.7:19.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:19.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:19.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:20.1",
      "pali": "Āraddhavīriyo sātatiko,"
    },
    {
      "id": "thag16.7:20.2",
      "pali": "…"
    },
    {
      "id": "thag16.7:20.3",
      "pali": "pe …"
    },
    {
      "id": "thag16.7:20.4",
      "pali": "…"
    },
    {
      "id": "thag16.7:21.1",
      "pali": "Hitvā satapalaṁ kaṁsaṁ,"
    },
    {
      "id": "thag16.7:21.2",
      "pali": "sovaṇṇaṁ satarājikaṁ;"
    },
    {
      "id": "thag16.7:21.3",
      "pali": "Aggahiṁ mattikāpattaṁ,"
    },
    {
      "id": "thag16.7:21.4",
      "pali": "idaṁ dutiyābhisecanaṁ."
    },
    {
      "id": "thag16.7:22.1",
      "pali": "Ucce maṇḍalipākāre,"
    },
    {
      "id": "thag16.7:22.2",
      "pali": "daḷhamaṭṭālakoṭṭhake;"
    },
    {
      "id": "thag16.7:22.3",
      "pali": "Rakkhito khaggahatthehi,"
    },
    {
      "id": "thag16.7:22.4",
      "pali": "uttasaṁ vihariṁ pure."
    },
    {
      "id": "thag16.7:23.1",
      "pali": "Sojja bhaddo anutrāsī,"
    },
    {
      "id": "thag16.7:23.2",
      "pali": "pahīnabhayabheravo;"
    },
    {
      "id": "thag16.7:23.3",
      "pali": "Jhāyati vanamoggayha,"
    },
    {
      "id": "thag16.7:23.4",
      "pali": "putto godhāya bhaddiyo."
    },
    {
      "id": "thag16.7:24.1",
      "pali": "Sīlakkhandhe patiṭṭhāya,"
    },
    {
      "id": "thag16.7:24.2",
      "pali": "satiṁ paññañca bhāvayaṁ;"
    },
    {
      "id": "thag16.7:24.3",
      "pali": "Pāpuṇiṁ anupubbena,"
    },
    {
      "id": "thag16.7:24.4",
      "pali": "sabbasaṁyojanakkhayan”ti."
    },
    {
      "id": "thag16.7:24.5",
      "pali": "… Bhaddiyo kāḷigodhāya putto thero …."
    }
  ]
}
