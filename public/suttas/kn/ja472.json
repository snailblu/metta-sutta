{
  "uid": "ja472",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja472:1.1",
      "pali": "“Nādaṭṭhā parato dosaṁ,"
    },
    {
      "id": "ja472:1.2",
      "pali": "aṇuṁthūlāni sabbaso;"
    },
    {
      "id": "ja472:1.3",
      "pali": "Issaro paṇaye daṇḍaṁ,"
    },
    {
      "id": "ja472:1.4",
      "pali": "sāmaṁ appaṭivekkhiya."
    },
    {
      "id": "ja472:2.1",
      "pali": "Yo ca appaṭivekkhitvā,"
    },
    {
      "id": "ja472:2.2",
      "pali": "daṇḍaṁ kubbati khattiyo;"
    },
    {
      "id": "ja472:2.3",
      "pali": "Sakaṇṭakaṁ so gilati,"
    },
    {
      "id": "ja472:2.4",
      "pali": "jaccandhova samakkhikaṁ."
    },
    {
      "id": "ja472:3.1",
      "pali": "Adaṇḍiyaṁ daṇḍayati,"
    },
    {
      "id": "ja472:3.2",
      "pali": "daṇḍiyañca adaṇḍiyaṁ;"
    },
    {
      "id": "ja472:3.3",
      "pali": "Andhova visamaṁ maggaṁ,"
    },
    {
      "id": "ja472:3.4",
      "pali": "na jānāti samāsamaṁ."
    },
    {
      "id": "ja472:4.1",
      "pali": "Yo ca etāni ṭhānāni,"
    },
    {
      "id": "ja472:4.2",
      "pali": "Aṇuṁthūlāni sabbaso;"
    },
    {
      "id": "ja472:4.3",
      "pali": "Sudiṭṭhamanusāseyya,"
    },
    {
      "id": "ja472:4.4",
      "pali": "Sa ve voharitumarahati."
    },
    {
      "id": "ja472:5.1",
      "pali": "Nekantamudunā sakkā,"
    },
    {
      "id": "ja472:5.2",
      "pali": "Ekantatikhiṇena vā;"
    },
    {
      "id": "ja472:5.3",
      "pali": "Attaṁ mahante ṭhapetuṁ,"
    },
    {
      "id": "ja472:5.4",
      "pali": "Tasmā ubhayamācare."
    },
    {
      "id": "ja472:6.1",
      "pali": "Paribhūto mudu hoti,"
    },
    {
      "id": "ja472:6.2",
      "pali": "atitikkho ca veravā;"
    },
    {
      "id": "ja472:6.3",
      "pali": "Etañca ubhayaṁ ñatvā,"
    },
    {
      "id": "ja472:6.4",
      "pali": "anumajjhaṁ samācare."
    },
    {
      "id": "ja472:7.1",
      "pali": "Bahumpi ratto bhāseyya,"
    },
    {
      "id": "ja472:7.2",
      "pali": "duṭṭhopi bahu bhāsati;"
    },
    {
      "id": "ja472:7.3",
      "pali": "Na itthikāraṇā rāja,"
    },
    {
      "id": "ja472:7.4",
      "pali": "puttaṁ ghātetumarahasi”."
    },
    {
      "id": "ja472:8.1",
      "pali": "“Sabbova loko ekato,"
    },
    {
      "id": "ja472:8.2",
      "pali": "Itthī ca ayamekikā;"
    },
    {
      "id": "ja472:8.3",
      "pali": "Tenāhaṁ paṭipajjissaṁ,"
    },
    {
      "id": "ja472:8.4",
      "pali": "Gacchatha pakkhipatheva taṁ”."
    },
    {
      "id": "ja472:9.1",
      "pali": "“Anekatāle narake,"
    },
    {
      "id": "ja472:9.2",
      "pali": "gambhīre ca suduttare;"
    },
    {
      "id": "ja472:9.3",
      "pali": "Pātito giriduggasmiṁ,"
    },
    {
      "id": "ja472:9.4",
      "pali": "kena tvaṁ tattha nāmari”."
    },
    {
      "id": "ja472:10.1",
      "pali": "“Nāgo jātaphaṇo tattha,"
    },
    {
      "id": "ja472:10.2",
      "pali": "thāmavā girisānujo;"
    },
    {
      "id": "ja472:10.3",
      "pali": "Paccaggahi maṁ bhogehi,"
    },
    {
      "id": "ja472:10.4",
      "pali": "tenāhaṁ tattha nāmariṁ”."
    },
    {
      "id": "ja472:11.1",
      "pali": "“Ehi taṁ paṭinessāmi,"
    },
    {
      "id": "ja472:11.2",
      "pali": "rājaputta sakaṁ gharaṁ;"
    },
    {
      "id": "ja472:11.3",
      "pali": "Rajjaṁ kārehi bhaddante,"
    },
    {
      "id": "ja472:11.4",
      "pali": "kiṁ araññe karissasi”."
    },
    {
      "id": "ja472:12.1",
      "pali": "“Yathā gilitvā baḷisaṁ,"
    },
    {
      "id": "ja472:12.2",
      "pali": "Uddhareyya salohitaṁ;"
    },
    {
      "id": "ja472:12.3",
      "pali": "Uddharitvā sukhī assa,"
    },
    {
      "id": "ja472:12.4",
      "pali": "Evaṁ passāmi attanaṁ”."
    },
    {
      "id": "ja472:13.1",
      "pali": "“Kiṁ nu tvaṁ baḷisaṁ brūsi,"
    },
    {
      "id": "ja472:13.2",
      "pali": "kiṁ tvaṁ brūsi salohitaṁ;"
    },
    {
      "id": "ja472:13.3",
      "pali": "Kiṁ nu tvaṁ ubbhataṁ brūsi,"
    },
    {
      "id": "ja472:13.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja472:14.1",
      "pali": "“Kāmāhaṁ baḷisaṁ brūmi,"
    },
    {
      "id": "ja472:14.2",
      "pali": "hatthiassaṁ salohitaṁ;"
    },
    {
      "id": "ja472:14.3",
      "pali": "Cattāhaṁ ubbhataṁ brūmi,"
    },
    {
      "id": "ja472:14.4",
      "pali": "evaṁ jānāhi khattiya”."
    },
    {
      "id": "ja472:15.1",
      "pali": "“Ciñcamāṇavikā mātā,"
    },
    {
      "id": "ja472:15.2",
      "pali": "devadatto ca me pitā;"
    },
    {
      "id": "ja472:15.3",
      "pali": "Ānando paṇḍito nāgo,"
    },
    {
      "id": "ja472:15.4",
      "pali": "sāriputto ca devatā;"
    },
    {
      "id": "ja472:15.5",
      "pali": "Rājaputto ahaṁ āsiṁ,"
    },
    {
      "id": "ja472:15.6",
      "pali": "evaṁ dhāretha jātakan”ti."
    },
    {
      "id": "ja472:16.1",
      "pali": "Mahāpadumajātakaṁ navamaṁ."
    }
  ]
}
