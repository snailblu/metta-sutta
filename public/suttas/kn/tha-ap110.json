{
  "uid": "tha-ap110",
  "title": "8 Āsanupaṭṭhāhakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap110:1.1",
      "pali": "“Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap110:1.2",
      "pali": "appasaddaṁ nirākulaṁ;"
    },
    {
      "id": "tha-ap110:1.3",
      "pali": "Sīhāsanaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap110:1.4",
      "pali": "atthadassissa tādino."
    },
    {
      "id": "tha-ap110:2.1",
      "pali": "Mālāhatthaṁ gahetvāna,"
    },
    {
      "id": "tha-ap110:2.2",
      "pali": "katvā ca naṁ padakkhiṇaṁ;"
    },
    {
      "id": "tha-ap110:2.3",
      "pali": "Satthāraṁ payirupāsitvā,"
    },
    {
      "id": "tha-ap110:2.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap110:3.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap110:3.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap110:3.3",
      "pali": "Sannibbāpemi attānaṁ,"
    },
    {
      "id": "tha-ap110:3.4",
      "pali": "bhavā sabbe samūhatā."
    },
    {
      "id": "tha-ap110:4.1",
      "pali": "Aṭṭhārasakappasate,"
    },
    {
      "id": "tha-ap110:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap110:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap110:4.4",
      "pali": "sīhāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap110:5.1",
      "pali": "Ito sattakappasate,"
    },
    {
      "id": "tha-ap110:5.2",
      "pali": "sannibbāpaka khattiyo;"
    },
    {
      "id": "tha-ap110:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap110:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap110:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap110:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap110:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap110:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā āsanupaṭṭhāhako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap110:8.1",
      "pali": "Āsanupaṭṭhāhakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
