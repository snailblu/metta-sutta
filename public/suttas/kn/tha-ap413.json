{
  "uid": "tha-ap413",
  "title": "Bhaddālittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap413:1.1",
      "pali": "“Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap413:1.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap413:1.3",
      "pali": "Vivekakāmo lokaggo,"
    },
    {
      "id": "tha-ap413:1.4",
      "pali": "himavantamupāgami."
    },
    {
      "id": "tha-ap413:2.1",
      "pali": "Ajjhogāhetvā himavaṁ,"
    },
    {
      "id": "tha-ap413:2.2",
      "pali": "sumedho lokanāyako;"
    },
    {
      "id": "tha-ap413:2.3",
      "pali": "Pallaṅkaṁ ābhujitvāna,"
    },
    {
      "id": "tha-ap413:2.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap413:3.1",
      "pali": "Samādhiṁ so samāpanno,"
    },
    {
      "id": "tha-ap413:3.2",
      "pali": "sumedho lokanāyako;"
    },
    {
      "id": "tha-ap413:3.3",
      "pali": "Sattarattindivaṁ buddho,"
    },
    {
      "id": "tha-ap413:3.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap413:4.1",
      "pali": "Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap413:4.2",
      "pali": "vanamajjhogahiṁ ahaṁ;"
    },
    {
      "id": "tha-ap413:4.3",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap413:4.4",
      "pali": "oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap413:5.1",
      "pali": "Sammajjaniṁ gahetvāna,"
    },
    {
      "id": "tha-ap413:5.2",
      "pali": "sammajjitvāna assamaṁ;"
    },
    {
      "id": "tha-ap413:5.3",
      "pali": "Catudaṇḍe ṭhapetvāna,"
    },
    {
      "id": "tha-ap413:5.4",
      "pali": "akāsiṁ maṇḍapaṁ tadā."
    },
    {
      "id": "tha-ap413:6.1",
      "pali": "Sālapupphaṁ āharitvā,"
    },
    {
      "id": "tha-ap413:6.2",
      "pali": "maṇḍapaṁ chādayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap413:6.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap413:6.4",
      "pali": "abhivandiṁ tathāgataṁ."
    },
    {
      "id": "tha-ap413:7.1",
      "pali": "Yaṁ vadanti sumedhoti,"
    },
    {
      "id": "tha-ap413:7.2",
      "pali": "bhūripaññaṁ sumedhasaṁ;"
    },
    {
      "id": "tha-ap413:7.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap413:7.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap413:8.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap413:8.2",
      "pali": "sabbe devā samāgamuṁ;"
    },
    {
      "id": "tha-ap413:8.3",
      "pali": "Asaṁsayaṁ buddhaseṭṭho,"
    },
    {
      "id": "tha-ap413:8.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap413:9.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap413:9.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap413:9.3",
      "pali": "Devasaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap413:9.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap413:10.1",
      "pali": "‘Yo me sattāhaṁ maṇḍapaṁ,"
    },
    {
      "id": "tha-ap413:10.2",
      "pali": "dhārayī sālachāditaṁ;"
    },
    {
      "id": "tha-ap413:10.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap413:10.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap413:11.1",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap413:11.2",
      "pali": "hemavaṇṇo bhavissati;"
    },
    {
      "id": "tha-ap413:11.3",
      "pali": "Pahūtabhogo hutvāna,"
    },
    {
      "id": "tha-ap413:11.4",
      "pali": "kāmabhogī bhavissati."
    },
    {
      "id": "tha-ap413:12.1",
      "pali": "Saṭṭhi nāgasahassāni,"
    },
    {
      "id": "tha-ap413:12.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap413:12.3",
      "pali": "Suvaṇṇakacchā mātaṅgā,"
    },
    {
      "id": "tha-ap413:12.4",
      "pali": "hemakappanavāsasā."
    },
    {
      "id": "tha-ap413:13.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap413:13.2",
      "pali": "tomaraṅkusapāṇibhi;"
    },
    {
      "id": "tha-ap413:13.3",
      "pali": "Sāyaṁ pāto upaṭṭhānaṁ,"
    },
    {
      "id": "tha-ap413:13.4",
      "pali": "āgamissantimaṁ naraṁ;"
    },
    {
      "id": "tha-ap413:13.5",
      "pali": "Tehi nāgehi parivuto,"
    },
    {
      "id": "tha-ap413:13.6",
      "pali": "ramissati ayaṁ naro."
    },
    {
      "id": "tha-ap413:14.1",
      "pali": "Saṭṭhi assasahassāni,"
    },
    {
      "id": "tha-ap413:14.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap413:14.3",
      "pali": "Ājānīyāva jātiyā,"
    },
    {
      "id": "tha-ap413:14.4",
      "pali": "sindhavā sīghavāhino."
    },
    {
      "id": "tha-ap413:15.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap413:15.2",
      "pali": "illiyācāpadhāribhi;"
    },
    {
      "id": "tha-ap413:15.3",
      "pali": "Parivāressantimaṁ niccaṁ,"
    },
    {
      "id": "tha-ap413:15.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap413:16.1",
      "pali": "Saṭṭhi rathasahassāni,"
    },
    {
      "id": "tha-ap413:16.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap413:16.3",
      "pali": "Dīpā athopi veyagghā,"
    },
    {
      "id": "tha-ap413:16.4",
      "pali": "sannaddhā ussitaddhajā."
    },
    {
      "id": "tha-ap413:17.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap413:17.2",
      "pali": "cāpahatthehi vammibhi;"
    },
    {
      "id": "tha-ap413:17.3",
      "pali": "Parivāressantimaṁ niccaṁ,"
    },
    {
      "id": "tha-ap413:17.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap413:18.1",
      "pali": "Saṭṭhi gāmasahassāni,"
    },
    {
      "id": "tha-ap413:18.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "tha-ap413:18.3",
      "pali": "Pahūtadhanadhaññāni,"
    },
    {
      "id": "tha-ap413:18.4",
      "pali": "susamiddhāni sabbaso;"
    },
    {
      "id": "tha-ap413:18.5",
      "pali": "Sadā pātubhavissanti,"
    },
    {
      "id": "tha-ap413:18.6",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap413:19.1",
      "pali": "Hatthī assā rathā pattī,"
    },
    {
      "id": "tha-ap413:19.2",
      "pali": "senā ca caturaṅginī;"
    },
    {
      "id": "tha-ap413:19.3",
      "pali": "Parivāressantimaṁ niccaṁ,"
    },
    {
      "id": "tha-ap413:19.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap413:20.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap413:20.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap413:20.3",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap413:20.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap413:21.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap413:21.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap413:21.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap413:21.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap413:22.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap413:22.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap413:22.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap413:22.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap413:23.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap413:23.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap413:23.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap413:23.4",
      "pali": "viharissatināsavo’."
    },
    {
      "id": "tha-ap413:24.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap413:24.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap413:24.3",
      "pali": "Etthantaramupādāya,"
    },
    {
      "id": "tha-ap413:24.4",
      "pali": "gavesiṁ amataṁ padaṁ."
    },
    {
      "id": "tha-ap413:25.1",
      "pali": "Lābhā mayhaṁ suladdhaṁ me,"
    },
    {
      "id": "tha-ap413:25.2",
      "pali": "yamahaññāsi sāsanaṁ;"
    },
    {
      "id": "tha-ap413:25.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap413:25.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap413:26.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap413:26.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap413:26.3",
      "pali": "Tava ñāṇaṁ pakittetvā,"
    },
    {
      "id": "tha-ap413:26.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap413:27.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap413:27.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap413:27.3",
      "pali": "Sabbattha sukhito homi,"
    },
    {
      "id": "tha-ap413:27.4",
      "pali": "phalaṁ me ñāṇakittane."
    },
    {
      "id": "tha-ap413:28.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap413:28.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap413:28.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap413:28.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap413:29.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap413:29.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap413:29.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap413:29.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap413:30.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap413:30.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap413:30.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap413:30.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap413:31.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap413:31.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap413:31.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap413:31.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap413:32.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhaddālitthero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap413:33.1",
      "pali": "Bhaddālittherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
