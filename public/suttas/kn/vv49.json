{
  "uid": "vv49",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv49:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv49:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv49:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv49:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv49:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv49:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv49:2.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv49:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv49:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv49:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv49:4.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv49:4.2",
      "pali": "Disvāna samaṇe sīlavante;"
    },
    {
      "id": "vv49:4.3",
      "pali": "Pādāni vanditvā manaṁ pasādayiṁ,"
    },
    {
      "id": "vv49:4.4",
      "pali": "Vittā cahaṁ añjalikaṁ akāsiṁ."
    },
    {
      "id": "vv49:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv49:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv49:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv49:6.1",
      "pali": "Vandanavimānaṁ ekādasamaṁ."
    }
  ]
}
