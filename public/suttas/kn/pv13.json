{
  "uid": "pv13",
  "title": "1. Saṁsāramocakapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv13:1.1",
      "pali": "“Naggā dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv13:1.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv13:1.3",
      "pali": "Upphāsulike kisike,"
    },
    {
      "id": "pv13:1.4",
      "pali": "kā nu tvaṁ idha tiṭṭhasī”ti."
    },
    {
      "id": "pv13:2.1",
      "pali": "“Ahaṁ bhadante petīmhi,"
    },
    {
      "id": "pv13:2.2",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv13:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv13:2.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv13:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv13:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv13:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv13:3.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv13:4.1",
      "pali": "“Anukampakā mayhaṁ nāhesuṁ bhante,"
    },
    {
      "id": "pv13:4.2",
      "pali": "Pitā ca mātā athavāpi ñātakā;"
    },
    {
      "id": "pv13:4.3",
      "pali": "Ye maṁ niyojeyyuṁ dadāhi dānaṁ,"
    },
    {
      "id": "pv13:4.4",
      "pali": "Pasannacittā samaṇabrāhmaṇānaṁ."
    },
    {
      "id": "pv13:5.1",
      "pali": "Ito ahaṁ vassasatāni pañca,"
    },
    {
      "id": "pv13:5.2",
      "pali": "Yaṁ evarūpā vicarāmi naggā;"
    },
    {
      "id": "pv13:5.3",
      "pali": "Khudāya taṇhāya ca khajjamānā,"
    },
    {
      "id": "pv13:5.4",
      "pali": "Pāpassa kammassa phalaṁ mamedaṁ."
    },
    {
      "id": "pv13:6.1",
      "pali": "Vandāmi taṁ ayya pasannacittā,"
    },
    {
      "id": "pv13:6.2",
      "pali": "Anukampa maṁ vīra mahānubhāva;"
    },
    {
      "id": "pv13:6.3",
      "pali": "Datvā ca me ādisa yaṁ hi kiñci,"
    },
    {
      "id": "pv13:6.4",
      "pali": "Mocehi maṁ duggatiyā bhadante”ti."
    },
    {
      "id": "pv13:7.1",
      "pali": "Sādhūti so paṭissutvā,"
    },
    {
      "id": "pv13:7.2",
      "pali": "sāriputtonukampako;"
    },
    {
      "id": "pv13:7.3",
      "pali": "Bhikkhūnaṁ ālopaṁ datvā,"
    },
    {
      "id": "pv13:7.4",
      "pali": "pāṇimattañca coḷakaṁ;"
    },
    {
      "id": "pv13:7.5",
      "pali": "Thālakassa ca pānīyaṁ,"
    },
    {
      "id": "pv13:7.6",
      "pali": "tassā dakkhiṇamādisi."
    },
    {
      "id": "pv13:8.1",
      "pali": "Samanantarānuddiṭṭhe,"
    },
    {
      "id": "pv13:8.2",
      "pali": "vipāko udapajjatha;"
    },
    {
      "id": "pv13:8.3",
      "pali": "Bhojanacchādanapānīyaṁ,"
    },
    {
      "id": "pv13:8.4",
      "pali": "dakkhiṇāya idaṁ phalaṁ."
    },
    {
      "id": "pv13:9.1",
      "pali": "Tato suddhā sucivasanā,"
    },
    {
      "id": "pv13:9.2",
      "pali": "kāsikuttamadhārinī;"
    },
    {
      "id": "pv13:9.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "pv13:9.4",
      "pali": "sāriputtaṁ upasaṅkami."
    },
    {
      "id": "pv13:10.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "pv13:10.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "pv13:10.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "pv13:10.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "pv13:11.1",
      "pali": "Kena te tādiso vaṇṇo,"
    },
    {
      "id": "pv13:11.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "pv13:11.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "pv13:11.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "pv13:12.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "pv13:12.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "pv13:12.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "pv13:12.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "pv13:13.1",
      "pali": "“Uppaṇḍukiṁ kisaṁ chātaṁ,"
    },
    {
      "id": "pv13:13.2",
      "pali": "naggaṁ sampatitacchaviṁ;"
    },
    {
      "id": "pv13:13.3",
      "pali": "Muni kāruṇiko loke,"
    },
    {
      "id": "pv13:13.4",
      "pali": "taṁ maṁ addakkhi duggataṁ."
    },
    {
      "id": "pv13:14.1",
      "pali": "Bhikkhūnaṁ ālopaṁ datvā,"
    },
    {
      "id": "pv13:14.2",
      "pali": "pāṇimattañca coḷakaṁ;"
    },
    {
      "id": "pv13:14.3",
      "pali": "Thālakassa ca pānīyaṁ,"
    },
    {
      "id": "pv13:14.4",
      "pali": "mama dakkhiṇamādisi."
    },
    {
      "id": "pv13:15.1",
      "pali": "Ālopassa phalaṁ passa,"
    },
    {
      "id": "pv13:15.2",
      "pali": "bhattaṁ vassasataṁ dasa;"
    },
    {
      "id": "pv13:15.3",
      "pali": "Bhuñjāmi kāmakāminī,"
    },
    {
      "id": "pv13:15.4",
      "pali": "anekarasabyañjanaṁ."
    },
    {
      "id": "pv13:16.1",
      "pali": "Pāṇimattassa coḷassa,"
    },
    {
      "id": "pv13:16.2",
      "pali": "vipākaṁ passa yādisaṁ;"
    },
    {
      "id": "pv13:16.3",
      "pali": "Yāvatā nandarājassa,"
    },
    {
      "id": "pv13:16.4",
      "pali": "vijitasmiṁ paṭicchadā."
    },
    {
      "id": "pv13:17.1",
      "pali": "Tato bahutarā bhante,"
    },
    {
      "id": "pv13:17.2",
      "pali": "vatthānacchādanāni me;"
    },
    {
      "id": "pv13:17.3",
      "pali": "Koseyyakambalīyāni,"
    },
    {
      "id": "pv13:17.4",
      "pali": "khomakappāsikāni ca."
    },
    {
      "id": "pv13:18.1",
      "pali": "Vipulā ca mahagghā ca,"
    },
    {
      "id": "pv13:18.2",
      "pali": "tepākāsevalambare;"
    },
    {
      "id": "pv13:18.3",
      "pali": "Sāhaṁ taṁ paridahāmi,"
    },
    {
      "id": "pv13:18.4",
      "pali": "yaṁ yaṁ hi manaso piyaṁ."
    },
    {
      "id": "pv13:19.1",
      "pali": "Thālakassa ca pānīyaṁ,"
    },
    {
      "id": "pv13:19.2",
      "pali": "vipākaṁ passa yādisaṁ;"
    },
    {
      "id": "pv13:19.3",
      "pali": "Gambhīrā caturassā ca,"
    },
    {
      "id": "pv13:19.4",
      "pali": "pokkharañño sunimmitā."
    },
    {
      "id": "pv13:20.1",
      "pali": "Setodakā suppatitthā,"
    },
    {
      "id": "pv13:20.2",
      "pali": "sītā appaṭigandhiyā;"
    },
    {
      "id": "pv13:20.3",
      "pali": "Padumuppalasañchannā,"
    },
    {
      "id": "pv13:20.4",
      "pali": "vārikiñjakkhapūritā."
    },
    {
      "id": "pv13:21.1",
      "pali": "Sāhaṁ ramāmi kīḷāmi,"
    },
    {
      "id": "pv13:21.2",
      "pali": "modāmi akutobhayā;"
    },
    {
      "id": "pv13:21.3",
      "pali": "Muniṁ kāruṇikaṁ loke,"
    },
    {
      "id": "pv13:21.4",
      "pali": "bhante vanditumāgatā”ti."
    },
    {
      "id": "pv13:22.1",
      "pali": "Saṁsāramocakapetivatthu paṭhamaṁ."
    }
  ]
}
