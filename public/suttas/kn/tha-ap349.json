{
  "uid": "tha-ap349",
  "title": "Padumapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap349:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap349:1.2",
      "pali": "romaso nāma pabbato;"
    },
    {
      "id": "tha-ap349:1.3",
      "pali": "Buddhopi sambhavo nāma,"
    },
    {
      "id": "tha-ap349:1.4",
      "pali": "abbhokāse vasī tadā."
    },
    {
      "id": "tha-ap349:2.1",
      "pali": "Bhavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap349:2.2",
      "pali": "padumaṁ dhārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap349:2.3",
      "pali": "Ekāhaṁ dhārayitvāna,"
    },
    {
      "id": "tha-ap349:2.4",
      "pali": "puna bhavanupāgamiṁ."
    },
    {
      "id": "tha-ap349:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap349:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap349:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap349:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap349:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap349:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap349:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap349:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap349:6.1",
      "pali": "Padumapūjakattherassāpadānaṁ sattamaṁ."
    },
    {
      "id": "tha-ap349:6.2",
      "pali": "Terasamaṁ bhāṇavāraṁ."
    }
  ]
}
