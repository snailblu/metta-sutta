{
  "uid": "tha-ap290",
  "title": "Sattāhapabbajitattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap290:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap290:1.2",
      "pali": "saṅgho sakkatamānito;"
    },
    {
      "id": "tha-ap290:1.3",
      "pali": "Byasanaṁ me anuppattaṁ,"
    },
    {
      "id": "tha-ap290:1.4",
      "pali": "ñātibhedo pure ahu."
    },
    {
      "id": "tha-ap290:2.1",
      "pali": "Pabbajjaṁ upagantvāna,"
    },
    {
      "id": "tha-ap290:2.2",
      "pali": "byasanupasamāyahaṁ;"
    },
    {
      "id": "tha-ap290:2.3",
      "pali": "Sattāhābhirato tattha,"
    },
    {
      "id": "tha-ap290:2.4",
      "pali": "satthusāsanakamyatā."
    },
    {
      "id": "tha-ap290:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap290:3.2",
      "pali": "yamahaṁ pabbajiṁ tadā;"
    },
    {
      "id": "tha-ap290:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap290:3.4",
      "pali": "pabbajjāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap290:4.1",
      "pali": "Sattasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap290:4.2",
      "pali": "satta āsuṁ mahīpatī;"
    },
    {
      "id": "tha-ap290:4.3",
      "pali": "Sunikkhamāti ñāyanti,"
    },
    {
      "id": "tha-ap290:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap290:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap290:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap290:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap290:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattāhapabbajito thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap290:7.1",
      "pali": "Sattāhapabbajitattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
