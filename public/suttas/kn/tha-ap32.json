{
  "uid": "tha-ap32",
  "title": "Khomadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap32:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap32:1.2",
      "pali": "ahosiṁ vāṇijo tadā;"
    },
    {
      "id": "tha-ap32:1.3",
      "pali": "Teneva dāraṁ posemi,"
    },
    {
      "id": "tha-ap32:1.4",
      "pali": "ropemi bījasampadaṁ."
    },
    {
      "id": "tha-ap32:2.1",
      "pali": "Rathiyaṁ paṭipannassa,"
    },
    {
      "id": "tha-ap32:2.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap32:2.3",
      "pali": "Ekaṁ khomaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap32:2.4",
      "pali": "kusalatthāya satthuno."
    },
    {
      "id": "tha-ap32:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap32:3.2",
      "pali": "yaṁ khomamadadiṁ tadā;"
    },
    {
      "id": "tha-ap32:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap32:3.4",
      "pali": "khomadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap32:4.1",
      "pali": "Sattarase ito kappe,"
    },
    {
      "id": "tha-ap32:4.2",
      "pali": "eko sindhavasandhano;"
    },
    {
      "id": "tha-ap32:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap32:4.4",
      "pali": "catudīpamhi issaro."
    },
    {
      "id": "tha-ap32:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap32:5.2",
      "pali": "Vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap32:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap32:5.4",
      "pali": "Kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap32:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā khomadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap32:7.1",
      "pali": "Khomadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap32:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap32:9.1",
      "pali": "Subhūti upavāno ca,"
    },
    {
      "id": "tha-ap32:9.2",
      "pali": "saraṇo sīlagāhako;"
    },
    {
      "id": "tha-ap32:9.3",
      "pali": "Annasaṁsāvako dhūpo,"
    },
    {
      "id": "tha-ap32:9.4",
      "pali": "pulino uttiyena ca."
    },
    {
      "id": "tha-ap32:10.1",
      "pali": "Añjalī khomadāyī ca,"
    },
    {
      "id": "tha-ap32:10.2",
      "pali": "daseva tatiye gaṇe;"
    },
    {
      "id": "tha-ap32:10.3",
      "pali": "Pañcāsītisataṁ vuttā,"
    },
    {
      "id": "tha-ap32:10.4",
      "pali": "gāthāyo sabbapiṇḍitā."
    },
    {
      "id": "tha-ap32:11.1",
      "pali": "Subhūtivaggo tatiyo."
    },
    {
      "id": "tha-ap32:12.1",
      "pali": "Catutthabhāṇavāraṁ."
    }
  ]
}
