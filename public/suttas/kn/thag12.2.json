{
  "uid": "thag12.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag12.2:1.1",
      "pali": "“Nīce kulamhi jātohaṁ,"
    },
    {
      "id": "thag12.2:1.2",
      "pali": "daliddo appabhojano;"
    },
    {
      "id": "thag12.2:1.3",
      "pali": "Hīnakammaṁ mamaṁ āsi,"
    },
    {
      "id": "thag12.2:1.4",
      "pali": "ahosiṁ pupphachaḍḍako."
    },
    {
      "id": "thag12.2:2.1",
      "pali": "Jigucchito manussānaṁ,"
    },
    {
      "id": "thag12.2:2.2",
      "pali": "paribhūto ca vambhito;"
    },
    {
      "id": "thag12.2:2.3",
      "pali": "Nīcaṁ manaṁ karitvāna,"
    },
    {
      "id": "thag12.2:2.4",
      "pali": "vandissaṁ bahukaṁ janaṁ."
    },
    {
      "id": "thag12.2:3.1",
      "pali": "Athaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "thag12.2:3.2",
      "pali": "bhikkhusaṅghapurakkhataṁ;"
    },
    {
      "id": "thag12.2:3.3",
      "pali": "Pavisantaṁ mahāvīraṁ,"
    },
    {
      "id": "thag12.2:3.4",
      "pali": "magadhānaṁ puruttamaṁ."
    },
    {
      "id": "thag12.2:4.1",
      "pali": "Nikkhipitvāna byābhaṅgiṁ,"
    },
    {
      "id": "thag12.2:4.2",
      "pali": "vandituṁ upasaṅkamiṁ;"
    },
    {
      "id": "thag12.2:4.3",
      "pali": "Mameva anukampāya,"
    },
    {
      "id": "thag12.2:4.4",
      "pali": "aṭṭhāsi purisuttamo."
    },
    {
      "id": "thag12.2:5.1",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "thag12.2:5.2",
      "pali": "ekamantaṁ ṭhito tadā;"
    },
    {
      "id": "thag12.2:5.3",
      "pali": "Pabbajjaṁ ahamāyāciṁ,"
    },
    {
      "id": "thag12.2:5.4",
      "pali": "sabbasattānamuttamaṁ."
    },
    {
      "id": "thag12.2:6.1",
      "pali": "Tato kāruṇiko satthā,"
    },
    {
      "id": "thag12.2:6.2",
      "pali": "sabbalokānukampako;"
    },
    {
      "id": "thag12.2:6.3",
      "pali": "‘Ehi bhikkhū’ti maṁ āha,"
    },
    {
      "id": "thag12.2:6.4",
      "pali": "sā me āsūpasampadā."
    },
    {
      "id": "thag12.2:7.1",
      "pali": "Sohaṁ eko araññasmiṁ,"
    },
    {
      "id": "thag12.2:7.2",
      "pali": "viharanto atandito;"
    },
    {
      "id": "thag12.2:7.3",
      "pali": "Akāsiṁ satthu vacanaṁ,"
    },
    {
      "id": "thag12.2:7.4",
      "pali": "yathā maṁ ovadī jino."
    },
    {
      "id": "thag12.2:8.1",
      "pali": "Rattiyā paṭhamaṁ yāmaṁ,"
    },
    {
      "id": "thag12.2:8.2",
      "pali": "Pubbajātimanussariṁ;"
    },
    {
      "id": "thag12.2:8.3",
      "pali": "Rattiyā majjhimaṁ yāmaṁ,"
    },
    {
      "id": "thag12.2:8.4",
      "pali": "Dibbacakkhuṁ visodhayiṁ;"
    },
    {
      "id": "thag12.2:8.5",
      "pali": "Rattiyā pacchime yāme,"
    },
    {
      "id": "thag12.2:8.6",
      "pali": "Tamokhandhaṁ padālayiṁ."
    },
    {
      "id": "thag12.2:9.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "thag12.2:9.2",
      "pali": "sūriyassuggamanaṁ pati;"
    },
    {
      "id": "thag12.2:9.3",
      "pali": "Indo brahmā ca āgantvā,"
    },
    {
      "id": "thag12.2:9.4",
      "pali": "maṁ namassiṁsu pañjalī."
    },
    {
      "id": "thag12.2:10.1",
      "pali": "‘Namo te purisājañña,"
    },
    {
      "id": "thag12.2:10.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "thag12.2:10.3",
      "pali": "Yassa te āsavā khīṇā,"
    },
    {
      "id": "thag12.2:10.4",
      "pali": "dakkhiṇeyyosi mārisa’."
    },
    {
      "id": "thag12.2:11.1",
      "pali": "Tato disvāna maṁ satthā,"
    },
    {
      "id": "thag12.2:11.2",
      "pali": "devasaṅghapurakkhataṁ;"
    },
    {
      "id": "thag12.2:11.3",
      "pali": "Sitaṁ pātukaritvāna,"
    },
    {
      "id": "thag12.2:11.4",
      "pali": "imamatthaṁ abhāsatha."
    },
    {
      "id": "thag12.2:12.1",
      "pali": "‘Tapena brahmacariyena,"
    },
    {
      "id": "thag12.2:12.2",
      "pali": "saṁyamena damena ca;"
    },
    {
      "id": "thag12.2:12.3",
      "pali": "Etena brāhmaṇo hoti,"
    },
    {
      "id": "thag12.2:12.4",
      "pali": "etaṁ brāhmaṇamuttaman’”ti."
    },
    {
      "id": "thag12.2:12.5",
      "pali": "… Sunīto thero …"
    },
    {
      "id": "thag12.2:12.6",
      "pali": "Dvādasakanipāto niṭṭhito."
    },
    {
      "id": "thag12.2:13.1",
      "pali": "Sīlavā ca sunīto ca,"
    },
    {
      "id": "thag12.2:13.2",
      "pali": "therā dve te mahiddhikā;"
    },
    {
      "id": "thag12.2:13.3",
      "pali": "Dvādasamhi nipātamhi,"
    },
    {
      "id": "thag12.2:13.4",
      "pali": "gāthāyo catuvīsatīti."
    }
  ]
}
