{
  "uid": "ja53",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja53:1.1",
      "pali": "“Tatheva puṇṇā pātiyo,"
    },
    {
      "id": "ja53:1.2",
      "pali": "aññāyaṁ vattate kathā;"
    },
    {
      "id": "ja53:1.3",
      "pali": "Ākāraṇena jānāmi,"
    },
    {
      "id": "ja53:1.4",
      "pali": "na cāyaṁ bhaddikā surā”ti."
    },
    {
      "id": "ja53:2.1",
      "pali": "Puṇṇapātijātakaṁ tatiyaṁ."
    }
  ]
}
