{
  "uid": "mil3.6.4",
  "title": "4. Bhagavatobrahmacāripañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.6.4:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.6.4:1.2",
      "pali": "“bhante nāgasena, buddho brahmacārī”ti?"
    },
    {
      "id": "mil3.6.4:1.3",
      "pali": "“Āma, mahārāja, bhagavā brahmacārī”ti."
    },
    {
      "id": "mil3.6.4:1.4",
      "pali": "“Tena hi, bhante nāgasena, buddho brahmuno sisso”ti?"
    },
    {
      "id": "mil3.6.4:1.5",
      "pali": "“Atthi pana te, mahārāja, hatthipāmokkho”ti?"
    },
    {
      "id": "mil3.6.4:1.6",
      "pali": "“Atthi, bhante”ti."
    },
    {
      "id": "mil3.6.4:1.7",
      "pali": "“Kiṁ nu kho, mahārāja, so hatthī kadāci karahaci koñcanādaṁ nadatī”ti?"
    },
    {
      "id": "mil3.6.4:1.8",
      "pali": "“Āma, bhante, nadatī”ti."
    },
    {
      "id": "mil3.6.4:1.9",
      "pali": "“Tena hi, mahārāja, so hatthī koñcasakuṇassa sisso”ti?"
    },
    {
      "id": "mil3.6.4:1.10",
      "pali": "“Na hi, bhante”ti."
    },
    {
      "id": "mil3.6.4:1.11",
      "pali": "“Kiṁ pana, mahārāja, brahmā sabuddhiko abuddhiko”ti?"
    },
    {
      "id": "mil3.6.4:1.12",
      "pali": "“Sabuddhiko, bhante”ti."
    },
    {
      "id": "mil3.6.4:1.13",
      "pali": "“Tena hi, mahārāja, brahmā bhagavato sisso”ti."
    },
    {
      "id": "mil3.6.4:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.6.4:3.1",
      "pali": "Bhagavato brahmacāripañho catuttho."
    }
  ]
}
