{
  "uid": "tha-ap443",
  "title": "1 Vibhītakamiñjiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap443:1.1",
      "pali": "“Kakusandho mahāvīro,"
    },
    {
      "id": "tha-ap443:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap443:1.3",
      "pali": "Gaṇamhā vūpakaṭṭho so,"
    },
    {
      "id": "tha-ap443:1.4",
      "pali": "agamāsi vanantaraṁ."
    },
    {
      "id": "tha-ap443:2.1",
      "pali": "Bījamiñjaṁ gahetvāna,"
    },
    {
      "id": "tha-ap443:2.2",
      "pali": "latāya āvuṇiṁ ahaṁ;"
    },
    {
      "id": "tha-ap443:2.3",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap443:2.4",
      "pali": "jhāyate pabbatantare."
    },
    {
      "id": "tha-ap443:3.1",
      "pali": "Disvānahaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap443:3.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap443:3.3",
      "pali": "Dakkhiṇeyyassa vīrassa,"
    },
    {
      "id": "tha-ap443:3.4",
      "pali": "bījamiñjamadāsahaṁ."
    },
    {
      "id": "tha-ap443:4.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "tha-ap443:4.2",
      "pali": "yaṁ miñjamadadiṁ tadā;"
    },
    {
      "id": "tha-ap443:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap443:4.4",
      "pali": "bījamiñjassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap443:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap443:5.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap443:5.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap443:5.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap443:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap443:6.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap443:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap443:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap443:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap443:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap443:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap443:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap443:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā vibhītakamiñjiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap443:9.1",
      "pali": "Vibhītakamiñjiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
