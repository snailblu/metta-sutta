{
  "uid": "ja174",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja174:1.1",
      "pali": "“Adamha te vāri pahūtarūpaṁ,"
    },
    {
      "id": "ja174:1.2",
      "pali": "Ghammābhitattassa pipāsitassa;"
    },
    {
      "id": "ja174:1.3",
      "pali": "So dāni pitvāna kiriṅkarosi,"
    },
    {
      "id": "ja174:1.4",
      "pali": "Asaṅgamo pāpajanena seyyo”."
    },
    {
      "id": "ja174:2.1",
      "pali": "“Ko te suto vā diṭṭho vā,"
    },
    {
      "id": "ja174:2.2",
      "pali": "sīlavā nāma makkaṭo;"
    },
    {
      "id": "ja174:2.3",
      "pali": "Idāni kho taṁ ohacchaṁ,"
    },
    {
      "id": "ja174:2.4",
      "pali": "esā asmāka dhammatā”ti."
    },
    {
      "id": "ja174:3.1",
      "pali": "Dubbhiyamakkaṭajātakaṁ catutthaṁ."
    }
  ]
}
