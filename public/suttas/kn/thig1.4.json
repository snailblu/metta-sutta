{
  "uid": "thig1.4",
  "title": "Tissātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.4:1.1",
      "pali": "“Tisse sikkhassu sikkhāya,"
    },
    {
      "id": "thig1.4:1.2",
      "pali": "mā taṁ yogā upaccaguṁ;"
    },
    {
      "id": "thig1.4:1.3",
      "pali": "Sabbayogavisaṁyuttā,"
    },
    {
      "id": "thig1.4:1.4",
      "pali": "cara loke anāsavā”ti."
    },
    {
      "id": "thig1.4:2.1",
      "pali": "… Tissā therī …."
    }
  ]
}
