{
  "uid": "ne25",
  "title": "Sampāta 6",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne25:1.1",
      "pali": "Tattha katamo catubyūho hārasampāto."
    },
    {
      "id": "ne25:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne25:2.2",
      "pali": "“Tasmā rakkhitacittassā”ti rakkhitaṁ paripālīyatīti esā nirutti."
    },
    {
      "id": "ne25:2.3",
      "pali": "Idha bhagavato ko adhippāyo?"
    },
    {
      "id": "ne25:2.4",
      "pali": "Ye duggatīhi parimuccitukāmā bhavissanti, te dhammacārino bhavissantīti ayaṁ ettha bhagavato adhippāyo."
    },
    {
      "id": "ne25:2.5",
      "pali": "Kokāliko hi sāriputtamoggallānesu theresu cittaṁ padosayitvā mahāpadumaniraye upapanno."
    },
    {
      "id": "ne25:2.6",
      "pali": "Bhagavā ca satiārakkhena cetasā samannāgato, suttamhi vuttaṁ—"
    },
    {
      "id": "ne25:2.7",
      "pali": "“satiyā cittaṁ rakkhitabban”ti."
    },
    {
      "id": "ne25:2.8",
      "pali": "Niyutto catubyūho hārasampāto."
    }
  ]
}
