{
  "uid": "ne2",
  "title": "2. Uddesavāra",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne2:1.1",
      "pali": "Tattha katame soḷasa hārā?"
    },
    {
      "id": "ne2:1.2",
      "pali": "Desanā vicayo yutti padaṭṭhāno lakkhaṇo catubyūho āvaṭṭo vibhatti parivattano vevacano paññatti otaraṇo sodhano adhiṭṭhāno parikkhāro samāropano iti."
    },
    {
      "id": "ne2:2.1",
      "pali": "Tassānugīti"
    },
    {
      "id": "ne2:3.1",
      "pali": "Desanā vicayo yutti,"
    },
    {
      "id": "ne2:3.2",
      "pali": "padaṭṭhāno ca lakkhaṇo;"
    },
    {
      "id": "ne2:3.3",
      "pali": "Catubyūho ca āvaṭṭo,"
    },
    {
      "id": "ne2:3.4",
      "pali": "vibhatti parivattano."
    },
    {
      "id": "ne2:4.1",
      "pali": "Vevacano ca paññatti,"
    },
    {
      "id": "ne2:4.2",
      "pali": "otaraṇo ca sodhano;"
    },
    {
      "id": "ne2:4.3",
      "pali": "Adhiṭṭhāno parikkhāro,"
    },
    {
      "id": "ne2:4.4",
      "pali": "samāropano soḷaso."
    },
    {
      "id": "ne2:5.1",
      "pali": "Ete soḷasa hārā,"
    },
    {
      "id": "ne2:5.2",
      "pali": "Pakittitā atthato asaṅkiṇṇā;"
    },
    {
      "id": "ne2:5.3",
      "pali": "Etesañceva bhavati,"
    },
    {
      "id": "ne2:5.4",
      "pali": "Vitthāratayā nayavibhattīti."
    },
    {
      "id": "ne2:6.1",
      "pali": "Tattha katame pañca nayā?"
    },
    {
      "id": "ne2:6.2",
      "pali": "Nandiyāvaṭṭo tipukkhalo sīhavikkīḷito disālocano aṅkuso iti."
    },
    {
      "id": "ne2:7.1",
      "pali": "Tassānugīti"
    },
    {
      "id": "ne2:8.1",
      "pali": "Paṭhamo nandiyāvaṭṭo,"
    },
    {
      "id": "ne2:8.2",
      "pali": "dutiyo ca tipukkhalo;"
    },
    {
      "id": "ne2:8.3",
      "pali": "Sīhavikkīḷito nāma,"
    },
    {
      "id": "ne2:8.4",
      "pali": "tatiyo nayalañjako."
    },
    {
      "id": "ne2:9.1",
      "pali": "Disālocanamāhaṁsu,"
    },
    {
      "id": "ne2:9.2",
      "pali": "catutthaṁ nayamuttamaṁ;"
    },
    {
      "id": "ne2:9.3",
      "pali": "Pañcamo aṅkuso nāma,"
    },
    {
      "id": "ne2:9.4",
      "pali": "sabbe pañca nayā gatāti."
    },
    {
      "id": "ne2:10.1",
      "pali": "Tattha katamāni aṭṭhārasa mūlapadāni?"
    },
    {
      "id": "ne2:10.2",
      "pali": "Nava padāni kusalāni nava padāni akusalāni."
    },
    {
      "id": "ne2:10.3",
      "pali": "Tattha katamāni nava padāni akusalāni, taṇhā avijjā lobho doso moho subhasaññā sukhasaññā niccasaññā attasaññāti, imāni nava padāni akusalāni, yattha sabbo akusalapakkho saṅgahaṁ samosaraṇaṁ gacchati."
    },
    {
      "id": "ne2:11.1",
      "pali": "Tattha katamāni nava padāni kusalāni?"
    },
    {
      "id": "ne2:11.2",
      "pali": "Samatho vipassanā alobho adoso amoho asubhasaññā dukkhasaññā aniccasaññā anattasaññāti, imāni nava padāni kusalāni, yattha sabbo kusalapakkho saṅgahaṁ samosaraṇaṁ gacchati."
    },
    {
      "id": "ne2:11.3",
      "pali": "Tatridaṁ uddānaṁ"
    },
    {
      "id": "ne2:12.1",
      "pali": "Taṇhā ca avijjāpi ca,"
    },
    {
      "id": "ne2:12.2",
      "pali": "Lobho doso tatheva moho ca;"
    },
    {
      "id": "ne2:12.3",
      "pali": "Caturo ca vipallāsā,"
    },
    {
      "id": "ne2:12.4",
      "pali": "Kilesabhūmī nava padāni."
    },
    {
      "id": "ne2:13.1",
      "pali": "Samatho ca vipassanā ca,"
    },
    {
      "id": "ne2:13.2",
      "pali": "Kusalāni ca yāni tīṇi mūlāni;"
    },
    {
      "id": "ne2:13.3",
      "pali": "Caturo satipaṭṭhānā,"
    },
    {
      "id": "ne2:13.4",
      "pali": "Indriyabhūmī nava padāni."
    },
    {
      "id": "ne2:14.1",
      "pali": "Navahi ca padehi kusalā,"
    },
    {
      "id": "ne2:14.2",
      "pali": "Navahi ca yujjanti akusalapakkhā;"
    },
    {
      "id": "ne2:14.3",
      "pali": "Ete kho mūlapadā,"
    },
    {
      "id": "ne2:14.4",
      "pali": "Bhavanti aṭṭhārasa padānīti."
    },
    {
      "id": "ne2:14.5",
      "pali": "Uddesavāro."
    }
  ]
}
