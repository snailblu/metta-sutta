{
  "uid": "ja119",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja119:1.1",
      "pali": "“Amātāpitarasaṁvaddho,"
    },
    {
      "id": "ja119:1.2",
      "pali": "anācerakule vasaṁ;"
    },
    {
      "id": "ja119:1.3",
      "pali": "Nāyaṁ kālaṁ akālaṁ vā,"
    },
    {
      "id": "ja119:1.4",
      "pali": "abhijānāti kukkuṭo”ti."
    },
    {
      "id": "ja119:2.1",
      "pali": "Akālarāvijātakaṁ navamaṁ."
    }
  ]
}
