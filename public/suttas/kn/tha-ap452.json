{
  "uid": "tha-ap452",
  "title": "10 Bodhigharadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap452:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap452:1.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap452:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap452:1.4",
      "pali": "bodhigharamakārayiṁ."
    },
    {
      "id": "tha-ap452:2.1",
      "pali": "Tusitaṁ upapannomhi,"
    },
    {
      "id": "tha-ap452:2.2",
      "pali": "vasāmi ratane ghare;"
    },
    {
      "id": "tha-ap452:2.3",
      "pali": "Na me sītaṁ vā uṇhaṁ vā,"
    },
    {
      "id": "tha-ap452:2.4",
      "pali": "vāto gatte na samphuse."
    },
    {
      "id": "tha-ap452:3.1",
      "pali": "Pañcasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap452:3.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap452:3.3",
      "pali": "Kāsikaṁ nāma nagaraṁ,"
    },
    {
      "id": "tha-ap452:3.4",
      "pali": "vissakammena māpitaṁ."
    },
    {
      "id": "tha-ap452:4.1",
      "pali": "Dasayojanaāyāmaṁ,"
    },
    {
      "id": "tha-ap452:4.2",
      "pali": "aṭṭhayojanavitthataṁ;"
    },
    {
      "id": "tha-ap452:4.3",
      "pali": "Na tamhi nagare atthi,"
    },
    {
      "id": "tha-ap452:4.4",
      "pali": "kaṭṭhaṁ vallī ca mattikā."
    },
    {
      "id": "tha-ap452:5.1",
      "pali": "Tiriyaṁ yojanaṁ āsi,"
    },
    {
      "id": "tha-ap452:5.2",
      "pali": "addhayojanavitthataṁ;"
    },
    {
      "id": "tha-ap452:5.3",
      "pali": "Maṅgalo nāma pāsādo,"
    },
    {
      "id": "tha-ap452:5.4",
      "pali": "vissakammena māpito."
    },
    {
      "id": "tha-ap452:6.1",
      "pali": "Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap452:6.2",
      "pali": "thambhā soṇṇamayā ahuṁ;"
    },
    {
      "id": "tha-ap452:6.3",
      "pali": "Maṇimayā ca niyyūhā,"
    },
    {
      "id": "tha-ap452:6.4",
      "pali": "chadanaṁ rūpiyaṁ ahu."
    },
    {
      "id": "tha-ap452:7.1",
      "pali": "Sabbasoṇṇamayaṁ gharaṁ,"
    },
    {
      "id": "tha-ap452:7.2",
      "pali": "vissakammena māpitaṁ;"
    },
    {
      "id": "tha-ap452:7.3",
      "pali": "Ajjhāvutthaṁ mayā etaṁ,"
    },
    {
      "id": "tha-ap452:7.4",
      "pali": "gharadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap452:8.1",
      "pali": "Te sabbe anubhotvāna,"
    },
    {
      "id": "tha-ap452:8.2",
      "pali": "devamānusake bhave;"
    },
    {
      "id": "tha-ap452:8.3",
      "pali": "Ajjhapattomhi nibbānaṁ,"
    },
    {
      "id": "tha-ap452:8.4",
      "pali": "santipadamanuttaraṁ."
    },
    {
      "id": "tha-ap452:9.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap452:9.2",
      "pali": "bodhigharamakārayiṁ;"
    },
    {
      "id": "tha-ap452:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap452:9.4",
      "pali": "gharadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap452:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap452:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap452:10.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap452:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap452:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap452:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap452:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap452:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap452:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap452:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā bodhigharadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap452:14.1",
      "pali": "Bodhigharadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap452:15.1",
      "pali": "Vibhītakavaggo pañcacattālīsamo."
    },
    {
      "id": "tha-ap452:16.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap452:17.1",
      "pali": "Vibhītakī kolaphalī,"
    },
    {
      "id": "tha-ap452:17.2",
      "pali": "billabhallātakappado;"
    },
    {
      "id": "tha-ap452:17.3",
      "pali": "Uttalambaṭakī ceva,"
    },
    {
      "id": "tha-ap452:17.4",
      "pali": "āsanī pādapīṭhako."
    },
    {
      "id": "tha-ap452:18.1",
      "pali": "Vediko bodhighariko,"
    },
    {
      "id": "tha-ap452:18.2",
      "pali": "gāthāyo gaṇitāpi ca;"
    },
    {
      "id": "tha-ap452:18.3",
      "pali": "Ekūnāsītikā sabbā,"
    },
    {
      "id": "tha-ap452:18.4",
      "pali": "asmiṁ vagge pakittitā."
    }
  ]
}
