{
  "uid": "ja68",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja68:1.1",
      "pali": "Yasmiṁ mano nivisati,"
    },
    {
      "id": "ja68:1.2",
      "pali": "cittañcāpi pasīdati;"
    },
    {
      "id": "ja68:1.3",
      "pali": "Adiṭṭhapubbake pose,"
    },
    {
      "id": "ja68:1.4",
      "pali": "kāmaṁ tasmimpi vissase”ti."
    },
    {
      "id": "ja68:2.1",
      "pali": "Sāketajātakaṁ aṭṭhamaṁ."
    }
  ]
}
