{
  "uid": "vv85",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv85:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv85:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv85:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv85:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv85:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv85:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv85:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv85:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv85:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv85:3.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv85:3.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv85:3.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv85:4.1",
      "pali": "Pucchāmi taṁ deva mahānubhāva,"
    },
    {
      "id": "vv85:4.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv85:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv85:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv85:5.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv85:5.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv85:5.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv85:5.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv85:6.1",
      "pali": "“Dunnikkhittaṁ mālaṁ sunikkhipitvā,"
    },
    {
      "id": "vv85:6.2",
      "pali": "Patiṭṭhapetvā sugatassa thūpe;"
    },
    {
      "id": "vv85:6.3",
      "pali": "Mahiddhiko camhi mahānubhāvo,"
    },
    {
      "id": "vv85:6.4",
      "pali": "Dibbehi kāmehi samaṅgibhūto."
    },
    {
      "id": "vv85:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv85:7.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv85:7.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv85:7.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv85:8.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv85:8.2",
      "pali": "Manussabhūto yamahaṁ akāsiṁ;"
    },
    {
      "id": "vv85:8.3",
      "pali": "Tenamhi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv85:8.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv85:9.1",
      "pali": "Sunikkhittavimānaṁ ekādasamaṁ."
    },
    {
      "id": "vv85:9.2",
      "pali": "Sunikkhittavaggo sattamo."
    },
    {
      "id": "vv85:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv85:11.1",
      "pali": "Dve daliddā vanavihārā,"
    },
    {
      "id": "vv85:11.2",
      "pali": "Bhatako gopālakaṇḍako;"
    },
    {
      "id": "vv85:11.3",
      "pali": "Anekavaṇṇamaṭṭhakuṇḍalī,"
    },
    {
      "id": "vv85:11.4",
      "pali": "Serīsako sunikkhittaṁ;"
    },
    {
      "id": "vv85:11.5",
      "pali": "Purisānaṁ tatiyo vaggo pavuccatīti."
    },
    {
      "id": "vv85:12.1",
      "pali": "Bhāṇavāraṁ catutthaṁ."
    },
    {
      "id": "vv85:13.1",
      "pali": "Vimānavatthupāḷi niṭṭhitā."
    }
  ]
}
