{
  "uid": "iti10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti10:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti10:2.1",
      "pali": "“Dosaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti10:2.2",
      "pali": "Dosañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti10:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti10:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti10:3.1",
      "pali": "“Yena dosena duṭṭhāse,"
    },
    {
      "id": "iti10:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti10:3.3",
      "pali": "Taṁ dosaṁ sammadaññāya,"
    },
    {
      "id": "iti10:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti10:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti10:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti10:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti10:4.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti10:4.3",
      "pali": "Pāṭibhogavaggo paṭhamo."
    },
    {
      "id": "iti10:5.1",
      "pali": "Rāgadosā atha moho,"
    },
    {
      "id": "iti10:5.2",
      "pali": "Kodhamakkhā mānaṁ sabbaṁ;"
    },
    {
      "id": "iti10:5.3",
      "pali": "Mānato rāgadosā puna dve,"
    },
    {
      "id": "iti10:5.4",
      "pali": "Pakāsitā vaggamāhu paṭhamanti."
    }
  ]
}
