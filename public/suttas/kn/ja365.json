{
  "uid": "ja365",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja365:1.1",
      "pali": "“Dhuttomhi samma sumukha,"
    },
    {
      "id": "ja365:1.2",
      "pali": "jūte akkhaparājito;"
    },
    {
      "id": "ja365:1.3",
      "pali": "Harehi ambapakkāni,"
    },
    {
      "id": "ja365:1.4",
      "pali": "vīriyaṁ te bhakkhayāmase”."
    },
    {
      "id": "ja365:2.1",
      "pali": "“Alikaṁ vata maṁ samma,"
    },
    {
      "id": "ja365:2.2",
      "pali": "abhūtena pasaṁsasi;"
    },
    {
      "id": "ja365:2.3",
      "pali": "Ko te suto vā diṭṭho vā,"
    },
    {
      "id": "ja365:2.4",
      "pali": "sumukho nāma makkaṭo."
    },
    {
      "id": "ja365:3.1",
      "pali": "Ajjāpi me taṁ manasi,"
    },
    {
      "id": "ja365:3.2",
      "pali": "yaṁ maṁ tvaṁ ahituṇḍika;"
    },
    {
      "id": "ja365:3.3",
      "pali": "Dhaññāpaṇaṁ pavisitvā,"
    },
    {
      "id": "ja365:3.4",
      "pali": "matto chātaṁ hanāsi maṁ."
    },
    {
      "id": "ja365:4.1",
      "pali": "Tāhaṁ saraṁ dukkhaseyyaṁ,"
    },
    {
      "id": "ja365:4.2",
      "pali": "api rajjampi kāraye;"
    },
    {
      "id": "ja365:4.3",
      "pali": "Nevāhaṁ yācito dajjaṁ,"
    },
    {
      "id": "ja365:4.4",
      "pali": "tathā hi bhayatajjito."
    },
    {
      "id": "ja365:5.1",
      "pali": "Yañca jaññā kule jātaṁ,"
    },
    {
      "id": "ja365:5.2",
      "pali": "Gabbhe tittaṁ amacchariṁ;"
    },
    {
      "id": "ja365:5.3",
      "pali": "Tena sakhiñca mittañca,"
    },
    {
      "id": "ja365:5.4",
      "pali": "Dhīro sandhātumarahatī”ti."
    },
    {
      "id": "ja365:6.1",
      "pali": "Ahituṇḍikajātakaṁ pañcamaṁ."
    }
  ]
}
