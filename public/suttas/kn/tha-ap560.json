{
  "uid": "tha-ap560",
  "title": "Bhaddajittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap560:1.1",
      "pali": "“Ogayha yaṁ pokkharaṇiṁ,"
    },
    {
      "id": "tha-ap560:1.2",
      "pali": "nānākuñjarasevitaṁ;"
    },
    {
      "id": "tha-ap560:1.3",
      "pali": "Uddharāmi bhisaṁ tattha,"
    },
    {
      "id": "tha-ap560:1.4",
      "pali": "ghāsahetu ahaṁ tadā."
    },
    {
      "id": "tha-ap560:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap560:2.2",
      "pali": "padumuttarasavhayo;"
    },
    {
      "id": "tha-ap560:2.3",
      "pali": "Rattambaradharo buddho,"
    },
    {
      "id": "tha-ap560:2.4",
      "pali": "gacchate anilañjase."
    },
    {
      "id": "tha-ap560:3.1",
      "pali": "Dhunanto paṁsukūlāni,"
    },
    {
      "id": "tha-ap560:3.2",
      "pali": "saddaṁ assosahaṁ tadā;"
    },
    {
      "id": "tha-ap560:3.3",
      "pali": "Uddhaṁ nijjhāyamānohaṁ,"
    },
    {
      "id": "tha-ap560:3.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap560:4.1",
      "pali": "Tattheva ṭhitako santo,"
    },
    {
      "id": "tha-ap560:4.2",
      "pali": "āyāciṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap560:4.3",
      "pali": "‘Madhuṁ bhisehi sahitaṁ,"
    },
    {
      "id": "tha-ap560:4.4",
      "pali": "khīraṁ sappiṁ muḷālikaṁ."
    },
    {
      "id": "tha-ap560:5.1",
      "pali": "Paṭiggaṇhātu me buddho,"
    },
    {
      "id": "tha-ap560:5.2",
      "pali": "anukampāya cakkhumā’;"
    },
    {
      "id": "tha-ap560:5.3",
      "pali": "Tato kāruṇiko satthā,"
    },
    {
      "id": "tha-ap560:5.4",
      "pali": "orohitvā mahāyaso."
    },
    {
      "id": "tha-ap560:6.1",
      "pali": "Paṭiggaṇhi mama bhikkhaṁ,"
    },
    {
      "id": "tha-ap560:6.2",
      "pali": "anukampāya cakkhumā;"
    },
    {
      "id": "tha-ap560:6.3",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "tha-ap560:6.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap560:7.1",
      "pali": "‘Sukhī hotu mahāpuñña,"
    },
    {
      "id": "tha-ap560:7.2",
      "pali": "gati tuyhaṁ samijjhatu;"
    },
    {
      "id": "tha-ap560:7.3",
      "pali": "Iminā bhisadānena,"
    },
    {
      "id": "tha-ap560:7.4",
      "pali": "labhassu vipulaṁ sukhaṁ’."
    },
    {
      "id": "tha-ap560:8.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap560:8.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap560:8.3",
      "pali": "Bhikkhamādāya sambuddho,"
    },
    {
      "id": "tha-ap560:8.4",
      "pali": "ākāsenāgamā jino."
    },
    {
      "id": "tha-ap560:9.1",
      "pali": "Tato bhisaṁ gahetvāna,"
    },
    {
      "id": "tha-ap560:9.2",
      "pali": "āgacchiṁ mama assamaṁ;"
    },
    {
      "id": "tha-ap560:9.3",
      "pali": "Bhisaṁ rukkhe laggetvāna,"
    },
    {
      "id": "tha-ap560:9.4",
      "pali": "mama dānaṁ anussariṁ."
    },
    {
      "id": "tha-ap560:10.1",
      "pali": "Mahāvāto uṭṭhahitvā,"
    },
    {
      "id": "tha-ap560:10.2",
      "pali": "sañcālesi vanaṁ tadā;"
    },
    {
      "id": "tha-ap560:10.3",
      "pali": "Ākāso abhinādittha,"
    },
    {
      "id": "tha-ap560:10.4",
      "pali": "asanī ca phalī tadā."
    },
    {
      "id": "tha-ap560:11.1",
      "pali": "Tato me asanīpāto,"
    },
    {
      "id": "tha-ap560:11.2",
      "pali": "matthake nipatī tadā;"
    },
    {
      "id": "tha-ap560:11.3",
      "pali": "Sohaṁ nisinnako santo,"
    },
    {
      "id": "tha-ap560:11.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap560:12.1",
      "pali": "Puññakammena saññutto,"
    },
    {
      "id": "tha-ap560:12.2",
      "pali": "tusitaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap560:12.3",
      "pali": "Kaḷevaraṁ me patitaṁ,"
    },
    {
      "id": "tha-ap560:12.4",
      "pali": "devaloke ramāmahaṁ."
    },
    {
      "id": "tha-ap560:13.1",
      "pali": "Chaḷasītisahassāni,"
    },
    {
      "id": "tha-ap560:13.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap560:13.3",
      "pali": "Sāyaṁ pātaṁ upaṭṭhanti,"
    },
    {
      "id": "tha-ap560:13.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap560:14.1",
      "pali": "Manussayonimāgantvā,"
    },
    {
      "id": "tha-ap560:14.2",
      "pali": "sukhito homahaṁ tadā;"
    },
    {
      "id": "tha-ap560:14.3",
      "pali": "Bhogā me ūnatā natthi,"
    },
    {
      "id": "tha-ap560:14.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap560:15.1",
      "pali": "Anukampitako tena,"
    },
    {
      "id": "tha-ap560:15.2",
      "pali": "devadevena tādinā;"
    },
    {
      "id": "tha-ap560:15.3",
      "pali": "Sabbāsavaparikkhīṇā,"
    },
    {
      "id": "tha-ap560:15.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap560:16.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap560:16.2",
      "pali": "yaṁ bhisaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap560:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap560:16.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap560:17.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap560:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap560:17.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap560:18.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap560:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap560:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap560:19.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap560:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap560:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap560:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhaddajitthero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap560:21.1",
      "pali": "Bhaddajittherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
