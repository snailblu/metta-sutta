{
  "uid": "iti62",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti62:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti62:2.1",
      "pali": "“Tīṇimāni, bhikkhave, indriyāni."
    },
    {
      "id": "iti62:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti62:2.3",
      "pali": "Anaññātaññassāmītindriyaṁ, aññindriyaṁ, aññātāvindriyaṁ—"
    },
    {
      "id": "iti62:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi indriyānī”ti."
    },
    {
      "id": "iti62:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti62:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti62:3.1",
      "pali": "“Sekhassa sikkhamānassa,"
    },
    {
      "id": "iti62:3.2",
      "pali": "ujumaggānusārino;"
    },
    {
      "id": "iti62:3.3",
      "pali": "Khayasmiṁ paṭhamaṁ ñāṇaṁ,"
    },
    {
      "id": "iti62:3.4",
      "pali": "tato aññā anantarā."
    },
    {
      "id": "iti62:4.1",
      "pali": "Tato aññāvimuttassa,"
    },
    {
      "id": "iti62:4.2",
      "pali": "ñāṇaṁ ve hoti tādino;"
    },
    {
      "id": "iti62:4.3",
      "pali": "Akuppā me vimuttīti,"
    },
    {
      "id": "iti62:4.4",
      "pali": "bhavasaṁyojanakkhayā."
    },
    {
      "id": "iti62:5.1",
      "pali": "Sa ve indriyasampanno,"
    },
    {
      "id": "iti62:5.2",
      "pali": "santo santipade rato;"
    },
    {
      "id": "iti62:5.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "iti62:5.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "iti62:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti62:6.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
