{
  "uid": "iti90",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti90:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti90:2.1",
      "pali": "“Tayome, bhikkhave, aggappasādā."
    },
    {
      "id": "iti90:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti90:2.3",
      "pali": "Yāvatā, bhikkhave, sattā apadā vā dvipadā vā catuppadā vā bahuppadā vā rūpino vā arūpino vā saññino vā asaññino vā nevasaññināsaññino vā, tathāgato tesaṁ aggamakkhāyati arahaṁ sammāsambuddho."
    },
    {
      "id": "iti90:2.4",
      "pali": "Ye, bhikkhave, buddhe pasannā, agge te pasannā."
    },
    {
      "id": "iti90:2.5",
      "pali": "Agge kho pana pasannānaṁ aggo vipāko hoti."
    },
    {
      "id": "iti90:3.1",
      "pali": "Yāvatā, bhikkhave, dhammā saṅkhatā vā asaṅkhatā vā, virāgo tesaṁ aggamakkhāyati, yadidaṁ madanimmadano pipāsavinayo ālayasamugghāto vaṭṭupacchedo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "iti90:3.2",
      "pali": "Ye, bhikkhave, virāge dhamme pasannā, agge te pasannā."
    },
    {
      "id": "iti90:3.3",
      "pali": "Agge kho pana pasannānaṁ aggo vipāko hoti."
    },
    {
      "id": "iti90:4.1",
      "pali": "Yāvatā, bhikkhave, saṅghā vā gaṇā vā, tathāgatasāvakasaṅgho tesaṁ aggamakkhāyati, yadidaṁ cattāri purisayugāni aṭṭha purisapuggalā esa bhagavato sāvakasaṅgho āhuneyyo pāhuneyyo dakkhiṇeyyo añjalikaraṇīyo anuttaraṁ puññakkhettaṁ lokassa."
    },
    {
      "id": "iti90:4.2",
      "pali": "Ye, bhikkhave, saṅghe pasannā, agge te pasannā."
    },
    {
      "id": "iti90:4.3",
      "pali": "Agge kho pana pasannānaṁ aggo vipāko hoti."
    },
    {
      "id": "iti90:4.4",
      "pali": "Ime kho, bhikkhave, tayo aggappasādā”ti."
    },
    {
      "id": "iti90:4.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti90:4.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti90:5.1",
      "pali": "“Aggato ve pasannānaṁ,"
    },
    {
      "id": "iti90:5.2",
      "pali": "aggaṁ dhammaṁ vijānataṁ;"
    },
    {
      "id": "iti90:5.3",
      "pali": "Agge buddhe pasannānaṁ,"
    },
    {
      "id": "iti90:5.4",
      "pali": "dakkhiṇeyye anuttare."
    },
    {
      "id": "iti90:6.1",
      "pali": "Agge dhamme pasannānaṁ,"
    },
    {
      "id": "iti90:6.2",
      "pali": "virāgūpasame sukhe;"
    },
    {
      "id": "iti90:6.3",
      "pali": "Agge saṅghe pasannānaṁ,"
    },
    {
      "id": "iti90:6.4",
      "pali": "puññakkhette anuttare."
    },
    {
      "id": "iti90:7.1",
      "pali": "Aggasmiṁ dānaṁ dadataṁ,"
    },
    {
      "id": "iti90:7.2",
      "pali": "aggaṁ puññaṁ pavaḍḍhati;"
    },
    {
      "id": "iti90:7.3",
      "pali": "Aggaṁ āyu ca vaṇṇo ca,"
    },
    {
      "id": "iti90:7.4",
      "pali": "yaso kitti sukhaṁ balaṁ."
    },
    {
      "id": "iti90:8.1",
      "pali": "Aggassa dātā medhāvī,"
    },
    {
      "id": "iti90:8.2",
      "pali": "aggadhammasamāhito;"
    },
    {
      "id": "iti90:8.3",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "iti90:8.4",
      "pali": "aggappatto pamodatī”ti."
    },
    {
      "id": "iti90:9.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti90:9.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
