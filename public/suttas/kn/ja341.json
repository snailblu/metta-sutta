{
  "uid": "ja341",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja341:1.1",
      "pali": "Narānamārāmakarāsu nārisu,"
    },
    {
      "id": "ja341:1.2",
      "pali": "Anekacittāsu aniggahāsu ca;"
    },
    {
      "id": "ja341:1.3",
      "pali": "Sabbattha nāpītikarāpi ce siyā,"
    },
    {
      "id": "ja341:1.4",
      "pali": "Na vissase titthasamā hi nāriyo."
    },
    {
      "id": "ja341:2.1",
      "pali": "“Yaṁ ve disvā kaṇḍarīkinnarānaṁ,"
    },
    {
      "id": "ja341:2.2",
      "pali": "Sabbitthiyo na ramanti agāre;"
    },
    {
      "id": "ja341:2.3",
      "pali": "Taṁ tādisaṁ maccaṁ cajitvā bhariyā,"
    },
    {
      "id": "ja341:2.4",
      "pali": "Aññaṁ disvā purisaṁ pīṭhasappiṁ”."
    },
    {
      "id": "ja341:3.1",
      "pali": "“Bakassa ca bāvarikassa rañño,"
    },
    {
      "id": "ja341:3.2",
      "pali": "Accantakāmānugatassa bhariyā;"
    },
    {
      "id": "ja341:3.3",
      "pali": "Avācarī paṭṭhavasānugassa,"
    },
    {
      "id": "ja341:3.4",
      "pali": "Kaṁ vāpi itthī nāticare tadaññaṁ”."
    },
    {
      "id": "ja341:4.1",
      "pali": "“Piṅgiyānī sabbalokissarassa,"
    },
    {
      "id": "ja341:4.2",
      "pali": "Rañño piyā brahmadattassa bhariyā;"
    },
    {
      "id": "ja341:4.3",
      "pali": "Avācarī paṭṭhavasānugassa,"
    },
    {
      "id": "ja341:4.4",
      "pali": "Taṁ vāpi sā nājjhagā kāmakāminī”ti."
    },
    {
      "id": "ja341:5.1",
      "pali": "Kaṇḍarījātakaṁ paṭhamaṁ."
    }
  ]
}
