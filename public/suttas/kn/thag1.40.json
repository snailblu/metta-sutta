{
  "uid": "thag1.40",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.40:1.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "thag1.40:1.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "thag1.40:1.3",
      "pali": "Bhavarāgappahānāya,"
    },
    {
      "id": "thag1.40:1.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "thag1.40:1.5",
      "pali": "… Vaḍḍhamāno thero …"
    },
    {
      "id": "thag1.40:1.6",
      "pali": "vaggo catuttho."
    },
    {
      "id": "thag1.40:2.1",
      "pali": "Gahvaratīriyo suppiyo,"
    },
    {
      "id": "thag1.40:2.2",
      "pali": "sopāko ceva posiyo;"
    },
    {
      "id": "thag1.40:2.3",
      "pali": "Sāmaññakāni kumāputto,"
    },
    {
      "id": "thag1.40:2.4",
      "pali": "kumāputtasahāyako;"
    },
    {
      "id": "thag1.40:2.5",
      "pali": "Gavampati tissatthero,"
    },
    {
      "id": "thag1.40:2.6",
      "pali": "vaḍḍhamāno mahāyasoti."
    }
  ]
}
