{
  "uid": "tha-ap459",
  "title": "Ekachattiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap459:1.1",
      "pali": "“Aṅgārajātā pathavī,"
    },
    {
      "id": "tha-ap459:1.2",
      "pali": "kukkuḷānugatā mahī;"
    },
    {
      "id": "tha-ap459:1.3",
      "pali": "Padumuttaro bhagavā,"
    },
    {
      "id": "tha-ap459:1.4",
      "pali": "abbhokāsamhi caṅkami."
    },
    {
      "id": "tha-ap459:2.1",
      "pali": "Paṇḍaraṁ chattamādāya,"
    },
    {
      "id": "tha-ap459:2.2",
      "pali": "addhānaṁ paṭipajjahaṁ;"
    },
    {
      "id": "tha-ap459:2.3",
      "pali": "Tattha disvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap459:2.4",
      "pali": "vitti me upapajjatha."
    },
    {
      "id": "tha-ap459:3.1",
      "pali": "Marīciyotthaṭā bhūmi,"
    },
    {
      "id": "tha-ap459:3.2",
      "pali": "aṅgārāva mahī ayaṁ;"
    },
    {
      "id": "tha-ap459:3.3",
      "pali": "Upahanti mahāvātā,"
    },
    {
      "id": "tha-ap459:3.4",
      "pali": "sarīrassāsukhepanā."
    },
    {
      "id": "tha-ap459:4.1",
      "pali": "Sītaṁ uṇhaṁ vihanantaṁ,"
    },
    {
      "id": "tha-ap459:4.2",
      "pali": "vātātapanivāraṇaṁ;"
    },
    {
      "id": "tha-ap459:4.3",
      "pali": "Paṭiggaṇha imaṁ chattaṁ,"
    },
    {
      "id": "tha-ap459:4.4",
      "pali": "phassayissāmi nibbutiṁ."
    },
    {
      "id": "tha-ap459:5.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap459:5.2",
      "pali": "padumuttaro mahāyaso;"
    },
    {
      "id": "tha-ap459:5.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap459:5.4",
      "pali": "paṭiggaṇhi tadā jino."
    },
    {
      "id": "tha-ap459:6.1",
      "pali": "Tiṁsa kappāni devindo,"
    },
    {
      "id": "tha-ap459:6.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap459:6.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap459:6.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap459:7.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap459:7.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap459:7.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap459:7.4",
      "pali": "pubbe sukatamattano."
    },
    {
      "id": "tha-ap459:8.1",
      "pali": "Ayaṁ me pacchimā jāti,"
    },
    {
      "id": "tha-ap459:8.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap459:8.3",
      "pali": "Ajjāpi setacchattaṁ me,"
    },
    {
      "id": "tha-ap459:8.4",
      "pali": "sabbakālaṁ dharīyati."
    },
    {
      "id": "tha-ap459:9.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap459:9.2",
      "pali": "yaṁ chattamadadiṁ tadā;"
    },
    {
      "id": "tha-ap459:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap459:9.4",
      "pali": "chattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap459:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap459:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap459:10.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap459:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap459:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap459:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap459:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap459:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap459:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap459:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekachattiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap459:14.1",
      "pali": "Ekachattiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
