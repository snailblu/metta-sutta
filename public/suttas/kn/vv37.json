{
  "uid": "vv37",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv37:1.1",
      "pali": "“Kā nāma tvaṁ visālakkhi,"
    },
    {
      "id": "vv37:1.2",
      "pali": "ramme cittalatāvane;"
    },
    {
      "id": "vv37:1.3",
      "pali": "Samantā anupariyāsi,"
    },
    {
      "id": "vv37:1.4",
      "pali": "nārīgaṇapurakkhatā."
    },
    {
      "id": "vv37:2.1",
      "pali": "Yadā devā tāvatiṁsā,"
    },
    {
      "id": "vv37:2.2",
      "pali": "pavisanti imaṁ vanaṁ;"
    },
    {
      "id": "vv37:2.3",
      "pali": "Sayoggā sarathā sabbe,"
    },
    {
      "id": "vv37:2.4",
      "pali": "citrā honti idhāgatā."
    },
    {
      "id": "vv37:3.1",
      "pali": "Tuyhañca idha pattāya,"
    },
    {
      "id": "vv37:3.2",
      "pali": "uyyāne vicarantiyā;"
    },
    {
      "id": "vv37:3.3",
      "pali": "Kāye na dissatī cittaṁ,"
    },
    {
      "id": "vv37:3.4",
      "pali": "kena rūpaṁ tavedisaṁ;"
    },
    {
      "id": "vv37:3.5",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv37:3.6",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv37:4.1",
      "pali": "“Yena kammena devinda,"
    },
    {
      "id": "vv37:4.2",
      "pali": "rūpaṁ mayhaṁ gatī ca me;"
    },
    {
      "id": "vv37:4.3",
      "pali": "Iddhi ca ānubhāvo ca,"
    },
    {
      "id": "vv37:4.4",
      "pali": "taṁ suṇohi purindada."
    },
    {
      "id": "vv37:5.1",
      "pali": "Ahaṁ rājagahe ramme,"
    },
    {
      "id": "vv37:5.2",
      "pali": "sunandā nāmupāsikā;"
    },
    {
      "id": "vv37:5.3",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "vv37:5.4",
      "pali": "saṁvibhāgaratā sadā."
    },
    {
      "id": "vv37:6.1",
      "pali": "Acchādanañca bhattañca,"
    },
    {
      "id": "vv37:6.2",
      "pali": "senāsanaṁ padīpiyaṁ;"
    },
    {
      "id": "vv37:6.3",
      "pali": "Adāsiṁ ujubhūtesu,"
    },
    {
      "id": "vv37:6.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "vv37:7.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv37:7.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv37:7.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv37:7.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "vv37:8.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "vv37:8.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "vv37:8.3",
      "pali": "Saññamā saṁvibhāgā ca,"
    },
    {
      "id": "vv37:8.4",
      "pali": "vimānaṁ āvasāmahaṁ."
    },
    {
      "id": "vv37:9.1",
      "pali": "Pāṇātipātā viratā,"
    },
    {
      "id": "vv37:9.2",
      "pali": "musāvādā ca saññatā;"
    },
    {
      "id": "vv37:9.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv37:9.4",
      "pali": "majjapānā ca ārakā."
    },
    {
      "id": "vv37:10.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv37:10.2",
      "pali": "ariyasaccāna kovidā;"
    },
    {
      "id": "vv37:10.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv37:10.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv37:11.1",
      "pali": "Tassā me ñātikulā dāsī,"
    },
    {
      "id": "vv37:11.2",
      "pali": "sadā mālābhihārati;"
    },
    {
      "id": "vv37:11.3",
      "pali": "Tāhaṁ bhagavato thūpe,"
    },
    {
      "id": "vv37:11.4",
      "pali": "sabbamevābhiropayiṁ."
    },
    {
      "id": "vv37:12.1",
      "pali": "Uposathe cahaṁ gantvā,"
    },
    {
      "id": "vv37:12.2",
      "pali": "mālāgandhavilepanaṁ;"
    },
    {
      "id": "vv37:12.3",
      "pali": "Thūpasmiṁ abhiropesiṁ,"
    },
    {
      "id": "vv37:12.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv37:13.1",
      "pali": "Tena kammena devinda,"
    },
    {
      "id": "vv37:13.2",
      "pali": "rūpaṁ mayhaṁ gatī ca me;"
    },
    {
      "id": "vv37:13.3",
      "pali": "Iddhī ca ānubhāvo ca,"
    },
    {
      "id": "vv37:13.4",
      "pali": "yaṁ mālaṁ abhiropayiṁ."
    },
    {
      "id": "vv37:14.1",
      "pali": "Yañca sīlavatī āsiṁ,"
    },
    {
      "id": "vv37:14.2",
      "pali": "na taṁ tāva vipaccati;"
    },
    {
      "id": "vv37:14.3",
      "pali": "Āsā ca pana me devinda,"
    },
    {
      "id": "vv37:14.4",
      "pali": "sakadāgāminī siyan”ti."
    },
    {
      "id": "vv37:15.1",
      "pali": "Visālakkhivimānaṁ navamaṁ."
    }
  ]
}
