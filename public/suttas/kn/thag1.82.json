{
  "uid": "thag1.82",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.82:1.1",
      "pali": "“Yena yena subhikkhāni,"
    },
    {
      "id": "thag1.82:1.2",
      "pali": "sivāni abhayāni ca;"
    },
    {
      "id": "thag1.82:1.3",
      "pali": "Tena puttaka gacchassu,"
    },
    {
      "id": "thag1.82:1.4",
      "pali": "mā sokāpahato bhavā”ti."
    },
    {
      "id": "thag1.82:1.5",
      "pali": "… Kassapo thero …."
    }
  ]
}
