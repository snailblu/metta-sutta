{
  "uid": "thag3.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.9:1.1",
      "pali": "“Kālapabbaṅgasaṅkāso,"
    },
    {
      "id": "thag3.9:1.2",
      "pali": "kiso dhamanisanthato;"
    },
    {
      "id": "thag3.9:1.3",
      "pali": "Mattaññū annapānamhi,"
    },
    {
      "id": "thag3.9:1.4",
      "pali": "adīnamānaso naro”."
    },
    {
      "id": "thag3.9:2.1",
      "pali": "“Phuṭṭho ḍaṁsehi makasehi,"
    },
    {
      "id": "thag3.9:2.2",
      "pali": "araññasmiṁ brahāvane;"
    },
    {
      "id": "thag3.9:2.3",
      "pali": "Nāgo saṅgāmasīseva,"
    },
    {
      "id": "thag3.9:2.4",
      "pali": "sato tatrādhivāsaye."
    },
    {
      "id": "thag3.9:3.1",
      "pali": "Yathā brahmā tathā eko,"
    },
    {
      "id": "thag3.9:3.2",
      "pali": "yathā devo tathā duve;"
    },
    {
      "id": "thag3.9:3.3",
      "pali": "Yathā gāmo tathā tayo,"
    },
    {
      "id": "thag3.9:3.4",
      "pali": "kolāhalaṁ tatuttarin”ti."
    },
    {
      "id": "thag3.9:3.5",
      "pali": "… Yasojo thero …."
    }
  ]
}
