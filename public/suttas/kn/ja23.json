{
  "uid": "ja23",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja23:1.1",
      "pali": "“Api passena semāno,"
    },
    {
      "id": "ja23:1.2",
      "pali": "sallebhi sallalīkato;"
    },
    {
      "id": "ja23:1.3",
      "pali": "Seyyova vaḷavā bhojjo,"
    },
    {
      "id": "ja23:1.4",
      "pali": "yuñja maññeva sārathī”ti."
    },
    {
      "id": "ja23:2.1",
      "pali": "Bhojājānīyajātakaṁ tatiyaṁ."
    }
  ]
}
