{
  "uid": "tha-ap529",
  "title": "Girinelapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap529:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap529:1.2",
      "pali": "vipine vicaraṁ ahaṁ;"
    },
    {
      "id": "tha-ap529:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap529:1.4",
      "pali": "sabbadhammāna pāraguṁ."
    },
    {
      "id": "tha-ap529:2.1",
      "pali": "Tasmiṁ mahākāruṇike,"
    },
    {
      "id": "tha-ap529:2.2",
      "pali": "sabbasattahite rate;"
    },
    {
      "id": "tha-ap529:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap529:2.4",
      "pali": "nelapupphamapūjayiṁ."
    },
    {
      "id": "tha-ap529:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap529:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap529:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap529:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap529:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap529:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap529:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap529:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap529:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap529:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap529:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap529:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap529:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap529:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā girinelapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap529:8.1",
      "pali": "Girinelapūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
