{
  "uid": "tha-ap226",
  "title": "Ārakkhadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap226:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap226:1.2",
      "pali": "vedi kārāpitā mayā;"
    },
    {
      "id": "tha-ap226:1.3",
      "pali": "Ārakkho ca mayā dinno,"
    },
    {
      "id": "tha-ap226:1.4",
      "pali": "sugatassa mahesino."
    },
    {
      "id": "tha-ap226:2.1",
      "pali": "Tena kammavisesena,"
    },
    {
      "id": "tha-ap226:2.2",
      "pali": "na passiṁ bhayabheravaṁ;"
    },
    {
      "id": "tha-ap226:2.3",
      "pali": "Kuhiñci upapannassa,"
    },
    {
      "id": "tha-ap226:2.4",
      "pali": "tāso mayhaṁ na vijjati."
    },
    {
      "id": "tha-ap226:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap226:3.2",
      "pali": "yaṁ vediṁ kārayiṁ pure;"
    },
    {
      "id": "tha-ap226:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap226:3.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap226:4.1",
      "pali": "Ito chaṭṭhamhi kappamhi,"
    },
    {
      "id": "tha-ap226:4.2",
      "pali": "apassenasanāmako;"
    },
    {
      "id": "tha-ap226:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap226:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap226:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap226:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap226:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap226:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ārakkhadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap226:7.1",
      "pali": "Ārakkhadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
