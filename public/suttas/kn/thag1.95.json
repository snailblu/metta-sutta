{
  "uid": "thag1.95",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.95:1.1",
      "pali": "“Andhohaṁ hatanettosmi,"
    },
    {
      "id": "thag1.95:1.2",
      "pali": "kantāraddhānapakkhando;"
    },
    {
      "id": "thag1.95:1.3",
      "pali": "Sayamānopi gacchissaṁ,"
    },
    {
      "id": "thag1.95:1.4",
      "pali": "na sahāyena pāpenā”ti."
    },
    {
      "id": "thag1.95:1.5",
      "pali": "… Cakkhupālo thero …."
    }
  ]
}
