{
  "uid": "iti26",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti26:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti26:2.1",
      "pali": "“Evañce, bhikkhave, sattā jāneyyuṁ dānasaṁvibhāgassa vipākaṁ yathāhaṁ jānāmi, na adatvā bhuñjeyyuṁ, na ca nesaṁ maccheramalaṁ cittaṁ pariyādāya tiṭṭheyya."
    },
    {
      "id": "iti26:2.2",
      "pali": "Yopi nesaṁ assa carimo ālopo carimaṁ kabaḷaṁ, tatopi na asaṁvibhajitvā bhuñjeyyuṁ, sace nesaṁ paṭiggāhakā assu."
    },
    {
      "id": "iti26:2.3",
      "pali": "Yasmā ca kho, bhikkhave, sattā na evaṁ jānanti dānasaṁvibhāgassa vipākaṁ yathāhaṁ jānāmi, tasmā adatvā bhuñjanti, maccheramalañca nesaṁ cittaṁ pariyādāya tiṭṭhatī”ti."
    },
    {
      "id": "iti26:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti26:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti26:3.1",
      "pali": "“Evañce sattā jāneyyuṁ,"
    },
    {
      "id": "iti26:3.2",
      "pali": "yathāvuttaṁ mahesinā;"
    },
    {
      "id": "iti26:3.3",
      "pali": "Vipākaṁ saṁvibhāgassa,"
    },
    {
      "id": "iti26:3.4",
      "pali": "yathā hoti mahapphalaṁ."
    },
    {
      "id": "iti26:4.1",
      "pali": "Vineyya maccheramalaṁ,"
    },
    {
      "id": "iti26:4.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "iti26:4.3",
      "pali": "Dajjuṁ kālena ariyesu,"
    },
    {
      "id": "iti26:4.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "iti26:5.1",
      "pali": "Annañca datvā bahuno,"
    },
    {
      "id": "iti26:5.2",
      "pali": "dakkhiṇeyyesu dakkhiṇaṁ;"
    },
    {
      "id": "iti26:5.3",
      "pali": "Ito cutā manussattā,"
    },
    {
      "id": "iti26:5.4",
      "pali": "saggaṁ gacchanti dāyakā."
    },
    {
      "id": "iti26:6.1",
      "pali": "Te ca saggagatā tattha,"
    },
    {
      "id": "iti26:6.2",
      "pali": "modanti kāmakāmino;"
    },
    {
      "id": "iti26:6.3",
      "pali": "Vipākaṁ saṁvibhāgassa,"
    },
    {
      "id": "iti26:6.4",
      "pali": "anubhonti amaccharā”ti."
    },
    {
      "id": "iti26:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti26:7.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
