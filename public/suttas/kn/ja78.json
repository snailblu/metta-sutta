{
  "uid": "ja78",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja78:1.1",
      "pali": "“Ubho khañjā ubho kuṇī,"
    },
    {
      "id": "ja78:1.2",
      "pali": "ubho visamacakkhukā;"
    },
    {
      "id": "ja78:1.3",
      "pali": "Ubhinnaṁ piḷakā jātā,"
    },
    {
      "id": "ja78:1.4",
      "pali": "nāhaṁ passāmi illisan”ti."
    },
    {
      "id": "ja78:2.1",
      "pali": "Illisajātakaṁ aṭṭhamaṁ."
    }
  ]
}
