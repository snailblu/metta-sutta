{
  "uid": "ja382",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja382:1.1",
      "pali": "“Kā nu kāḷena vaṇṇena,"
    },
    {
      "id": "ja382:1.2",
      "pali": "na cāpi piyadassanā;"
    },
    {
      "id": "ja382:1.3",
      "pali": "Kā vā tvaṁ kassa vā dhītā,"
    },
    {
      "id": "ja382:1.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja382:2.1",
      "pali": "“Mahārājassahaṁ dhītā,"
    },
    {
      "id": "ja382:2.2",
      "pali": "virūpakkhassa caṇḍiyā;"
    },
    {
      "id": "ja382:2.3",
      "pali": "Ahaṁ kāḷī alakkhikā,"
    },
    {
      "id": "ja382:2.4",
      "pali": "kāḷakaṇṇīti maṁ vidū;"
    },
    {
      "id": "ja382:2.5",
      "pali": "Okāsaṁ yācito dehi,"
    },
    {
      "id": "ja382:2.6",
      "pali": "vasemu tava santike”."
    },
    {
      "id": "ja382:3.1",
      "pali": "“Kiṁsīle kiṁsamācāre,"
    },
    {
      "id": "ja382:3.2",
      "pali": "Purise nivisase tuvaṁ;"
    },
    {
      "id": "ja382:3.3",
      "pali": "Puṭṭhā me kāḷi akkhāhi,"
    },
    {
      "id": "ja382:3.4",
      "pali": "Kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja382:4.1",
      "pali": "“Makkhī paḷāsī sārambhī,"
    },
    {
      "id": "ja382:4.2",
      "pali": "issukī maccharī saṭho;"
    },
    {
      "id": "ja382:4.3",
      "pali": "So mayhaṁ puriso kanto,"
    },
    {
      "id": "ja382:4.4",
      "pali": "laddhaṁ yassa vinassati."
    },
    {
      "id": "ja382:5.1",
      "pali": "Kodhano upanāhī ca,"
    },
    {
      "id": "ja382:5.2",
      "pali": "pisuṇo ca vibhedako;"
    },
    {
      "id": "ja382:5.3",
      "pali": "Kaṇḍakavāco pharuso,"
    },
    {
      "id": "ja382:5.4",
      "pali": "so me kantataro tato."
    },
    {
      "id": "ja382:6.1",
      "pali": "Ajja suveti puriso,"
    },
    {
      "id": "ja382:6.2",
      "pali": "sadatthaṁ nāvabujjhati;"
    },
    {
      "id": "ja382:6.3",
      "pali": "Ovajjamāno kuppati,"
    },
    {
      "id": "ja382:6.4",
      "pali": "seyyaṁ so atimaññati."
    },
    {
      "id": "ja382:7.1",
      "pali": "Davappaluddho puriso,"
    },
    {
      "id": "ja382:7.2",
      "pali": "sabbamittehi dhaṁsati;"
    },
    {
      "id": "ja382:7.3",
      "pali": "So mayhaṁ puriso kanto,"
    },
    {
      "id": "ja382:7.4",
      "pali": "tasmiṁ homi anāmayā”."
    },
    {
      "id": "ja382:8.1",
      "pali": "“Apehi etto tvaṁ kāḷi,"
    },
    {
      "id": "ja382:8.2",
      "pali": "netaṁ amhesu vijjati;"
    },
    {
      "id": "ja382:8.3",
      "pali": "Aññaṁ janapadaṁ gaccha,"
    },
    {
      "id": "ja382:8.4",
      "pali": "nigame rājadhāniyo”."
    },
    {
      "id": "ja382:9.1",
      "pali": "“Ahampi kho taṁ jānāmi,"
    },
    {
      "id": "ja382:9.2",
      "pali": "netaṁ tumhesu vijjati;"
    },
    {
      "id": "ja382:9.3",
      "pali": "Santi loke alakkhikā,"
    },
    {
      "id": "ja382:9.4",
      "pali": "saṅgharanti bahuṁ dhanaṁ;"
    },
    {
      "id": "ja382:9.5",
      "pali": "Ahaṁ devo ca me bhātā,"
    },
    {
      "id": "ja382:9.6",
      "pali": "ubho naṁ vidhamāmase”."
    },
    {
      "id": "ja382:10.1",
      "pali": "“Kā nu dibbena vaṇṇena,"
    },
    {
      "id": "ja382:10.2",
      "pali": "pathabyā supatiṭṭhitā;"
    },
    {
      "id": "ja382:10.3",
      "pali": "Kā vā tvaṁ kassa vā dhītā,"
    },
    {
      "id": "ja382:10.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja382:11.1",
      "pali": "“Mahārājassahaṁ dhītā,"
    },
    {
      "id": "ja382:11.2",
      "pali": "dhataraṭṭhassa sirīmato;"
    },
    {
      "id": "ja382:11.3",
      "pali": "Ahaṁ sirī ca lakkhī ca,"
    },
    {
      "id": "ja382:11.4",
      "pali": "bhūripaññāti maṁ vidū;"
    },
    {
      "id": "ja382:11.5",
      "pali": "Okāsaṁ yācito dehi,"
    },
    {
      "id": "ja382:11.6",
      "pali": "vasemu tava santike”."
    },
    {
      "id": "ja382:12.1",
      "pali": "“Kiṁsīle kiṁsamācāre,"
    },
    {
      "id": "ja382:12.2",
      "pali": "Purise nivisase tuvaṁ;"
    },
    {
      "id": "ja382:12.3",
      "pali": "Puṭṭhā me lakkhi akkhāhi,"
    },
    {
      "id": "ja382:12.4",
      "pali": "Kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja382:13.1",
      "pali": "“Yo cāpi sīte atha vāpi uṇhe,"
    },
    {
      "id": "ja382:13.2",
      "pali": "Vātātape ḍaṁsasarīsape ca;"
    },
    {
      "id": "ja382:13.3",
      "pali": "Khudhaṁ pipāsaṁ abhibhuyya sabbaṁ,"
    },
    {
      "id": "ja382:13.4",
      "pali": "Rattindivaṁ yo satataṁ niyutto."
    },
    {
      "id": "ja382:14.1",
      "pali": "Kālāgatañca na hāpeti atthaṁ,"
    },
    {
      "id": "ja382:14.2",
      "pali": "So me manāpo nivise ca tamhi;"
    },
    {
      "id": "ja382:14.3",
      "pali": "Akkodhano mittavā cāgavā ca,"
    },
    {
      "id": "ja382:14.4",
      "pali": "Sīlūpapanno asaṭhojubhūto."
    },
    {
      "id": "ja382:15.1",
      "pali": "Saṅgāhako sakhilo saṇhavāco,"
    },
    {
      "id": "ja382:15.2",
      "pali": "Mahattapattopi nivātavutti;"
    },
    {
      "id": "ja382:15.3",
      "pali": "Tasmiṁhaṁ pose vipulā bhavāmi,"
    },
    {
      "id": "ja382:15.4",
      "pali": "Ūmi samuddassa yathāpi vaṇṇaṁ."
    },
    {
      "id": "ja382:16.1",
      "pali": "Yo cāpi mitte atha vā amitte,"
    },
    {
      "id": "ja382:16.2",
      "pali": "Seṭṭhe sarikkhe atha vāpi hīne;"
    },
    {
      "id": "ja382:16.3",
      "pali": "Atthaṁ carantaṁ atha vā anatthaṁ,"
    },
    {
      "id": "ja382:16.4",
      "pali": "Āvī raho saṅgahameva vatte."
    },
    {
      "id": "ja382:17.1",
      "pali": "Vācaṁ na vajjā pharusaṁ kadāci,"
    },
    {
      "id": "ja382:17.2",
      "pali": "Matassa jīvassa ca tassa homi;"
    },
    {
      "id": "ja382:17.3",
      "pali": "Etesaṁ yo aññataraṁ labhitvā,"
    },
    {
      "id": "ja382:17.4",
      "pali": "Kantā sirī majjati appapañño;"
    },
    {
      "id": "ja382:17.5",
      "pali": "Taṁ dittarūpaṁ visamaṁ carantaṁ,"
    },
    {
      "id": "ja382:17.6",
      "pali": "Karīsaṭhānaṁva vivajjayāmi."
    },
    {
      "id": "ja382:18.1",
      "pali": "Attanā kurute lakkhiṁ,"
    },
    {
      "id": "ja382:18.2",
      "pali": "alakkhiṁ kurutattanā;"
    },
    {
      "id": "ja382:18.3",
      "pali": "Na hi lakkhiṁ alakkhiṁ vā,"
    },
    {
      "id": "ja382:18.4",
      "pali": "añño aññassa kārako”ti."
    },
    {
      "id": "ja382:19.1",
      "pali": "Sirikāḷakaṇṇijātakaṁ sattamaṁ."
    }
  ]
}
