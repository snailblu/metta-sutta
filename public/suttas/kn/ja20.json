{
  "uid": "ja20",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja20:1.1",
      "pali": "“Disvā padamanuttiṇṇaṁ,"
    },
    {
      "id": "ja20:1.2",
      "pali": "Disvānotaritaṁ padaṁ;"
    },
    {
      "id": "ja20:1.3",
      "pali": "Naḷena vāriṁ pissāma,"
    },
    {
      "id": "ja20:1.4",
      "pali": "Neva maṁ tvaṁ vadhissasī”ti."
    },
    {
      "id": "ja20:2.1",
      "pali": "Naḷapānajātakaṁ dasamaṁ."
    },
    {
      "id": "ja20:2.2",
      "pali": "Sīlavaggo dutiyo."
    },
    {
      "id": "ja20:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja20:4.1",
      "pali": "Atha lakkhaṇa sākha dhiratthu puna,"
    },
    {
      "id": "ja20:4.2",
      "pali": "Na kiratthi rasehi kharādiyā;"
    },
    {
      "id": "ja20:4.3",
      "pali": "Atibhoti vara māluta pāṇa,"
    },
    {
      "id": "ja20:4.4",
      "pali": "Muccena naḷaavhayanena bhavanti dasāti."
    }
  ]
}
