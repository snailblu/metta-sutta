{
  "uid": "iti107",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti107:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti107:2.1",
      "pali": "“Bahukārā, bhikkhave, brāhmaṇagahapatikā tumhākaṁ ye vo paccupaṭṭhitā cīvarapiṇḍapātasenāsanagilānapaccayabhesajjaparikkhārehi."
    },
    {
      "id": "iti107:2.2",
      "pali": "Tumhepi, bhikkhave, bahukārā brāhmaṇagahapatikānaṁ yaṁ nesaṁ dhammaṁ desetha ādikalyāṇaṁ majjhekalyāṇaṁ pariyosānakalyāṇaṁ sātthaṁ sabyañjanaṁ, kevalaparipuṇṇaṁ parisuddhaṁ brahmacariyaṁ pakāsetha."
    },
    {
      "id": "iti107:2.3",
      "pali": "Evamidaṁ, bhikkhave, aññamaññaṁ nissāya brahmacariyaṁ vussati oghassa nittharaṇatthāya sammā dukkhassa antakiriyāyā”ti."
    },
    {
      "id": "iti107:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti107:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti107:3.1",
      "pali": "“Sāgārā anagārā ca,"
    },
    {
      "id": "iti107:3.2",
      "pali": "ubho aññoññanissitā;"
    },
    {
      "id": "iti107:3.3",
      "pali": "Ārādhayanti saddhammaṁ,"
    },
    {
      "id": "iti107:3.4",
      "pali": "yogakkhemaṁ anuttaraṁ."
    },
    {
      "id": "iti107:4.1",
      "pali": "Sāgāresu ca cīvaraṁ,"
    },
    {
      "id": "iti107:4.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "iti107:4.3",
      "pali": "Anagārā paṭicchanti,"
    },
    {
      "id": "iti107:4.4",
      "pali": "parissayavinodanaṁ."
    },
    {
      "id": "iti107:5.1",
      "pali": "Sugataṁ pana nissāya,"
    },
    {
      "id": "iti107:5.2",
      "pali": "gahaṭṭhā gharamesino;"
    },
    {
      "id": "iti107:5.3",
      "pali": "Saddahānā arahataṁ,"
    },
    {
      "id": "iti107:5.4",
      "pali": "ariyapaññāya jhāyino."
    },
    {
      "id": "iti107:6.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "iti107:6.2",
      "pali": "maggaṁ sugatigāminaṁ;"
    },
    {
      "id": "iti107:6.3",
      "pali": "Nandino devalokasmiṁ,"
    },
    {
      "id": "iti107:6.4",
      "pali": "modanti kāmakāmino”ti."
    },
    {
      "id": "iti107:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti107:7.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
