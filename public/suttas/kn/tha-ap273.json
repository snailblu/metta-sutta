{
  "uid": "tha-ap273",
  "title": "1 Suvaṇṇabibbohaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap273:1.1",
      "pali": "“Ekāsanaṁ ahamadaṁ,"
    },
    {
      "id": "tha-ap273:1.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap273:1.3",
      "pali": "Bibbohanañca pādāsiṁ,"
    },
    {
      "id": "tha-ap273:1.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "tha-ap273:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap273:2.2",
      "pali": "bibbohanamadāsahaṁ;"
    },
    {
      "id": "tha-ap273:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap273:2.4",
      "pali": "bibbohanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap273:3.1",
      "pali": "Ito tesaṭṭhime kappe,"
    },
    {
      "id": "tha-ap273:3.2",
      "pali": "asamo nāma khattiyo;"
    },
    {
      "id": "tha-ap273:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap273:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap273:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap273:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap273:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap273:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap273:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā suvaṇṇabibbohaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap273:6.1",
      "pali": "Suvaṇṇabibbohaniyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
