{
  "uid": "tha-ap317",
  "title": "Pupphāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap317:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap317:1.2",
      "pali": "Pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap317:1.3",
      "pali": "Avidūrena gacchantaṁ,"
    },
    {
      "id": "tha-ap317:1.4",
      "pali": "Siddhatthaṁ aparājitaṁ."
    },
    {
      "id": "tha-ap317:2.1",
      "pali": "Tassa paccuggamitvāna,"
    },
    {
      "id": "tha-ap317:2.2",
      "pali": "pavesetvāna assamaṁ;"
    },
    {
      "id": "tha-ap317:2.3",
      "pali": "Pupphāsanaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap317:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap317:3.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap317:3.2",
      "pali": "vedajāto tadā ahaṁ;"
    },
    {
      "id": "tha-ap317:3.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap317:3.4",
      "pali": "taṁ kammaṁ pariṇāmayiṁ."
    },
    {
      "id": "tha-ap317:4.1",
      "pali": "Yaṁ me atthi kataṁ puññaṁ,"
    },
    {
      "id": "tha-ap317:4.2",
      "pali": "sayambhumhaparājite;"
    },
    {
      "id": "tha-ap317:4.3",
      "pali": "Sabbena tena kusalena,"
    },
    {
      "id": "tha-ap317:4.4",
      "pali": "vimalo homi sāsane."
    },
    {
      "id": "tha-ap317:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap317:5.2",
      "pali": "pupphāsanamadaṁ tadā;"
    },
    {
      "id": "tha-ap317:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap317:5.4",
      "pali": "pupphāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap317:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap317:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap317:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap317:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap317:8.1",
      "pali": "Pupphāsanadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
