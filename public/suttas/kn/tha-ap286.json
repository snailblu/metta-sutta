{
  "uid": "tha-ap286",
  "title": "Ekapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap286:1.1",
      "pali": "“Dakkhiṇamhi duvāramhi,"
    },
    {
      "id": "tha-ap286:1.2",
      "pali": "pisāco āsahaṁ tadā;"
    },
    {
      "id": "tha-ap286:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap286:1.4",
      "pali": "pītaraṁsiṁva bhāṇumaṁ."
    },
    {
      "id": "tha-ap286:2.1",
      "pali": "Vipassissa naraggassa,"
    },
    {
      "id": "tha-ap286:2.2",
      "pali": "sabbalokahitesino;"
    },
    {
      "id": "tha-ap286:2.3",
      "pali": "Ekapupphaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap286:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap286:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap286:3.2",
      "pali": "yaṁ pupphamadadiṁ tadā;"
    },
    {
      "id": "tha-ap286:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap286:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap286:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap286:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap286:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap286:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap286:6.1",
      "pali": "Ekapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
