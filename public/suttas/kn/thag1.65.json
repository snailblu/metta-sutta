{
  "uid": "thag1.65",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.65:1.1",
      "pali": "“Ukkhepakatavacchassa,"
    },
    {
      "id": "thag1.65:1.2",
      "pali": "Saṅkalitaṁ bahūhi vassehi;"
    },
    {
      "id": "thag1.65:1.3",
      "pali": "Taṁ bhāsati gahaṭṭhānaṁ,"
    },
    {
      "id": "thag1.65:1.4",
      "pali": "Sunisinno uḷārapāmojjo”ti."
    },
    {
      "id": "thag1.65:1.5",
      "pali": "… Ukkhepakatavaccho thero …."
    }
  ]
}
