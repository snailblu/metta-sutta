{
  "uid": "tha-ap492",
  "title": "Sālamaṇḍapiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap492:1.1",
      "pali": "“Ajjhogāhetvā sālavanaṁ,"
    },
    {
      "id": "tha-ap492:1.2",
      "pali": "sukato assamo mama;"
    },
    {
      "id": "tha-ap492:1.3",
      "pali": "Sālapupphehi sañchanno,"
    },
    {
      "id": "tha-ap492:1.4",
      "pali": "vasāmi vipine tadā."
    },
    {
      "id": "tha-ap492:2.1",
      "pali": "Piyadassī ca bhagavā,"
    },
    {
      "id": "tha-ap492:2.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap492:2.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap492:2.4",
      "pali": "sālavanamupāgami."
    },
    {
      "id": "tha-ap492:3.1",
      "pali": "Assamā abhinikkhamma,"
    },
    {
      "id": "tha-ap492:3.2",
      "pali": "pavanaṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap492:3.3",
      "pali": "Mūlaphalaṁ gavesanto,"
    },
    {
      "id": "tha-ap492:3.4",
      "pali": "āhiṇḍāmi vane tadā."
    },
    {
      "id": "tha-ap492:4.1",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap492:4.2",
      "pali": "piyadassiṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap492:4.3",
      "pali": "Sunisinnaṁ samāpannaṁ,"
    },
    {
      "id": "tha-ap492:4.4",
      "pali": "virocantaṁ mahāvane."
    },
    {
      "id": "tha-ap492:5.1",
      "pali": "Catudaṇḍe ṭhapetvāna,"
    },
    {
      "id": "tha-ap492:5.2",
      "pali": "buddhassa uparī ahaṁ;"
    },
    {
      "id": "tha-ap492:5.3",
      "pali": "Maṇḍapaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap492:5.4",
      "pali": "sālapupphehi chādayiṁ."
    },
    {
      "id": "tha-ap492:6.1",
      "pali": "Sattāhaṁ dhārayitvāna,"
    },
    {
      "id": "tha-ap492:6.2",
      "pali": "maṇḍapaṁ sālachāditaṁ;"
    },
    {
      "id": "tha-ap492:6.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap492:6.4",
      "pali": "buddhaseṭṭhamavandahaṁ."
    },
    {
      "id": "tha-ap492:7.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap492:7.2",
      "pali": "vuṭṭhahitvā samādhito;"
    },
    {
      "id": "tha-ap492:7.3",
      "pali": "Yugamattaṁ pekkhamāno,"
    },
    {
      "id": "tha-ap492:7.4",
      "pali": "nisīdi purisuttamo."
    },
    {
      "id": "tha-ap492:8.1",
      "pali": "Sāvako varuṇo nāma,"
    },
    {
      "id": "tha-ap492:8.2",
      "pali": "piyadassissa satthuno;"
    },
    {
      "id": "tha-ap492:8.3",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap492:8.4",
      "pali": "upagacchi vināyakaṁ."
    },
    {
      "id": "tha-ap492:9.1",
      "pali": "Piyadassī ca bhagavā,"
    },
    {
      "id": "tha-ap492:9.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap492:9.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap492:9.4",
      "pali": "sitaṁ pātukarī jino."
    },
    {
      "id": "tha-ap492:10.1",
      "pali": "Anuruddho upaṭṭhāko,"
    },
    {
      "id": "tha-ap492:10.2",
      "pali": "piyadassissa satthuno;"
    },
    {
      "id": "tha-ap492:10.3",
      "pali": "Ekaṁsaṁ cīvaraṁ katvā,"
    },
    {
      "id": "tha-ap492:10.4",
      "pali": "apucchittha mahāmuniṁ."
    },
    {
      "id": "tha-ap492:11.1",
      "pali": "‘Ko nu kho bhagavā hetu,"
    },
    {
      "id": "tha-ap492:11.2",
      "pali": "sitakammassa satthuno;"
    },
    {
      "id": "tha-ap492:11.3",
      "pali": "Kāraṇe vijjamānamhi,"
    },
    {
      "id": "tha-ap492:11.4",
      "pali": "satthā pātukare sitaṁ’."
    },
    {
      "id": "tha-ap492:12.1",
      "pali": "‘Sattāhaṁ sālacchadanaṁ,"
    },
    {
      "id": "tha-ap492:12.2",
      "pali": "yo me dhāresi māṇavo;"
    },
    {
      "id": "tha-ap492:12.3",
      "pali": "Tassa kammaṁ saritvāna,"
    },
    {
      "id": "tha-ap492:12.4",
      "pali": "sitaṁ pātukariṁ ahaṁ."
    },
    {
      "id": "tha-ap492:13.1",
      "pali": "Anokāsaṁ na passāmi,"
    },
    {
      "id": "tha-ap492:13.2",
      "pali": "yattha puññaṁ vipaccati;"
    },
    {
      "id": "tha-ap492:13.3",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap492:13.4",
      "pali": "okāsova na sammati."
    },
    {
      "id": "tha-ap492:14.1",
      "pali": "Devaloke vasantassa,"
    },
    {
      "id": "tha-ap492:14.2",
      "pali": "puññakammasamaṅgino;"
    },
    {
      "id": "tha-ap492:14.3",
      "pali": "Yāvatā parisā tassa,"
    },
    {
      "id": "tha-ap492:14.4",
      "pali": "sālacchannā bhavissati."
    },
    {
      "id": "tha-ap492:15.1",
      "pali": "Tattha dibbehi naccehi,"
    },
    {
      "id": "tha-ap492:15.2",
      "pali": "gītehi vāditehi ca;"
    },
    {
      "id": "tha-ap492:15.3",
      "pali": "Ramissati sadā santo,"
    },
    {
      "id": "tha-ap492:15.4",
      "pali": "puññakammasamāhito."
    },
    {
      "id": "tha-ap492:16.1",
      "pali": "Yāvatā parisā tassa,"
    },
    {
      "id": "tha-ap492:16.2",
      "pali": "gandhagandhī bhavissati;"
    },
    {
      "id": "tha-ap492:16.3",
      "pali": "Sālassa pupphavasso ca,"
    },
    {
      "id": "tha-ap492:16.4",
      "pali": "pavassissati tāvade."
    },
    {
      "id": "tha-ap492:17.1",
      "pali": "Tato cutoyaṁ manujo,"
    },
    {
      "id": "tha-ap492:17.2",
      "pali": "mānusaṁ āgamissati;"
    },
    {
      "id": "tha-ap492:17.3",
      "pali": "Idhāpi sālacchadanaṁ,"
    },
    {
      "id": "tha-ap492:17.4",
      "pali": "sabbakālaṁ dharissati."
    },
    {
      "id": "tha-ap492:18.1",
      "pali": "Idha naccañca gītañca,"
    },
    {
      "id": "tha-ap492:18.2",
      "pali": "sammatāḷasamāhitaṁ;"
    },
    {
      "id": "tha-ap492:18.3",
      "pali": "Parivāressanti maṁ niccaṁ,"
    },
    {
      "id": "tha-ap492:18.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap492:19.1",
      "pali": "Uggacchante ca sūriye,"
    },
    {
      "id": "tha-ap492:19.2",
      "pali": "sālavassaṁ pavassati;"
    },
    {
      "id": "tha-ap492:19.3",
      "pali": "Puññakammena saṁyuttaṁ,"
    },
    {
      "id": "tha-ap492:19.4",
      "pali": "vassate sabbakālikaṁ."
    },
    {
      "id": "tha-ap492:20.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap492:20.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap492:20.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap492:20.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap492:21.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap492:21.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap492:21.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap492:21.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap492:22.1",
      "pali": "Dhammaṁ abhisamentassa,"
    },
    {
      "id": "tha-ap492:22.2",
      "pali": "sālacchannaṁ bhavissati;"
    },
    {
      "id": "tha-ap492:22.3",
      "pali": "Citake jhāyamānassa,"
    },
    {
      "id": "tha-ap492:22.4",
      "pali": "chadanaṁ tattha hessati’."
    },
    {
      "id": "tha-ap492:23.1",
      "pali": "Vipākaṁ kittayitvāna,"
    },
    {
      "id": "tha-ap492:23.2",
      "pali": "piyadassī mahāmuni;"
    },
    {
      "id": "tha-ap492:23.3",
      "pali": "Parisāya dhammaṁ desesi,"
    },
    {
      "id": "tha-ap492:23.4",
      "pali": "tappento dhammavuṭṭhiyā."
    },
    {
      "id": "tha-ap492:24.1",
      "pali": "Tiṁsakappāni devesu,"
    },
    {
      "id": "tha-ap492:24.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap492:24.3",
      "pali": "Saṭṭhi ca sattakkhattuñca,"
    },
    {
      "id": "tha-ap492:24.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap492:25.1",
      "pali": "Devalokā idhāgantvā,"
    },
    {
      "id": "tha-ap492:25.2",
      "pali": "labhāmi vipulaṁ sukhaṁ;"
    },
    {
      "id": "tha-ap492:25.3",
      "pali": "Idhāpi sālacchadanaṁ,"
    },
    {
      "id": "tha-ap492:25.4",
      "pali": "maṇḍapassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap492:26.1",
      "pali": "Ayaṁ pacchimako mayhaṁ,"
    },
    {
      "id": "tha-ap492:26.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap492:26.3",
      "pali": "Idhāpi sālacchadanaṁ,"
    },
    {
      "id": "tha-ap492:26.4",
      "pali": "hessati sabbakālikaṁ."
    },
    {
      "id": "tha-ap492:27.1",
      "pali": "Mahāmuniṁ tosayitvā,"
    },
    {
      "id": "tha-ap492:27.2",
      "pali": "gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap492:27.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap492:27.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap492:28.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap492:28.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap492:28.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap492:28.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap492:29.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap492:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap492:29.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap492:30.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap492:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap492:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap492:31.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap492:31.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap492:31.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap492:32.1",
      "pali": "Itthaṁ sudaṁ āyasmā sālamaṇḍapiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap492:33.1",
      "pali": "Sālamaṇḍapiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap492:34.1",
      "pali": "Paṁsukūlavaggo ekūnapaññāsamo."
    },
    {
      "id": "tha-ap492:35.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap492:36.1",
      "pali": "Paṁsukūlaṁ buddhasaññī,"
    },
    {
      "id": "tha-ap492:36.2",
      "pali": "bhisado ñāṇakittako;"
    },
    {
      "id": "tha-ap492:36.3",
      "pali": "Candanī dhātupūjī ca,"
    },
    {
      "id": "tha-ap492:36.4",
      "pali": "pulinuppādakopi ca."
    },
    {
      "id": "tha-ap492:37.1",
      "pali": "Taraṇo dhammaruciko,"
    },
    {
      "id": "tha-ap492:37.2",
      "pali": "sālamaṇḍapiyo tathā;"
    },
    {
      "id": "tha-ap492:37.3",
      "pali": "Satāni dve honti gāthā,"
    },
    {
      "id": "tha-ap492:37.4",
      "pali": "ūnavīsatimeva ca."
    }
  ]
}
