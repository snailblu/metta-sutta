{
  "uid": "ja490",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja490:1.1",
      "pali": "“Appossukko dāni tuvaṁ kapota,"
    },
    {
      "id": "ja490:1.2",
      "pali": "Vihaṅgama na tava bhojanattho;"
    },
    {
      "id": "ja490:1.3",
      "pali": "Khudaṁ pipāsaṁ adhivāsayanto,"
    },
    {
      "id": "ja490:1.4",
      "pali": "Kasmā bhavaṁposathiko kapota”."
    },
    {
      "id": "ja490:2.1",
      "pali": "“Ahaṁ pure giddhigato kapotiyā,"
    },
    {
      "id": "ja490:2.2",
      "pali": "Asmiṁ padesasmimubho ramāma;"
    },
    {
      "id": "ja490:2.3",
      "pali": "Athaggahī sākuṇiko kapotiṁ,"
    },
    {
      "id": "ja490:2.4",
      "pali": "Akāmako tāya vinā ahosiṁ."
    },
    {
      "id": "ja490:3.1",
      "pali": "Nānābhavā vippayogena tassā,"
    },
    {
      "id": "ja490:3.2",
      "pali": "Manomayaṁ vedana vedayāmi;"
    },
    {
      "id": "ja490:3.3",
      "pali": "Tasmā ahaṁposathaṁ pālayāmi,"
    },
    {
      "id": "ja490:3.4",
      "pali": "Rāgo mamaṁ mā punarāgamāsi”."
    },
    {
      "id": "ja490:4.1",
      "pali": "“Anujjugāmī uragā dujivha,"
    },
    {
      "id": "ja490:4.2",
      "pali": "Dāṭhāvudho ghoravisosi sappa;"
    },
    {
      "id": "ja490:4.3",
      "pali": "Khudaṁ pipāsaṁ adhivāsayanto,"
    },
    {
      "id": "ja490:4.4",
      "pali": "Kasmā bhavaṁposathiko nu dīgha."
    },
    {
      "id": "ja490:5.1",
      "pali": "Usabho ahū balavā gāmikassa,"
    },
    {
      "id": "ja490:5.2",
      "pali": "Calakkakū vaṇṇabalūpapanno;"
    },
    {
      "id": "ja490:5.3",
      "pali": "So maṁ akkami taṁ kupito aḍaṁsiṁ,"
    },
    {
      "id": "ja490:5.4",
      "pali": "Dukkhābhitunno maraṇaṁ upāgā."
    },
    {
      "id": "ja490:6.1",
      "pali": "Tato janā nikkhamitvāna gāmā,"
    },
    {
      "id": "ja490:6.2",
      "pali": "Kanditvā roditvā apakkamiṁsu;"
    },
    {
      "id": "ja490:6.3",
      "pali": "Tasmā ahaṁposathaṁ pālayāmi,"
    },
    {
      "id": "ja490:6.4",
      "pali": "Kodho mamaṁ mā punarāgamāsi."
    },
    {
      "id": "ja490:7.1",
      "pali": "Matāna maṁsāni bahū susāne,"
    },
    {
      "id": "ja490:7.2",
      "pali": "Manuññarūpaṁ tava bhojane taṁ;"
    },
    {
      "id": "ja490:7.3",
      "pali": "Khudaṁ pipāsaṁ adhivāsayanto,"
    },
    {
      "id": "ja490:7.4",
      "pali": "Kasmā bhavaṁposathiko siṅgāla."
    },
    {
      "id": "ja490:8.1",
      "pali": "Pavisi kucchiṁ mahato gajassa,"
    },
    {
      "id": "ja490:8.2",
      "pali": "Kuṇape rato hatthimaṁsesu giddho;"
    },
    {
      "id": "ja490:8.3",
      "pali": "Uṇho ca vāto tikhiṇā ca rasmiyo,"
    },
    {
      "id": "ja490:8.4",
      "pali": "Te sosayuṁ tassa karīsamaggaṁ."
    },
    {
      "id": "ja490:9.1",
      "pali": "Kiso ca paṇḍū ca ahaṁ bhadante,"
    },
    {
      "id": "ja490:9.2",
      "pali": "Na me ahū nikkhamanāya maggo;"
    },
    {
      "id": "ja490:9.3",
      "pali": "Mahā ca megho sahasā pavassi,"
    },
    {
      "id": "ja490:9.4",
      "pali": "So temayī tassa karīsamaggaṁ."
    },
    {
      "id": "ja490:10.1",
      "pali": "Tato ahaṁ nikkhamisaṁ bhadante,"
    },
    {
      "id": "ja490:10.2",
      "pali": "Cando yathā rāhumukhā pamutto;"
    },
    {
      "id": "ja490:10.3",
      "pali": "Tasmā ahaṁposathaṁ pālayāmi,"
    },
    {
      "id": "ja490:10.4",
      "pali": "Lobho mamaṁ mā punarāgamāsi."
    },
    {
      "id": "ja490:11.1",
      "pali": "Vammīkathūpasmiṁ kipillikāni,"
    },
    {
      "id": "ja490:11.2",
      "pali": "Nippothayanto tuvaṁ pure carāsi;"
    },
    {
      "id": "ja490:11.3",
      "pali": "Khudaṁ pipāsaṁ adhivāsayanto,"
    },
    {
      "id": "ja490:11.4",
      "pali": "Kasmā bhavaṁposathiko nu accha."
    },
    {
      "id": "ja490:12.1",
      "pali": "Sakaṁ niketaṁ atihīḷayāno,"
    },
    {
      "id": "ja490:12.2",
      "pali": "Atricchatā mallagāmaṁ agacchiṁ;"
    },
    {
      "id": "ja490:12.3",
      "pali": "Tato janā nikkhamitvāna gāmā,"
    },
    {
      "id": "ja490:12.4",
      "pali": "Kodaṇḍakena paripothayiṁsu maṁ."
    },
    {
      "id": "ja490:13.1",
      "pali": "So bhinnasīso ruhiramakkhitaṅgo,"
    },
    {
      "id": "ja490:13.2",
      "pali": "Paccāgamāsiṁ sakaṁ niketaṁ;"
    },
    {
      "id": "ja490:13.3",
      "pali": "Tasmā ahaṁposathaṁ pālayāmi,"
    },
    {
      "id": "ja490:13.4",
      "pali": "Atricchatā mā punarāgamāsi”."
    },
    {
      "id": "ja490:14.1",
      "pali": "“Yaṁ no apucchittha tuvaṁ bhadante,"
    },
    {
      "id": "ja490:14.2",
      "pali": "Sabbeva byākarimha yathāpajānaṁ;"
    },
    {
      "id": "ja490:14.3",
      "pali": "Mayampi pucchāma tuvaṁ bhadante,"
    },
    {
      "id": "ja490:14.4",
      "pali": "Kasmā bhavaṁposathiko nu brahme”."
    },
    {
      "id": "ja490:15.1",
      "pali": "“Anūpalitto mama assamamhi,"
    },
    {
      "id": "ja490:15.2",
      "pali": "Paccekabuddho muhuttaṁ nisīdi;"
    },
    {
      "id": "ja490:15.3",
      "pali": "So maṁ avedī gatimāgatiñca,"
    },
    {
      "id": "ja490:15.4",
      "pali": "Nāmañca gottaṁ caraṇañca sabbaṁ."
    },
    {
      "id": "ja490:16.1",
      "pali": "Evampahaṁ vandi na tassa pāde,"
    },
    {
      "id": "ja490:16.2",
      "pali": "Na cāpi naṁ mānagatena pucchiṁ;"
    },
    {
      "id": "ja490:16.3",
      "pali": "Tasmā ahaṁposathaṁ pālayāmi,"
    },
    {
      "id": "ja490:16.4",
      "pali": "Māno mamaṁ mā punarāgamāsī”ti."
    },
    {
      "id": "ja490:17.1",
      "pali": "Pañcuposathikajātakaṁ sattamaṁ."
    }
  ]
}
