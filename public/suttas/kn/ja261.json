{
  "uid": "ja261",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja261:1.1",
      "pali": "“Yathā kesā ca massū ca,"
    },
    {
      "id": "ja261:1.2",
      "pali": "chinnaṁ chinnaṁ virūhati;"
    },
    {
      "id": "ja261:1.3",
      "pali": "Evaṁ rūhatu te nāsā,"
    },
    {
      "id": "ja261:1.4",
      "pali": "padumaṁ dehi yācito”."
    },
    {
      "id": "ja261:2.1",
      "pali": "“Yathā sāradikaṁ bījaṁ,"
    },
    {
      "id": "ja261:2.2",
      "pali": "khette vuttaṁ virūhati;"
    },
    {
      "id": "ja261:2.3",
      "pali": "Evaṁ rūhatu te nāsā,"
    },
    {
      "id": "ja261:2.4",
      "pali": "padumaṁ dehi yācito”."
    },
    {
      "id": "ja261:3.1",
      "pali": "“Ubhopi palapantete,"
    },
    {
      "id": "ja261:3.2",
      "pali": "api padmāni dassati;"
    },
    {
      "id": "ja261:3.3",
      "pali": "Vajjuṁ vā te na vā vajjuṁ,"
    },
    {
      "id": "ja261:3.4",
      "pali": "natthi nāsāya rūhanā;"
    },
    {
      "id": "ja261:3.5",
      "pali": "Dehi samma padumāni,"
    },
    {
      "id": "ja261:3.6",
      "pali": "ahaṁ yācāmi yācito”ti."
    },
    {
      "id": "ja261:4.1",
      "pali": "Padumajātakaṁ paṭhamaṁ."
    }
  ]
}
