{
  "uid": "mil3.4.3",
  "title": "3. Pañcāyatanakammanibbattapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.4.3:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.4.3:1.2",
      "pali": "“bhante nāgasena, yānimāni pañcāyatanāni, kiṁ nu tāni nānākammehi nibbattāni, udāhu ekena kammenā”ti?"
    },
    {
      "id": "mil3.4.3:1.3",
      "pali": "“Nānākammehi, mahārāja, nibbattāni, na ekena kammenā”ti."
    },
    {
      "id": "mil3.4.3:2.1",
      "pali": "“Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.4.3:2.2",
      "pali": "“Taṁ kiṁ maññasi, mahārāja, ekasmiṁ khette nānābījāni vappeyyuṁ, tesaṁ nānābījānaṁ nānāphalāni nibbatteyyun”ti?"
    },
    {
      "id": "mil3.4.3:2.3",
      "pali": "“Āma, bhante, nibbatteyyun”ti."
    },
    {
      "id": "mil3.4.3:2.4",
      "pali": "“Evameva kho, mahārāja, yāni yāni pañcāyatanāni, tāni tāni nānākammehi nibbattāni, na ekena kammenā”ti."
    },
    {
      "id": "mil3.4.3:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.4.3:4.1",
      "pali": "Pañcāyatanakammanibbattapañho tatiyo."
    }
  ]
}
