{
  "uid": "tha-ap199",
  "title": "Tindukadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap199:1.1",
      "pali": "“Giriduggacaro āsiṁ,"
    },
    {
      "id": "tha-ap199:1.2",
      "pali": "makkaṭo thāmavegiko;"
    },
    {
      "id": "tha-ap199:1.3",
      "pali": "Phalinaṁ tindukaṁ disvā,"
    },
    {
      "id": "tha-ap199:1.4",
      "pali": "buddhaseṭṭhaṁ anussariṁ."
    },
    {
      "id": "tha-ap199:2.1",
      "pali": "Nikkhamitvā katipāhaṁ,"
    },
    {
      "id": "tha-ap199:2.2",
      "pali": "viciniṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap199:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap199:2.4",
      "pali": "siddhatthaṁ tibhavantaguṁ."
    },
    {
      "id": "tha-ap199:3.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap199:3.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap199:3.3",
      "pali": "Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap199:3.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap199:4.1",
      "pali": "Pāmojjaṁ janayitvāna,"
    },
    {
      "id": "tha-ap199:4.2",
      "pali": "phalahattho upāgamiṁ;"
    },
    {
      "id": "tha-ap199:4.3",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap199:4.4",
      "pali": "sabbaññū vadataṁ varo."
    },
    {
      "id": "tha-ap199:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap199:5.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap199:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap199:5.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap199:6.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap199:6.2",
      "pali": "upanandasanāmako;"
    },
    {
      "id": "tha-ap199:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap199:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap199:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap199:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap199:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap199:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā tindukadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap199:9.1",
      "pali": "Tindukadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
