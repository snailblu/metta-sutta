{
  "uid": "ja431",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja431:1.1",
      "pali": "“Sutaṁ metaṁ mahābrahme,"
    },
    {
      "id": "ja431:1.2",
      "pali": "kāme bhuñjati hārito;"
    },
    {
      "id": "ja431:1.3",
      "pali": "Kaccetaṁ vacanaṁ tucchaṁ,"
    },
    {
      "id": "ja431:1.4",
      "pali": "kacci suddho iriyyasi”."
    },
    {
      "id": "ja431:2.1",
      "pali": "“Evametaṁ mahārāja,"
    },
    {
      "id": "ja431:2.2",
      "pali": "yathā te vacanaṁ sutaṁ;"
    },
    {
      "id": "ja431:2.3",
      "pali": "Kummaggaṁ paṭipannosmi,"
    },
    {
      "id": "ja431:2.4",
      "pali": "mohaneyyesu mucchito”."
    },
    {
      "id": "ja431:3.1",
      "pali": "“Adu paññā kimatthiyā,"
    },
    {
      "id": "ja431:3.2",
      "pali": "nipuṇā sādhucintinī;"
    },
    {
      "id": "ja431:3.3",
      "pali": "Yāya uppatitaṁ rāgaṁ,"
    },
    {
      "id": "ja431:3.4",
      "pali": "kiṁ mano na vinodaye”."
    },
    {
      "id": "ja431:4.1",
      "pali": "“Cattārome mahārāja,"
    },
    {
      "id": "ja431:4.2",
      "pali": "loke atibalā bhusā;"
    },
    {
      "id": "ja431:4.3",
      "pali": "Rāgo doso mado moho,"
    },
    {
      "id": "ja431:4.4",
      "pali": "yattha paññā na gādhati”."
    },
    {
      "id": "ja431:5.1",
      "pali": "“Arahā sīlasampanno,"
    },
    {
      "id": "ja431:5.2",
      "pali": "suddho carati hārito;"
    },
    {
      "id": "ja431:5.3",
      "pali": "Medhāvī paṇḍito ceva,"
    },
    {
      "id": "ja431:5.4",
      "pali": "iti no sammato bhavaṁ”."
    },
    {
      "id": "ja431:6.1",
      "pali": "“Medhāvīnampi hiṁsanti,"
    },
    {
      "id": "ja431:6.2",
      "pali": "isiṁ dhammaguṇe rataṁ;"
    },
    {
      "id": "ja431:6.3",
      "pali": "Vitakkā pāpakā rāja,"
    },
    {
      "id": "ja431:6.4",
      "pali": "subhā rāgūpasaṁhitā”."
    },
    {
      "id": "ja431:7.1",
      "pali": "“Uppannāyaṁ sarīrajo,"
    },
    {
      "id": "ja431:7.2",
      "pali": "Rāgo vaṇṇavidūsano tava;"
    },
    {
      "id": "ja431:7.3",
      "pali": "Taṁ pajaha bhaddamatthu te,"
    },
    {
      "id": "ja431:7.4",
      "pali": "Bahunnāsi medhāvisammato”."
    },
    {
      "id": "ja431:8.1",
      "pali": "“Te andhakārake kāme,"
    },
    {
      "id": "ja431:8.2",
      "pali": "Bahudukkhe mahāvise;"
    },
    {
      "id": "ja431:8.3",
      "pali": "Tesaṁ mūlaṁ gavesissaṁ,"
    },
    {
      "id": "ja431:8.4",
      "pali": "Checchaṁ rāgaṁ sabandhanaṁ”."
    },
    {
      "id": "ja431:9.1",
      "pali": "“Idaṁ vatvāna hārito,"
    },
    {
      "id": "ja431:9.2",
      "pali": "isi saccaparakkamo;"
    },
    {
      "id": "ja431:9.3",
      "pali": "Kāmarāgaṁ virājetvā,"
    },
    {
      "id": "ja431:9.4",
      "pali": "brahmalokūpago ahū”ti."
    },
    {
      "id": "ja431:10.1",
      "pali": "Haritacajātakaṁ pañcamaṁ."
    }
  ]
}
