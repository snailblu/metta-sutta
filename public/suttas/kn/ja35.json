{
  "uid": "ja35",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja35:1.1",
      "pali": "“Santi pakkhā apatanā,"
    },
    {
      "id": "ja35:1.2",
      "pali": "santi pādā avañcanā;"
    },
    {
      "id": "ja35:1.3",
      "pali": "Mātāpitā ca nikkhantā,"
    },
    {
      "id": "ja35:1.4",
      "pali": "jātaveda paṭikkamā”ti."
    },
    {
      "id": "ja35:2.1",
      "pali": "Vaṭṭakajātakaṁ pañcamaṁ."
    }
  ]
}
