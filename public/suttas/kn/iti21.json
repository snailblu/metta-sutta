{
  "uid": "iti21",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti21:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti21:2.1",
      "pali": "“Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ pasannacittaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "iti21:2.2",
      "pali": "‘imamhi cāyaṁ samaye puggalo kālaṁ kareyya yathābhataṁ nikkhitto evaṁ sagge’."
    },
    {
      "id": "iti21:2.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "iti21:2.4",
      "pali": "Cittaṁ hissa, bhikkhave, pasannaṁ."
    },
    {
      "id": "iti21:2.5",
      "pali": "Cetopasādahetu kho pana, bhikkhave, evam’idhekacce sattā kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjantī”ti."
    },
    {
      "id": "iti21:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti21:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti21:3.1",
      "pali": "“Pasannacittaṁ ñatvāna,"
    },
    {
      "id": "iti21:3.2",
      "pali": "ekaccaṁ idha puggalaṁ;"
    },
    {
      "id": "iti21:3.3",
      "pali": "Etamatthañca byākāsi,"
    },
    {
      "id": "iti21:3.4",
      "pali": "buddho bhikkhūna santike."
    },
    {
      "id": "iti21:4.1",
      "pali": "Imamhi cāyaṁ samaye,"
    },
    {
      "id": "iti21:4.2",
      "pali": "kālaṁ kayirātha puggalo;"
    },
    {
      "id": "iti21:4.3",
      "pali": "Sugatiṁ upapajjeyya,"
    },
    {
      "id": "iti21:4.4",
      "pali": "cittaṁ hissa pasāditaṁ."
    },
    {
      "id": "iti21:5.1",
      "pali": "Yathā haritvā nikkhipeyya,"
    },
    {
      "id": "iti21:5.2",
      "pali": "evamevaṁ tathāvidho;"
    },
    {
      "id": "iti21:5.3",
      "pali": "Cetopasādahetu hi,"
    },
    {
      "id": "iti21:5.4",
      "pali": "sattā gacchanti suggatin”ti."
    },
    {
      "id": "iti21:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti21:6.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
