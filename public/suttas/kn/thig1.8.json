{
  "uid": "thig1.8",
  "title": "Mittātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.8:1.1",
      "pali": "“Saddhāya pabbajitvāna,"
    },
    {
      "id": "thig1.8:1.2",
      "pali": "mitte mittaratā bhava;"
    },
    {
      "id": "thig1.8:1.3",
      "pali": "Bhāvehi kusale dhamme,"
    },
    {
      "id": "thig1.8:1.4",
      "pali": "yogakkhemassa pattiyā”ti."
    },
    {
      "id": "thig1.8:2.1",
      "pali": "… Mittā therī …."
    }
  ]
}
