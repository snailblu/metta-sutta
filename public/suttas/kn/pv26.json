{
  "uid": "pv26",
  "title": "1. Abhijjamānapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv26:1.1",
      "pali": "“Abhijjamāne vārimhi,"
    },
    {
      "id": "pv26:1.2",
      "pali": "gaṅgāya idha gacchasi;"
    },
    {
      "id": "pv26:1.3",
      "pali": "Naggo pubbaddhapetova,"
    },
    {
      "id": "pv26:1.4",
      "pali": "māladhārī alaṅkato;"
    },
    {
      "id": "pv26:1.5",
      "pali": "Kuhiṁ gamissasi peta,"
    },
    {
      "id": "pv26:1.6",
      "pali": "kattha vāso bhavissatī”ti."
    },
    {
      "id": "pv26:2.1",
      "pali": "“Cundaṭṭhilaṁ gamissāmi,"
    },
    {
      "id": "pv26:2.2",
      "pali": "peto so iti bhāsati;"
    },
    {
      "id": "pv26:2.3",
      "pali": "Antare vāsabhagāmaṁ,"
    },
    {
      "id": "pv26:2.4",
      "pali": "bārāṇasiṁ ca santike”."
    },
    {
      "id": "pv26:3.1",
      "pali": "Tañca disvā mahāmatto,"
    },
    {
      "id": "pv26:3.2",
      "pali": "koliyo iti vissuto;"
    },
    {
      "id": "pv26:3.3",
      "pali": "Sattuṁ bhattañca petassa,"
    },
    {
      "id": "pv26:3.4",
      "pali": "pītakañca yugaṁ adā."
    },
    {
      "id": "pv26:4.1",
      "pali": "Nāvāya tiṭṭhamānāya,"
    },
    {
      "id": "pv26:4.2",
      "pali": "kappakassa adāpayi;"
    },
    {
      "id": "pv26:4.3",
      "pali": "Kappakassa padinnamhi,"
    },
    {
      "id": "pv26:4.4",
      "pali": "ṭhāne petassa dissatha."
    },
    {
      "id": "pv26:5.1",
      "pali": "Tato suvatthavasano,"
    },
    {
      "id": "pv26:5.2",
      "pali": "māladhārī alaṅkato;"
    },
    {
      "id": "pv26:5.3",
      "pali": "Ṭhāne ṭhitassa petassa,"
    },
    {
      "id": "pv26:5.4",
      "pali": "dakkhiṇā upakappatha;"
    },
    {
      "id": "pv26:5.5",
      "pali": "Tasmā dajjetha petānaṁ,"
    },
    {
      "id": "pv26:5.6",
      "pali": "anukampāya punappunaṁ."
    },
    {
      "id": "pv26:6.1",
      "pali": "Sātunnavasanā eke,"
    },
    {
      "id": "pv26:6.2",
      "pali": "aññe kesanivāsanā;"
    },
    {
      "id": "pv26:6.3",
      "pali": "Petā bhattāya gacchanti,"
    },
    {
      "id": "pv26:6.4",
      "pali": "pakkamanti disodisaṁ."
    },
    {
      "id": "pv26:7.1",
      "pali": "Dūre eke padhāvitvā,"
    },
    {
      "id": "pv26:7.2",
      "pali": "aladdhāva nivattare;"
    },
    {
      "id": "pv26:7.3",
      "pali": "Chātā pamucchitā bhantā,"
    },
    {
      "id": "pv26:7.4",
      "pali": "bhūmiyaṁ paṭisumbhitā."
    },
    {
      "id": "pv26:8.1",
      "pali": "Te ca tattha papatitā,"
    },
    {
      "id": "pv26:8.2",
      "pali": "bhūmiyaṁ paṭisumbhitā;"
    },
    {
      "id": "pv26:8.3",
      "pali": "Pubbe akatakalyāṇā,"
    },
    {
      "id": "pv26:8.4",
      "pali": "aggidaḍḍhāva ātape."
    },
    {
      "id": "pv26:9.1",
      "pali": "“Mayaṁ pubbe pāpadhammā,"
    },
    {
      "id": "pv26:9.2",
      "pali": "gharaṇī kulamātaro;"
    },
    {
      "id": "pv26:9.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv26:9.4",
      "pali": "dīpaṁ nākamha attano."
    },
    {
      "id": "pv26:10.1",
      "pali": "Pahūtaṁ annapānampi,"
    },
    {
      "id": "pv26:10.2",
      "pali": "apissu avakirīyati;"
    },
    {
      "id": "pv26:10.3",
      "pali": "Sammaggate pabbajite,"
    },
    {
      "id": "pv26:10.4",
      "pali": "na ca kiñci adamhase."
    },
    {
      "id": "pv26:11.1",
      "pali": "Akammakāmā alasā,"
    },
    {
      "id": "pv26:11.2",
      "pali": "Sādukāmā mahagghasā;"
    },
    {
      "id": "pv26:11.3",
      "pali": "Ālopapiṇḍadātāro,"
    },
    {
      "id": "pv26:11.4",
      "pali": "Paṭiggahe paribhāsimhase."
    },
    {
      "id": "pv26:12.1",
      "pali": "Te gharā tā ca dāsiyo,"
    },
    {
      "id": "pv26:12.2",
      "pali": "tānevābharaṇāni no;"
    },
    {
      "id": "pv26:12.3",
      "pali": "Te aññe paricārenti,"
    },
    {
      "id": "pv26:12.4",
      "pali": "mayaṁ dukkhassa bhāgino."
    },
    {
      "id": "pv26:13.1",
      "pali": "Veṇī vā avaññā honti,"
    },
    {
      "id": "pv26:13.2",
      "pali": "rathakārī ca dubbhikā;"
    },
    {
      "id": "pv26:13.3",
      "pali": "Caṇḍālī kapaṇā honti,"
    },
    {
      "id": "pv26:13.4",
      "pali": "kappakā ca punappunaṁ."
    },
    {
      "id": "pv26:14.1",
      "pali": "Yāni yāni nihīnāni,"
    },
    {
      "id": "pv26:14.2",
      "pali": "kulāni kapaṇāni ca;"
    },
    {
      "id": "pv26:14.3",
      "pali": "Tesu tesveva jāyanti,"
    },
    {
      "id": "pv26:14.4",
      "pali": "esā maccharino gati."
    },
    {
      "id": "pv26:15.1",
      "pali": "Pubbe ca katakalyāṇā,"
    },
    {
      "id": "pv26:15.2",
      "pali": "dāyakā vītamaccharā;"
    },
    {
      "id": "pv26:15.3",
      "pali": "Saggaṁ te paripūrenti,"
    },
    {
      "id": "pv26:15.4",
      "pali": "obhāsenti ca nandanaṁ."
    },
    {
      "id": "pv26:16.1",
      "pali": "Vejayante ca pāsāde,"
    },
    {
      "id": "pv26:16.2",
      "pali": "ramitvā kāmakāmino;"
    },
    {
      "id": "pv26:16.3",
      "pali": "Uccākulesu jāyanti,"
    },
    {
      "id": "pv26:16.4",
      "pali": "sabhogesu tato cutā."
    },
    {
      "id": "pv26:17.1",
      "pali": "Kūṭāgāre ca pāsāde,"
    },
    {
      "id": "pv26:17.2",
      "pali": "pallaṅke gonakatthate;"
    },
    {
      "id": "pv26:17.3",
      "pali": "Bījitaṅgā morahatthehi,"
    },
    {
      "id": "pv26:17.4",
      "pali": "kule jātā yasassino."
    },
    {
      "id": "pv26:18.1",
      "pali": "Aṅkato aṅkaṁ gacchanti,"
    },
    {
      "id": "pv26:18.2",
      "pali": "māladhārī alaṅkatā;"
    },
    {
      "id": "pv26:18.3",
      "pali": "Dhātiyo upatiṭṭhanti,"
    },
    {
      "id": "pv26:18.4",
      "pali": "sāyaṁ pātaṁ sukhesino."
    },
    {
      "id": "pv26:19.1",
      "pali": "Nayidaṁ akatapuññānaṁ,"
    },
    {
      "id": "pv26:19.2",
      "pali": "katapuññānamevidaṁ;"
    },
    {
      "id": "pv26:19.3",
      "pali": "Asokaṁ nandanaṁ rammaṁ,"
    },
    {
      "id": "pv26:19.4",
      "pali": "tidasānaṁ mahāvanaṁ."
    },
    {
      "id": "pv26:20.1",
      "pali": "Sukhaṁ akatapuññānaṁ,"
    },
    {
      "id": "pv26:20.2",
      "pali": "idha natthi parattha ca;"
    },
    {
      "id": "pv26:20.3",
      "pali": "Sukhañca katapuññānaṁ,"
    },
    {
      "id": "pv26:20.4",
      "pali": "idha ceva parattha ca."
    },
    {
      "id": "pv26:21.1",
      "pali": "Tesaṁ sahabyakāmānaṁ,"
    },
    {
      "id": "pv26:21.2",
      "pali": "kattabbaṁ kusalaṁ bahuṁ;"
    },
    {
      "id": "pv26:21.3",
      "pali": "Katapuññā hi modanti,"
    },
    {
      "id": "pv26:21.4",
      "pali": "sagge bhogasamaṅgino”ti."
    },
    {
      "id": "pv26:22.1",
      "pali": "Abhijjamānapetavatthu paṭhamaṁ."
    }
  ]
}
