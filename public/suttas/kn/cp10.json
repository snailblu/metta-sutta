{
  "uid": "cp10",
  "title": "Dānapāramī 10",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp10:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp10:1.2",
      "pali": "Sasako pavanacārako;"
    },
    {
      "id": "cp10:1.3",
      "pali": "Tiṇapaṇṇasākaphalabhakkho,"
    },
    {
      "id": "cp10:1.4",
      "pali": "Paraheṭhanavivajjito."
    },
    {
      "id": "cp10:2.1",
      "pali": "Makkaṭo ca siṅgālo ca,"
    },
    {
      "id": "cp10:2.2",
      "pali": "suttapoto cahaṁ tadā;"
    },
    {
      "id": "cp10:2.3",
      "pali": "Vasāma ekasāmantā,"
    },
    {
      "id": "cp10:2.4",
      "pali": "sāyaṁ pāto ca dissare."
    },
    {
      "id": "cp10:3.1",
      "pali": "Ahaṁ te anusāsāmi,"
    },
    {
      "id": "cp10:3.2",
      "pali": "kiriye kalyāṇapāpake;"
    },
    {
      "id": "cp10:3.3",
      "pali": "‘Pāpāni parivajjetha,"
    },
    {
      "id": "cp10:3.4",
      "pali": "kalyāṇe abhinivissatha’."
    },
    {
      "id": "cp10:4.1",
      "pali": "Uposathamhi divase,"
    },
    {
      "id": "cp10:4.2",
      "pali": "candaṁ disvāna pūritaṁ;"
    },
    {
      "id": "cp10:4.3",
      "pali": "Etesaṁ tattha ācikkhiṁ,"
    },
    {
      "id": "cp10:4.4",
      "pali": "‘divaso ajjuposatho."
    },
    {
      "id": "cp10:5.1",
      "pali": "Dānāni paṭiyādetha,"
    },
    {
      "id": "cp10:5.2",
      "pali": "dakkhiṇeyyassa dātave;"
    },
    {
      "id": "cp10:5.3",
      "pali": "Datvā dānaṁ dakkhiṇeyye,"
    },
    {
      "id": "cp10:5.4",
      "pali": "upavassathuposathaṁ’."
    },
    {
      "id": "cp10:6.1",
      "pali": "Te me sādhūti vatvāna,"
    },
    {
      "id": "cp10:6.2",
      "pali": "yathāsatti yathābalaṁ;"
    },
    {
      "id": "cp10:6.3",
      "pali": "Dānāni paṭiyādetvā,"
    },
    {
      "id": "cp10:6.4",
      "pali": "dakkhiṇeyyaṁ gavesisuṁ."
    },
    {
      "id": "cp10:7.1",
      "pali": "Ahaṁ nisajja cintesiṁ,"
    },
    {
      "id": "cp10:7.2",
      "pali": "dānaṁ dakkhiṇanucchavaṁ;"
    },
    {
      "id": "cp10:7.3",
      "pali": "‘Yadihaṁ labhe dakkhiṇeyyaṁ,"
    },
    {
      "id": "cp10:7.4",
      "pali": "kiṁ me dānaṁ bhavissati."
    },
    {
      "id": "cp10:8.1",
      "pali": "Na me atthi tilā muggā,"
    },
    {
      "id": "cp10:8.2",
      "pali": "māsā vā taṇḍulā ghataṁ;"
    },
    {
      "id": "cp10:8.3",
      "pali": "Ahaṁ tiṇena yāpemi,"
    },
    {
      "id": "cp10:8.4",
      "pali": "na sakkā tiṇa dātave."
    },
    {
      "id": "cp10:9.1",
      "pali": "Yadi koci eti dakkhiṇeyyo,"
    },
    {
      "id": "cp10:9.2",
      "pali": "Bhikkhāya mama santike;"
    },
    {
      "id": "cp10:9.3",
      "pali": "Dajjāhaṁ sakamattānaṁ,"
    },
    {
      "id": "cp10:9.4",
      "pali": "Na so tuccho gamissati’."
    },
    {
      "id": "cp10:10.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "cp10:10.2",
      "pali": "sakko brāhmaṇavaṇṇinā;"
    },
    {
      "id": "cp10:10.3",
      "pali": "Āsayaṁ me upāgacchi,"
    },
    {
      "id": "cp10:10.4",
      "pali": "dānavīmaṁsanāya me."
    },
    {
      "id": "cp10:11.1",
      "pali": "Tamahaṁ disvāna santuṭṭho,"
    },
    {
      "id": "cp10:11.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "cp10:11.3",
      "pali": "‘Sādhu khosi anuppatto,"
    },
    {
      "id": "cp10:11.4",
      "pali": "ghāsahetu mamantike."
    },
    {
      "id": "cp10:12.1",
      "pali": "Adinnapubbaṁ dānavaraṁ,"
    },
    {
      "id": "cp10:12.2",
      "pali": "ajja dassāmi te ahaṁ;"
    },
    {
      "id": "cp10:12.3",
      "pali": "Tuvaṁ sīlaguṇūpeto,"
    },
    {
      "id": "cp10:12.4",
      "pali": "ayuttaṁ te paraheṭhanaṁ."
    },
    {
      "id": "cp10:13.1",
      "pali": "Ehi aggiṁ padīpehi,"
    },
    {
      "id": "cp10:13.2",
      "pali": "nānākaṭṭhe samānaya;"
    },
    {
      "id": "cp10:13.3",
      "pali": "Ahaṁ pacissamattānaṁ,"
    },
    {
      "id": "cp10:13.4",
      "pali": "pakkaṁ tvaṁ bhakkhayissasi’."
    },
    {
      "id": "cp10:14.1",
      "pali": "‘Sādhū’ti so haṭṭhamano,"
    },
    {
      "id": "cp10:14.2",
      "pali": "nānākaṭṭhe samānayi;"
    },
    {
      "id": "cp10:14.3",
      "pali": "Mahantaṁ akāsi citakaṁ,"
    },
    {
      "id": "cp10:14.4",
      "pali": "katvā aṅgāragabbhakaṁ."
    },
    {
      "id": "cp10:15.1",
      "pali": "Aggiṁ tattha padīpesi,"
    },
    {
      "id": "cp10:15.2",
      "pali": "yathā so khippaṁ mahā bhave;"
    },
    {
      "id": "cp10:15.3",
      "pali": "Phoṭetvā rajagate gatte,"
    },
    {
      "id": "cp10:15.4",
      "pali": "ekamantaṁ upāvisiṁ."
    },
    {
      "id": "cp10:16.1",
      "pali": "Yadā mahākaṭṭhapuñjo,"
    },
    {
      "id": "cp10:16.2",
      "pali": "āditto dhamadhamāyati;"
    },
    {
      "id": "cp10:16.3",
      "pali": "Taduppatitvā papatiṁ,"
    },
    {
      "id": "cp10:16.4",
      "pali": "majjhe jālasikhantare."
    },
    {
      "id": "cp10:17.1",
      "pali": "Yathā sītodakaṁ nāma,"
    },
    {
      "id": "cp10:17.2",
      "pali": "Paviṭṭhaṁ yassa kassaci;"
    },
    {
      "id": "cp10:17.3",
      "pali": "Sameti darathapariḷāhaṁ,"
    },
    {
      "id": "cp10:17.4",
      "pali": "Assādaṁ deti pīti ca."
    },
    {
      "id": "cp10:18.1",
      "pali": "Tatheva jalitaṁ aggiṁ,"
    },
    {
      "id": "cp10:18.2",
      "pali": "paviṭṭhassa mamaṁ tadā;"
    },
    {
      "id": "cp10:18.3",
      "pali": "Sabbaṁ sameti darathaṁ,"
    },
    {
      "id": "cp10:18.4",
      "pali": "yathā sītodakaṁ viya."
    },
    {
      "id": "cp10:19.1",
      "pali": "Chaviṁ cammaṁ maṁsaṁ nhāruṁ,"
    },
    {
      "id": "cp10:19.2",
      "pali": "Aṭṭhiṁ hadayabandhanaṁ;"
    },
    {
      "id": "cp10:19.3",
      "pali": "Kevalaṁ sakalaṁ kāyaṁ,"
    },
    {
      "id": "cp10:19.4",
      "pali": "Brāhmaṇassa adāsahan”ti."
    },
    {
      "id": "cp10:20.1",
      "pali": "Sasapaṇḍitacariyaṁ dasamaṁ."
    },
    {
      "id": "cp10:21.1",
      "pali": "Akittivaggo paṭhamo."
    },
    {
      "id": "cp10:22.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "cp10:23.1",
      "pali": "Akittibrāhmaṇo saṅkho,"
    },
    {
      "id": "cp10:23.2",
      "pali": "kururājā dhanañcayo;"
    },
    {
      "id": "cp10:23.3",
      "pali": "Mahāsudassano rājā,"
    },
    {
      "id": "cp10:23.4",
      "pali": "mahāgovindabrāhmaṇo."
    },
    {
      "id": "cp10:24.1",
      "pali": "Nimi candakumāro ca,"
    },
    {
      "id": "cp10:24.2",
      "pali": "sivi vessantaro saso;"
    },
    {
      "id": "cp10:24.3",
      "pali": "Ahameva tadā āsiṁ,"
    },
    {
      "id": "cp10:24.4",
      "pali": "yo te dānavare adā."
    },
    {
      "id": "cp10:25.1",
      "pali": "Ete dānaparikkhārā,"
    },
    {
      "id": "cp10:25.2",
      "pali": "ete dānassa pāramī;"
    },
    {
      "id": "cp10:25.3",
      "pali": "Jīvitaṁ yācake datvā,"
    },
    {
      "id": "cp10:25.4",
      "pali": "imaṁ pārami pūrayiṁ."
    },
    {
      "id": "cp10:26.1",
      "pali": "Bhikkhāya upagataṁ disvā,"
    },
    {
      "id": "cp10:26.2",
      "pali": "sakattānaṁ pariccajiṁ;"
    },
    {
      "id": "cp10:26.3",
      "pali": "Dānena me samo natthi,"
    },
    {
      "id": "cp10:26.4",
      "pali": "esā me dānapāramīti."
    },
    {
      "id": "cp10:27.1",
      "pali": "Dānapāraminiddeso niṭṭhito."
    }
  ]
}
