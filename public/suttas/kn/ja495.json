    },
    {
      "id": "ja495:44.3",
      "pali": "Na te vuccanti brāhmaṇā;"
    },
    {
      "id": "ja495:44.4",
      "pali": "Aññe vidhura pariyesa,"
    },
    {
      "id": "ja495:44.5",
      "pali": "Sīlavante bahussute."
    },
    {
      "id": "ja495:45.1",
      "pali": "Virate methunā dhammā,"
    },
    {
      "id": "ja495:45.2",
      "pali": "ye me bhuñjeyyu bhojanaṁ;"
    },
    {
      "id": "ja495:45.3",
      "pali": "Dakkhiṇaṁ samma dassāma,"
    },
    {
      "id": "ja495:45.4",
      "pali": "yattha dinnaṁ mahapphalaṁ”."
    },
    {
      "id": "ja495:46.1",
      "pali": "“Atthi kho brāhmaṇā deva,"
    },
    {
      "id": "ja495:46.2",
      "pali": "sīlavanto bahussutā;"
    },
    {
      "id": "ja495:46.3",
      "pali": "Viratā methunā dhammā,"
    },
    {
      "id": "ja495:46.4",
      "pali": "ye te bhuñjeyyu bhojanaṁ."
    },
    {
      "id": "ja495:47.1",
      "pali": "Ekañca bhattaṁ bhuñjanti,"
    },
    {
      "id": "ja495:47.2",
      "pali": "na ca majjaṁ pivanti te;"
    },
    {
      "id": "ja495:47.3",
      "pali": "Akkhātā te mahārāja,"
    },
    {
      "id": "ja495:47.4",
      "pali": "tādise nipatāmase”."
    },
    {
      "id": "ja495:48.1",
      "pali": "“Ete kho brāhmaṇā vidhura,"
    },
    {
      "id": "ja495:48.2",
      "pali": "Sīlavanto bahussutā;"
    },
    {
      "id": "ja495:48.3",
      "pali": "Ete vidhura pariyesa,"
    },
    {
      "id": "ja495:48.4",
      "pali": "Khippañca ne nimantayā”ti."
    },
    {
      "id": "ja495:49.1",
      "pali": "Dasabrāhmaṇajātakaṁ dvādasamaṁ."
    }
  ]
}
