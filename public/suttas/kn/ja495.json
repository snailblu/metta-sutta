    },
    {
      "id": "ja495:41.2",
      "pali": "ye me bhuñjeyyu bhojanaṁ;"
    },
    {
      "id": "ja495:41.3",
      "pali": "Dakkhiṇaṁ samma dassāma,"
    },
    {
      "id": "ja495:41.4",
      "pali": "yattha dinnaṁ mahapphalaṁ”."
    },
    {
      "id": "ja495:42.1",
      "pali": "“Aññe dhanassa kāmā hi,"
    },
    {
      "id": "ja495:42.2",
      "pali": "heṭṭhāmañce pasakkitā;"
    },
    {
      "id": "ja495:42.3",
      "pali": "Rājāno upari nhāyanti,"
    },
    {
      "id": "ja495:42.4",
      "pali": "somayāge upaṭṭhite."
    },
    {
      "id": "ja495:43.1",
      "pali": "Malamajjakasamā rāja,"
    },
    {
      "id": "ja495:43.2",
      "pali": "Tepi vuccanti brāhmaṇā;"
    },
    {
      "id": "ja495:43.3",
      "pali": "Akkhātā te mahārāja,"
    },
    {
      "id": "ja495:43.4",
      "pali": "Tādise nipatāmase”."
    },
    {
      "id": "ja495:44.1",
      "pali": "“Apetā te ca brahmaññā,"
    },
    {
      "id": "ja495:44.2",
