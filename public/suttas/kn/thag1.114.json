{
  "uid": "thag1.114",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.114:1.1",
      "pali": "“Kāyaduṭṭhullagaruno,"
    },
    {
      "id": "thag1.114:1.2",
      "pali": "hiyyamānamhi jīvite;"
    },
    {
      "id": "thag1.114:1.3",
      "pali": "Sarīrasukhagiddhassa,"
    },
    {
      "id": "thag1.114:1.4",
      "pali": "kuto samaṇasādhutā”ti."
    },
    {
      "id": "thag1.114:1.5",
      "pali": "… Adhimutto thero …."
    }
  ]
}
