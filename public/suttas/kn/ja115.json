{
  "uid": "ja115",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja115:1.1",
      "pali": "“Yāyañña manusāsati,"
    },
    {
      "id": "ja115:1.2",
      "pali": "sayaṁ loluppacārinī;"
    },
    {
      "id": "ja115:1.3",
      "pali": "Sāyaṁ vipakkhikā seti,"
    },
    {
      "id": "ja115:1.4",
      "pali": "hatā cakkena sāsikāti."
    },
    {
      "id": "ja115:2.1",
      "pali": "Anusāsikajātakaṁ pañcamaṁ."
    }
  ]
}
