{
  "uid": "tha-ap310",
  "title": "Anulepadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap310:1.1",
      "pali": "“Atthadassissa munino,"
    },
    {
      "id": "tha-ap310:1.2",
      "pali": "addasaṁ sāvakaṁ ahaṁ;"
    },
    {
      "id": "tha-ap310:1.3",
      "pali": "Navakammaṁ karontassa,"
    },
    {
      "id": "tha-ap310:1.4",
      "pali": "sīmāya upagacchahaṁ."
    },
    {
      "id": "tha-ap310:2.1",
      "pali": "Niṭṭhite navakamme ca,"
    },
    {
      "id": "tha-ap310:2.2",
      "pali": "anulepamadāsahaṁ;"
    },
    {
      "id": "tha-ap310:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap310:2.4",
      "pali": "puññakkhette anuttare."
    },
    {
      "id": "tha-ap310:3.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap310:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap310:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap310:3.4",
      "pali": "anulepassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap310:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap310:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap310:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap310:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā anulepadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap310:6.1",
      "pali": "Anulepadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
