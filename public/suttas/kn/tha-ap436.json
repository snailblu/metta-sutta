{
  "uid": "tha-ap436",
  "title": "Ñāṇatthavikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap436:1.1",
      "pali": "“Kaṇikāraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap436:1.2",
      "pali": "dīparukkhaṁva jotitaṁ;"
    },
    {
      "id": "tha-ap436:1.3",
      "pali": "Kañcanaṁva virocantaṁ,"
    },
    {
      "id": "tha-ap436:1.4",
      "pali": "addasaṁ dvipaduttamaṁ."
    },
    {
      "id": "tha-ap436:2.1",
      "pali": "Kamaṇḍaluṁ ṭhapetvāna,"
    },
    {
      "id": "tha-ap436:2.2",
      "pali": "vākacīrañca kuṇḍikaṁ;"
    },
    {
      "id": "tha-ap436:2.3",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "tha-ap436:2.4",
      "pali": "buddhaseṭṭhaṁ thaviṁ ahaṁ."
    },
    {
      "id": "tha-ap436:3.1",
      "pali": "‘Tamandhakāraṁ vidhamaṁ,"
    },
    {
      "id": "tha-ap436:3.2",
      "pali": "mohajālasamākulaṁ;"
    },
    {
      "id": "tha-ap436:3.3",
      "pali": "Ñāṇālokaṁ dassetvāna,"
    },
    {
      "id": "tha-ap436:3.4",
      "pali": "nittiṇṇosi mahāmuni."
    },
    {
      "id": "tha-ap436:4.1",
      "pali": "Samuddharasimaṁ lokaṁ,"
    },
    {
      "id": "tha-ap436:4.2",
      "pali": "sabbāvantamanuttaraṁ;"
    },
    {
      "id": "tha-ap436:4.3",
      "pali": "Ñāṇe te upamā natthi,"
    },
    {
      "id": "tha-ap436:4.4",
      "pali": "yāvatājagatogati."
    },
    {
      "id": "tha-ap436:5.1",
      "pali": "Tena ñāṇena sabbaññū,"
    },
    {
      "id": "tha-ap436:5.2",
      "pali": "iti buddho pavuccati;"
    },
    {
      "id": "tha-ap436:5.3",
      "pali": "Vandāmi taṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap436:5.4",
      "pali": "sabbaññutamanāvaraṁ’."
    },
    {
      "id": "tha-ap436:6.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap436:6.2",
      "pali": "buddhaseṭṭhaṁ thaviṁ ahaṁ;"
    },
    {
      "id": "tha-ap436:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap436:6.4",
      "pali": "ñāṇatthavāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap436:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap436:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap436:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap436:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap436:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap436:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap436:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap436:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap436:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap436:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā ñāṇatthaviko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap436:11.1",
      "pali": "Ñāṇatthavikattherassāpadānaṁ catutthaṁ."
    }
  ]
}
