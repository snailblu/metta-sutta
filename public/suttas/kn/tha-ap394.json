{
  "uid": "tha-ap394",
  "title": "Selattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap394:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap394:1.2",
      "pali": "vīthisāmī ahosahaṁ;"
    },
    {
      "id": "tha-ap394:1.3",
      "pali": "Mama ñātī samānetvā,"
    },
    {
      "id": "tha-ap394:1.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap394:2.1",
      "pali": "‘Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap394:2.2",
      "pali": "puññakkhetto anuttaro;"
    },
    {
      "id": "tha-ap394:2.3",
      "pali": "Āsi so sabbalokassa,"
    },
    {
      "id": "tha-ap394:2.4",
      "pali": "āhutīnaṁ paṭiggaho."
    },
    {
      "id": "tha-ap394:3.1",
      "pali": "Khattiyā negamā ceva,"
    },
    {
      "id": "tha-ap394:3.2",
      "pali": "mahāsālā ca brāhmaṇā;"
    },
    {
      "id": "tha-ap394:3.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:3.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:4.1",
      "pali": "Hatthārohā anīkaṭṭhā,"
    },
    {
      "id": "tha-ap394:4.2",
      "pali": "rathikā pattikārakā;"
    },
    {
      "id": "tha-ap394:4.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:4.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:5.1",
      "pali": "Uggā ca rājaputtā ca,"
    },
    {
      "id": "tha-ap394:5.2",
      "pali": "vesiyānā ca brāhmaṇā;"
    },
    {
      "id": "tha-ap394:5.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:5.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:6.1",
      "pali": "Āḷārikā kappakā ca,"
    },
    {
      "id": "tha-ap394:6.2",
      "pali": "nhāpakā mālakārakā;"
    },
    {
      "id": "tha-ap394:6.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:6.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:7.1",
      "pali": "Rajakā pesakārā ca,"
    },
    {
      "id": "tha-ap394:7.2",
      "pali": "cammakārā ca nhāpitā;"
    },
    {
      "id": "tha-ap394:7.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:7.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:8.1",
      "pali": "Usukārā bhamakārā,"
    },
    {
      "id": "tha-ap394:8.2",
      "pali": "cammakārā ca tacchakā;"
    },
    {
      "id": "tha-ap394:8.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:8.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:9.1",
      "pali": "Kammārā soṇṇakārā ca,"
    },
    {
      "id": "tha-ap394:9.2",
      "pali": "tipulohakarā tathā;"
    },
    {
      "id": "tha-ap394:9.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "tha-ap394:9.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:10.1",
      "pali": "Bhatakā ceṭakā ceva,"
    },
    {
      "id": "tha-ap394:10.2",
      "pali": "dāsakammakarā bahū;"
    },
    {
      "id": "tha-ap394:10.3",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap394:10.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:11.1",
      "pali": "Udahārā kaṭṭhahārā,"
    },
    {
      "id": "tha-ap394:11.2",
      "pali": "kassakā tiṇahārakā;"
    },
    {
      "id": "tha-ap394:11.3",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap394:11.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:12.1",
      "pali": "Pupphikā mālikā ceva,"
    },
    {
      "id": "tha-ap394:12.2",
      "pali": "paṇṇikā phalahārakā;"
    },
    {
      "id": "tha-ap394:12.3",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap394:12.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:13.1",
      "pali": "Gaṇikā kumbhadāsī ca,"
    },
    {
      "id": "tha-ap394:13.2",
      "pali": "pūvikā macchikāpi ca;"
    },
    {
      "id": "tha-ap394:13.3",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap394:13.4",
      "pali": "pūgadhammaṁ akaṁsu te."
    },
    {
      "id": "tha-ap394:14.1",
      "pali": "Etha sabbe samāgantvā,"
    },
    {
      "id": "tha-ap394:14.2",
      "pali": "gaṇaṁ bandhāma ekato;"
    },
    {
      "id": "tha-ap394:14.3",
      "pali": "Adhikāraṁ karissāma,"
    },
    {
      "id": "tha-ap394:14.4",
      "pali": "puññakkhette anuttare’."
    },
    {
      "id": "tha-ap394:15.1",
      "pali": "Te me sutvāna vacanaṁ,"
    },
    {
      "id": "tha-ap394:15.2",
      "pali": "gaṇaṁ bandhiṁsu tāvade;"
    },
    {
      "id": "tha-ap394:15.3",
      "pali": "‘Upaṭṭhānasālaṁ sukataṁ,"
    },
    {
      "id": "tha-ap394:15.4",
      "pali": "bhikkhusaṅghassa kārayuṁ’."
    },
    {
      "id": "tha-ap394:16.1",
      "pali": "Niṭṭhāpetvāna taṁ sālaṁ,"
    },
    {
      "id": "tha-ap394:16.2",
      "pali": "udaggo tuṭṭhamānaso;"
    },
    {
      "id": "tha-ap394:16.3",
      "pali": "Pareto tehi sabbehi,"
    },
    {
      "id": "tha-ap394:16.4",
      "pali": "sambuddhamupasaṅkamiṁ."
    },
    {
      "id": "tha-ap394:17.1",
      "pali": "Upasaṅkamma sambuddhaṁ,"
    },
    {
      "id": "tha-ap394:17.2",
      "pali": "lokanāthaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap394:17.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap394:17.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap394:18.1",
      "pali": "‘Ime tīṇi satā vīra,"
    },
    {
      "id": "tha-ap394:18.2",
      "pali": "Purisā ekato gaṇā;"
    },
    {
      "id": "tha-ap394:18.3",
      "pali": "Upaṭṭhānasālaṁ sukataṁ,"
    },
    {
      "id": "tha-ap394:18.4",
      "pali": "Niyyādenti tuvaṁ muni."
    },
    {
      "id": "tha-ap394:19.1",
      "pali": "Bhikkhusaṅghassa purato,"
    },
    {
      "id": "tha-ap394:19.2",
      "pali": "sampaṭicchitva cakkhumā’;"
    },
    {
      "id": "tha-ap394:19.3",
      "pali": "Tiṇṇaṁ satānaṁ purato,"
    },
    {
      "id": "tha-ap394:19.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap394:20.1",
      "pali": "‘Tisatāpi ca jeṭṭho ca,"
    },
    {
      "id": "tha-ap394:20.2",
      "pali": "anuvattiṁsu ekato;"
    },
    {
      "id": "tha-ap394:20.3",
      "pali": "Sampattiñhi karitvāna,"
    },
    {
      "id": "tha-ap394:20.4",
      "pali": "sabbe anubhavissatha."
    },
    {
      "id": "tha-ap394:21.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap394:21.2",
      "pali": "sītibhāvamanuttaraṁ;"
    },
    {
      "id": "tha-ap394:21.3",
      "pali": "Ajaraṁ amataṁ santaṁ,"
    },
    {
      "id": "tha-ap394:21.4",
      "pali": "nibbānaṁ phassayissatha’."
    },
    {
      "id": "tha-ap394:22.1",
      "pali": "Evaṁ buddho viyākāsi,"
    },
    {
      "id": "tha-ap394:22.2",
      "pali": "sabbaññū samaṇuttaro;"
    },
    {
      "id": "tha-ap394:22.3",
      "pali": "Buddhassa vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap394:22.4",
      "pali": "somanassaṁ pavedayiṁ."
    },
    {
      "id": "tha-ap394:23.1",
      "pali": "Tiṁsa kappasahassāni,"
    },
    {
      "id": "tha-ap394:23.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap394:23.3",
      "pali": "Devādhipo pañcasataṁ,"
    },
    {
      "id": "tha-ap394:23.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap394:24.1",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap394:24.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap394:24.3",
      "pali": "Devarajjaṁ karontassa,"
    },
    {
      "id": "tha-ap394:24.4",
      "pali": "mahādevā avandisuṁ."
    },
    {
      "id": "tha-ap394:25.1",
      "pali": "Idha mānusake rajjaṁ,"
    },
    {
      "id": "tha-ap394:25.2",
      "pali": "parisā honti bandhavā;"
    },
    {
      "id": "tha-ap394:25.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap394:25.4",
      "pali": "vāseṭṭho nāma brāhmaṇo."
    },
    {
      "id": "tha-ap394:26.1",
      "pali": "Asītikoṭi nicayo,"
    },
    {
      "id": "tha-ap394:26.2",
      "pali": "tassa putto ahosahaṁ;"
    },
    {
      "id": "tha-ap394:26.3",
      "pali": "Selo iti mamaṁ nāmaṁ,"
    },
    {
      "id": "tha-ap394:26.4",
      "pali": "chaḷaṅge pāramiṁ gato."
    },
    {
      "id": "tha-ap394:27.1",
      "pali": "Jaṅghāvihāraṁ vicaraṁ,"
    },
    {
      "id": "tha-ap394:27.2",
      "pali": "sasissehi purakkhato;"
    },
    {
      "id": "tha-ap394:27.3",
      "pali": "Jaṭābhārikabharitaṁ,"
    },
    {
      "id": "tha-ap394:27.4",
      "pali": "keṇiyaṁ nāma tāpasaṁ."
    },
    {
      "id": "tha-ap394:28.1",
      "pali": "Paṭiyattāhutiṁ disvā,"
    },
    {
      "id": "tha-ap394:28.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "tha-ap394:28.3",
      "pali": "‘Āvāho vā vivāho vā,"
    },
    {
      "id": "tha-ap394:28.4",
      "pali": "rājā vā te nimantito’."
    },
    {
      "id": "tha-ap394:29.1",
      "pali": "‘Āhutiṁ yiṭṭhukāmohaṁ,"
    },
    {
      "id": "tha-ap394:29.2",
      "pali": "brāhmaṇe devasammate;"
    },
    {
      "id": "tha-ap394:29.3",
      "pali": "Na nimantemi rājānaṁ,"
    },
    {
      "id": "tha-ap394:29.4",
      "pali": "āhutī me na vijjati."
    },
    {
      "id": "tha-ap394:30.1",
      "pali": "Na catthi mayhamāvāho,"
    },
    {
      "id": "tha-ap394:30.2",
      "pali": "vivāho me na vijjati;"
    },
    {
      "id": "tha-ap394:30.3",
      "pali": "Sakyānaṁ nandijanano,"
    },
    {
      "id": "tha-ap394:30.4",
      "pali": "seṭṭho loke sadevake."
    },
    {
      "id": "tha-ap394:31.1",
      "pali": "Sabbalokahitatthāya,"
    },
    {
      "id": "tha-ap394:31.2",
      "pali": "sabbasattasukhāvaho;"
    },
    {
      "id": "tha-ap394:31.3",
      "pali": "So me nimantito ajja,"
    },
    {
      "id": "tha-ap394:31.4",
      "pali": "tassetaṁ paṭiyādanaṁ."
    },
    {
      "id": "tha-ap394:32.1",
      "pali": "Timbarūsakavaṇṇābho,"
    },
    {
      "id": "tha-ap394:32.2",
      "pali": "appameyyo anūpamo;"
    },
    {
      "id": "tha-ap394:32.3",
      "pali": "Rūpenāsadiso buddho,"
    },
    {
      "id": "tha-ap394:32.4",
      "pali": "svātanāya nimantito."
    },
    {
      "id": "tha-ap394:33.1",
      "pali": "Ukkāmukhapahaṭṭhova,"
    },
    {
      "id": "tha-ap394:33.2",
      "pali": "khadiraṅgārasannibho;"
    },
    {
      "id": "tha-ap394:33.3",
      "pali": "Vijjūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:33.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:34.1",
      "pali": "Pabbatagge yathā acci,"
    },
    {
      "id": "tha-ap394:34.2",
      "pali": "puṇṇamāyeva candimā;"
    },
    {
      "id": "tha-ap394:34.3",
      "pali": "Naḷaggivaṇṇasaṅkāso,"
    },
    {
      "id": "tha-ap394:34.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:35.1",
      "pali": "Asambhīto bhayātīto,"
    },
    {
      "id": "tha-ap394:35.2",
      "pali": "bhavantakaraṇo muni;"
    },
    {
      "id": "tha-ap394:35.3",
      "pali": "Sīhūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:35.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:36.1",
      "pali": "Kusalo buddhadhammehi,"
    },
    {
      "id": "tha-ap394:36.2",
      "pali": "apasayho parehi so;"
    },
    {
      "id": "tha-ap394:36.3",
      "pali": "Nāgūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:36.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:37.1",
      "pali": "Saddhammācārakusalo,"
    },
    {
      "id": "tha-ap394:37.2",
      "pali": "buddhanāgo asādiso;"
    },
    {
      "id": "tha-ap394:37.3",
      "pali": "Usabhūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:37.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:38.1",
      "pali": "Anantavaṇṇo amitayaso,"
    },
    {
      "id": "tha-ap394:38.2",
      "pali": "Vicittasabbalakkhaṇo;"
    },
    {
      "id": "tha-ap394:38.3",
      "pali": "Sakkūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:38.4",
      "pali": "So me buddho nimantito."
    },
    {
      "id": "tha-ap394:39.1",
      "pali": "Vasī gaṇī patāpī ca,"
    },
    {
      "id": "tha-ap394:39.2",
      "pali": "tejassī ca durāsado;"
    },
    {
      "id": "tha-ap394:39.3",
      "pali": "Brahmūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:39.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:40.1",
      "pali": "Pattadhammo dasabalo,"
    },
    {
      "id": "tha-ap394:40.2",
      "pali": "balātibalapārago;"
    },
    {
      "id": "tha-ap394:40.3",
      "pali": "Dharaṇūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:40.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:41.1",
      "pali": "Sīlavīcisamākiṇṇo,"
    },
    {
      "id": "tha-ap394:41.2",
      "pali": "dhammaviññāṇakhobhito;"
    },
    {
      "id": "tha-ap394:41.3",
      "pali": "Udadhūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:41.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:42.1",
      "pali": "Durāsado duppasaho,"
    },
    {
      "id": "tha-ap394:42.2",
      "pali": "acalo uggato brahā;"
    },
    {
      "id": "tha-ap394:42.3",
      "pali": "Nerūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:42.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:43.1",
      "pali": "Anantañāṇo asamasamo,"
    },
    {
      "id": "tha-ap394:43.2",
      "pali": "Atulo aggataṁ gato;"
    },
    {
      "id": "tha-ap394:43.3",
      "pali": "Gaganūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:43.4",
      "pali": "So me buddho nimantito."
    },
    {
      "id": "tha-ap394:44.1",
      "pali": "Pannarasamaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap394:45.1",
      "pali": "Patiṭṭhā bhayabhītānaṁ,"
    },
    {
      "id": "tha-ap394:45.2",
      "pali": "tāṇo saraṇagāminaṁ;"
    },
    {
      "id": "tha-ap394:45.3",
      "pali": "Assāsako mahāvīro,"
    },
    {
      "id": "tha-ap394:45.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:46.1",
      "pali": "Āsayo buddhimantānaṁ,"
    },
    {
      "id": "tha-ap394:46.2",
      "pali": "puññakkhettaṁ sukhesinaṁ;"
    },
    {
      "id": "tha-ap394:46.3",
      "pali": "Ratanākaro mahāvīro,"
    },
    {
      "id": "tha-ap394:46.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:47.1",
      "pali": "Assāsako vedakaro,"
    },
    {
      "id": "tha-ap394:47.2",
      "pali": "sāmaññaphaladāyako;"
    },
    {
      "id": "tha-ap394:47.3",
      "pali": "Meghūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:47.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:48.1",
      "pali": "Lokacakkhu mahātejo,"
    },
    {
      "id": "tha-ap394:48.2",
      "pali": "sabbatamavinodano;"
    },
    {
      "id": "tha-ap394:48.3",
      "pali": "Sūriyūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:48.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:49.1",
      "pali": "Ārammaṇavimuttīsu,"
    },
    {
      "id": "tha-ap394:49.2",
      "pali": "sabhāvadassano muni;"
    },
    {
      "id": "tha-ap394:49.3",
      "pali": "Candūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:49.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:50.1",
      "pali": "Buddho samussito loke,"
    },
    {
      "id": "tha-ap394:50.2",
      "pali": "lakkhaṇehi alaṅkato;"
    },
    {
      "id": "tha-ap394:50.3",
      "pali": "Appameyyo mahāvīro,"
    },
    {
      "id": "tha-ap394:50.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:51.1",
      "pali": "Yassa ñāṇaṁ appameyyaṁ,"
    },
    {
      "id": "tha-ap394:51.2",
      "pali": "sīlaṁ yassa anūpamaṁ;"
    },
    {
      "id": "tha-ap394:51.3",
      "pali": "Vimutti asadisā yassa,"
    },
    {
      "id": "tha-ap394:51.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:52.1",
      "pali": "Yassa dhīti asadisā,"
    },
    {
      "id": "tha-ap394:52.2",
      "pali": "thāmo yassa acintiyo;"
    },
    {
      "id": "tha-ap394:52.3",
      "pali": "Yassa parakkamo jeṭṭho,"
    },
    {
      "id": "tha-ap394:52.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:53.1",
      "pali": "Rāgo doso ca moho ca,"
    },
    {
      "id": "tha-ap394:53.2",
      "pali": "visā sabbe samūhatā;"
    },
    {
      "id": "tha-ap394:53.3",
      "pali": "Agadūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:53.4",
      "pali": "so me buddho nimantito."
    },
    {
      "id": "tha-ap394:54.1",
      "pali": "Klesabyādhibahudukkha,"
    },
    {
      "id": "tha-ap394:54.2",
      "pali": "sabbatamavinodano;"
    },
    {
      "id": "tha-ap394:54.3",
      "pali": "Vejjūpamo mahāvīro,"
    },
    {
      "id": "tha-ap394:54.4",
      "pali": "so me buddho nimantito’."
    },
    {
      "id": "tha-ap394:55.1",
      "pali": "Buddhoti bho yaṁ vadesi,"
    },
    {
      "id": "tha-ap394:55.2",
      "pali": "ghosopeso sudullabho;"
    },
    {
      "id": "tha-ap394:55.3",
      "pali": "Buddho buddhoti sutvāna,"
    },
    {
      "id": "tha-ap394:55.4",
      "pali": "pīti me udapajjatha."
    },
    {
      "id": "tha-ap394:56.1",
      "pali": "Abbhantaraṁ agaṇhantaṁ,"
    },
    {
      "id": "tha-ap394:56.2",
      "pali": "pīti me bahi nicchare;"
    },
    {
      "id": "tha-ap394:56.3",
      "pali": "Sohaṁ pītimano santo,"
    },
    {
      "id": "tha-ap394:56.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap394:57.1",
      "pali": "‘Kahaṁ nu kho so bhagavā,"
    },
    {
      "id": "tha-ap394:57.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap394:57.3",
      "pali": "Tattha gantvā namassissaṁ,"
    },
    {
      "id": "tha-ap394:57.4",
      "pali": "sāmaññaphaladāyakaṁ."
    },
    {
      "id": "tha-ap394:58.1",
      "pali": "Paggayha dakkhiṇaṁ bāhuṁ,"
    },
    {
      "id": "tha-ap394:58.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap394:58.3",
      "pali": "Ācikkhi me dhammarājaṁ,"
    },
    {
      "id": "tha-ap394:58.4",
      "pali": "sokasallavinodanaṁ’."
    },
    {
      "id": "tha-ap394:59.1",
      "pali": "‘Udentaṁva mahāmeghaṁ,"
    },
    {
      "id": "tha-ap394:59.2",
      "pali": "nīlaṁ añjanasannibhaṁ;"
    },
    {
      "id": "tha-ap394:59.3",
      "pali": "Sāgaraṁ viya dissantaṁ,"
    },
    {
      "id": "tha-ap394:59.4",
      "pali": "passasetaṁ mahāvanaṁ."
    },
    {
      "id": "tha-ap394:60.1",
      "pali": "Ettha so vasate buddho,"
    },
    {
      "id": "tha-ap394:60.2",
      "pali": "adantadamako muni;"
    },
    {
      "id": "tha-ap394:60.3",
      "pali": "Vinayanto ca veneyye,"
    },
    {
      "id": "tha-ap394:60.4",
      "pali": "bodhento bodhipakkhiye’."
    },
    {
      "id": "tha-ap394:61.1",
      "pali": "Pipāsitova udakaṁ,"
    },
    {
      "id": "tha-ap394:61.2",
      "pali": "bhojanaṁva jighacchito;"
    },
    {
      "id": "tha-ap394:61.3",
      "pali": "Gāvī yathā vacchagiddhā,"
    },
    {
      "id": "tha-ap394:61.4",
      "pali": "evāhaṁ viciniṁ jinaṁ."
    },
    {
      "id": "tha-ap394:62.1",
      "pali": "Ācāraupacāraññū,"
    },
    {
      "id": "tha-ap394:62.2",
      "pali": "dhammānucchavisaṁvaraṁ;"
    },
    {
      "id": "tha-ap394:62.3",
      "pali": "Sikkhāpemi sake sisse,"
    },
    {
      "id": "tha-ap394:62.4",
      "pali": "gacchante jinasantikaṁ."
    },
    {
      "id": "tha-ap394:63.1",
      "pali": "‘Durāsadā bhagavanto,"
    },
    {
      "id": "tha-ap394:63.2",
      "pali": "sīhāva ekacārino;"
    },
    {
      "id": "tha-ap394:63.3",
      "pali": "Pade padaṁ nikkhipantā,"
    },
    {
      "id": "tha-ap394:63.4",
      "pali": "āgaccheyyātha māṇavā."
    },
    {
      "id": "tha-ap394:64.1",
      "pali": "Āsīviso yathā ghoro,"
    },
    {
      "id": "tha-ap394:64.2",
      "pali": "migarājāva kesarī;"
    },
    {
      "id": "tha-ap394:64.3",
      "pali": "Mattova kuñjaro dantī,"
    },
    {
      "id": "tha-ap394:64.4",
      "pali": "evaṁ buddhā durāsadā."
    },
    {
      "id": "tha-ap394:65.1",
      "pali": "Ukkāsitañca khipitaṁ,"
    },
    {
      "id": "tha-ap394:65.2",
      "pali": "ajjhupekkhiya māṇavā;"
    },
    {
      "id": "tha-ap394:65.3",
      "pali": "Pade padaṁ nikkhipantā,"
    },
    {
      "id": "tha-ap394:65.4",
      "pali": "upetha buddhasantikaṁ."
    },
    {
      "id": "tha-ap394:66.1",
      "pali": "Paṭisallānagarukā,"
    },
    {
      "id": "tha-ap394:66.2",
      "pali": "appasaddā durāsadā;"
    },
    {
      "id": "tha-ap394:66.3",
      "pali": "Durūpasaṅkamā buddhā,"
    },
    {
      "id": "tha-ap394:66.4",
      "pali": "garū honti sadevake."
    },
    {
      "id": "tha-ap394:67.1",
      "pali": "Yadāhaṁ pañhaṁ pucchāmi,"
    },
    {
      "id": "tha-ap394:67.2",
      "pali": "paṭisammodayāmi vā;"
    },
    {
      "id": "tha-ap394:67.3",
      "pali": "Appasaddā tadā hotha,"
    },
    {
      "id": "tha-ap394:67.4",
      "pali": "munibhūtāva tiṭṭhatha."
    },
    {
      "id": "tha-ap394:68.1",
      "pali": "Yaṁ so deseti sambuddho,"
    },
    {
      "id": "tha-ap394:68.2",
      "pali": "khemaṁ nibbānapattiyā;"
    },
    {
      "id": "tha-ap394:68.3",
      "pali": "Tamevatthaṁ nisāmetha,"
    },
    {
      "id": "tha-ap394:68.4",
      "pali": "saddhammasavanaṁ sukhaṁ’."
    },
    {
      "id": "tha-ap394:69.1",
      "pali": "Upasaṅkamma sambuddhaṁ,"
    },
    {
      "id": "tha-ap394:69.2",
      "pali": "sammodiṁ muninā ahaṁ;"
    },
    {
      "id": "tha-ap394:69.3",
      "pali": "Taṁ kathaṁ vītisāretvā,"
    },
    {
      "id": "tha-ap394:69.4",
      "pali": "lakkhaṇe upadhārayiṁ."
    },
    {
      "id": "tha-ap394:70.1",
      "pali": "Lakkhaṇe dve ca kaṅkhāmi,"
    },
    {
      "id": "tha-ap394:70.2",
      "pali": "passāmi tiṁsalakkhaṇe;"
    },
    {
      "id": "tha-ap394:70.3",
      "pali": "Kosohitavatthaguyhaṁ,"
    },
    {
      "id": "tha-ap394:70.4",
      "pali": "iddhiyā dassayī muni."
    },
    {
      "id": "tha-ap394:71.1",
      "pali": "Jivhaṁ ninnāmayitvāna,"
    },
    {
      "id": "tha-ap394:71.2",
      "pali": "kaṇṇasote ca nāsike;"
    },
    {
      "id": "tha-ap394:71.3",
      "pali": "Paṭimasi nalāṭantaṁ,"
    },
    {
      "id": "tha-ap394:71.4",
      "pali": "kevalaṁ chādayī jino."
    },
    {
      "id": "tha-ap394:72.1",
      "pali": "Tassāhaṁ lakkhaṇe disvā,"
    },
    {
      "id": "tha-ap394:72.2",
      "pali": "paripuṇṇe sabyañjane;"
    },
    {
      "id": "tha-ap394:72.3",
      "pali": "Buddhoti niṭṭhaṁ gantvāna,"
    },
    {
      "id": "tha-ap394:72.4",
      "pali": "saha sissehi pabbajiṁ."
    },
    {
      "id": "tha-ap394:73.1",
      "pali": "Satehi tīhi sahito,"
    },
    {
      "id": "tha-ap394:73.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap394:73.3",
      "pali": "Addhamāse asampatte,"
    },
    {
      "id": "tha-ap394:73.4",
      "pali": "sabbe pattāmha nibbutiṁ."
    },
    {
      "id": "tha-ap394:74.1",
      "pali": "Ekato kammaṁ katvāna,"
    },
    {
      "id": "tha-ap394:74.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "tha-ap394:74.3",
      "pali": "Ekato saṁsaritvāna,"
    },
    {
      "id": "tha-ap394:74.4",
      "pali": "ekato vinivattayuṁ."
    },
    {
      "id": "tha-ap394:75.1",
      "pali": "Gopānasiyo datvāna,"
    },
    {
      "id": "tha-ap394:75.2",
      "pali": "pūgadhamme vasiṁ ahaṁ;"
    },
    {
      "id": "tha-ap394:75.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:75.4",
      "pali": "aṭṭha hetū labhāmahaṁ."
    },
    {
      "id": "tha-ap394:76.1",
      "pali": "Disāsu pūjito homi,"
    },
    {
      "id": "tha-ap394:76.2",
      "pali": "bhogā ca amitā mama;"
    },
    {
      "id": "tha-ap394:76.3",
      "pali": "Patiṭṭhā homi sabbesaṁ,"
    },
    {
      "id": "tha-ap394:76.4",
      "pali": "tāso mama na vijjati."
    },
    {
      "id": "tha-ap394:77.1",
      "pali": "Byādhayo me na vijjanti,"
    },
    {
      "id": "tha-ap394:77.2",
      "pali": "dīghāyuṁ pālayāmi ca;"
    },
    {
      "id": "tha-ap394:77.3",
      "pali": "Sukhumacchaviko homi,"
    },
    {
      "id": "tha-ap394:77.4",
      "pali": "āvāse patthite vase."
    },
    {
      "id": "tha-ap394:78.1",
      "pali": "Aṭṭha gopānasī datvā,"
    },
    {
      "id": "tha-ap394:78.2",
      "pali": "pūgadhamme vasiṁ ahaṁ;"
    },
    {
      "id": "tha-ap394:78.3",
      "pali": "Paṭisambhidārahattañca,"
    },
    {
      "id": "tha-ap394:78.4",
      "pali": "etaṁ me aparaṭṭhamaṁ."
    },
    {
      "id": "tha-ap394:79.1",
      "pali": "Sabbavositavosāno,"
    },
    {
      "id": "tha-ap394:79.2",
      "pali": "katakicco anāsavo;"
    },
    {
      "id": "tha-ap394:79.3",
      "pali": "Aṭṭhagopānasī nāma,"
    },
    {
      "id": "tha-ap394:79.4",
      "pali": "tava putto mahāmuni."
    },
    {
      "id": "tha-ap394:80.1",
      "pali": "Pañca thambhāni datvāna,"
    },
    {
      "id": "tha-ap394:80.2",
      "pali": "pūgadhamme vasiṁ ahaṁ;"
    },
    {
      "id": "tha-ap394:80.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:80.4",
      "pali": "pañca hetū labhāmahaṁ."
    },
    {
      "id": "tha-ap394:81.1",
      "pali": "Acalo homi mettāya,"
    },
    {
      "id": "tha-ap394:81.2",
      "pali": "anūnaṅgo bhavāmahaṁ;"
    },
    {
      "id": "tha-ap394:81.3",
      "pali": "Ādeyyavacano homi,"
    },
    {
      "id": "tha-ap394:81.4",
      "pali": "na dhaṁsemi yathā ahaṁ."
    },
    {
      "id": "tha-ap394:82.1",
      "pali": "Abhantaṁ hoti me cittaṁ,"
    },
    {
      "id": "tha-ap394:82.2",
      "pali": "akhilo homi kassaci;"
    },
    {
      "id": "tha-ap394:82.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:82.4",
      "pali": "vimalo homi sāsane."
    },
    {
      "id": "tha-ap394:83.1",
      "pali": "Sagāravo sappatisso,"
    },
    {
      "id": "tha-ap394:83.2",
      "pali": "katakicco anāsavo;"
    },
    {
      "id": "tha-ap394:83.3",
      "pali": "Sāvako te mahāvīra,"
    },
    {
      "id": "tha-ap394:83.4",
      "pali": "bhikkhu taṁ vandate muni."
    },
    {
      "id": "tha-ap394:84.1",
      "pali": "Katvā sukatapallaṅkaṁ,"
    },
    {
      "id": "tha-ap394:84.2",
      "pali": "sālāyaṁ paññapesahaṁ;"
    },
    {
      "id": "tha-ap394:84.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:84.4",
      "pali": "pañca hetū labhāmahaṁ."
    },
    {
      "id": "tha-ap394:85.1",
      "pali": "Ucce kule pajāyitvā,"
    },
    {
      "id": "tha-ap394:85.2",
      "pali": "mahābhogo bhavāmahaṁ;"
    },
    {
      "id": "tha-ap394:85.3",
      "pali": "Sabbasampattiko homi,"
    },
    {
      "id": "tha-ap394:85.4",
      "pali": "maccheraṁ me na vijjati."
    },
    {
      "id": "tha-ap394:86.1",
      "pali": "Gamane patthite mayhaṁ,"
    },
    {
      "id": "tha-ap394:86.2",
      "pali": "pallaṅko upatiṭṭhati;"
    },
    {
      "id": "tha-ap394:86.3",
      "pali": "Saha pallaṅkaseṭṭhena,"
    },
    {
      "id": "tha-ap394:86.4",
      "pali": "gacchāmi mama patthitaṁ."
    },
    {
      "id": "tha-ap394:87.1",
      "pali": "Tena pallaṅkadānena,"
    },
    {
      "id": "tha-ap394:87.2",
      "pali": "tamaṁ sabbaṁ vinodayiṁ;"
    },
    {
      "id": "tha-ap394:87.3",
      "pali": "Sabbābhiññābalappatto,"
    },
    {
      "id": "tha-ap394:87.4",
      "pali": "thero vandati taṁ muni."
    },
    {
      "id": "tha-ap394:88.1",
      "pali": "Parakiccattakiccāni,"
    },
    {
      "id": "tha-ap394:88.2",
      "pali": "sabbakiccāni sādhayiṁ;"
    },
    {
      "id": "tha-ap394:88.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:88.4",
      "pali": "pāvisiṁ abhayaṁ puraṁ."
    },
    {
      "id": "tha-ap394:89.1",
      "pali": "Pariniṭṭhitasālamhi,"
    },
    {
      "id": "tha-ap394:89.2",
      "pali": "paribhogamadāsahaṁ;"
    },
    {
      "id": "tha-ap394:89.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap394:89.4",
      "pali": "seṭṭhattaṁ ajjhupāgato."
    },
    {
      "id": "tha-ap394:90.1",
      "pali": "Ye keci damakā loke,"
    },
    {
      "id": "tha-ap394:90.2",
      "pali": "hatthiasse damenti ye;"
    },
    {
      "id": "tha-ap394:90.3",
      "pali": "Karitvā kāraṇā nānā,"
    },
    {
      "id": "tha-ap394:90.4",
      "pali": "dāruṇena damenti te."
    },
    {
      "id": "tha-ap394:91.1",
      "pali": "Na hevaṁ tvaṁ mahāvīra,"
    },
    {
      "id": "tha-ap394:91.2",
      "pali": "damesi naranāriyo;"
    },
    {
      "id": "tha-ap394:91.3",
      "pali": "Adaṇḍena asatthena,"
    },
    {
      "id": "tha-ap394:91.4",
      "pali": "damesi uttame dame."
    },
    {
      "id": "tha-ap394:92.1",
      "pali": "Dānassa vaṇṇe kittento,"
    },
    {
      "id": "tha-ap394:92.2",
      "pali": "desanākusalo muni;"
    },
    {
      "id": "tha-ap394:92.3",
      "pali": "Ekapañhaṁ kathentova,"
    },
    {
      "id": "tha-ap394:92.4",
      "pali": "bodhesi tisate muni."
    },
    {
      "id": "tha-ap394:93.1",
      "pali": "Dantā mayaṁ sārathinā,"
    },
    {
      "id": "tha-ap394:93.2",
      "pali": "suvimuttā anāsavā;"
    },
    {
      "id": "tha-ap394:93.3",
      "pali": "Sabbābhiññābalapattā,"
    },
    {
      "id": "tha-ap394:93.4",
      "pali": "nibbutā upadhikkhaye."
    },
    {
      "id": "tha-ap394:94.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap394:94.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap394:94.3",
      "pali": "Atikkantā bhayā sabbe,"
    },
    {
      "id": "tha-ap394:94.4",
      "pali": "sālādānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap394:95.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap394:95.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap394:95.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap394:96.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap394:96.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap394:96.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap394:97.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap394:97.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap394:97.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap394:98.1",
      "pali": "Itthaṁ sudaṁ āyasmā selo sapariso bhagavato santike imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap394:99.1",
      "pali": "Selattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
