{
  "uid": "thag2.33",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.33:1.1",
      "pali": "“Arahaṁ sugato loke,"
    },
    {
      "id": "thag2.33:1.2",
      "pali": "vātehābādhiko muni;"
    },
    {
      "id": "thag2.33:1.3",
      "pali": "Sace uṇhodakaṁ atthi,"
    },
    {
      "id": "thag2.33:1.4",
      "pali": "munino dehi brāhmaṇa."
    },
    {
      "id": "thag2.33:2.1",
      "pali": "Pūjito pūjaneyyānaṁ,"
    },
    {
      "id": "thag2.33:2.2",
      "pali": "sakkareyyāna sakkato;"
    },
    {
      "id": "thag2.33:2.3",
      "pali": "Apacitopaceyyānaṁ,"
    },
    {
      "id": "thag2.33:2.4",
      "pali": "tassa icchāmi hātave”ti."
    },
    {
      "id": "thag2.33:2.5",
      "pali": "… Upavāṇo thero …."
    }
  ]
}
