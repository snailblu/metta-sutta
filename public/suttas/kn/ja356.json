{
  "uid": "ja356",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja356:1.1",
      "pali": "“Eko araññe girikandarāyaṁ,"
    },
    {
      "id": "ja356:1.2",
      "pali": "Paggayha paggayha silaṁ pavecchasi;"
    },
    {
      "id": "ja356:1.3",
      "pali": "Punappunaṁ santaramānarūpo,"
    },
    {
      "id": "ja356:1.4",
      "pali": "Koraṇḍiya ko nu tava yidhattho”."
    },
    {
      "id": "ja356:2.1",
      "pali": "“Ahañhimaṁ sāgara sevitantaṁ,"
    },
    {
      "id": "ja356:2.2",
      "pali": "Samaṁ karissāmi yathāpi pāṇi;"
    },
    {
      "id": "ja356:2.3",
      "pali": "Vikiriya sānūni ca pabbatāni ca,"
    },
    {
      "id": "ja356:2.4",
      "pali": "Tasmā silaṁ dariyā pakkhipāmi”."
    },
    {
      "id": "ja356:3.1",
      "pali": "“Nayimaṁ mahiṁ arahati pāṇikappaṁ,"
    },
    {
      "id": "ja356:3.2",
      "pali": "Samaṁ manusso karaṇāya meko;"
    },
    {
      "id": "ja356:3.3",
      "pali": "Maññāmimaññeva dariṁ jigīsaṁ,"
    },
    {
      "id": "ja356:3.4",
      "pali": "Koraṇḍiya hāhasi jīvalokaṁ”."
    },
    {
      "id": "ja356:4.1",
      "pali": "“Sace ahaṁ bhūtadharaṁ na sakkā,"
    },
    {
      "id": "ja356:4.2",
      "pali": "Samaṁ manusso karaṇāya meko;"
    },
    {
      "id": "ja356:4.3",
      "pali": "Evameva tvaṁ brahme ime manusse,"
    },
    {
      "id": "ja356:4.4",
      "pali": "Nānādiṭṭhike nānayissasi te”."
    },
    {
      "id": "ja356:5.1",
      "pali": "“Saṅkhittarūpena bhavaṁ mamatthaṁ,"
    },
    {
      "id": "ja356:5.2",
      "pali": "Akkhāsi koraṇḍiya evametaṁ;"
    },
    {
      "id": "ja356:5.3",
      "pali": "Yathā na sakkā pathavī samāyaṁ,"
    },
    {
      "id": "ja356:5.4",
      "pali": "Kattuṁ manussena tathā manussā”ti."
    },
    {
      "id": "ja356:6.1",
      "pali": "Koraṇḍiyajātakaṁ chaṭṭhaṁ."
    }
  ]
}
