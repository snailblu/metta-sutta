{
  "uid": "ja99",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja99:1.1",
      "pali": "Parosahassampi samāgatānaṁ,"
    },
    {
      "id": "ja99:1.2",
      "pali": "Kandeyyuṁ te vassasataṁ apaññā;"
    },
    {
      "id": "ja99:1.3",
      "pali": "Ekova seyyo puriso sapañño,"
    },
    {
      "id": "ja99:1.4",
      "pali": "Yo bhāsitassa vijānāti atthan”ti."
    },
    {
      "id": "ja99:2.1",
      "pali": "Parosahassajātakaṁ navamaṁ."
    }
  ]
}
