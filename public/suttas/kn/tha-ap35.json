{
  "uid": "tha-ap35",
  "title": "3 Mahākaccānattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap35:1.1",
      "pali": "“Padumuttaranāthassa,"
    },
    {
      "id": "tha-ap35:1.2",
      "pali": "padumaṁ nāma cetiyaṁ;"
    },
    {
      "id": "tha-ap35:1.3",
      "pali": "Silāsanaṁ kārayitvā,"
    },
    {
      "id": "tha-ap35:1.4",
      "pali": "suvaṇṇenābhilepayiṁ."
    },
    {
      "id": "tha-ap35:2.1",
      "pali": "Ratanāmayachattañca,"
    },
    {
      "id": "tha-ap35:2.2",
      "pali": "paggayha vāḷabījaniṁ;"
    },
    {
      "id": "tha-ap35:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap35:2.4",
      "pali": "lokabandhussa tādino."
    },
    {
      "id": "tha-ap35:3.1",
      "pali": "Yāvatā devatā bhummā,"
    },
    {
      "id": "tha-ap35:3.2",
      "pali": "sabbe sannipatuṁ tadā;"
    },
    {
      "id": "tha-ap35:3.3",
      "pali": "Ratanāmayachattānaṁ,"
    },
    {
      "id": "tha-ap35:3.4",
      "pali": "vipākaṁ kathayissati."
    },
    {
      "id": "tha-ap35:4.1",
      "pali": "Tañca sabbaṁ suṇissāma,"
    },
    {
      "id": "tha-ap35:4.2",
      "pali": "kathayantassa satthuno;"
    },
    {
      "id": "tha-ap35:4.3",
      "pali": "Bhiyyo hāsaṁ janeyyāma,"
    },
    {
      "id": "tha-ap35:4.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap35:5.1",
      "pali": "Hemāsane nisīditvā,"
    },
    {
      "id": "tha-ap35:5.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap35:5.3",
      "pali": "Bhikkhusaṅghaparibyūḷho,"
    },
    {
      "id": "tha-ap35:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap35:6.1",
      "pali": "‘Yenidaṁ āsanaṁ dinnaṁ,"
    },
    {
      "id": "tha-ap35:6.2",
      "pali": "sovaṇṇaṁ ratanāmayaṁ;"
    },
    {
      "id": "tha-ap35:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap35:6.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap35:7.1",
      "pali": "Tiṁsa kappāni devindo,"
    },
    {
      "id": "tha-ap35:7.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap35:7.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap35:7.4",
      "pali": "ābhāyābhibhavissati."
    },
    {
      "id": "tha-ap35:8.1",
      "pali": "Manussalokamāgantvā,"
    },
    {
      "id": "tha-ap35:8.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap35:8.3",
      "pali": "Pabhassaroti nāmena,"
    },
    {
      "id": "tha-ap35:8.4",
      "pali": "uggatejo bhavissati."
    },
    {
      "id": "tha-ap35:9.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "tha-ap35:9.2",
      "pali": "sataraṁsīva uggato;"
    },
    {
      "id": "tha-ap35:9.3",
      "pali": "Samantā aṭṭharatanaṁ,"
    },
    {
      "id": "tha-ap35:9.4",
      "pali": "ujjotissati khattiyo."
    },
    {
      "id": "tha-ap35:10.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap35:10.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap35:10.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap35:10.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap35:11.1",
      "pali": "Tusitā hi cavitvāna,"
    },
    {
      "id": "tha-ap35:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap35:11.3",
      "pali": "Kaccāno nāma nāmena,"
    },
    {
      "id": "tha-ap35:11.4",
      "pali": "brahmabandhu bhavissati."
    },
    {
      "id": "tha-ap35:12.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap35:12.2",
      "pali": "arahā hessatināsavo;"
    },
    {
      "id": "tha-ap35:12.3",
      "pali": "Gotamo lokapajjoto,"
    },
    {
      "id": "tha-ap35:12.4",
      "pali": "aggaṭṭhāne ṭhapessati."
    },
    {
      "id": "tha-ap35:13.1",
      "pali": "Saṅkhittapucchitaṁ pañhaṁ,"
    },
    {
      "id": "tha-ap35:13.2",
      "pali": "Vitthārena kathessati;"
    },
    {
      "id": "tha-ap35:13.3",
      "pali": "Kathayanto ca taṁ pañhaṁ,"
    },
    {
      "id": "tha-ap35:13.4",
      "pali": "Ajjhāsayaṁ pūrayissati’."
    },
    {
      "id": "tha-ap35:14.1",
      "pali": "Aḍḍhe kule abhijāto,"
    },
    {
      "id": "tha-ap35:14.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap35:14.3",
      "pali": "Ohāya dhanadhaññāni,"
    },
    {
      "id": "tha-ap35:14.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap35:15.1",
      "pali": "Saṅkhittenapi pucchante,"
    },
    {
      "id": "tha-ap35:15.2",
      "pali": "vitthārena kathemahaṁ;"
    },
    {
      "id": "tha-ap35:15.3",
      "pali": "Ajjhāsayaṁ tesaṁ pūremi,"
    },
    {
      "id": "tha-ap35:15.4",
      "pali": "tosemi dvipaduttamaṁ."
    },
    {
      "id": "tha-ap35:16.1",
      "pali": "Tosito me mahāvīro,"
    },
    {
      "id": "tha-ap35:16.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap35:16.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap35:16.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap35:17.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap35:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap35:17.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap35:18.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahākaccāno thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap35:19.1",
      "pali": "Mahākaccānattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
