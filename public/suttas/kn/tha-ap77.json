{
  "uid": "tha-ap77",
  "title": "Ekasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap77:1.1",
      "pali": "“Khaṇḍo nāmāsi nāmena,"
    },
    {
      "id": "tha-ap77:1.2",
      "pali": "vipassissaggasāvako;"
    },
    {
      "id": "tha-ap77:1.3",
      "pali": "Ekā bhikkhā mayā dinnā,"
    },
    {
      "id": "tha-ap77:1.4",
      "pali": "lokāhutipaṭiggahe."
    },
    {
      "id": "tha-ap77:2.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap77:2.2",
      "pali": "dvipadinda narāsabha;"
    },
    {
      "id": "tha-ap77:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap77:2.4",
      "pali": "ekabhikkhāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap77:3.1",
      "pali": "Cattālīsamhito kappe,"
    },
    {
      "id": "tha-ap77:3.2",
      "pali": "varuṇo nāma khattiyo;"
    },
    {
      "id": "tha-ap77:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap77:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap77:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap77:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap77:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap77:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap77:6.1",
      "pali": "Ekasaññakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
