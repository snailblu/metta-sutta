{
  "uid": "thag1.46",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.46:1.1",
      "pali": "“Saddhāyāhaṁ pabbajito,"
    },
    {
      "id": "thag1.46:1.2",
      "pali": "Agārasmānagāriyaṁ;"
    },
    {
      "id": "thag1.46:1.3",
      "pali": "Sati paññā ca me vuḍḍhā,"
    },
    {
      "id": "thag1.46:1.4",
      "pali": "Cittañca susamāhitaṁ;"
    },
    {
      "id": "thag1.46:1.5",
      "pali": "Kāmaṁ karassu rūpāni,"
    },
    {
      "id": "thag1.46:1.6",
      "pali": "Neva maṁ byādhayissasī”ti."
    },
    {
      "id": "thag1.46:1.7",
      "pali": "… Samiddhitthero …."
    }
  ]
}
