{
  "uid": "thag6.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.6:1.1",
      "pali": "“Paṇṇavīsativassāni,"
    },
    {
      "id": "thag6.6:1.2",
      "pali": "yato pabbajito ahaṁ;"
    },
    {
      "id": "thag6.6:1.3",
      "pali": "Accharāsaṅghātamattampi,"
    },
    {
      "id": "thag6.6:1.4",
      "pali": "cetosantimanajjhagaṁ."
    },
    {
      "id": "thag6.6:2.1",
      "pali": "Aladdhā cittassekaggaṁ,"
    },
    {
      "id": "thag6.6:2.2",
      "pali": "kāmarāgena aṭṭito;"
    },
    {
      "id": "thag6.6:2.3",
      "pali": "Bāhā paggayha kandanto,"
    },
    {
      "id": "thag6.6:2.4",
      "pali": "vihārā upanikkhamiṁ."
    },
    {
      "id": "thag6.6:3.1",
      "pali": "Satthaṁ vā āharissāmi,"
    },
    {
      "id": "thag6.6:3.2",
      "pali": "Ko attho jīvitena me;"
    },
    {
      "id": "thag6.6:3.3",
      "pali": "Kathaṁ hi sikkhaṁ paccakkhaṁ,"
    },
    {
      "id": "thag6.6:3.4",
      "pali": "Kālaṁ kubbetha mādiso."
    },
    {
      "id": "thag6.6:4.1",
      "pali": "Tadāhaṁ khuramādāya,"
    },
    {
      "id": "thag6.6:4.2",
      "pali": "mañcakamhi upāvisiṁ;"
    },
    {
      "id": "thag6.6:4.3",
      "pali": "Parinīto khuro āsi,"
    },
    {
      "id": "thag6.6:4.4",
      "pali": "dhamaniṁ chettumattano."
    },
    {
      "id": "thag6.6:5.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag6.6:5.2",
      "pali": "yoniso udapajjatha;"
    },
    {
      "id": "thag6.6:5.3",
      "pali": "Ādīnavo pāturahu,"
    },
    {
      "id": "thag6.6:5.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag6.6:6.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag6.6:6.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag6.6:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag6.6:6.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag6.6:6.5",
      "pali": "… Sappadāso thero …."
    }
  ]
}
