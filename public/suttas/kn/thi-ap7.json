{
  "uid": "thi-ap7",
  "title": "7 Kaṭacchubhikkhādāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap7:1.1",
      "pali": "“Piṇḍacāraṁ carantassa,"
    },
    {
      "id": "thi-ap7:1.2",
      "pali": "tissanāmassa satthuno;"
    },
    {
      "id": "thi-ap7:1.3",
      "pali": "Kaṭacchubhikkhaṁ paggayha,"
    },
    {
      "id": "thi-ap7:1.4",
      "pali": "buddhaseṭṭhassa dāsahaṁ."
    },
    {
      "id": "thi-ap7:2.1",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "thi-ap7:2.2",
      "pali": "tisso lokagganāyako;"
    },
    {
      "id": "thi-ap7:2.3",
      "pali": "Vīthiyā saṇṭhito satthā,"
    },
    {
      "id": "thi-ap7:2.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "thi-ap7:3.1",
      "pali": "‘Kaṭacchubhikkhaṁ datvāna,"
    },
    {
      "id": "thi-ap7:3.2",
      "pali": "tāvatiṁsaṁ gamissasi;"
    },
    {
      "id": "thi-ap7:3.3",
      "pali": "Chattiṁsadevarājūnaṁ,"
    },
    {
      "id": "thi-ap7:3.4",
      "pali": "mahesittaṁ karissasi."
    },
    {
      "id": "thi-ap7:4.1",
      "pali": "Paññāsaṁ cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap7:4.2",
      "pali": "mahesittaṁ karissasi;"
    },
    {
      "id": "thi-ap7:4.3",
      "pali": "Manasā patthitaṁ sabbaṁ,"
    },
    {
      "id": "thi-ap7:4.4",
      "pali": "paṭilacchasi sabbadā."
    },
    {
      "id": "thi-ap7:5.1",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "thi-ap7:5.2",
      "pali": "pabbajissasikiñcanā;"
    },
    {
      "id": "thi-ap7:5.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "thi-ap7:5.4",
      "pali": "nibbāyissasināsavā’."
    },
    {
      "id": "thi-ap7:6.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "thi-ap7:6.2",
      "pali": "tisso lokagganāyako;"
    },
    {
      "id": "thi-ap7:6.3",
      "pali": "Nabhaṁ abbhuggamī vīro,"
    },
    {
      "id": "thi-ap7:6.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "thi-ap7:7.1",
      "pali": "Sudinnaṁ me dānavaraṁ,"
    },
    {
      "id": "thi-ap7:7.2",
      "pali": "suyiṭṭhā yāgasampadā;"
    },
    {
      "id": "thi-ap7:7.3",
      "pali": "Kaṭacchubhikkhaṁ datvāna,"
    },
    {
      "id": "thi-ap7:7.4",
      "pali": "pattāhaṁ acalaṁ padaṁ."
    },
    {
      "id": "thi-ap7:8.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "thi-ap7:8.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "thi-ap7:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap7:8.4",
      "pali": "bhikkhādānassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap7:9.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap7:9.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap7:9.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap7:10.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap7:10.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap7:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap7:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap7:11.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap7:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap7:12.1",
      "pali": "Itthaṁ sudaṁ kaṭacchubhikkhādāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap7:13.1",
      "pali": "Kaṭacchubhikkhādāyikātheriyāpadānaṁ sattamaṁ."
    }
  ]
}
