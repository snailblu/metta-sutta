{
  "uid": "cp35",
  "title": "Upekkhāpāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp35:1.1",
      "pali": "“Susāne seyyaṁ kappemi,"
    },
    {
      "id": "cp35:1.2",
      "pali": "Chavaṭṭhikaṁ upanidhāyahaṁ;"
    },
    {
      "id": "cp35:1.3",
      "pali": "Gāmaṇḍalā upāgantvā,"
    },
    {
      "id": "cp35:1.4",
      "pali": "Rūpaṁ dassentinappakaṁ."
    },
    {
      "id": "cp35:2.1",
      "pali": "Apare gandhamālañca,"
    },
    {
      "id": "cp35:2.2",
      "pali": "bhojanaṁ vividhaṁ bahuṁ;"
    },
    {
      "id": "cp35:2.3",
      "pali": "Upāyanānūpanenti,"
    },
    {
      "id": "cp35:2.4",
      "pali": "haṭṭhā saṁviggamānasā."
    },
    {
      "id": "cp35:3.1",
      "pali": "Ye me dukkhaṁ upaharanti,"
    },
    {
      "id": "cp35:3.2",
      "pali": "ye ca denti sukhaṁ mama;"
    },
    {
      "id": "cp35:3.3",
      "pali": "Sabbesaṁ samako homi,"
    },
    {
      "id": "cp35:3.4",
      "pali": "dayā kopo na vijjati."
    },
    {
      "id": "cp35:4.1",
      "pali": "Sukhadukkhe tulābhūto,"
    },
    {
      "id": "cp35:4.2",
      "pali": "Yasesu ayasesu ca;"
    },
    {
      "id": "cp35:4.3",
      "pali": "Sabbattha samako homi,"
    },
    {
      "id": "cp35:4.4",
      "pali": "Esā me upekkhāpāramī”ti."
    },
    {
      "id": "cp35:5.1",
      "pali": "Mahālomahaṁsacariyaṁ pannarasamaṁ."
    },
    {
      "id": "cp35:6.1",
      "pali": "Yudhañjayavaggo tatiyo."
    },
    {
      "id": "cp35:7.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "cp35:8.1",
      "pali": "Yudhañjayo somanasso,"
    },
    {
      "id": "cp35:8.2",
      "pali": "ayogharabhisena ca;"
    },
    {
      "id": "cp35:8.3",
      "pali": "Soṇanando mūgapakkho,"
    },
    {
      "id": "cp35:8.4",
      "pali": "kapirājā saccasavhayo."
    },
    {
      "id": "cp35:9.1",
      "pali": "Vaṭṭako maccharājā ca,"
    },
    {
      "id": "cp35:9.2",
      "pali": "kaṇhadīpāyano isi;"
    },
    {
      "id": "cp35:9.3",
      "pali": "Sutasomo puna āsiṁ,"
    },
    {
      "id": "cp35:9.4",
      "pali": "sāmo ca ekarājahu;"
    },
    {
      "id": "cp35:9.5",
      "pali": "Upekkhāpāramī āsi,"
    },
    {
      "id": "cp35:9.6",
      "pali": "iti vutthaṁ mahesinā."
    },
    {
      "id": "cp35:10.1",
      "pali": "Evaṁ bahubbidhaṁ dukkhaṁ,"
    },
    {
      "id": "cp35:10.2",
      "pali": "sampattī ca bahubbidhā;"
    },
    {
      "id": "cp35:10.3",
      "pali": "Bhavābhave anubhavitvā,"
    },
    {
      "id": "cp35:10.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "cp35:11.1",
      "pali": "Datvā dātabbakaṁ dānaṁ,"
    },
    {
      "id": "cp35:11.2",
      "pali": "sīlaṁ pūretvā asesato;"
    },
    {
      "id": "cp35:11.3",
      "pali": "Nekkhamme pāramiṁ gantvā,"
    },
    {
      "id": "cp35:11.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "cp35:12.1",
      "pali": "Paṇḍite paripucchitvā,"
    },
    {
      "id": "cp35:12.2",
      "pali": "vīriyaṁ katvāna muttamaṁ;"
    },
    {
      "id": "cp35:12.3",
      "pali": "Khantiyā pāramiṁ gantvā,"
    },
    {
      "id": "cp35:12.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "cp35:13.1",
      "pali": "Katvā daḷhamadhiṭṭhānaṁ,"
    },
    {
      "id": "cp35:13.2",
      "pali": "saccavācānurakkhiya;"
    },
    {
      "id": "cp35:13.3",
      "pali": "Mettāya pāramiṁ gantvā,"
    },
    {
      "id": "cp35:13.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "cp35:14.1",
      "pali": "Lābhālābhe yasāyase,"
    },
    {
      "id": "cp35:14.2",
      "pali": "sammānanāvamānane;"
    },
    {
      "id": "cp35:14.3",
      "pali": "Sabbattha samako hutvā,"
    },
    {
      "id": "cp35:14.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "cp35:15.1",
      "pali": "Kosajjaṁ bhayato disvā,"
    },
    {
      "id": "cp35:15.2",
      "pali": "vīriyārambhañca khemato;"
    },
    {
      "id": "cp35:15.3",
      "pali": "Āraddhavīriyā hotha,"
    },
    {
      "id": "cp35:15.4",
      "pali": "esā buddhānusāsanī."
    },
    {
      "id": "cp35:16.1",
      "pali": "Vivādaṁ bhayato disvā,"
    },
    {
      "id": "cp35:16.2",
      "pali": "avivādañca khemato;"
    },
    {
      "id": "cp35:16.3",
      "pali": "Samaggā sakhilā hotha,"
    },
    {
      "id": "cp35:16.4",
      "pali": "esā buddhānusāsanī."
    },
    {
      "id": "cp35:17.1",
      "pali": "Pamādaṁ bhayato disvā,"
    },
    {
      "id": "cp35:17.2",
      "pali": "appamādañca khemato;"
    },
    {
      "id": "cp35:17.3",
      "pali": "Bhāvethaṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "cp35:17.4",
      "pali": "esā buddhānusāsanī."
    },
    {
      "id": "cp35:18.1",
      "pali": "Itthaṁ sudaṁ bhagavā attano pubbacariyaṁ sambhāvayamāno buddhāpadāniyaṁ nāma dhammapariyāyaṁ abhāsitthāti."
    },
    {
      "id": "cp35:19.1",
      "pali": "Cariyāpiṭakaṁ niṭṭhitaṁ."
    }
  ]
}
