{
  "uid": "thig15.1",
  "title": "Isidāsītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig15.1:1.1",
      "pali": "Nagaramhi kusumanāme,"
    },
    {
      "id": "thig15.1:1.2",
      "pali": "Pāṭaliputtamhi pathaviyā maṇḍe;"
    },
    {
      "id": "thig15.1:1.3",
      "pali": "Sakyakulakulīnāyo,"
    },
    {
      "id": "thig15.1:1.4",
      "pali": "Dve bhikkhuniyo hi guṇavatiyo."
    },
    {
      "id": "thig15.1:2.1",
      "pali": "Isidāsī tattha ekā,"
    },
    {
      "id": "thig15.1:2.2",
      "pali": "Dutiyā bodhīti sīlasampannā ca;"
    },
    {
      "id": "thig15.1:2.3",
      "pali": "Jhānajjhāyanaratāyo,"
    },
    {
      "id": "thig15.1:2.4",
      "pali": "Bahussutāyo dhutakilesāyo."
    },
    {
      "id": "thig15.1:3.1",
      "pali": "Tā piṇḍāya caritvā,"
    },
    {
      "id": "thig15.1:3.2",
      "pali": "Bhattatthaṁ kariya dhotapattāyo;"
    },
    {
      "id": "thig15.1:3.3",
      "pali": "Rahitamhi sukhanisinnā,"
    },
    {
      "id": "thig15.1:3.4",
      "pali": "Imā girā abbhudīresuṁ."
    },
    {
      "id": "thig15.1:4.1",
      "pali": "“Pāsādikāsi ayye,"
    },
    {
      "id": "thig15.1:4.2",
      "pali": "Isidāsi vayopi te aparihīno;"
    },
    {
      "id": "thig15.1:4.3",
      "pali": "Kiṁ disvāna byālikaṁ,"
    },
    {
      "id": "thig15.1:4.4",
      "pali": "Athāsi nekkhammamanuyuttā”."
    },
    {
      "id": "thig15.1:5.1",
      "pali": "Evamanuyuñjiyamānā sā,"
    },
    {
      "id": "thig15.1:5.2",
      "pali": "Rahite dhammadesanākusalā;"
    },
    {
      "id": "thig15.1:5.3",
      "pali": "Isidāsī vacanamabravi,"
    },
    {
      "id": "thig15.1:5.4",
      "pali": "“Suṇa bodhi yathāmhi pabbajitā”."
    },
    {
      "id": "thig15.1:6.1",
      "pali": "“Ujjeniyā puravare,"
    },
    {
      "id": "thig15.1:6.2",
      "pali": "Mayhaṁ pitā sīlasaṁvuto seṭṭhi;"
    },
    {
      "id": "thig15.1:6.3",
      "pali": "Tassamhi ekadhītā,"
    },
    {
      "id": "thig15.1:6.4",
      "pali": "Piyā manāpā ca dayitā ca."
    },
    {
      "id": "thig15.1:7.1",
      "pali": "Atha me sāketato varakā,"
    },
    {
      "id": "thig15.1:7.2",
      "pali": "Āgacchumuttamakulīnā;"
    },
    {
      "id": "thig15.1:7.3",
      "pali": "Seṭṭhī pahūtaratano,"
    },
    {
      "id": "thig15.1:7.4",
      "pali": "Tassa mamaṁ suṇhamadāsi tāto."
    },
    {
      "id": "thig15.1:8.1",
      "pali": "Sassuyā sasurassa ca,"
    },
    {
      "id": "thig15.1:8.2",
      "pali": "Sāyaṁ pātaṁ paṇāmamupagamma;"
    },
    {
      "id": "thig15.1:8.3",
      "pali": "Sirasā karomi pāde,"
    },
    {
      "id": "thig15.1:8.4",
      "pali": "Vandāmi yathāmhi anusiṭṭhā."
    },
    {
      "id": "thig15.1:9.1",
      "pali": "Yā mayhaṁ sāmikassa,"
    },
    {
      "id": "thig15.1:9.2",
      "pali": "Bhaginiyo bhātuno parijano vā;"
    },
    {
      "id": "thig15.1:9.3",
      "pali": "Tamekavarakampi disvā,"
    },
    {
      "id": "thig15.1:9.4",
      "pali": "Ubbiggā āsanaṁ demi."
    },
    {
      "id": "thig15.1:10.1",
      "pali": "Annena ca pānena ca,"
    },
    {
      "id": "thig15.1:10.2",
      "pali": "Khajjena ca yañca tattha sannihitaṁ;"
    },
    {
      "id": "thig15.1:10.3",
      "pali": "Chādemi upanayāmi ca,"
    },
    {
      "id": "thig15.1:10.4",
      "pali": "Demi ca yaṁ yassa patirūpaṁ."
    },
    {
      "id": "thig15.1:11.1",
      "pali": "Kālena upaṭṭhahitvā,"
    },
    {
      "id": "thig15.1:11.2",
      "pali": "Gharaṁ samupagamāmi ummāre;"
    },
    {
      "id": "thig15.1:11.3",
      "pali": "Dhovantī hatthapāde,"
    },
    {
      "id": "thig15.1:11.4",
      "pali": "Pañjalikā sāmikamupemi."
    },
    {
      "id": "thig15.1:12.1",
      "pali": "Kocchaṁ pasādaṁ añjaniñca,"
    },
    {
      "id": "thig15.1:12.2",
      "pali": "Ādāsakañca gaṇhitvā;"
    },
    {
      "id": "thig15.1:12.3",
      "pali": "Parikammakārikā viya,"
    },
    {
      "id": "thig15.1:12.4",
      "pali": "Sayameva patiṁ vibhūsemi."
    },
    {
      "id": "thig15.1:13.1",
      "pali": "Sayameva odanaṁ sādhayāmi,"
    },
    {
      "id": "thig15.1:13.2",
      "pali": "Sayameva bhājanaṁ dhovantī;"
    },
    {
      "id": "thig15.1:13.3",
      "pali": "Mātāva ekaputtakaṁ,"
    },
    {
      "id": "thig15.1:13.4",
      "pali": "Tathā bhattāraṁ paricarāmi."
    },
    {
      "id": "thig15.1:14.1",
      "pali": "Evaṁ maṁ bhattikataṁ,"
    },
    {
      "id": "thig15.1:14.2",
      "pali": "Anurattaṁ kārikaṁ nihatamānaṁ;"
    },
    {
      "id": "thig15.1:14.3",
      "pali": "Uṭṭhāyikaṁ analasaṁ,"
    },
    {
      "id": "thig15.1:14.4",
      "pali": "Sīlavatiṁ dussate bhattā."
    },
    {
      "id": "thig15.1:15.1",
      "pali": "So mātarañca pitarañca,"
    },
    {
      "id": "thig15.1:15.2",
      "pali": "Bhaṇati ‘āpucchahaṁ gamissāmi;"
    },
    {
      "id": "thig15.1:15.3",
      "pali": "Isidāsiyā na saha vacchaṁ,"
    },
    {
      "id": "thig15.1:15.4",
      "pali": "Ekāgārehaṁ saha vatthuṁ’."
    },
    {
      "id": "thig15.1:16.1",
      "pali": "‘Mā evaṁ putta avaca,"
    },
    {
      "id": "thig15.1:16.2",
      "pali": "Isidāsī paṇḍitā paribyattā;"
    },
    {
      "id": "thig15.1:16.3",
      "pali": "Uṭṭhāyikā analasā,"
    },
    {
      "id": "thig15.1:16.4",
      "pali": "Kiṁ tuyhaṁ na rocate putta’."
    },
    {
      "id": "thig15.1:17.1",
      "pali": "‘Na ca me hiṁsati kiñci,"
    },
    {
      "id": "thig15.1:17.2",
      "pali": "Na cahaṁ isidāsiyā saha vacchaṁ;"
    },
    {
      "id": "thig15.1:17.3",
      "pali": "Dessāva me alaṁ me,"
    },
    {
      "id": "thig15.1:17.4",
      "pali": "Apucchāhaṁ gamissāmi’."
    },
    {
      "id": "thig15.1:18.1",
      "pali": "Tassa vacanaṁ suṇitvā,"
    },
    {
      "id": "thig15.1:18.2",
      "pali": "Sassu sasuro ca maṁ apucchiṁsu;"
    },
    {
      "id": "thig15.1:18.3",
      "pali": "‘Kissa tayā aparaddhaṁ,"
    },
    {
      "id": "thig15.1:18.4",
      "pali": "Bhaṇa vissaṭṭhā yathābhūtaṁ’."
    },
    {
      "id": "thig15.1:19.1",
      "pali": "‘Napihaṁ aparajjhaṁ kiñci,"
    },
    {
      "id": "thig15.1:19.2",
      "pali": "Napi hiṁsemi na bhaṇāmi dubbacanaṁ;"
    },
    {
      "id": "thig15.1:19.3",
      "pali": "Kiṁ sakkā kātuyye,"
    },
    {
      "id": "thig15.1:19.4",
      "pali": "Yaṁ maṁ viddessate bhattā’."
    },
    {
      "id": "thig15.1:20.1",
      "pali": "Te maṁ pitugharaṁ paṭinayiṁsu,"
    },
    {
      "id": "thig15.1:20.2",
      "pali": "Vimanā dukhena adhibhūtā;"
    },
    {
      "id": "thig15.1:20.3",
      "pali": "Puttamanurakkhamānā,"
    },
    {
      "id": "thig15.1:20.4",
      "pali": "‘Jitāmhase rūpiniṁ lakkhiṁ’."
    },
    {
      "id": "thig15.1:21.1",
      "pali": "Atha maṁ adāsi tāto,"
    },
    {
      "id": "thig15.1:21.2",
      "pali": "Aḍḍhassa gharamhi dutiyakulikassa;"
    },
    {
      "id": "thig15.1:21.3",
      "pali": "Tato upaḍḍhasuṅkena,"
    },
    {
      "id": "thig15.1:21.4",
      "pali": "Yena maṁ vindatha seṭṭhi."
    },
    {
      "id": "thig15.1:22.1",
      "pali": "Tassapi gharamhi māsaṁ,"
    },
    {
      "id": "thig15.1:22.2",
      "pali": "Avasiṁ atha sopi maṁ paṭiccharayi;"
    },
    {
      "id": "thig15.1:22.3",
      "pali": "Dāsīva upaṭṭhahantiṁ,"
    },
    {
      "id": "thig15.1:22.4",
      "pali": "Adūsikaṁ sīlasampannaṁ."
    },
    {
      "id": "thig15.1:23.1",
      "pali": "Bhikkhāya ca vicarantaṁ,"
    },
    {
      "id": "thig15.1:23.2",
      "pali": "Damakaṁ dantaṁ me pitā bhaṇati;"
    },
    {
      "id": "thig15.1:23.3",
      "pali": "‘Hohisi me jāmātā,"
    },
    {
      "id": "thig15.1:23.4",
      "pali": "Nikkhipa poṭṭhiñca ghaṭikañca’."
    },
    {
      "id": "thig15.1:24.1",
      "pali": "Sopi vasitvā pakkhaṁ,"
    },
    {
      "id": "thig15.1:24.2",
      "pali": "Atha tātaṁ bhaṇati ‘dehi me poṭṭhiṁ;"
    },
    {
      "id": "thig15.1:24.3",
      "pali": "Ghaṭikañca mallakañca,"
    },
    {
      "id": "thig15.1:24.4",
      "pali": "Punapi bhikkhaṁ carissāmi’."
    },
    {
      "id": "thig15.1:25.1",
      "pali": "Atha naṁ bhaṇatī tāto,"
    },
    {
      "id": "thig15.1:25.2",
      "pali": "Ammā sabbo ca me ñātigaṇavaggo;"
    },
    {
      "id": "thig15.1:25.3",
      "pali": "‘Kiṁ te na kīrati idha,"
    },
    {
      "id": "thig15.1:25.4",
      "pali": "Bhaṇa khippaṁ taṁ te karihi’ti."
    },
    {
      "id": "thig15.1:26.1",
      "pali": "Evaṁ bhaṇito bhaṇati,"
    },
    {
      "id": "thig15.1:26.2",
      "pali": "‘Yadi me attā sakkoti alaṁ mayhaṁ;"
    },
    {
      "id": "thig15.1:26.3",
      "pali": "Isidāsiyā na saha vacchaṁ,"
    },
    {
      "id": "thig15.1:26.4",
      "pali": "Ekagharehaṁ saha vatthuṁ’."
    },
    {
      "id": "thig15.1:27.1",
      "pali": "Vissajjito gato so,"
    },
    {
      "id": "thig15.1:27.2",
      "pali": "Ahampi ekākinī vicintemi;"
    },
    {
      "id": "thig15.1:27.3",
      "pali": "‘Āpucchitūna gacchaṁ,"
    },
    {
      "id": "thig15.1:27.4",
      "pali": "Marituye vā pabbajissaṁ vā’."
    },
    {
      "id": "thig15.1:28.1",
      "pali": "Atha ayyā jinadattā,"
    },
    {
      "id": "thig15.1:28.2",
      "pali": "Āgacchī gocarāya caramānā;"
    },
    {
      "id": "thig15.1:28.3",
      "pali": "Tātakulaṁ vinayadharī,"
    },
    {
      "id": "thig15.1:28.4",
      "pali": "Bahussutā sīlasampannā."
    },
    {
      "id": "thig15.1:29.1",
      "pali": "Taṁ disvāna amhākaṁ,"
    },
    {
      "id": "thig15.1:29.2",
      "pali": "Uṭṭhāyāsanaṁ tassā paññāpayiṁ;"
    },
    {
      "id": "thig15.1:29.3",
      "pali": "Nisinnāya ca pāde,"
    },
    {
      "id": "thig15.1:29.4",
      "pali": "Vanditvā bhojanamadāsiṁ."
    },
    {
      "id": "thig15.1:30.1",
      "pali": "Annena ca pānena ca,"
    },
    {
      "id": "thig15.1:30.2",
      "pali": "Khajjena ca yañca tattha sannihitaṁ;"
    },
    {
      "id": "thig15.1:30.3",
      "pali": "Santappayitvā avacaṁ,"
    },
    {
      "id": "thig15.1:30.4",
      "pali": "‘Ayye icchāmi pabbajituṁ’."
    },
    {
      "id": "thig15.1:31.1",
      "pali": "Atha maṁ bhaṇatī tāto,"
    },
    {
      "id": "thig15.1:31.2",
      "pali": "‘Idheva puttaka carāhi tvaṁ dhammaṁ;"
    },
    {
      "id": "thig15.1:31.3",
      "pali": "Annena ca pānena ca,"
    },
    {
      "id": "thig15.1:31.4",
      "pali": "Tappaya samaṇe dvijātī ca’."
    },
    {
      "id": "thig15.1:32.1",
      "pali": "Athahaṁ bhaṇāmi tātaṁ,"
    },
    {
      "id": "thig15.1:32.2",
      "pali": "Rodantī añjaliṁ paṇāmetvā;"
    },
    {
      "id": "thig15.1:32.3",
      "pali": "‘Pāpañhi mayā pakataṁ,"
    },
    {
      "id": "thig15.1:32.4",
      "pali": "Kammaṁ taṁ nijjaressāmi’."
    },
    {
      "id": "thig15.1:33.1",
      "pali": "Atha maṁ bhaṇatī tāto,"
    },
    {
      "id": "thig15.1:33.2",
      "pali": "‘Pāpuṇa bodhiñca aggadhammañca;"
    },
    {
      "id": "thig15.1:33.3",
      "pali": "Nibbānañca labhassu,"
    },
    {
      "id": "thig15.1:33.4",
      "pali": "Yaṁ sacchikarī dvipadaseṭṭho’."
    },
    {
      "id": "thig15.1:34.1",
      "pali": "Mātāpitū abhivādayitvā,"
    },
    {
      "id": "thig15.1:34.2",
      "pali": "Sabbañca ñātigaṇavaggaṁ;"
    },
    {
      "id": "thig15.1:34.3",
      "pali": "Sattāhaṁ pabbajitā,"
    },
    {
      "id": "thig15.1:34.4",
      "pali": "Tisso vijjā aphassayiṁ."
    },
    {
      "id": "thig15.1:35.1",
      "pali": "Jānāmi attano satta,"
    },
    {
      "id": "thig15.1:35.2",
      "pali": "Jātiyo yassayaṁ phalavipāko;"
    },
    {
      "id": "thig15.1:35.3",
      "pali": "Taṁ tava ācikkhissaṁ,"
    },
    {
      "id": "thig15.1:35.4",
      "pali": "Taṁ ekamanā nisāmehi."
    },
    {
      "id": "thig15.1:36.1",
      "pali": "Nagaramhi erakacche,"
    },
    {
      "id": "thig15.1:36.2",
      "pali": "Suvaṇṇakāro ahaṁ pahūtadhano;"
    },
    {
      "id": "thig15.1:36.3",
      "pali": "Yobbanamadena matto,"
    },
    {
      "id": "thig15.1:36.4",
      "pali": "So paradāraṁ asevihaṁ."
    },
    {
      "id": "thig15.1:37.1",
      "pali": "Sohaṁ tato cavitvā,"
    },
    {
      "id": "thig15.1:37.2",
      "pali": "Nirayamhi apaccisaṁ ciraṁ;"
    },
    {
      "id": "thig15.1:37.3",
      "pali": "Pakko tato ca uṭṭhahitvā,"
    },
    {
      "id": "thig15.1:37.4",
      "pali": "Makkaṭiyā kucchimokkamiṁ."
    },
    {
      "id": "thig15.1:38.1",
      "pali": "Sattāhajātakaṁ maṁ,"
    },
    {
      "id": "thig15.1:38.2",
      "pali": "Mahākapi yūthapo nillacchesi;"
    },
    {
      "id": "thig15.1:38.3",
      "pali": "Tassetaṁ kammaphalaṁ,"
    },
    {
      "id": "thig15.1:38.4",
      "pali": "Yathāpi gantvāna paradāraṁ."
    },
    {
      "id": "thig15.1:39.1",
      "pali": "Sohaṁ tato cavitvā,"
    },
    {
      "id": "thig15.1:39.2",
      "pali": "Kālaṁ karitvā sindhavāraññe;"
    },
    {
      "id": "thig15.1:39.3",
      "pali": "Kāṇāya ca khañjāya ca,"
    },
    {
      "id": "thig15.1:39.4",
      "pali": "Eḷakiyā kucchimokkamiṁ."
    },
    {
      "id": "thig15.1:40.1",
      "pali": "Dvādasa vassāni ahaṁ,"
    },
    {
      "id": "thig15.1:40.2",
      "pali": "Nillacchito dārake parivahitvā;"
    },
    {
      "id": "thig15.1:40.3",
      "pali": "Kimināvaṭṭo akallo,"
    },
    {
      "id": "thig15.1:40.4",
      "pali": "Yathāpi gantvāna paradāraṁ."
    },
    {
      "id": "thig15.1:41.1",
      "pali": "Sohaṁ tato cavitvā,"
    },
    {
      "id": "thig15.1:41.2",
      "pali": "Govāṇijakassa gāviyā jāto;"
    },
    {
      "id": "thig15.1:41.3",
      "pali": "Vaccho lākhātambo,"
    },
    {
      "id": "thig15.1:41.4",
      "pali": "Nillacchito dvādase māse."
    },
    {
      "id": "thig15.1:42.1",
      "pali": "Voḍhūna naṅgalamahaṁ,"
    },
    {
      "id": "thig15.1:42.2",
      "pali": "Sakaṭañca dhārayāmi;"
    },
    {
      "id": "thig15.1:42.3",
      "pali": "Andhovaṭṭo akallo,"
    },
    {
      "id": "thig15.1:42.4",
      "pali": "Yathāpi gantvāna paradāraṁ."
    },
    {
      "id": "thig15.1:43.1",
      "pali": "Sohaṁ tato cavitvā,"
    },
    {
      "id": "thig15.1:43.2",
      "pali": "Vīthiyā dāsiyā ghare jāto;"
    },
    {
      "id": "thig15.1:43.3",
      "pali": "Neva mahilā na puriso,"
    },
    {
      "id": "thig15.1:43.4",
      "pali": "Yathāpi gantvāna paradāraṁ."
    },
    {
      "id": "thig15.1:44.1",
      "pali": "Tiṁsativassamhi mato,"
    },
    {
      "id": "thig15.1:44.2",
      "pali": "Sākaṭikakulamhi dārikā jātā;"
    },
    {
      "id": "thig15.1:44.3",
      "pali": "Kapaṇamhi appabhoge,"
    },
    {
      "id": "thig15.1:44.4",
      "pali": "Dhanika purisapātabahulamhi."
    },
    {
      "id": "thig15.1:45.1",
      "pali": "Taṁ maṁ tato satthavāho,"
    },
    {
      "id": "thig15.1:45.2",
      "pali": "Ussannāya vipulāya vaḍḍhiyā;"
    },
    {
      "id": "thig15.1:45.3",
      "pali": "Okaḍḍhati vilapantiṁ,"
    },
    {
      "id": "thig15.1:45.4",
      "pali": "Acchinditvā kulagharasmā."
    },
    {
      "id": "thig15.1:46.1",
      "pali": "Atha soḷasame vasse,"
    },
    {
      "id": "thig15.1:46.2",
      "pali": "Disvā maṁ pattayobbanaṁ kaññaṁ;"
    },
    {
      "id": "thig15.1:46.3",
      "pali": "Orundhatassa putto,"
    },
    {
      "id": "thig15.1:46.4",
      "pali": "Giridāso nāma nāmena."
    },
    {
      "id": "thig15.1:47.1",
      "pali": "Tassapi aññā bhariyā,"
    },
    {
      "id": "thig15.1:47.2",
      "pali": "Sīlavatī guṇavatī yasavatī ca;"
    },
    {
      "id": "thig15.1:47.3",
      "pali": "Anurattā bhattāraṁ,"
    },
    {
      "id": "thig15.1:47.4",
      "pali": "Tassāhaṁ viddesanamakāsiṁ."
    },
    {
      "id": "thig15.1:48.1",
      "pali": "Tassetaṁ kammaphalaṁ,"
    },
    {
      "id": "thig15.1:48.2",
      "pali": "Yaṁ maṁ apakīritūna gacchanti;"
    },
    {
      "id": "thig15.1:48.3",
      "pali": "Dāsīva upaṭṭhahantiṁ,"
    },
    {
      "id": "thig15.1:48.4",
      "pali": "Tassapi anto kato mayā”ti."
    },
    {
      "id": "thig15.1:49.1",
      "pali": "… Isidāsī therī …."
    },
    {
      "id": "thig15.1:50.1",
      "pali": "Cattālīsanipāto niṭṭhito."
    }
  ]
}
