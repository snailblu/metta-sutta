{
  "uid": "thi-ap3",
  "title": "Maṇḍapadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap3:1.1",
      "pali": "“Koṇāgamanabuddhassa,"
    },
    {
      "id": "thi-ap3:1.2",
      "pali": "maṇḍapo kārito mayā;"
    },
    {
      "id": "thi-ap3:1.3",
      "pali": "Dhuvaṁ ticīvaraṁdāsiṁ,"
    },
    {
      "id": "thi-ap3:1.4",
      "pali": "buddhassa lokabandhuno."
    },
    {
      "id": "thi-ap3:2.1",
      "pali": "Yaṁ yaṁ janapadaṁ yāmi,"
    },
    {
      "id": "thi-ap3:2.2",
      "pali": "nigame rājadhāniyo;"
    },
    {
      "id": "thi-ap3:2.3",
      "pali": "Sabbattha pūjitā homi,"
    },
    {
      "id": "thi-ap3:2.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap3:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap3:3.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap3:3.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap3:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap3:4.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap3:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap3:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap3:5.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap3:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap3:6.1",
      "pali": "Itthaṁ sudaṁ maṇḍapadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap3:7.1",
      "pali": "Maṇḍapadāyikātheriyāpadānaṁ tatiyaṁ."
    }
  ]
}
