{
  "uid": "tha-ap196",
  "title": "Asokapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap196:1.1",
      "pali": "“Tivarāyaṁ pure ramme,"
    },
    {
      "id": "tha-ap196:1.2",
      "pali": "rājuyyānaṁ ahu tadā;"
    },
    {
      "id": "tha-ap196:1.3",
      "pali": "Uyyānapālo tatthāsiṁ,"
    },
    {
      "id": "tha-ap196:1.4",
      "pali": "rañño baddhacaro ahaṁ."
    },
    {
      "id": "tha-ap196:2.1",
      "pali": "Padumo nāma nāmena,"
    },
    {
      "id": "tha-ap196:2.2",
      "pali": "sayambhū sappabho ahu;"
    },
    {
      "id": "tha-ap196:2.3",
      "pali": "Nisinnaṁ puṇḍarīkamhi,"
    },
    {
      "id": "tha-ap196:2.4",
      "pali": "chāyā na jahi taṁ muniṁ."
    },
    {
      "id": "tha-ap196:3.1",
      "pali": "Asokaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap196:3.2",
      "pali": "piṇḍibhāraṁ sudassanaṁ;"
    },
    {
      "id": "tha-ap196:3.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap196:3.4",
      "pali": "jalajuttamanāmino."
    },
    {
      "id": "tha-ap196:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap196:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap196:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap196:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap196:5.1",
      "pali": "Sattatiṁsamhito kappe,"
    },
    {
      "id": "tha-ap196:5.2",
      "pali": "soḷasa araṇañjahā;"
    },
    {
      "id": "tha-ap196:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap196:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap196:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap196:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap196:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap196:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā asokapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap196:8.1",
      "pali": "Asokapūjakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
