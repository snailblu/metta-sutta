{
  "uid": "ja534",
  "title": "Cūḷahaṁsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja534:1.1",
      "pali": "“Ete haṁsā pakkamanti,"
    },
    {
      "id": "ja534:1.2",
      "pali": "vakkaṅgā bhayameritā;"
    },
    {
      "id": "ja534:1.3",
      "pali": "Harittaca hemavaṇṇa,"
    },
    {
      "id": "ja534:1.4",
      "pali": "kāmaṁ sumukha pakkama."
    },
    {
      "id": "ja534:2.1",
      "pali": "Ohāya maṁ ñātigaṇā,"
    },
    {
      "id": "ja534:2.2",
      "pali": "ekaṁ pāsavasaṁ gataṁ;"
    },
    {
      "id": "ja534:2.3",
      "pali": "Anapekkhamānā gacchanti,"
    },
    {
      "id": "ja534:2.4",
      "pali": "kiṁ eko avahīyasi."
    },
    {
      "id": "ja534:3.1",
      "pali": "Pateva patataṁ seṭṭha,"
    },
    {
      "id": "ja534:3.2",
      "pali": "natthi baddhe sahāyatā;"
    },
    {
      "id": "ja534:3.3",
      "pali": "Mā anīghāya hāpesi,"
    },
    {
      "id": "ja534:3.4",
      "pali": "kāmaṁ sumukha pakkama”."
    },
    {
      "id": "ja534:4.1",
      "pali": "“Nāhaṁ dukkhaparetopi,"
    },
    {
      "id": "ja534:4.2",
      "pali": "dhataraṭṭha tuvaṁ jahe;"
    },
    {
      "id": "ja534:4.3",
      "pali": "Jīvitaṁ maraṇaṁ vā me,"
    },
    {
      "id": "ja534:4.4",
      "pali": "tayā saddhiṁ bhavissati."
    },
    {
      "id": "ja534:5.1",
      "pali": "Nāhaṁ dukkhaparetopi,"
    },
    {
      "id": "ja534:5.2",
      "pali": "dhataraṭṭha tuvaṁ jahe;"
    },
    {
      "id": "ja534:5.3",
      "pali": "Na maṁ anariyasaṁyutte,"
    },
    {
      "id": "ja534:5.4",
      "pali": "kamme yojetumarahasi."
    },
    {
      "id": "ja534:6.1",
      "pali": "Sakumāro sakhā tyasmi,"
    },
    {
      "id": "ja534:6.2",
      "pali": "sacitte casmi te ṭhito;"
    },
    {
      "id": "ja534:6.3",
      "pali": "Ñāto senāpati tyāhaṁ,"
    },
    {
      "id": "ja534:6.4",
      "pali": "haṁsānaṁ pavaruttama."
    },
    {
      "id": "ja534:7.1",
      "pali": "Kathaṁ ahaṁ vikatthissaṁ,"
    },
    {
      "id": "ja534:7.2",
      "pali": "ñātimajjhe ito gato;"
    },
    {
      "id": "ja534:7.3",
      "pali": "Taṁ hitvā patataṁ seṭṭha,"
    },
    {
      "id": "ja534:7.4",
      "pali": "kiṁ te vakkhāmito gato;"
    },
    {
      "id": "ja534:7.5",
      "pali": "Idha pāṇaṁ cajissāmi,"
    },
    {
      "id": "ja534:7.6",
      "pali": "nānariyaṁ kattumussahe”."
    },
    {
      "id": "ja534:8.1",
      "pali": "“Eso hi dhammo sumukha,"
    },
    {
      "id": "ja534:8.2",
      "pali": "yaṁ tvaṁ ariyapathe ṭhito;"
    },
    {
      "id": "ja534:8.3",
      "pali": "Yo bhattāraṁ sakhāraṁ maṁ,"
    },
    {
      "id": "ja534:8.4",
      "pali": "na pariccattumussahe."
    },
    {
      "id": "ja534:9.1",
      "pali": "Tañhi me pekkhamānassa,"
    },
    {
      "id": "ja534:9.2",
      "pali": "bhayaṁ na tveva jāyati;"
    },
    {
      "id": "ja534:9.3",
      "pali": "Adhigacchasi tvaṁ mayhaṁ,"
    },
    {
      "id": "ja534:9.4",
      "pali": "evaṁ bhūtassa jīvitaṁ”."
    },
    {
      "id": "ja534:10.1",
      "pali": "Iccevaṁ mantayantānaṁ,"
    },
    {
      "id": "ja534:10.2",
      "pali": "Ariyānaṁ ariyavuttinaṁ;"
    },
    {
      "id": "ja534:10.3",
      "pali": "Daṇḍamādāya nesādo,"
    },
    {
      "id": "ja534:10.4",
      "pali": "Āpatī turito bhusaṁ."
    },
    {
      "id": "ja534:11.1",
      "pali": "Tamāpatantaṁ disvāna,"
    },
    {
      "id": "ja534:11.2",
      "pali": "Sumukho atibrūhayi;"
    },
    {
      "id": "ja534:11.3",
      "pali": "Aṭṭhāsi purato rañño,"
    },
    {
      "id": "ja534:11.4",
      "pali": "Haṁso vissāsayaṁ byathaṁ."
    },
    {
      "id": "ja534:12.1",
      "pali": "“Mā bhāyi patataṁ seṭṭha,"
    },
    {
      "id": "ja534:12.2",
      "pali": "na hi bhāyanti tādisā;"
    },
    {
      "id": "ja534:12.3",
      "pali": "Ahaṁ yogaṁ payuñjissaṁ,"
    },
    {
      "id": "ja534:12.4",
      "pali": "yuttaṁ dhammūpasaṁhitaṁ;"
    },
    {
      "id": "ja534:12.5",
      "pali": "Tena pariyāpadānena,"
    },
    {
      "id": "ja534:12.6",
      "pali": "khippaṁ pāsā pamokkhasi”."
    },
    {
      "id": "ja534:13.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja534:13.2",
      "pali": "sumukhassa subhāsitaṁ;"
    },
    {
      "id": "ja534:13.3",
      "pali": "Pahaṭṭhalomo nesādo,"
    },
    {
      "id": "ja534:13.4",
      "pali": "añjalissa paṇāmayi."
    },
    {
      "id": "ja534:14.1",
      "pali": "“Na me sutaṁ vā diṭṭhaṁ vā,"
    },
    {
      "id": "ja534:14.2",
      "pali": "bhāsanto mānusiṁ dijo;"
    },
    {
      "id": "ja534:14.3",
      "pali": "Ariyaṁ bruvāno vakkaṅgo,"
    },
    {
      "id": "ja534:14.4",
      "pali": "cajanto mānusiṁ giraṁ."
    },
    {
      "id": "ja534:15.1",
      "pali": "Kiṁ nu tāyaṁ dijo hoti,"
    },
    {
      "id": "ja534:15.2",
      "pali": "mutto baddhaṁ upāsasi;"
    },
    {
      "id": "ja534:15.3",
      "pali": "Ohāya sakuṇā yanti,"
    },
    {
      "id": "ja534:15.4",
      "pali": "kiṁ eko avahīyasi”."
    },
    {
      "id": "ja534:16.1",
      "pali": "“Rājā me so dijāmitta,"
    },
    {
      "id": "ja534:16.2",
      "pali": "senāpaccassa kārayiṁ;"
    },
    {
      "id": "ja534:16.3",
      "pali": "Tamāpade pariccattuṁ,"
    },
    {
      "id": "ja534:16.4",
      "pali": "nussahe vihagādhipaṁ."
    },
    {
      "id": "ja534:17.1",
      "pali": "Mahāgaṇāya bhattā me,"
    },
    {
      "id": "ja534:17.2",
      "pali": "mā eko byasanaṁ agā;"
    },
    {
      "id": "ja534:17.3",
      "pali": "Tathā taṁ samma nesāda,"
    },
    {
      "id": "ja534:17.4",
      "pali": "bhattāyaṁ abhito rame”."
    },
    {
      "id": "ja534:18.1",
      "pali": "“Ariyavattasi vakkaṅga,"
    },
    {
      "id": "ja534:18.2",
      "pali": "yo piṇḍamapacāyasi;"
    },
    {
      "id": "ja534:18.3",
      "pali": "Cajāmi te taṁ bhattāraṁ,"
    },
    {
      "id": "ja534:18.4",
      "pali": "gacchathūbho yathāsukhaṁ”."
    },
    {
      "id": "ja534:19.1",
      "pali": "“Sace attappayogena,"
    },
    {
      "id": "ja534:19.2",
      "pali": "ohito haṁsapakkhinaṁ;"
    },
    {
      "id": "ja534:19.3",
      "pali": "Paṭigaṇhāma te samma,"
    },
    {
      "id": "ja534:19.4",
      "pali": "etaṁ abhayadakkhiṇaṁ."
    },
    {
      "id": "ja534:20.1",
      "pali": "No ce attappayogena,"
    },
    {
      "id": "ja534:20.2",
      "pali": "ohito haṁsapakkhinaṁ;"
    },
    {
      "id": "ja534:20.3",
      "pali": "Anissaro muñcamamhe,"
    },
    {
      "id": "ja534:20.4",
      "pali": "theyyaṁ kayirāsi luddaka”."
    },
    {
      "id": "ja534:21.1",
      "pali": "“Yassa tvaṁ bhatako rañño,"
    },
    {
      "id": "ja534:21.2",
      "pali": "kāmaṁ tasseva pāpaya;"
    },
    {
      "id": "ja534:21.3",
      "pali": "Tattha saṁyamano rājā,"
    },
    {
      "id": "ja534:21.4",
      "pali": "yathābhiññaṁ karissati”."
    },
    {
      "id": "ja534:22.1",
      "pali": "Iccevaṁ vutto nesādo,"
    },
    {
      "id": "ja534:22.2",
      "pali": "hemavaṇṇe harittace;"
    },
    {
      "id": "ja534:22.3",
      "pali": "Ubho hatthehi saṅgayha,"
    },
    {
      "id": "ja534:22.4",
      "pali": "pañjare ajjhavodahi."
    },
    {
      "id": "ja534:23.1",
      "pali": "Te pañjaragate pakkhī,"
    },
    {
      "id": "ja534:23.2",
      "pali": "ubho bhassaravaṇṇine;"
    },
    {
      "id": "ja534:23.3",
      "pali": "Sumukhaṁ dhataraṭṭhañca,"
    },
    {
      "id": "ja534:23.4",
      "pali": "luddo ādāya pakkami."
    },
    {
      "id": "ja534:24.1",
      "pali": "Harīyamāno dhataraṭṭho,"
    },
    {
      "id": "ja534:24.2",
      "pali": "sumukhaṁ etadabravi;"
    },
    {
      "id": "ja534:24.3",
      "pali": "“Bāḷhaṁ bhāyāmi sumukha,"
    },
    {
      "id": "ja534:24.4",
      "pali": "sāmāya lakkhaṇūruyā;"
    },
    {
      "id": "ja534:24.5",
      "pali": "Asmākaṁ vadhamaññāya,"
    },
    {
      "id": "ja534:24.6",
      "pali": "athattānaṁ vadhissati."
    },
    {
      "id": "ja534:25.1",
      "pali": "Pākahaṁsā ca sumukha,"
    },
    {
      "id": "ja534:25.2",
      "pali": "suhemā hemasuttacā;"
    },
    {
      "id": "ja534:25.3",
      "pali": "Koñcī samuddatīreva,"
    },
    {
      "id": "ja534:25.4",
      "pali": "kapaṇā nūna rucchati”."
    },
    {
      "id": "ja534:26.1",
      "pali": "“Evaṁ mahanto lokassa,"
    },
    {
      "id": "ja534:26.2",
      "pali": "appameyyo mahāgaṇī;"
    },
    {
      "id": "ja534:26.3",
      "pali": "Ekitthimanusoceyya,"
    },
    {
      "id": "ja534:26.4",
      "pali": "nayidaṁ paññavatāmiva."
    },
    {
      "id": "ja534:27.1",
      "pali": "Vātova gandhamādeti,"
    },
    {
      "id": "ja534:27.2",
      "pali": "ubhayaṁ chekapāpakaṁ;"
    },
    {
      "id": "ja534:27.3",
      "pali": "Bālo āmakapakkaṁva,"
    },
    {
      "id": "ja534:27.4",
      "pali": "lolo andhova āmisaṁ."
    },
    {
      "id": "ja534:28.1",
      "pali": "Avinicchayaññu atthesu,"
    },
    {
      "id": "ja534:28.2",
      "pali": "mandova paṭibhāsi maṁ;"
    },
    {
      "id": "ja534:28.3",
      "pali": "Kiccākiccaṁ na jānāsi,"
    },
    {
      "id": "ja534:28.4",
      "pali": "sampatto kālapariyāyaṁ."
    },
    {
      "id": "ja534:29.1",
      "pali": "Aḍḍhummatto udīresi,"
    },
    {
      "id": "ja534:29.2",
      "pali": "yo seyyā maññasitthiyo;"
    },
    {
      "id": "ja534:29.3",
      "pali": "Bahusādhāraṇā hetā,"
    },
    {
      "id": "ja534:29.4",
      "pali": "soṇḍānaṁva surāgharaṁ."
    },
    {
      "id": "ja534:30.1",
      "pali": "Māyā cesā marīcī ca,"
    },
    {
      "id": "ja534:30.2",
      "pali": "soko rogo cupaddavo;"
    },
    {
      "id": "ja534:30.3",
      "pali": "Kharā ca bandhanā cetā,"
    },
    {
      "id": "ja534:30.4",
      "pali": "maccupāsā guhāsayā;"
    },
    {
      "id": "ja534:30.5",
      "pali": "Tāsu yo vissase poso,"
    },
    {
      "id": "ja534:30.6",
      "pali": "so naresu narādhamo”."
    },
    {
      "id": "ja534:31.1",
      "pali": "“Yaṁ vuddhehi upaññātaṁ,"
    },
    {
      "id": "ja534:31.2",
      "pali": "ko taṁ ninditumarahati;"
    },
    {
      "id": "ja534:31.3",
      "pali": "Mahābhūtitthiyo nāma,"
    },
    {
      "id": "ja534:31.4",
      "pali": "lokasmiṁ udapajjisuṁ."
    },
    {
      "id": "ja534:32.1",
      "pali": "Khiḍḍā paṇihitā tyāsu,"
    },
    {
      "id": "ja534:32.2",
      "pali": "rati tyāsu patiṭṭhitā;"
    },
    {
      "id": "ja534:32.3",
      "pali": "Bījāni tyāsu rūhanti,"
    },
    {
      "id": "ja534:32.4",
      "pali": "yadidaṁ sattā pajāyare;"
    },
    {
      "id": "ja534:32.5",
      "pali": "Tāsu ko nibbide poso,"
    },
    {
      "id": "ja534:32.6",
      "pali": "pāṇamāsajja pāṇibhi."
    },
    {
      "id": "ja534:33.1",
      "pali": "Tvameva nañño sumukha,"
    },
    {
      "id": "ja534:33.2",
      "pali": "thīnaṁ atthesu yuñjasi;"
    },
    {
      "id": "ja534:33.3",
      "pali": "Tassa tyajja bhaye jāte,"
    },
    {
      "id": "ja534:33.4",
      "pali": "bhītena jāyate mati."
    },
    {
      "id": "ja534:34.1",
      "pali": "Sabbo hi saṁsayaṁ patto,"
    },
    {
      "id": "ja534:34.2",
      "pali": "bhayaṁ bhīru titikkhati;"
    },
    {
      "id": "ja534:34.3",
      "pali": "Paṇḍitā ca mahantāno,"
    },
    {
      "id": "ja534:34.4",
      "pali": "atthe yuñjanti duyyuje."
    },
    {
      "id": "ja534:35.1",
      "pali": "Etadatthāya rājāno,"
    },
    {
      "id": "ja534:35.2",
      "pali": "sūramicchanti mantinaṁ;"
    },
    {
      "id": "ja534:35.3",
      "pali": "Paṭibāhati yaṁ sūro,"
    },
    {
      "id": "ja534:35.4",
      "pali": "āpadaṁ attapariyāyaṁ."
    },
    {
      "id": "ja534:36.1",
      "pali": "Mā no ajja vikantiṁsu,"
    },
    {
      "id": "ja534:36.2",
      "pali": "rañño sūdā mahānase;"
    },
    {
      "id": "ja534:36.3",
      "pali": "Tathā hi vaṇṇo pattānaṁ,"
    },
    {
      "id": "ja534:36.4",
      "pali": "phalaṁ veḷuṁva taṁ vadhi."
    },
    {
      "id": "ja534:37.1",
      "pali": "Muttopi na icchi uḍḍetuṁ,"
    },
    {
      "id": "ja534:37.2",
      "pali": "Sayaṁ bandhaṁ upāgami;"
    },
    {
      "id": "ja534:37.3",
      "pali": "Sopajja saṁsayaṁ patto,"
    },
    {
      "id": "ja534:37.4",
      "pali": "Atthaṁ gaṇhāhi mā mukhaṁ."
    },
    {
      "id": "ja534:38.1",
      "pali": "So taṁ yogaṁ payuñjassu,"
    },
    {
      "id": "ja534:38.2",
      "pali": "yuttaṁ dhammūpasaṁhitaṁ;"
    },
    {
      "id": "ja534:38.3",
      "pali": "Tava pariyāpadānena,"
    },
    {
      "id": "ja534:38.4",
      "pali": "mama pāṇesanaṁ cara”."
    },
    {
      "id": "ja534:39.1",
      "pali": "“Mā bhāyi patataṁ seṭṭha,"
    },
    {
      "id": "ja534:39.2",
      "pali": "na hi bhāyanti tādisā;"
    },
    {
      "id": "ja534:39.3",
      "pali": "Ahaṁ yogaṁ payuñjissaṁ,"
    },
    {
      "id": "ja534:39.4",
      "pali": "yuttaṁ dhammūpasaṁhitaṁ;"
    },
    {
      "id": "ja534:39.5",
      "pali": "Mama pariyāpadānena,"
    },
    {
      "id": "ja534:39.6",
      "pali": "khippaṁ pāsā pamokkhasi”."
    },
    {
      "id": "ja534:40.1",
      "pali": "So luddo haṁsakājena,"
    },
    {
      "id": "ja534:40.2",
      "pali": "rājadvāraṁ upāgami;"
    },
    {
      "id": "ja534:40.3",
      "pali": "“Paṭivedetha maṁ rañño,"
    },
    {
      "id": "ja534:40.4",
      "pali": "dhataraṭṭhāyamāgato”."
    },
    {
      "id": "ja534:41.1",
      "pali": "Te disvā puññasaṅkāse,"
    },
    {
      "id": "ja534:41.2",
      "pali": "ubho lakkhaṇasammate;"
    },
    {
      "id": "ja534:41.3",
      "pali": "Khalu saṁyamano rājā,"
    },
    {
      "id": "ja534:41.4",
      "pali": "amacce ajjhabhāsatha."
    },
    {
      "id": "ja534:42.1",
      "pali": "“Detha luddassa vatthāni,"
    },
    {
      "id": "ja534:42.2",
      "pali": "annaṁ pānañca bhojanaṁ;"
    },
    {
      "id": "ja534:42.3",
      "pali": "Kāmaṅkaro hiraññassa,"
    },
    {
      "id": "ja534:42.4",
      "pali": "yāvanto esa icchati”."
    },
    {
      "id": "ja534:43.1",
      "pali": "Disvā luddaṁ pasannattaṁ,"
    },
    {
      "id": "ja534:43.2",
      "pali": "Kāsirājā tadabravi;"
    },
    {
      "id": "ja534:43.3",
      "pali": "“Yadyāyaṁ samma khemaka,"
    },
    {
      "id": "ja534:43.4",
      "pali": "Puṇṇā haṁsehi tiṭṭhati."
    },
    {
      "id": "ja534:44.1",
      "pali": "Kathaṁ rucimajjhagataṁ,"
    },
    {
      "id": "ja534:44.2",
      "pali": "pāsahattho upāgami;"
    },
    {
      "id": "ja534:44.3",
      "pali": "Okiṇṇaṁ ñātisaṅghehi,"
    },
    {
      "id": "ja534:44.4",
      "pali": "nimmajjhimaṁ kathaṁ gahi”."
    },
    {
      "id": "ja534:45.1",
      "pali": "“Ajja me sattamā ratti,"
    },
    {
      "id": "ja534:45.2",
      "pali": "adanāni upāsato;"
    },
    {
      "id": "ja534:45.3",
      "pali": "Padametassa anvesaṁ,"
    },
    {
      "id": "ja534:45.4",
      "pali": "appamatto ghaṭassito."
    },
    {
      "id": "ja534:46.1",
      "pali": "Athassa padamaddakkhiṁ,"
    },
    {
      "id": "ja534:46.2",
      "pali": "carato adanesanaṁ;"
    },
    {
      "id": "ja534:46.3",
      "pali": "Tatthāhaṁ odahiṁ pāsaṁ,"
    },
    {
      "id": "ja534:46.4",
      "pali": "evaṁ taṁ dijamaggahiṁ”."
    },
    {
      "id": "ja534:47.1",
      "pali": "“Ludda dve ime sakuṇā,"
    },
    {
      "id": "ja534:47.2",
      "pali": "atha ekoti bhāsasi;"
    },
    {
      "id": "ja534:47.3",
      "pali": "Cittaṁ nu te vipariyattaṁ,"
    },
    {
      "id": "ja534:47.4",
      "pali": "adu kiṁ nu jigīsasi”."
    },
    {
      "id": "ja534:48.1",
      "pali": "“Yassa lohitakā tālā,"
    },
    {
      "id": "ja534:48.2",
      "pali": "tapanīyanibhā subhā;"
    },
    {
      "id": "ja534:48.3",
      "pali": "Uraṁ saṁhacca tiṭṭhanti,"
    },
    {
      "id": "ja534:48.4",
      "pali": "so me bandhaṁ upāgami."
    },
    {
      "id": "ja534:49.1",
      "pali": "Athāyaṁ bhassaro pakkhī,"
    },
    {
      "id": "ja534:49.2",
      "pali": "abaddho baddhamāturaṁ;"
    },
    {
      "id": "ja534:49.3",
      "pali": "Ariyaṁ bruvāno aṭṭhāsi,"
    },
    {
      "id": "ja534:49.4",
      "pali": "cajanto mānusiṁ giraṁ”."
    },
    {
      "id": "ja534:50.1",
      "pali": "“Atha kiṁ dāni sumukha,"
    },
    {
      "id": "ja534:50.2",
      "pali": "Hanuṁ saṁhacca tiṭṭhasi;"
    },
    {
      "id": "ja534:50.3",
      "pali": "Adu me parisaṁ patto,"
    },
    {
      "id": "ja534:50.4",
      "pali": "Bhayā bhīto na bhāsasi”."
    },
    {
      "id": "ja534:51.1",
      "pali": "“Nāhaṁ kāsipati bhīto,"
    },
    {
      "id": "ja534:51.2",
      "pali": "ogayha parisaṁ tava;"
    },
    {
      "id": "ja534:51.3",
      "pali": "Nāhaṁ bhayā na bhāsissaṁ,"
    },
    {
      "id": "ja534:51.4",
      "pali": "vākyaṁ atthamhi tādise”."
    },
    {
      "id": "ja534:52.1",
      "pali": "“Na te abhisaraṁ passe,"
    },
    {
      "id": "ja534:52.2",
      "pali": "na rathe napi pattike;"
    },
    {
      "id": "ja534:52.3",
      "pali": "Nāssa cammaṁ va kīṭaṁ vā,"
    },
    {
      "id": "ja534:52.4",
      "pali": "vammite ca dhanuggahe."
    },
    {
      "id": "ja534:53.1",
      "pali": "Na hiraññaṁ suvaṇṇaṁ vā,"
    },
    {
      "id": "ja534:53.2",
      "pali": "nagaraṁ vā sumāpitaṁ;"
    },
    {
      "id": "ja534:53.3",
      "pali": "Okiṇṇaparikhaṁ duggaṁ,"
    },
    {
      "id": "ja534:53.4",
      "pali": "daḷhamaṭṭālakoṭṭhakaṁ;"
    },
    {
      "id": "ja534:53.5",
      "pali": "Yattha paviṭṭho sumukha,"
    },
    {
      "id": "ja534:53.6",
      "pali": "bhāyitabbaṁ na bhāyasi”."
    },
    {
      "id": "ja534:54.1",
      "pali": "“Na me abhisarenattho,"
    },
    {
      "id": "ja534:54.2",
      "pali": "nagarena dhanena vā;"
    },
    {
      "id": "ja534:54.3",
      "pali": "Apathena pathaṁ yāma,"
    },
    {
      "id": "ja534:54.4",
      "pali": "antalikkhecarā mayaṁ."
    },
    {
      "id": "ja534:55.1",
      "pali": "Sutā ca paṇḍitā tyamhā,"
    },
    {
      "id": "ja534:55.2",
      "pali": "nipuṇā atthacintakā;"
    },
    {
      "id": "ja534:55.3",
      "pali": "Bhāsematthavatiṁ vācaṁ,"
    },
    {
      "id": "ja534:55.4",
      "pali": "sacce cassa patiṭṭhito."
    },
    {
      "id": "ja534:56.1",
      "pali": "Kiñca tuyhaṁ asaccassa,"
    },
    {
      "id": "ja534:56.2",
      "pali": "anariyassa karissati;"
    },
    {
      "id": "ja534:56.3",
      "pali": "Musāvādissa luddassa,"
    },
    {
      "id": "ja534:56.4",
      "pali": "bhaṇitampi subhāsitaṁ."
    },
    {
      "id": "ja534:57.1",
      "pali": "Taṁ brāhmaṇānaṁ vacanā,"
    },
    {
      "id": "ja534:57.2",
      "pali": "imaṁ khemamakārayi;"
    },
    {
      "id": "ja534:57.3",
      "pali": "Abhayañca tayā ghuṭṭhaṁ,"
    },
    {
      "id": "ja534:57.4",
      "pali": "imāyo dasadhā disā."
    },
    {
      "id": "ja534:58.1",
      "pali": "Ogayha te pokkharaṇiṁ,"
    },
    {
      "id": "ja534:58.2",
      "pali": "vippasannodakaṁ suciṁ;"
    },
    {
      "id": "ja534:58.3",
      "pali": "Pahūtaṁ cādanaṁ tattha,"
    },
    {
      "id": "ja534:58.4",
      "pali": "ahiṁsā cettha pakkhinaṁ."
    },
    {
      "id": "ja534:59.1",
      "pali": "Idaṁ sutvāna nigghosaṁ,"
    },
    {
      "id": "ja534:59.2",
      "pali": "āgatamha tavantike;"
    },
    {
      "id": "ja534:59.3",
      "pali": "Te te bandhasma pāsena,"
    },
    {
      "id": "ja534:59.4",
      "pali": "etaṁ te bhāsitaṁ musā."
    },
    {
      "id": "ja534:60.1",
      "pali": "Musāvādaṁ purakkhatvā,"
    },
    {
      "id": "ja534:60.2",
      "pali": "icchālobhañca pāpakaṁ;"
    },
    {
      "id": "ja534:60.3",
      "pali": "Ubho sandhimatikkamma,"
    },
    {
      "id": "ja534:60.4",
      "pali": "asātaṁ upapajjati”."
    },
    {
      "id": "ja534:61.1",
      "pali": "“Nāparajjhāma sumukha,"
    },
    {
      "id": "ja534:61.2",
      "pali": "napi lobhāva maggahiṁ;"
    },
    {
      "id": "ja534:61.3",
      "pali": "Sutā ca paṇḍitātyattha-"
    },
    {
      "id": "ja534:61.4",
      "pali": "nipuṇā atthacintakā."
    },
    {
      "id": "ja534:62.1",
      "pali": "Appevatthavatiṁ vācaṁ,"
    },
    {
      "id": "ja534:62.2",
      "pali": "byāhareyyuṁ idhāgatā;"
    },
    {
      "id": "ja534:62.3",
      "pali": "Tathā taṁ samma nesādo,"
    },
    {
      "id": "ja534:62.4",
      "pali": "vutto sumukha maggahi”."
    },
    {
      "id": "ja534:63.1",
      "pali": "“Neva bhītā kāsipati,"
    },
    {
      "id": "ja534:63.2",
      "pali": "upanītasmi jīvite;"
    },
    {
      "id": "ja534:63.3",
      "pali": "Bhāsematthavatiṁ vācaṁ,"
    },
    {
      "id": "ja534:63.4",
      "pali": "sampattā kālapariyāyaṁ."
    },
    {
      "id": "ja534:64.1",
      "pali": "Yo migena migaṁ hanti,"
    },
    {
      "id": "ja534:64.2",
      "pali": "pakkhiṁ vā pana pakkhinā;"
    },
    {
      "id": "ja534:64.3",
      "pali": "Sutena vā sutaṁ kiṇyā,"
    },
    {
      "id": "ja534:64.4",
      "pali": "kiṁ anariyataraṁ tato."
    },
    {
      "id": "ja534:65.1",
      "pali": "Yo cāriyarudaṁ bhāse,"
    },
    {
      "id": "ja534:65.2",
      "pali": "anariyadhammavassito;"
    },
    {
      "id": "ja534:65.3",
      "pali": "Ubho so dhaṁsate lokā,"
    },
    {
      "id": "ja534:65.4",
      "pali": "idha ceva parattha ca."
    },
    {
      "id": "ja534:66.1",
      "pali": "Na majjetha yasaṁ patto,"
    },
    {
      "id": "ja534:66.2",
      "pali": "na byādhe pattasaṁsayaṁ;"
    },
    {
      "id": "ja534:66.3",
      "pali": "Vāyametheva kiccesu,"
    },
    {
      "id": "ja534:66.4",
      "pali": "saṁvare vivarāni ca."
    },
    {
      "id": "ja534:67.1",
      "pali": "Ye vuddhā abbhatikkantā,"
    },
    {
      "id": "ja534:67.2",
      "pali": "sampattā kālapariyāyaṁ;"
    },
    {
      "id": "ja534:67.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja534:67.4",
      "pali": "evaṁte tidivaṁ gatā."
    },
    {
      "id": "ja534:68.1",
      "pali": "Idaṁ sutvā kāsipati,"
    },
    {
      "id": "ja534:68.2",
      "pali": "dhammamattani pālaya;"
    },
    {
      "id": "ja534:68.3",
      "pali": "Dhataraṭṭhañca muñcāhi,"
    },
    {
      "id": "ja534:68.4",
      "pali": "haṁsānaṁ pavaruttamaṁ”."
    },
    {
      "id": "ja534:69.1",
      "pali": "“Āharantudakaṁ pajjaṁ,"
    },
    {
      "id": "ja534:69.2",
      "pali": "āsanañca mahārahaṁ;"
    },
    {
      "id": "ja534:69.3",
      "pali": "Pañjarato pamokkhāmi,"
    },
    {
      "id": "ja534:69.4",
      "pali": "dhataraṭṭhaṁ yasassinaṁ."
    },
    {
      "id": "ja534:70.1",
      "pali": "Tañca senāpatiṁ dhīraṁ,"
    },
    {
      "id": "ja534:70.2",
      "pali": "nipuṇaṁ atthacintakaṁ;"
    },
    {
      "id": "ja534:70.3",
      "pali": "Yo sukhe sukhito rañño,"
    },
    {
      "id": "ja534:70.4",
      "pali": "dukkhite hoti dukkhito."
    },
    {
      "id": "ja534:71.1",
      "pali": "Ediso kho arahati,"
    },
    {
      "id": "ja534:71.2",
      "pali": "piṇḍamasnātu bhattuno;"
    },
    {
      "id": "ja534:71.3",
      "pali": "Yathāyaṁ sumukho rañño,"
    },
    {
      "id": "ja534:71.4",
      "pali": "pāṇasādhāraṇo sakhā”."
    },
    {
      "id": "ja534:72.1",
      "pali": "Pīṭhañca sabbasovaṇṇaṁ,"
    },
    {
      "id": "ja534:72.2",
      "pali": "Aṭṭhapādaṁ manoramaṁ;"
    },
    {
      "id": "ja534:72.3",
      "pali": "Maṭṭhaṁ kāsikamatthannaṁ,"
    },
    {
      "id": "ja534:72.4",
      "pali": "Dhataraṭṭho upāvisi."
    },
    {
      "id": "ja534:73.1",
      "pali": "Kocchañca sabbasovaṇṇaṁ,"
    },
    {
      "id": "ja534:73.2",
      "pali": "veyyagghaparisibbitaṁ;"
    },
    {
      "id": "ja534:73.3",
      "pali": "Sumukho ajjhupāvekkhi,"
    },
    {
      "id": "ja534:73.4",
      "pali": "dhataraṭṭhassanantarā."
    },
    {
      "id": "ja534:74.1",
      "pali": "Tesaṁ kañcanapattehi,"
    },
    {
      "id": "ja534:74.2",
      "pali": "puthū ādāya kāsiyo;"
    },
    {
      "id": "ja534:74.3",
      "pali": "Haṁsānaṁ abhihāresuṁ,"
    },
    {
      "id": "ja534:74.4",
      "pali": "aggarañño pavāsitaṁ."
    },
    {
      "id": "ja534:75.1",
      "pali": "Disvā abhihaṭaṁ aggaṁ,"
    },
    {
      "id": "ja534:75.2",
      "pali": "kāsirājena pesitaṁ;"
    },
    {
      "id": "ja534:75.3",
      "pali": "Kusalo khattadhammānaṁ,"
    },
    {
      "id": "ja534:75.4",
      "pali": "tato pucchi anantarā."
    },
    {
      "id": "ja534:76.1",
      "pali": "“Kaccinnu bhoto kusalaṁ,"
    },
    {
      "id": "ja534:76.2",
      "pali": "kacci bhoto anāmayaṁ;"
    },
    {
      "id": "ja534:76.3",
      "pali": "Kacci raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja534:76.4",
      "pali": "dhammena manusāsasi”."
    },
    {
      "id": "ja534:77.1",
      "pali": "“Kusalañceva me haṁsa,"
    },
    {
      "id": "ja534:77.2",
      "pali": "atho haṁsa anāmayaṁ;"
    },
    {
      "id": "ja534:77.3",
      "pali": "Atho raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja534:77.4",
      "pali": "dhammenaṁ manusāsahaṁ”."
    },
    {
      "id": "ja534:78.1",
      "pali": "“Kacci bhoto amaccesu,"
    },
    {
      "id": "ja534:78.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja534:78.3",
      "pali": "Kacci ca te tavatthesu,"
    },
    {
      "id": "ja534:78.4",
      "pali": "nāvakaṅkhanti jīvitaṁ”."
    },
    {
      "id": "ja534:79.1",
      "pali": "“Athopi me amaccesu,"
    },
    {
      "id": "ja534:79.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja534:79.3",
      "pali": "Athopi te mamatthesu,"
    },
    {
      "id": "ja534:79.4",
      "pali": "nāvakaṅkhanti jīvitaṁ”."
    },
    {
      "id": "ja534:80.1",
      "pali": "“Kacci te sādisī bhariyā,"
    },
    {
      "id": "ja534:80.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja534:80.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja534:80.4",
      "pali": "tava chandavasānugā”."
    },
    {
      "id": "ja534:81.1",
      "pali": "“Atho me sādisī bhariyā,"
    },
    {
      "id": "ja534:81.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja534:81.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja534:81.4",
      "pali": "mama chandavasānugā”."
    },
    {
      "id": "ja534:82.1",
      "pali": "“Kacci raṭṭhaṁ anuppīḷaṁ,"
    },
    {
      "id": "ja534:82.2",
      "pali": "akutociupaddavaṁ;"
    },
    {
      "id": "ja534:82.3",
      "pali": "Asāhasena dhammena,"
    },
    {
      "id": "ja534:82.4",
      "pali": "samena manusāsasi”."
    },
    {
      "id": "ja534:83.1",
      "pali": "“Atho raṭṭhaṁ anuppīḷaṁ,"
    },
    {
      "id": "ja534:83.2",
      "pali": "akutociupaddavaṁ;"
    },
    {
      "id": "ja534:83.3",
      "pali": "Asāhasena dhammena,"
    },
    {
      "id": "ja534:83.4",
      "pali": "samena manusāsahaṁ”."
    },
    {
      "id": "ja534:84.1",
      "pali": "“Kacci santo apacitā,"
    },
    {
      "id": "ja534:84.2",
      "pali": "Asanto parivajjitā;"
    },
    {
      "id": "ja534:84.3",
      "pali": "No ce dhammaṁ niraṅkatvā,"
    },
    {
      "id": "ja534:84.4",
      "pali": "Adhammamanuvattasi”."
    },
    {
      "id": "ja534:85.1",
      "pali": "“Santo ca me apacitā,"
    },
    {
      "id": "ja534:85.2",
      "pali": "asanto parivajjitā;"
    },
    {
      "id": "ja534:85.3",
      "pali": "Dhammamevānuvattāmi,"
    },
    {
      "id": "ja534:85.4",
      "pali": "adhammo me niraṅkato”."
    },
    {
      "id": "ja534:86.1",
      "pali": "“Kacci nānāgataṁ dīghaṁ,"
    },
    {
      "id": "ja534:86.2",
      "pali": "samavekkhasi khattiya;"
    },
    {
      "id": "ja534:86.3",
      "pali": "Kacci matto madanīye,"
    },
    {
      "id": "ja534:86.4",
      "pali": "paralokaṁ na santasi”."
    },
    {
      "id": "ja534:87.1",
      "pali": "“Nāhaṁ anāgataṁ dīghaṁ,"
    },
    {
      "id": "ja534:87.2",
      "pali": "samavekkhāmi pakkhima;"
    },
    {
      "id": "ja534:87.3",
      "pali": "Ṭhito dasasu dhammesu,"
    },
    {
      "id": "ja534:87.4",
      "pali": "paralokaṁ na santase."
    },
    {
      "id": "ja534:88.1",
      "pali": "Dānaṁ sīlaṁ pariccāgaṁ,"
    },
    {
      "id": "ja534:88.2",
      "pali": "ajjavaṁ maddavaṁ tapaṁ;"
    },
    {
      "id": "ja534:88.3",
      "pali": "Akkodhaṁ avihiṁsañca,"
    },
    {
      "id": "ja534:88.4",
      "pali": "khantiñca avirodhanaṁ."
    },
    {
      "id": "ja534:89.1",
      "pali": "Iccete kusale dhamme,"
    },
    {
      "id": "ja534:89.2",
      "pali": "ṭhite passāmi attani;"
    },
    {
      "id": "ja534:89.3",
      "pali": "Tato me jāyate pīti,"
    },
    {
      "id": "ja534:89.4",
      "pali": "somanassañcanappakaṁ."
    },
    {
      "id": "ja534:90.1",
      "pali": "Sumukho ca acintetvā,"
    },
    {
      "id": "ja534:90.2",
      "pali": "visajji pharusaṁ giraṁ;"
    },
    {
      "id": "ja534:90.3",
      "pali": "Bhāvadosamanaññāya,"
    },
    {
      "id": "ja534:90.4",
      "pali": "asmākāyaṁ vihaṅgamo."
    },
    {
      "id": "ja534:91.1",
      "pali": "So kuddho pharusaṁ vācaṁ,"
    },
    {
      "id": "ja534:91.2",
      "pali": "nicchāresi ayoniso;"
    },
    {
      "id": "ja534:91.3",
      "pali": "Yānasmesu na vijjanti,"
    },
    {
      "id": "ja534:91.4",
      "pali": "nayidaṁ paññavatāmiva”."
    },
    {
      "id": "ja534:92.1",
      "pali": "“Atthi me taṁ atisāraṁ,"
    },
    {
      "id": "ja534:92.2",
      "pali": "vegena manujādhipa;"
    },
    {
      "id": "ja534:92.3",
      "pali": "Dhataraṭṭhe ca baddhasmiṁ,"
    },
    {
      "id": "ja534:92.4",
      "pali": "dukkhaṁ me vipulaṁ ahu."
    },
    {
      "id": "ja534:93.1",
      "pali": "Tvaṁ no pitāva puttānaṁ,"
    },
    {
      "id": "ja534:93.2",
      "pali": "bhūtānaṁ dharaṇīriva;"
    },
    {
      "id": "ja534:93.3",
      "pali": "Asmākaṁ adhipannānaṁ,"
    },
    {
      "id": "ja534:93.4",
      "pali": "khamassu rājakuñjara”."
    },
    {
      "id": "ja534:94.1",
      "pali": "“Etaṁ te anumodāma,"
    },
    {
      "id": "ja534:94.2",
      "pali": "yaṁ bhāvaṁ na nigūhasi;"
    },
    {
      "id": "ja534:94.3",
      "pali": "Khilaṁ pabhindasi pakkhi,"
    },
    {
      "id": "ja534:94.4",
      "pali": "ujukosi vihaṅgama."
    },
    {
      "id": "ja534:95.1",
      "pali": "Yaṁ kiñci ratanaṁ atthi,"
    },
    {
      "id": "ja534:95.2",
      "pali": "kāsirājanivesane;"
    },
    {
      "id": "ja534:95.3",
      "pali": "Rajataṁ jātarūpañca,"
    },
    {
      "id": "ja534:95.4",
      "pali": "muttā veḷuriyā bahū."
    },
    {
      "id": "ja534:96.1",
      "pali": "Maṇayo saṅkhamuttā ca,"
    },
    {
      "id": "ja534:96.2",
      "pali": "vatthakaṁ haricandanaṁ;"
    },
    {
      "id": "ja534:96.3",
      "pali": "Ajinaṁ dantabhaṇḍañca,"
    },
    {
      "id": "ja534:96.4",
      "pali": "lohaṁ kāḷāyasaṁ bahuṁ;"
    },
    {
      "id": "ja534:96.5",
      "pali": "Etaṁ dadāmi vo vittaṁ,"
    },
    {
      "id": "ja534:96.6",
      "pali": "issaraṁ vissajāmi vo”."
    },
    {
      "id": "ja534:97.1",
      "pali": "“Addhā apacitā tyamhā,"
    },
    {
      "id": "ja534:97.2",
      "pali": "sakkatā ca rathesabha;"
    },
    {
      "id": "ja534:97.3",
      "pali": "Dhammesu vattamānānaṁ,"
    },
    {
      "id": "ja534:97.4",
      "pali": "tvaṁ no ācariyo bhava."
    },
    {
      "id": "ja534:98.1",
      "pali": "Ācariya samanuññātā,"
    },
    {
      "id": "ja534:98.2",
      "pali": "Tayā anumatā mayaṁ;"
    },
    {
      "id": "ja534:98.3",
      "pali": "Taṁ padakkhiṇato katvā,"
    },
    {
      "id": "ja534:98.4",
      "pali": "Ñātiṁ passemurindama”."
    },
    {
      "id": "ja534:99.1",
      "pali": "Sabbarattiṁ cintayitvā,"
    },
    {
      "id": "ja534:99.2",
      "pali": "mantayitvā yathātathaṁ;"
    },
    {
      "id": "ja534:99.3",
      "pali": "Kāsirājā anuññāsi,"
    },
    {
      "id": "ja534:99.4",
      "pali": "haṁsānaṁ pavaruttamaṁ."
    },
    {
      "id": "ja534:100.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "ja534:100.2",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "ja534:100.3",
      "pali": "Pekkhato kāsirājassa,"
    },
    {
      "id": "ja534:100.4",
      "pali": "bhavanā te vigāhisuṁ."
    },
    {
      "id": "ja534:101.1",
      "pali": "Te aroge anuppatte,"
    },
    {
      "id": "ja534:101.2",
      "pali": "disvāna parame dije;"
    },
    {
      "id": "ja534:101.3",
      "pali": "Kekāti makaruṁ haṁsā,"
    },
    {
      "id": "ja534:101.4",
      "pali": "puthusaddo ajāyatha."
    },
    {
      "id": "ja534:102.1",
      "pali": "Te patītā pamuttena,"
    },
    {
      "id": "ja534:102.2",
      "pali": "bhattunā bhattugāravā;"
    },
    {
      "id": "ja534:102.3",
      "pali": "Samantā parikiriṁsu,"
    },
    {
      "id": "ja534:102.4",
      "pali": "aṇḍajā laddhapaccayā."
    },
    {
      "id": "ja534:103.1",
      "pali": "Evaṁ mittavataṁ atthā,"
    },
    {
      "id": "ja534:103.2",
      "pali": "sabbe honti padakkhiṇā;"
    },
    {
      "id": "ja534:103.3",
      "pali": "Haṁsā yathā dhataraṭṭhā,"
    },
    {
      "id": "ja534:103.4",
      "pali": "ñātisaṅghaṁ upāgamunti."
    },
    {
      "id": "ja534:104.1",
      "pali": "Mahāhaṁsajātakaṁ dutiyaṁ."
    }
  ]
}
