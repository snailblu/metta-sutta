{
  "uid": "tha-ap5",
  "title": "Mahākassapattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap5:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap5:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap5:1.3",
      "pali": "Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap5:1.4",
      "pali": "Pūjaṁ kubbanti satthuno."
    },
    {
      "id": "tha-ap5:2.1",
      "pali": "Udaggacittā janatā,"
    },
    {
      "id": "tha-ap5:2.2",
      "pali": "āmoditapamoditā;"
    },
    {
      "id": "tha-ap5:2.3",
      "pali": "Tesu saṁvegajātesu,"
    },
    {
      "id": "tha-ap5:2.4",
      "pali": "pīti me udapajjatha."
    },
    {
      "id": "tha-ap5:3.1",
      "pali": "Ñātimitte samānetvā,"
    },
    {
      "id": "tha-ap5:3.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "tha-ap5:3.3",
      "pali": "Parinibbuto mahāvīro,"
    },
    {
      "id": "tha-ap5:3.4",
      "pali": "handa pūjaṁ karomase."
    },
    {
      "id": "tha-ap5:4.1",
      "pali": "Sādhūti te paṭissutvā,"
    },
    {
      "id": "tha-ap5:4.2",
      "pali": "bhiyyo hāsaṁ janiṁsu me;"
    },
    {
      "id": "tha-ap5:4.3",
      "pali": "Buddhasmiṁ lokanāthamhi,"
    },
    {
      "id": "tha-ap5:4.4",
      "pali": "kāhāma puññasañcayaṁ."
    },
    {
      "id": "tha-ap5:5.1",
      "pali": "Agghiyaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap5:5.2",
      "pali": "satahatthasamuggataṁ;"
    },
    {
      "id": "tha-ap5:5.3",
      "pali": "Diyaḍḍhahatthapatthaṭaṁ,"
    },
    {
      "id": "tha-ap5:5.4",
      "pali": "vimānaṁ nabhamuggataṁ."
    },
    {
      "id": "tha-ap5:6.1",
      "pali": "Katvāna hammiyaṁ tattha,"
    },
    {
      "id": "tha-ap5:6.2",
      "pali": "tālapantīhi cittitaṁ;"
    },
    {
      "id": "tha-ap5:6.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap5:6.4",
      "pali": "cetiyaṁ pūjayuttamaṁ."
    },
    {
      "id": "tha-ap5:7.1",
      "pali": "Aggikkhandhova jalito,"
    },
    {
      "id": "tha-ap5:7.2",
      "pali": "kiṁsuko iva phullito;"
    },
    {
      "id": "tha-ap5:7.3",
      "pali": "Indalaṭṭhīva ākāse,"
    },
    {
      "id": "tha-ap5:7.4",
      "pali": "obhāsati catuddisā."
    },
    {
      "id": "tha-ap5:8.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap5:8.2",
      "pali": "katvāna kusalaṁ bahuṁ;"
    },
    {
      "id": "tha-ap5:8.3",
      "pali": "Pubbakammaṁ saritvāna,"
    },
    {
      "id": "tha-ap5:8.4",
      "pali": "tidasaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap5:9.1",
      "pali": "Sahassayuttaṁ hayavāhiṁ,"
    },
    {
      "id": "tha-ap5:9.2",
      "pali": "Dibbayānamadhiṭṭhito;"
    },
    {
      "id": "tha-ap5:9.3",
      "pali": "Ubbiddhaṁ bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap5:9.4",
      "pali": "Sattabhūmaṁ samuggataṁ."
    },
    {
      "id": "tha-ap5:10.1",
      "pali": "Kūṭāgārasahassāni,"
    },
    {
      "id": "tha-ap5:10.2",
      "pali": "sabbasoṇṇamayā ahuṁ;"
    },
    {
      "id": "tha-ap5:10.3",
      "pali": "Jalanti sakatejena,"
    },
    {
      "id": "tha-ap5:10.4",
      "pali": "disā sabbā pabhāsayaṁ."
    },
    {
      "id": "tha-ap5:11.1",
      "pali": "Santi aññepi niyyūhā,"
    },
    {
      "id": "tha-ap5:11.2",
      "pali": "lohitaṅgamayā tadā;"
    },
    {
      "id": "tha-ap5:11.3",
      "pali": "Tepi jotanti ābhāya,"
    },
    {
      "id": "tha-ap5:11.4",
      "pali": "samantā caturo disā."
    },
    {
      "id": "tha-ap5:12.1",
      "pali": "Puññakammābhinibbattā,"
    },
    {
      "id": "tha-ap5:12.2",
      "pali": "kūṭāgārā sunimmitā;"
    },
    {
      "id": "tha-ap5:12.3",
      "pali": "Maṇimayāpi jotanti,"
    },
    {
      "id": "tha-ap5:12.4",
      "pali": "disā dasa samantato."
    },
    {
      "id": "tha-ap5:13.1",
      "pali": "Tesaṁ ujjotamānānaṁ,"
    },
    {
      "id": "tha-ap5:13.2",
      "pali": "obhāso vipulo ahu;"
    },
    {
      "id": "tha-ap5:13.3",
      "pali": "Sabbe deve abhibhomi,"
    },
    {
      "id": "tha-ap5:13.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap5:14.1",
      "pali": "Saṭṭhikappasahassamhi,"
    },
    {
      "id": "tha-ap5:14.2",
      "pali": "ubbiddho nāma khattiyo;"
    },
    {
      "id": "tha-ap5:14.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap5:14.4",
      "pali": "pathaviṁ āvasiṁ ahaṁ."
    },
    {
      "id": "tha-ap5:15.1",
      "pali": "Tatheva bhaddake kappe,"
    },
    {
      "id": "tha-ap5:15.2",
      "pali": "tiṁsakkhattuṁ ahosahaṁ;"
    },
    {
      "id": "tha-ap5:15.3",
      "pali": "Sakakammābhiraddhomhi,"
    },
    {
      "id": "tha-ap5:15.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap5:16.1",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap5:16.2",
      "pali": "catudīpamhi issaro;"
    },
    {
      "id": "tha-ap5:16.3",
      "pali": "Tatthāpi bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap5:16.4",
      "pali": "indalaṭṭhīva uggataṁ."
    },
    {
      "id": "tha-ap5:17.1",
      "pali": "Āyāmato catubbīsaṁ,"
    },
    {
      "id": "tha-ap5:17.2",
      "pali": "vitthārena ca dvādasa;"
    },
    {
      "id": "tha-ap5:17.3",
      "pali": "Rammaṇaṁ nāma nagaraṁ,"
    },
    {
      "id": "tha-ap5:17.4",
      "pali": "daḷhapākāratoraṇaṁ."
    },
    {
      "id": "tha-ap5:18.1",
      "pali": "Āyāmato pañcasataṁ,"
    },
    {
      "id": "tha-ap5:18.2",
      "pali": "vitthārena tadaḍḍhakaṁ;"
    },
    {
      "id": "tha-ap5:18.3",
      "pali": "Ākiṇṇaṁ janakāyehi,"
    },
    {
      "id": "tha-ap5:18.4",
      "pali": "tidasānaṁ puraṁ viya."
    },
    {
      "id": "tha-ap5:19.1",
      "pali": "Yathā sūcighare sūcī,"
    },
    {
      "id": "tha-ap5:19.2",
      "pali": "pakkhittā paṇṇavīsati;"
    },
    {
      "id": "tha-ap5:19.3",
      "pali": "Aññamaññaṁ paghaṭṭenti,"
    },
    {
      "id": "tha-ap5:19.4",
      "pali": "ākiṇṇaṁ hoti laṅkataṁ."
    },
    {
      "id": "tha-ap5:20.1",
      "pali": "Evampi nagaraṁ mayhaṁ,"
    },
    {
      "id": "tha-ap5:20.2",
      "pali": "hatthissarathasaṅkulaṁ;"
    },
    {
      "id": "tha-ap5:20.3",
      "pali": "Manussehi sadākiṇṇaṁ,"
    },
    {
      "id": "tha-ap5:20.4",
      "pali": "rammaṇaṁ nagaruttamaṁ."
    },
    {
      "id": "tha-ap5:21.1",
      "pali": "Tattha bhutvā pivitvā ca,"
    },
    {
      "id": "tha-ap5:21.2",
      "pali": "puna devattanaṁ gato;"
    },
    {
      "id": "tha-ap5:21.3",
      "pali": "Bhave pacchimake mayhaṁ,"
    },
    {
      "id": "tha-ap5:21.4",
      "pali": "ahosi kulasampadā."
    },
    {
      "id": "tha-ap5:22.1",
      "pali": "Brāhmaññakulasambhūto,"
    },
    {
      "id": "tha-ap5:22.2",
      "pali": "mahāratanasañcayo;"
    },
    {
      "id": "tha-ap5:22.3",
      "pali": "Asītikoṭiyo hitvā,"
    },
    {
      "id": "tha-ap5:22.4",
      "pali": "hiraññassāpi pabbajiṁ."
    },
    {
      "id": "tha-ap5:23.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap5:23.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap5:23.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap5:23.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap5:24.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahākassapo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap5:25.1",
      "pali": "Mahākassapattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
