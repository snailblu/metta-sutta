{
  "uid": "thi-ap6",
  "title": "Ekapiṇḍapātadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap6:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "thi-ap6:1.2",
      "pali": "bandhumā nāma khattiyo;"
    },
    {
      "id": "thi-ap6:1.3",
      "pali": "Tassa rañño ahuṁ bhariyā,"
    },
    {
      "id": "thi-ap6:1.4",
      "pali": "ekajjhaṁ cārayāmahaṁ."
    },
    {
      "id": "thi-ap6:2.1",
      "pali": "Rahogatā nisīditvā,"
    },
    {
      "id": "thi-ap6:2.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "thi-ap6:2.3",
      "pali": "‘Ādāya gamanīyaṁ hi,"
    },
    {
      "id": "thi-ap6:2.4",
      "pali": "kusalaṁ natthi me kataṁ."
    },
    {
      "id": "thi-ap6:3.1",
      "pali": "Mahābhitāpaṁ kaṭukaṁ,"
    },
    {
      "id": "thi-ap6:3.2",
      "pali": "ghorarūpaṁ sudāruṇaṁ;"
    },
    {
      "id": "thi-ap6:3.3",
      "pali": "Nirayaṁ nūna gacchāmi,"
    },
    {
      "id": "thi-ap6:3.4",
      "pali": "ettha me natthi saṁsayo’."
    },
    {
      "id": "thi-ap6:4.1",
      "pali": "Rājānaṁ upasaṅkamma,"
    },
    {
      "id": "thi-ap6:4.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "thi-ap6:4.3",
      "pali": "‘Ekaṁ me samaṇaṁ dehi,"
    },
    {
      "id": "thi-ap6:4.4",
      "pali": "bhojayissāmi khattiya’."
    },
    {
      "id": "thi-ap6:5.1",
      "pali": "Adāsi me mahārājā,"
    },
    {
      "id": "thi-ap6:5.2",
      "pali": "samaṇaṁ bhāvitindriyaṁ;"
    },
    {
      "id": "thi-ap6:5.3",
      "pali": "Tassa pattaṁ gahetvāna,"
    },
    {
      "id": "thi-ap6:5.4",
      "pali": "paramannena pūrayiṁ."
    },
    {
      "id": "thi-ap6:6.1",
      "pali": "Pūrayitvā paramannaṁ,"
    },
    {
      "id": "thi-ap6:6.2",
      "pali": "gandhālepaṁ akāsahaṁ;"
    },
    {
      "id": "thi-ap6:6.3",
      "pali": "Jālena pidahitvāna,"
    },
    {
      "id": "thi-ap6:6.4",
      "pali": "vatthayugena chādayiṁ."
    },
    {
      "id": "thi-ap6:7.1",
      "pali": "Ārammaṇaṁ mamaṁ etaṁ,"
    },
    {
      "id": "thi-ap6:7.2",
      "pali": "sarāmi yāvajīvihaṁ;"
    },
    {
      "id": "thi-ap6:7.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "thi-ap6:7.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap6:8.1",
      "pali": "Tiṁsānaṁ devarājūnaṁ,"
    },
    {
      "id": "thi-ap6:8.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap6:8.3",
      "pali": "Manasā patthitaṁ mayhaṁ,"
    },
    {
      "id": "thi-ap6:8.4",
      "pali": "nibbattati yathicchitaṁ."
    },
    {
      "id": "thi-ap6:9.1",
      "pali": "Vīsānaṁ cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap6:9.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap6:9.3",
      "pali": "Ocitattāva hutvāna,"
    },
    {
      "id": "thi-ap6:9.4",
      "pali": "saṁsarāmi bhavesvahaṁ."
    },
    {
      "id": "thi-ap6:10.1",
      "pali": "Sabbabandhanamuttāhaṁ,"
    },
    {
      "id": "thi-ap6:10.2",
      "pali": "apetā me upādikā;"
    },
    {
      "id": "thi-ap6:10.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap6:10.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap6:11.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap6:11.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "thi-ap6:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap6:11.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap6:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap6:12.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap6:12.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap6:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap6:13.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap6:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap6:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap6:14.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap6:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap6:15.1",
      "pali": "Itthaṁ sudaṁ ekapiṇḍapātadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap6:16.1",
      "pali": "Ekapiṇḍapātadāyikātheriyāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
