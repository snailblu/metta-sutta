{
  "uid": "thag2.31",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.31:1.1",
      "pali": "“Yato ahaṁ pabbajito,"
    },
    {
      "id": "thag2.31:1.2",
      "pali": "sammāsambuddhasāsane;"
    },
    {
      "id": "thag2.31:1.3",
      "pali": "Vimuccamāno uggacchiṁ,"
    },
    {
      "id": "thag2.31:1.4",
      "pali": "kāmadhātuṁ upaccagaṁ."
    },
    {
      "id": "thag2.31:2.1",
      "pali": "Brahmuno pekkhamānassa,"
    },
    {
      "id": "thag2.31:2.2",
      "pali": "tato cittaṁ vimucci me;"
    },
    {
      "id": "thag2.31:2.3",
      "pali": "Akuppā me vimuttīti,"
    },
    {
      "id": "thag2.31:2.4",
      "pali": "sabbasaṁyojanakkhayā”ti."
    },
    {
      "id": "thag2.31:2.5",
      "pali": "… Migasiro thero …."
    }
  ]
}
