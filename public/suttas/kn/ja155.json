{
  "uid": "ja155",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja155:1.1",
      "pali": "“Jīva vassasataṁ bhagga,"
    },
    {
      "id": "ja155:1.2",
      "pali": "aparāni ca vīsatiṁ;"
    },
    {
      "id": "ja155:1.3",
      "pali": "Mā maṁ pisācā khādantu,"
    },
    {
      "id": "ja155:1.4",
      "pali": "jīva tvaṁ sarado sataṁ”."
    },
    {
      "id": "ja155:2.1",
      "pali": "“Tvampi vassasataṁ jīva,"
    },
    {
      "id": "ja155:2.2",
      "pali": "aparāni ca vīsatiṁ;"
    },
    {
      "id": "ja155:2.3",
      "pali": "Visaṁ pisācā khādantu,"
    },
    {
      "id": "ja155:2.4",
      "pali": "jīva tvaṁ sarado satan”ti."
    },
    {
      "id": "ja155:3.1",
      "pali": "Bhaggajātakaṁ pañcamaṁ."
    }
  ]
}
