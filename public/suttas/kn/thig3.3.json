{
  "uid": "thig3.3",
  "title": "Aparāuttamātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.3:1.1",
      "pali": "“Ye ime satta bojjhaṅgā,"
    },
    {
      "id": "thig3.3:1.2",
      "pali": "maggā nibbānapattiyā;"
    },
    {
      "id": "thig3.3:1.3",
      "pali": "Bhāvitā te mayā sabbe,"
    },
    {
      "id": "thig3.3:1.4",
      "pali": "yathā buddhena desitā."
    },
    {
      "id": "thig3.3:2.1",
      "pali": "Suññatassānimittassa,"
    },
    {
      "id": "thig3.3:2.2",
      "pali": "lābhinīhaṁ yadicchakaṁ;"
    },
    {
      "id": "thig3.3:2.3",
      "pali": "Orasā dhītā buddhassa,"
    },
    {
      "id": "thig3.3:2.4",
      "pali": "nibbānābhiratā sadā."
    },
    {
      "id": "thig3.3:3.1",
      "pali": "Sabbe kāmā samucchinnā,"
    },
    {
      "id": "thig3.3:3.2",
      "pali": "ye dibbā ye ca mānusā;"
    },
    {
      "id": "thig3.3:3.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thig3.3:3.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thig3.3:4.1",
      "pali": "… Aparā uttamā therī …."
    }
  ]
}
