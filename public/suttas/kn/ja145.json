{
  "uid": "ja145",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja145:1.1",
      "pali": "“Na tvaṁ rādha vijānāsi,"
    },
    {
      "id": "ja145:1.2",
      "pali": "aḍḍharatte anāgate;"
    },
    {
      "id": "ja145:1.3",
      "pali": "Abyayataṁ vilapasi,"
    },
    {
      "id": "ja145:1.4",
      "pali": "virattā kosiyāyane”ti."
    },
    {
      "id": "ja145:2.1",
      "pali": "Rādhajātakaṁ pañcamaṁ."
    }
  ]
}
