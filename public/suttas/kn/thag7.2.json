{
  "uid": "thag7.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag7.2:1.1",
      "pali": "“Pare ambāṭakārāme,"
    },
    {
      "id": "thag7.2:1.2",
      "pali": "vanasaṇḍamhi bhaddiyo;"
    },
    {
      "id": "thag7.2:1.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "thag7.2:1.4",
      "pali": "tattha bhaddova jhāyati."
    },
    {
      "id": "thag7.2:2.1",
      "pali": "Ramanteke mudiṅgehi,"
    },
    {
      "id": "thag7.2:2.2",
      "pali": "vīṇāhi paṇavehi ca;"
    },
    {
      "id": "thag7.2:2.3",
      "pali": "Ahañca rukkhamūlasmiṁ,"
    },
    {
      "id": "thag7.2:2.4",
      "pali": "rato buddhassa sāsane."
    },
    {
      "id": "thag7.2:3.1",
      "pali": "Buddho ce me varaṁ dajjā,"
    },
    {
      "id": "thag7.2:3.2",
      "pali": "so ca labbhetha me varo;"
    },
    {
      "id": "thag7.2:3.3",
      "pali": "Gaṇhehaṁ sabbalokassa,"
    },
    {
      "id": "thag7.2:3.4",
      "pali": "niccaṁ kāyagataṁ satiṁ."
    },
    {
      "id": "thag7.2:4.1",
      "pali": "Ye maṁ rūpena pāmiṁsu,"
    },
    {
      "id": "thag7.2:4.2",
      "pali": "ye ca ghosena anvagū;"
    },
    {
      "id": "thag7.2:4.3",
      "pali": "Chandarāgavasūpetā,"
    },
    {
      "id": "thag7.2:4.4",
      "pali": "na maṁ jānanti te janā."
    },
    {
      "id": "thag7.2:5.1",
      "pali": "Ajjhattañca na jānāti,"
    },
    {
      "id": "thag7.2:5.2",
      "pali": "bahiddhā ca na passati;"
    },
    {
      "id": "thag7.2:5.3",
      "pali": "Samantāvaraṇo bālo,"
    },
    {
      "id": "thag7.2:5.4",
      "pali": "sa ve ghosena vuyhati."
    },
    {
      "id": "thag7.2:6.1",
      "pali": "Ajjhattañca na jānāti,"
    },
    {
      "id": "thag7.2:6.2",
      "pali": "bahiddhā ca vipassati;"
    },
    {
      "id": "thag7.2:6.3",
      "pali": "Bahiddhā phaladassāvī,"
    },
    {
      "id": "thag7.2:6.4",
      "pali": "sopi ghosena vuyhati."
    },
    {
      "id": "thag7.2:7.1",
      "pali": "Ajjhattañca pajānāti,"
    },
    {
      "id": "thag7.2:7.2",
      "pali": "bahiddhā ca vipassati;"
    },
    {
      "id": "thag7.2:7.3",
      "pali": "Anāvaraṇadassāvī,"
    },
    {
      "id": "thag7.2:7.4",
      "pali": "na so ghosena vuyhatī”ti."
    },
    {
      "id": "thag7.2:7.5",
      "pali": "… Lakuṇḍakabhaddiyo thero …."
    }
  ]
}
