{
  "uid": "iti8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti8:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti8:2.1",
      "pali": "“Mānaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti8:2.2",
      "pali": "Mānañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti8:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti8:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti8:3.1",
      "pali": "“Mānupetā ayaṁ pajā,"
    },
    {
      "id": "iti8:3.2",
      "pali": "mānaganthā bhave ratā;"
    },
    {
      "id": "iti8:3.3",
      "pali": "Mānaṁ aparijānantā,"
    },
    {
      "id": "iti8:3.4",
      "pali": "āgantāro punabbhavaṁ."
    },
    {
      "id": "iti8:4.1",
      "pali": "Ye ca mānaṁ pahantvāna,"
    },
    {
      "id": "iti8:4.2",
      "pali": "vimuttā mānasaṅkhaye;"
    },
    {
      "id": "iti8:4.3",
      "pali": "Te mānaganthābhibhuno,"
    },
    {
      "id": "iti8:4.4",
      "pali": "sabbadukkhamupaccagun”ti."
    },
    {
      "id": "iti8:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti8:5.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
