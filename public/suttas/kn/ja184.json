{
  "uid": "ja184",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja184:1.1",
      "pali": "“Dūsito giridattena,"
    },
    {
      "id": "ja184:1.2",
      "pali": "hayo sāmassa paṇḍavo;"
    },
    {
      "id": "ja184:1.3",
      "pali": "Porāṇaṁ pakatiṁ hitvā,"
    },
    {
      "id": "ja184:1.4",
      "pali": "tassevānuvidhiyyati."
    },
    {
      "id": "ja184:2.1",
      "pali": "Sace ca tanujo poso,"
    },
    {
      "id": "ja184:2.2",
      "pali": "sikharākārakappito;"
    },
    {
      "id": "ja184:2.3",
      "pali": "Ānane naṁ gahetvāna,"
    },
    {
      "id": "ja184:2.4",
      "pali": "maṇḍale parivattaye;"
    },
    {
      "id": "ja184:2.5",
      "pali": "Khippameva pahantvāna,"
    },
    {
      "id": "ja184:2.6",
      "pali": "tassevānuvidhiyyatī”ti."
    },
    {
      "id": "ja184:3.1",
      "pali": "Giridattajātakaṁ catutthaṁ."
    }
  ]
}
