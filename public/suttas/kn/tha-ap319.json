{
  "uid": "tha-ap319",
  "title": "Saddasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap319:1.1",
      "pali": "“Sudassano mahāvīro,"
    },
    {
      "id": "tha-ap319:1.2",
      "pali": "deseti amataṁ padaṁ;"
    },
    {
      "id": "tha-ap319:1.3",
      "pali": "Parivuto sāvakehi,"
    },
    {
      "id": "tha-ap319:1.4",
      "pali": "vasati gharamuttame."
    },
    {
      "id": "tha-ap319:2.1",
      "pali": "Tāya vācāya madhurāya,"
    },
    {
      "id": "tha-ap319:2.2",
      "pali": "saṅgaṇhāti mahājanaṁ;"
    },
    {
      "id": "tha-ap319:2.3",
      "pali": "Ghoso ca vipulo āsi,"
    },
    {
      "id": "tha-ap319:2.4",
      "pali": "āsīso devamānuse."
    },
    {
      "id": "tha-ap319:3.1",
      "pali": "Nigghosasaddaṁ sutvāna,"
    },
    {
      "id": "tha-ap319:3.2",
      "pali": "siddhatthassa mahesino;"
    },
    {
      "id": "tha-ap319:3.3",
      "pali": "Sadde cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap319:3.4",
      "pali": "avandiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap319:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap319:4.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap319:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap319:4.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap319:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap319:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap319:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap319:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā saddasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap319:7.1",
      "pali": "Saddasaññakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
