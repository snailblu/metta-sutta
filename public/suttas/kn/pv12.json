{
  "uid": "pv12",
  "title": "12. Uragapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv12:1.1",
      "pali": "“Uragova tacaṁ jiṇṇaṁ,"
    },
    {
      "id": "pv12:1.2",
      "pali": "hitvā gacchati saṁ tanuṁ;"
    },
    {
      "id": "pv12:1.3",
      "pali": "Evaṁ sarīre nibbhoge,"
    },
    {
      "id": "pv12:1.4",
      "pali": "pete kālaṅkate sati."
    },
    {
      "id": "pv12:2.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "pv12:2.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "pv12:2.3",
      "pali": "Tasmā etaṁ na rodāmi,"
    },
    {
      "id": "pv12:2.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "pv12:3.1",
      "pali": "“Anabbhito tato āgā,"
    },
    {
      "id": "pv12:3.2",
      "pali": "nānuññāto ito gato;"
    },
    {
      "id": "pv12:3.3",
      "pali": "Yathāgato tathā gato,"
    },
    {
      "id": "pv12:3.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "pv12:4.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "pv12:4.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "pv12:4.3",
      "pali": "Tasmā etaṁ na rodāmi,"
    },
    {
      "id": "pv12:4.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "pv12:5.1",
      "pali": "“Sace rode kisā assaṁ,"
    },
    {
      "id": "pv12:5.2",
      "pali": "tattha me kiṁ phalaṁ siyā;"
    },
    {
      "id": "pv12:5.3",
      "pali": "Ñātimittasuhajjānaṁ,"
    },
    {
      "id": "pv12:5.4",
      "pali": "bhiyyo no aratī siyā."
    },
    {
      "id": "pv12:6.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "pv12:6.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "pv12:6.3",
      "pali": "Tasmā etaṁ na rodāmi,"
    },
    {
      "id": "pv12:6.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "pv12:7.1",
      "pali": "“Yathāpi dārako candaṁ,"
    },
    {
      "id": "pv12:7.2",
      "pali": "gacchantamanurodati;"
    },
    {
      "id": "pv12:7.3",
      "pali": "Evaṁ sampadamevetaṁ,"
    },
    {
      "id": "pv12:7.4",
      "pali": "yo petamanusocati."
    },
    {
      "id": "pv12:8.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "pv12:8.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "pv12:8.3",
      "pali": "Tasmā etaṁ na rodāmi,"
    },
    {
      "id": "pv12:8.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "pv12:9.1",
      "pali": "“Yathāpi brahme udakumbho,"
    },
    {
      "id": "pv12:9.2",
      "pali": "bhinno appaṭisandhiyo;"
    },
    {
      "id": "pv12:9.3",
      "pali": "Evaṁ sampadamevetaṁ,"
    },
    {
      "id": "pv12:9.4",
      "pali": "yo petamanusocati."
    },
    {
      "id": "pv12:10.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "pv12:10.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "pv12:10.3",
      "pali": "Tasmā etaṁ na rodāmi,"
    },
    {
      "id": "pv12:10.4",
      "pali": "gato so tassa yā gatī”ti."
    },
    {
      "id": "pv12:11.1",
      "pali": "Uragapetavatthu dvādasamaṁ."
    },
    {
      "id": "pv12:12.1",
      "pali": "Uragavaggo paṭhamo."
    },
    {
      "id": "pv12:13.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "pv12:14.1",
      "pali": "Khettañca sūkaraṁ pūti,"
    },
    {
      "id": "pv12:14.2",
      "pali": "piṭṭhaṁ cāpi tirokuṭṭaṁ;"
    },
    {
      "id": "pv12:14.3",
      "pali": "Pañcāpi sattaputtañca,"
    },
    {
      "id": "pv12:14.4",
      "pali": "goṇaṁ pesakārakañca;"
    },
    {
      "id": "pv12:14.5",
      "pali": "Tathā khallāṭiyaṁ nāgaṁ,"
    },
    {
      "id": "pv12:14.6",
      "pali": "dvādasaṁ uragañcevāti."
    }
  ]
}
