{
  "uid": "tha-ap95",
  "title": "3 Aḍḍhaceḷakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap95:1.1",
      "pali": "“Tissassāhaṁ bhagavato,"
    },
    {
      "id": "tha-ap95:1.2",
      "pali": "upaḍḍhadussamadāsahaṁ;"
    },
    {
      "id": "tha-ap95:1.3",
      "pali": "Paramakāpaññapattomhi,"
    },
    {
      "id": "tha-ap95:1.4",
      "pali": "duggatena samappito."
    },
    {
      "id": "tha-ap95:2.1",
      "pali": "Upaḍḍhadussaṁ datvāna,"
    },
    {
      "id": "tha-ap95:2.2",
      "pali": "kappaṁ saggamhi modahaṁ;"
    },
    {
      "id": "tha-ap95:2.3",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap95:2.4",
      "pali": "kusalaṁ kāritaṁ mayā."
    },
    {
      "id": "tha-ap95:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap95:3.2",
      "pali": "yaṁ dussamadadiṁ tadā;"
    },
    {
      "id": "tha-ap95:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap95:3.4",
      "pali": "dussadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap95:4.1",
      "pali": "Ekūnapaññāsakappamhi,"
    },
    {
      "id": "tha-ap95:4.2",
      "pali": "rājāno cakkavattino;"
    },
    {
      "id": "tha-ap95:4.3",
      "pali": "Samantacchadanā nāma,"
    },
    {
      "id": "tha-ap95:4.4",
      "pali": "bāttiṁsāsuṁ janādhipā."
    },
    {
      "id": "tha-ap95:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap95:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap95:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap95:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā aḍḍhaceḷako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap95:7.1",
      "pali": "Aḍḍhaceḷakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
