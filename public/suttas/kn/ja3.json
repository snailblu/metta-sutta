{
  "uid": "ja3",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja3:1.1",
      "pali": "“Idha ce naṁ virādhesi,"
    },
    {
      "id": "ja3:1.2",
      "pali": "saddhammassa niyāmataṁ;"
    },
    {
      "id": "ja3:1.3",
      "pali": "Ciraṁ tvaṁ anutappesi,"
    },
    {
      "id": "ja3:1.4",
      "pali": "serivāyaṁva vāṇijo”ti."
    },
    {
      "id": "ja3:2.1",
      "pali": "Serivavāṇijajātakaṁ tatiyaṁ."
    }
  ]
}
