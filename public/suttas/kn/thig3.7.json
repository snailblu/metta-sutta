{
  "uid": "thig3.7",
  "title": "Selātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.7:1.1",
      "pali": "“Natthi nissaraṇaṁ loke,"
    },
    {
      "id": "thig3.7:1.2",
      "pali": "kiṁ vivekena kāhasi;"
    },
    {
      "id": "thig3.7:1.3",
      "pali": "Bhuñjāhi kāmaratiyo,"
    },
    {
      "id": "thig3.7:1.4",
      "pali": "māhu pacchānutāpinī”."
    },
    {
      "id": "thig3.7:2.1",
      "pali": "“Sattisūlūpamā kāmā,"
    },
    {
      "id": "thig3.7:2.2",
      "pali": "khandhāsaṁ adhikuṭṭanā;"
    },
    {
      "id": "thig3.7:2.3",
      "pali": "Yaṁ tvaṁ ‘kāmaratiṁ’ brūsi,"
    },
    {
      "id": "thig3.7:2.4",
      "pali": "‘aratī’ dāni sā mama."
    },
    {
      "id": "thig3.7:3.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig3.7:3.2",
      "pali": "Tamokhandho padālito;"
    },
    {
      "id": "thig3.7:3.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig3.7:3.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "thig3.7:4.1",
      "pali": "… Selā therī …."
    }
  ]
}
