{
  "uid": "ja351",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja351:1.1",
      "pali": "“Jīno rathassaṁ maṇikuṇḍale ca,"
    },
    {
      "id": "ja351:1.2",
      "pali": "Putte ca dāre ca tatheva jīno;"
    },
    {
      "id": "ja351:1.3",
      "pali": "Sabbesu bhogesu asesakesu,"
    },
    {
      "id": "ja351:1.4",
      "pali": "Kasmā na santappasi sokakāle”."
    },
    {
      "id": "ja351:2.1",
      "pali": "“Pubbeva maccaṁ vijahanti bhogā,"
    },
    {
      "id": "ja351:2.2",
      "pali": "Macco vā te pubbataraṁ jahāti;"
    },
    {
      "id": "ja351:2.3",
      "pali": "Asassatā bhogino kāmakāmi,"
    },
    {
      "id": "ja351:2.4",
      "pali": "Tasmā na socāmahaṁ sokakāle."
    },
    {
      "id": "ja351:3.1",
      "pali": "Udeti āpūrati veti cando,"
    },
    {
      "id": "ja351:3.2",
      "pali": "Atthaṁ tapetvāna paleti sūriyo;"
    },
    {
      "id": "ja351:3.3",
      "pali": "Viditā mayā sattuka lokadhammā,"
    },
    {
      "id": "ja351:3.4",
      "pali": "Tasmā na socāmahaṁ sokakāle”."
    },
    {
      "id": "ja351:4.1",
      "pali": "“Alaso gihī kāmabhogī na sādhu,"
    },
    {
      "id": "ja351:4.2",
      "pali": "Asaññato pabbajito na sādhu;"
    },
    {
      "id": "ja351:4.3",
      "pali": "Rājā na sādhu anisammakārī,"
    },
    {
      "id": "ja351:4.4",
      "pali": "Yo paṇḍito kodhano taṁ na sādhu."
    },
    {
      "id": "ja351:5.1",
      "pali": "Nisamma khattiyo kayirā,"
    },
    {
      "id": "ja351:5.2",
      "pali": "nānisamma disampati;"
    },
    {
      "id": "ja351:5.3",
      "pali": "Nisammakārino rāja,"
    },
    {
      "id": "ja351:5.4",
      "pali": "yaso kitti ca vaḍḍhatī”ti."
    },
    {
      "id": "ja351:6.1",
      "pali": "Maṇikuṇḍalajātakaṁ paṭhamaṁ."
    }
  ]
}
