{
  "uid": "thi-ap28",
  "title": "Yasodharātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap28:1.1",
      "pali": "Ekasmiṁ samaye ramme,"
    },
    {
      "id": "thi-ap28:1.2",
      "pali": "iddhe rājagahe pure;"
    },
    {
      "id": "thi-ap28:1.3",
      "pali": "Pabbhāramhi varekamhi,"
    },
    {
      "id": "thi-ap28:1.4",
      "pali": "vasante naranāyake."
    },
    {
      "id": "thi-ap28:2.1",
      "pali": "Vasantiyā tamhi nagare,"
    },
    {
      "id": "thi-ap28:2.2",
      "pali": "ramme bhikkhunupassaye;"
    },
    {
      "id": "thi-ap28:2.3",
      "pali": "Yasodharābhikkhuniyā,"
    },
    {
      "id": "thi-ap28:2.4",
      "pali": "evaṁ āsi vitakkitaṁ."
    },
    {
      "id": "thi-ap28:3.1",
      "pali": "“Suddhodano mahārājā,"
    },
    {
      "id": "thi-ap28:3.2",
      "pali": "gotamī ca pajāpatī;"
    },
    {
      "id": "thi-ap28:3.3",
      "pali": "Abhiññātā mahātherā,"
    },
    {
      "id": "thi-ap28:3.4",
      "pali": "theriyo ca mahiddhikā."
    },
    {
      "id": "thi-ap28:4.1",
      "pali": "Santiṁ gatāva āsuṁ te,"
    },
    {
      "id": "thi-ap28:4.2",
      "pali": "dīpaccīva nirāsavā;"
    },
    {
      "id": "thi-ap28:4.3",
      "pali": "Lokanāthe dharanteva,"
    },
    {
      "id": "thi-ap28:4.4",
      "pali": "ahampi ca sivaṁ padaṁ."
    },
    {
      "id": "thi-ap28:5.1",
      "pali": "Gamissāmī”ti cintetvā,"
    },
    {
      "id": "thi-ap28:5.2",
      "pali": "passantī āyumattano;"
    },
    {
      "id": "thi-ap28:5.3",
      "pali": "Passitvā āyusaṅkhāraṁ,"
    },
    {
      "id": "thi-ap28:5.4",
      "pali": "tadaheva khayaṁ gataṁ."
    },
    {
      "id": "thi-ap28:6.1",
      "pali": "Pattacīvaramādāya,"
    },
    {
      "id": "thi-ap28:6.2",
      "pali": "nikkhamitvā sakassamā;"
    },
    {
      "id": "thi-ap28:6.3",
      "pali": "Purakkhatā bhikkhunībhi,"
    },
    {
      "id": "thi-ap28:6.4",
      "pali": "satehi sahassehi sā."
    },
    {
      "id": "thi-ap28:7.1",
      "pali": "Mahiddhikā mahāpaññā,"
    },
    {
      "id": "thi-ap28:7.2",
      "pali": "sambuddhaṁ upasaṅkami;"
    },
    {
      "id": "thi-ap28:7.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "thi-ap28:7.4",
      "pali": "satthuno cakkalakkhaṇe;"
    },
    {
      "id": "thi-ap28:7.5",
      "pali": "Nisinnā ekamantamhi,"
    },
    {
      "id": "thi-ap28:7.6",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "thi-ap28:8.1",
      "pali": "“Aṭṭhasattativassāhaṁ,"
    },
    {
      "id": "thi-ap28:8.2",
      "pali": "pacchimo vattate vayo;"
    },
    {
      "id": "thi-ap28:8.3",
      "pali": "Pabbhāramhi anuppattā,"
    },
    {
      "id": "thi-ap28:8.4",
      "pali": "ārocemi mahāmuni."
    },
    {
      "id": "thi-ap28:9.1",
      "pali": "Paripakko vayo mayhaṁ,"
    },
    {
      "id": "thi-ap28:9.2",
      "pali": "parittaṁ mama jīvitaṁ;"
    },
    {
      "id": "thi-ap28:9.3",
      "pali": "Pahāya vo gamissāmi,"
    },
    {
      "id": "thi-ap28:9.4",
      "pali": "kataṁ me saraṇamattano."
    },
    {
      "id": "thi-ap28:10.1",
      "pali": "Vayamhi pacchime kāle,"
    },
    {
      "id": "thi-ap28:10.2",
      "pali": "maraṇaṁ uparuddhati;"
    },
    {
      "id": "thi-ap28:10.3",
      "pali": "Ajjarattiṁ mahāvīra,"
    },
    {
      "id": "thi-ap28:10.4",
      "pali": "pāpuṇissāmi nibbutiṁ."
    },
    {
      "id": "thi-ap28:11.1",
      "pali": "Natthi jāti jarā byādhi,"
    },
    {
      "id": "thi-ap28:11.2",
      "pali": "maraṇañca mahāmune;"
    },
    {
      "id": "thi-ap28:11.3",
      "pali": "Ajarāmaraṇaṁ puraṁ,"
    },
    {
      "id": "thi-ap28:11.4",
      "pali": "gamissāmi asaṅkhataṁ."
    },
    {
      "id": "thi-ap28:12.1",
      "pali": "Yāvatā parisā nāma,"
    },
    {
      "id": "thi-ap28:12.2",
      "pali": "samupāsanti satthuno;"
    },
    {
      "id": "thi-ap28:12.3",
      "pali": "Aparādhamajānantī,"
    },
    {
      "id": "thi-ap28:12.4",
      "pali": "khamantaṁ sammukhā mune."
    },
    {
      "id": "thi-ap28:13.1",
      "pali": "Saṁsaritvā ca saṁsāre,"
    },
    {
      "id": "thi-ap28:13.2",
      "pali": "khalitañce mamaṁ tayi;"
    },
    {
      "id": "thi-ap28:13.3",
      "pali": "Ārocemi mahāvīra,"
    },
    {
      "id": "thi-ap28:13.4",
      "pali": "aparādhaṁ khamassu me”."
    },
    {
      "id": "thi-ap28:14.1",
      "pali": "Sutvāna vacanaṁ tassā,"
    },
    {
      "id": "thi-ap28:14.2",
      "pali": "munindo idamabravi;"
    },
    {
      "id": "thi-ap28:14.3",
      "pali": "“Kimuttaraṁ te vakkhāmi,"
    },
    {
      "id": "thi-ap28:14.4",
      "pali": "nibbānāya vajantiyā."
    },
    {
      "id": "thi-ap28:15.1",
      "pali": "Iddhiñcāpi nidassehi,"
    },
    {
      "id": "thi-ap28:15.2",
      "pali": "mama sāsanakārike;"
    },
    {
      "id": "thi-ap28:15.3",
      "pali": "Parisānañca sabbāsaṁ,"
    },
    {
      "id": "thi-ap28:15.4",
      "pali": "kaṅkhaṁ chindassu yāvatā”."
    },
    {
      "id": "thi-ap28:16.1",
      "pali": "Sutvā taṁ munino vācaṁ,"
    },
    {
      "id": "thi-ap28:16.2",
      "pali": "bhikkhunī sā yasodharā;"
    },
    {
      "id": "thi-ap28:16.3",
      "pali": "Vanditvā munirājaṁ taṁ,"
    },
    {
      "id": "thi-ap28:16.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "thi-ap28:17.1",
      "pali": "“Yasodharā ahaṁ vīra,"
    },
    {
      "id": "thi-ap28:17.2",
      "pali": "agāre te pajāpati;"
    },
    {
      "id": "thi-ap28:17.3",
      "pali": "Sākiyamhi kule jātā,"
    },
    {
      "id": "thi-ap28:17.4",
      "pali": "itthiaṅge patiṭṭhitā."
    },
    {
      "id": "thi-ap28:18.1",
      "pali": "Thīnaṁ satasahassānaṁ,"
    },
    {
      "id": "thi-ap28:18.2",
      "pali": "navutīnaṁ chaduttari;"
    },
    {
      "id": "thi-ap28:18.3",
      "pali": "Agāre te ahaṁ vīra,"
    },
    {
      "id": "thi-ap28:18.4",
      "pali": "pāmokkhā sabbā issarā."
    },
    {
      "id": "thi-ap28:19.1",
      "pali": "Rūpācāraguṇūpetā,"
    },
    {
      "id": "thi-ap28:19.2",
      "pali": "yobbanaṭṭhā piyaṁvadā;"
    },
    {
      "id": "thi-ap28:19.3",
      "pali": "Sabbā maṁ apacāyanti,"
    },
    {
      "id": "thi-ap28:19.4",
      "pali": "devatā viya mānusā."
    },
    {
      "id": "thi-ap28:20.1",
      "pali": "Kaññāsatasahassapamukhā,"
    },
    {
      "id": "thi-ap28:20.2",
      "pali": "Sakyaputtanivesane;"
    },
    {
      "id": "thi-ap28:20.3",
      "pali": "Samānasukhadukkhatā,"
    },
    {
      "id": "thi-ap28:20.4",
      "pali": "Devatā viya nandane."
    },
    {
      "id": "thi-ap28:21.1",
      "pali": "Kāmadhātumatikkamma,"
    },
    {
      "id": "thi-ap28:21.2",
      "pali": "saṇṭhitā rūpadhātuyā;"
    },
    {
      "id": "thi-ap28:21.3",
      "pali": "Rūpena sadisā natthi,"
    },
    {
      "id": "thi-ap28:21.4",
      "pali": "ṭhapetvā lokanāyakaṁ”."
    },
    {
      "id": "thi-ap28:22.1",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "thi-ap28:22.2",
      "pali": "iddhiṁ dassesi satthuno;"
    },
    {
      "id": "thi-ap28:22.3",
      "pali": "Nekā nānāvidhākārā,"
    },
    {
      "id": "thi-ap28:22.4",
      "pali": "mahāiddhīpi dassayī."
    },
    {
      "id": "thi-ap28:23.1",
      "pali": "Cakkavāḷasamaṁ kāyaṁ,"
    },
    {
      "id": "thi-ap28:23.2",
      "pali": "sīsaṁ uttarato kuru;"
    },
    {
      "id": "thi-ap28:23.3",
      "pali": "Ubho pakkhā duve dīpā,"
    },
    {
      "id": "thi-ap28:23.4",
      "pali": "jambudīpaṁ sarīrato."
    },
    {
      "id": "thi-ap28:24.1",
      "pali": "Dakkhiṇañca saraṁ piñchaṁ,"
    },
    {
      "id": "thi-ap28:24.2",
      "pali": "nānāsākhā tu pattakā;"
    },
    {
      "id": "thi-ap28:24.3",
      "pali": "Candañca sūriyañcakkhi,"
    },
    {
      "id": "thi-ap28:24.4",
      "pali": "merupabbatato sikhaṁ."
    },
    {
      "id": "thi-ap28:25.1",
      "pali": "Cakkavāḷagiriṁ tuṇḍaṁ,"
    },
    {
      "id": "thi-ap28:25.2",
      "pali": "jamburukkhaṁ samūlakaṁ;"
    },
    {
      "id": "thi-ap28:25.3",
      "pali": "Bījamānā upāgantvā,"
    },
    {
      "id": "thi-ap28:25.4",
      "pali": "vandantī lokanāyakaṁ."
    },
    {
      "id": "thi-ap28:26.1",
      "pali": "Hatthivaṇṇaṁ tathevassaṁ,"
    },
    {
      "id": "thi-ap28:26.2",
      "pali": "pabbataṁ jaladhiṁ tathā;"
    },
    {
      "id": "thi-ap28:26.3",
      "pali": "Candimaṁ sūriyaṁ meruṁ,"
    },
    {
      "id": "thi-ap28:26.4",
      "pali": "sakkavaṇṇañca dassayi."
    },
    {
      "id": "thi-ap28:27.1",
      "pali": "“Yasodharā ahaṁ vīra,"
    },
    {
      "id": "thi-ap28:27.2",
      "pali": "pāde vandāmi cakkhuma”;"
    },
    {
      "id": "thi-ap28:27.3",
      "pali": "Sahassalokadhātūnaṁ,"
    },
    {
      "id": "thi-ap28:27.4",
      "pali": "phullapadmena chādayi."
    },
    {
      "id": "thi-ap28:28.1",
      "pali": "Brahmavaṇṇañca māpetvā,"
    },
    {
      "id": "thi-ap28:28.2",
      "pali": "dhammaṁ desesi suññataṁ;"
    },
    {
      "id": "thi-ap28:28.3",
      "pali": "“Yasodharā ahaṁ vīra,"
    },
    {
      "id": "thi-ap28:28.4",
      "pali": "pāde vandāmi cakkhuma."
    },
    {
      "id": "thi-ap28:29.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap28:29.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap28:29.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap28:29.4",
      "pali": "vasī homi mahāmuni."
    },
    {
      "id": "thi-ap28:30.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap28:30.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap28:30.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap28:30.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap28:31.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap28:31.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap28:31.3",
      "pali": "Ñāṇaṁ mayhaṁ mahāvīra,"
    },
    {
      "id": "thi-ap28:31.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap28:32.1",
      "pali": "Pubbānaṁ lokanāthānaṁ,"
    },
    {
      "id": "thi-ap28:32.2",
      "pali": "saṅgamaṁ te nidassitaṁ;"
    },
    {
      "id": "thi-ap28:32.3",
      "pali": "Adhikāraṁ bahuṁ mayhaṁ,"
    },
    {
      "id": "thi-ap28:32.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap28:33.1",
      "pali": "Yaṁ mayhaṁ pūritaṁ kammaṁ,"
    },
    {
      "id": "thi-ap28:33.2",
      "pali": "Kusalaṁ sarase mune;"
    },
    {
      "id": "thi-ap28:33.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap28:33.4",
      "pali": "Puññaṁ upacitaṁ mayā."
    },
    {
      "id": "thi-ap28:34.1",
      "pali": "Abhabbaṭṭhāne vajjetvā,"
    },
    {
      "id": "thi-ap28:34.2",
      "pali": "vārayitvā anācaraṁ;"
    },
    {
      "id": "thi-ap28:34.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap28:34.4",
      "pali": "sañcattaṁ jīvitaṁ mayā."
    },
    {
      "id": "thi-ap28:35.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap28:35.2",
      "pali": "bhariyatthāyadāsi maṁ;"
    },
    {
      "id": "thi-ap28:35.3",
      "pali": "Na tattha vimanā homi,"
    },
    {
      "id": "thi-ap28:35.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap28:36.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap28:36.2",
      "pali": "upakārāyadāsi maṁ;"
    },
    {
      "id": "thi-ap28:36.3",
      "pali": "Na tattha vimanā homi,"
    },
    {
      "id": "thi-ap28:36.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap28:37.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap28:37.2",
      "pali": "bhojanatthāyadāsi maṁ;"
    },
    {
      "id": "thi-ap28:37.3",
      "pali": "Na tattha vimanā homi,"
    },
    {
      "id": "thi-ap28:37.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap28:38.1",
      "pali": "Nekakoṭisahassāni,"
    },
    {
      "id": "thi-ap28:38.2",
      "pali": "jīvitāni pariccajiṁ;"
    },
    {
      "id": "thi-ap28:38.3",
      "pali": "Bhayamokkhaṁ karissanti,"
    },
    {
      "id": "thi-ap28:38.4",
      "pali": "dadāmi mama jīvitaṁ."
    },
    {
      "id": "thi-ap28:39.1",
      "pali": "Aṅgagate alaṅkāre,"
    },
    {
      "id": "thi-ap28:39.2",
      "pali": "vatthe nānāvidhe bahū;"
    },
    {
      "id": "thi-ap28:39.3",
      "pali": "Itthimaṇḍe na gūhāmi,"
    },
    {
      "id": "thi-ap28:39.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap28:40.1",
      "pali": "Dhanadhaññapariccāgaṁ,"
    },
    {
      "id": "thi-ap28:40.2",
      "pali": "gāmāni nigamāni ca;"
    },
    {
      "id": "thi-ap28:40.3",
      "pali": "Khettaṁ puttā ca dhītā ca,"
    },
    {
      "id": "thi-ap28:40.4",
      "pali": "pariccattā mahāmuni."
    },
    {
      "id": "thi-ap28:41.1",
      "pali": "Hatthī assā gavā cāpi,"
    },
    {
      "id": "thi-ap28:41.2",
      "pali": "dāsiyo paricārikā;"
    },
    {
      "id": "thi-ap28:41.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap28:41.4",
      "pali": "pariccattā asaṅkhiyā."
    },
    {
      "id": "thi-ap28:42.1",
      "pali": "Yaṁ mayhaṁ paṭimantesi,"
    },
    {
      "id": "thi-ap28:42.2",
      "pali": "dānaṁ dassāmi yācake;"
    },
    {
      "id": "thi-ap28:42.3",
      "pali": "Vimanaṁ me na passāmi,"
    },
    {
      "id": "thi-ap28:42.4",
      "pali": "dadato dānamuttamaṁ."
    },
    {
      "id": "thi-ap28:43.1",
      "pali": "Nānāvidhaṁ bahuṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap28:43.2",
      "pali": "saṁsāre ca bahubbidhe;"
    },
    {
      "id": "thi-ap28:43.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap28:43.4",
      "pali": "anubhuttaṁ asaṅkhiyaṁ."
    },
    {
      "id": "thi-ap28:44.1",
      "pali": "Sukhappattānumodāmi,"
    },
    {
      "id": "thi-ap28:44.2",
      "pali": "na ca dukkhesu dummanā;"
    },
    {
      "id": "thi-ap28:44.3",
      "pali": "Sabbattha tulitā homi,"
    },
    {
      "id": "thi-ap28:44.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap28:45.1",
      "pali": "Anumaggena sambuddho,"
    },
    {
      "id": "thi-ap28:45.2",
      "pali": "yaṁ dhammaṁ abhinīhari;"
    },
    {
      "id": "thi-ap28:45.3",
      "pali": "Anubhotvā sukhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap28:45.4",
      "pali": "patto bodhiṁ mahāmuni."
    },
    {
      "id": "thi-ap28:46.1",
      "pali": "Brahmadevañca sambuddhaṁ,"
    },
    {
      "id": "thi-ap28:46.2",
      "pali": "gotamaṁ lokanāyakaṁ;"
    },
    {
      "id": "thi-ap28:46.3",
      "pali": "Aññesaṁ lokanāthānaṁ,"
    },
    {
      "id": "thi-ap28:46.4",
      "pali": "saṅgamaṁ te bahuṁ mayā."
    },
    {
      "id": "thi-ap28:47.1",
      "pali": "Adhikāraṁ bahuṁ mayhaṁ,"
    },
    {
      "id": "thi-ap28:47.2",
      "pali": "tuyhatthāya mahāmuni;"
    },
    {
      "id": "thi-ap28:47.3",
      "pali": "Gavesato buddhadhamme,"
    },
    {
      "id": "thi-ap28:47.4",
      "pali": "ahaṁ te paricārikā."
    },
    {
      "id": "thi-ap28:48.1",
      "pali": "Kappe ca satasahasse,"
    },
    {
      "id": "thi-ap28:48.2",
      "pali": "caturo ca asaṅkhiye;"
    },
    {
      "id": "thi-ap28:48.3",
      "pali": "Dīpaṅkaro mahāvīro,"
    },
    {
      "id": "thi-ap28:48.4",
      "pali": "uppajji lokanāyako."
    },
    {
      "id": "thi-ap28:49.1",
      "pali": "Paccantadesavisaye,"
    },
    {
      "id": "thi-ap28:49.2",
      "pali": "nimantetvā tathāgataṁ;"
    },
    {
      "id": "thi-ap28:49.3",
      "pali": "Tassa āgamanaṁ maggaṁ,"
    },
    {
      "id": "thi-ap28:49.4",
      "pali": "sodhenti tuṭṭhamānasā."
    },
    {
      "id": "thi-ap28:50.1",
      "pali": "Tena kālena so āsi,"
    },
    {
      "id": "thi-ap28:50.2",
      "pali": "sumedho nāma brāhmaṇo;"
    },
    {
      "id": "thi-ap28:50.3",
      "pali": "Maggañca paṭiyādesi,"
    },
    {
      "id": "thi-ap28:50.4",
      "pali": "āyato sabbadassino."
    },
    {
      "id": "thi-ap28:51.1",
      "pali": "Tena kālenahaṁ āsiṁ,"
    },
    {
      "id": "thi-ap28:51.2",
      "pali": "kaññā brāhmaṇasambhavā;"
    },
    {
      "id": "thi-ap28:51.3",
      "pali": "Sumittā nāma nāmena,"
    },
    {
      "id": "thi-ap28:51.4",
      "pali": "upagacchiṁ samāgamaṁ."
    },
    {
      "id": "thi-ap28:52.1",
      "pali": "Aṭṭha uppalahatthāni,"
    },
    {
      "id": "thi-ap28:52.2",
      "pali": "pūjanatthāya satthuno;"
    },
    {
      "id": "thi-ap28:52.3",
      "pali": "Ādāya janasammajjhe,"
    },
    {
      "id": "thi-ap28:52.4",
      "pali": "addasaṁ isimuggataṁ."
    },
    {
      "id": "thi-ap28:53.1",
      "pali": "Cirānugataṁ dayitaṁ,"
    },
    {
      "id": "thi-ap28:53.2",
      "pali": "atikkantaṁ manoharaṁ;"
    },
    {
      "id": "thi-ap28:53.3",
      "pali": "Disvā tadā amaññissaṁ,"
    },
    {
      "id": "thi-ap28:53.4",
      "pali": "saphalaṁ jīvitaṁ mama."
    },
    {
      "id": "thi-ap28:54.1",
      "pali": "Parakkamaṁ taṁ saphalaṁ,"
    },
    {
      "id": "thi-ap28:54.2",
      "pali": "addasaṁ isino tadā;"
    },
    {
      "id": "thi-ap28:54.3",
      "pali": "Pubbakammena sambuddhe,"
    },
    {
      "id": "thi-ap28:54.4",
      "pali": "cittañcāpi pasīdi me."
    },
    {
      "id": "thi-ap28:55.1",
      "pali": "Bhiyyo cittaṁ pasādesiṁ,"
    },
    {
      "id": "thi-ap28:55.2",
      "pali": "ise uggatamānase;"
    },
    {
      "id": "thi-ap28:55.3",
      "pali": "Deyyaṁ aññaṁ na passāmi,"
    },
    {
      "id": "thi-ap28:55.4",
      "pali": "demi pupphāni te isi."
    },
    {
      "id": "thi-ap28:56.1",
      "pali": "‘Pañca hatthā tava hontu,"
    },
    {
      "id": "thi-ap28:56.2",
      "pali": "tayo hontu mamaṁ ise;"
    },
    {
      "id": "thi-ap28:56.3",
      "pali": "Tena saddhiṁ samā hontu,"
    },
    {
      "id": "thi-ap28:56.4",
      "pali": "bodhatthāya tavaṁ ise’."
    },
    {
      "id": "thi-ap28:57.1",
      "pali": "Catutthaṁ bhāṇavāraṁ."
    },
    {
      "id": "thi-ap28:58.1",
      "pali": "Isi gahetvā pupphāni,"
    },
    {
      "id": "thi-ap28:58.2",
      "pali": "āgacchantaṁ mahāyasaṁ;"
    },
    {
      "id": "thi-ap28:58.3",
      "pali": "Pūjesi janasammajjhe,"
    },
    {
      "id": "thi-ap28:58.4",
      "pali": "bodhatthāya mahāisi."
    },
    {
      "id": "thi-ap28:59.1",
      "pali": "Passitvā janasammajjhe,"
    },
    {
      "id": "thi-ap28:59.2",
      "pali": "dīpaṅkaro mahāmuni;"
    },
    {
      "id": "thi-ap28:59.3",
      "pali": "Viyākāsi mahāvīro,"
    },
    {
      "id": "thi-ap28:59.4",
      "pali": "isi muggatamānasaṁ."
    },
    {
      "id": "thi-ap28:60.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "thi-ap28:60.2",
      "pali": "dīpaṅkaro mahāmuni;"
    },
    {
      "id": "thi-ap28:60.3",
      "pali": "Mama kammaṁ viyākāsi,"
    },
    {
      "id": "thi-ap28:60.4",
      "pali": "ujubhāvaṁ mahāmuni."
    },
    {
      "id": "thi-ap28:61.1",
      "pali": "‘Samacittā samakammā,"
    },
    {
      "id": "thi-ap28:61.2",
      "pali": "samakārī bhavissati;"
    },
    {
      "id": "thi-ap28:61.3",
      "pali": "Piyā hessati kammena,"
    },
    {
      "id": "thi-ap28:61.4",
      "pali": "tuyhatthāya mahāisi."
    },
    {
      "id": "thi-ap28:62.1",
      "pali": "Sudassanā supiyā ca,"
    },
    {
      "id": "thi-ap28:62.2",
      "pali": "manāpā piyavādinī;"
    },
    {
      "id": "thi-ap28:62.3",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap28:62.4",
      "pali": "viharissati iddhikā."
    },
    {
      "id": "thi-ap28:63.1",
      "pali": "Yathāpi bhaṇḍasāmuggaṁ,"
    },
    {
      "id": "thi-ap28:63.2",
      "pali": "anurakkhati sāmino;"
    },
    {
      "id": "thi-ap28:63.3",
      "pali": "Evaṁ kusaladhammānaṁ,"
    },
    {
      "id": "thi-ap28:63.4",
      "pali": "anurakkhissate ayaṁ."
    },
    {
      "id": "thi-ap28:64.1",
      "pali": "Tassa te anukampantī,"
    },
    {
      "id": "thi-ap28:64.2",
      "pali": "pūrayissati pāramī;"
    },
    {
      "id": "thi-ap28:64.3",
      "pali": "Sīhova pañjaraṁ bhetvā,"
    },
    {
      "id": "thi-ap28:64.4",
      "pali": "pāpuṇissati bodhiyaṁ’."
    },
    {
      "id": "thi-ap28:65.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "thi-ap28:65.2",
      "pali": "yaṁ maṁ buddho viyākarī;"
    },
    {
      "id": "thi-ap28:65.3",
      "pali": "Taṁ vācaṁ anumodentī,"
    },
    {
      "id": "thi-ap28:65.4",
      "pali": "evaṅkārī bhaviṁ ahaṁ."
    },
    {
      "id": "thi-ap28:66.1",
      "pali": "Tassa kammassa sukatassa,"
    },
    {
      "id": "thi-ap28:66.2",
      "pali": "tattha cittaṁ pasādayiṁ;"
    },
    {
      "id": "thi-ap28:66.3",
      "pali": "Devamanussakaṁ yoniṁ,"
    },
    {
      "id": "thi-ap28:66.4",
      "pali": "anubhotvā asaṅkhiyaṁ."
    },
    {
      "id": "thi-ap28:67.1",
      "pali": "Sukhadukkhenubhotvāhaṁ,"
    },
    {
      "id": "thi-ap28:67.2",
      "pali": "devesu mānusesu ca;"
    },
    {
      "id": "thi-ap28:67.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap28:67.4",
      "pali": "ajāyiṁ sākiye kule."
    },
    {
      "id": "thi-ap28:68.1",
      "pali": "Rūpavatī bhogavatī,"
    },
    {
      "id": "thi-ap28:68.2",
      "pali": "yasasīlavatī tato;"
    },
    {
      "id": "thi-ap28:68.3",
      "pali": "Sabbaṅgasampadā homi,"
    },
    {
      "id": "thi-ap28:68.4",
      "pali": "kulesu abhisakkatā."
    },
    {
      "id": "thi-ap28:69.1",
      "pali": "Lābhaṁ silokaṁ sakkāraṁ,"
    },
    {
      "id": "thi-ap28:69.2",
      "pali": "lokadhammasamāgamaṁ;"
    },
    {
      "id": "thi-ap28:69.3",
      "pali": "Cittañca dukkhitaṁ natthi,"
    },
    {
      "id": "thi-ap28:69.4",
      "pali": "vasāmi akutobhayā."
    },
    {
      "id": "thi-ap28:70.1",
      "pali": "Vuttañhetaṁ bhagavatā,"
    },
    {
      "id": "thi-ap28:70.2",
      "pali": "‘rañño antepure tadā;"
    },
    {
      "id": "thi-ap28:70.3",
      "pali": "Khattiyānaṁ pure vīra,"
    },
    {
      "id": "thi-ap28:70.4",
      "pali": "upakārañca niddisi."
    },
    {
      "id": "thi-ap28:71.1",
      "pali": "Upakārā ca yā nārī,"
    },
    {
      "id": "thi-ap28:71.2",
      "pali": "yā ca nārī sukhe dukhe;"
    },
    {
      "id": "thi-ap28:71.3",
      "pali": "Atthakkhāyī ca yā nārī,"
    },
    {
      "id": "thi-ap28:71.4",
      "pali": "yā ca nārīnukampikā’."
    },
    {
      "id": "thi-ap28:72.1",
      "pali": "Pañcakoṭisatā buddhā,"
    },
    {
      "id": "thi-ap28:72.2",
      "pali": "navakoṭisatāni ca;"
    },
    {
      "id": "thi-ap28:72.3",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:72.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "thi-ap28:73.1",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:73.2",
      "pali": "dhammarāja suṇohi me;"
    },
    {
      "id": "thi-ap28:73.3",
      "pali": "Ekādasakoṭisatā,"
    },
    {
      "id": "thi-ap28:73.4",
      "pali": "buddhā dvādasa koṭiyo."
    },
    {
      "id": "thi-ap28:74.1",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:74.2",
      "pali": "mahādānaṁ pavattayiṁ;"
    },
    {
      "id": "thi-ap28:74.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:74.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:75.1",
      "pali": "Vīsakoṭisatā buddhā,"
    },
    {
      "id": "thi-ap28:75.2",
      "pali": "tiṁsakoṭisatāni ca;"
    },
    {
      "id": "thi-ap28:75.3",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:75.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "thi-ap28:76.1",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:76.2",
      "pali": "dhammarāja suṇohi me;"
    },
    {
      "id": "thi-ap28:76.3",
      "pali": "Cattālīsakoṭisatā,"
    },
    {
      "id": "thi-ap28:76.4",
      "pali": "paññāsa koṭisatāni ca."
    },
    {
      "id": "thi-ap28:77.1",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:77.2",
      "pali": "mahādānaṁ pavattayiṁ;"
    },
    {
      "id": "thi-ap28:77.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:77.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:78.1",
      "pali": "Saṭṭhikoṭisatā buddhā,"
    },
    {
      "id": "thi-ap28:78.2",
      "pali": "sattatikoṭisatāni ca;"
    },
    {
      "id": "thi-ap28:78.3",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:78.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "thi-ap28:79.1",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:79.2",
      "pali": "dhammarāja suṇohi me;"
    },
    {
      "id": "thi-ap28:79.3",
      "pali": "Asītikoṭisatā buddhā,"
    },
    {
      "id": "thi-ap28:79.4",
      "pali": "navutikoṭisatāni ca."
    },
    {
      "id": "thi-ap28:80.1",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:80.2",
      "pali": "mahādānaṁ pavattayiṁ;"
    },
    {
      "id": "thi-ap28:80.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:80.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:81.1",
      "pali": "Koṭisatasahassāni,"
    },
    {
      "id": "thi-ap28:81.2",
      "pali": "honti lokagganāyakā;"
    },
    {
      "id": "thi-ap28:81.3",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:81.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "thi-ap28:82.1",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:82.2",
      "pali": "dhammarāja suṇohi me;"
    },
    {
      "id": "thi-ap28:82.3",
      "pali": "Navakoṭisahassāni,"
    },
    {
      "id": "thi-ap28:82.4",
      "pali": "apare lokanāyakā."
    },
    {
      "id": "thi-ap28:83.1",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:83.2",
      "pali": "mahādānaṁ pavattayiṁ;"
    },
    {
      "id": "thi-ap28:83.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:83.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:84.1",
      "pali": "Koṭisatasahassāni,"
    },
    {
      "id": "thi-ap28:84.2",
      "pali": "pañcāsītimahesinaṁ;"
    },
    {
      "id": "thi-ap28:84.3",
      "pali": "Pañcāsītikoṭisatā,"
    },
    {
      "id": "thi-ap28:84.4",
      "pali": "sattatiṁsā ca koṭiyo."
    },
    {
      "id": "thi-ap28:85.1",
      "pali": "Etesaṁ devadevānaṁ,"
    },
    {
      "id": "thi-ap28:85.2",
      "pali": "mahādānaṁ pavattayiṁ;"
    },
    {
      "id": "thi-ap28:85.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:85.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:86.1",
      "pali": "Paccekabuddhā vītarāgā,"
    },
    {
      "id": "thi-ap28:86.2",
      "pali": "aṭṭhaṭṭhamakakoṭiyo;"
    },
    {
      "id": "thi-ap28:86.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:86.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:87.1",
      "pali": "Khīṇāsavā vītamalā,"
    },
    {
      "id": "thi-ap28:87.2",
      "pali": "asaṅkhiyā buddhasāvakā;"
    },
    {
      "id": "thi-ap28:87.3",
      "pali": "Adhikāraṁ mahā mayhaṁ,"
    },
    {
      "id": "thi-ap28:87.4",
      "pali": "dhammarāja suṇohi me."
    },
    {
      "id": "thi-ap28:88.1",
      "pali": "Evaṁ dhamme suciṇṇānaṁ,"
    },
    {
      "id": "thi-ap28:88.2",
      "pali": "sadā dhammassa cārinaṁ;"
    },
    {
      "id": "thi-ap28:88.3",
      "pali": "Dhammacārī sukhaṁ seti,"
    },
    {
      "id": "thi-ap28:88.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "thi-ap28:89.1",
      "pali": "Dhammaṁ care sucaritaṁ,"
    },
    {
      "id": "thi-ap28:89.2",
      "pali": "na naṁ duccaritaṁ care;"
    },
    {
      "id": "thi-ap28:89.3",
      "pali": "Dhammacārī sukhaṁ seti,"
    },
    {
      "id": "thi-ap28:89.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "thi-ap28:90.1",
      "pali": "Nibbinditvāna saṁsāre,"
    },
    {
      "id": "thi-ap28:90.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap28:90.3",
      "pali": "Sahassaparivārena,"
    },
    {
      "id": "thi-ap28:90.4",
      "pali": "pabbajitvā akiñcanā."
    },
    {
      "id": "thi-ap28:91.1",
      "pali": "Agāraṁ vijahitvāna,"
    },
    {
      "id": "thi-ap28:91.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap28:91.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "thi-ap28:91.4",
      "pali": "catusaccamapāpuṇiṁ."
    },
    {
      "id": "thi-ap28:92.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap28:92.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap28:92.3",
      "pali": "Upanenti bahū janā,"
    },
    {
      "id": "thi-ap28:92.4",
      "pali": "sāgareyeva ūmiyo."
    },
    {
      "id": "thi-ap28:93.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap28:93.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap28:93.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap28:94.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap28:94.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap28:94.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap28:95.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap28:95.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap28:95.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap28:96.1",
      "pali": "Evaṁ bahuvidhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap28:96.2",
      "pali": "sampattī ca bahubbidhā;"
    },
    {
      "id": "thi-ap28:96.3",
      "pali": "Visuddhibhāvaṁ sampattā,"
    },
    {
      "id": "thi-ap28:96.4",
      "pali": "labhāmi sabbasampadā."
    },
    {
      "id": "thi-ap28:97.1",
      "pali": "Yā dadāti sakattānaṁ,"
    },
    {
      "id": "thi-ap28:97.2",
      "pali": "puññatthāya mahesino;"
    },
    {
      "id": "thi-ap28:97.3",
      "pali": "Sahāyasampadā honti,"
    },
    {
      "id": "thi-ap28:97.4",
      "pali": "nibbānapadamasaṅkhataṁ."
    },
    {
      "id": "thi-ap28:98.1",
      "pali": "Parikkhīṇaṁ atītañca,"
    },
    {
      "id": "thi-ap28:98.2",
      "pali": "Paccuppannaṁ anāgataṁ;"
    },
    {
      "id": "thi-ap28:98.3",
      "pali": "Sabbakammaṁ mamaṁ khīṇaṁ,"
    },
    {
      "id": "thi-ap28:98.4",
      "pali": "Pāde vandāmi cakkhuma”."
    },
    {
      "id": "thi-ap28:99.1",
      "pali": "Itthaṁ sudaṁ yasodharā bhikkhunī bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap28:100.1",
      "pali": "Yasodharātheriyāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
