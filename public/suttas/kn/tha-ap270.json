{
  "uid": "tha-ap270",
  "title": "8 Saḷalapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap270:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap270:1.2",
      "pali": "ahosiṁ kinnaro tadā;"
    },
    {
      "id": "tha-ap270:1.3",
      "pali": "Vipassiṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap270:1.4",
      "pali": "raṁsijālasamākulaṁ."
    },
    {
      "id": "tha-ap270:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap270:2.2",
      "pali": "paramāya ca pītiyā;"
    },
    {
      "id": "tha-ap270:2.3",
      "pali": "Paggayha saḷalaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap270:2.4",
      "pali": "vipassiṁ okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap270:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap270:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap270:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap270:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap270:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap270:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap270:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap270:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā saḷalapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap270:6.1",
      "pali": "Saḷalapupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
