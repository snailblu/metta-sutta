{
  "uid": "ja170",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja170:1.1",
      "pali": "“Nāyaṁ pure uṇṇamati,"
    },
    {
      "id": "ja170:1.2",
      "pali": "toraṇagge kakaṇṭako;"
    },
    {
      "id": "ja170:1.3",
      "pali": "Mahosadha vijānāhi,"
    },
    {
      "id": "ja170:1.4",
      "pali": "kena thaddho kakaṇṭako”."
    },
    {
      "id": "ja170:2.1",
      "pali": "“Aladdhapubbaṁ laddhāna,"
    },
    {
      "id": "ja170:2.2",
      "pali": "aḍḍhamāsaṁ kakaṇṭako;"
    },
    {
      "id": "ja170:2.3",
      "pali": "Atimaññati rājānaṁ,"
    },
    {
      "id": "ja170:2.4",
      "pali": "vedehaṁ mithilaggahan”ti."
    },
    {
      "id": "ja170:3.1",
      "pali": "Kakaṇṭakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja170:3.2",
      "pali": "Santhavavaggo dutiyo."
    },
    {
      "id": "ja170:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja170:5.1",
      "pali": "Atha indasamāna sapaṇṇakuṭi,"
    },
    {
      "id": "ja170:5.2",
      "pali": "Susimuttama gijjha jalābujako;"
    },
    {
      "id": "ja170:5.3",
      "pali": "Upasāḷaka bhikkhu salāpavaro,"
    },
    {
      "id": "ja170:5.4",
      "pali": "Atha mettavaro dasapuṇṇamatīti."
    }
  ]
}
