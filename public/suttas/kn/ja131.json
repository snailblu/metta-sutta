{
  "uid": "ja131",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja131:1.1",
      "pali": "“Asampadānenitarītarassa,"
    },
    {
      "id": "ja131:1.2",
      "pali": "Bālassa mittāni kalī bhavanti;"
    },
    {
      "id": "ja131:1.3",
      "pali": "Tasmā harāmi bhusaṁ aḍḍhamānaṁ,"
    },
    {
      "id": "ja131:1.4",
      "pali": "Mā me mitti jīyittha sassatāyan”ti."
    },
    {
      "id": "ja131:2.1",
      "pali": "Asampadānajātakaṁ paṭhamaṁ."
    }
  ]
}
