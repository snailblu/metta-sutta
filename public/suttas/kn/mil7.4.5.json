{
  "uid": "mil7.4.5",
  "title": "Pathavīvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.4.5:1.1",
      "pali": "“Bhante nāgasena, ‘pabbatassa pañca aṅgāni gahetabbānī’ti yaṁ vadesi, katamāni tāni pañca aṅgāni gahetabbānī”ti?"
    },
    {
      "id": "mil7.4.5:1.2",
      "pali": "“Yathā, mahārāja, pabbato acalo akampito asampavedhī;"
    },
    {
      "id": "mil7.4.5:1.3",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena sammānane vimānane sakkāre asakkāre garukāre agarukāre yase ayase nindāya pasaṁsāya sukhe dukkhe iṭṭhāniṭṭhesu sabbattha rūpasaddagandharasaphoṭṭhabbadhammesu rajanīyesu na rajjitabbaṁ, dussanīyesu na dussitabbaṁ, muyhanīyesu na muyhitabbaṁ, na kampitabbaṁ na calitabbaṁ, pabbatena viya acalena bhavitabbaṁ."
    },
    {
      "id": "mil7.4.5:1.4",
      "pali": "Idaṁ, mahārāja, pabbatassa paṭhamaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.4.5:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, bhagavatā devātidevena—"
    },
    {
      "id": "mil7.4.5:2.1",
      "pali": "‘Selo yathā ekaghano,"
    },
    {
      "id": "mil7.4.5:2.2",
      "pali": "vātena na samīrati;"
    },
    {
      "id": "mil7.4.5:2.3",
      "pali": "Evaṁ nindāpasaṁsāsu,"
    },
    {
      "id": "mil7.4.5:2.4",
      "pali": "na samiñjanti paṇḍitā’ti."
    },
    {
      "id": "mil7.4.5:3.1",
      "pali": "Puna caparaṁ, mahārāja, pabbato thaddho na kenaci saṁsaṭṭho;"
    },
    {
      "id": "mil7.4.5:3.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena thaddhena asaṁsaṭṭhena bhavitabbaṁ, na kenaci saṁsaggo karaṇīyo."
    },
    {
      "id": "mil7.4.5:3.3",
      "pali": "Idaṁ, mahārāja, pabbatassa dutiyaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.4.5:3.4",
      "pali": "Bhāsitampetaṁ, mahārāja, bhagavatā devātidevena—"
    },
    {
      "id": "mil7.4.5:4.1",
      "pali": "‘Asaṁsaṭṭhaṁ gahaṭṭhehi,"
    },
    {
      "id": "mil7.4.5:4.2",
      "pali": "anāgārehi cūbhayaṁ;"
    },
    {
      "id": "mil7.4.5:4.3",
      "pali": "Anokasārimappicchaṁ,"
    },
    {
      "id": "mil7.4.5:4.4",
      "pali": "tamahaṁ brūmi brāhmaṇan’ti."
    },
    {
      "id": "mil7.4.5:5.1",
      "pali": "Puna caparaṁ, mahārāja, pabbate bījaṁ na virūhati;"
    },
    {
      "id": "mil7.4.5:5.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena sakamānase kilesā na virūhāpetabbā."
    },
    {
      "id": "mil7.4.5:5.3",
      "pali": "Idaṁ, mahārāja, pabbatassa tatiyaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.4.5:5.4",
      "pali": "Bhāsitampetaṁ, mahārāja, therena subhūtinā—"
    },
    {
      "id": "mil7.4.5:6.1",
      "pali": "‘Rāgūpasaṁhitaṁ cittaṁ,"
    },
    {
      "id": "mil7.4.5:6.2",
      "pali": "yadā uppajjate mama;"
    },
    {
      "id": "mil7.4.5:6.3",
      "pali": "Sayaṁva paccavekkhāmi,"
    },
    {
      "id": "mil7.4.5:6.4",
      "pali": "ekaggo taṁ damemahaṁ."
    },
    {
      "id": "mil7.4.5:7.1",
      "pali": "Rajjase rajanīye ca,"
    },
    {
      "id": "mil7.4.5:7.2",
      "pali": "dussanīye ca dussase;"
    },
    {
      "id": "mil7.4.5:7.3",
      "pali": "Muyhase mohanīye ca,"
    },
    {
      "id": "mil7.4.5:7.4",
      "pali": "nikkhamassu vanā tuvaṁ."
    },
    {
      "id": "mil7.4.5:8.1",
      "pali": "Visuddhānaṁ ayaṁ vāso,"
    },
    {
      "id": "mil7.4.5:8.2",
      "pali": "nimmalānaṁ tapassinaṁ;"
    },
    {
      "id": "mil7.4.5:8.3",
      "pali": "Mā kho visuddhaṁ dūsesi,"
    },
    {
      "id": "mil7.4.5:8.4",
      "pali": "nikkhamassu vanā tuvan’ti."
    },
    {
      "id": "mil7.4.5:9.1",
      "pali": "Puna caparaṁ, mahārāja, pabbato accuggato;"
    },
    {
      "id": "mil7.4.5:9.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena ñāṇaccuggatena bhavitabbaṁ."
    },
    {
      "id": "mil7.4.5:9.3",
      "pali": "Idaṁ, mahārāja, pabbatassa catutthaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.4.5:9.4",
      "pali": "Bhāsitampetaṁ, mahārāja, bhagavatā devātidevena—"
    },
    {
      "id": "mil7.4.5:10.1",
      "pali": "‘Pamādaṁ appamādena,"
    },
    {
      "id": "mil7.4.5:10.2",
      "pali": "yadā nudati paṇḍito;"
    },
    {
      "id": "mil7.4.5:10.3",
      "pali": "Paññāpāsādamāruyha,"
    },
    {
      "id": "mil7.4.5:10.4",
      "pali": "asoko sokiniṁ pajaṁ;"
    },
    {
      "id": "mil7.4.5:10.5",
      "pali": "Pabbataṭṭhova bhūmaṭṭhe,"
    },
    {
      "id": "mil7.4.5:10.6",
      "pali": "dhīro bāle avekkhatī’ti."
    },
    {
      "id": "mil7.4.5:11.1",
      "pali": "Puna caparaṁ, mahārāja, pabbato anunnato anonato;"
    },
    {
      "id": "mil7.4.5:11.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena unnatāvanati na karaṇīyā."
    },
    {
      "id": "mil7.4.5:11.3",
      "pali": "Idaṁ, mahārāja, pabbatassa pañcamaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.4.5:11.4",
      "pali": "Bhāsitampetaṁ, mahārāja, upāsikāya cūḷasubhaddāya sakasamaṇe parikittayamānāya—"
    },
    {
      "id": "mil7.4.5:12.1",
      "pali": "‘Lābhena unnato loko,"
    },
    {
      "id": "mil7.4.5:12.2",
      "pali": "alābhena ca onato;"
    },
    {
      "id": "mil7.4.5:12.3",
      "pali": "Lābhālābhena ekaṭṭhā,"
    },
    {
      "id": "mil7.4.5:12.4",
      "pali": "tādisā samaṇā mamā’”ti."
    },
    {
      "id": "mil7.4.5:13.1",
      "pali": "Pabbataṅgapañho pañcamo."
    }
  ]
}
