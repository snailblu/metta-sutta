{
  "uid": "vv62",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv62:1.1",
      "pali": "“Ko nu dibbena yānena,"
    },
    {
      "id": "vv62:1.2",
      "pali": "sabbasetena hatthinā;"
    },
    {
      "id": "vv62:1.3",
      "pali": "Tūriyatāḷitanigghoso,"
    },
    {
      "id": "vv62:1.4",
      "pali": "antalikkhe mahīyati."
    },
    {
      "id": "vv62:2.1",
      "pali": "Devatā nusi gandhabbo,"
    },
    {
      "id": "vv62:2.2",
      "pali": "adu sakko purindado;"
    },
    {
      "id": "vv62:2.3",
      "pali": "Ajānantā taṁ pucchāma,"
    },
    {
      "id": "vv62:2.4",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "vv62:3.1",
      "pali": "“Namhi devo na gandhabbo,"
    },
    {
      "id": "vv62:3.2",
      "pali": "nāpi sakko purindado;"
    },
    {
      "id": "vv62:3.3",
      "pali": "Sudhammā nāma ye devā,"
    },
    {
      "id": "vv62:3.4",
      "pali": "tesaṁ aññataro ahan”ti."
    },
    {
      "id": "vv62:4.1",
      "pali": "“Pucchāma devaṁ sudhammaṁ,"
    },
    {
      "id": "vv62:4.2",
      "pali": "Puthuṁ katvāna añjaliṁ;"
    },
    {
      "id": "vv62:4.3",
      "pali": "Kiṁ katvā mānuse kammaṁ,"
    },
    {
      "id": "vv62:4.4",
      "pali": "Sudhammaṁ upapajjatī”ti."
    },
    {
      "id": "vv62:5.1",
      "pali": "“Ucchāgāraṁ tiṇāgāraṁ,"
    },
    {
      "id": "vv62:5.2",
      "pali": "vatthāgārañca yo dade;"
    },
    {
      "id": "vv62:5.3",
      "pali": "Tiṇṇaṁ aññataraṁ datvā,"
    },
    {
      "id": "vv62:5.4",
      "pali": "sudhammaṁ upapajjatī”ti."
    },
    {
      "id": "vv62:6.1",
      "pali": "Tatiyanāgavimānaṁ dvādasamaṁ."
    }
  ]
}
