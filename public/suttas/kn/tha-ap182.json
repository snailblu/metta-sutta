{
  "uid": "tha-ap182",
  "title": "Saṅghupaṭṭhākattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap182:1.1",
      "pali": "“Vessabhumhi bhagavati,"
    },
    {
      "id": "tha-ap182:1.2",
      "pali": "ahosārāmiko ahaṁ;"
    },
    {
      "id": "tha-ap182:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap182:1.4",
      "pali": "upaṭṭhiṁ saṅghamuttamaṁ."
    },
    {
      "id": "tha-ap182:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap182:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap182:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap182:2.4",
      "pali": "upaṭṭhānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap182:3.1",
      "pali": "Ito te sattame kappe,"
    },
    {
      "id": "tha-ap182:3.2",
      "pali": "sattevāsuṁ samodakā;"
    },
    {
      "id": "tha-ap182:3.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap182:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap182:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap182:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap182:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap182:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā saṅghupaṭṭhāko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap182:6.1",
      "pali": "Saṅghupaṭṭhākattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap182:7.1",
      "pali": "Kumudavaggo aṭṭhārasamo."
    },
    {
      "id": "tha-ap182:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap182:9.1",
      "pali": "Kumudo atha nisseṇī,"
    },
    {
      "id": "tha-ap182:9.2",
      "pali": "rattiko udapānado;"
    },
    {
      "id": "tha-ap182:9.3",
      "pali": "Sīhāsanī maggadado,"
    },
    {
      "id": "tha-ap182:9.4",
      "pali": "ekadīpī maṇippado;"
    },
    {
      "id": "tha-ap182:9.5",
      "pali": "Tikicchako upaṭṭhāko,"
    },
    {
      "id": "tha-ap182:9.6",
      "pali": "ekapaññāsa gāthakāti."
    }
  ]
}
