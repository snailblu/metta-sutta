{
  "uid": "tha-ap43",
  "title": "1 Bhāgineyyupālittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap43:1.1",
      "pali": "“Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap43:1.2",
      "pali": "parivuto lokanāyako;"
    },
    {
      "id": "tha-ap43:1.3",
      "pali": "Vivekamanuyutto so,"
    },
    {
      "id": "tha-ap43:1.4",
      "pali": "gacchate paṭisallituṁ."
    },
    {
      "id": "tha-ap43:2.1",
      "pali": "Ajinena nivatthohaṁ,"
    },
    {
      "id": "tha-ap43:2.2",
      "pali": "tidaṇḍaparidhārako;"
    },
    {
      "id": "tha-ap43:2.3",
      "pali": "Bhikkhusaṅghaparibyūḷhaṁ,"
    },
    {
      "id": "tha-ap43:2.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap43:3.1",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "tha-ap43:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap43:3.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap43:3.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap43:4.1",
      "pali": "Yathāṇḍajā ca saṁsedā,"
    },
    {
      "id": "tha-ap43:4.2",
      "pali": "opapātī jalābujā;"
    },
    {
      "id": "tha-ap43:4.3",
      "pali": "Kākādipakkhino sabbe,"
    },
    {
      "id": "tha-ap43:4.4",
      "pali": "antalikkhacarā sadā."
    },
    {
      "id": "tha-ap43:5.1",
      "pali": "‘Ye keci pāṇabhūtatthi,"
    },
    {
      "id": "tha-ap43:5.2",
      "pali": "saññino vā asaññino;"
    },
    {
      "id": "tha-ap43:5.3",
      "pali": "Sabbe te tava ñāṇamhi,"
    },
    {
      "id": "tha-ap43:5.4",
      "pali": "anto honti samogadhā."
    },
    {
      "id": "tha-ap43:6.1",
      "pali": "Gandhā ca pabbateyyā ye,"
    },
    {
      "id": "tha-ap43:6.2",
      "pali": "himavantanaguttame;"
    },
    {
      "id": "tha-ap43:6.3",
      "pali": "Sabbe te tava sīlamhi,"
    },
    {
      "id": "tha-ap43:6.4",
      "pali": "kalāyapi na yujjare."
    },
    {
      "id": "tha-ap43:7.1",
      "pali": "Mohandhakārapakkhando,"
    },
    {
      "id": "tha-ap43:7.2",
      "pali": "ayaṁ loko sadevako;"
    },
    {
      "id": "tha-ap43:7.3",
      "pali": "Tava ñāṇamhi jotante,"
    },
    {
      "id": "tha-ap43:7.4",
      "pali": "andhakārā vidhaṁsitā."
    },
    {
      "id": "tha-ap43:8.1",
      "pali": "Yathā atthaṅgate sūriye,"
    },
    {
      "id": "tha-ap43:8.2",
      "pali": "honti sattā tamogatā;"
    },
    {
      "id": "tha-ap43:8.3",
      "pali": "Evaṁ buddhe anuppanne,"
    },
    {
      "id": "tha-ap43:8.4",
      "pali": "hoti loko tamogato."
    },
    {
      "id": "tha-ap43:9.1",
      "pali": "Yathodayanto ādicco,"
    },
    {
      "id": "tha-ap43:9.2",
      "pali": "vinodeti tamaṁ sadā;"
    },
    {
      "id": "tha-ap43:9.3",
      "pali": "Tatheva tvaṁ buddhaseṭṭha,"
    },
    {
      "id": "tha-ap43:9.4",
      "pali": "viddhaṁsesi tamaṁ sadā."
    },
    {
      "id": "tha-ap43:10.1",
      "pali": "Padhānapahitattosi,"
    },
    {
      "id": "tha-ap43:10.2",
      "pali": "buddho loke sadevake;"
    },
    {
      "id": "tha-ap43:10.3",
      "pali": "Tava kammābhiraddhena,"
    },
    {
      "id": "tha-ap43:10.4",
      "pali": "tosesi janataṁ bahuṁ’."
    },
    {
      "id": "tha-ap43:11.1",
      "pali": "Taṁ sabbaṁ anumoditvā,"
    },
    {
      "id": "tha-ap43:11.2",
      "pali": "padumuttaro mahāmuni;"
    },
    {
      "id": "tha-ap43:11.3",
      "pali": "Nabhaṁ abbhuggamī dhīro,"
    },
    {
      "id": "tha-ap43:11.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap43:12.1",
      "pali": "Abbhuggantvāna sambuddho,"
    },
    {
      "id": "tha-ap43:12.2",
      "pali": "mahesi padumuttaro;"
    },
    {
      "id": "tha-ap43:12.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap43:12.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap43:13.1",
      "pali": "Yenidaṁ thavitaṁ ñāṇaṁ,"
    },
    {
      "id": "tha-ap43:13.2",
      "pali": "opammehi samāyutaṁ;"
    },
    {
      "id": "tha-ap43:13.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap43:13.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap43:14.1",
      "pali": "‘Aṭṭhārasañca khattuṁ so,"
    },
    {
      "id": "tha-ap43:14.2",
      "pali": "devarājā bhavissati;"
    },
    {
      "id": "tha-ap43:14.3",
      "pali": "Pathabyā rajjaṁ tisataṁ,"
    },
    {
      "id": "tha-ap43:14.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap43:15.1",
      "pali": "Pañcavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap43:15.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap43:15.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap43:15.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap43:16.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap43:16.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap43:16.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap43:16.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap43:17.1",
      "pali": "Tusitā hi cavitvāna,"
    },
    {
      "id": "tha-ap43:17.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap43:17.3",
      "pali": "Hīnova jātiyā santo,"
    },
    {
      "id": "tha-ap43:17.4",
      "pali": "upāli nāma hessati."
    },
    {
      "id": "tha-ap43:18.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap43:18.2",
      "pali": "virājetvāna pāpakaṁ;"
    },
    {
      "id": "tha-ap43:18.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap43:18.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap43:19.1",
      "pali": "Tuṭṭho ca gotamo buddho,"
    },
    {
      "id": "tha-ap43:19.2",
      "pali": "sakyaputto mahāyaso;"
    },
    {
      "id": "tha-ap43:19.3",
      "pali": "Vinayādhigataṁ tassa,"
    },
    {
      "id": "tha-ap43:19.4",
      "pali": "etadagge ṭhapessati’."
    },
    {
      "id": "tha-ap43:20.1",
      "pali": "Saddhāyāhaṁ pabbajito,"
    },
    {
      "id": "tha-ap43:20.2",
      "pali": "katakicco anāsavo;"
    },
    {
      "id": "tha-ap43:20.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap43:20.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap43:21.1",
      "pali": "Bhagavā cānukampī maṁ,"
    },
    {
      "id": "tha-ap43:21.2",
      "pali": "vinayehaṁ visārado;"
    },
    {
      "id": "tha-ap43:21.3",
      "pali": "Sakakammābhiraddho ca,"
    },
    {
      "id": "tha-ap43:21.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap43:22.1",
      "pali": "Saṁvuto pātimokkhamhi,"
    },
    {
      "id": "tha-ap43:22.2",
      "pali": "indriyesu ca pañcasu;"
    },
    {
      "id": "tha-ap43:22.3",
      "pali": "Dhāremi vinayaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap43:22.4",
      "pali": "kevalaṁ ratanākaraṁ."
    },
    {
      "id": "tha-ap43:23.1",
      "pali": "Mamañca guṇamaññāya,"
    },
    {
      "id": "tha-ap43:23.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap43:23.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap43:23.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap43:24.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap43:24.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap43:24.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap43:24.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap43:25.1",
      "pali": "Itthaṁ sudaṁ āyasmā upāli thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap43:26.1",
      "pali": "Bhāgineyyupālittherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
