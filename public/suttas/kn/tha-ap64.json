{
  "uid": "tha-ap64",
  "title": "2 Avopupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap64:1.1",
      "pali": "“Vihārā abhinikkhamma,"
    },
    {
      "id": "tha-ap64:1.2",
      "pali": "abbhuṭṭhāsi ca caṅkame;"
    },
    {
      "id": "tha-ap64:1.3",
      "pali": "Catusaccaṁ pakāsanto,"
    },
    {
      "id": "tha-ap64:1.4",
      "pali": "desento amataṁ padaṁ."
    },
    {
      "id": "tha-ap64:2.1",
      "pali": "Sikhissa giramaññāya,"
    },
    {
      "id": "tha-ap64:2.2",
      "pali": "buddhaseṭṭhassa tādino;"
    },
    {
      "id": "tha-ap64:2.3",
      "pali": "Nānāpupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap64:2.4",
      "pali": "ākāsamhi samokiriṁ."
    },
    {
      "id": "tha-ap64:3.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap64:3.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap64:3.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap64:3.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap64:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap64:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap64:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap64:4.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap64:5.1",
      "pali": "Ito vīsatikappamhi,"
    },
    {
      "id": "tha-ap64:5.2",
      "pali": "sumedho nāma khattiyo;"
    },
    {
      "id": "tha-ap64:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap64:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap64:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap64:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap64:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap64:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā avopupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap64:8.1",
      "pali": "Avopupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
