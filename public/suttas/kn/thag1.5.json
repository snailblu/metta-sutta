{
  "uid": "thag1.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.5:1.1",
      "pali": "“Yo duddamiyo damena danto,"
    },
    {
      "id": "thag1.5:1.2",
      "pali": "Dabbo santusito vitiṇṇakaṅkho;"
    },
    {
      "id": "thag1.5:1.3",
      "pali": "Vijitāvī apetabheravo hi,"
    },
    {
      "id": "thag1.5:1.4",
      "pali": "Dabbo so parinibbuto ṭhitatto”ti."
    },
    {
      "id": "thag1.5:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā dabbo thero gāthaṁ abhāsitthāti."
    }
  ]
}
