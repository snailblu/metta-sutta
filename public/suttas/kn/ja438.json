{
  "uid": "ja438",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja438:1.1",
      "pali": "“Yo te puttake akhādi,"
    },
    {
      "id": "ja438:1.2",
      "pali": "dinnabhatto adūsake;"
    },
    {
      "id": "ja438:1.3",
      "pali": "Tasmiṁ dāṭhaṁ nipātehi,"
    },
    {
      "id": "ja438:1.4",
      "pali": "mā te muccittha jīvato”."
    },
    {
      "id": "ja438:2.1",
      "pali": "“Ākiṇṇaluddo puriso,"
    },
    {
      "id": "ja438:2.2",
      "pali": "dhāticelaṁva makkhito;"
    },
    {
      "id": "ja438:2.3",
      "pali": "Padesaṁ taṁ na passāmi,"
    },
    {
      "id": "ja438:2.4",
      "pali": "yattha dāṭhaṁ nipātaye."
    },
    {
      "id": "ja438:3.1",
      "pali": "Akataññussa posassa,"
    },
    {
      "id": "ja438:3.2",
      "pali": "niccaṁ vivaradassino;"
    },
    {
      "id": "ja438:3.3",
      "pali": "Sabbañce pathaviṁ dajjā,"
    },
    {
      "id": "ja438:3.4",
      "pali": "neva naṁ abhirādhaye”."
    },
    {
      "id": "ja438:4.1",
      "pali": "“Kiṁ nu subāhu taramānarūpo,"
    },
    {
      "id": "ja438:4.2",
      "pali": "Paccāgatosi saha māṇavena;"
    },
    {
      "id": "ja438:4.3",
      "pali": "Kiṁ kiccamatthaṁ idhamatthi tuyhaṁ,"
    },
    {
      "id": "ja438:4.4",
      "pali": "Akkhāhi me pucchito etamatthaṁ”."
    },
    {
      "id": "ja438:5.1",
      "pali": "“Yo te sakhā daddaro sādhurūpo,"
    },
    {
      "id": "ja438:5.2",
      "pali": "Tassa vadhaṁ parisaṅkāmi ajja;"
    },
    {
      "id": "ja438:5.3",
      "pali": "Purisassa kammāyatanāni sutvā,"
    },
    {
      "id": "ja438:5.4",
      "pali": "Nāhaṁ sukhiṁ daddaraṁ ajja maññe”."
    },
    {
      "id": "ja438:6.1",
      "pali": "“Kānissa kammāyatanāni assu,"
    },
    {
      "id": "ja438:6.2",
      "pali": "Purisassa vuttisamodhānatāya;"
    },
    {
      "id": "ja438:6.3",
      "pali": "Kaṁ vā paṭiññaṁ purisassa sutvā,"
    },
    {
      "id": "ja438:6.4",
      "pali": "Parisaṅkasi daddaraṁ māṇavena”."
    },
    {
      "id": "ja438:7.1",
      "pali": "“Ciṇṇā kaliṅgā caritā vaṇijjā,"
    },
    {
      "id": "ja438:7.2",
      "pali": "Vettācaro saṅkupathopi ciṇṇo;"
    },
    {
      "id": "ja438:7.3",
      "pali": "Naṭehi ciṇṇaṁ saha vākurehi,"
    },
    {
      "id": "ja438:7.4",
      "pali": "Daṇḍena yuddhampi samajjamajjhe."
    },
    {
      "id": "ja438:8.1",
      "pali": "Baddhā kulīkā mitamāḷhakena,"
    },
    {
      "id": "ja438:8.2",
      "pali": "Akkhā jitā saṁyamo abbhatīto;"
    },
    {
      "id": "ja438:8.3",
      "pali": "Abbāhitaṁ pubbakaṁ aḍḍharattaṁ,"
    },
    {
      "id": "ja438:8.4",
      "pali": "Hatthā daḍḍhā piṇḍapaṭiggahena."
    },
    {
      "id": "ja438:9.1",
      "pali": "Tānissa kammāyatanāni assu,"
    },
    {
      "id": "ja438:9.2",
      "pali": "Purisassa vuttisamodhānatāya;"
    },
    {
      "id": "ja438:9.3",
      "pali": "Yathā ayaṁ dissati lomapiṇḍo,"
    },
    {
      "id": "ja438:9.4",
      "pali": "Gāvo hatā kiṁ pana daddarassā”ti."
    },
    {
      "id": "ja438:10.1",
      "pali": "Daddarajātakaṁ dvādasamaṁ."
    },
    {
      "id": "ja438:11.1",
      "pali": "Navakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja438:12.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja438:13.1",
      "pali": "Varagijjha samajjana haṁsavaro,"
    },
    {
      "id": "ja438:13.2",
      "pali": "Nidhisavhaya hārita pāṭaliko;"
    },
    {
      "id": "ja438:13.3",
      "pali": "Ajarāmara dhaṅka titikkha kuto,"
    },
    {
      "id": "ja438:13.4",
      "pali": "Atha dvādasa pekkhana daddaribhīti."
    }
  ]
}
