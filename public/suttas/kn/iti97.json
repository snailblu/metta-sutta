{
  "uid": "iti97",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti97:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti97:2.1",
      "pali": "“Kalyāṇasīlo, bhikkhave, bhikkhu kalyāṇadhammo kalyāṇapañño imasmiṁ dhammavinaye ‘kevalī vusitavā uttamapuriso’ti vuccati—"
    },
    {
      "id": "iti97:3.1",
      "pali": "Kathañca, bhikkhave, bhikkhu kalyāṇasīlo hoti?"
    },
    {
      "id": "iti97:3.2",
      "pali": "Idha, bhikkhave, bhikkhu sīlavā hoti, pātimokkhasaṁvarasaṁvuto viharati, ācāragocarasampanno aṇumattesu vajjesu bhayadassāvī, samādāya sikkhati sikkhāpadesu."
    },
    {
      "id": "iti97:3.3",
      "pali": "Evaṁ kho, bhikkhave, bhikkhu kalyāṇasīlo hoti."
    },
    {
      "id": "iti97:3.4",
      "pali": "Iti kalyāṇasīlo."
    },
    {
      "id": "iti97:4.1",
      "pali": "Kalyāṇadhammo ca kathaṁ hoti?"
    },
    {
      "id": "iti97:4.2",
      "pali": "Idha, bhikkhave, bhikkhu sattannaṁ bodhipakkhiyānaṁ dhammānaṁ bhāvanānuyogamanuyutto viharati."
    },
    {
      "id": "iti97:4.3",
      "pali": "Evaṁ kho, bhikkhave, bhikkhu kalyāṇadhammo hoti."
    },
    {
      "id": "iti97:4.4",
      "pali": "Iti kalyāṇasīlo, kalyāṇadhammo."
    },
    {
      "id": "iti97:5.1",
      "pali": "Kalyāṇapañño ca kathaṁ hoti?"
    },
    {
      "id": "iti97:5.2",
      "pali": "Idha, bhikkhave, bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati."
    },
    {
      "id": "iti97:5.3",
      "pali": "Evaṁ kho, bhikkhave, bhikkhu kalyāṇapañño hoti."
    },
    {
      "id": "iti97:6.1",
      "pali": "Iti kalyāṇasīlo kalyāṇadhammo kalyāṇapañño imasmiṁ dhammavinaye ‘kevalī vusitavā uttamapuriso’ti vuccatī”ti."
    },
    {
      "id": "iti97:6.2",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti97:6.3",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti97:7.1",
      "pali": "“Yassa kāyena vācāya,"
    },
    {
      "id": "iti97:7.2",
      "pali": "manasā natthi dukkaṭaṁ;"
    },
    {
      "id": "iti97:7.3",
      "pali": "Taṁ ve kalyāṇasīloti,"
    },
    {
      "id": "iti97:7.4",
      "pali": "āhu bhikkhuṁ hirīmanaṁ."
    },
    {
      "id": "iti97:8.1",
      "pali": "Yassa dhammā subhāvitā,"
    },
    {
      "id": "iti97:8.2",
      "pali": "satta sambodhigāmino;"
    },
    {
      "id": "iti97:8.3",
      "pali": "Taṁ ve kalyāṇadhammoti,"
    },
    {
      "id": "iti97:8.4",
      "pali": "āhu bhikkhuṁ anussadaṁ."
    },
    {
      "id": "iti97:9.1",
      "pali": "Yo dukkhassa pajānāti,"
    },
    {
      "id": "iti97:9.2",
      "pali": "idheva khayamattano;"
    },
    {
      "id": "iti97:9.3",
      "pali": "Taṁ ve kalyāṇapaññoti,"
    },
    {
      "id": "iti97:9.4",
      "pali": "āhu bhikkhuṁ anāsavaṁ."
    },
    {
      "id": "iti97:10.1",
      "pali": "Tehi dhammehi sampannaṁ,"
    },
    {
      "id": "iti97:10.2",
      "pali": "anīghaṁ chinnasaṁsayaṁ;"
    },
    {
      "id": "iti97:10.3",
      "pali": "Asitaṁ sabbalokassa,"
    },
    {
      "id": "iti97:10.4",
      "pali": "āhu sabbapahāyinan”ti."
    },
    {
      "id": "iti97:11.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti97:11.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
