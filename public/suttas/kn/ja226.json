{
  "uid": "ja226",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja226:1.1",
      "pali": "“Kāle nikkhamanā sādhu,"
    },
    {
      "id": "ja226:1.2",
      "pali": "nākāle sādhu nikkhamo;"
    },
    {
      "id": "ja226:1.3",
      "pali": "Akālena hi nikkhamma,"
    },
    {
      "id": "ja226:1.4",
      "pali": "ekakampi bahujjano;"
    },
    {
      "id": "ja226:1.5",
      "pali": "Na kiñci atthaṁ joteti,"
    },
    {
      "id": "ja226:1.6",
      "pali": "dhaṅkasenāva kosiyaṁ."
    },
    {
      "id": "ja226:2.1",
      "pali": "Dhīro ca vidhividhānaññū,"
    },
    {
      "id": "ja226:2.2",
      "pali": "paresaṁ vivarānugū;"
    },
    {
      "id": "ja226:2.3",
      "pali": "Sabbāmitte vasīkatvā,"
    },
    {
      "id": "ja226:2.4",
      "pali": "kosiyova sukhī siyā”ti."
    },
    {
      "id": "ja226:3.1",
      "pali": "Kosiyajātakaṁ chaṭṭhaṁ."
    }
  ]
}
