{
  "uid": "ja418",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja418:1.1",
      "pali": "“Idaṁ pure ninnamāhu,"
    },
    {
      "id": "ja418:1.2",
      "pali": "bahumacchaṁ mahodakaṁ;"
    },
    {
      "id": "ja418:1.3",
      "pali": "Āvāso bakarājassa,"
    },
    {
      "id": "ja418:1.4",
      "pali": "pettikaṁ bhavanaṁ mama;"
    },
    {
      "id": "ja418:1.5",
      "pali": "Tyajja bhekena yāpema,"
    },
    {
      "id": "ja418:1.6",
      "pali": "okaṁ na vijahāmase”."
    },
    {
      "id": "ja418:2.1",
      "pali": "“Ko dutiyaṁ asīlissa,"
    },
    {
      "id": "ja418:2.2",
      "pali": "bandharassakkhi bhecchati;"
    },
    {
      "id": "ja418:2.3",
      "pali": "Ko me putte kulāvakaṁ,"
    },
    {
      "id": "ja418:2.4",
      "pali": "mañca sotthiṁ karissati”."
    },
    {
      "id": "ja418:3.1",
      "pali": "“Sabbā parikkhayā pheggu,"
    },
    {
      "id": "ja418:3.2",
      "pali": "yāva tassā gatī ahu;"
    },
    {
      "id": "ja418:3.3",
      "pali": "Khīṇabhakkho mahārāja,"
    },
    {
      "id": "ja418:3.4",
      "pali": "sāre na ramatī ghuṇo”."
    },
    {
      "id": "ja418:4.1",
      "pali": "“Sā nūnāhaṁ ito gantvā,"
    },
    {
      "id": "ja418:4.2",
      "pali": "rañño muttā nivesanā;"
    },
    {
      "id": "ja418:4.3",
      "pali": "Attānaṁ ramayissāmi,"
    },
    {
      "id": "ja418:4.4",
      "pali": "dumasākhaniketinī”."
    },
    {
      "id": "ja418:5.1",
      "pali": "“So nūnāhaṁ ito gantvā,"
    },
    {
      "id": "ja418:5.2",
      "pali": "rañño mutto nivesanā;"
    },
    {
      "id": "ja418:5.3",
      "pali": "Aggodakāni pissāmi,"
    },
    {
      "id": "ja418:5.4",
      "pali": "yūthassa purato vajaṁ”."
    },
    {
      "id": "ja418:6.1",
      "pali": "“Taṁ maṁ kāmehi sammattaṁ,"
    },
    {
      "id": "ja418:6.2",
      "pali": "rattaṁ kāmesu mucchitaṁ;"
    },
    {
      "id": "ja418:6.3",
      "pali": "Ānayī bharato luddo,"
    },
    {
      "id": "ja418:6.4",
      "pali": "bāhiko bhaddamatthu te”."
    },
    {
      "id": "ja418:7.1",
      "pali": "“Andhakāratimisāyaṁ,"
    },
    {
      "id": "ja418:7.2",
      "pali": "tuṅge uparipabbate;"
    },
    {
      "id": "ja418:7.3",
      "pali": "Sā maṁ saṇhena mudunā,"
    },
    {
      "id": "ja418:7.4",
      "pali": "mā pādaṁ khali yasmani”."
    },
    {
      "id": "ja418:8.1",
      "pali": "“Asaṁsayaṁ jātikhayantadassī,"
    },
    {
      "id": "ja418:8.2",
      "pali": "Na gabbhaseyyaṁ punarāvajissaṁ;"
    },
    {
      "id": "ja418:8.3",
      "pali": "Ayamantimā pacchimā gabbhaseyyā,"
    },
    {
      "id": "ja418:8.4",
      "pali": "Khīṇo me saṁsāro punabbhavāyā”ti."
    },
    {
      "id": "ja418:9.1",
      "pali": "Aṭṭhasaddajātakaṁ dutiyaṁ."
    }
  ]
}
