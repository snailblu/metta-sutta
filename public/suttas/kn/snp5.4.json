{
  "uid": "snp5.4",
  "title": "Puṇṇakamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.4:1.1",
      "pali": "“Anejaṁ mūladassāviṁ,"
    },
    {
      "id": "snp5.4:1.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "snp5.4:1.3",
      "pali": "Atthi pañhena āgamaṁ;"
    },
    {
      "id": "snp5.4:1.4",
      "pali": "Kiṁ nissitā isayo manujā,"
    },
    {
      "id": "snp5.4:1.5",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "snp5.4:1.6",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "snp5.4:1.7",
      "pali": "Pucchāmi taṁ bhagavā brūhi me taṁ”."
    },
    {
      "id": "snp5.4:2.1",
      "pali": "“Ye kecime isayo manujā,"
    },
    {
      "id": "snp5.4:2.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "snp5.4:2.3",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "snp5.4:2.4",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "snp5.4:2.5",
      "pali": "Āsīsamānā puṇṇaka itthattaṁ;"
    },
    {
      "id": "snp5.4:2.6",
      "pali": "Jaraṁ sitā yaññamakappayiṁsu”."
    },
    {
      "id": "snp5.4:3.1",
      "pali": "“Ye kecime isayo manujā,"
    },
    {
      "id": "snp5.4:3.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "snp5.4:3.3",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "snp5.4:3.4",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "snp5.4:3.5",
      "pali": "Kaccissu te bhagavā yaññapathe appamattā;"
    },
    {
      "id": "snp5.4:3.6",
      "pali": "Atāruṁ jātiñca jarañca mārisa,"
    },
    {
      "id": "snp5.4:3.7",
      "pali": "Pucchāmi taṁ bhagavā brūhi me taṁ”."
    },
    {
      "id": "snp5.4:4.1",
      "pali": "“Āsīsanti thomayanti abhijappanti juhanti,"
    },
    {
      "id": "snp5.4:4.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "snp5.4:4.3",
      "pali": "Kāmābhijappanti paṭicca lābhaṁ;"
    },
    {
      "id": "snp5.4:4.4",
      "pali": "Te yājayogā bhavarāgarattā,"
    },
    {
      "id": "snp5.4:4.5",
      "pali": "Nātariṁsu jātijaranti brūmi”."
    },
    {
      "id": "snp5.4:5.1",
      "pali": "“Te ce nātariṁsu yājayogā,"
    },
    {
      "id": "snp5.4:5.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "snp5.4:5.3",
      "pali": "Yaññehi jātiñca jarañca mārisa;"
    },
    {
      "id": "snp5.4:5.4",
      "pali": "Atha ko carahi devamanussaloke,"
    },
    {
      "id": "snp5.4:5.5",
      "pali": "Atāri jātiñca jarañca mārisa;"
    },
    {
      "id": "snp5.4:5.6",
      "pali": "Pucchāmi taṁ bhagavā brūhi me taṁ”."
    },
    {
      "id": "snp5.4:6.1",
      "pali": "“Saṅkhāya lokasmi paroparāni,"
    },
    {
      "id": "snp5.4:6.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "snp5.4:6.3",
      "pali": "Yassiñjitaṁ natthi kuhiñci loke;"
    },
    {
      "id": "snp5.4:6.4",
      "pali": "Santo vidhūmo anīgho nirāso,"
    },
    {
      "id": "snp5.4:6.5",
      "pali": "Atāri so jātijaranti brūmī”ti."
    },
    {
      "id": "snp5.4:6.6",
      "pali": "Puṇṇakamāṇavapucchā tatiyā."
    }
  ]
}
