{
  "uid": "tha-ap222",
  "title": "Pāpanivāriyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap222:1.1",
      "pali": "“Piyadassissa bhagavato,"
    },
    {
      "id": "tha-ap222:1.2",
      "pali": "caṅkamaṁ sodhitaṁ mayā;"
    },
    {
      "id": "tha-ap222:1.3",
      "pali": "Naḷakehi paṭicchannaṁ,"
    },
    {
      "id": "tha-ap222:1.4",
      "pali": "vātātapanivāraṇaṁ."
    },
    {
      "id": "tha-ap222:2.1",
      "pali": "Pāpaṁ vivajjanatthāya,"
    },
    {
      "id": "tha-ap222:2.2",
      "pali": "kusalassupasampadā;"
    },
    {
      "id": "tha-ap222:2.3",
      "pali": "Kilesānaṁ pahānāya,"
    },
    {
      "id": "tha-ap222:2.4",
      "pali": "padahiṁ satthu sāsane."
    },
    {
      "id": "tha-ap222:3.1",
      "pali": "Ito ekādase kappe,"
    },
    {
      "id": "tha-ap222:3.2",
      "pali": "aggidevoti vissuto;"
    },
    {
      "id": "tha-ap222:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap222:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap222:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap222:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap222:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap222:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāpanivāriyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap222:6.1",
      "pali": "Pāpanivāriyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap222:7.1",
      "pali": "Hatthivaggo bāvīsatimo."
    },
    {
      "id": "tha-ap222:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap222:9.1",
      "pali": "Hatthi pānadhi saccañca,"
    },
    {
      "id": "tha-ap222:9.2",
      "pali": "ekasaññi ca raṁsiko;"
    },
    {
      "id": "tha-ap222:9.3",
      "pali": "Sandhito tālavaṇṭañca,"
    },
    {
      "id": "tha-ap222:9.4",
      "pali": "tathā akkantasaññako;"
    },
    {
      "id": "tha-ap222:9.5",
      "pali": "Sappi pāpanivārī ca,"
    },
    {
      "id": "tha-ap222:9.6",
      "pali": "catuppaññāsa gāthakāti."
    }
  ]
}
