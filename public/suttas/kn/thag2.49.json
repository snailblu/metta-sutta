{
  "uid": "thag2.49",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.49:1.1",
      "pali": "“Assatthe haritobhāse,"
    },
    {
      "id": "thag2.49:1.2",
      "pali": "saṁvirūḷhamhi pādape;"
    },
    {
      "id": "thag2.49:1.3",
      "pali": "Ekaṁ buddhagataṁ saññaṁ,"
    },
    {
      "id": "thag2.49:1.4",
      "pali": "alabhitthaṁ patissato."
    },
    {
      "id": "thag2.49:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "thag2.49:2.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "thag2.49:2.3",
      "pali": "Tassā saññāya vāhasā,"
    },
    {
      "id": "thag2.49:2.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag2.49:2.5",
      "pali": "… Sandhito thero …"
    },
    {
      "id": "thag2.49:2.6",
      "pali": "vaggo pañcamo."
    },
    {
      "id": "thag2.49:3.1",
      "pali": "Kumārakassapo thero,"
    },
    {
      "id": "thag2.49:3.2",
      "pali": "dhammapālo ca brahmāli;"
    },
    {
      "id": "thag2.49:3.3",
      "pali": "Mogharājā visākho ca,"
    },
    {
      "id": "thag2.49:3.4",
      "pali": "cūḷako ca anūpamo;"
    },
    {
      "id": "thag2.49:3.5",
      "pali": "Vajjito sandhito thero,"
    },
    {
      "id": "thag2.49:3.6",
      "pali": "kilesarajavāhanoti."
    },
    {
      "id": "thag2.49:3.7",
      "pali": "Dukanipāto niṭṭhito."
    },
    {
      "id": "thag2.49:4.1",
      "pali": "Gāthādukanipātamhi,"
    },
    {
      "id": "thag2.49:4.2",
      "pali": "navuti ceva aṭṭha ca;"
    },
    {
      "id": "thag2.49:4.3",
      "pali": "Therā ekūnapaññāsaṁ,"
    },
    {
      "id": "thag2.49:4.4",
      "pali": "bhāsitā nayakovidāti."
    }
  ]
}
