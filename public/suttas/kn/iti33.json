{
  "uid": "iti33",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti33:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti33:2.1",
      "pali": "“Dvīhi, bhikkhave, dhammehi samannāgato puggalo yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "iti33:2.2",
      "pali": "Katamehi dvīhi?"
    },
    {
      "id": "iti33:2.3",
      "pali": "Bhaddakena ca sīlena, bhaddikāya ca diṭṭhiyā."
    },
    {
      "id": "iti33:2.4",
      "pali": "Imehi kho, bhikkhave, dvīhi dhammehi samannāgato puggalo yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "iti33:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti33:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti33:3.1",
      "pali": "“Bhaddakena ca sīlena,"
    },
    {
      "id": "iti33:3.2",
      "pali": "bhaddikāya ca diṭṭhiyā;"
    },
    {
      "id": "iti33:3.3",
      "pali": "Etehi dvīhi dhammehi,"
    },
    {
      "id": "iti33:3.4",
      "pali": "yo samannāgato naro;"
    },
    {
      "id": "iti33:3.5",
      "pali": "Kāyassa bhedā sappañño,"
    },
    {
      "id": "iti33:3.6",
      "pali": "saggaṁ so upapajjatī”ti."
    },
    {
      "id": "iti33:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti33:4.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
