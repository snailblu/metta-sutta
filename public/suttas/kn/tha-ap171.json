{
  "uid": "tha-ap171",
  "title": "Samādapakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap171:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap171:1.2",
      "pali": "mahāpūgagaṇo ahu;"
    },
    {
      "id": "tha-ap171:1.3",
      "pali": "Tesāhaṁ pavaro āsiṁ,"
    },
    {
      "id": "tha-ap171:1.4",
      "pali": "mama baddhacarā ca te."
    },
    {
      "id": "tha-ap171:2.1",
      "pali": "Sabbe te sannipātetvā,"
    },
    {
      "id": "tha-ap171:2.2",
      "pali": "puññakamme samādayiṁ;"
    },
    {
      "id": "tha-ap171:2.3",
      "pali": "Māḷaṁ kassāma saṅghassa,"
    },
    {
      "id": "tha-ap171:2.4",
      "pali": "puññakkhettaṁ anuttaraṁ."
    },
    {
      "id": "tha-ap171:3.1",
      "pali": "Sādhūti te paṭissutvā,"
    },
    {
      "id": "tha-ap171:3.2",
      "pali": "mama chandavasānugā;"
    },
    {
      "id": "tha-ap171:3.3",
      "pali": "Niṭṭhāpetvā ca taṁ māḷaṁ,"
    },
    {
      "id": "tha-ap171:3.4",
      "pali": "vipassissa adamhase."
    },
    {
      "id": "tha-ap171:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap171:4.2",
      "pali": "yaṁ māḷamadadiṁ tadā;"
    },
    {
      "id": "tha-ap171:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap171:4.4",
      "pali": "māḷadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap171:5.1",
      "pali": "Ekūnasattatikappe,"
    },
    {
      "id": "tha-ap171:5.2",
      "pali": "eko āsi janādhipo;"
    },
    {
      "id": "tha-ap171:5.3",
      "pali": "Ādeyyo nāma nāmena,"
    },
    {
      "id": "tha-ap171:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap171:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap171:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap171:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap171:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā samādapako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap171:8.1",
      "pali": "Samādapakattherassāpadānaṁ navamaṁ."
    }
  ]
}
