{
  "uid": "tha-ap168",
  "title": "Sappidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap168:1.1",
      "pali": "“Phusso nāmāsi bhagavā,"
    },
    {
      "id": "tha-ap168:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap168:1.3",
      "pali": "Gacchate vīthiyaṁ vīro,"
    },
    {
      "id": "tha-ap168:1.4",
      "pali": "nibbāpento mahājanaṁ."
    },
    {
      "id": "tha-ap168:2.1",
      "pali": "Anupubbena bhagavā,"
    },
    {
      "id": "tha-ap168:2.2",
      "pali": "āgacchi mama santikaṁ;"
    },
    {
      "id": "tha-ap168:2.3",
      "pali": "Tato taṁ pattaṁ paggayha,"
    },
    {
      "id": "tha-ap168:2.4",
      "pali": "sappitelamadāsahaṁ."
    },
    {
      "id": "tha-ap168:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap168:3.2",
      "pali": "yaṁ sappimadadiṁ tadā;"
    },
    {
      "id": "tha-ap168:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap168:3.4",
      "pali": "sappidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap168:4.1",
      "pali": "Chappaññāse ito kappe,"
    },
    {
      "id": "tha-ap168:4.2",
      "pali": "eko āsi samodako;"
    },
    {
      "id": "tha-ap168:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap168:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap168:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap168:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap168:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap168:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sappidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap168:7.1",
      "pali": "Sappidāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
