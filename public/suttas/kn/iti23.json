{
  "uid": "iti23",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti23:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti23:2.1",
      "pali": "“Ekadhammo, bhikkhave, bhāvito bahulīkato ubho atthe samadhigayha tiṭṭhati—"
    },
    {
      "id": "iti23:2.2",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañca."
    },
    {
      "id": "iti23:2.3",
      "pali": "Katamo ekadhammo?"
    },
    {
      "id": "iti23:2.4",
      "pali": "Appamādo kusalesu dhammesu."
    },
    {
      "id": "iti23:2.5",
      "pali": "Ayaṁ kho, bhikkhave, ekadhammo bhāvito bahulīkato ubho atthe samadhigayha tiṭṭhati—"
    },
    {
      "id": "iti23:2.6",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcā”ti."
    },
    {
      "id": "iti23:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti23:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti23:3.1",
      "pali": "“Appamādaṁ pasaṁsanti,"
    },
    {
      "id": "iti23:3.2",
      "pali": "puññakiriyāsu paṇḍitā;"
    },
    {
      "id": "iti23:3.3",
      "pali": "Appamatto ubho atthe,"
    },
    {
      "id": "iti23:3.4",
      "pali": "adhigaṇhāti paṇḍito."
    },
    {
      "id": "iti23:4.1",
      "pali": "Diṭṭhe dhamme ca yo attho,"
    },
    {
      "id": "iti23:4.2",
      "pali": "yo cattho samparāyiko;"
    },
    {
      "id": "iti23:4.3",
      "pali": "Atthābhisamayā dhīro,"
    },
    {
      "id": "iti23:4.4",
      "pali": "paṇḍitoti pavuccatī”ti."
    },
    {
      "id": "iti23:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti23:5.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
