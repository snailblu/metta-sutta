{
  "uid": "ja70",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja70:1.1",
      "pali": "“Na taṁ jitaṁ sādhu jitaṁ,"
    },
    {
      "id": "ja70:1.2",
      "pali": "yaṁ jitaṁ avajīyati;"
    },
    {
      "id": "ja70:1.3",
      "pali": "Taṁ kho jitaṁ sādhu jitaṁ,"
    },
    {
      "id": "ja70:1.4",
      "pali": "yaṁ jitaṁ nāvajīyatī”ti."
    },
    {
      "id": "ja70:2.1",
      "pali": "Kuddālajātakaṁ dasamaṁ."
    },
    {
      "id": "ja70:2.2",
      "pali": "Itthivaggo sattamo."
    },
    {
      "id": "ja70:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja70:4.1",
      "pali": "Sikhīsabbaghasopi ca vīṇavaro,"
    },
    {
      "id": "ja70:4.2",
      "pali": "Pisuṇā mittabhedikā nandī nadī;"
    },
    {
      "id": "ja70:4.3",
      "pali": "Mudulakkhaṇa sodariyā ca mano,"
    },
    {
      "id": "ja70:4.4",
      "pali": "Visa sādhujitena bhavanti dasāti."
    }
  ]
}
