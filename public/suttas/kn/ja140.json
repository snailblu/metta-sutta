{
  "uid": "ja140",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja140:1.1",
      "pali": "“Niccaṁ ubbiggahadayā,"
    },
    {
      "id": "ja140:1.2",
      "pali": "sabbalokavihesakā;"
    },
    {
      "id": "ja140:1.3",
      "pali": "Tasmā nesaṁ vasā natthi,"
    },
    {
      "id": "ja140:1.4",
      "pali": "kākānamhāka ñātinan”ti."
    },
    {
      "id": "ja140:2.1",
      "pali": "Kākajātakaṁ dasamaṁ."
    },
    {
      "id": "ja140:2.2",
      "pali": "Asampadānavaggo cuddasamo."
    },
    {
      "id": "ja140:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja140:4.1",
      "pali": "Itarītara rakkhasi khemiyo ca,"
    },
    {
      "id": "ja140:4.2",
      "pali": "Parosatapañhena ābhassaro puna;"
    },
    {
      "id": "ja140:4.3",
      "pali": "Atha haṁsavaruttamababbujaṭaṁ,"
    },
    {
      "id": "ja140:4.4",
      "pali": "Paṭanaṭṭhaka kākavarena dasāti."
    }
  ]
}
