{
  "uid": "tha-ap283",
  "title": "Paṇṇadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap283:1.1",
      "pali": "“Paṇṇasāle nisinnomhi,"
    },
    {
      "id": "tha-ap283:1.2",
      "pali": "paṇṇabhojanabhojano;"
    },
    {
      "id": "tha-ap283:1.3",
      "pali": "Upaviṭṭhañca maṁ santaṁ,"
    },
    {
      "id": "tha-ap283:1.4",
      "pali": "upāgacchi mahāisi."
    },
    {
      "id": "tha-ap283:2.1",
      "pali": "Siddhattho lokapajjoto,"
    },
    {
      "id": "tha-ap283:2.2",
      "pali": "sabbalokatikicchako;"
    },
    {
      "id": "tha-ap283:2.3",
      "pali": "Tassa paṇṇaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap283:2.4",
      "pali": "nisinnaṁ paṇṇasanthare."
    },
    {
      "id": "tha-ap283:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap283:3.2",
      "pali": "yaṁ paṇṇamadadiṁ tadā;"
    },
    {
      "id": "tha-ap283:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap283:3.4",
      "pali": "paṇṇadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap283:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap283:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap283:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap283:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap283:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṇṇadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap283:6.1",
      "pali": "Paṇṇadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
