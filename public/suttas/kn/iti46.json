{
  "uid": "iti46",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti46:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti46:2.1",
      "pali": "“Sikkhānisaṁsā, bhikkhave, viharatha paññuttarā vimuttisārā satādhipateyyā."
    },
    {
      "id": "iti46:2.2",
      "pali": "Sikkhānisaṁsānaṁ, bhikkhave, viharataṁ paññuttarānaṁ vimuttisārānaṁ satādhipateyyānaṁ dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "iti46:2.3",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "iti46:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti46:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti46:3.1",
      "pali": "“Paripuṇṇasikkhaṁ apahānadhammaṁ,"
    },
    {
      "id": "iti46:3.2",
      "pali": "Paññuttaraṁ jātikhayantadassiṁ;"
    },
    {
      "id": "iti46:3.3",
      "pali": "Taṁ ve muniṁ antimadehadhāriṁ,"
    },
    {
      "id": "iti46:3.4",
      "pali": "Mārañjahaṁ brūmi jarāya pāraguṁ."
    },
    {
      "id": "iti46:4.1",
      "pali": "Tasmā sadā jhānaratā samāhitā,"
    },
    {
      "id": "iti46:4.2",
      "pali": "Ātāpino jātikhayantadassino;"
    },
    {
      "id": "iti46:4.3",
      "pali": "Māraṁ sasenaṁ abhibhuyya bhikkhavo,"
    },
    {
      "id": "iti46:4.4",
      "pali": "Bhavatha jātimaraṇassa pāragā”ti."
    },
    {
      "id": "iti46:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti46:5.2",
      "pali": "Navamaṁ."
    }
  ]
}
