{
  "uid": "tha-ap61",
  "title": "Padumattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap61:1.1",
      "pali": "“Catusaccaṁ pakāsento,"
    },
    {
      "id": "tha-ap61:1.2",
      "pali": "varadhammappavattako;"
    },
    {
      "id": "tha-ap61:1.3",
      "pali": "Vassate amataṁ vuṭṭhiṁ,"
    },
    {
      "id": "tha-ap61:1.4",
      "pali": "nibbāpento mahājanaṁ."
    },
    {
      "id": "tha-ap61:2.1",
      "pali": "Sadhajaṁ padumaṁ gayha,"
    },
    {
      "id": "tha-ap61:2.2",
      "pali": "aḍḍhakose ṭhito ahaṁ;"
    },
    {
      "id": "tha-ap61:2.3",
      "pali": "Padumuttaramunissa,"
    },
    {
      "id": "tha-ap61:2.4",
      "pali": "pahaṭṭho ukkhipimambare."
    },
    {
      "id": "tha-ap61:3.1",
      "pali": "Āgacchante ca padume,"
    },
    {
      "id": "tha-ap61:3.2",
      "pali": "abbhuto āsi tāvade;"
    },
    {
      "id": "tha-ap61:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap61:3.4",
      "pali": "paggaṇhi vadataṁ varo."
    },
    {
      "id": "tha-ap61:4.1",
      "pali": "Karaseṭṭhena paggayha,"
    },
    {
      "id": "tha-ap61:4.2",
      "pali": "jalajaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap61:4.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap61:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap61:5.1",
      "pali": "‘Yenidaṁ padumaṁ khittaṁ,"
    },
    {
      "id": "tha-ap61:5.2",
      "pali": "sabbaññumhi vināyake;"
    },
    {
      "id": "tha-ap61:5.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap61:5.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap61:6.1",
      "pali": "Tiṁsakappāni devindo,"
    },
    {
      "id": "tha-ap61:6.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap61:6.3",
      "pali": "Pathabyā rajjaṁ sattasataṁ,"
    },
    {
      "id": "tha-ap61:6.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap61:7.1",
      "pali": "Tattha pattaṁ gaṇetvāna,"
    },
    {
      "id": "tha-ap61:7.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap61:7.3",
      "pali": "Ākāsato pupphavuṭṭhi,"
    },
    {
      "id": "tha-ap61:7.4",
      "pali": "abhivassissatī tadā."
    },
    {
      "id": "tha-ap61:8.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap61:8.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap61:8.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap61:8.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap61:9.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap61:9.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap61:9.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap61:9.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap61:10.1",
      "pali": "Nikkhamitvāna kucchimhā,"
    },
    {
      "id": "tha-ap61:10.2",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "tha-ap61:10.3",
      "pali": "Jātiyā pañcavassohaṁ,"
    },
    {
      "id": "tha-ap61:10.4",
      "pali": "arahattaṁ apāpuṇiṁ."
    },
    {
      "id": "tha-ap61:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap61:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap61:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap61:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap61:13.1",
      "pali": "Padumattherassāpadānaṁ navamaṁ."
    }
  ]
}
