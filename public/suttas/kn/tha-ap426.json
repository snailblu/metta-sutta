{
  "uid": "tha-ap426",
  "title": "Sattakadambapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap426:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap426:1.2",
      "pali": "kukkuṭo nāma pabbato;"
    },
    {
      "id": "tha-ap426:1.3",
      "pali": "Tamhi pabbatapādamhi,"
    },
    {
      "id": "tha-ap426:1.4",
      "pali": "satta buddhā vasiṁsu te."
    },
    {
      "id": "tha-ap426:2.1",
      "pali": "Kadambaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap426:2.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap426:2.3",
      "pali": "Satta mālā gahetvāna,"
    },
    {
      "id": "tha-ap426:2.4",
      "pali": "puññacittena okiriṁ."
    },
    {
      "id": "tha-ap426:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap426:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap426:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap426:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap426:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap426:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap426:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap426:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap426:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap426:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap426:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap426:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap426:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap426:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap426:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap426:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap426:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap426:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattakadambapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap426:9.1",
      "pali": "Sattakadambapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
