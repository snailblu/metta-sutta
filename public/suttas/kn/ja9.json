{
  "uid": "ja9",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja9:1.1",
      "pali": "“Uttamaṅgaruhā mayhaṁ,"
    },
    {
      "id": "ja9:1.2",
      "pali": "ime jātā vayoharā;"
    },
    {
      "id": "ja9:1.3",
      "pali": "Pātubhūtā devadūtā,"
    },
    {
      "id": "ja9:1.4",
      "pali": "pabbajjāsamayo mamā”ti."
    },
    {
      "id": "ja9:2.1",
      "pali": "Maghadevajātakaṁ navamaṁ."
    }
  ]
}
