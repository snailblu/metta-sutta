{
  "uid": "tha-ap227",
  "title": "Abyādhikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap227:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap227:1.2",
      "pali": "aggisālaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap227:1.3",
      "pali": "Byādhikānañca āvāsaṁ,"
    },
    {
      "id": "tha-ap227:1.4",
      "pali": "uṇhodakapaṭiggahaṁ."
    },
    {
      "id": "tha-ap227:2.1",
      "pali": "Tena kammenayaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap227:2.2",
      "pali": "attabhāvo sunimmito;"
    },
    {
      "id": "tha-ap227:2.3",
      "pali": "Byādhāhaṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap227:2.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap227:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap227:3.2",
      "pali": "yaṁ sālamadadiṁ tadā;"
    },
    {
      "id": "tha-ap227:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap227:3.4",
      "pali": "aggisālāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap227:4.1",
      "pali": "Ito ca sattame kappe,"
    },
    {
      "id": "tha-ap227:4.2",
      "pali": "ekosiṁ aparājito;"
    },
    {
      "id": "tha-ap227:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap227:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap227:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap227:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap227:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap227:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā abyādhiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap227:7.1",
      "pali": "Abyādhikattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
