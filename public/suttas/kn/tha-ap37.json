{
  "uid": "tha-ap37",
  "title": "Mogharājattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap37:1.1",
      "pali": "“Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap37:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap37:1.3",
      "pali": "Bhikkhusaṅghaparibyūḷho,"
    },
    {
      "id": "tha-ap37:1.4",
      "pali": "rathiyaṁ paṭipajjatha."
    },
    {
      "id": "tha-ap37:2.1",
      "pali": "Sissehi samparivuto,"
    },
    {
      "id": "tha-ap37:2.2",
      "pali": "gharamhā abhinikkhamiṁ;"
    },
    {
      "id": "tha-ap37:2.3",
      "pali": "Nikkhamitvānahaṁ tattha,"
    },
    {
      "id": "tha-ap37:2.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap37:3.1",
      "pali": "Abhivādiya sambuddhaṁ,"
    },
    {
      "id": "tha-ap37:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap37:3.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap37:3.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap37:4.1",
      "pali": "Yāvatā rūpino sattā,"
    },
    {
      "id": "tha-ap37:4.2",
      "pali": "arūpī vā asaññino;"
    },
    {
      "id": "tha-ap37:4.3",
      "pali": "Sabbe te tava ñāṇamhi,"
    },
    {
      "id": "tha-ap37:4.4",
      "pali": "anto honti samogadhā."
    },
    {
      "id": "tha-ap37:5.1",
      "pali": "Sukhumacchikajālena,"
    },
    {
      "id": "tha-ap37:5.2",
      "pali": "udakaṁ yo parikkhipe;"
    },
    {
      "id": "tha-ap37:5.3",
      "pali": "Ye keci udake pāṇā,"
    },
    {
      "id": "tha-ap37:5.4",
      "pali": "antojāle bhavanti te."
    },
    {
      "id": "tha-ap37:6.1",
      "pali": "Yesañca cetanā atthi,"
    },
    {
      "id": "tha-ap37:6.2",
      "pali": "rūpino ca arūpino;"
    },
    {
      "id": "tha-ap37:6.3",
      "pali": "Sabbe te tava ñāṇamhi,"
    },
    {
      "id": "tha-ap37:6.4",
      "pali": "anto honti samogadhā."
    },
    {
      "id": "tha-ap37:7.1",
      "pali": "Samuddharasimaṁ lokaṁ,"
    },
    {
      "id": "tha-ap37:7.2",
      "pali": "andhakārasamākulaṁ;"
    },
    {
      "id": "tha-ap37:7.3",
      "pali": "Tava dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap37:7.4",
      "pali": "kaṅkhāsotaṁ taranti te."
    },
    {
      "id": "tha-ap37:8.1",
      "pali": "Avijjānivute loke,"
    },
    {
      "id": "tha-ap37:8.2",
      "pali": "andhakārena otthaṭe;"
    },
    {
      "id": "tha-ap37:8.3",
      "pali": "Tava ñāṇamhi jotante,"
    },
    {
      "id": "tha-ap37:8.4",
      "pali": "andhakārā padhaṁsitā."
    },
    {
      "id": "tha-ap37:9.1",
      "pali": "Tuvaṁ cakkhūsi sabbesaṁ,"
    },
    {
      "id": "tha-ap37:9.2",
      "pali": "mahātamapanūdano;"
    },
    {
      "id": "tha-ap37:9.3",
      "pali": "Tava dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap37:9.4",
      "pali": "nibbāyati bahujjano."
    },
    {
      "id": "tha-ap37:10.1",
      "pali": "Puṭakaṁ pūrayitvāna,"
    },
    {
      "id": "tha-ap37:10.2",
      "pali": "madhukhuddamaneḷakaṁ;"
    },
    {
      "id": "tha-ap37:10.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap37:10.4",
      "pali": "upanesiṁ mahesino."
    },
    {
      "id": "tha-ap37:11.1",
      "pali": "Paṭiggaṇhi mahāvīro,"
    },
    {
      "id": "tha-ap37:11.2",
      "pali": "sahatthena mahā isi;"
    },
    {
      "id": "tha-ap37:11.3",
      "pali": "Bhuñjitvā tañca sabbaññū,"
    },
    {
      "id": "tha-ap37:11.4",
      "pali": "vehāsaṁ nabhamuggami."
    },
    {
      "id": "tha-ap37:12.1",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap37:12.2",
      "pali": "atthadassī narāsabho;"
    },
    {
      "id": "tha-ap37:12.3",
      "pali": "Mama cittaṁ pasādento,"
    },
    {
      "id": "tha-ap37:12.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap37:13.1",
      "pali": "‘Yenidaṁ thavitaṁ ñāṇaṁ,"
    },
    {
      "id": "tha-ap37:13.2",
      "pali": "buddhaseṭṭho ca thomito;"
    },
    {
      "id": "tha-ap37:13.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap37:13.4",
      "pali": "duggatiṁ so na gacchati."
    },
    {
      "id": "tha-ap37:14.1",
      "pali": "Catuddasañcakkhattuṁ so,"
    },
    {
      "id": "tha-ap37:14.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap37:14.3",
      "pali": "Pathabyā rajjaṁ aṭṭhasataṁ,"
    },
    {
      "id": "tha-ap37:14.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap37:15.1",
      "pali": "Pañceva satakkhattuñca,"
    },
    {
      "id": "tha-ap37:15.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap37:15.3",
      "pali": "Padesarajjaṁ asaṅkheyyaṁ,"
    },
    {
      "id": "tha-ap37:15.4",
      "pali": "mahiyā kārayissati."
    },
    {
      "id": "tha-ap37:16.1",
      "pali": "Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap37:16.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap37:16.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap37:16.4",
      "pali": "sāsane pabbajissati."
    },
    {
      "id": "tha-ap37:17.1",
      "pali": "Gambhīraṁ nipuṇaṁ atthaṁ,"
    },
    {
      "id": "tha-ap37:17.2",
      "pali": "ñāṇena vicinissati;"
    },
    {
      "id": "tha-ap37:17.3",
      "pali": "Mogharājāti nāmena,"
    },
    {
      "id": "tha-ap37:17.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap37:18.1",
      "pali": "Tīhi vijjāhi sampannaṁ,"
    },
    {
      "id": "tha-ap37:18.2",
      "pali": "katakiccamanāsavaṁ;"
    },
    {
      "id": "tha-ap37:18.3",
      "pali": "Gotamo satthavāhaggo,"
    },
    {
      "id": "tha-ap37:18.4",
      "pali": "etadagge ṭhapessati’."
    },
    {
      "id": "tha-ap37:19.1",
      "pali": "Hitvā mānusakaṁ yogaṁ,"
    },
    {
      "id": "tha-ap37:19.2",
      "pali": "chetvāna bhavabandhanaṁ;"
    },
    {
      "id": "tha-ap37:19.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap37:19.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap37:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap37:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap37:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap37:21.1",
      "pali": "Itthaṁ sudaṁ āyasmā mogharājo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap37:22.1",
      "pali": "Mogharājattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
