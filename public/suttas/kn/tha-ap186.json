{
  "uid": "tha-ap186",
  "title": "Pañcahatthiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap186:1.1",
      "pali": "“Tisso nāmāsi bhagavā,"
    },
    {
      "id": "tha-ap186:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap186:1.3",
      "pali": "Purakkhato sāvakehi,"
    },
    {
      "id": "tha-ap186:1.4",
      "pali": "rathiyaṁ paṭipajjatha."
    },
    {
      "id": "tha-ap186:2.1",
      "pali": "Pañca uppalahatthā ca,"
    },
    {
      "id": "tha-ap186:2.2",
      "pali": "cāturā ṭhapitā mayā;"
    },
    {
      "id": "tha-ap186:2.3",
      "pali": "Āhutiṁ dātukāmohaṁ,"
    },
    {
      "id": "tha-ap186:2.4",
      "pali": "paggaṇhiṁ vatasiddhiyā."
    },
    {
      "id": "tha-ap186:3.1",
      "pali": "Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap186:3.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap186:3.3",
      "pali": "Buddharaṁsīhi phuṭṭhosmi,"
    },
    {
      "id": "tha-ap186:3.4",
      "pali": "Pūjesiṁ dvipaduttamaṁ."
    },
    {
      "id": "tha-ap186:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap186:4.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap186:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap186:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap186:5.1",
      "pali": "Ito terasakappamhi,"
    },
    {
      "id": "tha-ap186:5.2",
      "pali": "pañca susabhasammatā;"
    },
    {
      "id": "tha-ap186:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap186:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap186:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap186:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap186:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap186:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pañcahatthiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap186:8.1",
      "pali": "Pañcahatthiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
