{
  "uid": "ja462",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja462:1.1",
      "pali": "“Jānanto no mahārāja,"
    },
    {
      "id": "ja462:1.2",
      "pali": "tava sīlaṁ janādhipo;"
    },
    {
      "id": "ja462:1.3",
      "pali": "Ime kumāre pūjento,"
    },
    {
      "id": "ja462:1.4",
      "pali": "na taṁ kenaci maññatha."
    },
    {
      "id": "ja462:2.1",
      "pali": "Tiṭṭhante no mahārāje,"
    },
    {
      "id": "ja462:2.2",
      "pali": "adu deve divaṅgate;"
    },
    {
      "id": "ja462:2.3",
      "pali": "Ñātī taṁ samanuññiṁsu,"
    },
    {
      "id": "ja462:2.4",
      "pali": "sampassaṁ atthamattano."
    },
    {
      "id": "ja462:3.1",
      "pali": "Kena saṁvara vattena,"
    },
    {
      "id": "ja462:3.2",
      "pali": "sañjāte abhitiṭṭhasi;"
    },
    {
      "id": "ja462:3.3",
      "pali": "Kena taṁ nātivattanti,"
    },
    {
      "id": "ja462:3.4",
      "pali": "ñātisaṅghā samāgatā”."
    },
    {
      "id": "ja462:4.1",
      "pali": "“Na rājaputta usūyāmi,"
    },
    {
      "id": "ja462:4.2",
      "pali": "samaṇānaṁ mahesinaṁ;"
    },
    {
      "id": "ja462:4.3",
      "pali": "Sakkaccaṁ te namassāmi,"
    },
    {
      "id": "ja462:4.4",
      "pali": "pāde vandāmi tādinaṁ."
    },
    {
      "id": "ja462:5.1",
      "pali": "Te maṁ dhammaguṇe yuttaṁ,"
    },
    {
      "id": "ja462:5.2",
      "pali": "sussūsamanusūyakaṁ;"
    },
    {
      "id": "ja462:5.3",
      "pali": "Samaṇā manusāsanti,"
    },
    {
      "id": "ja462:5.4",
      "pali": "isī dhammaguṇe ratā."
    },
    {
      "id": "ja462:6.1",
      "pali": "Tesāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja462:6.2",
      "pali": "samaṇānaṁ mahesinaṁ;"
    },
    {
      "id": "ja462:6.3",
      "pali": "Na kiñci atimaññāmi,"
    },
    {
      "id": "ja462:6.4",
      "pali": "dhamme me nirato mano."
    },
    {
      "id": "ja462:7.1",
      "pali": "Hatthārohā anīkaṭṭhā,"
    },
    {
      "id": "ja462:7.2",
      "pali": "rathikā pattikārakā;"
    },
    {
      "id": "ja462:7.3",
      "pali": "Tesaṁ nappaṭibandhāmi,"
    },
    {
      "id": "ja462:7.4",
      "pali": "niviṭṭhaṁ bhattavetanaṁ."
    },
    {
      "id": "ja462:8.1",
      "pali": "Mahāmattā ca me atthi,"
    },
    {
      "id": "ja462:8.2",
      "pali": "mantino paricārakā;"
    },
    {
      "id": "ja462:8.3",
      "pali": "Bārāṇasiṁ voharanti,"
    },
    {
      "id": "ja462:8.4",
      "pali": "bahumaṁsasurodakaṁ."
    },
    {
      "id": "ja462:9.1",
      "pali": "Athopi vāṇijā phītā,"
    },
    {
      "id": "ja462:9.2",
      "pali": "nānāraṭṭhehi āgatā;"
    },
    {
      "id": "ja462:9.3",
      "pali": "Tesu me vihitā rakkhā,"
    },
    {
      "id": "ja462:9.4",
      "pali": "evaṁ jānāhuposatha”."
    },
    {
      "id": "ja462:10.1",
      "pali": "“Dhammena kira ñātīnaṁ,"
    },
    {
      "id": "ja462:10.2",
      "pali": "rajjaṁ kārehi saṁvara;"
    },
    {
      "id": "ja462:10.3",
      "pali": "Medhāvī paṇḍito cāsi,"
    },
    {
      "id": "ja462:10.4",
      "pali": "athopi ñātinaṁ hito."
    },
    {
      "id": "ja462:11.1",
      "pali": "Taṁ taṁ ñātiparibyūḷhaṁ,"
    },
    {
      "id": "ja462:11.2",
      "pali": "nānāratanamocitaṁ;"
    },
    {
      "id": "ja462:11.3",
      "pali": "Amittā nappasahanti,"
    },
    {
      "id": "ja462:11.4",
      "pali": "indaṁva asurādhipo”ti."
    },
    {
      "id": "ja462:12.1",
      "pali": "Saṁvarajātakaṁ aṭṭhamaṁ."
    }
  ]
}
