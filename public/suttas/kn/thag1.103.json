{
  "uid": "thag1.103",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.103:1.1",
      "pali": "“Nāhaṁ etena atthiko,"
    },
    {
      "id": "thag1.103:1.2",
      "pali": "Sukhito dhammarasena tappito;"
    },
    {
      "id": "thag1.103:1.3",
      "pali": "Pitvā rasaggamuttamaṁ,"
    },
    {
      "id": "thag1.103:1.4",
      "pali": "Na ca kāhāmi visena santhavan”ti."
    },
    {
      "id": "thag1.103:1.5",
      "pali": "… Bandhuro thero …."
    }
  ]
}
