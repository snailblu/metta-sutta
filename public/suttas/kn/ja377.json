{
  "uid": "ja377",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja377:1.1",
      "pali": "“Mā tāta kujjhi na hi sādhu kodho,"
    },
    {
      "id": "ja377:1.2",
      "pali": "Bahumpi te adiṭṭhamassutañca;"
    },
    {
      "id": "ja377:1.3",
      "pali": "Mātā pitā disatā setaketu,"
    },
    {
      "id": "ja377:1.4",
      "pali": "Ācariyamāhu disataṁ pasatthā."
    },
    {
      "id": "ja377:2.1",
      "pali": "Agārino annadapānavatthadā,"
    },
    {
      "id": "ja377:2.2",
      "pali": "Avhāyikā tampi disaṁ vadanti;"
    },
    {
      "id": "ja377:2.3",
      "pali": "Esā disā paramā setaketu,"
    },
    {
      "id": "ja377:2.4",
      "pali": "Yaṁ patvā dukkhī sukhino bhavanti”."
    },
    {
      "id": "ja377:3.1",
      "pali": "“Kharājinā jaṭilā paṅkadantā,"
    },
    {
      "id": "ja377:3.2",
      "pali": "Dummakkharūpā yeme jappanti mante;"
    },
    {
      "id": "ja377:3.3",
      "pali": "Kacci nu te mānusake payoge,"
    },
    {
      "id": "ja377:3.4",
      "pali": "Idaṁ vidū parimuttā apāyā”."
    },
    {
      "id": "ja377:4.1",
      "pali": "“Pāpāni kammāni katvāna rāja,"
    },
    {
      "id": "ja377:4.2",
      "pali": "Bahussuto ce na careyya dhammaṁ;"
    },
    {
      "id": "ja377:4.3",
      "pali": "Sahassavedopi na taṁ paṭicca,"
    },
    {
      "id": "ja377:4.4",
      "pali": "Dukkhā pamucce caraṇaṁ apatvā”."
    },
    {
      "id": "ja377:5.1",
      "pali": "“Sahassavedopi na taṁ paṭicca,"
    },
    {
      "id": "ja377:5.2",
      "pali": "Dukkhā pamucce caraṇaṁ apatvā;"
    },
    {
      "id": "ja377:5.3",
      "pali": "Maññāmi vedā aphalā bhavanti,"
    },
    {
      "id": "ja377:5.4",
      "pali": "Sasaṁyamaṁ caraṇameva saccaṁ”."
    },
    {
      "id": "ja377:6.1",
      "pali": "“Na heva vedā aphalā bhavanti,"
    },
    {
      "id": "ja377:6.2",
      "pali": "Sasaṁyamaṁ caraṇameva saccaṁ;"
    },
    {
      "id": "ja377:6.3",
      "pali": "Kittiñhi pappoti adhicca vede,"
    },
    {
      "id": "ja377:6.4",
      "pali": "Santiṁ puṇeti caraṇena danto”ti."
    },
    {
      "id": "ja377:7.1",
      "pali": "Setaketujātakaṁ dutiyaṁ."
    }
  ]
}
