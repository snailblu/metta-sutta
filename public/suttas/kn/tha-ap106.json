{
  "uid": "tha-ap106",
  "title": "Padapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap106:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap106:1.2",
      "pali": "jātipupphamadāsahaṁ;"
    },
    {
      "id": "tha-ap106:1.3",
      "pali": "Pādesu satta pupphāni,"
    },
    {
      "id": "tha-ap106:1.4",
      "pali": "hāsenokiritāni me."
    },
    {
      "id": "tha-ap106:2.1",
      "pali": "Tena kammenahaṁ ajja,"
    },
    {
      "id": "tha-ap106:2.2",
      "pali": "abhibhomi narāmare;"
    },
    {
      "id": "tha-ap106:2.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap106:2.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap106:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap106:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap106:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap106:3.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap106:4.1",
      "pali": "Samantagandhanāmāsuṁ,"
    },
    {
      "id": "tha-ap106:4.2",
      "pali": "terasa cakkavattino;"
    },
    {
      "id": "tha-ap106:4.3",
      "pali": "Ito pañcamake kappe,"
    },
    {
      "id": "tha-ap106:4.4",
      "pali": "cāturantā janādhipā."
    },
    {
      "id": "tha-ap106:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap106:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap106:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap106:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā padapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap106:7.1",
      "pali": "Padapūjakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
