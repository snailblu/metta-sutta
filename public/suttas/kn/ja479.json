{
  "uid": "ja479",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja479:1.1",
      "pali": "Rājā kāliṅgo cakkavatti,"
    },
    {
      "id": "ja479:1.2",
      "pali": "Dhammena pathavimanusāsaṁ;"
    },
    {
      "id": "ja479:1.3",
      "pali": "Agamā bodhisamīpaṁ,"
    },
    {
      "id": "ja479:1.4",
      "pali": "Nāgena mahānubhāvena."
    },
    {
      "id": "ja479:2.1",
      "pali": "Kāliṅgo bhāradvājo ca,"
    },
    {
      "id": "ja479:2.2",
      "pali": "Rājānaṁ kāliṅgaṁ samaṇakolaññaṁ;"
    },
    {
      "id": "ja479:2.3",
      "pali": "Cakkaṁ vattayato pariggahetvā,"
    },
    {
      "id": "ja479:2.4",
      "pali": "Pañjalī idamavoca."
    },
    {
      "id": "ja479:3.1",
      "pali": "“Paccoroha mahārāja,"
    },
    {
      "id": "ja479:3.2",
      "pali": "Bhūmibhāgo yathā samaṇuggato;"
    },
    {
      "id": "ja479:3.3",
      "pali": "Idha anadhivarā buddhā,"
    },
    {
      "id": "ja479:3.4",
      "pali": "Abhisambuddhā virocanti."
    },
    {
      "id": "ja479:4.1",
      "pali": "Padakkhiṇato āvaṭṭā,"
    },
    {
      "id": "ja479:4.2",
      "pali": "Tiṇalatā asmiṁ bhūmibhāgasmiṁ;"
    },
    {
      "id": "ja479:4.3",
      "pali": "Pathaviyā nābhiyaṁ maṇḍo,"
    },
    {
      "id": "ja479:4.4",
      "pali": "Iti no sutaṁ mante mahārāja."
    },
    {
      "id": "ja479:5.1",
      "pali": "Sāgarapariyantāya,"
    },
    {
      "id": "ja479:5.2",
      "pali": "Mediniyā sabbabhūtadharaṇiyā;"
    },
    {
      "id": "ja479:5.3",
      "pali": "Pathaviyā ayaṁ maṇḍo,"
    },
    {
      "id": "ja479:5.4",
      "pali": "Orohitvā namo karohi."
    },
    {
      "id": "ja479:6.1",
      "pali": "Ye te bhavanti nāgā ca,"
    },
    {
      "id": "ja479:6.2",
      "pali": "abhijātā ca kuñjarā;"
    },
    {
      "id": "ja479:6.3",
      "pali": "Ettāvatā padesaṁ te,"
    },
    {
      "id": "ja479:6.4",
      "pali": "nāgā neva mupayanti."
    },
    {
      "id": "ja479:7.1",
      "pali": "Abhijāto nāgo kāmaṁ,"
    },
    {
      "id": "ja479:7.2",
      "pali": "Pesehi kuñjaraṁ dantiṁ;"
    },
    {
      "id": "ja479:7.3",
      "pali": "Ettāvatā padeso,"
    },
    {
      "id": "ja479:7.4",
      "pali": "Sakkā nāgena mupagantuṁ."
    },
    {
      "id": "ja479:8.1",
      "pali": "Taṁ sutvā rājā kāliṅgo,"
    },
    {
      "id": "ja479:8.2",
      "pali": "Veyyañjanikavaco nisāmetvā;"
    },
    {
      "id": "ja479:8.3",
      "pali": "Sampesesi nāgaṁ ñassāma,"
    },
    {
      "id": "ja479:8.4",
      "pali": "Mayaṁ yathimassidaṁ vacanaṁ”."
    },
    {
      "id": "ja479:9.1",
      "pali": "Sampesito ca raññā,"
    },
    {
      "id": "ja479:9.2",
      "pali": "Nāgo koñcova abhinaditvāna;"
    },
    {
      "id": "ja479:9.3",
      "pali": "Paṭisakkitvā nisīdi,"
    },
    {
      "id": "ja479:9.4",
      "pali": "Garuṁva bhāraṁ asahamāno."
    },
    {
      "id": "ja479:10.1",
      "pali": "Kāliṅgabhāradvājo,"
    },
    {
      "id": "ja479:10.2",
      "pali": "Nāgaṁ khīṇāyukaṁ viditvāna;"
    },
    {
      "id": "ja479:10.3",
      "pali": "Rājānaṁ kāliṅgaṁ,"
    },
    {
      "id": "ja479:10.4",
      "pali": "Taramāno ajjhabhāsittha;"
    },
    {
      "id": "ja479:10.5",
      "pali": "“Aññaṁ saṅkama nāgaṁ,"
    },
    {
      "id": "ja479:10.6",
      "pali": "Nāgo khīṇāyuko mahārāja”."
    },
    {
      "id": "ja479:11.1",
      "pali": "Taṁ sutvā kāliṅgo,"
    },
    {
      "id": "ja479:11.2",
      "pali": "taramāno saṅkamī nāgaṁ;"
    },
    {
      "id": "ja479:11.3",
      "pali": "Saṅkanteva raññe,"
    },
    {
      "id": "ja479:11.4",
      "pali": "nāgo tattheva pati bhumyā;"
    },
    {
      "id": "ja479:11.5",
      "pali": "Veyyañjanikavaco,"
    },
    {
      "id": "ja479:11.6",
      "pali": "yathā tathā ahu nāgo."
    },
    {
      "id": "ja479:12.1",
      "pali": "Kāliṅgo rājā kāliṅgaṁ,"
    },
    {
      "id": "ja479:12.2",
      "pali": "brāhmaṇaṁ etadavoca;"
    },
    {
      "id": "ja479:12.3",
      "pali": "“Tvameva asi sambuddho,"
    },
    {
      "id": "ja479:12.4",
      "pali": "sabbaññū sabbadassāvī”."
    },
    {
      "id": "ja479:13.1",
      "pali": "Taṁ anadhivāsento kāliṅgaṁ,"
    },
    {
      "id": "ja479:13.2",
      "pali": "Brāhmaṇo idamavoca;"
    },
    {
      "id": "ja479:13.3",
      "pali": "“Veyyañjanikā hi mayaṁ,"
    },
    {
      "id": "ja479:13.4",
      "pali": "Buddhā sabbaññuno mahārāja."
    },
    {
      "id": "ja479:14.1",
      "pali": "Sabbaññū sabbavidū ca,"
    },
    {
      "id": "ja479:14.2",
      "pali": "Buddhā na lakkhaṇena jānanti;"
    },
    {
      "id": "ja479:14.3",
      "pali": "Āgamabalasā hi mayaṁ,"
    },
    {
      "id": "ja479:14.4",
      "pali": "Buddhā sabbaṁ pajānanti”."
    },
    {
      "id": "ja479:15.1",
      "pali": "Mahayitvā sambodhiṁ,"
    },
    {
      "id": "ja479:15.2",
      "pali": "Nānāturiyehi vajjamānehi;"
    },
    {
      "id": "ja479:15.3",
      "pali": "Mālāvilepanaṁ abhiharitvā,"
    },
    {
      "id": "ja479:15.4",
      "pali": "Atha rājā manupāyāsi."
    },
    {
      "id": "ja479:16.1",
      "pali": "Saṭṭhi vāhasahassāni,"
    },
    {
      "id": "ja479:16.2",
      "pali": "pupphānaṁ sannipātayi;"
    },
    {
      "id": "ja479:16.3",
      "pali": "Pūjesi rājā kāliṅgo,"
    },
    {
      "id": "ja479:16.4",
      "pali": "bodhimaṇḍamanuttaranti."
    },
    {
      "id": "ja479:17.1",
      "pali": "Kāliṅgabodhijātakaṁ chaṭṭhaṁ."
    }
  ]
}
