{
  "uid": "tha-ap399",
  "title": "Girimānandattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap399:1.1",
      "pali": "“Bhariyā me kālaṅkatā,"
    },
    {
      "id": "tha-ap399:1.2",
      "pali": "putto sīvathikaṁ gato;"
    },
    {
      "id": "tha-ap399:1.3",
      "pali": "Mātā pitā matā bhātā,"
    },
    {
      "id": "tha-ap399:1.4",
      "pali": "ekacitamhi ḍayhare."
    },
    {
      "id": "tha-ap399:2.1",
      "pali": "Tena sokena santatto,"
    },
    {
      "id": "tha-ap399:2.2",
      "pali": "kiso paṇḍu ahosahaṁ;"
    },
    {
      "id": "tha-ap399:2.3",
      "pali": "Cittakkhepo ca me āsi,"
    },
    {
      "id": "tha-ap399:2.4",
      "pali": "tena sokena aṭṭito."
    },
    {
      "id": "tha-ap399:3.1",
      "pali": "Sokasallaparetohaṁ,"
    },
    {
      "id": "tha-ap399:3.2",
      "pali": "vanantamupasaṅkamiṁ;"
    },
    {
      "id": "tha-ap399:3.3",
      "pali": "Pavattaphalaṁ bhuñjitvā,"
    },
    {
      "id": "tha-ap399:3.4",
      "pali": "rukkhamūle vasāmahaṁ."
    },
    {
      "id": "tha-ap399:4.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap399:4.2",
      "pali": "dukkhassantakaro jino;"
    },
    {
      "id": "tha-ap399:4.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap399:4.4",
      "pali": "āgañchi mama santikaṁ."
    },
    {
      "id": "tha-ap399:5.1",
      "pali": "Padasaddaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap399:5.2",
      "pali": "sumedhassa mahesino;"
    },
    {
      "id": "tha-ap399:5.3",
      "pali": "Paggahetvānahaṁ sīsaṁ,"
    },
    {
      "id": "tha-ap399:5.4",
      "pali": "ullokesiṁ mahāmuniṁ."
    },
    {
      "id": "tha-ap399:6.1",
      "pali": "Upāgate mahāvīre,"
    },
    {
      "id": "tha-ap399:6.2",
      "pali": "pīti me udapajjatha;"
    },
    {
      "id": "tha-ap399:6.3",
      "pali": "Tadāsimekaggamano,"
    },
    {
      "id": "tha-ap399:6.4",
      "pali": "disvā taṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap399:7.1",
      "pali": "Satiṁ paṭilabhitvāna,"
    },
    {
      "id": "tha-ap399:7.2",
      "pali": "paṇṇamuṭṭhimadāsahaṁ;"
    },
    {
      "id": "tha-ap399:7.3",
      "pali": "Nisīdi bhagavā tattha,"
    },
    {
      "id": "tha-ap399:7.4",
      "pali": "anukampāya cakkhumā."
    },
    {
      "id": "tha-ap399:8.1",
      "pali": "Nisajja tattha bhagavā,"
    },
    {
      "id": "tha-ap399:8.2",
      "pali": "sumedho lokanāyako;"
    },
    {
      "id": "tha-ap399:8.3",
      "pali": "Dhammaṁ me kathayī buddho,"
    },
    {
      "id": "tha-ap399:8.4",
      "pali": "sokasallavinodanaṁ."
    },
    {
      "id": "tha-ap399:9.1",
      "pali": "‘Anavhitā tato āguṁ,"
    },
    {
      "id": "tha-ap399:9.2",
      "pali": "ananuññātā ito gatā;"
    },
    {
      "id": "tha-ap399:9.3",
      "pali": "Yathāgatā tathā gatā,"
    },
    {
      "id": "tha-ap399:9.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "tha-ap399:10.1",
      "pali": "Yathāpi pathikā sattā,"
    },
    {
      "id": "tha-ap399:10.2",
      "pali": "vassamānāya vuṭṭhiyā;"
    },
    {
      "id": "tha-ap399:10.3",
      "pali": "Sabhaṇḍā upagacchanti,"
    },
    {
      "id": "tha-ap399:10.4",
      "pali": "vassassāpatanāya te."
    },
    {
      "id": "tha-ap399:11.1",
      "pali": "Vasse ca te oramite,"
    },
    {
      "id": "tha-ap399:11.2",
      "pali": "sampayanti yadicchakaṁ;"
    },
    {
      "id": "tha-ap399:11.3",
      "pali": "Evaṁ mātā pitā tuyhaṁ,"
    },
    {
      "id": "tha-ap399:11.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "tha-ap399:12.1",
      "pali": "Āgantukā pāhunakā,"
    },
    {
      "id": "tha-ap399:12.2",
      "pali": "caliteritakampitā;"
    },
    {
      "id": "tha-ap399:12.3",
      "pali": "Evaṁ mātā pitā tuyhaṁ,"
    },
    {
      "id": "tha-ap399:12.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "tha-ap399:13.1",
      "pali": "Yathāpi urago jiṇṇaṁ,"
    },
    {
      "id": "tha-ap399:13.2",
      "pali": "hitvā gacchati saṁ tacaṁ;"
    },
    {
      "id": "tha-ap399:13.3",
      "pali": "Evaṁ mātā pitā tuyhaṁ,"
    },
    {
      "id": "tha-ap399:13.4",
      "pali": "saṁ tanuṁ idha hīyare’."
    },
    {
      "id": "tha-ap399:14.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap399:14.2",
      "pali": "sokasallaṁ vivajjayiṁ;"
    },
    {
      "id": "tha-ap399:14.3",
      "pali": "Pāmojjaṁ janayitvāna,"
    },
    {
      "id": "tha-ap399:14.4",
      "pali": "buddhaseṭṭhaṁ avandahaṁ."
    },
    {
      "id": "tha-ap399:15.1",
      "pali": "Vanditvāna mahānāgaṁ,"
    },
    {
      "id": "tha-ap399:15.2",
      "pali": "Pūjayiṁ girimañjariṁ;"
    },
    {
      "id": "tha-ap399:15.3",
      "pali": "Dibbagandhaṁ sampavantaṁ,"
    },
    {
      "id": "tha-ap399:15.4",
      "pali": "Sumedhaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap399:16.1",
      "pali": "Pūjayitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap399:16.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap399:16.3",
      "pali": "Anussaraṁ guṇaggāni,"
    },
    {
      "id": "tha-ap399:16.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap399:17.1",
      "pali": "‘Nittiṇṇosi mahāvīra,"
    },
    {
      "id": "tha-ap399:17.2",
      "pali": "sabbaññu lokanāyaka;"
    },
    {
      "id": "tha-ap399:17.3",
      "pali": "Sabbe satte uddharasi,"
    },
    {
      "id": "tha-ap399:17.4",
      "pali": "ñāṇena tvaṁ mahāmune."
    },
    {
      "id": "tha-ap399:18.1",
      "pali": "Vimatiṁ dveḷhakaṁ vāpi,"
    },
    {
      "id": "tha-ap399:18.2",
      "pali": "sañchindasi mahāmune;"
    },
    {
      "id": "tha-ap399:18.3",
      "pali": "Paṭipādesi me maggaṁ,"
    },
    {
      "id": "tha-ap399:18.4",
      "pali": "tava ñāṇena cakkhuma."
    },
    {
      "id": "tha-ap399:19.1",
      "pali": "Arahā vasipattā ca,"
    },
    {
      "id": "tha-ap399:19.2",
      "pali": "chaḷabhiññā mahiddhikā;"
    },
    {
      "id": "tha-ap399:19.3",
      "pali": "Antalikkhacarā dhīrā,"
    },
    {
      "id": "tha-ap399:19.4",
      "pali": "parivārenti tāvade."
    },
    {
      "id": "tha-ap399:20.1",
      "pali": "Paṭipannā ca sekhā ca,"
    },
    {
      "id": "tha-ap399:20.2",
      "pali": "phalaṭṭhā santi sāvakā;"
    },
    {
      "id": "tha-ap399:20.3",
      "pali": "Sūrodayeva padumā,"
    },
    {
      "id": "tha-ap399:20.4",
      "pali": "pupphanti tava sāvakā."
    },
    {
      "id": "tha-ap399:21.1",
      "pali": "Mahāsamuddovakkhobho,"
    },
    {
      "id": "tha-ap399:21.2",
      "pali": "atulopi duruttaro;"
    },
    {
      "id": "tha-ap399:21.3",
      "pali": "Evaṁ ñāṇena sampanno,"
    },
    {
      "id": "tha-ap399:21.4",
      "pali": "appameyyosi cakkhuma’."
    },
    {
      "id": "tha-ap399:22.1",
      "pali": "Vanditvāhaṁ lokajinaṁ,"
    },
    {
      "id": "tha-ap399:22.2",
      "pali": "cakkhumantaṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap399:22.3",
      "pali": "Puthu disā namassanto,"
    },
    {
      "id": "tha-ap399:22.4",
      "pali": "paṭikuṭiko agañchahaṁ."
    },
    {
      "id": "tha-ap399:23.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap399:23.2",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "tha-ap399:23.3",
      "pali": "Okkamiṁ mātuyā kucchiṁ,"
    },
    {
      "id": "tha-ap399:23.4",
      "pali": "sandhāvanto bhavābhave."
    },
    {
      "id": "tha-ap399:24.1",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap399:24.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap399:24.3",
      "pali": "Ātāpī nipako jhāyī,"
    },
    {
      "id": "tha-ap399:24.4",
      "pali": "paṭisallānagocaro."
    },
    {
      "id": "tha-ap399:25.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "tha-ap399:25.2",
      "pali": "tosayitvā mahāmuniṁ;"
    },
    {
      "id": "tha-ap399:25.3",
      "pali": "Candovabbhaghanā mutto,"
    },
    {
      "id": "tha-ap399:25.4",
      "pali": "vicarāmi ahaṁ sadā."
    },
    {
      "id": "tha-ap399:26.1",
      "pali": "Vivekamanuyuttomhi,"
    },
    {
      "id": "tha-ap399:26.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap399:26.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap399:26.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap399:27.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap399:27.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap399:27.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap399:27.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap399:28.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap399:28.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap399:28.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap399:28.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap399:29.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap399:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap399:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap399:30.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap399:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap399:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap399:31.1",
      "pali": "Itthaṁ sudaṁ āyasmā girimānando thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap399:32.1",
      "pali": "Girimānandattherassāpadānaṁ sattamaṁ."
    }
  ]
}
