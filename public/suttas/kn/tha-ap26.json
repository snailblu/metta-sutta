{
  "uid": "tha-ap26",
  "title": "Pañcasīlasamādāniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap26:1.1",
      "pali": "“Nagare candavatiyā,"
    },
    {
      "id": "tha-ap26:1.2",
      "pali": "bhatako āsahaṁ tadā;"
    },
    {
      "id": "tha-ap26:1.3",
      "pali": "Parakammāyane yutto,"
    },
    {
      "id": "tha-ap26:1.4",
      "pali": "pabbajjaṁ na labhāmahaṁ."
    },
    {
      "id": "tha-ap26:2.1",
      "pali": "Mahandhakārapihitā,"
    },
    {
      "id": "tha-ap26:2.2",
      "pali": "tividhaggīhi ḍayhare;"
    },
    {
      "id": "tha-ap26:2.3",
      "pali": "Kena nu kho upāyena,"
    },
    {
      "id": "tha-ap26:2.4",
      "pali": "visaṁyutto bhave ahaṁ."
    },
    {
      "id": "tha-ap26:3.1",
      "pali": "Deyyadhammo ca me natthi,"
    },
    {
      "id": "tha-ap26:3.2",
      "pali": "varāko bhatako ahaṁ;"
    },
    {
      "id": "tha-ap26:3.3",
      "pali": "Yannūnāhaṁ pañcasīlaṁ,"
    },
    {
      "id": "tha-ap26:3.4",
      "pali": "rakkheyyaṁ paripūrayaṁ."
    },
    {
      "id": "tha-ap26:4.1",
      "pali": "Anomadassissa munino,"
    },
    {
      "id": "tha-ap26:4.2",
      "pali": "nisabho nāma sāvako;"
    },
    {
      "id": "tha-ap26:4.3",
      "pali": "Tamahaṁ upasaṅkamma,"
    },
    {
      "id": "tha-ap26:4.4",
      "pali": "pañcasikkhāpadaggahiṁ."
    },
    {
      "id": "tha-ap26:5.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap26:5.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap26:5.3",
      "pali": "Tāvatā pañcasīlāni,"
    },
    {
      "id": "tha-ap26:5.4",
      "pali": "paripuṇṇāni gopayiṁ."
    },
    {
      "id": "tha-ap26:6.1",
      "pali": "Maccukāle ca sampatte,"
    },
    {
      "id": "tha-ap26:6.2",
      "pali": "devā assāsayanti maṁ;"
    },
    {
      "id": "tha-ap26:6.3",
      "pali": "‘Ratho sahassayutto te,"
    },
    {
      "id": "tha-ap26:6.4",
      "pali": "mārisāyaṁ upaṭṭhito’."
    },
    {
      "id": "tha-ap26:7.1",
      "pali": "Vattante carime citte,"
    },
    {
      "id": "tha-ap26:7.2",
      "pali": "mama sīlaṁ anussariṁ;"
    },
    {
      "id": "tha-ap26:7.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap26:7.4",
      "pali": "tāvatiṁsaṁ agacchahaṁ."
    },
    {
      "id": "tha-ap26:8.1",
      "pali": "Tiṁsakkhattuñca devindo,"
    },
    {
      "id": "tha-ap26:8.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap26:8.3",
      "pali": "Dibbasukhaṁ anubhaviṁ,"
    },
    {
      "id": "tha-ap26:8.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap26:9.1",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap26:9.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap26:9.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap26:9.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap26:10.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap26:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap26:10.3",
      "pali": "Pure vesāliyaṁ jāto,"
    },
    {
      "id": "tha-ap26:10.4",
      "pali": "mahāsāle suaḍḍhake."
    },
    {
      "id": "tha-ap26:11.1",
      "pali": "Vassūpanāyike kāle,"
    },
    {
      "id": "tha-ap26:11.2",
      "pali": "dippante jinasāsane;"
    },
    {
      "id": "tha-ap26:11.3",
      "pali": "Mātā ca me pitā ceva,"
    },
    {
      "id": "tha-ap26:11.4",
      "pali": "pañcasikkhāpadaggahuṁ."
    },
    {
      "id": "tha-ap26:12.1",
      "pali": "Saha sutvānahaṁ sīlaṁ,"
    },
    {
      "id": "tha-ap26:12.2",
      "pali": "mama sīlaṁ anussariṁ;"
    },
    {
      "id": "tha-ap26:12.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap26:12.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap26:13.1",
      "pali": "<b>Jātiyā pañcavassena</b>,"
    },
    {
      "id": "tha-ap26:13.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap26:13.3",
      "pali": "Upasampādayi buddho,"
    },
    {
      "id": "tha-ap26:13.4",
      "pali": "guṇamaññāya cakkhumā."
    },
    {
      "id": "tha-ap26:14.1",
      "pali": "Paripuṇṇāni gopetvā,"
    },
    {
      "id": "tha-ap26:14.2",
      "pali": "pañcasikkhāpadānahaṁ;"
    },
    {
      "id": "tha-ap26:14.3",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap26:14.4",
      "pali": "vinipātaṁ na gacchahaṁ."
    },
    {
      "id": "tha-ap26:15.1",
      "pali": "Svāhaṁ yasamanubhaviṁ,"
    },
    {
      "id": "tha-ap26:15.2",
      "pali": "tesaṁ sīlāna vāhasā;"
    },
    {
      "id": "tha-ap26:15.3",
      "pali": "Kappakoṭimpi kittento,"
    },
    {
      "id": "tha-ap26:15.4",
      "pali": "kittaye ekadesakaṁ."
    },
    {
      "id": "tha-ap26:16.1",
      "pali": "Pañca sīlāni gopetvā,"
    },
    {
      "id": "tha-ap26:16.2",
      "pali": "tayo hetū labhāmahaṁ;"
    },
    {
      "id": "tha-ap26:16.3",
      "pali": "Dīghāyuko mahābhogo,"
    },
    {
      "id": "tha-ap26:16.4",
      "pali": "tikkhapañño bhavāmahaṁ."
    },
    {
      "id": "tha-ap26:17.1",
      "pali": "Saṅkittento ca sabbesaṁ,"
    },
    {
      "id": "tha-ap26:17.2",
      "pali": "adhimattañca porisaṁ;"
    },
    {
      "id": "tha-ap26:17.3",
      "pali": "Bhavābhave saṁsaritvā,"
    },
    {
      "id": "tha-ap26:17.4",
      "pali": "ete ṭhāne labhāmahaṁ."
    },
    {
      "id": "tha-ap26:18.1",
      "pali": "Aparimeyyasīlesu,"
    },
    {
      "id": "tha-ap26:18.2",
      "pali": "vattantā jinasāvakā;"
    },
    {
      "id": "tha-ap26:18.3",
      "pali": "Bhavesu yadi rajjeyyuṁ,"
    },
    {
      "id": "tha-ap26:18.4",
      "pali": "vipāko kīdiso bhave."
    },
    {
      "id": "tha-ap26:19.1",
      "pali": "Suciṇṇaṁ me pañcasīlaṁ,"
    },
    {
      "id": "tha-ap26:19.2",
      "pali": "bhatakena tapassinā;"
    },
    {
      "id": "tha-ap26:19.3",
      "pali": "Tena sīlenahaṁ ajja,"
    },
    {
      "id": "tha-ap26:19.4",
      "pali": "mocayiṁ sabbabandhanā."
    },
    {
      "id": "tha-ap26:20.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap26:20.2",
      "pali": "pañca sīlāni gopayiṁ;"
    },
    {
      "id": "tha-ap26:20.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap26:20.4",
      "pali": "pañcasīlānidaṁ phalaṁ."
    },
    {
      "id": "tha-ap26:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap26:21.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap26:21.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap26:21.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap26:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā pañcasīlasamādāniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap26:23.1",
      "pali": "Pañcasīlasamādāniyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
