{
  "uid": "tha-ap56",
  "title": "4 Gandhodakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap56:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap56:1.2",
      "pali": "mahābodhimaho ahu;"
    },
    {
      "id": "tha-ap56:1.3",
      "pali": "Vicittaṁ ghaṭamādāya,"
    },
    {
      "id": "tha-ap56:1.4",
      "pali": "gandhodakamadāsahaṁ."
    },
    {
      "id": "tha-ap56:2.1",
      "pali": "Nhānakāle ca bodhiyā,"
    },
    {
      "id": "tha-ap56:2.2",
      "pali": "mahāmegho pavassatha;"
    },
    {
      "id": "tha-ap56:2.3",
      "pali": "Ninnādo ca mahā āsi,"
    },
    {
      "id": "tha-ap56:2.4",
      "pali": "asaniyā phalantiyā."
    },
    {
      "id": "tha-ap56:3.1",
      "pali": "Tenevāsanivegena,"
    },
    {
      "id": "tha-ap56:3.2",
      "pali": "tattha kālaṅkato ahaṁ;"
    },
    {
      "id": "tha-ap56:3.3",
      "pali": "Devaloke ṭhito santo,"
    },
    {
      "id": "tha-ap56:3.4",
      "pali": "imā gāthā abhāsahaṁ."
    },
    {
      "id": "tha-ap56:4.1",
      "pali": "‘Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap56:4.2",
      "pali": "aho no satthusampadā;"
    },
    {
      "id": "tha-ap56:4.3",
      "pali": "Kaḷevaraṁ me patitaṁ,"
    },
    {
      "id": "tha-ap56:4.4",
      "pali": "devaloke ramāmahaṁ."
    },
    {
      "id": "tha-ap56:5.1",
      "pali": "Ubbiddhaṁ bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap56:5.2",
      "pali": "Satabhūmaṁ samuggataṁ;"
    },
    {
      "id": "tha-ap56:5.3",
      "pali": "Kaññāsatasahassāni,"
    },
    {
      "id": "tha-ap56:5.4",
      "pali": "Parivārenti maṁ sadā."
    },
    {
      "id": "tha-ap56:6.1",
      "pali": "Ābādhā me na vijjanti,"
    },
    {
      "id": "tha-ap56:6.2",
      "pali": "soko mayhaṁ na vijjati;"
    },
    {
      "id": "tha-ap56:6.3",
      "pali": "Pariḷāhaṁ na passāmi,"
    },
    {
      "id": "tha-ap56:6.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap56:7.1",
      "pali": "Aṭṭhavīse kappasate,"
    },
    {
      "id": "tha-ap56:7.2",
      "pali": "rājā saṁvasito ahuṁ;"
    },
    {
      "id": "tha-ap56:7.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap56:7.4",
      "pali": "cakkavattī mahabbalo’."
    },
    {
      "id": "tha-ap56:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap56:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap56:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap56:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhodakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap56:10.1",
      "pali": "Gandhodakiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
