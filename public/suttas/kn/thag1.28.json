{
  "uid": "thag1.28",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.28:1.1",
      "pali": "“Kacci no vatthapasuto,"
    },
    {
      "id": "thag1.28:1.2",
      "pali": "Kacci no bhūsanārato;"
    },
    {
      "id": "thag1.28:1.3",
      "pali": "Kacci sīlamayaṁ gandhaṁ,"
    },
    {
      "id": "thag1.28:1.4",
      "pali": "Kiṁ tvaṁ vāyasi netarā pajā”ti."
    },
    {
      "id": "thag1.28:1.5",
      "pali": "… Jambugāmikaputto thero …."
    }
  ]
}
