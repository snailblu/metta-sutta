{
  "uid": "vv77",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv77:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv77:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv77:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv77:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv77:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv77:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv77:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv77:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv77:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv77:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv77:3.3",
      "pali": "vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv77:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv77:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv77:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv77:5.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv77:5.2",
      "pali": "Vivane pathe saṅkamanaṁ akāsiṁ;"
    },
    {
      "id": "vv77:5.3",
      "pali": "Ārāmarukkhāni ca ropayissaṁ,"
    },
    {
      "id": "vv77:5.4",
      "pali": "Piyā ca me sīlavanto ahesuṁ;"
    },
    {
      "id": "vv77:5.5",
      "pali": "Annañca pānañca pasannacitto,"
    },
    {
      "id": "vv77:5.6",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv77:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv77:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv77:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv77:7.1",
      "pali": "Maṇithūṇavimānaṁ tatiyaṁ."
    }
  ]
}
