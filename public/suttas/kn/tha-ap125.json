{
  "uid": "tha-ap125",
  "title": "3 Pāyasadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap125:1.1",
      "pali": "“Suvaṇṇavaṇṇo sambuddho,"
    },
    {
      "id": "tha-ap125:1.2",
      "pali": "Bāttiṁsavaralakkhaṇo;"
    },
    {
      "id": "tha-ap125:1.3",
      "pali": "Pavanā abhinikkhanto,"
    },
    {
      "id": "tha-ap125:1.4",
      "pali": "Bhikkhusaṅghapurakkhato."
    },
    {
      "id": "tha-ap125:2.1",
      "pali": "Mahaccā kaṁsapātiyā,"
    },
    {
      "id": "tha-ap125:2.2",
      "pali": "vaḍḍhetvā pāyasaṁ ahaṁ;"
    },
    {
      "id": "tha-ap125:2.3",
      "pali": "Āhutiṁ yiṭṭhukāmo so,"
    },
    {
      "id": "tha-ap125:2.4",
      "pali": "upanesiṁ baliṁ ahaṁ."
    },
    {
      "id": "tha-ap125:3.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap125:3.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap125:3.3",
      "pali": "Caṅkamaṁ susamārūḷho,"
    },
    {
      "id": "tha-ap125:3.4",
      "pali": "ambare anilāyane."
    },
    {
      "id": "tha-ap125:4.1",
      "pali": "Tañca acchariyaṁ disvā,"
    },
    {
      "id": "tha-ap125:4.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "tha-ap125:4.3",
      "pali": "Ṭhapayitvā kaṁsapātiṁ,"
    },
    {
      "id": "tha-ap125:4.4",
      "pali": "vipassiṁ abhivādayiṁ."
    },
    {
      "id": "tha-ap125:5.1",
      "pali": "Tuvaṁ devosi sabbaññū,"
    },
    {
      "id": "tha-ap125:5.2",
      "pali": "sadeve sahamānuse;"
    },
    {
      "id": "tha-ap125:5.3",
      "pali": "Anukampaṁ upādāya,"
    },
    {
      "id": "tha-ap125:5.4",
      "pali": "paṭigaṇha mahāmuni."
    },
    {
      "id": "tha-ap125:6.1",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap125:6.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap125:6.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap125:6.4",
      "pali": "satthā loke mahāmuni."
    },
    {
      "id": "tha-ap125:7.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap125:7.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap125:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap125:7.4",
      "pali": "pāyasassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap125:8.1",
      "pali": "Ekatālīsito kappe,"
    },
    {
      "id": "tha-ap125:8.2",
      "pali": "buddho nāmāsi khattiyo;"
    },
    {
      "id": "tha-ap125:8.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap125:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap125:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap125:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap125:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap125:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāyasadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap125:11.1",
      "pali": "Pāyasadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
