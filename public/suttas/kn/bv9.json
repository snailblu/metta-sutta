{
  "uid": "bv9",
  "title": "9 Anomadassībuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv9:1.1",
      "pali": "“Sobhitassa aparena,"
    },
    {
      "id": "bv9:1.2",
      "pali": "Sambuddho dvipaduttamo;"
    },
    {
      "id": "bv9:1.3",
      "pali": "Anomadassī amitayaso,"
    },
    {
      "id": "bv9:1.4",
      "pali": "Tejassī duratikkamo."
    },
    {
      "id": "bv9:2.1",
      "pali": "So chetvā bandhanaṁ sabbaṁ,"
    },
    {
      "id": "bv9:2.2",
      "pali": "viddhaṁsetvā tayo bhave;"
    },
    {
      "id": "bv9:2.3",
      "pali": "Anivattigamanaṁ maggaṁ,"
    },
    {
      "id": "bv9:2.4",
      "pali": "desesi devamānuse."
    },
    {
      "id": "bv9:3.1",
      "pali": "Sāgarova asaṅkhobbho,"
    },
    {
      "id": "bv9:3.2",
      "pali": "pabbatova durāsado;"
    },
    {
      "id": "bv9:3.3",
      "pali": "Ākāsova ananto so,"
    },
    {
      "id": "bv9:3.4",
      "pali": "sālarājāva phullito."
    },
    {
      "id": "bv9:4.1",
      "pali": "Dassanenapi taṁ buddhaṁ,"
    },
    {
      "id": "bv9:4.2",
      "pali": "tositā honti pāṇino;"
    },
    {
      "id": "bv9:4.3",
      "pali": "Byāharantaṁ giraṁ sutvā,"
    },
    {
      "id": "bv9:4.4",
      "pali": "amataṁ pāpuṇanti te."
    },
    {
      "id": "bv9:5.1",
      "pali": "Dhammābhisamayo tassa,"
    },
    {
      "id": "bv9:5.2",
      "pali": "Iddho phīto tadā ahu;"
    },
    {
      "id": "bv9:5.3",
      "pali": "Koṭisatāni abhisamiṁsu,"
    },
    {
      "id": "bv9:5.4",
      "pali": "Paṭhame dhammadesane."
    },
    {
      "id": "bv9:6.1",
      "pali": "Tato paraṁ abhisamaye,"
    },
    {
      "id": "bv9:6.2",
      "pali": "Vassante dhammavuṭṭhiyo;"
    },
    {
      "id": "bv9:6.3",
      "pali": "Asītikoṭiyobhisamiṁsu,"
    },
    {
      "id": "bv9:6.4",
      "pali": "Dutiye dhammadesane."
    },
    {
      "id": "bv9:7.1",
      "pali": "Tatoparañhi vassante,"
    },
    {
      "id": "bv9:7.2",
      "pali": "tappayante ca pāṇinaṁ;"
    },
    {
      "id": "bv9:7.3",
      "pali": "Aṭṭhasattatikoṭīnaṁ,"
    },
    {
      "id": "bv9:7.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv9:8.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv9:8.2",
      "pali": "tassāpi ca mahesino;"
    },
    {
      "id": "bv9:8.3",
      "pali": "Abhiññābalappattānaṁ,"
    },
    {
      "id": "bv9:8.4",
      "pali": "pupphitānaṁ vimuttiyā."
    },
    {
      "id": "bv9:9.1",
      "pali": "Aṭṭhasatasahassānaṁ,"
    },
    {
      "id": "bv9:9.2",
      "pali": "sannipāto tadā ahu;"
    },
    {
      "id": "bv9:9.3",
      "pali": "Pahīnamadamohānaṁ,"
    },
    {
      "id": "bv9:9.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv9:10.1",
      "pali": "Sattasatasahassānaṁ,"
    },
    {
      "id": "bv9:10.2",
      "pali": "dutiyo āsi samāgamo;"
    },
    {
      "id": "bv9:10.3",
      "pali": "Anaṅgaṇānaṁ virajānaṁ,"
    },
    {
      "id": "bv9:10.4",
      "pali": "upasantāna tādinaṁ."
    },
    {
      "id": "bv9:11.1",
      "pali": "Channaṁ satasahassānaṁ,"
    },
    {
      "id": "bv9:11.2",
      "pali": "tatiyo āsi samāgamo;"
    },
    {
      "id": "bv9:11.3",
      "pali": "Abhiññābalappattānaṁ,"
    },
    {
      "id": "bv9:11.4",
      "pali": "nibbutānaṁ tapassinaṁ."
    },
    {
      "id": "bv9:12.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv9:12.2",
      "pali": "yakkho āsiṁ mahiddhiko;"
    },
    {
      "id": "bv9:12.3",
      "pali": "Nekānaṁ yakkhakoṭīnaṁ,"
    },
    {
      "id": "bv9:12.4",
      "pali": "vasavattimhi issaro."
    },
    {
      "id": "bv9:13.1",
      "pali": "Tadāpi taṁ buddhavaraṁ,"
    },
    {
      "id": "bv9:13.2",
      "pali": "upagantvā mahesinaṁ;"
    },
    {
      "id": "bv9:13.3",
      "pali": "Annapānena tappesiṁ,"
    },
    {
      "id": "bv9:13.4",
      "pali": "sasaṅghaṁ lokanāyakaṁ."
    },
    {
      "id": "bv9:14.1",
      "pali": "Sopi maṁ tadā byākāsi,"
    },
    {
      "id": "bv9:14.2",
      "pali": "visuddhanayano muni;"
    },
    {
      "id": "bv9:14.3",
      "pali": "‘Aparimeyyito kappe,"
    },
    {
      "id": "bv9:14.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv9:15.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv9:15.2",
      "pali": "…pe…"
    },
    {
      "id": "bv9:15.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv9:16.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv9:16.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "bv9:16.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv9:16.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv9:17.1",
      "pali": "Nagaraṁ candavatī nāma,"
    },
    {
      "id": "bv9:17.2",
      "pali": "yasavā nāma khattiyo;"
    },
    {
      "id": "bv9:17.3",
      "pali": "Mātā yasodharā nāma,"
    },
    {
      "id": "bv9:17.4",
      "pali": "anomadassissa satthuno."
    },
    {
      "id": "bv9:18.1",
      "pali": "Dasavassasahassāni,"
    },
    {
      "id": "bv9:18.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv9:18.3",
      "pali": "Sirī upasirī vaḍḍho,"
    },
    {
      "id": "bv9:18.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv9:19.1",
      "pali": "Tevīsatisahassāni,"
    },
    {
      "id": "bv9:19.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv9:19.3",
      "pali": "Sirimā nāma sā nārī,"
    },
    {
      "id": "bv9:19.4",
      "pali": "upavāṇo nāma atrajo."
    },
    {
      "id": "bv9:20.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv9:20.2",
      "pali": "sivikāyābhinikkhami;"
    },
    {
      "id": "bv9:20.3",
      "pali": "Anūnadasamāsāni,"
    },
    {
      "id": "bv9:20.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv9:21.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv9:21.2",
      "pali": "anomadassī mahāmuni;"
    },
    {
      "id": "bv9:21.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv9:21.4",
      "pali": "uyyāne so sudassane."
    },
    {
      "id": "bv9:22.1",
      "pali": "Nisabho ca anomo ca,"
    },
    {
      "id": "bv9:22.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv9:22.3",
      "pali": "Varuṇo nāmupaṭṭhāko,"
    },
    {
      "id": "bv9:22.4",
      "pali": "anomadassissa satthuno."
    },
    {
      "id": "bv9:23.1",
      "pali": "Sundarī ca sumanā ca,"
    },
    {
      "id": "bv9:23.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv9:23.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv9:23.4",
      "pali": "ajjunoti pavuccati."
    },
    {
      "id": "bv9:24.1",
      "pali": "Nandivaḍḍho sirivaḍḍho,"
    },
    {
      "id": "bv9:24.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv9:24.3",
      "pali": "Uppalā ceva padumā ca,"
    },
    {
      "id": "bv9:24.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv9:25.1",
      "pali": "Aṭṭhapaṇṇāsaratanaṁ,"
    },
    {
      "id": "bv9:25.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv9:25.3",
      "pali": "Pabhā niddhāvatī tassa,"
    },
    {
      "id": "bv9:25.4",
      "pali": "sataraṁsīva uggato."
    },
    {
      "id": "bv9:26.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv9:26.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv9:26.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv9:26.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv9:27.1",
      "pali": "Supupphitaṁ pāvacanaṁ,"
    },
    {
      "id": "bv9:27.2",
      "pali": "arahantehi tādihi;"
    },
    {
      "id": "bv9:27.3",
      "pali": "Vītarāgehi vimalehi,"
    },
    {
      "id": "bv9:27.4",
      "pali": "sobhittha jinasāsanaṁ."
    },
    {
      "id": "bv9:28.1",
      "pali": "So ca satthā amitayaso,"
    },
    {
      "id": "bv9:28.2",
      "pali": "Yugāni tāni atuliyāni;"
    },
    {
      "id": "bv9:28.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv9:28.4",
      "pali": "Nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv9:29.1",
      "pali": "Anomadassī jino satthā,"
    },
    {
      "id": "bv9:29.2",
      "pali": "Dhammārāmamhi nibbuto;"
    },
    {
      "id": "bv9:29.3",
      "pali": "Tatthevassa jinathūpo,"
    },
    {
      "id": "bv9:29.4",
      "pali": "Ubbedho pañcavīsatī”ti."
    },
    {
      "id": "bv9:30.1",
      "pali": "Anomadassissa bhagavato vaṁso sattamo."
    }
  ]
}
