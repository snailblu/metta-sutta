{
  "uid": "ja403",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja403:1.1",
      "pali": "“Yeme ahaṁ na jānāmi,"
    },
    {
      "id": "ja403:1.2",
      "pali": "aṭṭhisena vanibbake;"
    },
    {
      "id": "ja403:1.3",
      "pali": "Te maṁ saṅgamma yācanti,"
    },
    {
      "id": "ja403:1.4",
      "pali": "kasmā maṁ tvaṁ na yācasi”."
    },
    {
      "id": "ja403:2.1",
      "pali": "“Yācako appiyo hoti,"
    },
    {
      "id": "ja403:2.2",
      "pali": "yācaṁ adadamappiyo;"
    },
    {
      "id": "ja403:2.3",
      "pali": "Tasmāhaṁ taṁ na yācāmi,"
    },
    {
      "id": "ja403:2.4",
      "pali": "mā me videssanā ahu”."
    },
    {
      "id": "ja403:3.1",
      "pali": "“Yo ve yācanajīvāno,"
    },
    {
      "id": "ja403:3.2",
      "pali": "kāle yācaṁ na yācati;"
    },
    {
      "id": "ja403:3.3",
      "pali": "Parañca puññā dhaṁseti,"
    },
    {
      "id": "ja403:3.4",
      "pali": "attanāpi na jīvati."
    },
    {
      "id": "ja403:4.1",
      "pali": "Yo ca yācanajīvāno,"
    },
    {
      "id": "ja403:4.2",
      "pali": "kāle yācañhi yācati;"
    },
    {
      "id": "ja403:4.3",
      "pali": "Parañca puññaṁ labbheti,"
    },
    {
      "id": "ja403:4.4",
      "pali": "attanāpi ca jīvati."
    },
    {
      "id": "ja403:5.1",
      "pali": "Na ve dessanti sappaññā,"
    },
    {
      "id": "ja403:5.2",
      "pali": "Disvā yācakamāgate;"
    },
    {
      "id": "ja403:5.3",
      "pali": "Brahmacāri piyo mesi,"
    },
    {
      "id": "ja403:5.4",
      "pali": "Vada tvaṁ bhaññamicchasi”."
    },
    {
      "id": "ja403:6.1",
      "pali": "“Na ve yācanti sappaññā,"
    },
    {
      "id": "ja403:6.2",
      "pali": "Dhīro ca veditumarahati;"
    },
    {
      "id": "ja403:6.3",
      "pali": "Uddissa ariyā tiṭṭhanti,"
    },
    {
      "id": "ja403:6.4",
      "pali": "Esā ariyāna yācanā”."
    },
    {
      "id": "ja403:7.1",
      "pali": "“Dadāmi te brāhmaṇa rohiṇīnaṁ,"
    },
    {
      "id": "ja403:7.2",
      "pali": "Gavaṁ sahassaṁ saha puṅgavena;"
    },
    {
      "id": "ja403:7.3",
      "pali": "Ariyo hi ariyassa kathaṁ na dajjā,"
    },
    {
      "id": "ja403:7.4",
      "pali": "Sutvāna gāthā tava dhammayuttā”ti."
    },
    {
      "id": "ja403:8.1",
      "pali": "Aṭṭhisenakajātakaṁ aṭṭhamaṁ."
    }
  ]
}
