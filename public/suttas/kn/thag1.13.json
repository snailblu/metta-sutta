{
  "uid": "thag1.13",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.13:1.1",
      "pali": "“Nīlabbhavaṇṇā rucirā,"
    },
    {
      "id": "thag1.13:1.2",
      "pali": "sītavārī sucindharā;"
    },
    {
      "id": "thag1.13:1.3",
      "pali": "Indagopakasañchannā,"
    },
    {
      "id": "thag1.13:1.4",
      "pali": "te selā ramayanti man”ti."
    },
    {
      "id": "thag1.13:1.5",
      "pali": "… Vanavaccho thero …."
    }
  ]
}
