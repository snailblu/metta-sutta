{
  "uid": "thag5.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.2:1.1",
      "pali": "“Ayoge yuñjamattānaṁ,"
    },
    {
      "id": "thag5.2:1.2",
      "pali": "puriso kiccamicchako;"
    },
    {
      "id": "thag5.2:1.3",
      "pali": "Carañce nādhigaccheyya,"
    },
    {
      "id": "thag5.2:1.4",
      "pali": "‘taṁ me dubbhagalakkhaṇaṁ’."
    },
    {
      "id": "thag5.2:2.1",
      "pali": "Abbūḷhaṁ aghagataṁ vijitaṁ,"
    },
    {
      "id": "thag5.2:2.2",
      "pali": "Ekañce ossajeyya kalīva siyā;"
    },
    {
      "id": "thag5.2:2.3",
      "pali": "Sabbānipi ce ossajeyya andhova siyā,"
    },
    {
      "id": "thag5.2:2.4",
      "pali": "Samavisamassa adassanato."
    },
    {
      "id": "thag5.2:3.1",
      "pali": "Yañhi kayirā tañhi vade,"
    },
    {
      "id": "thag5.2:3.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "thag5.2:3.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "thag5.2:3.4",
      "pali": "parijānanti paṇḍitā."
    },
    {
      "id": "thag5.2:4.1",
      "pali": "Yathāpi ruciraṁ pupphaṁ,"
    },
    {
      "id": "thag5.2:4.2",
      "pali": "vaṇṇavantaṁ agandhakaṁ;"
    },
    {
      "id": "thag5.2:4.3",
      "pali": "Evaṁ subhāsitā vācā,"
    },
    {
      "id": "thag5.2:4.4",
      "pali": "aphalā hoti akubbato."
    },
    {
      "id": "thag5.2:5.1",
      "pali": "Yathāpi ruciraṁ pupphaṁ,"
    },
    {
      "id": "thag5.2:5.2",
      "pali": "Vaṇṇavantaṁ sugandhakaṁ;"
    },
    {
      "id": "thag5.2:5.3",
      "pali": "Evaṁ subhāsitā vācā,"
    },
    {
      "id": "thag5.2:5.4",
      "pali": "Saphalā hoti kubbato”ti."
    },
    {
      "id": "thag5.2:5.5",
      "pali": "… Subhūto thero …."
    }
  ]
}
