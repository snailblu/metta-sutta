{
  "uid": "ja49",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja49:1.1",
      "pali": "Nakkhattaṁ paṭimānentaṁ,"
    },
    {
      "id": "ja49:1.2",
      "pali": "attho bālaṁ upaccagā;"
    },
    {
      "id": "ja49:1.3",
      "pali": "Attho atthassa nakkhattaṁ,"
    },
    {
      "id": "ja49:1.4",
      "pali": "kiṁ karissanti tārakā”ti."
    },
    {
      "id": "ja49:2.1",
      "pali": "Nakkhattajātakaṁ navamaṁ."
    }
  ]
}
