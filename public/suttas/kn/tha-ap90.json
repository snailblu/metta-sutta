{
  "uid": "tha-ap90",
  "title": "Saddasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap90:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap90:1.2",
      "pali": "vasāmi paṇṇasanthare;"
    },
    {
      "id": "tha-ap90:1.3",
      "pali": "Phussassa dhammaṁ bhaṇato,"
    },
    {
      "id": "tha-ap90:1.4",
      "pali": "sadde cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap90:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap90:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap90:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap90:2.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap90:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap90:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap90:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap90:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā saddasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap90:5.1",
      "pali": "Saddasaññakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
