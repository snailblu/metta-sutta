{
  "uid": "vv8",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv8:1.1",
      "pali": "“Suvaṇṇacchadanaṁ nāvaṁ,"
    },
    {
      "id": "vv8:1.2",
      "pali": "Nāri āruyha tiṭṭhasi;"
    },
    {
      "id": "vv8:1.3",
      "pali": "Ogāhasi pokkharaṇiṁ,"
    },
    {
      "id": "vv8:1.4",
      "pali": "Padmaṁ chindasi pāṇinā."
    },
    {
      "id": "vv8:2.1",
      "pali": "Kūṭāgārā nivesā te,"
    },
    {
      "id": "vv8:2.2",
      "pali": "vibhattā bhāgaso mitā;"
    },
    {
      "id": "vv8:2.3",
      "pali": "Daddallamānā ābhanti,"
    },
    {
      "id": "vv8:2.4",
      "pali": "samantā caturo disā."
    },
    {
      "id": "vv8:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv8:3.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv8:3.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv8:3.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv8:4.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv8:4.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv8:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv8:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv8:5.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv8:5.2",
      "pali": "sambuddheneva pucchitā;"
    },
    {
      "id": "vv8:5.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv8:5.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv8:6.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv8:6.2",
      "pali": "Purimāya jātiyā manussaloke;"
    },
    {
      "id": "vv8:6.3",
      "pali": "Disvāna bhikkhū tasite kilante,"
    },
    {
      "id": "vv8:6.4",
      "pali": "Uṭṭhāya pātuṁ udakaṁ adāsiṁ."
    },
    {
      "id": "vv8:7.1",
      "pali": "Yo ve kilantāna pipāsitānaṁ,"
    },
    {
      "id": "vv8:7.2",
      "pali": "Uṭṭhāya pātuṁ udakaṁ dadāti;"
    },
    {
      "id": "vv8:7.3",
      "pali": "Sītodakā tassa bhavanti najjo,"
    },
    {
      "id": "vv8:7.4",
      "pali": "Pahūtamalyā bahupuṇḍarīkā."
    },
    {
      "id": "vv8:8.1",
      "pali": "Taṁ āpagā anupariyanti sabbadā,"
    },
    {
      "id": "vv8:8.2",
      "pali": "Sītodakā vālukasanthatā nadī;"
    },
    {
      "id": "vv8:8.3",
      "pali": "Ambā ca sālā tilakā ca jambuyo,"
    },
    {
      "id": "vv8:8.4",
      "pali": "Uddālakā pāṭaliyo ca phullā."
    },
    {
      "id": "vv8:9.1",
      "pali": "Taṁ bhūmibhāgehi upetarūpaṁ,"
    },
    {
      "id": "vv8:9.2",
      "pali": "Vimānaseṭṭhaṁ bhusa sobhamānaṁ;"
    },
    {
      "id": "vv8:9.3",
      "pali": "Tassīdha kammassa ayaṁ vipāko,"
    },
    {
      "id": "vv8:9.4",
      "pali": "Etādisaṁ puññakatā labhanti."
    },
    {
      "id": "vv8:10.1",
      "pali": "Kūṭāgārā nivesā me,"
    },
    {
      "id": "vv8:10.2",
      "pali": "vibhattā bhāgaso mitā;"
    },
    {
      "id": "vv8:10.3",
      "pali": "Daddallamānā ābhanti,"
    },
    {
      "id": "vv8:10.4",
      "pali": "samantā caturo disā."
    },
    {
      "id": "vv8:11.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv8:11.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv8:11.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv8:11.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv8:12.1",
      "pali": "Akkhāmi te buddha mahānubhāva,"
    },
    {
      "id": "vv8:12.2",
      "pali": "Manussabhūtā yamakāsi puññaṁ;"
    },
    {
      "id": "vv8:12.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv8:12.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsati;"
    },
    {
      "id": "vv8:12.5",
      "pali": "Etassa kammassa phalaṁ mamedaṁ,"
    },
    {
      "id": "vv8:12.6",
      "pali": "Atthāya buddho udakaṁ apāyī”ti."
    },
    {
      "id": "vv8:13.1",
      "pali": "Tatiyanāvāvimānaṁ aṭṭhamaṁ."
    }
  ]
}
