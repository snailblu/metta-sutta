{
  "uid": "ja2",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja2:1.1",
      "pali": "“Akilāsuno vaṇṇupathe khaṇantā,"
    },
    {
      "id": "ja2:1.2",
      "pali": "Udaṅgaṇe tattha papaṁ avinduṁ;"
    },
    {
      "id": "ja2:1.3",
      "pali": "Evaṁ munī viriyabalūpapanno,"
    },
    {
      "id": "ja2:1.4",
      "pali": "Akilāsu vinde hadayassa santin”ti."
    },
    {
      "id": "ja2:2.1",
      "pali": "Vaṇṇupathajātakaṁ dutiyaṁ."
    }
  ]
}
