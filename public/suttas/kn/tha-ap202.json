{
  "uid": "tha-ap202",
  "title": "10 Yūthikapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap202:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap202:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap202:1.3",
      "pali": "Pavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap202:1.4",
      "pali": "vihāraṁ yāti cakkhumā."
    },
    {
      "id": "tha-ap202:2.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap202:2.2",
      "pali": "yūthikaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap202:2.3",
      "pali": "Buddhassa abhiropayiṁ,"
    },
    {
      "id": "tha-ap202:2.4",
      "pali": "mettacittassa tādino."
    },
    {
      "id": "tha-ap202:3.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap202:3.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap202:3.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap202:3.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap202:4.1",
      "pali": "Ito paññāsakappesu,"
    },
    {
      "id": "tha-ap202:4.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap202:4.3",
      "pali": "Samittanandano nāma,"
    },
    {
      "id": "tha-ap202:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap202:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap202:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap202:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap202:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā yūthikapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap202:7.1",
      "pali": "Yūthikapupphiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap202:7.2",
      "pali": "Tamālapupphiyavaggo vīsatimo."
    },
    {
      "id": "tha-ap202:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap202:9.1",
      "pali": "Tamālatiṇasanthāro,"
    },
    {
      "id": "tha-ap202:9.2",
      "pali": "khaṇḍaphulli asokiyo;"
    },
    {
      "id": "tha-ap202:9.3",
      "pali": "Aṅkolakī kisalayo,"
    },
    {
      "id": "tha-ap202:9.4",
      "pali": "tinduko nelapupphiyo;"
    },
    {
      "id": "tha-ap202:9.5",
      "pali": "Kiṅkaṇiko yūthiko ca,"
    },
    {
      "id": "tha-ap202:9.6",
      "pali": "gāthā paññāsa aṭṭha cāti."
    },
    {
      "id": "tha-ap202:10.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap202:11.1",
      "pali": "Bhikkhādāyī parivāro,"
    },
    {
      "id": "tha-ap202:11.2",
      "pali": "sereyyo sobhito tathā;"
    },
    {
      "id": "tha-ap202:11.3",
      "pali": "Chattañca bandhujīvī ca,"
    },
    {
      "id": "tha-ap202:11.4",
      "pali": "supāricariyopi ca."
    },
    {
      "id": "tha-ap202:12.1",
      "pali": "Kumudo kuṭajo ceva,"
    },
    {
      "id": "tha-ap202:12.2",
      "pali": "tamāli dasamo kato;"
    },
    {
      "id": "tha-ap202:12.3",
      "pali": "Chasatāni ca gāthāni,"
    },
    {
      "id": "tha-ap202:12.4",
      "pali": "chasaṭṭhi ca tatuttari."
    },
    {
      "id": "tha-ap202:13.1",
      "pali": "Bhikkhāvaggadasakaṁ."
    },
    {
      "id": "tha-ap202:14.1",
      "pali": "Dutiyasatakaṁ samattaṁ."
    }
  ]
}
