{
  "uid": "pv46",
  "title": "11. Pāṭaliputtapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv46:1.1",
      "pali": "“Diṭṭhā tayā nirayā tiracchānayoni,"
    },
    {
      "id": "pv46:1.2",
      "pali": "Petā asurā athavāpi mānusā devā;"
    },
    {
      "id": "pv46:1.3",
      "pali": "Sayamaddasa kammavipākamattano,"
    },
    {
      "id": "pv46:1.4",
      "pali": "Nessāmi taṁ pāṭaliputtamakkhataṁ;"
    },
    {
      "id": "pv46:1.5",
      "pali": "Tattha gantvā kusalaṁ karohi kammaṁ”."
    },
    {
      "id": "pv46:2.1",
      "pali": "“Atthakāmosi me yakkha,"
    },
    {
      "id": "pv46:2.2",
      "pali": "hitakāmosi devate;"
    },
    {
      "id": "pv46:2.3",
      "pali": "Karomi tuyhaṁ vacanaṁ,"
    },
    {
      "id": "pv46:2.4",
      "pali": "tvaṁsi ācariyo mama."
    },
    {
      "id": "pv46:3.1",
      "pali": "Diṭṭhā mayā nirayā tiracchānayoni,"
    },
    {
      "id": "pv46:3.2",
      "pali": "Petā asurā athavāpi mānusā devā;"
    },
    {
      "id": "pv46:3.3",
      "pali": "Sayamaddasaṁ kammavipākamattano,"
    },
    {
      "id": "pv46:3.4",
      "pali": "Kāhāmi puññāni anappakānī”ti."
    },
    {
      "id": "pv46:4.1",
      "pali": "Pāṭaliputtapetavatthu ekādasamaṁ."
    }
  ]
}
