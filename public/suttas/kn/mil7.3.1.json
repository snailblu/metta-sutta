{
  "uid": "mil7.3.1",
  "title": "Samuddavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.3.1:1.1",
      "pali": "“Bhante nāgasena, ‘lābulatāya ekaṁ aṅgaṁ gahetabban’ti yaṁ vadesi, katamaṁ taṁ ekaṁ aṅgaṁ gahetabban”ti?"
    },
    {
      "id": "mil7.3.1:1.2",
      "pali": "“Yathā, mahārāja, lābulatā tiṇe vā kaṭṭhe vā latāya vā soṇḍikāhi ālambitvā tassūpari vaḍḍhati;"
    },
    {
      "id": "mil7.3.1:1.3",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena arahatte abhivaḍḍhitukāmena manasā ārammaṇaṁ ālambitvā arahatte abhivaḍḍhitabbaṁ."
    },
    {
      "id": "mil7.3.1:1.4",
      "pali": "Idaṁ, mahārāja, lābulatāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.3.1:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, therena sāriputtena dhammasenāpatinā—"
    },
    {
      "id": "mil7.3.1:2.1",
      "pali": "‘Yathā lābulatā nāma,"
    },
    {
      "id": "mil7.3.1:2.2",
      "pali": "tiṇe kaṭṭhe latāya vā;"
    },
    {
      "id": "mil7.3.1:2.3",
      "pali": "Ālambitvā soṇḍikāhi,"
    },
    {
      "id": "mil7.3.1:2.4",
      "pali": "tato vaḍḍhati uppari."
    },
    {
      "id": "mil7.3.1:3.1",
      "pali": "Tatheva buddhaputtena,"
    },
    {
      "id": "mil7.3.1:3.2",
      "pali": "Arahattaphalakāminā;"
    },
    {
      "id": "mil7.3.1:3.3",
      "pali": "Ārammaṇaṁ ālambitvā,"
    },
    {
      "id": "mil7.3.1:3.4",
      "pali": "Vaḍḍhitabbaṁ asekkhaphale’”ti."
    },
    {
      "id": "mil7.3.1:4.1",
      "pali": "Lābulataṅgapañho paṭhamo."
    }
  ]
}
