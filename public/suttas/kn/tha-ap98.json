{
  "uid": "tha-ap98",
  "title": "Tipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap98:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap98:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap98:1.3",
      "pali": "Pāṭaliṁ haritaṁ disvā,"
    },
    {
      "id": "tha-ap98:1.4",
      "pali": "tīṇi pupphāni okiriṁ."
    },
    {
      "id": "tha-ap98:2.1",
      "pali": "Patitapattāni gaṇhitvā,"
    },
    {
      "id": "tha-ap98:2.2",
      "pali": "bahi chaḍḍesahaṁ tadā;"
    },
    {
      "id": "tha-ap98:2.3",
      "pali": "Antosuddhaṁ bahisuddhaṁ,"
    },
    {
      "id": "tha-ap98:2.4",
      "pali": "suvimuttaṁ anāsavaṁ."
    },
    {
      "id": "tha-ap98:3.1",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap98:3.2",
      "pali": "vipassiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap98:3.3",
      "pali": "Pāṭaliṁ abhivādetvā,"
    },
    {
      "id": "tha-ap98:3.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap98:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap98:4.2",
      "pali": "yaṁ bodhimabhipūjayiṁ;"
    },
    {
      "id": "tha-ap98:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap98:4.4",
      "pali": "bodhipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap98:5.1",
      "pali": "Samantapāsādikā nāma,"
    },
    {
      "id": "tha-ap98:5.2",
      "pali": "terasāsiṁsu rājino;"
    },
    {
      "id": "tha-ap98:5.3",
      "pali": "Ito tettiṁsakappamhi,"
    },
    {
      "id": "tha-ap98:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap98:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap98:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap98:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap98:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap98:8.1",
      "pali": "Tipupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
