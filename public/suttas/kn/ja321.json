{
  "uid": "ja321",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja321:1.1",
      "pali": "“Manussasseva te sīsaṁ,"
    },
    {
      "id": "ja321:1.2",
      "pali": "hatthapādā ca vānara;"
    },
    {
      "id": "ja321:1.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja321:1.4",
      "pali": "agāraṁ te na vijjati”."
    },
    {
      "id": "ja321:2.1",
      "pali": "“Manussasseva me sīsaṁ,"
    },
    {
      "id": "ja321:2.2",
      "pali": "hatthapādā ca siṅgila;"
    },
    {
      "id": "ja321:2.3",
      "pali": "Yāhu seṭṭhā manussesu,"
    },
    {
      "id": "ja321:2.4",
      "pali": "sā me paññā na vijjati”."
    },
    {
      "id": "ja321:3.1",
      "pali": "“Anavaṭṭhitacittassa,"
    },
    {
      "id": "ja321:3.2",
      "pali": "lahucittassa dubbhino;"
    },
    {
      "id": "ja321:3.3",
      "pali": "Niccaṁ addhuvasīlassa,"
    },
    {
      "id": "ja321:3.4",
      "pali": "sukhabhāvo na vijjati."
    },
    {
      "id": "ja321:4.1",
      "pali": "So karassu ānubhāvaṁ,"
    },
    {
      "id": "ja321:4.2",
      "pali": "vītivattassu sīliyaṁ;"
    },
    {
      "id": "ja321:4.3",
      "pali": "Sītavātaparittāṇaṁ,"
    },
    {
      "id": "ja321:4.4",
      "pali": "karassu kuṭavaṁ kapī”ti."
    },
    {
      "id": "ja321:5.1",
      "pali": "Kuṭidūsakajātakaṁ paṭhamaṁ."
    }
  ]
}
