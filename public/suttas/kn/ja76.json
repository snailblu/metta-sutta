{
  "uid": "ja76",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja76:1.1",
      "pali": "“Asaṅkiyomhi gāmamhi,"
    },
    {
      "id": "ja76:1.2",
      "pali": "araññe natthi me bhayaṁ;"
    },
    {
      "id": "ja76:1.3",
      "pali": "Ujuṁ maggaṁ samārūḷho,"
    },
    {
      "id": "ja76:1.4",
      "pali": "mettāya karuṇāya cā”ti."
    },
    {
      "id": "ja76:2.1",
      "pali": "Asaṅkiyajātakaṁ chaṭṭhaṁ."
    }
  ]
}
