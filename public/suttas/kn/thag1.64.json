{
  "uid": "thag1.64",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.64:1.1",
      "pali": "“Dumavhayāya uppanno,"
    },
    {
      "id": "thag1.64:1.2",
      "pali": "jāto paṇḍaraketunā;"
    },
    {
      "id": "thag1.64:1.3",
      "pali": "Ketuhā ketunāyeva,"
    },
    {
      "id": "thag1.64:1.4",
      "pali": "mahāketuṁ padhaṁsayī”ti."
    },
    {
      "id": "thag1.64:1.5",
      "pali": "… Vimalakoṇḍañño thero …."
    }
  ]
}
