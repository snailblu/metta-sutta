{
  "uid": "tha-ap18",
  "title": "Rāhulattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap18:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap18:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap18:1.3",
      "pali": "Sattabhūmamhi pāsāde,"
    },
    {
      "id": "tha-ap18:1.4",
      "pali": "Ādāsaṁ santhariṁ ahaṁ."
    },
    {
      "id": "tha-ap18:2.1",
      "pali": "Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap18:2.2",
      "pali": "parikiṇṇo mahāmuni;"
    },
    {
      "id": "tha-ap18:2.3",
      "pali": "Upāgami gandhakuṭiṁ,"
    },
    {
      "id": "tha-ap18:2.4",
      "pali": "dvipadindo narāsabho."
    },
    {
      "id": "tha-ap18:3.1",
      "pali": "Virocento gandhakuṭiṁ,"
    },
    {
      "id": "tha-ap18:3.2",
      "pali": "devadevo narāsabho;"
    },
    {
      "id": "tha-ap18:3.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap18:3.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap18:4.1",
      "pali": "‘Yenāyaṁ jotitā seyyā,"
    },
    {
      "id": "tha-ap18:4.2",
      "pali": "ādāsova susanthato;"
    },
    {
      "id": "tha-ap18:4.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap18:4.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap18:5.1",
      "pali": "Soṇṇamayā rūpimayā,"
    },
    {
      "id": "tha-ap18:5.2",
      "pali": "atho veḷuriyāmayā;"
    },
    {
      "id": "tha-ap18:5.3",
      "pali": "Nibbattissanti pāsādā,"
    },
    {
      "id": "tha-ap18:5.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "tha-ap18:6.1",
      "pali": "Catusaṭṭhikkhattuṁ devindo,"
    },
    {
      "id": "tha-ap18:6.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap18:6.3",
      "pali": "Sahassakkhattuṁ cakkavattī,"
    },
    {
      "id": "tha-ap18:6.4",
      "pali": "bhavissati anantarā."
    },
    {
      "id": "tha-ap18:7.1",
      "pali": "Ekavīsatikappamhi,"
    },
    {
      "id": "tha-ap18:7.2",
      "pali": "vimalo nāma khattiyo;"
    },
    {
      "id": "tha-ap18:7.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap18:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap18:8.1",
      "pali": "Nagaraṁ reṇuvatī nāma,"
    },
    {
      "id": "tha-ap18:8.2",
      "pali": "iṭṭhakāhi sumāpitaṁ;"
    },
    {
      "id": "tha-ap18:8.3",
      "pali": "Āyāmato tīṇi sataṁ,"
    },
    {
      "id": "tha-ap18:8.4",
      "pali": "caturassasamāyutaṁ."
    },
    {
      "id": "tha-ap18:9.1",
      "pali": "Sudassano nāma pāsādo,"
    },
    {
      "id": "tha-ap18:9.2",
      "pali": "vissakammena māpito;"
    },
    {
      "id": "tha-ap18:9.3",
      "pali": "Kūṭāgāravarūpeto,"
    },
    {
      "id": "tha-ap18:9.4",
      "pali": "sattaratanabhūsito."
    },
    {
      "id": "tha-ap18:10.1",
      "pali": "Dasasaddāvivittaṁ taṁ,"
    },
    {
      "id": "tha-ap18:10.2",
      "pali": "vijjādharasamākulaṁ;"
    },
    {
      "id": "tha-ap18:10.3",
      "pali": "Sudassanaṁva nagaraṁ,"
    },
    {
      "id": "tha-ap18:10.4",
      "pali": "devatānaṁ bhavissati."
    },
    {
      "id": "tha-ap18:11.1",
      "pali": "Pabhā niggacchate tassa,"
    },
    {
      "id": "tha-ap18:11.2",
      "pali": "uggacchanteva sūriye;"
    },
    {
      "id": "tha-ap18:11.3",
      "pali": "Virocessati taṁ niccaṁ,"
    },
    {
      "id": "tha-ap18:11.4",
      "pali": "samantā aṭṭhayojanaṁ."
    },
    {
      "id": "tha-ap18:12.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap18:12.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap18:12.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap18:12.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap18:13.1",
      "pali": "Tusitā so cavitvāna,"
    },
    {
      "id": "tha-ap18:13.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap18:13.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap18:13.4",
      "pali": "atrajo so bhavissati."
    },
    {
      "id": "tha-ap18:14.1",
      "pali": "Sacevaseyya agāraṁ,"
    },
    {
      "id": "tha-ap18:14.2",
      "pali": "cakkavattī bhaveyya so;"
    },
    {
      "id": "tha-ap18:14.3",
      "pali": "Aṭṭhānametaṁ yaṁ tādī,"
    },
    {
      "id": "tha-ap18:14.4",
      "pali": "agāre ratimajjhagā."
    },
    {
      "id": "tha-ap18:15.1",
      "pali": "Nikkhamitvā agāramhā,"
    },
    {
      "id": "tha-ap18:15.2",
      "pali": "pabbajissati subbato;"
    },
    {
      "id": "tha-ap18:15.3",
      "pali": "Rāhulo nāma nāmena,"
    },
    {
      "id": "tha-ap18:15.4",
      "pali": "arahā so bhavissati’."
    },
    {
      "id": "tha-ap18:16.1",
      "pali": "Kikīva aṇḍaṁ rakkheyya,"
    },
    {
      "id": "tha-ap18:16.2",
      "pali": "cāmarī viya vāladhiṁ;"
    },
    {
      "id": "tha-ap18:16.3",
      "pali": "Nipako sīlasampanno,"
    },
    {
      "id": "tha-ap18:16.4",
      "pali": "evaṁ rakkhiṁ mahāmuni."
    },
    {
      "id": "tha-ap18:17.1",
      "pali": "Tassāhaṁ dhammamaññāya,"
    },
    {
      "id": "tha-ap18:17.2",
      "pali": "vihāsiṁ sāsane rato;"
    },
    {
      "id": "tha-ap18:17.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap18:17.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap18:18.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap18:18.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap18:18.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap18:18.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap18:19.1",
      "pali": "Itthaṁ sudaṁ āyasmā rāhulo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap18:20.1",
      "pali": "Rāhulattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
