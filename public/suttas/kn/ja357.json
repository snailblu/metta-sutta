{
  "uid": "ja357",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja357:1.1",
      "pali": "“Vandāmi taṁ kuñjara saṭṭhihāyanaṁ,"
    },
    {
      "id": "ja357:1.2",
      "pali": "Āraññakaṁ yūthapatiṁ yasassiṁ;"
    },
    {
      "id": "ja357:1.3",
      "pali": "Pakkhehi taṁ pañjalikaṁ karomi,"
    },
    {
      "id": "ja357:1.4",
      "pali": "Mā me vadhī puttake dubbalāya”."
    },
    {
      "id": "ja357:2.1",
      "pali": "“Vandāmi taṁ kuñjara ekacāriṁ,"
    },
    {
      "id": "ja357:2.2",
      "pali": "Āraññakaṁ pabbatasānugocaraṁ;"
    },
    {
      "id": "ja357:2.3",
      "pali": "Pakkhehi taṁ pañjalikaṁ karomi,"
    },
    {
      "id": "ja357:2.4",
      "pali": "Mā me vadhī puttake dubbalāya”."
    },
    {
      "id": "ja357:3.1",
      "pali": "“Vadhissāmi te laṭukike puttakāni,"
    },
    {
      "id": "ja357:3.2",
      "pali": "Kiṁ me tuvaṁ kāhasi dubbalāsi;"
    },
    {
      "id": "ja357:3.3",
      "pali": "Sataṁ sahassānipi tādisīnaṁ,"
    },
    {
      "id": "ja357:3.4",
      "pali": "Vāmena pādena papothayeyyaṁ”."
    },
    {
      "id": "ja357:4.1",
      "pali": "“Na heva sabbattha balena kiccaṁ,"
    },
    {
      "id": "ja357:4.2",
      "pali": "Balañhi bālassa vadhāya hoti;"
    },
    {
      "id": "ja357:4.3",
      "pali": "Karissāmi te nāgarājā anatthaṁ,"
    },
    {
      "id": "ja357:4.4",
      "pali": "Yo me vadhī puttake dubbalāya”."
    },
    {
      "id": "ja357:5.1",
      "pali": "“Kākañca passa laṭukikaṁ,"
    },
    {
      "id": "ja357:5.2",
      "pali": "Maṇḍūkaṁ nīlamakkhikaṁ;"
    },
    {
      "id": "ja357:5.3",
      "pali": "Ete nāgaṁ aghātesuṁ,"
    },
    {
      "id": "ja357:5.4",
      "pali": "Passa verassa verinaṁ;"
    },
    {
      "id": "ja357:5.5",
      "pali": "Tasmā hi veraṁ na kayirātha,"
    },
    {
      "id": "ja357:5.6",
      "pali": "Appiyenapi kenacī”ti."
    },
    {
      "id": "ja357:6.1",
      "pali": "Laṭukikajātakaṁ sattamaṁ."
    }
  ]
}
