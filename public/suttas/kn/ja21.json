{
  "uid": "ja21",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja21:1.1",
      "pali": "“Ñātametaṁ kuruṅgassa,"
    },
    {
      "id": "ja21:1.2",
      "pali": "yaṁ tvaṁ sepaṇṇi siyyasi;"
    },
    {
      "id": "ja21:1.3",
      "pali": "Aññaṁ sepaṇṇi gacchāmi,"
    },
    {
      "id": "ja21:1.4",
      "pali": "na me te ruccate phalan”ti."
    },
    {
      "id": "ja21:2.1",
      "pali": "Kuruṅgamigajātakaṁ paṭhamaṁ."
    }
  ]
}
