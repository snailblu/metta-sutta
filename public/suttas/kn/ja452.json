{
  "uid": "ja452",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja452:1.1",
      "pali": "“Saccaṁ kira tvaṁ api bhūripañña,"
    },
    {
      "id": "ja452:1.2",
      "pali": "Yā tādisī sīri dhitī matī ca;"
    },
    {
      "id": "ja452:1.3",
      "pali": "Na tāyatebhāvavasūpanitaṁ,"
    },
    {
      "id": "ja452:1.4",
      "pali": "Yo yavakaṁ bhuñjasi appasūpaṁ”."
    },
    {
      "id": "ja452:2.1",
      "pali": "“Sukhaṁ dukkhena paripācayanto,"
    },
    {
      "id": "ja452:2.2",
      "pali": "Kālā kālaṁ vicinaṁ chandachanno;"
    },
    {
      "id": "ja452:2.3",
      "pali": "Atthassa dvārāni avāpuranto,"
    },
    {
      "id": "ja452:2.4",
      "pali": "Tenāhaṁ tussāmi yavodanena."
    },
    {
      "id": "ja452:3.1",
      "pali": "Kālañca ñatvā abhijīhanāya,"
    },
    {
      "id": "ja452:3.2",
      "pali": "Mantehi atthaṁ paripācayitvā;"
    },
    {
      "id": "ja452:3.3",
      "pali": "Vijambhissaṁ sīhavijambhitāni,"
    },
    {
      "id": "ja452:3.4",
      "pali": "Tāyiddhiyā dakkhasi maṁ punāpi”."
    },
    {
      "id": "ja452:4.1",
      "pali": "“Sukhīpi heke na karonti pāpaṁ,"
    },
    {
      "id": "ja452:4.2",
      "pali": "Avaṇṇasaṁsaggabhayā puneke;"
    },
    {
      "id": "ja452:4.3",
      "pali": "Pahū samāno vipulatthacintī,"
    },
    {
      "id": "ja452:4.4",
      "pali": "Kiṅkāraṇā me na karosi dukkhaṁ”."
    },
    {
      "id": "ja452:5.1",
      "pali": "“Na paṇḍitā attasukhassa hetu,"
    },
    {
      "id": "ja452:5.2",
      "pali": "Pāpāni kammāni samācaranti;"
    },
    {
      "id": "ja452:5.3",
      "pali": "Dukkhena phuṭṭhā khalitāpi santā,"
    },
    {
      "id": "ja452:5.4",
      "pali": "Chandā ca dosā na jahanti dhammaṁ”."
    },
    {
      "id": "ja452:6.1",
      "pali": "“Yena kenaci vaṇṇena,"
    },
    {
      "id": "ja452:6.2",
      "pali": "mudunā dāruṇena vā;"
    },
    {
      "id": "ja452:6.3",
      "pali": "Uddhare dīnamattānaṁ,"
    },
    {
      "id": "ja452:6.4",
      "pali": "pacchā dhammaṁ samācare”."
    },
    {
      "id": "ja452:7.1",
      "pali": "“Yassa rukkhassa chāyāya,"
    },
    {
      "id": "ja452:7.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "ja452:7.3",
      "pali": "Na tassa sākhaṁ bhañjeyya,"
    },
    {
      "id": "ja452:7.4",
      "pali": "mittadubbho hi pāpako."
    },
    {
      "id": "ja452:8.1",
      "pali": "Yassāpi dhammaṁ puriso vijaññā,"
    },
    {
      "id": "ja452:8.2",
      "pali": "Ye cassa kaṅkhaṁ vinayanti santo;"
    },
    {
      "id": "ja452:8.3",
      "pali": "Taṁ hissa dīpañca parāyanañca,"
    },
    {
      "id": "ja452:8.4",
      "pali": "Na tena mettiṁ jarayetha pañño”."
    },
    {
      "id": "ja452:9.1",
      "pali": "“Alaso gihī kāmabhogī na sādhu,"
    },
    {
      "id": "ja452:9.2",
      "pali": "Asaññato pabbajito na sādhu;"
    },
    {
      "id": "ja452:9.3",
      "pali": "Rājā na sādhu anisammakārī,"
    },
    {
      "id": "ja452:9.4",
      "pali": "Yo paṇḍito kodhano taṁ na sādhu."
    },
    {
      "id": "ja452:10.1",
      "pali": "Nisamma khattiyo kayirā,"
    },
    {
      "id": "ja452:10.2",
      "pali": "nānisamma disampati;"
    },
    {
      "id": "ja452:10.3",
      "pali": "Nisammakārino rāja,"
    },
    {
      "id": "ja452:10.4",
      "pali": "yaso kitti ca vaḍḍhatī”ti."
    },
    {
      "id": "ja452:11.1",
      "pali": "Bhūripaññajātakaṁ cuddasamaṁ."
    }
  ]
}
