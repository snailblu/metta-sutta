{
  "uid": "ja10",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja10:1.1",
      "pali": "“Yañca aññe na rakkhanti,"
    },
    {
      "id": "ja10:1.2",
      "pali": "yo ca aññe na rakkhati;"
    },
    {
      "id": "ja10:1.3",
      "pali": "Sa ve rāja sukhaṁ seti,"
    },
    {
      "id": "ja10:1.4",
      "pali": "kāmesu anapekkhavā”ti."
    },
    {
      "id": "ja10:2.1",
      "pali": "Sukhavihārijātakaṁ dasamaṁ."
    },
    {
      "id": "ja10:2.2",
      "pali": "Apaṇṇakavaggo paṭhamo."
    },
    {
      "id": "ja10:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja10:4.1",
      "pali": "Varāpaṇṇaka vaṇṇupatha serivaro,"
    },
    {
      "id": "ja10:4.2",
      "pali": "Suvicakkhaṇa taṇḍulanāḷikassā;"
    },
    {
      "id": "ja10:4.3",
      "pali": "Hiri puttavaruttagāmaṇinā,"
    },
    {
      "id": "ja10:4.4",
      "pali": "Yo ca na rakkhati tena dasāti."
    }
  ]
}
