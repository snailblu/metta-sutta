{
  "uid": "thag1.91",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.91:1.1",
      "pali": "“Na tathā mataṁ satarasaṁ,"
    },
    {
      "id": "thag1.91:1.2",
      "pali": "Sudhannaṁ yaṁ mayajja paribhuttaṁ;"
    },
    {
      "id": "thag1.91:1.3",
      "pali": "Aparimitadassinā gotamena,"
    },
    {
      "id": "thag1.91:1.4",
      "pali": "Buddhena desito dhammo”ti."
    },
    {
      "id": "thag1.91:1.5",
      "pali": "… Paripuṇṇako thero …."
    }
  ]
}
