{
  "uid": "tha-ap127",
  "title": "Sammukhāthavikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap127:1.1",
      "pali": "“Jāyamāne vipassimhi,"
    },
    {
      "id": "tha-ap127:1.2",
      "pali": "nimittaṁ byākariṁ ahaṁ;"
    },
    {
      "id": "tha-ap127:1.3",
      "pali": "‘Nibbāpayiñca janataṁ,"
    },
    {
      "id": "tha-ap127:1.4",
      "pali": "buddho loke bhavissati."
    },
    {
      "id": "tha-ap127:2.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:2.2",
      "pali": "dasasahassi kampati;"
    },
    {
      "id": "tha-ap127:2.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:2.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:3.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:3.2",
      "pali": "āloko vipulo ahu;"
    },
    {
      "id": "tha-ap127:3.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:3.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:4.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:4.2",
      "pali": "saritāyo na sandayuṁ;"
    },
    {
      "id": "tha-ap127:4.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:4.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:5.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:5.2",
      "pali": "avīcaggi na pajjali;"
    },
    {
      "id": "tha-ap127:5.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:5.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:6.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:6.2",
      "pali": "pakkhisaṅgho na sañcari;"
    },
    {
      "id": "tha-ap127:6.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:6.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:7.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:7.2",
      "pali": "vātakkhandho na vāyati;"
    },
    {
      "id": "tha-ap127:7.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:7.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:8.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:8.2",
      "pali": "sabbaratanāni jotayuṁ;"
    },
    {
      "id": "tha-ap127:8.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:8.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:9.1",
      "pali": "Yasmiñca jāyamānasmiṁ,"
    },
    {
      "id": "tha-ap127:9.2",
      "pali": "sattāsuṁ padavikkamā;"
    },
    {
      "id": "tha-ap127:9.3",
      "pali": "So dāni bhagavā satthā,"
    },
    {
      "id": "tha-ap127:9.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap127:10.1",
      "pali": "Jātamatto ca sambuddho,"
    },
    {
      "id": "tha-ap127:10.2",
      "pali": "disā sabbā vilokayi;"
    },
    {
      "id": "tha-ap127:10.3",
      "pali": "Vācāsabhimudīresi,"
    },
    {
      "id": "tha-ap127:10.4",
      "pali": "esā buddhāna dhammatā’."
    },
    {
      "id": "tha-ap127:11.1",
      "pali": "Saṁvejayitvā janataṁ,"
    },
    {
      "id": "tha-ap127:11.2",
      "pali": "thavitvā lokanāyakaṁ;"
    },
    {
      "id": "tha-ap127:11.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap127:11.4",
      "pali": "pakkāmiṁ pācināmukho."
    },
    {
      "id": "tha-ap127:12.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap127:12.2",
      "pali": "yaṁ buddhamabhithomayiṁ;"
    },
    {
      "id": "tha-ap127:12.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap127:12.4",
      "pali": "thomanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap127:13.1",
      "pali": "Ito navutikappamhi,"
    },
    {
      "id": "tha-ap127:13.2",
      "pali": "sammukhāthavikavhayo;"
    },
    {
      "id": "tha-ap127:13.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:13.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:14.1",
      "pali": "Pathavīdundubhi nāma,"
    },
    {
      "id": "tha-ap127:14.2",
      "pali": "ekūnanavutimhito;"
    },
    {
      "id": "tha-ap127:14.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:14.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:15.1",
      "pali": "Aṭṭhāsītimhito kappe,"
    },
    {
      "id": "tha-ap127:15.2",
      "pali": "obhāso nāma khattiyo;"
    },
    {
      "id": "tha-ap127:15.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:15.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:16.1",
      "pali": "Sattāsītimhito kappe,"
    },
    {
      "id": "tha-ap127:16.2",
      "pali": "saritacchedanavhayo;"
    },
    {
      "id": "tha-ap127:16.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:16.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:17.1",
      "pali": "Agginibbāpano nāma,"
    },
    {
      "id": "tha-ap127:17.2",
      "pali": "kappānaṁ chaḷasītiyā;"
    },
    {
      "id": "tha-ap127:17.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:17.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:18.1",
      "pali": "Gatipacchedano nāma,"
    },
    {
      "id": "tha-ap127:18.2",
      "pali": "kappānaṁ pañcasītiyā;"
    },
    {
      "id": "tha-ap127:18.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:18.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:19.1",
      "pali": "Rājā vātasamo nāma,"
    },
    {
      "id": "tha-ap127:19.2",
      "pali": "kappānaṁ cullasītiyā;"
    },
    {
      "id": "tha-ap127:19.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:19.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:20.1",
      "pali": "Ratanapajjalo nāma,"
    },
    {
      "id": "tha-ap127:20.2",
      "pali": "kappānaṁ teasītiyā;"
    },
    {
      "id": "tha-ap127:20.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:20.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:21.1",
      "pali": "Padavikkamano nāma,"
    },
    {
      "id": "tha-ap127:21.2",
      "pali": "kappānaṁ dveasītiyā;"
    },
    {
      "id": "tha-ap127:21.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:21.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:22.1",
      "pali": "Rājā vilokano nāma,"
    },
    {
      "id": "tha-ap127:22.2",
      "pali": "kappānaṁ ekasītiyā;"
    },
    {
      "id": "tha-ap127:22.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:22.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:23.1",
      "pali": "Girasāroti nāmena,"
    },
    {
      "id": "tha-ap127:23.2",
      "pali": "kappesītimhi khattiyo;"
    },
    {
      "id": "tha-ap127:23.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap127:23.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap127:24.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap127:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap127:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap127:25.1",
      "pali": "Itthaṁ sudaṁ āyasmā sammukhāthaviko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap127:26.1",
      "pali": "Sammukhāthavikattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
