{
  "uid": "tha-ap511",
  "title": "9 Tālaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap511:1.1",
      "pali": "“Sataraṁsī nāma bhagavā,"
    },
    {
      "id": "tha-ap511:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap511:1.3",
      "pali": "Vivekā vuṭṭhahitvāna,"
    },
    {
      "id": "tha-ap511:1.4",
      "pali": "gocarāyābhinikkhami."
    },
    {
      "id": "tha-ap511:2.1",
      "pali": "Phalahattho ahaṁ disvā,"
    },
    {
      "id": "tha-ap511:2.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap511:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap511:2.4",
      "pali": "tālaphalaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap511:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap511:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap511:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap511:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap511:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap511:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap511:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap511:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap511:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap511:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap511:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap511:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap511:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap511:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tālaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap511:8.1",
      "pali": "Tālaphaladāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
