{
  "uid": "ja223",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja223:1.1",
      "pali": "“Name namantassa bhaje bhajantaṁ,"
    },
    {
      "id": "ja223:1.2",
      "pali": "Kiccānukubbassa kareyya kiccaṁ;"
    },
    {
      "id": "ja223:1.3",
      "pali": "Nānatthakāmassa kareyya atthaṁ,"
    },
    {
      "id": "ja223:1.4",
      "pali": "Asambhajantampi na sambhajeyya."
    },
    {
      "id": "ja223:2.1",
      "pali": "Caje cajantaṁ vanathaṁ na kayirā,"
    },
    {
      "id": "ja223:2.2",
      "pali": "Apetacittena na sambhajeyya;"
    },
    {
      "id": "ja223:2.3",
      "pali": "Dijo dumaṁ khīṇaphalanti ñatvā,"
    },
    {
      "id": "ja223:2.4",
      "pali": "Aññaṁ samekkheyya mahā hi loko”ti."
    },
    {
      "id": "ja223:3.1",
      "pali": "Puṭabhattajātakaṁ tatiyaṁ."
    }
  ]
}
