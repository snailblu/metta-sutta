{
  "uid": "ja373",
  "title": "Aḍḍhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja373:1.1",
      "pali": "“Kuhiṁ gatā kattha gatā,"
    },
    {
      "id": "ja373:1.2",
      "pali": "iti lālappatī jano;"
    },
    {
      "id": "ja373:1.3",
      "pali": "Ahameveko jānāmi,"
    },
    {
      "id": "ja373:1.4",
      "pali": "udapāne mūsikā hatā."
    },
    {
      "id": "ja373:2.1",
      "pali": "Yañcetaṁ iti cīti ca,"
    },
    {
      "id": "ja373:2.2",
      "pali": "gadrabhova nivattasi;"
    },
    {
      "id": "ja373:2.3",
      "pali": "Udapāne mūsikaṁ hantvā,"
    },
    {
      "id": "ja373:2.4",
      "pali": "yavaṁ bhakkhetumicchasi."
    },
    {
      "id": "ja373:3.1",
      "pali": "Daharo cāsi dummedha,"
    },
    {
      "id": "ja373:3.2",
      "pali": "paṭhamuppattiko susu;"
    },
    {
      "id": "ja373:3.3",
      "pali": "Dīghañcetaṁ samāsajja,"
    },
    {
      "id": "ja373:3.4",
      "pali": "na te dassāmi jīvitaṁ."
    },
    {
      "id": "ja373:4.1",
      "pali": "Nāntalikkhabhavanena,"
    },
    {
      "id": "ja373:4.2",
      "pali": "nāṅgaputtapinena vā;"
    },
    {
      "id": "ja373:4.3",
      "pali": "Puttena hi patthayito,"
    },
    {
      "id": "ja373:4.4",
      "pali": "silokehi pamocito."
    },
    {
      "id": "ja373:5.1",
      "pali": "Sabbaṁ sutamadhīyetha,"
    },
    {
      "id": "ja373:5.2",
      "pali": "hīnamukkaṭṭhamajjhimaṁ;"
    },
    {
      "id": "ja373:5.3",
      "pali": "Sabbassa atthaṁ jāneyya,"
    },
    {
      "id": "ja373:5.4",
      "pali": "na ca sabbaṁ payojaye;"
    },
    {
      "id": "ja373:5.5",
      "pali": "Hoti tādisako kālo,"
    },
    {
      "id": "ja373:5.6",
      "pali": "yattha atthāvahaṁ sutan”ti."
    },
    {
      "id": "ja373:6.1",
      "pali": "Mūsikajātakaṁ tatiyaṁ."
    }
  ]
}
