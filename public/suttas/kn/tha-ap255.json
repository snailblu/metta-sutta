{
  "uid": "tha-ap255",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap255:1.1",
      "pali": "“Ānando nāma sambuddho,"
    },
    {
      "id": "tha-ap255:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap255:1.3",
      "pali": "Araññe parinibbāyi,"
    },
    {
      "id": "tha-ap255:1.4",
      "pali": "amanussamhi kānane."
    },
    {
      "id": "tha-ap255:2.1",
      "pali": "Devalokā idhāgantvā,"
    },
    {
      "id": "tha-ap255:2.2",
      "pali": "citaṁ katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap255:2.3",
      "pali": "Sarīraṁ tattha jhāpesiṁ,"
    },
    {
      "id": "tha-ap255:2.4",
      "pali": "sakkārañca akāsahaṁ."
    },
    {
      "id": "tha-ap255:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap255:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap255:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap255:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap255:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap255:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap255:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap255:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap255:6.1",
      "pali": "Citakapūjakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
