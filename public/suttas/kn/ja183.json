{
  "uid": "ja183",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja183:1.1",
      "pali": "“Vālodakaṁ apparasaṁ nihīnaṁ,"
    },
    {
      "id": "ja183:1.2",
      "pali": "Pitvā mado jāyati gadrabhānaṁ;"
    },
    {
      "id": "ja183:1.3",
      "pali": "Imañca pitvāna rasaṁ paṇītaṁ,"
    },
    {
      "id": "ja183:1.4",
      "pali": "Mado na sañjāyati sindhavānaṁ”."
    },
    {
      "id": "ja183:2.1",
      "pali": "“Appaṁ pivitvāna nihīnajacco,"
    },
    {
      "id": "ja183:2.2",
      "pali": "So majjatī tena janinda puṭṭho;"
    },
    {
      "id": "ja183:2.3",
      "pali": "Dhorayhasīlī ca kulamhi jāto,"
    },
    {
      "id": "ja183:2.4",
      "pali": "Na majjatī aggarasaṁ pivitvā”ti."
    },
    {
      "id": "ja183:3.1",
      "pali": "Vālodakajātakaṁ tatiyaṁ."
    }
  ]
}
