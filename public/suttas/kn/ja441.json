{
  "uid": "ja441",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja441:1.1",
      "pali": "“Yo kopaneyye na karoti kopaṁ,"
    },
    {
      "id": "ja441:1.2",
      "pali": "Na kujjhati sappuriso kadāci;"
    },
    {
      "id": "ja441:1.3",
      "pali": "Kuddhopi so nāvikaroti kopaṁ,"
    },
    {
      "id": "ja441:1.4",
      "pali": "Taṁ ve naraṁ samaṇamāhu loke”."
    },
    {
      "id": "ja441:2.1",
      "pali": "“Ūnūdaro yo sahate jighacchaṁ,"
    },
    {
      "id": "ja441:2.2",
      "pali": "Danto tapassī mitapānabhojano;"
    },
    {
      "id": "ja441:2.3",
      "pali": "Āhārahetu na karoti pāpaṁ,"
    },
    {
      "id": "ja441:2.4",
      "pali": "Taṁ ve naraṁ samaṇamāhu loke”."
    },
    {
      "id": "ja441:3.1",
      "pali": "“Khiḍḍaṁ ratiṁ vippajahitvāna sabbaṁ,"
    },
    {
      "id": "ja441:3.2",
      "pali": "Na cālikaṁ bhāsasi kiñci loke;"
    },
    {
      "id": "ja441:3.3",
      "pali": "Vibhūsaṭṭhānā virato methunasmā,"
    },
    {
      "id": "ja441:3.4",
      "pali": "Taṁ ve naraṁ samaṇamāhu loke”."
    },
    {
      "id": "ja441:4.1",
      "pali": "“Pariggahaṁ lobhadhammañca sabbaṁ,"
    },
    {
      "id": "ja441:4.2",
      "pali": "Yo ve pariññāya pariccajeti;"
    },
    {
      "id": "ja441:4.3",
      "pali": "Dantaṁ ṭhitattaṁ amamaṁ nirāsaṁ,"
    },
    {
      "id": "ja441:4.4",
      "pali": "Taṁ ve naraṁ samaṇamāhu loke”."
    },
    {
      "id": "ja441:5.1",
      "pali": "“Pucchāma kattāramanomapaññaṁ,"
    },
    {
      "id": "ja441:5.2",
      "pali": "Kathāsu no viggaho atthi jāto;"
    },
    {
      "id": "ja441:5.3",
      "pali": "Chindajja kaṅkhaṁ vicikicchitāni,"
    },
    {
      "id": "ja441:5.4",
      "pali": "Tadajja kaṅkhaṁ vitaremu sabbe”."
    },
    {
      "id": "ja441:6.1",
      "pali": "“Ye paṇḍitā atthadasā bhavanti,"
    },
    {
      "id": "ja441:6.2",
      "pali": "Bhāsanti te yoniso tattha kāle;"
    },
    {
      "id": "ja441:6.3",
      "pali": "Kathaṁ nu kathānaṁ abhāsitānaṁ,"
    },
    {
      "id": "ja441:6.4",
      "pali": "Atthaṁ nayeyyuṁ kusalā janindā."
    },
    {
      "id": "ja441:7.1",
      "pali": "Kathaṁ have bhāsati nāgarājā,"
    },
    {
      "id": "ja441:7.2",
      "pali": "Garuḷo pana venateyyo kimāha;"
    },
    {
      "id": "ja441:7.3",
      "pali": "Gandhabbarājā pana kiṁ vadesi,"
    },
    {
      "id": "ja441:7.4",
      "pali": "Kathaṁ pana kurūnaṁ rājaseṭṭho”."
    },
    {
      "id": "ja441:8.1",
      "pali": "“Khantiṁ have bhāsati nāgarājā,"
    },
    {
      "id": "ja441:8.2",
      "pali": "Appāhāraṁ garuḷo venateyyo;"
    },
    {
      "id": "ja441:8.3",
      "pali": "Gandhabbarājā rativippahānaṁ,"
    },
    {
      "id": "ja441:8.4",
      "pali": "Akiñcanaṁ kurūnaṁ rājaseṭṭho”."
    },
    {
      "id": "ja441:9.1",
      "pali": "“Sabbāni etāni subhāsitāni,"
    },
    {
      "id": "ja441:9.2",
      "pali": "Na hettha dubbhāsitamatthi kiñci;"
    },
    {
      "id": "ja441:9.3",
      "pali": "Yasmiñca etāni patiṭṭhitāni,"
    },
    {
      "id": "ja441:9.4",
      "pali": "Arāva nābhyā susamohitāni;"
    },
    {
      "id": "ja441:9.5",
      "pali": "Catubbhi dhammehi samaṅgibhūtaṁ,"
    },
    {
      "id": "ja441:9.6",
      "pali": "Taṁ ve naraṁ samaṇamāhu loke”."
    },
    {
      "id": "ja441:10.1",
      "pali": "“Tuvañhi seṭṭho tvamanuttarosi,"
    },
    {
      "id": "ja441:10.2",
      "pali": "Tvaṁ dhammagū dhammavidū sumedho;"
    },
    {
      "id": "ja441:10.3",
      "pali": "Paññāya pañhaṁ samadhiggahetvā,"
    },
    {
      "id": "ja441:10.4",
      "pali": "Acchecchi dhīro vicikicchitāni;"
    },
    {
      "id": "ja441:10.5",
      "pali": "Acchecchi kaṅkhaṁ vicikicchitāni,"
    },
    {
      "id": "ja441:10.6",
      "pali": "Cundo yathā nāgadantaṁ kharena."
    },
    {
      "id": "ja441:11.1",
      "pali": "Nīluppalābhaṁ vimalaṁ anagghaṁ,"
    },
    {
      "id": "ja441:11.2",
      "pali": "Vatthaṁ idaṁ dhūmasamānavaṇṇaṁ;"
    },
    {
      "id": "ja441:11.3",
      "pali": "Pañhassa veyyākaraṇena tuṭṭho,"
    },
    {
      "id": "ja441:11.4",
      "pali": "Dadāmi te dhammapūjāya dhīra."
    },
    {
      "id": "ja441:12.1",
      "pali": "Suvaṇṇamālaṁ satapattaphullitaṁ,"
    },
    {
      "id": "ja441:12.2",
      "pali": "Sakesaraṁ ratnasahassamaṇḍitaṁ;"
    },
    {
      "id": "ja441:12.3",
      "pali": "Pañhassa veyyākaraṇena tuṭṭho,"
    },
    {
      "id": "ja441:12.4",
      "pali": "Dadāmi te dhammapūjāya dhīra."
    },
    {
      "id": "ja441:13.1",
      "pali": "Maṇiṁ anagghaṁ ruciraṁ pabhassaraṁ,"
    },
    {
      "id": "ja441:13.2",
      "pali": "Kaṇṭhāvasattaṁ maṇibhūsitaṁ me;"
    },
    {
      "id": "ja441:13.3",
      "pali": "Pañhassa veyyākaraṇena tuṭṭho,"
    },
    {
      "id": "ja441:13.4",
      "pali": "Dadāmi te dhammapūjāya dhīra."
    },
    {
      "id": "ja441:14.1",
      "pali": "Gavaṁ sahassaṁ usabhañca nāgaṁ,"
    },
    {
      "id": "ja441:14.2",
      "pali": "Ājaññayutte ca rathe dasa ime;"
    },
    {
      "id": "ja441:14.3",
      "pali": "Pañhassa veyyākaraṇena tuṭṭho,"
    },
    {
      "id": "ja441:14.4",
      "pali": "Dadāmi te gāmavarāni soḷasa”."
    },
    {
      "id": "ja441:15.1",
      "pali": "“Sāriputto tadā nāgo,"
    },
    {
      "id": "ja441:15.2",
      "pali": "supaṇṇo pana kolito;"
    },
    {
      "id": "ja441:15.3",
      "pali": "Gandhabbarājā anuruddho,"
    },
    {
      "id": "ja441:15.4",
      "pali": "rājā ānandapaṇḍito;"
    },
    {
      "id": "ja441:15.5",
      "pali": "Vidhuro bodhisatto ca,"
    },
    {
      "id": "ja441:15.6",
      "pali": "evaṁ dhāretha jātakan”ti."
    },
    {
      "id": "ja441:16.1",
      "pali": "Catuposathiyajātakaṁ tatiyaṁ."
    }
  ]
}
