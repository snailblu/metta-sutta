{
  "uid": "tha-ap522",
  "title": "10 Padumadhārikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap522:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap522:1.2",
      "pali": "romaso nāma pabbato;"
    },
    {
      "id": "tha-ap522:1.3",
      "pali": "Buddhopi sambhavo nāma,"
    },
    {
      "id": "tha-ap522:1.4",
      "pali": "abbhokāse vasī tadā."
    },
    {
      "id": "tha-ap522:2.1",
      "pali": "Bhavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap522:2.2",
      "pali": "padumaṁ dhārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap522:2.3",
      "pali": "Ekāhaṁ dhārayitvāna,"
    },
    {
      "id": "tha-ap522:2.4",
      "pali": "bhavanaṁ punarāgamiṁ."
    },
    {
      "id": "tha-ap522:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap522:3.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap522:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap522:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap522:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap522:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap522:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap522:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap522:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap522:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap522:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap522:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap522:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap522:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumadhāriko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap522:8.1",
      "pali": "Padumadhārikattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap522:9.1",
      "pali": "Phaladāyakavaggo dvepaññāsamo."
    },
    {
      "id": "tha-ap522:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap522:11.1",
      "pali": "Kurañciyaṁ kapitthañca,"
    },
    {
      "id": "tha-ap522:11.2",
      "pali": "kosambamatha ketakaṁ;"
    },
    {
      "id": "tha-ap522:11.3",
      "pali": "Nāgapupphajjunañceva,"
    },
    {
      "id": "tha-ap522:11.4",
      "pali": "kuṭajī ghosasaññako."
    },
    {
      "id": "tha-ap522:12.1",
      "pali": "Thero ca sabbaphalado,"
    },
    {
      "id": "tha-ap522:12.2",
      "pali": "tathā padumadhāriko;"
    },
    {
      "id": "tha-ap522:12.3",
      "pali": "Asīti cettha gāthāyo,"
    },
    {
      "id": "tha-ap522:12.4",
      "pali": "tisso gāthā taduttari."
    }
  ]
}
