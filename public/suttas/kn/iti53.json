{
  "uid": "iti53",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti53:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti53:2.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "iti53:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti53:2.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā."
    },
    {
      "id": "iti53:2.4",
      "pali": "Sukhā, bhikkhave, vedanā dukkhato daṭṭhabbā;"
    },
    {
      "id": "iti53:2.5",
      "pali": "dukkhā vedanā sallato daṭṭhabbā;"
    },
    {
      "id": "iti53:2.6",
      "pali": "adukkhamasukhā vedanā aniccato daṭṭhabbā."
    },
    {
      "id": "iti53:2.7",
      "pali": "Yato kho, bhikkhave, bhikkhuno sukhā vedanā dukkhato diṭṭhā hoti, dukkhā vedanā sallato diṭṭhā hoti, adukkhamasukhā vedanā aniccato diṭṭhā hoti;"
    },
    {
      "id": "iti53:2.8",
      "pali": "ayaṁ vuccati, bhikkhave, ‘bhikkhu ariyo, sammaddaso, acchecchi taṇhaṁ, vivattayi saṁyojanaṁ, sammā mānābhisamayā antamakāsi dukkhassā’”ti."
    },
    {
      "id": "iti53:2.9",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti53:2.10",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti53:3.1",
      "pali": "“Yo sukhaṁ dukkhato adda,"
    },
    {
      "id": "iti53:3.2",
      "pali": "Dukkhamaddakkhi sallato;"
    },
    {
      "id": "iti53:3.3",
      "pali": "Adukkhamasukhaṁ santaṁ,"
    },
    {
      "id": "iti53:3.4",
      "pali": "Adakkhi naṁ aniccato."
    },
    {
      "id": "iti53:4.1",
      "pali": "Sa ve sammaddaso bhikkhu,"
    },
    {
      "id": "iti53:4.2",
      "pali": "yato tattha vimuccati;"
    },
    {
      "id": "iti53:4.3",
      "pali": "Abhiññāvosito santo,"
    },
    {
      "id": "iti53:4.4",
      "pali": "sa ve yogātigo munī”ti."
    },
    {
      "id": "iti53:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti53:5.2",
      "pali": "Catutthaṁ."
    }
  ]
}
