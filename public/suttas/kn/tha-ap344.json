{
  "uid": "tha-ap344",
  "title": "2 Tīṇuppalamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap344:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap344:1.2",
      "pali": "ahosiṁ vānaro tadā;"
    },
    {
      "id": "tha-ap344:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap344:1.4",
      "pali": "nisinnaṁ pabbatantare."
    },
    {
      "id": "tha-ap344:2.1",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap344:2.2",
      "pali": "sālarājaṁva phullitaṁ;"
    },
    {
      "id": "tha-ap344:2.3",
      "pali": "Lakkhaṇabyañjanūpetaṁ,"
    },
    {
      "id": "tha-ap344:2.4",
      "pali": "disvā attamano ahuṁ."
    },
    {
      "id": "tha-ap344:3.1",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap344:3.2",
      "pali": "pītiyā haṭṭhamānaso;"
    },
    {
      "id": "tha-ap344:3.3",
      "pali": "Tīṇi uppalapupphāni,"
    },
    {
      "id": "tha-ap344:3.4",
      "pali": "matthake abhiropayiṁ."
    },
    {
      "id": "tha-ap344:4.1",
      "pali": "Pupphāni abhiropetvā,"
    },
    {
      "id": "tha-ap344:4.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap344:4.3",
      "pali": "Sagāravo bhavitvāna,"
    },
    {
      "id": "tha-ap344:4.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap344:5.1",
      "pali": "Gacchanto paṭikuṭiko,"
    },
    {
      "id": "tha-ap344:5.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap344:5.3",
      "pali": "Selantare patitvāna,"
    },
    {
      "id": "tha-ap344:5.4",
      "pali": "pāpuṇiṁ jīvitakkhayaṁ."
    },
    {
      "id": "tha-ap344:6.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap344:6.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap344:6.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap344:6.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap344:7.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap344:7.2",
      "pali": "devarajjaṁ akārayiṁ;"
    },
    {
      "id": "tha-ap344:7.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap344:7.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap344:8.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap344:8.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap344:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap344:8.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap344:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap344:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap344:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap344:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā tīṇuppalamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap344:11.1",
      "pali": "Tīṇuppalamāliyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
