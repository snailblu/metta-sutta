{
  "uid": "tha-ap94",
  "title": "2 Sucintikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap94:1.1",
      "pali": "“Tissassa lokanāthassa,"
    },
    {
      "id": "tha-ap94:1.2",
      "pali": "suddhapīṭhamadāsahaṁ;"
    },
    {
      "id": "tha-ap94:1.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap94:1.4",
      "pali": "buddhassādiccabandhuno."
    },
    {
      "id": "tha-ap94:2.1",
      "pali": "Aṭṭhārase ito kappe,"
    },
    {
      "id": "tha-ap94:2.2",
      "pali": "rājā āsiṁ mahāruci;"
    },
    {
      "id": "tha-ap94:2.3",
      "pali": "Bhogo ca vipulo āsi,"
    },
    {
      "id": "tha-ap94:2.4",
      "pali": "sayanañca anappakaṁ."
    },
    {
      "id": "tha-ap94:3.1",
      "pali": "Pīṭhaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap94:3.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap94:3.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap94:3.4",
      "pali": "pubbe sukatamattano."
    },
    {
      "id": "tha-ap94:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap94:4.2",
      "pali": "yaṁ pīṭhamadadiṁ tadā;"
    },
    {
      "id": "tha-ap94:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap94:4.4",
      "pali": "pīṭhadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap94:5.1",
      "pali": "Aṭṭhatiṁse ito kappe,"
    },
    {
      "id": "tha-ap94:5.2",
      "pali": "tayo te cakkavattino;"
    },
    {
      "id": "tha-ap94:5.3",
      "pali": "Ruci uparuci ceva,"
    },
    {
      "id": "tha-ap94:5.4",
      "pali": "mahāruci tatiyako."
    },
    {
      "id": "tha-ap94:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap94:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap94:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap94:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sucintiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap94:8.1",
      "pali": "Sucintikattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
