{
  "uid": "ja24",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja24:1.1",
      "pali": "“Yadā yadā yattha yadā,"
    },
    {
      "id": "ja24:1.2",
      "pali": "yattha yattha yadā yadā;"
    },
    {
      "id": "ja24:1.3",
      "pali": "Ājañño kurute vegaṁ,"
    },
    {
      "id": "ja24:1.4",
      "pali": "hāyanti tattha vāḷavā”ti."
    },
    {
      "id": "ja24:2.1",
      "pali": "Ājaññajātakaṁ catutthaṁ."
    }
  ]
}
