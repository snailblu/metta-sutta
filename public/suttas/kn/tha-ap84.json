{
  "uid": "tha-ap84",
  "title": "Gatasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap84:1.1",
      "pali": "“Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap84:1.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap84:1.3",
      "pali": "Avandiṁ satthuno pāde,"
    },
    {
      "id": "tha-ap84:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap84:2.1",
      "pali": "Sattanaṅgalakīpupphe,"
    },
    {
      "id": "tha-ap84:2.2",
      "pali": "ākāse ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap84:2.3",
      "pali": "Tissaṁ buddhaṁ samuddissa,"
    },
    {
      "id": "tha-ap84:2.4",
      "pali": "anantaguṇasāgaraṁ."
    },
    {
      "id": "tha-ap84:3.1",
      "pali": "Sugatānugataṁ maggaṁ,"
    },
    {
      "id": "tha-ap84:3.2",
      "pali": "pūjetvā haṭṭhamānaso;"
    },
    {
      "id": "tha-ap84:3.3",
      "pali": "Añjaliñca tadākāsiṁ,"
    },
    {
      "id": "tha-ap84:3.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap84:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap84:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap84:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap84:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap84:5.1",
      "pali": "Ito aṭṭhamake kappe,"
    },
    {
      "id": "tha-ap84:5.2",
      "pali": "tayo aggisikhā ahu;"
    },
    {
      "id": "tha-ap84:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap84:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap84:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap84:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap84:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap84:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā gatasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap84:8.1",
      "pali": "Gatasaññakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
