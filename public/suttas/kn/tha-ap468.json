{
  "uid": "tha-ap468",
  "title": "6 Avaṭaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap468:1.1",
      "pali": "“Sataraṁsī nāma bhagavā,"
    },
    {
      "id": "tha-ap468:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap468:1.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap468:1.4",
      "pali": "gocarāyābhinikkhami."
    },
    {
      "id": "tha-ap468:2.1",
      "pali": "Phalahattho ahaṁ disvā,"
    },
    {
      "id": "tha-ap468:2.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap468:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap468:2.4",
      "pali": "adāsiṁ avaṭaṁ phalaṁ."
    },
    {
      "id": "tha-ap468:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap468:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap468:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap468:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap468:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap468:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap468:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap468:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap468:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap468:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap468:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap468:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap468:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap468:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā avaṭaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap468:8.1",
      "pali": "Avaṭaphaliyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
