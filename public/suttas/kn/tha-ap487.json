{
  "uid": "tha-ap487",
  "title": "Candanamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap487:1.1",
      "pali": "“Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "tha-ap487:1.2",
      "pali": "piyarūpe manorame;"
    },
    {
      "id": "tha-ap487:1.3",
      "pali": "Asītikoṭiyo hitvā,"
    },
    {
      "id": "tha-ap487:1.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap487:2.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "tha-ap487:2.2",
      "pali": "pāpakammaṁ vivajjayiṁ;"
    },
    {
      "id": "tha-ap487:2.3",
      "pali": "Vacīduccaritaṁ hitvā,"
    },
    {
      "id": "tha-ap487:2.4",
      "pali": "nadīkūle vasāmahaṁ."
    },
    {
      "id": "tha-ap487:3.1",
      "pali": "Ekakaṁ maṁ viharantaṁ,"
    },
    {
      "id": "tha-ap487:3.2",
      "pali": "buddhaseṭṭho upāgami;"
    },
    {
      "id": "tha-ap487:3.3",
      "pali": "Nāhaṁ jānāmi buddhoti,"
    },
    {
      "id": "tha-ap487:3.4",
      "pali": "akāsiṁ paṭisanthāraṁ."
    },
    {
      "id": "tha-ap487:4.1",
      "pali": "Karitvā paṭisanthāraṁ,"
    },
    {
      "id": "tha-ap487:4.2",
      "pali": "nāmagottamapucchahaṁ;"
    },
    {
      "id": "tha-ap487:4.3",
      "pali": "‘Devatānusi gandhabbo,"
    },
    {
      "id": "tha-ap487:4.4",
      "pali": "adu sakko purindado."
    },
    {
      "id": "tha-ap487:5.1",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "tha-ap487:5.2",
      "pali": "mahābrahmā idhāgato;"
    },
    {
      "id": "tha-ap487:5.3",
      "pali": "Virocesi disā sabbā,"
    },
    {
      "id": "tha-ap487:5.4",
      "pali": "udayaṁ sūriyo yathā."
    },
    {
      "id": "tha-ap487:6.1",
      "pali": "Sahassārāni cakkāni,"
    },
    {
      "id": "tha-ap487:6.2",
      "pali": "pāde dissanti mārisa;"
    },
    {
      "id": "tha-ap487:6.3",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "tha-ap487:6.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ;"
    },
    {
      "id": "tha-ap487:6.5",
      "pali": "Nāmagottaṁ pavedehi,"
    },
    {
      "id": "tha-ap487:6.6",
      "pali": "saṁsayaṁ apanehi me."
    },
    {
      "id": "tha-ap487:7.1",
      "pali": "Namhi devo na gandhabbo,"
    },
    {
      "id": "tha-ap487:7.2",
      "pali": "namhi sakko purindado;"
    },
    {
      "id": "tha-ap487:7.3",
      "pali": "Brahmabhāvo ca me natthi,"
    },
    {
      "id": "tha-ap487:7.4",
      "pali": "etesaṁ uttamo ahaṁ."
    },
    {
      "id": "tha-ap487:8.1",
      "pali": "Atīto visayaṁ tesaṁ,"
    },
    {
      "id": "tha-ap487:8.2",
      "pali": "dālayiṁ kāmabandhanaṁ;"
    },
    {
      "id": "tha-ap487:8.3",
      "pali": "Sabbe kilese jhāpetvā,"
    },
    {
      "id": "tha-ap487:8.4",
      "pali": "patto sambodhimuttamaṁ’."
    },
    {
      "id": "tha-ap487:9.1",
      "pali": "Tassa vācaṁ suṇitvāhaṁ,"
    },
    {
      "id": "tha-ap487:9.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "tha-ap487:9.3",
      "pali": "‘Yadi buddhoti sabbaññū,"
    },
    {
      "id": "tha-ap487:9.4",
      "pali": "nisīda tvaṁ mahāmune."
    },
    {
      "id": "tha-ap487:10.1",
      "pali": "Tamahaṁ pūjayissāmi,"
    },
    {
      "id": "tha-ap487:10.2",
      "pali": "dukkhassantakaro tuvaṁ’;"
    },
    {
      "id": "tha-ap487:10.3",
      "pali": "Pattharitvā jinacammaṁ,"
    },
    {
      "id": "tha-ap487:10.4",
      "pali": "adāsi satthuno ahaṁ."
    },
    {
      "id": "tha-ap487:11.1",
      "pali": "Nisīdi tattha bhagavā,"
    },
    {
      "id": "tha-ap487:11.2",
      "pali": "sīhova girigabbhare;"
    },
    {
      "id": "tha-ap487:11.3",
      "pali": "Khippaṁ pabbatamāruyha,"
    },
    {
      "id": "tha-ap487:11.4",
      "pali": "ambassa phalamaggahiṁ."
    },
    {
      "id": "tha-ap487:12.1",
      "pali": "Sālakalyāṇikaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap487:12.2",
      "pali": "Candanañca mahārahaṁ;"
    },
    {
      "id": "tha-ap487:12.3",
      "pali": "Khippaṁ paggayha taṁ sabbaṁ,"
    },
    {
      "id": "tha-ap487:12.4",
      "pali": "Upetvā lokanāyakaṁ."
    },
    {
      "id": "tha-ap487:13.1",
      "pali": "Phalaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap487:13.2",
      "pali": "sālapupphamapūjayiṁ;"
    },
    {
      "id": "tha-ap487:13.3",
      "pali": "Candanaṁ anulimpitvā,"
    },
    {
      "id": "tha-ap487:13.4",
      "pali": "avandiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap487:14.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap487:14.2",
      "pali": "vipulāya ca pītiyā;"
    },
    {
      "id": "tha-ap487:14.3",
      "pali": "Ajinamhi nisīditvā,"
    },
    {
      "id": "tha-ap487:14.4",
      "pali": "sumedho lokanāyako."
    },
    {
      "id": "tha-ap487:15.1",
      "pali": "Mama kammaṁ pakittesi,"
    },
    {
      "id": "tha-ap487:15.2",
      "pali": "hāsayanto mamaṁ tadā;"
    },
    {
      "id": "tha-ap487:15.3",
      "pali": "‘Iminā phaladānena,"
    },
    {
      "id": "tha-ap487:15.4",
      "pali": "gandhamālehi cūbhayaṁ."
    },
    {
      "id": "tha-ap487:16.1",
      "pali": "Pañcavīse kappasate,"
    },
    {
      "id": "tha-ap487:16.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap487:16.3",
      "pali": "Anūnamanasaṅkappo,"
    },
    {
      "id": "tha-ap487:16.4",
      "pali": "vasavattī bhavissati."
    },
    {
      "id": "tha-ap487:17.1",
      "pali": "Chabbīsatikappasate,"
    },
    {
      "id": "tha-ap487:17.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap487:17.3",
      "pali": "Bhavissati cakkavattī,"
    },
    {
      "id": "tha-ap487:17.4",
      "pali": "cāturanto mahiddhiko."
    },
    {
      "id": "tha-ap487:18.1",
      "pali": "Vebhāraṁ nāma nagaraṁ,"
    },
    {
      "id": "tha-ap487:18.2",
      "pali": "vissakammena māpitaṁ;"
    },
    {
      "id": "tha-ap487:18.3",
      "pali": "Hessati sabbasovaṇṇaṁ,"
    },
    {
      "id": "tha-ap487:18.4",
      "pali": "nānāratanabhūsitaṁ."
    },
    {
      "id": "tha-ap487:19.1",
      "pali": "Eteneva upāyena,"
    },
    {
      "id": "tha-ap487:19.2",
      "pali": "saṁsarissati so bhave;"
    },
    {
      "id": "tha-ap487:19.3",
      "pali": "Sabbattha pūjito hutvā,"
    },
    {
      "id": "tha-ap487:19.4",
      "pali": "devatte atha mānuse."
    },
    {
      "id": "tha-ap487:20.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap487:20.2",
      "pali": "brahmabandhu bhavissati;"
    },
    {
      "id": "tha-ap487:20.3",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap487:20.4",
      "pali": "anagārī bhavissati;"
    },
    {
      "id": "tha-ap487:20.5",
      "pali": "Abhiññāpāragū hutvā,"
    },
    {
      "id": "tha-ap487:20.6",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap487:21.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap487:21.2",
      "pali": "sumedho lokanāyako;"
    },
    {
      "id": "tha-ap487:21.3",
      "pali": "Mama nijjhāyamānassa,"
    },
    {
      "id": "tha-ap487:21.4",
      "pali": "pakkāmi anilañjase."
    },
    {
      "id": "tha-ap487:22.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap487:22.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap487:22.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap487:22.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap487:23.1",
      "pali": "Tusitato cavitvāna,"
    },
    {
      "id": "tha-ap487:23.2",
      "pali": "nibbattiṁ mātukucchiyaṁ;"
    },
    {
      "id": "tha-ap487:23.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap487:23.4",
      "pali": "yamhi gabbhe vasāmahaṁ."
    },
    {
      "id": "tha-ap487:24.1",
      "pali": "Mātukucchigate mayi,"
    },
    {
      "id": "tha-ap487:24.2",
      "pali": "annapānañca bhojanaṁ;"
    },
    {
      "id": "tha-ap487:24.3",
      "pali": "Mātuyā mama chandena,"
    },
    {
      "id": "tha-ap487:24.4",
      "pali": "nibbattati yadicchakaṁ."
    },
    {
      "id": "tha-ap487:25.1",
      "pali": "Jātiyā pañcavassena,"
    },
    {
      "id": "tha-ap487:25.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap487:25.3",
      "pali": "Oropitamhi kesamhi,"
    },
    {
      "id": "tha-ap487:25.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap487:26.1",
      "pali": "Pubbakammaṁ gavesanto,"
    },
    {
      "id": "tha-ap487:26.2",
      "pali": "orena nāddasaṁ ahaṁ;"
    },
    {
      "id": "tha-ap487:26.3",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap487:26.4",
      "pali": "mama kammamanussariṁ."
    },
    {
      "id": "tha-ap487:27.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap487:27.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap487:27.3",
      "pali": "Tava sāsanamāgamma,"
    },
    {
      "id": "tha-ap487:27.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap487:28.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap487:28.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap487:28.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap487:28.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap487:29.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap487:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap487:29.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap487:30.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap487:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap487:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap487:31.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap487:31.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap487:31.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap487:32.1",
      "pali": "Itthaṁ sudaṁ āyasmā candanamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap487:33.1",
      "pali": "Candanamāliyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
