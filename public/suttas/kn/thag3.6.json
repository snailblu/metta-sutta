{
  "uid": "thag3.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.6:1.1",
      "pali": "“Ye cittakathī bahussutā,"
    },
    {
      "id": "thag3.6:1.2",
      "pali": "Samaṇā pāṭaliputtavāsino;"
    },
    {
      "id": "thag3.6:1.3",
      "pali": "Tesaññataroyamāyuvā,"
    },
    {
      "id": "thag3.6:1.4",
      "pali": "Dvāre tiṭṭhati khujjasobhito”."
    },
    {
      "id": "thag3.6:2.1",
      "pali": "“Ye cittakathī bahussutā,"
    },
    {
      "id": "thag3.6:2.2",
      "pali": "Samaṇā pāṭaliputtavāsino;"
    },
    {
      "id": "thag3.6:2.3",
      "pali": "Tesaññataroyamāyuvā,"
    },
    {
      "id": "thag3.6:2.4",
      "pali": "Dvāre tiṭṭhati māluterito”."
    },
    {
      "id": "thag3.6:3.1",
      "pali": "“Suyuddhena suyiṭṭhena,"
    },
    {
      "id": "thag3.6:3.2",
      "pali": "saṅgāmavijayena ca;"
    },
    {
      "id": "thag3.6:3.3",
      "pali": "Brahmacariyānuciṇṇena,"
    },
    {
      "id": "thag3.6:3.4",
      "pali": "evāyaṁ sukhamedhatī”ti."
    },
    {
      "id": "thag3.6:3.5",
      "pali": "… Khujjasobhito thero …."
    }
  ]
}
