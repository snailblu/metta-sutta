{
  "uid": "tha-ap456",
  "title": "4 Tiṇukkadhāriyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap456:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap456:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap456:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap456:1.4",
      "pali": "tayo ukke adhārayiṁ."
    },
    {
      "id": "tha-ap456:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap456:2.2",
      "pali": "sohaṁ ukkamadhārayiṁ;"
    },
    {
      "id": "tha-ap456:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap456:2.4",
      "pali": "ukkadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap456:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap456:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap456:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap456:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap456:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap456:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap456:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap456:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap456:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap456:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇukkadhāriyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap456:7.1",
      "pali": "Tiṇukkadhāriyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
