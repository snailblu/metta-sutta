{
  "uid": "ja444",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja444:1.1",
      "pali": "“Sattāhamevāhaṁ pasannacitto,"
    },
    {
      "id": "ja444:1.2",
      "pali": "Puññatthiko ācariṁ brahmacariyaṁ;"
    },
    {
      "id": "ja444:1.3",
      "pali": "Athāparaṁ yaṁ caritaṁ mamedaṁ,"
    },
    {
      "id": "ja444:1.4",
      "pali": "Vassāni paññāsa samādhikāni;"
    },
    {
      "id": "ja444:1.5",
      "pali": "Akāmakovāpi ahaṁ carāmi,"
    },
    {
      "id": "ja444:1.6",
      "pali": "Etena saccena suvatthi hotu;"
    },
    {
      "id": "ja444:1.7",
      "pali": "Hataṁ visaṁ jīvatu yaññadatto”."
    },
    {
      "id": "ja444:2.1",
      "pali": "“Yasmā dānaṁ nābhinandiṁ kadāci,"
    },
    {
      "id": "ja444:2.2",
      "pali": "Disvānahaṁ atithiṁ vāsakāle;"
    },
    {
      "id": "ja444:2.3",
      "pali": "Na cāpi me appiyataṁ aveduṁ,"
    },
    {
      "id": "ja444:2.4",
      "pali": "Bahussutā samaṇabrāhmaṇā ca”."
    },
    {
      "id": "ja444:2.5",
      "pali": "Akāmakovāpi ahaṁ dadāmi,"
    },
    {
      "id": "ja444:2.6",
      "pali": "Etena saccena suvatthi hotu;"
    },
    {
      "id": "ja444:2.7",
      "pali": "Hataṁ visaṁ jīvatu yaññadatto."
    },
    {
      "id": "ja444:3.1",
      "pali": "“Āsīviso tāta pahūtatejo,"
    },
    {
      "id": "ja444:3.2",
      "pali": "Yo taṁ adaṁsī sacarā udicca;"
    },
    {
      "id": "ja444:3.3",
      "pali": "Tasmiñca me appiyatāya ajja,"
    },
    {
      "id": "ja444:3.4",
      "pali": "Pitari ca te natthi koci viseso;"
    },
    {
      "id": "ja444:3.5",
      "pali": "Etena saccena suvatthi hotu,"
    },
    {
      "id": "ja444:3.6",
      "pali": "Hataṁ visaṁ jīvatu yaññadatto”."
    },
    {
      "id": "ja444:4.1",
      "pali": "“Santā dantāyeva paribbajanti,"
    },
    {
      "id": "ja444:4.2",
      "pali": "Aññatra kaṇhā natthākāmarūpā;"
    },
    {
      "id": "ja444:4.3",
      "pali": "Dīpāyana kissa jigucchamāno,"
    },
    {
      "id": "ja444:4.4",
      "pali": "Akāmako carasi brahmacariyaṁ”."
    },
    {
      "id": "ja444:5.1",
      "pali": "“Saddhāya nikkhamma punaṁ nivatto,"
    },
    {
      "id": "ja444:5.2",
      "pali": "So eḷamūgova bālo vatāyaṁ;"
    },
    {
      "id": "ja444:5.3",
      "pali": "Etassa vādassa jigucchamāno,"
    },
    {
      "id": "ja444:5.4",
      "pali": "Akāmako carāmi brahmacariyaṁ;"
    },
    {
      "id": "ja444:5.5",
      "pali": "Viññuppasatthañca satañca ṭhānaṁ,"
    },
    {
      "id": "ja444:5.6",
      "pali": "Evampahaṁ puññakaro bhavāmi”."
    },
    {
      "id": "ja444:6.1",
      "pali": "“Samaṇe tuvaṁ brāhmaṇe addhike ca,"
    },
    {
      "id": "ja444:6.2",
      "pali": "Santappayāsi annapānena bhikkhaṁ;"
    },
    {
      "id": "ja444:6.3",
      "pali": "Opānabhūtaṁva gharaṁ tava yidaṁ,"
    },
    {
      "id": "ja444:6.4",
      "pali": "Annena pānena upetarūpaṁ;"
    },
    {
      "id": "ja444:6.5",
      "pali": "Atha kissa vādassa jigucchamāno,"
    },
    {
      "id": "ja444:6.6",
      "pali": "Akāmako dānamimaṁ dadāsi”."
    },
    {
      "id": "ja444:7.1",
      "pali": "“Pitaro ca me āsuṁ pitāmahā ca,"
    },
    {
      "id": "ja444:7.2",
      "pali": "Saddhā ahuṁ dānapatī vadaññū;"
    },
    {
      "id": "ja444:7.3",
      "pali": "Taṁ kullavattaṁ anuvattamāno,"
    },
    {
      "id": "ja444:7.4",
      "pali": "Māhaṁ kule antimagandhano ahuṁ;"
    },
    {
      "id": "ja444:7.5",
      "pali": "Etassa vādassa jigucchamāno,"
    },
    {
      "id": "ja444:7.6",
      "pali": "Akāmako dānamimaṁ dadāmi”."
    },
    {
      "id": "ja444:8.1",
      "pali": "“Dahariṁ kumāriṁ asamatthapaññaṁ,"
    },
    {
      "id": "ja444:8.2",
      "pali": "Yaṁ tānayiṁ ñātikulā sugatte;"
    },
    {
      "id": "ja444:8.3",
      "pali": "Na cāpi me appiyataṁ avedi,"
    },
    {
      "id": "ja444:8.4",
      "pali": "Aññatra kāmā paricārayantā;"
    },
    {
      "id": "ja444:8.5",
      "pali": "Atha kena vaṇṇena mayā te bhoti,"
    },
    {
      "id": "ja444:8.6",
      "pali": "Saṁvāsadhammo ahu evarūpo”."
    },
    {
      "id": "ja444:9.1",
      "pali": "“Ārā dūre nayidha kadāci atthi,"
    },
    {
      "id": "ja444:9.2",
      "pali": "Paramparā nāma kule imasmiṁ;"
    },
    {
      "id": "ja444:9.3",
      "pali": "Taṁ kullavattaṁ anuvattamānā,"
    },
    {
      "id": "ja444:9.4",
      "pali": "Māhaṁ kule antimagandhinī ahuṁ;"
    },
    {
      "id": "ja444:9.5",
      "pali": "Etassa vādassa jigucchamānā,"
    },
    {
      "id": "ja444:9.6",
      "pali": "Akāmikā paddhacarāmhi tuyhaṁ”."
    },
    {
      "id": "ja444:10.1",
      "pali": "“Maṇḍabya bhāsiṁ yamabhāsaneyyaṁ,"
    },
    {
      "id": "ja444:10.2",
      "pali": "Taṁ khamyataṁ puttakahetu majja;"
    },
    {
      "id": "ja444:10.3",
      "pali": "Puttapemā na idha paratthi kiñci,"
    },
    {
      "id": "ja444:10.4",
      "pali": "So no ayaṁ jīvati yaññadatto”ti."
    },
    {
      "id": "ja444:11.1",
      "pali": "Kaṇhadīpāyanajātakaṁ chaṭṭhaṁ."
    }
  ]
}
