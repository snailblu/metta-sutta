{
  "uid": "tha-ap513",
  "title": "1 Kurañciyaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap513:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap513:1.2",
      "pali": "vipine vicaraṁ ahaṁ;"
    },
    {
      "id": "tha-ap513:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap513:1.4",
      "pali": "sabbadhammāna pāraguṁ."
    },
    {
      "id": "tha-ap513:2.1",
      "pali": "Kurañciyaphalaṁ gayha,"
    },
    {
      "id": "tha-ap513:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap513:2.3",
      "pali": "Puññakkhettassa tādino,"
    },
    {
      "id": "tha-ap513:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap513:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap513:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap513:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap513:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap513:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap513:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap513:4.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap513:4.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap513:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap513:5.2",
      "pali": "buddhaseṭṭhassa santike;"
    },
    {
      "id": "tha-ap513:5.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap513:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap513:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap513:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap513:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap513:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap513:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kurañciyaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap513:8.1",
      "pali": "Kurañciyaphaladāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
