{
  "uid": "ja204",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja204:1.1",
      "pali": "“Api vīraka passesi,"
    },
    {
      "id": "ja204:1.2",
      "pali": "sakuṇaṁ mañjubhāṇakaṁ;"
    },
    {
      "id": "ja204:1.3",
      "pali": "Mayūragīvasaṅkāsaṁ,"
    },
    {
      "id": "ja204:1.4",
      "pali": "patiṁ mayhaṁ saviṭṭhakaṁ”."
    },
    {
      "id": "ja204:2.1",
      "pali": "“Udakathalacarassa pakkhino,"
    },
    {
      "id": "ja204:2.2",
      "pali": "Niccaṁ āmakamacchabhojino;"
    },
    {
      "id": "ja204:2.3",
      "pali": "Tassānukaraṁ saviṭṭhako,"
    },
    {
      "id": "ja204:2.4",
      "pali": "Sevāle paliguṇṭhito mato”ti."
    },
    {
      "id": "ja204:3.1",
      "pali": "Vīrakajātakaṁ catutthaṁ."
    }
  ]
}
