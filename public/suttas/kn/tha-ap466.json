{
  "uid": "tha-ap466",
  "title": "Setudāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap466:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap466:1.2",
      "pali": "caṅkamantassa sammukhā;"
    },
    {
      "id": "tha-ap466:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap466:1.4",
      "pali": "setuṁ kārāpayiṁ ahaṁ."
    },
    {
      "id": "tha-ap466:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap466:2.2",
      "pali": "yaṁ setuṁ kārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap466:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap466:2.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap466:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap466:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap466:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap466:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap466:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap466:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap466:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap466:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap466:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap466:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā setudāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap466:7.1",
      "pali": "Setudāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
