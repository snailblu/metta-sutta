{
  "uid": "ja128",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja128:1.1",
      "pali": "“Yo ve dhammaṁ dhajaṁ katvā,"
    },
    {
      "id": "ja128:1.2",
      "pali": "Nigūḷho pāpamācare;"
    },
    {
      "id": "ja128:1.3",
      "pali": "Vissāsayitvā bhūtāni,"
    },
    {
      "id": "ja128:1.4",
      "pali": "Biḷāraṁ nāma taṁ vatan”ti."
    },
    {
      "id": "ja128:2.1",
      "pali": "Biḷāravatajātakaṁ aṭṭhamaṁ."
    }
  ]
}
