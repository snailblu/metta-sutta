{
  "uid": "tha-ap135",
  "title": "3 Candanapūjanakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap135:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap135:1.2",
      "pali": "ahosiṁ kinnaro tadā;"
    },
    {
      "id": "tha-ap135:1.3",
      "pali": "Pupphabhakkho cahaṁ āsiṁ,"
    },
    {
      "id": "tha-ap135:1.4",
      "pali": "pupphānivasano tathā."
    },
    {
      "id": "tha-ap135:2.1",
      "pali": "Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap135:2.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap135:2.3",
      "pali": "Vipinaggena niyyāsi,"
    },
    {
      "id": "tha-ap135:2.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap135:3.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap135:3.2",
      "pali": "cittaṁ te suvisodhitaṁ;"
    },
    {
      "id": "tha-ap135:3.3",
      "pali": "Pasannamukhavaṇṇosi,"
    },
    {
      "id": "tha-ap135:3.4",
      "pali": "vippasannamukhindriyo."
    },
    {
      "id": "tha-ap135:4.1",
      "pali": "Orohitvāna ākāsā,"
    },
    {
      "id": "tha-ap135:4.2",
      "pali": "bhūripañño sumedhaso;"
    },
    {
      "id": "tha-ap135:4.3",
      "pali": "Saṅghāṭiṁ pattharitvāna,"
    },
    {
      "id": "tha-ap135:4.4",
      "pali": "pallaṅkena upāvisi."
    },
    {
      "id": "tha-ap135:5.1",
      "pali": "Vilīnaṁ candanādāya,"
    },
    {
      "id": "tha-ap135:5.2",
      "pali": "agamāsiṁ jinantikaṁ;"
    },
    {
      "id": "tha-ap135:5.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap135:5.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap135:6.1",
      "pali": "Abhivādetvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap135:6.2",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap135:6.3",
      "pali": "Pāmojjaṁ janayitvāna,"
    },
    {
      "id": "tha-ap135:6.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap135:7.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap135:7.2",
      "pali": "candanaṁ yaṁ apūjayiṁ;"
    },
    {
      "id": "tha-ap135:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap135:7.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap135:8.1",
      "pali": "Catuddase kappasate,"
    },
    {
      "id": "tha-ap135:8.2",
      "pali": "ito āsiṁsu te tayo;"
    },
    {
      "id": "tha-ap135:8.3",
      "pali": "Rohaṇī nāma nāmena,"
    },
    {
      "id": "tha-ap135:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap135:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap135:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap135:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap135:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā candanapūjanako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap135:11.1",
      "pali": "Candanapūjanakattherassāpadānaṁ tatiyaṁ."
    },
    {
      "id": "tha-ap135:11.2",
      "pali": "Aṭṭhamabhāṇavāraṁ."
    }
  ]
}
