{
  "uid": "ja320",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja320:1.1",
      "pali": "“Succajaṁ vata naccaji,"
    },
    {
      "id": "ja320:1.2",
      "pali": "vācāya adadaṁ giriṁ;"
    },
    {
      "id": "ja320:1.3",
      "pali": "Kiṁ hitassa cajantassa,"
    },
    {
      "id": "ja320:1.4",
      "pali": "vācāya adada pabbataṁ”."
    },
    {
      "id": "ja320:2.1",
      "pali": "“Yañhi kayirā tañhi vade,"
    },
    {
      "id": "ja320:2.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "ja320:2.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "ja320:2.4",
      "pali": "parijānanti paṇḍitā”."
    },
    {
      "id": "ja320:3.1",
      "pali": "“Rājaputta namo tyatthu,"
    },
    {
      "id": "ja320:3.2",
      "pali": "sacce dhamme ṭhito casi;"
    },
    {
      "id": "ja320:3.3",
      "pali": "Yassa te byasanaṁ patto,"
    },
    {
      "id": "ja320:3.4",
      "pali": "saccasmiṁ ramate mano”."
    },
    {
      "id": "ja320:4.1",
      "pali": "“Yā daliddī daliddassa,"
    },
    {
      "id": "ja320:4.2",
      "pali": "aḍḍhā aḍḍhassa kittima;"
    },
    {
      "id": "ja320:4.3",
      "pali": "Sā hissa paramā bhariyā,"
    },
    {
      "id": "ja320:4.4",
      "pali": "sahiraññassa itthiyo”ti."
    },
    {
      "id": "ja320:5.1",
      "pali": "Succajajātakaṁ dasamaṁ."
    },
    {
      "id": "ja320:5.2",
      "pali": "Pucimandavaggo dutiyo."
    },
    {
      "id": "ja320:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja320:7.1",
      "pali": "Atha cora sakassapa khantīvaro,"
    },
    {
      "id": "ja320:7.2",
      "pali": "Dujjīvitatā ca varā pharusā;"
    },
    {
      "id": "ja320:7.3",
      "pali": "Atha sasa matañca vasanta sukhaṁ,"
    },
    {
      "id": "ja320:7.4",
      "pali": "Succajaṁvatanaccajinā ca dasāti."
    }
  ]
}
