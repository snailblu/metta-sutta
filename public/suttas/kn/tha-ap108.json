{
  "uid": "tha-ap108",
  "title": "Udakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap108:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap108:1.2",
      "pali": "Gacchantaṁ anilañjase;"
    },
    {
      "id": "tha-ap108:1.3",
      "pali": "Ghatāsanaṁva jalitaṁ,"
    },
    {
      "id": "tha-ap108:1.4",
      "pali": "Ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap108:2.1",
      "pali": "Pāṇinā udakaṁ gayha,"
    },
    {
      "id": "tha-ap108:2.2",
      "pali": "ākāse ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap108:2.3",
      "pali": "Sampaṭicchi mahāvīro,"
    },
    {
      "id": "tha-ap108:2.4",
      "pali": "buddho kāruṇiko isi."
    },
    {
      "id": "tha-ap108:3.1",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap108:3.2",
      "pali": "padumuttaranāmako;"
    },
    {
      "id": "tha-ap108:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap108:3.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap108:4.1",
      "pali": "‘Iminā dakadānena,"
    },
    {
      "id": "tha-ap108:4.2",
      "pali": "pītiuppādanena ca;"
    },
    {
      "id": "tha-ap108:4.3",
      "pali": "Kappasatasahassampi,"
    },
    {
      "id": "tha-ap108:4.4",
      "pali": "duggatiṁ nupapajjati’."
    },
    {
      "id": "tha-ap108:5.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap108:5.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap108:5.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap108:5.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap108:6.1",
      "pali": "Sahassarājanāmena,"
    },
    {
      "id": "tha-ap108:6.2",
      "pali": "tayo te cakkavattino;"
    },
    {
      "id": "tha-ap108:6.3",
      "pali": "Pañcasaṭṭhikappasate,"
    },
    {
      "id": "tha-ap108:6.4",
      "pali": "cāturantā janādhipā."
    },
    {
      "id": "tha-ap108:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap108:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap108:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap108:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā udakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap108:9.1",
      "pali": "Udakapūjakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
