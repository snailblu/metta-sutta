{
  "uid": "vv5",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv5:1.1",
      "pali": "“Kuñjaro te varāroho,"
    },
    {
      "id": "vv5:1.2",
      "pali": "Nānāratanakappano;"
    },
    {
      "id": "vv5:1.3",
      "pali": "Ruciro thāmavā javasampanno,"
    },
    {
      "id": "vv5:1.4",
      "pali": "Ākāsamhi samīhati."
    },
    {
      "id": "vv5:2.1",
      "pali": "Padumi padmapattakkhi,"
    },
    {
      "id": "vv5:2.2",
      "pali": "padmuppalajutindharo;"
    },
    {
      "id": "vv5:2.3",
      "pali": "Padmacuṇṇābhikiṇṇaṅgo,"
    },
    {
      "id": "vv5:2.4",
      "pali": "soṇṇapokkharamāladhā."
    },
    {
      "id": "vv5:3.1",
      "pali": "Padumānusaṭaṁ maggaṁ,"
    },
    {
      "id": "vv5:3.2",
      "pali": "padmapattavibhūsitaṁ;"
    },
    {
      "id": "vv5:3.3",
      "pali": "Ṭhitaṁ vaggu manugghātī,"
    },
    {
      "id": "vv5:3.4",
      "pali": "mitaṁ gacchati vāraṇo."
    },
    {
      "id": "vv5:4.1",
      "pali": "Tassa pakkamamānassa,"
    },
    {
      "id": "vv5:4.2",
      "pali": "soṇṇakaṁsā ratissarā;"
    },
    {
      "id": "vv5:4.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv5:4.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv5:5.1",
      "pali": "Tassa nāgassa khandhamhi,"
    },
    {
      "id": "vv5:5.2",
      "pali": "sucivatthā alaṅkatā;"
    },
    {
      "id": "vv5:5.3",
      "pali": "Mahantaṁ accharāsaṅghaṁ,"
    },
    {
      "id": "vv5:5.4",
      "pali": "vaṇṇena atirocasi."
    },
    {
      "id": "vv5:6.1",
      "pali": "Dānassa te idaṁ phalaṁ,"
    },
    {
      "id": "vv5:6.2",
      "pali": "atho sīlassa vā pana;"
    },
    {
      "id": "vv5:6.3",
      "pali": "Atho añjalikammassa,"
    },
    {
      "id": "vv5:6.4",
      "pali": "taṁ me akkhāhi pucchitā”ti."
    },
    {
      "id": "vv5:7.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv5:7.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv5:7.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv5:7.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv5:8.1",
      "pali": "“Disvāna guṇasampannaṁ,"
    },
    {
      "id": "vv5:8.2",
      "pali": "jhāyiṁ jhānarataṁ sataṁ;"
    },
    {
      "id": "vv5:8.3",
      "pali": "Adāsiṁ pupphābhikiṇṇaṁ,"
    },
    {
      "id": "vv5:8.4",
      "pali": "āsanaṁ dussasanthataṁ."
    },
    {
      "id": "vv5:9.1",
      "pali": "Upaḍḍhaṁ padmamālāhaṁ,"
    },
    {
      "id": "vv5:9.2",
      "pali": "āsanassa samantato;"
    },
    {
      "id": "vv5:9.3",
      "pali": "Abbhokirissaṁ pattehi,"
    },
    {
      "id": "vv5:9.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv5:10.1",
      "pali": "Tassa kammakusalassa,"
    },
    {
      "id": "vv5:10.2",
      "pali": "idaṁ me īdisaṁ phalaṁ;"
    },
    {
      "id": "vv5:10.3",
      "pali": "Sakkāro garukāro ca,"
    },
    {
      "id": "vv5:10.4",
      "pali": "devānaṁ apacitā ahaṁ."
    },
    {
      "id": "vv5:11.1",
      "pali": "Yo ve sammāvimuttānaṁ,"
    },
    {
      "id": "vv5:11.2",
      "pali": "santānaṁ brahmacārinaṁ;"
    },
    {
      "id": "vv5:11.3",
      "pali": "Pasanno āsanaṁ dajjā,"
    },
    {
      "id": "vv5:11.4",
      "pali": "evaṁ nande yathā ahaṁ."
    },
    {
      "id": "vv5:12.1",
      "pali": "Tasmā hi attakāmena,"
    },
    {
      "id": "vv5:12.2",
      "pali": "mahattamabhikaṅkhatā;"
    },
    {
      "id": "vv5:12.3",
      "pali": "Āsanaṁ dātabbaṁ hoti,"
    },
    {
      "id": "vv5:12.4",
      "pali": "sarīrantimadhārinan”ti."
    },
    {
      "id": "vv5:13.1",
      "pali": "Kuñjaravimānaṁ pañcamaṁ."
    }
  ]
}
