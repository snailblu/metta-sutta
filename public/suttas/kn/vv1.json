{
  "uid": "vv1",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "vv1:2.1",
      "pali": "“Pīṭhaṁ te sovaṇṇamayaṁ uḷāraṁ,"
    },
    {
      "id": "vv1:2.2",
      "pali": "Manojavaṁ gacchati yenakāmaṁ;"
    },
    {
      "id": "vv1:2.3",
      "pali": "Alaṅkate malyadhare suvatthe,"
    },
    {
      "id": "vv1:2.4",
      "pali": "Obhāsasi vijjurivabbhakūṭaṁ."
    },
    {
      "id": "vv1:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv1:3.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv1:3.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv1:3.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv1:4.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv1:4.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv1:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv1:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv1:5.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv1:5.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv1:5.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv1:5.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv1:6.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv1:6.2",
      "pali": "Abbhāgatānāsanakaṁ adāsiṁ;"
    },
    {
      "id": "vv1:6.3",
      "pali": "Abhivādayiṁ añjalikaṁ akāsiṁ,"
    },
    {
      "id": "vv1:6.4",
      "pali": "Yathānubhāvañca adāsi dānaṁ."
    },
    {
      "id": "vv1:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv1:7.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv1:7.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv1:7.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv1:8.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv1:8.2",
      "pali": "Manussabhūtā yamakāsi puññaṁ;"
    },
    {
      "id": "vv1:8.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv1:8.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv1:9.1",
      "pali": "Paṭhamapīṭhavimānaṁ paṭhamaṁ."
    }
  ]
}
