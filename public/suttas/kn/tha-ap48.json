{
  "uid": "tha-ap48",
  "title": "Padumacchadaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap48:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap48:1.2",
      "pali": "vipassimhaggapuggale;"
    },
    {
      "id": "tha-ap48:1.3",
      "pali": "Suphullapadumaṁ gayha,"
    },
    {
      "id": "tha-ap48:1.4",
      "pali": "citamāropayiṁ ahaṁ."
    },
    {
      "id": "tha-ap48:2.1",
      "pali": "Āropite ca citake,"
    },
    {
      "id": "tha-ap48:2.2",
      "pali": "vehāsaṁ nabhamuggami;"
    },
    {
      "id": "tha-ap48:2.3",
      "pali": "Ākāse chadanaṁ katvā,"
    },
    {
      "id": "tha-ap48:2.4",
      "pali": "citakamhi adhārayi."
    },
    {
      "id": "tha-ap48:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap48:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap48:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap48:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap48:4.1",
      "pali": "Sattatālīsito kappe,"
    },
    {
      "id": "tha-ap48:4.2",
      "pali": "padumissaranāmako;"
    },
    {
      "id": "tha-ap48:4.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap48:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap48:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap48:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap48:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap48:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumacchadaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap48:7.1",
      "pali": "Padumacchadaniyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
