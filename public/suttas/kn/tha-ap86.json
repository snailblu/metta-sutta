{
  "uid": "tha-ap86",
  "title": "Adhopupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap86:1.1",
      "pali": "“Abhibhū nāma so bhikkhu,"
    },
    {
      "id": "tha-ap86:1.2",
      "pali": "sikhino aggasāvako;"
    },
    {
      "id": "tha-ap86:1.3",
      "pali": "Mahānubhāvo tevijjo,"
    },
    {
      "id": "tha-ap86:1.4",
      "pali": "himavantaṁ upāgami."
    },
    {
      "id": "tha-ap86:2.1",
      "pali": "Ahampi himavantamhi,"
    },
    {
      "id": "tha-ap86:2.2",
      "pali": "ramaṇīyassame isi;"
    },
    {
      "id": "tha-ap86:2.3",
      "pali": "Vasāmi appamaññāsu,"
    },
    {
      "id": "tha-ap86:2.4",
      "pali": "iddhīsu ca tadā vasī."
    },
    {
      "id": "tha-ap86:3.1",
      "pali": "Pakkhijāto viyākāse,"
    },
    {
      "id": "tha-ap86:3.2",
      "pali": "pabbataṁ adhivatthayiṁ;"
    },
    {
      "id": "tha-ap86:3.3",
      "pali": "Adhopupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap86:3.4",
      "pali": "āgacchiṁ pabbataṁ ahaṁ."
    },
    {
      "id": "tha-ap86:4.1",
      "pali": "Satta pupphāni gaṇhitvā,"
    },
    {
      "id": "tha-ap86:4.2",
      "pali": "matthake okiriṁ ahaṁ;"
    },
    {
      "id": "tha-ap86:4.3",
      "pali": "Ālokite ca vīrena,"
    },
    {
      "id": "tha-ap86:4.4",
      "pali": "pakkāmiṁ pācināmukho."
    },
    {
      "id": "tha-ap86:5.1",
      "pali": "Āvāsaṁ abhisambhosiṁ,"
    },
    {
      "id": "tha-ap86:5.2",
      "pali": "patvāna assamaṁ ahaṁ;"
    },
    {
      "id": "tha-ap86:5.3",
      "pali": "Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap86:5.4",
      "pali": "pāyāsiṁ pabbatantaraṁ."
    },
    {
      "id": "tha-ap86:6.1",
      "pali": "Ajagaro maṁ pīḷesi,"
    },
    {
      "id": "tha-ap86:6.2",
      "pali": "ghorarūpo mahabbalo;"
    },
    {
      "id": "tha-ap86:6.3",
      "pali": "Pubbakammaṁ saritvāna,"
    },
    {
      "id": "tha-ap86:6.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap86:7.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap86:7.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap86:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap86:7.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap86:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap86:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap86:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap86:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā adhopupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap86:10.1",
      "pali": "Adhopupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
