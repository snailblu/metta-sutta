{
  "uid": "thi-ap39",
  "title": "9 Ambapālitherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap39:1.1",
      "pali": "“Yo raṁsiphusitāveḷo,"
    },
    {
      "id": "thi-ap39:1.2",
      "pali": "phusso nāma mahāmuni;"
    },
    {
      "id": "thi-ap39:1.3",
      "pali": "Tassāhaṁ bhaginī āsiṁ,"
    },
    {
      "id": "thi-ap39:1.4",
      "pali": "ajāyiṁ khattiye kule."
    },
    {
      "id": "thi-ap39:2.1",
      "pali": "Tassa dhammaṁ suṇitvāhaṁ,"
    },
    {
      "id": "thi-ap39:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "thi-ap39:2.3",
      "pali": "Mahādānaṁ daditvāna,"
    },
    {
      "id": "thi-ap39:2.4",
      "pali": "patthayiṁ rūpasampadaṁ."
    },
    {
      "id": "thi-ap39:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "thi-ap39:3.2",
      "pali": "sikhī lokagganāyako;"
    },
    {
      "id": "thi-ap39:3.3",
      "pali": "Uppanno lokapajjoto,"
    },
    {
      "id": "thi-ap39:3.4",
      "pali": "tilokasaraṇo jino."
    },
    {
      "id": "thi-ap39:4.1",
      "pali": "Tadāruṇapure ramme,"
    },
    {
      "id": "thi-ap39:4.2",
      "pali": "brāhmaññakulasambhavā;"
    },
    {
      "id": "thi-ap39:4.3",
      "pali": "Vimuttacittaṁ kupitā,"
    },
    {
      "id": "thi-ap39:4.4",
      "pali": "bhikkhuniṁ abhisāpayiṁ."
    },
    {
      "id": "thi-ap39:5.1",
      "pali": "‘Vesikāva anācārā’,"
    },
    {
      "id": "thi-ap39:5.2",
      "pali": "jinasāsanadūsikā;"
    },
    {
      "id": "thi-ap39:5.3",
      "pali": "Evaṁ akkosayitvāna,"
    },
    {
      "id": "thi-ap39:5.4",
      "pali": "tena pāpena kammunā."
    },
    {
      "id": "thi-ap39:6.1",
      "pali": "Dāruṇaṁ nirayaṁ gantvā,"
    },
    {
      "id": "thi-ap39:6.2",
      "pali": "mahādukkhasamappitā;"
    },
    {
      "id": "thi-ap39:6.3",
      "pali": "Tato cutā manussesu,"
    },
    {
      "id": "thi-ap39:6.4",
      "pali": "upapannā tapassinī."
    },
    {
      "id": "thi-ap39:7.1",
      "pali": "Dasajātisahassāni,"
    },
    {
      "id": "thi-ap39:7.2",
      "pali": "gaṇikattamakārayiṁ;"
    },
    {
      "id": "thi-ap39:7.3",
      "pali": "Tamhā pāpā na muccissaṁ,"
    },
    {
      "id": "thi-ap39:7.4",
      "pali": "bhutvā duṭṭhavisaṁ yathā."
    },
    {
      "id": "thi-ap39:8.1",
      "pali": "Brahmacariyamasevissaṁ,"
    },
    {
      "id": "thi-ap39:8.2",
      "pali": "kassape jinasāsane;"
    },
    {
      "id": "thi-ap39:8.3",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "thi-ap39:8.4",
      "pali": "ajāyiṁ tidase pure."
    },
    {
      "id": "thi-ap39:9.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap39:9.2",
      "pali": "ahosiṁ opapātikā;"
    },
    {
      "id": "thi-ap39:9.3",
      "pali": "Ambasākhantare jātā,"
    },
    {
      "id": "thi-ap39:9.4",
      "pali": "ambapālīti tenahaṁ."
    },
    {
      "id": "thi-ap39:10.1",
      "pali": "Parivutā pāṇakoṭīhi,"
    },
    {
      "id": "thi-ap39:10.2",
      "pali": "pabbajiṁ jinasāsane;"
    },
    {
      "id": "thi-ap39:10.3",
      "pali": "Pattāhaṁ acalaṁ ṭhānaṁ,"
    },
    {
      "id": "thi-ap39:10.4",
      "pali": "dhītā buddhassa orasā."
    },
    {
      "id": "thi-ap39:11.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap39:11.2",
      "pali": "sotadhātuvisuddhiyā;"
    },
    {
      "id": "thi-ap39:11.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap39:11.4",
      "pali": "vasī homi mahāmuni."
    },
    {
      "id": "thi-ap39:12.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap39:12.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap39:12.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap39:12.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap39:13.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap39:13.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap39:13.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap39:13.4",
      "pali": "buddhaseṭṭhassa vāhasā."
    },
    {
      "id": "thi-ap39:14.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap39:14.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap39:14.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap39:15.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap39:15.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap39:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap39:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap39:16.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap39:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap39:17.1",
      "pali": "Itthaṁ sudaṁ ambapāli bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap39:18.1",
      "pali": "Ambapālitheriyāpadānaṁ navamaṁ."
    }
  ]
}
