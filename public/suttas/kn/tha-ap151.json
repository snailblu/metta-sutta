{
  "uid": "tha-ap151",
  "title": "Vaṭaṁsakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap151:1.1",
      "pali": "“Sumedho nāma nāmena,"
    },
    {
      "id": "tha-ap151:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap151:1.3",
      "pali": "Vivekamanubrūhanto,"
    },
    {
      "id": "tha-ap151:1.4",
      "pali": "ajjhogāhi mahāvanaṁ."
    },
    {
      "id": "tha-ap151:2.1",
      "pali": "Saḷalaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap151:2.2",
      "pali": "ganthitvāna vaṭaṁsakaṁ;"
    },
    {
      "id": "tha-ap151:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap151:2.4",
      "pali": "sammukhā lokanāyakaṁ."
    },
    {
      "id": "tha-ap151:3.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap151:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap151:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap151:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap151:4.1",
      "pali": "Ūnavīse kappasate,"
    },
    {
      "id": "tha-ap151:4.2",
      "pali": "soḷasāsuṁ sunimmitā;"
    },
    {
      "id": "tha-ap151:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap151:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap151:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap151:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap151:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap151:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā vaṭaṁsakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap151:7.1",
      "pali": "Vaṭaṁsakiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
