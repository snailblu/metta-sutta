{
  "uid": "thag5.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.10:1.1",
      "pali": "“Upārambhacitto dummedho,"
    },
    {
      "id": "thag5.10:1.2",
      "pali": "suṇāti jinasāsanaṁ;"
    },
    {
      "id": "thag5.10:1.3",
      "pali": "Ārakā hoti saddhammā,"
    },
    {
      "id": "thag5.10:1.4",
      "pali": "nabhaso pathavī yathā."
    },
    {
      "id": "thag5.10:2.1",
      "pali": "Upārambhacitto dummedho,"
    },
    {
      "id": "thag5.10:2.2",
      "pali": "suṇāti jinasāsanaṁ;"
    },
    {
      "id": "thag5.10:2.3",
      "pali": "Parihāyati saddhammā,"
    },
    {
      "id": "thag5.10:2.4",
      "pali": "kāḷapakkheva candimā."
    },
    {
      "id": "thag5.10:3.1",
      "pali": "Upārambhacitto dummedho,"
    },
    {
      "id": "thag5.10:3.2",
      "pali": "suṇāti jinasāsanaṁ;"
    },
    {
      "id": "thag5.10:3.3",
      "pali": "Parisussati saddhamme,"
    },
    {
      "id": "thag5.10:3.4",
      "pali": "maccho appodake yathā."
    },
    {
      "id": "thag5.10:4.1",
      "pali": "Upārambhacitto dummedho,"
    },
    {
      "id": "thag5.10:4.2",
      "pali": "suṇāti jinasāsanaṁ;"
    },
    {
      "id": "thag5.10:4.3",
      "pali": "Na virūhati saddhamme,"
    },
    {
      "id": "thag5.10:4.4",
      "pali": "khette bījaṁva pūtikaṁ."
    },
    {
      "id": "thag5.10:5.1",
      "pali": "Yo ca tuṭṭhena cittena,"
    },
    {
      "id": "thag5.10:5.2",
      "pali": "suṇāti jinasāsanaṁ;"
    },
    {
      "id": "thag5.10:5.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thag5.10:5.4",
      "pali": "sacchikatvā akuppataṁ;"
    },
    {
      "id": "thag5.10:5.5",
      "pali": "Pappuyya paramaṁ santiṁ,"
    },
    {
      "id": "thag5.10:5.6",
      "pali": "parinibbātināsavo”ti."
    },
    {
      "id": "thag5.10:5.7",
      "pali": "… Yasadatto thero …."
    }
  ]
}
