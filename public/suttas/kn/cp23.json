{
  "uid": "cp23",
  "title": "Nekkhammapāramī 3",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp23:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp23:1.2",
      "pali": "kāsirājassa atrajo;"
    },
    {
      "id": "cp23:1.3",
      "pali": "Ayogharamhi saṁvaḍḍho,"
    },
    {
      "id": "cp23:1.4",
      "pali": "nāmenāsi ayogharo."
    },
    {
      "id": "cp23:2.1",
      "pali": "‘Dukkhena jīvito laddho,"
    },
    {
      "id": "cp23:2.2",
      "pali": "saṁpīḷe patiposito;"
    },
    {
      "id": "cp23:2.3",
      "pali": "Ajjeva putta paṭipajja,"
    },
    {
      "id": "cp23:2.4",
      "pali": "kevalaṁ vasudhaṁ imaṁ’."
    },
    {
      "id": "cp23:3.1",
      "pali": "Saraṭṭhakaṁ sanigamaṁ,"
    },
    {
      "id": "cp23:3.2",
      "pali": "sajanaṁ vanditva khattiyaṁ;"
    },
    {
      "id": "cp23:3.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "cp23:3.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "cp23:4.1",
      "pali": "‘Ye keci mahiyā sattā,"
    },
    {
      "id": "cp23:4.2",
      "pali": "hīnamukkaṭṭhamajjhimā;"
    },
    {
      "id": "cp23:4.3",
      "pali": "Nirārakkhā sake gehe,"
    },
    {
      "id": "cp23:4.4",
      "pali": "vaḍḍhanti sakañātibhi."
    },
    {
      "id": "cp23:5.1",
      "pali": "Idaṁ loke uttariyaṁ,"
    },
    {
      "id": "cp23:5.2",
      "pali": "saṁpīḷe mama posanaṁ;"
    },
    {
      "id": "cp23:5.3",
      "pali": "Ayogharamhi saṁvaḍḍho,"
    },
    {
      "id": "cp23:5.4",
      "pali": "appabhe candasūriye."
    },
    {
      "id": "cp23:6.1",
      "pali": "Pūtikuṇapasampuṇṇā,"
    },
    {
      "id": "cp23:6.2",
      "pali": "muccitvā mātukucchito;"
    },
    {
      "id": "cp23:6.3",
      "pali": "Tato ghoratare dukkhe,"
    },
    {
      "id": "cp23:6.4",
      "pali": "puna pakkhittayoghare."
    },
    {
      "id": "cp23:7.1",
      "pali": "Yadihaṁ tādisaṁ patvā,"
    },
    {
      "id": "cp23:7.2",
      "pali": "dukkhaṁ paramadāruṇaṁ;"
    },
    {
      "id": "cp23:7.3",
      "pali": "Rajjesu yadi rajjāmi,"
    },
    {
      "id": "cp23:7.4",
      "pali": "pāpānaṁ uttamo siyaṁ."
    },
    {
      "id": "cp23:8.1",
      "pali": "Ukkaṇṭhitomhi kāyena,"
    },
    {
      "id": "cp23:8.2",
      "pali": "rajjenamhi anatthiko;"
    },
    {
      "id": "cp23:8.3",
      "pali": "Nibbutiṁ pariyesissaṁ,"
    },
    {
      "id": "cp23:8.4",
      "pali": "yattha maṁ maccu na maddiye’."
    },
    {
      "id": "cp23:9.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "cp23:9.2",
      "pali": "viravante mahājane;"
    },
    {
      "id": "cp23:9.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "cp23:9.4",
      "pali": "pāvisiṁ kānanaṁ vanaṁ."
    },
    {
      "id": "cp23:10.1",
      "pali": "Mātāpitā na me dessā,"
    },
    {
      "id": "cp23:10.2",
      "pali": "napi me dessaṁ mahāyasaṁ;"
    },
    {
      "id": "cp23:10.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp23:10.4",
      "pali": "tasmā rajjaṁ pariccajin”ti."
    },
    {
      "id": "cp23:11.1",
      "pali": "Ayogharacariyaṁ tatiyaṁ."
    }
  ]
}
