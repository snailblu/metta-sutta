{
  "uid": "thag1.24",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.24:1.1",
      "pali": "“Anuvassiko pabbajito,"
    },
    {
      "id": "thag1.24:1.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag1.24:1.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag1.24:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.24:1.5",
      "pali": "… Sugandho thero …."
    }
  ]
}
