{
  "uid": "thag2.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.5:1.1",
      "pali": "“Api ce hoti tevijjo,"
    },
    {
      "id": "thag2.5:1.2",
      "pali": "maccuhāyī anāsavo;"
    },
    {
      "id": "thag2.5:1.3",
      "pali": "Appaññātoti naṁ bālā,"
    },
    {
      "id": "thag2.5:1.4",
      "pali": "avajānanti ajānatā."
    },
    {
      "id": "thag2.5:2.1",
      "pali": "Yo ca kho annapānassa,"
    },
    {
      "id": "thag2.5:2.2",
      "pali": "lābhī hotidha puggalo;"
    },
    {
      "id": "thag2.5:2.3",
      "pali": "Pāpadhammopi ce hoti,"
    },
    {
      "id": "thag2.5:2.4",
      "pali": "so nesaṁ hoti sakkato”ti."
    },
    {
      "id": "thag2.5:2.5",
      "pali": "… Ajino thero …."
    }
  ]
}
