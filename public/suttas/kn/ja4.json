{
  "uid": "ja4",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja4:1.1",
      "pali": "“Appakenapi medhāvī,"
    },
    {
      "id": "ja4:1.2",
      "pali": "pābhatena vicakkhaṇo;"
    },
    {
      "id": "ja4:1.3",
      "pali": "Samuṭṭhāpeti attānaṁ,"
    },
    {
      "id": "ja4:1.4",
      "pali": "aṇuṁ aggiṁva sandhaman”ti."
    },
    {
      "id": "ja4:2.1",
      "pali": "Cūḷaseṭṭhijātakaṁ catutthaṁ."
    }
  ]
}
