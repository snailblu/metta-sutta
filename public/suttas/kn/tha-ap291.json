{
  "uid": "tha-ap291",
  "title": "9 Buddhupaṭṭhāyikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap291:1.1",
      "pali": "“Veṭambhinīti me nāmaṁ,"
    },
    {
      "id": "tha-ap291:1.2",
      "pali": "pitusantaṁ mamaṁ tadā;"
    },
    {
      "id": "tha-ap291:1.3",
      "pali": "Mama hatthaṁ gahetvāna,"
    },
    {
      "id": "tha-ap291:1.4",
      "pali": "upānayi mahāmuniṁ."
    },
    {
      "id": "tha-ap291:2.1",
      "pali": "Imemaṁ uddisissanti,"
    },
    {
      "id": "tha-ap291:2.2",
      "pali": "buddhā lokagganāyakā;"
    },
    {
      "id": "tha-ap291:2.3",
      "pali": "Tehaṁ upaṭṭhiṁ sakkaccaṁ,"
    },
    {
      "id": "tha-ap291:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap291:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap291:3.2",
      "pali": "buddhe upaṭṭhahiṁ tadā;"
    },
    {
      "id": "tha-ap291:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap291:3.4",
      "pali": "upaṭṭhānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap291:4.1",
      "pali": "Tevīsamhi ito kappe,"
    },
    {
      "id": "tha-ap291:4.2",
      "pali": "caturo āsu khattiyā;"
    },
    {
      "id": "tha-ap291:4.3",
      "pali": "Samaṇupaṭṭhākā nāma,"
    },
    {
      "id": "tha-ap291:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap291:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap291:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap291:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap291:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhupaṭṭhāyiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap291:7.1",
      "pali": "Buddhupaṭṭhāyikattherassāpadānaṁ navamaṁ."
    }
  ]
}
