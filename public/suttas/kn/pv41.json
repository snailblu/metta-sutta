{
  "uid": "pv41",
  "title": "6. Kumārapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv41:1.1",
      "pali": "“Sāvatthi nāma nagaraṁ,"
    },
    {
      "id": "pv41:1.2",
      "pali": "himavantassa passato;"
    },
    {
      "id": "pv41:1.3",
      "pali": "Tattha āsuṁ dve kumārā,"
    },
    {
      "id": "pv41:1.4",
      "pali": "rājaputtāti me sutaṁ."
    },
    {
      "id": "pv41:2.1",
      "pali": "Sammattā rajanīyesu,"
    },
    {
      "id": "pv41:2.2",
      "pali": "kāmassādābhinandino;"
    },
    {
      "id": "pv41:2.3",
      "pali": "Paccuppannasukhe giddhā,"
    },
    {
      "id": "pv41:2.4",
      "pali": "na te passiṁsunāgataṁ."
    },
    {
      "id": "pv41:3.1",
      "pali": "Te cutā ca manussattā,"
    },
    {
      "id": "pv41:3.2",
      "pali": "paralokaṁ ito gatā;"
    },
    {
      "id": "pv41:3.3",
      "pali": "Tedha ghosentyadissantā,"
    },
    {
      "id": "pv41:3.4",
      "pali": "pubbe dukkaṭamattano."
    },
    {
      "id": "pv41:4.1",
      "pali": "Bahūsu vata santesu,"
    },
    {
      "id": "pv41:4.2",
      "pali": "deyyadhamme upaṭṭhite;"
    },
    {
      "id": "pv41:4.3",
      "pali": "Nāsakkhimhā ca attānaṁ,"
    },
    {
      "id": "pv41:4.4",
      "pali": "parittaṁ kātuṁ sukhāvahaṁ."
    },
    {
      "id": "pv41:5.1",
      "pali": "Kiṁ tato pāpakaṁ assa,"
    },
    {
      "id": "pv41:5.2",
      "pali": "yaṁ no rājakulā cutā;"
    },
    {
      "id": "pv41:5.3",
      "pali": "Upapannā pettivisayaṁ,"
    },
    {
      "id": "pv41:5.4",
      "pali": "khuppipāsasamappitā."
    },
    {
      "id": "pv41:6.1",
      "pali": "Sāmino idha hutvāna,"
    },
    {
      "id": "pv41:6.2",
      "pali": "honti asāmino tahiṁ;"
    },
    {
      "id": "pv41:6.3",
      "pali": "Bhamanti khuppipāsāya,"
    },
    {
      "id": "pv41:6.4",
      "pali": "manussā unnatonatā."
    },
    {
      "id": "pv41:7.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "pv41:7.2",
      "pali": "issaramadasambhavaṁ;"
    },
    {
      "id": "pv41:7.3",
      "pali": "Pahāya issaramadaṁ,"
    },
    {
      "id": "pv41:7.4",
      "pali": "bhave saggagato naro;"
    },
    {
      "id": "pv41:7.5",
      "pali": "Kāyassa bhedā sappañño,"
    },
    {
      "id": "pv41:7.6",
      "pali": "saggaṁ so upapajjatī”ti."
    },
    {
      "id": "pv41:8.1",
      "pali": "Kumārapetavatthu chaṭṭhaṁ."
    }
  ]
}
