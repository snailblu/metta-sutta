{
  "uid": "tha-ap250",
  "title": "8 Sattalipupphapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap250:1.1",
      "pali": "“Satta sattalipupphāni,"
    },
    {
      "id": "tha-ap250:1.2",
      "pali": "sīse katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap250:1.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap250:1.4",
      "pali": "vessabhumhi naruttame."
    },
    {
      "id": "tha-ap250:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap250:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap250:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap250:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap250:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap250:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap250:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap250:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattalipupphapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap250:5.1",
      "pali": "Sattalipupphapūjakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
