{
  "uid": "cp20",
  "title": "Sīlapāramī 10",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp20:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp20:1.2",
      "pali": "saṅkhapālo mahiddhiko;"
    },
    {
      "id": "cp20:1.3",
      "pali": "Dāṭhāvudho ghoraviso,"
    },
    {
      "id": "cp20:1.4",
      "pali": "dvijivho uragādhibhū."
    },
    {
      "id": "cp20:2.1",
      "pali": "Catuppathe mahāmagge,"
    },
    {
      "id": "cp20:2.2",
      "pali": "nānājanasamākule;"
    },
    {
      "id": "cp20:2.3",
      "pali": "Caturo aṅge adhiṭṭhāya,"
    },
    {
      "id": "cp20:2.4",
      "pali": "tattha vāsamakappayiṁ."
    },
    {
      "id": "cp20:3.1",
      "pali": "Chaviyā cammena maṁsena,"
    },
    {
      "id": "cp20:3.2",
      "pali": "Nahāruaṭṭhikehi vā;"
    },
    {
      "id": "cp20:3.3",
      "pali": "Yassa etena karaṇīyaṁ,"
    },
    {
      "id": "cp20:3.4",
      "pali": "Dinnaṁyeva harātu so."
    },
    {
      "id": "cp20:4.1",
      "pali": "Addasaṁsu bhojaputtā,"
    },
    {
      "id": "cp20:4.2",
      "pali": "kharā luddā akāruṇā;"
    },
    {
      "id": "cp20:4.3",
      "pali": "Upagañchuṁ mamaṁ tattha,"
    },
    {
      "id": "cp20:4.4",
      "pali": "daṇḍamuggarapāṇino."
    },
    {
      "id": "cp20:5.1",
      "pali": "Nāsāya vinivijjhitvā,"
    },
    {
      "id": "cp20:5.2",
      "pali": "naṅguṭṭhe piṭṭhikaṇṭake;"
    },
    {
      "id": "cp20:5.3",
      "pali": "Kāje āropayitvāna,"
    },
    {
      "id": "cp20:5.4",
      "pali": "bhojaputtā hariṁsu maṁ."
    },
    {
      "id": "cp20:6.1",
      "pali": "Sasāgarantaṁ pathaviṁ,"
    },
    {
      "id": "cp20:6.2",
      "pali": "sakānanaṁ sapabbataṁ;"
    },
    {
      "id": "cp20:6.3",
      "pali": "Icchamāno cahaṁ tattha,"
    },
    {
      "id": "cp20:6.4",
      "pali": "nāsāvātena jhāpaye."
    },
    {
      "id": "cp20:7.1",
      "pali": "Sūlehi vinivijjhante,"
    },
    {
      "id": "cp20:7.2",
      "pali": "Koṭṭayantepi sattibhi;"
    },
    {
      "id": "cp20:7.3",
      "pali": "Bhojaputte na kuppāmi,"
    },
    {
      "id": "cp20:7.4",
      "pali": "Esā me sīlapāramī”ti."
    },
    {
      "id": "cp20:8.1",
      "pali": "Saṅkhapālacariyaṁ dasamaṁ."
    },
    {
      "id": "cp20:9.1",
      "pali": "Hatthināgavaggo dutiyo."
    },
    {
      "id": "cp20:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "cp20:11.1",
      "pali": "Hatthināgo bhūridatto,"
    },
    {
      "id": "cp20:11.2",
      "pali": "campeyyo bodhi mahiṁso;"
    },
    {
      "id": "cp20:11.3",
      "pali": "Ruru mātaṅgo dhammo ca,"
    },
    {
      "id": "cp20:11.4",
      "pali": "atrajo ca jayaddiso."
    },
    {
      "id": "cp20:12.1",
      "pali": "Ete nava sīlabalā,"
    },
    {
      "id": "cp20:12.2",
      "pali": "parikkhārā padesikā;"
    },
    {
      "id": "cp20:12.3",
      "pali": "Jīvitaṁ parirakkhitvā,"
    },
    {
      "id": "cp20:12.4",
      "pali": "sīlāni anurakkhisaṁ."
    },
    {
      "id": "cp20:13.1",
      "pali": "Saṅkhapālassa me sato,"
    },
    {
      "id": "cp20:13.2",
      "pali": "sabbakālampi jīvitaṁ;"
    },
    {
      "id": "cp20:13.3",
      "pali": "Yassa kassaci niyyattaṁ,"
    },
    {
      "id": "cp20:13.4",
      "pali": "tasmā sā sīlapāramīti."
    },
    {
      "id": "cp20:14.1",
      "pali": "Sīlapāraminiddeso niṭṭhito."
    }
  ]
}
