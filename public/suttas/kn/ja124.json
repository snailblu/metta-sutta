{
  "uid": "ja124",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja124:1.1",
      "pali": "“Vāyametheva puriso,"
    },
    {
      "id": "ja124:1.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja124:1.3",
      "pali": "Vāyāmassa phalaṁ passa,"
    },
    {
      "id": "ja124:1.4",
      "pali": "bhuttā ambā anītihan”ti."
    },
    {
      "id": "ja124:2.1",
      "pali": "Ambajātakaṁ catutthaṁ."
    }
  ]
}
