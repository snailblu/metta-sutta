{
  "uid": "ja533",
  "title": "Cūḷahaṁsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja533:1.1",
      "pali": "“Sumukha anupacinantā,"
    },
    {
      "id": "ja533:1.2",
      "pali": "pakkamanti vihaṅgamā;"
    },
    {
      "id": "ja533:1.3",
      "pali": "Gaccha tuvampi mā kaṅkhi,"
    },
    {
      "id": "ja533:1.4",
      "pali": "natthi baddhe sahāyatā”."
    },
    {
      "id": "ja533:2.1",
      "pali": "“Gacche vāhaṁ na vā gacche,"
    },
    {
      "id": "ja533:2.2",
      "pali": "na tena amaro siyaṁ;"
    },
    {
      "id": "ja533:2.3",
      "pali": "Sukhitaṁ taṁ upāsitvā,"
    },
    {
      "id": "ja533:2.4",
      "pali": "dukkhitaṁ taṁ kathaṁ jahe."
    },
    {
      "id": "ja533:3.1",
      "pali": "Maraṇaṁ vā tayā saddhiṁ,"
    },
    {
      "id": "ja533:3.2",
      "pali": "jīvitaṁ vā tayā vinā;"
    },
    {
      "id": "ja533:3.3",
      "pali": "Tadeva maraṇaṁ seyyo,"
    },
    {
      "id": "ja533:3.4",
      "pali": "yañce jīve tayā vinā."
    },
    {
      "id": "ja533:4.1",
      "pali": "Nesa dhammo mahārāja,"
    },
    {
      "id": "ja533:4.2",
      "pali": "yaṁ taṁ evaṁ gataṁ jahe;"
    },
    {
      "id": "ja533:4.3",
      "pali": "Yā gati tuyhaṁ sā mayhaṁ,"
    },
    {
      "id": "ja533:4.4",
      "pali": "ruccate vihagādhipa”."
    },
    {
      "id": "ja533:5.1",
      "pali": "“Kā nu pāsena baddhassa,"
    },
    {
      "id": "ja533:5.2",
      "pali": "gati aññā mahānasā;"
    },
    {
      "id": "ja533:5.3",
      "pali": "Sā kathaṁ cetayānassa,"
    },
    {
      "id": "ja533:5.4",
      "pali": "muttassa tava ruccati."
    },
    {
      "id": "ja533:6.1",
      "pali": "Kaṁ vā tvaṁ passase atthaṁ,"
    },
    {
      "id": "ja533:6.2",
      "pali": "mama tuyhañca pakkhima;"
    },
    {
      "id": "ja533:6.3",
      "pali": "Ñātīnaṁ vāvasiṭṭhānaṁ,"
    },
    {
      "id": "ja533:6.4",
      "pali": "ubhinnaṁ jīvitakkhaye."
    },
    {
      "id": "ja533:7.1",
      "pali": "Yaṁ na kañcanadepiñcha,"
    },
    {
      "id": "ja533:7.2",
      "pali": "Andhena tamasā gataṁ;"
    },
    {
      "id": "ja533:7.3",
      "pali": "Tādise sañcajaṁ pāṇaṁ,"
    },
    {
      "id": "ja533:7.4",
      "pali": "Kamatthamabhijotaye”."
    },
    {
      "id": "ja533:8.1",
      "pali": "“Kathaṁ nu patataṁ seṭṭha,"
    },
    {
      "id": "ja533:8.2",
      "pali": "Dhamme atthaṁ na bujjhasi;"
    },
    {
      "id": "ja533:8.3",
      "pali": "Dhammo apacito santo,"
    },
    {
      "id": "ja533:8.4",
      "pali": "Atthaṁ dasseti pāṇinaṁ."
    },
    {
      "id": "ja533:9.1",
      "pali": "Sohaṁ dhammaṁ apekkhāno,"
    },
    {
      "id": "ja533:9.2",
      "pali": "dhammā catthaṁ samuṭṭhitaṁ;"
    },
    {
      "id": "ja533:9.3",
      "pali": "Bhattiñca tayi sampassaṁ,"
    },
    {
      "id": "ja533:9.4",
      "pali": "nāvakaṅkhāmi jīvitaṁ."
    },
    {
      "id": "ja533:10.1",
      "pali": "Addhā eso sataṁ dhammo,"
    },
    {
      "id": "ja533:10.2",
      "pali": "yo mitto mittamāpade;"
    },
    {
      "id": "ja533:10.3",
      "pali": "Na caje jīvitassāpi,"
    },
    {
      "id": "ja533:10.4",
      "pali": "hetudhammamanussaraṁ”."
    },
    {
      "id": "ja533:11.1",
      "pali": "“Svāyaṁ dhammo ca te ciṇṇo,"
    },
    {
      "id": "ja533:11.2",
      "pali": "bhatti ca viditā mayi;"
    },
    {
      "id": "ja533:11.3",
      "pali": "Kāmaṁ karassu mayhetaṁ,"
    },
    {
      "id": "ja533:11.4",
      "pali": "gacchevānumato mayā."
    },
    {
      "id": "ja533:12.1",
      "pali": "Api tvevaṁ gate kāle,"
    },
    {
      "id": "ja533:12.2",
      "pali": "yaṁ khaṇḍaṁ ñātinaṁ mayā;"
    },
    {
      "id": "ja533:12.3",
      "pali": "Tayā taṁ buddhisampannaṁ,"
    },
    {
      "id": "ja533:12.4",
      "pali": "assa paramasaṁvutaṁ”."
    },
    {
      "id": "ja533:13.1",
      "pali": "Iccevaṁ mantayantānaṁ,"
    },
    {
      "id": "ja533:13.2",
      "pali": "Ariyānaṁ ariyavuttinaṁ;"
    },
    {
      "id": "ja533:13.3",
      "pali": "Paccadissatha nesādo,"
    },
    {
      "id": "ja533:13.4",
      "pali": "Āturānamivantako."
    },
    {
      "id": "ja533:14.1",
      "pali": "Te sattumabhisañcikkha,"
    },
    {
      "id": "ja533:14.2",
      "pali": "dīgharattaṁ hitā dijā;"
    },
    {
      "id": "ja533:14.3",
      "pali": "Tuṇhīmāsittha ubhayo,"
    },
    {
      "id": "ja533:14.4",
      "pali": "na sañcalesumāsanā."
    },
    {
      "id": "ja533:15.1",
      "pali": "Dhataraṭṭhe ca disvāna,"
    },
    {
      "id": "ja533:15.2",
      "pali": "samuḍḍente tato tato;"
    },
    {
      "id": "ja533:15.3",
      "pali": "Abhikkamatha vegena,"
    },
    {
      "id": "ja533:15.4",
      "pali": "dijasattu dijādhipe."
    },
    {
      "id": "ja533:16.1",
      "pali": "So ca vegenabhikkamma,"
    },
    {
      "id": "ja533:16.2",
      "pali": "āsajja parame dije;"
    },
    {
      "id": "ja533:16.3",
      "pali": "Paccakamittha nesādo,"
    },
    {
      "id": "ja533:16.4",
      "pali": "baddhā iti vicintayaṁ."
    },
    {
      "id": "ja533:17.1",
      "pali": "Ekaṁva baddhamāsīnaṁ,"
    },
    {
      "id": "ja533:17.2",
      "pali": "abaddhañca punāparaṁ;"
    },
    {
      "id": "ja533:17.3",
      "pali": "Āsajja baddhamāsīnaṁ,"
    },
    {
      "id": "ja533:17.4",
      "pali": "pekkhamānamadīnavaṁ."
    },
    {
      "id": "ja533:18.1",
      "pali": "Tato so vimatoyeva,"
    },
    {
      "id": "ja533:18.2",
      "pali": "paṇḍare ajjhabhāsatha;"
    },
    {
      "id": "ja533:18.3",
      "pali": "Pavaḍḍhakāye āsīne,"
    },
    {
      "id": "ja533:18.4",
      "pali": "dijasaṅghagaṇādhipe."
    },
    {
      "id": "ja533:19.1",
      "pali": "“Yannu pāsena mahatā,"
    },
    {
      "id": "ja533:19.2",
      "pali": "baddho na kurute disaṁ;"
    },
    {
      "id": "ja533:19.3",
      "pali": "Atha kasmā abaddho tvaṁ,"
    },
    {
      "id": "ja533:19.4",
      "pali": "balī pakkhi na gacchasi."
    },
    {
      "id": "ja533:20.1",
      "pali": "Kiṁ nu tyāyaṁ dijo hoti,"
    },
    {
      "id": "ja533:20.2",
      "pali": "mutto baddhaṁ upāsasi;"
    },
    {
      "id": "ja533:20.3",
      "pali": "Ohāya sakuṇā yanti,"
    },
    {
      "id": "ja533:20.4",
      "pali": "kiṁ eko avahīyasi”."
    },
    {
      "id": "ja533:21.1",
      "pali": "“Rājā me so dijāmitta,"
    },
    {
      "id": "ja533:21.2",
      "pali": "sakhā pāṇasamo ca me;"
    },
    {
      "id": "ja533:21.3",
      "pali": "Neva naṁ vijahissāmi,"
    },
    {
      "id": "ja533:21.4",
      "pali": "yāva kālassa pariyāyaṁ”."
    },
    {
      "id": "ja533:22.1",
      "pali": "“Kathaṁ panāyaṁ vihaṅgo,"
    },
    {
      "id": "ja533:22.2",
      "pali": "nāddasa pāsamoḍḍitaṁ;"
    },
    {
      "id": "ja533:22.3",
      "pali": "Padañhetaṁ mahantānaṁ,"
    },
    {
      "id": "ja533:22.4",
      "pali": "boddhumarahanti āpadaṁ”."
    },
    {
      "id": "ja533:23.1",
      "pali": "“Yadā parābhavo hoti,"
    },
    {
      "id": "ja533:23.2",
      "pali": "poso jīvitasaṅkhaye;"
    },
    {
      "id": "ja533:23.3",
      "pali": "Atha jālañca pāsañca,"
    },
    {
      "id": "ja533:23.4",
      "pali": "āsajjāpi na bujjhati."
    },
    {
      "id": "ja533:24.1",
      "pali": "Api tveva mahāpañña,"
    },
    {
      "id": "ja533:24.2",
      "pali": "pāsā bahuvidhā tatā;"
    },
    {
      "id": "ja533:24.3",
      "pali": "Guyhamāsajja bajjhanti,"
    },
    {
      "id": "ja533:24.4",
      "pali": "athevaṁ jīvitakkhaye”."
    },
    {
      "id": "ja533:25.1",
      "pali": "“Api nāyaṁ tayā saddhiṁ,"
    },
    {
      "id": "ja533:25.2",
      "pali": "saṁvāsassa sukhudrayo;"
    },
    {
      "id": "ja533:25.3",
      "pali": "Api no anumaññāsi,"
    },
    {
      "id": "ja533:25.4",
      "pali": "api no jīvitaṁ dade”."
    },
    {
      "id": "ja533:26.1",
      "pali": "“Na ceva me tvaṁ baddhosi,"
    },
    {
      "id": "ja533:26.2",
      "pali": "napi icchāmi te vadhaṁ;"
    },
    {
      "id": "ja533:26.3",
      "pali": "Kāmaṁ khippamito gantvā,"
    },
    {
      "id": "ja533:26.4",
      "pali": "jīva tvaṁ anigho ciraṁ”."
    },
    {
      "id": "ja533:27.1",
      "pali": "“Nevāhametamicchāmi,"
    },
    {
      "id": "ja533:27.2",
      "pali": "aññatretassa jīvitā;"
    },
    {
      "id": "ja533:27.3",
      "pali": "Sace ekena tuṭṭhosi,"
    },
    {
      "id": "ja533:27.4",
      "pali": "muñcetaṁ mañca bhakkhaya."
    },
    {
      "id": "ja533:28.1",
      "pali": "Ārohapariṇāhena,"
    },
    {
      "id": "ja533:28.2",
      "pali": "tulyāsmā vayasā ubho;"
    },
    {
      "id": "ja533:28.3",
      "pali": "Na te lābhena jīvatthi,"
    },
    {
      "id": "ja533:28.4",
      "pali": "etena niminā tuvaṁ."
    },
    {
      "id": "ja533:29.1",
      "pali": "Tadiṅgha samapekkhassu,"
    },
    {
      "id": "ja533:29.2",
      "pali": "hotu giddhi tavamhasu;"
    },
    {
      "id": "ja533:29.3",
      "pali": "Maṁ pubbe bandha pāsena,"
    },
    {
      "id": "ja533:29.4",
      "pali": "pacchā muñca dijādhipaṁ."
    },
    {
      "id": "ja533:30.1",
      "pali": "Tāvadeva ca te lābho,"
    },
    {
      "id": "ja533:30.2",
      "pali": "katāssa yācanāya ca;"
    },
    {
      "id": "ja533:30.3",
      "pali": "Mitti ca dhataraṭṭhehi,"
    },
    {
      "id": "ja533:30.4",
      "pali": "yāvajīvāya te siyā”."
    },
    {
      "id": "ja533:31.1",
      "pali": "“Passantu no mahāsaṅghā,"
    },
    {
      "id": "ja533:31.2",
      "pali": "tayā muttaṁ ito gataṁ;"
    },
    {
      "id": "ja533:31.3",
      "pali": "Mittāmaccā ca bhaccā ca,"
    },
    {
      "id": "ja533:31.4",
      "pali": "puttadārā ca bandhavā."
    },
    {
      "id": "ja533:32.1",
      "pali": "Na ca te tādisā mittā,"
    },
    {
      "id": "ja533:32.2",
      "pali": "bahūnaṁ idha vijjati;"
    },
    {
      "id": "ja533:32.3",
      "pali": "Yathā tvaṁ dhataraṭṭhassa,"
    },
    {
      "id": "ja533:32.4",
      "pali": "pāṇasādhāraṇo sakhā."
    },
    {
      "id": "ja533:33.1",
      "pali": "So te sahāyaṁ muñcāmi,"
    },
    {
      "id": "ja533:33.2",
      "pali": "hotu rājā tavānugo;"
    },
    {
      "id": "ja533:33.3",
      "pali": "Kāmaṁ khippamito gantvā,"
    },
    {
      "id": "ja533:33.4",
      "pali": "ñātimajjhe virocatha”."
    },
    {
      "id": "ja533:34.1",
      "pali": "“So patīto pamuttena,"
    },
    {
      "id": "ja533:34.2",
      "pali": "bhattunā bhattugāravo;"
    },
    {
      "id": "ja533:34.3",
      "pali": "Ajjhabhāsatha vakkaṅgo,"
    },
    {
      "id": "ja533:34.4",
      "pali": "vācaṁ kaṇṇasukhaṁ bhaṇaṁ."
    },
    {
      "id": "ja533:35.1",
      "pali": "Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja533:35.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja533:35.3",
      "pali": "Yathāhamajja nandāmi,"
    },
    {
      "id": "ja533:35.4",
      "pali": "muttaṁ disvā dijādhipaṁ”."
    },
    {
      "id": "ja533:36.1",
      "pali": "“Ehi taṁ anusikkhāmi,"
    },
    {
      "id": "ja533:36.2",
      "pali": "Yathā tvamapi lacchase;"
    },
    {
      "id": "ja533:36.3",
      "pali": "Lābhaṁ tavāyaṁ dhataraṭṭho,"
    },
    {
      "id": "ja533:36.4",
      "pali": "Pāpaṁ kiñci na dakkhati."
    },
    {
      "id": "ja533:37.1",
      "pali": "Khippamantepuraṁ netvā,"
    },
    {
      "id": "ja533:37.2",
      "pali": "rañño dassehi no ubho;"
    },
    {
      "id": "ja533:37.3",
      "pali": "Abaddhe pakatibhūte,"
    },
    {
      "id": "ja533:37.4",
      "pali": "kāje ubhayato ṭhite."
    },
    {
      "id": "ja533:38.1",
      "pali": "Dhataraṭṭhā mahārāja,"
    },
    {
      "id": "ja533:38.2",
      "pali": "haṁsādhipatino ime;"
    },
    {
      "id": "ja533:38.3",
      "pali": "Ayañhi rājā haṁsānaṁ,"
    },
    {
      "id": "ja533:38.4",
      "pali": "ayaṁ senāpatītaro."
    },
    {
      "id": "ja533:39.1",
      "pali": "Asaṁsayaṁ imaṁ disvā,"
    },
    {
      "id": "ja533:39.2",
      "pali": "haṁsarājaṁ narādhipo;"
    },
    {
      "id": "ja533:39.3",
      "pali": "Patīto sumano vitto,"
    },
    {
      "id": "ja533:39.4",
      "pali": "bahuṁ dassati te dhanaṁ”."
    },
    {
      "id": "ja533:40.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja533:40.2",
      "pali": "kammunā upapādayi;"
    },
    {
      "id": "ja533:40.3",
      "pali": "Khippamantepuraṁ gantvā,"
    },
    {
      "id": "ja533:40.4",
      "pali": "rañño haṁse adassayi;"
    },
    {
      "id": "ja533:40.5",
      "pali": "Abaddhe pakatibhūte,"
    },
    {
      "id": "ja533:40.6",
      "pali": "kāje ubhayato ṭhite."
    },
    {
      "id": "ja533:41.1",
      "pali": "“Dhataraṭṭhā mahārāja,"
    },
    {
      "id": "ja533:41.2",
      "pali": "haṁsādhipatino ime;"
    },
    {
      "id": "ja533:41.3",
      "pali": "Ayañhi rājā haṁsānaṁ,"
    },
    {
      "id": "ja533:41.4",
      "pali": "ayaṁ senāpatītaro”."
    },
    {
      "id": "ja533:42.1",
      "pali": "“Kathaṁ panime vihaṅgā,"
    },
    {
      "id": "ja533:42.2",
      "pali": "tava hatthattamāgatā;"
    },
    {
      "id": "ja533:42.3",
      "pali": "Kathaṁ luddo mahantānaṁ,"
    },
    {
      "id": "ja533:42.4",
      "pali": "issare idha ajjhagā”."
    },
    {
      "id": "ja533:43.1",
      "pali": "“Vihitā santime pāsā,"
    },
    {
      "id": "ja533:43.2",
      "pali": "pallalesu janādhipa;"
    },
    {
      "id": "ja533:43.3",
      "pali": "Yaṁ yadāyatanaṁ maññe,"
    },
    {
      "id": "ja533:43.4",
      "pali": "dijānaṁ pāṇarodhanaṁ."
    },
    {
      "id": "ja533:44.1",
      "pali": "Tādisaṁ pāsamāsajja,"
    },
    {
      "id": "ja533:44.2",
      "pali": "haṁsarājā abajjhatha;"
    },
    {
      "id": "ja533:44.3",
      "pali": "Taṁ abaddho upāsīno,"
    },
    {
      "id": "ja533:44.4",
      "pali": "mamāyaṁ ajjhabhāsatha."
    },
    {
      "id": "ja533:45.1",
      "pali": "Sudukkaraṁ anariyehi,"
    },
    {
      "id": "ja533:45.2",
      "pali": "dahate bhāvamuttamaṁ;"
    },
    {
      "id": "ja533:45.3",
      "pali": "Bhatturatthe parakkanto,"
    },
    {
      "id": "ja533:45.4",
      "pali": "dhammayutto vihaṅgamo."
    },
    {
      "id": "ja533:46.1",
      "pali": "Attanāyaṁ cajitvāna,"
    },
    {
      "id": "ja533:46.2",
      "pali": "jīvitaṁ jīvitāraho;"
    },
    {
      "id": "ja533:46.3",
      "pali": "Anutthunanto āsīno,"
    },
    {
      "id": "ja533:46.4",
      "pali": "bhattu yācittha jīvitaṁ."
    },
    {
      "id": "ja533:47.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja533:47.2",
      "pali": "pasādamahamajjhagā;"
    },
    {
      "id": "ja533:47.3",
      "pali": "Tato naṁ pāmuciṁ pāsā,"
    },
    {
      "id": "ja533:47.4",
      "pali": "anuññāsiṁ sukhena ca."
    },
    {
      "id": "ja533:48.1",
      "pali": "So patīto pamuttena,"
    },
    {
      "id": "ja533:48.2",
      "pali": "bhattunā bhattugāravo;"
    },
    {
      "id": "ja533:48.3",
      "pali": "Ajjhabhāsatha vakkaṅgo,"
    },
    {
      "id": "ja533:48.4",
      "pali": "vācaṁ kaṇṇasukhaṁ bhaṇaṁ."
    },
    {
      "id": "ja533:49.1",
      "pali": "‘Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja533:49.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja533:49.3",
      "pali": "Yathāhamajja nandāmi,"
    },
    {
      "id": "ja533:49.4",
      "pali": "muttaṁ disvā dijādhipaṁ."
    },
    {
      "id": "ja533:50.1",
      "pali": "Ehi taṁ anusikkhāmi,"
    },
    {
      "id": "ja533:50.2",
      "pali": "yathā tvamapi lacchase;"
    },
    {
      "id": "ja533:50.3",
      "pali": "Lābhaṁ tavāyaṁ dhataraṭṭho,"
    },
    {
      "id": "ja533:50.4",
      "pali": "pāpaṁ kiñci na dakkhati."
    },
    {
      "id": "ja533:51.1",
      "pali": "Khippamantepuraṁ netvā,"
    },
    {
      "id": "ja533:51.2",
      "pali": "rañño dassehi no ubho;"
    },
    {
      "id": "ja533:51.3",
      "pali": "Abaddhe pakatibhūte,"
    },
    {
      "id": "ja533:51.4",
      "pali": "kāje ubhayato ṭhite."
    },
    {
      "id": "ja533:52.1",
      "pali": "“Dhataraṭṭhā mahārāja,"
    },
    {
      "id": "ja533:52.2",
      "pali": "haṁsādhipatino ime;"
    },
    {
      "id": "ja533:52.3",
      "pali": "Ayañhi rājā haṁsānaṁ,"
    },
    {
      "id": "ja533:52.4",
      "pali": "ayaṁ senāpatītaro”."
    },
    {
      "id": "ja533:53.1",
      "pali": "Asaṁsayaṁ imaṁ disvā,"
    },
    {
      "id": "ja533:53.2",
      "pali": "haṁsarājaṁ narādhipo;"
    },
    {
      "id": "ja533:53.3",
      "pali": "Patīto sumano vitto,"
    },
    {
      "id": "ja533:53.4",
      "pali": "bahuṁ dassati te dhanaṁ’."
    },
    {
      "id": "ja533:54.1",
      "pali": "Evametassa vacanā,"
    },
    {
      "id": "ja533:54.2",
      "pali": "ānītāme ubho mayā;"
    },
    {
      "id": "ja533:54.3",
      "pali": "Ettheva hi ime āsuṁ,"
    },
    {
      "id": "ja533:54.4",
      "pali": "ubho anumatā mayā."
    },
    {
      "id": "ja533:55.1",
      "pali": "Soyaṁ evaṁ gato pakkhī,"
    },
    {
      "id": "ja533:55.2",
      "pali": "dijo paramadhammiko;"
    },
    {
      "id": "ja533:55.3",
      "pali": "Mādisassa hi luddassa,"
    },
    {
      "id": "ja533:55.4",
      "pali": "janayeyyātha maddavaṁ."
    },
    {
      "id": "ja533:56.1",
      "pali": "Upāyanañca te deva,"
    },
    {
      "id": "ja533:56.2",
      "pali": "nāññaṁ passāmi edisaṁ;"
    },
    {
      "id": "ja533:56.3",
      "pali": "Sabbasākuṇikāgāme,"
    },
    {
      "id": "ja533:56.4",
      "pali": "taṁ passa manujādhipa”."
    },
    {
      "id": "ja533:57.1",
      "pali": "Disvā nisinnaṁ rājānaṁ,"
    },
    {
      "id": "ja533:57.2",
      "pali": "pīṭhe sovaṇṇaye subhe;"
    },
    {
      "id": "ja533:57.3",
      "pali": "Ajjhabhāsatha vakkaṅgo,"
    },
    {
      "id": "ja533:57.4",
      "pali": "vācaṁ kaṇṇasukhaṁ bhaṇaṁ."
    },
    {
      "id": "ja533:58.1",
      "pali": "“Kaccinnu bhoto kusalaṁ,"
    },
    {
      "id": "ja533:58.2",
      "pali": "kacci bhoto anāmayaṁ;"
    },
    {
      "id": "ja533:58.3",
      "pali": "Kacci raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja533:58.4",
      "pali": "dhammena manusāsasi”."
    },
    {
      "id": "ja533:59.1",
      "pali": "“Kusalañceva me haṁsa,"
    },
    {
      "id": "ja533:59.2",
      "pali": "Atho haṁsa anāmayaṁ;"
    },
    {
      "id": "ja533:59.3",
      "pali": "Atho raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja533:59.4",
      "pali": "Dhammena manusāsahaṁ”."
    },
    {
      "id": "ja533:60.1",
      "pali": "“Kacci bhoto amaccesu,"
    },
    {
      "id": "ja533:60.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja533:60.3",
      "pali": "Kacci ca te tavatthesu,"
    },
    {
      "id": "ja533:60.4",
      "pali": "nāvakaṅkhanti jīvitaṁ”."
    },
    {
      "id": "ja533:61.1",
      "pali": "“Athopi me amaccesu,"
    },
    {
      "id": "ja533:61.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja533:61.3",
      "pali": "Athopi te mamatthesu,"
    },
    {
      "id": "ja533:61.4",
      "pali": "nāvakaṅkhanti jīvitaṁ”."
    },
    {
      "id": "ja533:62.1",
      "pali": "“Kacci te sādisī bhariyā,"
    },
    {
      "id": "ja533:62.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja533:62.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja533:62.4",
      "pali": "tava chandavasānugā”."
    },
    {
      "id": "ja533:63.1",
      "pali": "“Atho me sādisī bhariyā,"
    },
    {
      "id": "ja533:63.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja533:63.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja533:63.4",
      "pali": "mama chandavasānugā."
    },
    {
      "id": "ja533:64.1",
      "pali": "Bhavantaṁ kacci nu mahā-"
    },
    {
      "id": "ja533:64.2",
      "pali": "sattuhatthattataṁ gato;"
    },
    {
      "id": "ja533:64.3",
      "pali": "Dukkhamāpajji vipulaṁ,"
    },
    {
      "id": "ja533:64.4",
      "pali": "tasmiṁ paṭhamamāpade."
    },
    {
      "id": "ja533:65.1",
      "pali": "Kacci yantāpatitvāna,"
    },
    {
      "id": "ja533:65.2",
      "pali": "daṇḍena samapothayi;"
    },
    {
      "id": "ja533:65.3",
      "pali": "Evametesaṁ jammānaṁ,"
    },
    {
      "id": "ja533:65.4",
      "pali": "pātikaṁ bhavati tāvade”."
    },
    {
      "id": "ja533:66.1",
      "pali": "“Khemamāsi mahārāja,"
    },
    {
      "id": "ja533:66.2",
      "pali": "evamāpadiyā sati;"
    },
    {
      "id": "ja533:66.3",
      "pali": "Na cāyaṁ kiñci rasmāsu,"
    },
    {
      "id": "ja533:66.4",
      "pali": "sattūva samapajjatha."
    },
    {
      "id": "ja533:67.1",
      "pali": "Paccagamittha nesādo,"
    },
    {
      "id": "ja533:67.2",
      "pali": "pubbeva ajjhabhāsatha;"
    },
    {
      "id": "ja533:67.3",
      "pali": "Tadāyaṁ sumukhoyeva,"
    },
    {
      "id": "ja533:67.4",
      "pali": "paṇḍito paccabhāsatha."
    },
    {
      "id": "ja533:68.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja533:68.2",
      "pali": "pasādamayamajjhagā;"
    },
    {
      "id": "ja533:68.3",
      "pali": "Tato maṁ pāmucī pāsā,"
    },
    {
      "id": "ja533:68.4",
      "pali": "anuññāsi sukhena ca."
    },
    {
      "id": "ja533:69.1",
      "pali": "Idañca sumukheneva,"
    },
    {
      "id": "ja533:69.2",
      "pali": "etadatthāya cintitaṁ;"
    },
    {
      "id": "ja533:69.3",
      "pali": "Bhoto sakāsegamanaṁ,"
    },
    {
      "id": "ja533:69.4",
      "pali": "etassa dhanamicchatā”."
    },
    {
      "id": "ja533:70.1",
      "pali": "“Svāgatañcevidaṁ bhavataṁ,"
    },
    {
      "id": "ja533:70.2",
      "pali": "patīto casmi dassanā;"
    },
    {
      "id": "ja533:70.3",
      "pali": "Eso cāpi bahuṁ vittaṁ,"
    },
    {
      "id": "ja533:70.4",
      "pali": "labhataṁ yāvadicchati”."
    },
    {
      "id": "ja533:71.1",
      "pali": "Santappayitvā nesādaṁ,"
    },
    {
      "id": "ja533:71.2",
      "pali": "bhogehi manujādhipo;"
    },
    {
      "id": "ja533:71.3",
      "pali": "Ajjhabhāsatha vakkaṅgaṁ,"
    },
    {
      "id": "ja533:71.4",
      "pali": "vācaṁ kaṇṇasukhaṁ bhaṇaṁ."
    },
    {
      "id": "ja533:72.1",
      "pali": "“Yaṁ khalu dhammamādhīnaṁ,"
    },
    {
      "id": "ja533:72.2",
      "pali": "vaso vattati kiñcanaṁ;"
    },
    {
      "id": "ja533:72.3",
      "pali": "Sabbatthissariyaṁ tava,"
    },
    {
      "id": "ja533:72.4",
      "pali": "taṁ pasāsa yadicchatha."
    },
    {
      "id": "ja533:73.1",
      "pali": "Dānatthaṁ upabhottuṁ vā,"
    },
    {
      "id": "ja533:73.2",
      "pali": "yaṁ caññaṁ upakappati;"
    },
    {
      "id": "ja533:73.3",
      "pali": "Etaṁ dadāmi vo vittaṁ,"
    },
    {
      "id": "ja533:73.4",
      "pali": "issariyaṁ vissajāmi vo”."
    },
    {
      "id": "ja533:74.1",
      "pali": "“Yathā ca myāyaṁ sumukho,"
    },
    {
      "id": "ja533:74.2",
      "pali": "ajjhabhāseyya paṇḍito;"
    },
    {
      "id": "ja533:74.3",
      "pali": "Kāmasā buddhisampanno,"
    },
    {
      "id": "ja533:74.4",
      "pali": "taṁ myāssa paramappiyaṁ”."
    },
    {
      "id": "ja533:75.1",
      "pali": "“Ahaṁ khalu mahārāja,"
    },
    {
      "id": "ja533:75.2",
      "pali": "nāgarājārivantaraṁ;"
    },
    {
      "id": "ja533:75.3",
      "pali": "Paṭivattuṁ na sakkomi,"
    },
    {
      "id": "ja533:75.4",
      "pali": "na me so vinayo siyā."
    },
    {
      "id": "ja533:76.1",
      "pali": "Amhākañceva so seṭṭho,"
    },
    {
      "id": "ja533:76.2",
      "pali": "tvañca uttamasattavo;"
    },
    {
      "id": "ja533:76.3",
      "pali": "Bhūmipālo manussindo,"
    },
    {
      "id": "ja533:76.4",
      "pali": "pūjā bahūhi hetuhi."
    },
    {
      "id": "ja533:77.1",
      "pali": "Tesaṁ ubhinnaṁ bhaṇataṁ,"
    },
    {
      "id": "ja533:77.2",
      "pali": "vattamāne vinicchaye;"
    },
    {
      "id": "ja533:77.3",
      "pali": "Nantaraṁ paṭivattabbaṁ,"
    },
    {
      "id": "ja533:77.4",
      "pali": "pessena manujādhipa”."
    },
    {
      "id": "ja533:78.1",
      "pali": "“Dhammena kira nesādo,"
    },
    {
      "id": "ja533:78.2",
      "pali": "paṇḍito aṇḍajo iti;"
    },
    {
      "id": "ja533:78.3",
      "pali": "Na heva akatattassa,"
    },
    {
      "id": "ja533:78.4",
      "pali": "nayo etādiso siyā."
    },
    {
      "id": "ja533:79.1",
      "pali": "Evaṁ aggapakatimā,"
    },
    {
      "id": "ja533:79.2",
      "pali": "evaṁ uttamasattavo;"
    },
    {
      "id": "ja533:79.3",
      "pali": "Yāvatatthi mayā diṭṭhā,"
    },
    {
      "id": "ja533:79.4",
      "pali": "nāññaṁ passāmi edisaṁ."
    },
    {
      "id": "ja533:80.1",
      "pali": "Tuṭṭhosmi vo pakatiyā,"
    },
    {
      "id": "ja533:80.2",
      "pali": "vākyena madhurena ca;"
    },
    {
      "id": "ja533:80.3",
      "pali": "Eso cāpi mamacchando,"
    },
    {
      "id": "ja533:80.4",
      "pali": "ciraṁ passeyya vo ubho”."
    },
    {
      "id": "ja533:81.1",
      "pali": "“Yaṁ kiccaṁ parame mitte,"
    },
    {
      "id": "ja533:81.2",
      "pali": "katamasmāsu taṁ tayā;"
    },
    {
      "id": "ja533:81.3",
      "pali": "Pattā nissaṁsayaṁ tyāmhā,"
    },
    {
      "id": "ja533:81.4",
      "pali": "bhattirasmāsu yā tava."
    },
    {
      "id": "ja533:82.1",
      "pali": "Aduñca nūna sumahā,"
    },
    {
      "id": "ja533:82.2",
      "pali": "ñātisaṅghassa mantaraṁ;"
    },
    {
      "id": "ja533:82.3",
      "pali": "Adassanena asmākaṁ,"
    },
    {
      "id": "ja533:82.4",
      "pali": "dukkhaṁ bahūsu pakkhisu."
    },
    {
      "id": "ja533:83.1",
      "pali": "Tesaṁ sokavighātāya,"
    },
    {
      "id": "ja533:83.2",
      "pali": "Tayā anumatā mayaṁ;"
    },
    {
      "id": "ja533:83.3",
      "pali": "Taṁ padakkhiṇato katvā,"
    },
    {
      "id": "ja533:83.4",
      "pali": "Ñātiṁ passemurindama."
    },
    {
      "id": "ja533:84.1",
      "pali": "Addhāhaṁ vipulaṁ pītiṁ,"
    },
    {
      "id": "ja533:84.2",
      "pali": "bhavataṁ vindāmi dassanā;"
    },
    {
      "id": "ja533:84.3",
      "pali": "Eso cāpi mahā attho,"
    },
    {
      "id": "ja533:84.4",
      "pali": "ñātivissāsanā siyā”."
    },
    {
      "id": "ja533:85.1",
      "pali": "Idaṁ vatvā dhataraṭṭho,"
    },
    {
      "id": "ja533:85.2",
      "pali": "haṁsarājā narādhipaṁ;"
    },
    {
      "id": "ja533:85.3",
      "pali": "Uttamaṁ javamanvāya,"
    },
    {
      "id": "ja533:85.4",
      "pali": "ñātisaṅghaṁ upāgamuṁ."
    },
    {
      "id": "ja533:86.1",
      "pali": "Te aroge anuppatte,"
    },
    {
      "id": "ja533:86.2",
      "pali": "disvāna parame dije;"
    },
    {
      "id": "ja533:86.3",
      "pali": "Kekāti makaruṁ haṁsā,"
    },
    {
      "id": "ja533:86.4",
      "pali": "puthusaddo ajāyatha."
    },
    {
      "id": "ja533:87.1",
      "pali": "Te patītā pamuttena,"
    },
    {
      "id": "ja533:87.2",
      "pali": "bhattunā bhattugāravā;"
    },
    {
      "id": "ja533:87.3",
      "pali": "Samantā parikiriṁsu,"
    },
    {
      "id": "ja533:87.4",
      "pali": "aṇḍajā laddhapaccayā."
    },
    {
      "id": "ja533:88.1",
      "pali": "Evaṁ mittavataṁ atthā,"
    },
    {
      "id": "ja533:88.2",
      "pali": "sabbe honti padakkhiṇā;"
    },
    {
      "id": "ja533:88.3",
      "pali": "Haṁsā yathā dhataraṭṭhā,"
    },
    {
      "id": "ja533:88.4",
      "pali": "ñātisaṅghaṁ upāgamunti."
    },
    {
      "id": "ja533:89.1",
      "pali": "Cūḷahaṁsajātakaṁ paṭhamaṁ."
    }
  ]
}
