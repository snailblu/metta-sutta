{
  "uid": "ja246",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja246:1.1",
      "pali": "“Hantvā chetvā vadhitvā ca,"
    },
    {
      "id": "ja246:1.2",
      "pali": "deti dānaṁ asaññato;"
    },
    {
      "id": "ja246:1.3",
      "pali": "Edisaṁ bhattaṁ bhuñjamāno,"
    },
    {
      "id": "ja246:1.4",
      "pali": "sa pāpena upalippati”."
    },
    {
      "id": "ja246:2.1",
      "pali": "“Puttadārampi ce hantvā,"
    },
    {
      "id": "ja246:2.2",
      "pali": "Deti dānaṁ asaññato;"
    },
    {
      "id": "ja246:2.3",
      "pali": "Bhuñjamānopi sappañño,"
    },
    {
      "id": "ja246:2.4",
      "pali": "Na pāpena upalippatī”ti."
    },
    {
      "id": "ja246:3.1",
      "pali": "Bālovādajātakaṁ chaṭṭhaṁ."
    }
  ]
}
