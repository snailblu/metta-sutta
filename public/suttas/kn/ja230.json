{
  "uid": "ja230",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja230:1.1",
      "pali": "“Dhajamaparimitaṁ anantapāraṁ,"
    },
    {
      "id": "ja230:1.2",
      "pali": "Duppasahaṁ dhaṅkehi sāgaraṁva;"
    },
    {
      "id": "ja230:1.3",
      "pali": "Girimiva anilena duppasayho,"
    },
    {
      "id": "ja230:1.4",
      "pali": "Duppasaho ahamajjatādisena”."
    },
    {
      "id": "ja230:2.1",
      "pali": "“Mā bāliyaṁ vilapi na hissa tādisaṁ,"
    },
    {
      "id": "ja230:2.2",
      "pali": "Viḍayhase na hi labhase nisedhakaṁ;"
    },
    {
      "id": "ja230:2.3",
      "pali": "Āsajjasi gajamiva ekacārinaṁ,"
    },
    {
      "id": "ja230:2.4",
      "pali": "Yo taṁ padā naḷamiva pothayissatī”ti."
    },
    {
      "id": "ja230:3.1",
      "pali": "Dutiyapalāyitajātakaṁ dasamaṁ."
    },
    {
      "id": "ja230:3.2",
      "pali": "Kāsāvavaggo aṭṭhamo."
    },
    {
      "id": "ja230:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja230:5.1",
      "pali": "Varavatthavaco dumakhīṇaphalaṁ,"
    },
    {
      "id": "ja230:5.2",
      "pali": "Caturodhammavaraṁ purisuttama;"
    },
    {
      "id": "ja230:5.3",
      "pali": "Dhaṅkamagadhā ca tayogirināma,"
    },
    {
      "id": "ja230:5.4",
      "pali": "Gajaggavaro dhajavarena dasāti."
    }
  ]
}
