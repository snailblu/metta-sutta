{
  "uid": "ja197",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja197:1.1",
      "pali": "“Na naṁ umhayate disvā,"
    },
    {
      "id": "ja197:1.2",
      "pali": "na ca naṁ paṭinandati;"
    },
    {
      "id": "ja197:1.3",
      "pali": "Cakkhūni cassa na dadāti,"
    },
    {
      "id": "ja197:1.4",
      "pali": "paṭilomañca vattati."
    },
    {
      "id": "ja197:2.1",
      "pali": "Ete bhavanti ākārā,"
    },
    {
      "id": "ja197:2.2",
      "pali": "amittasmiṁ patiṭṭhitā;"
    },
    {
      "id": "ja197:2.3",
      "pali": "Yehi amittaṁ jāneyya,"
    },
    {
      "id": "ja197:2.4",
      "pali": "disvā sutvā ca paṇḍito”ti."
    },
    {
      "id": "ja197:3.1",
      "pali": "Mittāmittajātakaṁ sattamaṁ."
    }
  ]
}
