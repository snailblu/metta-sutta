{
  "uid": "thag1.44",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.44:1.1",
      "pali": "“Mataṁ vā amma rodanti,"
    },
    {
      "id": "thag1.44:1.2",
      "pali": "Yo vā jīvaṁ na dissati;"
    },
    {
      "id": "thag1.44:1.3",
      "pali": "Jīvantaṁ maṁ amma passantī,"
    },
    {
      "id": "thag1.44:1.4",
      "pali": "Kasmā maṁ amma rodasī”ti."
    },
    {
      "id": "thag1.44:1.5",
      "pali": "… Sānutthero …."
    }
  ]
}
