{
  "uid": "iti112",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti112:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti112:2.1",
      "pali": "“Loko, bhikkhave, tathāgatena abhisambuddho,"
    },
    {
      "id": "iti112:2.2",
      "pali": "lokasmā tathāgato visaṁyutto."
    },
    {
      "id": "iti112:2.3",
      "pali": "Lokasamudayo, bhikkhave, tathāgatena abhisambuddho,"
    },
    {
      "id": "iti112:2.4",
      "pali": "lokasamudayo tathāgatassa pahīno."
    },
    {
      "id": "iti112:2.5",
      "pali": "Lokanirodho, bhikkhave, tathāgatena abhisambuddho,"
    },
    {
      "id": "iti112:2.6",
      "pali": "lokanirodho tathāgatassa sacchikato."
    },
    {
      "id": "iti112:2.7",
      "pali": "Lokanirodhagāminī paṭipadā, bhikkhave, tathāgatena abhisambuddhā,"
    },
    {
      "id": "iti112:2.8",
      "pali": "lokanirodhagāminī paṭipadā tathāgatassa bhāvitā."
    },
    {
      "id": "iti112:3.1",
      "pali": "Yaṁ, bhikkhave, sadevakassa lokassa samārakassa sabrahmakassa sassamaṇabrāhmaṇiyā pajāya sadevamanussāya diṭṭhaṁ sutaṁ mutaṁ viññātaṁ pattaṁ pariyesitaṁ anuvicaritaṁ manasā yasmā taṁ tathāgatena abhisambuddhaṁ,"
    },
    {
      "id": "iti112:3.2",
      "pali": "tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "iti112:4.1",
      "pali": "Yañca, bhikkhave, rattiṁ tathāgato anuttaraṁ sammāsambodhiṁ abhisambujjhati, yañca rattiṁ anupādisesāya nibbānadhātuyā parinibbāyati, yaṁ etasmiṁ antare bhāsati lapati niddisati, sabbaṁ taṁ tatheva hoti no aññathā,"
    },
    {
      "id": "iti112:4.2",
      "pali": "tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "iti112:5.1",
      "pali": "Yathāvādī, bhikkhave, tathāgato tathākārī, yathākārī tathāvādī,"
    },
    {
      "id": "iti112:5.2",
      "pali": "iti yathāvādī tathākārī yathākārī tathāvādī,"
    },
    {
      "id": "iti112:5.3",
      "pali": "tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "iti112:6.1",
      "pali": "Sadevake, bhikkhave, loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya tathāgato abhibhū anabhibhūto aññadatthudaso vasavattī,"
    },
    {
      "id": "iti112:6.2",
      "pali": "tasmā tathāgatoti vuccatī”ti."
    },
    {
      "id": "iti112:6.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti112:6.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti112:7.1",
      "pali": "“Sabbalokaṁ abhiññāya,"
    },
    {
      "id": "iti112:7.2",
      "pali": "sabbaloke yathātathaṁ;"
    },
    {
      "id": "iti112:7.3",
      "pali": "Sabbalokavisaṁyutto,"
    },
    {
      "id": "iti112:7.4",
      "pali": "sabbaloke anūpayo."
    },
    {
      "id": "iti112:8.1",
      "pali": "Sa ve sabbābhibhū dhīro,"
    },
    {
      "id": "iti112:8.2",
      "pali": "sabbaganthappamocano;"
    },
    {
      "id": "iti112:8.3",
      "pali": "Phuṭṭhāssa paramā santi,"
    },
    {
      "id": "iti112:8.4",
      "pali": "nibbānaṁ akutobhayaṁ."
    },
    {
      "id": "iti112:9.1",
      "pali": "Esa khīṇāsavo buddho,"
    },
    {
      "id": "iti112:9.2",
      "pali": "anīgho chinnasaṁsayo;"
    },
    {
      "id": "iti112:9.3",
      "pali": "Sabbakammakkhayaṁ patto,"
    },
    {
      "id": "iti112:9.4",
      "pali": "vimutto upadhisaṅkhaye."
    },
    {
      "id": "iti112:10.1",
      "pali": "Esa so bhagavā buddho,"
    },
    {
      "id": "iti112:10.2",
      "pali": "esa sīho anuttaro;"
    },
    {
      "id": "iti112:10.3",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "iti112:10.4",
      "pali": "brahmacakkaṁ pavattayi."
    },
    {
      "id": "iti112:11.1",
      "pali": "Iti devā manussā ca,"
    },
    {
      "id": "iti112:11.2",
      "pali": "ye buddhaṁ saraṇaṁ gatā;"
    },
    {
      "id": "iti112:11.3",
      "pali": "Saṅgamma taṁ namassanti,"
    },
    {
      "id": "iti112:11.4",
      "pali": "mahantaṁ vītasāradaṁ."
    },
    {
      "id": "iti112:12.1",
      "pali": "Danto damayataṁ seṭṭho,"
    },
    {
      "id": "iti112:12.2",
      "pali": "santo samayataṁ isi;"
    },
    {
      "id": "iti112:12.3",
      "pali": "Mutto mocayataṁ aggo,"
    },
    {
      "id": "iti112:12.4",
      "pali": "tiṇṇo tārayataṁ varo."
    },
    {
      "id": "iti112:13.1",
      "pali": "Iti hetaṁ namassanti,"
    },
    {
      "id": "iti112:13.2",
      "pali": "mahantaṁ vītasāradaṁ;"
    },
    {
      "id": "iti112:13.3",
      "pali": "Sadevakasmiṁ lokasmiṁ,"
    },
    {
      "id": "iti112:13.4",
      "pali": "natthi te paṭipuggalo”ti."
    },
    {
      "id": "iti112:14.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti112:14.2",
      "pali": "Terasamaṁ."
    },
    {
      "id": "iti112:14.3",
      "pali": "Catukkanipāto niṭṭhito."
    },
    {
      "id": "iti112:15.1",
      "pali": "Brāhmaṇasulabhā jānaṁ,"
    },
    {
      "id": "iti112:15.2",
      "pali": "Samaṇasīlā taṇhā brahmā;"
    },
    {
      "id": "iti112:15.3",
      "pali": "Bahukārā kuhapurisā,"
    },
    {
      "id": "iti112:15.4",
      "pali": "Cara sampannalokena terasāti."
    },
    {
      "id": "iti112:16.1",
      "pali": "Sattavisekanipātaṁ,"
    },
    {
      "id": "iti112:16.2",
      "pali": "Dukkaṁ bāvīsasuttasaṅgahitaṁ;"
    },
    {
      "id": "iti112:16.3",
      "pali": "Samapaññāsamathatikaṁ,"
    },
    {
      "id": "iti112:16.4",
      "pali": "Terasa catukkañca iti yamidaṁ."
    },
    {
      "id": "iti112:17.1",
      "pali": "Dvidasuttarasuttasate,"
    },
    {
      "id": "iti112:17.2",
      "pali": "Saṅgāyitvā samādahiṁsu purā;"
    },
    {
      "id": "iti112:17.3",
      "pali": "Arahanto ciraṭṭhitiyā,"
    },
    {
      "id": "iti112:17.4",
      "pali": "Tamāhu nāmena itivuttanti."
    },
    {
      "id": "iti112:17.5",
      "pali": "Itivuttakapāḷi niṭṭhitā."
    }
  ]
}
