{
  "uid": "thig1.15",
  "title": "Uttarātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.15:1.1",
      "pali": "“Kāyena saṁvutā āsiṁ,"
    },
    {
      "id": "thig1.15:1.2",
      "pali": "vācāya uda cetasā;"
    },
    {
      "id": "thig1.15:1.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "thig1.15:1.4",
      "pali": "sītibhūtāmhi nibbutā”ti."
    },
    {
      "id": "thig1.15:2.1",
      "pali": "… Uttarā therī …."
    }
  ]
}
