{
  "uid": "ja32",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja32:1.1",
      "pali": "“Rudaṁ manuññaṁ rucirā ca piṭṭhi,"
    },
    {
      "id": "ja32:1.2",
      "pali": "Veḷuriyavaṇṇūpanibhā ca gīvā;"
    },
    {
      "id": "ja32:1.3",
      "pali": "Byāmamattāni ca pekhuṇāni,"
    },
    {
      "id": "ja32:1.4",
      "pali": "Naccena te dhītaraṁ no dadāmī”ti."
    },
    {
      "id": "ja32:2.1",
      "pali": "Naccajātakaṁ dutiyaṁ."
    }
  ]
}
