{
  "uid": "thag3.13",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.13:1.1",
      "pali": "“Suṇātha ñātayo sabbe,"
    },
    {
      "id": "thag3.13:1.2",
      "pali": "yāvantettha samāgatā;"
    },
    {
      "id": "thag3.13:1.3",
      "pali": "Dhammaṁ vo desayissāmi,"
    },
    {
      "id": "thag3.13:1.4",
      "pali": "dukkhā jāti punappunaṁ."
    },
    {
      "id": "thag3.13:2.1",
      "pali": "Ārambhatha nikkamatha,"
    },
    {
      "id": "thag3.13:2.2",
      "pali": "Yuñjatha buddhasāsane;"
    },
    {
      "id": "thag3.13:2.3",
      "pali": "Dhunātha maccuno senaṁ,"
    },
    {
      "id": "thag3.13:2.4",
      "pali": "Naḷāgāraṁva kuñjaro."
    },
    {
      "id": "thag3.13:3.1",
      "pali": "Yo imasmiṁ dhammavinaye,"
    },
    {
      "id": "thag3.13:3.2",
      "pali": "appamatto vihassati;"
    },
    {
      "id": "thag3.13:3.3",
      "pali": "Pahāya jātisaṁsāraṁ,"
    },
    {
      "id": "thag3.13:3.4",
      "pali": "dukkhassantaṁ karissatī”ti."
    },
    {
      "id": "thag3.13:3.5",
      "pali": "… Abhibhūto thero …."
    }
  ]
}
