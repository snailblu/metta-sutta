{
  "uid": "ja186",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja186:1.1",
      "pali": "“Vaṇṇagandharasūpeto,"
    },
    {
      "id": "ja186:1.2",
      "pali": "amboyaṁ ahuvā pure;"
    },
    {
      "id": "ja186:1.3",
      "pali": "Tameva pūjaṁ labhamāno,"
    },
    {
      "id": "ja186:1.4",
      "pali": "kenambo kaṭukapphalo”."
    },
    {
      "id": "ja186:2.1",
      "pali": "“Pucimandaparivāro,"
    },
    {
      "id": "ja186:2.2",
      "pali": "ambo te dadhivāhana;"
    },
    {
      "id": "ja186:2.3",
      "pali": "Mūlaṁ mūlena saṁsaṭṭhaṁ,"
    },
    {
      "id": "ja186:2.4",
      "pali": "sākhā sākhā nisevare;"
    },
    {
      "id": "ja186:2.5",
      "pali": "Asātasannivāsena,"
    },
    {
      "id": "ja186:2.6",
      "pali": "tenambo kaṭukapphalo”ti."
    },
    {
      "id": "ja186:3.1",
      "pali": "Dadhivāhanajātakaṁ chaṭṭhaṁ."
    }
  ]
}
