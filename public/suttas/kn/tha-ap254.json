{
  "uid": "tha-ap254",
  "title": "Ekāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap254:1.1",
      "pali": "“Vijahitvā devavaṇṇaṁ,"
    },
    {
      "id": "tha-ap254:1.2",
      "pali": "sabhariyo idhāgamiṁ;"
    },
    {
      "id": "tha-ap254:1.3",
      "pali": "Adhikāraṁ kattukāmo,"
    },
    {
      "id": "tha-ap254:1.4",
      "pali": "buddhaseṭṭhassa sāsane."
    },
    {
      "id": "tha-ap254:2.1",
      "pali": "Devalo nāma nāmena,"
    },
    {
      "id": "tha-ap254:2.2",
      "pali": "padumuttarasāvako;"
    },
    {
      "id": "tha-ap254:2.3",
      "pali": "Tassa bhikkhā mayā dinnā,"
    },
    {
      "id": "tha-ap254:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap254:3.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap254:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap254:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap254:3.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap254:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap254:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap254:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap254:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap254:6.1",
      "pali": "Ekāsanadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
