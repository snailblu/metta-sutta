{
  "uid": "tha-ap246",
  "title": "4 Viravapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap246:1.1",
      "pali": "“Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap246:1.2",
      "pali": "niyyāti lokanāyako;"
    },
    {
      "id": "tha-ap246:1.3",
      "pali": "Viravapupphamādāya,"
    },
    {
      "id": "tha-ap246:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap246:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap246:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap246:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap246:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap246:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap246:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap246:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap246:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā viravapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap246:5.1",
      "pali": "Viravapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
