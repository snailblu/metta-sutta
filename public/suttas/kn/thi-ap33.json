{
  "uid": "thi-ap33",
  "title": "Uppaladāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap33:1.1",
      "pali": "“Nagare aruṇavatiyā,"
    },
    {
      "id": "thi-ap33:1.2",
      "pali": "aruṇo nāma khattiyo;"
    },
    {
      "id": "thi-ap33:1.3",
      "pali": "Tassa rañño ahuṁ bhariyā,"
    },
    {
      "id": "thi-ap33:1.4",
      "pali": "ekajjhaṁ cārayāmahaṁ."
    },
    {
      "id": "thi-ap33:2.1",
      "pali": "Rahogatā nisīditvā,"
    },
    {
      "id": "thi-ap33:2.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "thi-ap33:2.3",
      "pali": "‘Kusalaṁ me kataṁ natthi,"
    },
    {
      "id": "thi-ap33:2.4",
      "pali": "ādāya gamiyaṁ mama."
    },
    {
      "id": "thi-ap33:3.1",
      "pali": "Mahābhitāpaṁ kaṭukaṁ,"
    },
    {
      "id": "thi-ap33:3.2",
      "pali": "ghorarūpaṁ sudāruṇaṁ;"
    },
    {
      "id": "thi-ap33:3.3",
      "pali": "Nirayaṁ nūna gacchāmi,"
    },
    {
      "id": "thi-ap33:3.4",
      "pali": "ettha me natthi saṁsayo’."
    },
    {
      "id": "thi-ap33:4.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "thi-ap33:4.2",
      "pali": "pahaṁsetvāna mānasaṁ;"
    },
    {
      "id": "thi-ap33:4.3",
      "pali": "Rājānaṁ upagantvāna,"
    },
    {
      "id": "thi-ap33:4.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "thi-ap33:5.1",
      "pali": "‘Itthī nāma mayaṁ deva,"
    },
    {
      "id": "thi-ap33:5.2",
      "pali": "purisānittarā ahu;"
    },
    {
      "id": "thi-ap33:5.3",
      "pali": "Ekaṁ me samaṇaṁ dehi,"
    },
    {
      "id": "thi-ap33:5.4",
      "pali": "bhojayissāmi khattiya’."
    },
    {
      "id": "thi-ap33:6.1",
      "pali": "Adāsi me tadā rājā,"
    },
    {
      "id": "thi-ap33:6.2",
      "pali": "samaṇaṁ bhāvitindriyaṁ;"
    },
    {
      "id": "thi-ap33:6.3",
      "pali": "Tassa pattaṁ gahetvāna,"
    },
    {
      "id": "thi-ap33:6.4",
      "pali": "paramannena pūrayiṁ."
    },
    {
      "id": "thi-ap33:7.1",
      "pali": "Pūretvā paramaṁ annaṁ,"
    },
    {
      "id": "thi-ap33:7.2",
      "pali": "saha sugandhalepanaṁ;"
    },
    {
      "id": "thi-ap33:7.3",
      "pali": "Mahācelena chāditvā,"
    },
    {
      "id": "thi-ap33:7.4",
      "pali": "adāsiṁ tuṭṭhamānasā."
    },
    {
      "id": "thi-ap33:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap33:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap33:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap33:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap33:9.1",
      "pali": "Sahassadevarājūnaṁ,"
    },
    {
      "id": "thi-ap33:9.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap33:9.3",
      "pali": "Sahassacakkavattīnaṁ,"
    },
    {
      "id": "thi-ap33:9.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap33:10.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "thi-ap33:10.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "thi-ap33:10.3",
      "pali": "Nānāvidhaṁ bahuṁ aññaṁ,"
    },
    {
      "id": "thi-ap33:10.4",
      "pali": "tassa kammaphalaṁ tato."
    },
    {
      "id": "thi-ap33:11.1",
      "pali": "Uppalasseva me vaṇṇo,"
    },
    {
      "id": "thi-ap33:11.2",
      "pali": "abhirūpā sudassanā;"
    },
    {
      "id": "thi-ap33:11.3",
      "pali": "Itthisabbaṅgasampannā,"
    },
    {
      "id": "thi-ap33:11.4",
      "pali": "abhijātā jutindharā."
    },
    {
      "id": "thi-ap33:12.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap33:12.2",
      "pali": "ajāyiṁ sākiye kule;"
    },
    {
      "id": "thi-ap33:12.3",
      "pali": "Nārīsahassapāmokkhā,"
    },
    {
      "id": "thi-ap33:12.4",
      "pali": "suddhodanasutassahaṁ."
    },
    {
      "id": "thi-ap33:13.1",
      "pali": "Nibbinditvā agārehaṁ,"
    },
    {
      "id": "thi-ap33:13.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap33:13.3",
      "pali": "Sattamīrattisampattā,"
    },
    {
      "id": "thi-ap33:13.4",
      "pali": "catusaccamapāpuṇiṁ."
    },
    {
      "id": "thi-ap33:14.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap33:14.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap33:14.3",
      "pali": "Parimetuṁ na sakkomi,"
    },
    {
      "id": "thi-ap33:14.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap33:15.1",
      "pali": "Yaṁ mayhaṁ pūritaṁ kammaṁ,"
    },
    {
      "id": "thi-ap33:15.2",
      "pali": "Kusalaṁ sarase muni;"
    },
    {
      "id": "thi-ap33:15.3",
      "pali": "Tuyhatthāya mahāvīra,"
    },
    {
      "id": "thi-ap33:15.4",
      "pali": "Paricattaṁ bahuṁ mayā."
    },
    {
      "id": "thi-ap33:16.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "thi-ap33:16.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "thi-ap33:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap33:16.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap33:17.1",
      "pali": "Dve gatiyo pajānāmi,"
    },
    {
      "id": "thi-ap33:17.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "thi-ap33:17.3",
      "pali": "Aññaṁ gatiṁ na jānāmi,"
    },
    {
      "id": "thi-ap33:17.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap33:18.1",
      "pali": "Ucce kule pajānāmi,"
    },
    {
      "id": "thi-ap33:18.2",
      "pali": "mahāsāle mahaddhane;"
    },
    {
      "id": "thi-ap33:18.3",
      "pali": "Aññe kule na jānāmi,"
    },
    {
      "id": "thi-ap33:18.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap33:19.1",
      "pali": "Bhavābhave saṁsaritvā,"
    },
    {
      "id": "thi-ap33:19.2",
      "pali": "sukkamūlena coditā;"
    },
    {
      "id": "thi-ap33:19.3",
      "pali": "Amanāpaṁ na passāmi,"
    },
    {
      "id": "thi-ap33:19.4",
      "pali": "somanassakataṁ phalaṁ."
    },
    {
      "id": "thi-ap33:20.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap33:20.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap33:20.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap33:20.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap33:21.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap33:21.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap33:21.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap33:21.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap33:22.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap33:22.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap33:22.3",
      "pali": "Ñāṇaṁ mama mahāvīra,"
    },
    {
      "id": "thi-ap33:22.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap33:23.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap33:23.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap33:23.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap33:24.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap33:24.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap33:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap33:25.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap33:25.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap33:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap33:26.1",
      "pali": "Itthaṁ sudaṁ uppaladāyikā bhikkhunī bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap33:27.1",
      "pali": "Uppaladāyikātheriyāpadānaṁ tatiyaṁ."
    }
  ]
}
