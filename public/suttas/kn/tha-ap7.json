{
  "uid": "tha-ap7",
  "title": "7 Puṇṇamantāṇiputtattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap7:1.1",
      "pali": "“Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap7:1.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap7:1.3",
      "pali": "Purakkhatomhi sissehi,"
    },
    {
      "id": "tha-ap7:1.4",
      "pali": "upagacchiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap7:2.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap7:2.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap7:2.3",
      "pali": "Mama kammaṁ pakittesi,"
    },
    {
      "id": "tha-ap7:2.4",
      "pali": "saṅkhittena mahāmuni."
    },
    {
      "id": "tha-ap7:3.1",
      "pali": "Tāhaṁ dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap7:3.2",
      "pali": "Abhivādetvāna satthuno;"
    },
    {
      "id": "tha-ap7:3.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap7:3.4",
      "pali": "Pakkamiṁ dakkhiṇāmukho."
    },
    {
      "id": "tha-ap7:4.1",
      "pali": "Saṅkhittena suṇitvāna,"
    },
    {
      "id": "tha-ap7:4.2",
      "pali": "vitthārena abhāsayiṁ;"
    },
    {
      "id": "tha-ap7:4.3",
      "pali": "Sabbe sissā attamanā,"
    },
    {
      "id": "tha-ap7:4.4",
      "pali": "sutvāna mama bhāsato;"
    },
    {
      "id": "tha-ap7:4.5",
      "pali": "Sakaṁ diṭṭhiṁ vinodetvā,"
    },
    {
      "id": "tha-ap7:4.6",
      "pali": "buddhe cittaṁ pasādayuṁ."
    },
    {
      "id": "tha-ap7:5.1",
      "pali": "Saṅkhittenapi desemi,"
    },
    {
      "id": "tha-ap7:5.2",
      "pali": "vitthārena tathevahaṁ;"
    },
    {
      "id": "tha-ap7:5.3",
      "pali": "Abhidhammanayaññūhaṁ,"
    },
    {
      "id": "tha-ap7:5.4",
      "pali": "kathāvatthuvisuddhiyā;"
    },
    {
      "id": "tha-ap7:5.5",
      "pali": "Sabbesaṁ viññāpetvāna,"
    },
    {
      "id": "tha-ap7:5.6",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap7:6.1",
      "pali": "Ito pañcasate kappe,"
    },
    {
      "id": "tha-ap7:6.2",
      "pali": "caturo suppakāsakā;"
    },
    {
      "id": "tha-ap7:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap7:6.4",
      "pali": "catudīpamhi issarā."
    },
    {
      "id": "tha-ap7:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap7:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap7:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap7:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap7:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā puṇṇo mantāṇiputto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap7:9.1",
      "pali": "Puṇṇamantāṇiputtattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
