{
  "uid": "tha-ap530",
  "title": "Bodhisammajjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap530:1.1",
      "pali": "“Ahaṁ pure bodhipattaṁ,"
    },
    {
      "id": "tha-ap530:1.2",
      "pali": "ujjhitaṁ cetiyaṅgaṇe;"
    },
    {
      "id": "tha-ap530:1.3",
      "pali": "Taṁ gahetvāna chaḍḍesiṁ,"
    },
    {
      "id": "tha-ap530:1.4",
      "pali": "alabhiṁ vīsatīguṇe."
    },
    {
      "id": "tha-ap530:2.1",
      "pali": "Tassa kammassa tejena,"
    },
    {
      "id": "tha-ap530:2.2",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "tha-ap530:2.3",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap530:2.4",
      "pali": "devatte cāpi mānuse."
    },
    {
      "id": "tha-ap530:3.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap530:3.2",
      "pali": "āgantvā mānusaṁ bhavaṁ;"
    },
    {
      "id": "tha-ap530:3.3",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap530:3.4",
      "pali": "khattiye cāpi brāhmaṇe."
    },
    {
      "id": "tha-ap530:4.1",
      "pali": "Aṅgapaccaṅgasampanno,"
    },
    {
      "id": "tha-ap530:4.2",
      "pali": "ārohapariṇāhavā;"
    },
    {
      "id": "tha-ap530:4.3",
      "pali": "Abhirūpo suci homi,"
    },
    {
      "id": "tha-ap530:4.4",
      "pali": "sampuṇṇaṅgo anūnako."
    },
    {
      "id": "tha-ap530:5.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap530:5.2",
      "pali": "jāto vā yattha katthaci;"
    },
    {
      "id": "tha-ap530:5.3",
      "pali": "Bhave suvaṇṇavaṇṇo ca,"
    },
    {
      "id": "tha-ap530:5.4",
      "pali": "uttattakanakūpamo."
    },
    {
      "id": "tha-ap530:6.1",
      "pali": "Mudukā maddavā sniddhā,"
    },
    {
      "id": "tha-ap530:6.2",
      "pali": "sukhumā sukumārikā;"
    },
    {
      "id": "tha-ap530:6.3",
      "pali": "Chavi me sabbadā hoti,"
    },
    {
      "id": "tha-ap530:6.4",
      "pali": "bodhipatte suchaḍḍite."
    },
    {
      "id": "tha-ap530:7.1",
      "pali": "Yato kutoci gatīsu,"
    },
    {
      "id": "tha-ap530:7.2",
      "pali": "sarīre samudāgate;"
    },
    {
      "id": "tha-ap530:7.3",
      "pali": "Na limpati rajojallaṁ,"
    },
    {
      "id": "tha-ap530:7.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:8.1",
      "pali": "Uṇhe vātātape tassa,"
    },
    {
      "id": "tha-ap530:8.2",
      "pali": "aggitāpena vā pana;"
    },
    {
      "id": "tha-ap530:8.3",
      "pali": "Gatte sedā na muccanti,"
    },
    {
      "id": "tha-ap530:8.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:9.1",
      "pali": "Kuṭṭhaṁ gaṇḍo kilāso ca,"
    },
    {
      "id": "tha-ap530:9.2",
      "pali": "tilakā piḷakā tathā;"
    },
    {
      "id": "tha-ap530:9.3",
      "pali": "Na honti kāye daddu ca,"
    },
    {
      "id": "tha-ap530:9.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:10.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:10.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:10.3",
      "pali": "Rogā na honti kāyasmiṁ,"
    },
    {
      "id": "tha-ap530:10.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:11.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:11.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:11.3",
      "pali": "Na hoti cittajā pīḷā,"
    },
    {
      "id": "tha-ap530:11.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:12.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:12.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:12.3",
      "pali": "Amittā na bhavantassa,"
    },
    {
      "id": "tha-ap530:12.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:13.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:13.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:13.3",
      "pali": "Anūnabhogo bhavati,"
    },
    {
      "id": "tha-ap530:13.4",
      "pali": "vipāko pattachaḍḍite."
    },
    {
      "id": "tha-ap530:14.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:14.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:14.3",
      "pali": "Aggirājūhi corehi,"
    },
    {
      "id": "tha-ap530:14.4",
      "pali": "na hoti udake bhayaṁ."
    },
    {
      "id": "tha-ap530:15.1",
      "pali": "Aparampi guṇaṁ tassa,"
    },
    {
      "id": "tha-ap530:15.2",
      "pali": "nibbattati bhavābhave;"
    },
    {
      "id": "tha-ap530:15.3",
      "pali": "Dāsidāsā anucarā,"
    },
    {
      "id": "tha-ap530:15.4",
      "pali": "honti cittānuvattakā."
    },
    {
      "id": "tha-ap530:16.1",
      "pali": "Yamhi āyuppamāṇamhi,"
    },
    {
      "id": "tha-ap530:16.2",
      "pali": "jāyate mānuse bhave;"
    },
    {
      "id": "tha-ap530:16.3",
      "pali": "Tato na hāyate āyu,"
    },
    {
      "id": "tha-ap530:16.4",
      "pali": "tiṭṭhate yāvatāyukaṁ."
    },
    {
      "id": "tha-ap530:17.1",
      "pali": "Abbhantarā ca bāhirā,"
    },
    {
      "id": "tha-ap530:17.2",
      "pali": "negamā ca saraṭṭhakā;"
    },
    {
      "id": "tha-ap530:17.3",
      "pali": "Nuyuttā honti sabbepi,"
    },
    {
      "id": "tha-ap530:17.4",
      "pali": "vuddhikāmā sukhicchakā."
    },
    {
      "id": "tha-ap530:18.1",
      "pali": "Bhogavā yasavā homi,"
    },
    {
      "id": "tha-ap530:18.2",
      "pali": "sirimā ñātipakkhavā;"
    },
    {
      "id": "tha-ap530:18.3",
      "pali": "Apetabhayasantāso,"
    },
    {
      "id": "tha-ap530:18.4",
      "pali": "bhavehaṁ sabbato bhave."
    },
    {
      "id": "tha-ap530:19.1",
      "pali": "Devā manussā asurā,"
    },
    {
      "id": "tha-ap530:19.2",
      "pali": "gandhabbā yakkharakkhasā;"
    },
    {
      "id": "tha-ap530:19.3",
      "pali": "Sabbe te parirakkhanti,"
    },
    {
      "id": "tha-ap530:19.4",
      "pali": "bhave saṁsarato sadā."
    },
    {
      "id": "tha-ap530:20.1",
      "pali": "Devaloke manusse ca,"
    },
    {
      "id": "tha-ap530:20.2",
      "pali": "anubhotvā ubho yase;"
    },
    {
      "id": "tha-ap530:20.3",
      "pali": "Avasāne ca nibbānaṁ,"
    },
    {
      "id": "tha-ap530:20.4",
      "pali": "sivaṁ patto anuttaraṁ."
    },
    {
      "id": "tha-ap530:21.1",
      "pali": "Sambuddhamuddisitvāna,"
    },
    {
      "id": "tha-ap530:21.2",
      "pali": "bodhiṁ vā tassa satthuno;"
    },
    {
      "id": "tha-ap530:21.3",
      "pali": "Yo puññaṁ pasave poso,"
    },
    {
      "id": "tha-ap530:21.4",
      "pali": "tassa kiṁ nāma dullabhaṁ."
    },
    {
      "id": "tha-ap530:22.1",
      "pali": "Magge phale āgame ca,"
    },
    {
      "id": "tha-ap530:22.2",
      "pali": "jhānābhiññāguṇesu ca;"
    },
    {
      "id": "tha-ap530:22.3",
      "pali": "Aññesaṁ adhiko hutvā,"
    },
    {
      "id": "tha-ap530:22.4",
      "pali": "nibbāyāmi anāsavo."
    },
    {
      "id": "tha-ap530:23.1",
      "pali": "Purehaṁ bodhiyā pattaṁ,"
    },
    {
      "id": "tha-ap530:23.2",
      "pali": "chaḍḍetvā haṭṭhamānaso;"
    },
    {
      "id": "tha-ap530:23.3",
      "pali": "Imehi vīsataṅgehi,"
    },
    {
      "id": "tha-ap530:23.4",
      "pali": "samaṅgī homi sabbadā."
    },
    {
      "id": "tha-ap530:24.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap530:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap530:24.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap530:25.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap530:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap530:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap530:26.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap530:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap530:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap530:27.1",
      "pali": "Itthaṁ sudaṁ āyasmā bodhisammajjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap530:28.1",
      "pali": "Bodhisammajjakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
