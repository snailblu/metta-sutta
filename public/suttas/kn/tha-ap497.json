{
  "uid": "tha-ap497",
  "title": "Upaḍḍhadussadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap497:1.1",
      "pali": "“Padumuttarabhagavato,"
    },
    {
      "id": "tha-ap497:1.2",
      "pali": "sujāto nāma sāvako;"
    },
    {
      "id": "tha-ap497:1.3",
      "pali": "Paṁsukūlaṁ gavesanto,"
    },
    {
      "id": "tha-ap497:1.4",
      "pali": "saṅkāre carate tadā."
    },
    {
      "id": "tha-ap497:2.1",
      "pali": "Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap497:2.2",
      "pali": "paresaṁ bhatako ahaṁ;"
    },
    {
      "id": "tha-ap497:2.3",
      "pali": "Upaḍḍhadussaṁ datvāna,"
    },
    {
      "id": "tha-ap497:2.4",
      "pali": "sirasā abhivādayiṁ."
    },
    {
      "id": "tha-ap497:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap497:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap497:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap497:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap497:4.1",
      "pali": "Tettiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap497:4.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap497:4.3",
      "pali": "Sattasattatikkhattuñca,"
    },
    {
      "id": "tha-ap497:4.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap497:5.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap497:5.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap497:5.3",
      "pali": "Upaḍḍhadussadānena,"
    },
    {
      "id": "tha-ap497:5.4",
      "pali": "modāmi akutobhayo."
    },
    {
      "id": "tha-ap497:6.1",
      "pali": "Icchamāno cahaṁ ajja,"
    },
    {
      "id": "tha-ap497:6.2",
      "pali": "sakānanaṁ sapabbataṁ;"
    },
    {
      "id": "tha-ap497:6.3",
      "pali": "Khomadussehi chādeyyaṁ,"
    },
    {
      "id": "tha-ap497:6.4",
      "pali": "aḍḍhadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap497:7.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap497:7.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap497:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap497:7.4",
      "pali": "aḍḍhadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap497:8.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap497:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap497:8.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap497:9.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap497:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap497:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap497:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap497:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap497:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap497:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā upaḍḍhadussadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap497:12.1",
      "pali": "Upaḍḍhadussadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
