{
  "uid": "ja259",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja259:1.1",
      "pali": "“Nayimassa vijjāmayamatthi kiñci,"
    },
    {
      "id": "ja259:1.2",
      "pali": "Na bandhavo no pana te sahāyo;"
    },
    {
      "id": "ja259:1.3",
      "pali": "Atha kena vaṇṇena tirīṭavaccho,"
    },
    {
      "id": "ja259:1.4",
      "pali": "Tedaṇḍiko bhuñjati aggapiṇḍaṁ”."
    },
    {
      "id": "ja259:2.1",
      "pali": "“Āpāsu me yuddhaparājitassa,"
    },
    {
      "id": "ja259:2.2",
      "pali": "Ekassa katvā vivanasmi ghore;"
    },
    {
      "id": "ja259:2.3",
      "pali": "Pasārayī kicchagatassa pāṇiṁ,"
    },
    {
      "id": "ja259:2.4",
      "pali": "Tenūdatāriṁ dukhasampareto."
    },
    {
      "id": "ja259:3.1",
      "pali": "Etassa kiccena idhānupatto,"
    },
    {
      "id": "ja259:3.2",
      "pali": "Vesāyino visayā jīvaloke;"
    },
    {
      "id": "ja259:3.3",
      "pali": "Lābhāraho tāta tirīṭavaccho,"
    },
    {
      "id": "ja259:3.4",
      "pali": "Dethassa bhogaṁ yajathañca yaññan”ti."
    },
    {
      "id": "ja259:4.1",
      "pali": "Tirīṭavacchajātakaṁ navamaṁ."
    }
  ]
}
