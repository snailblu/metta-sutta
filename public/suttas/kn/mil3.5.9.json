{
  "uid": "mil3.5.9",
  "title": "9. Uppajjatijānanapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.5.9:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.5.9:1.2",
      "pali": "“bhante nāgasena, yo uppajjati, jānāti so ‘uppajjissāmī’”ti?"
    },
    {
      "id": "mil3.5.9:1.3",
      "pali": "“Āma, mahārāja, yo uppajjati jānāti so ‘uppajjissāmī’”ti."
    },
    {
      "id": "mil3.5.9:2.1",
      "pali": "“Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.5.9:2.2",
      "pali": "“Yathā, mahārāja, kassako gahapatiko bījāni pathaviyaṁ nikkhipitvā sammā deve vassante jānāti ‘dhaññaṁ nibbattissatī’”ti?"
    },
    {
      "id": "mil3.5.9:2.3",
      "pali": "“Āma, bhante, jāneyyā”ti."
    },
    {
      "id": "mil3.5.9:2.4",
      "pali": "“Evameva kho, mahārāja, yo uppajjati, jānāti so ‘uppajjissāmī’”ti."
    },
    {
      "id": "mil3.5.9:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.5.9:4.1",
      "pali": "Uppajjatijānanapañho navamo."
    }
  ]
}
