{
  "uid": "tha-ap299",
  "title": "7 Desakittakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap299:1.1",
      "pali": "“Upasālakanāmohaṁ,"
    },
    {
      "id": "tha-ap299:1.2",
      "pali": "ahosiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap299:1.3",
      "pali": "Kānanaṁ vanamogāḷhaṁ,"
    },
    {
      "id": "tha-ap299:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap299:2.1",
      "pali": "Disvāna vandiṁ pādesu,"
    },
    {
      "id": "tha-ap299:2.2",
      "pali": "lokāhutipaṭiggahaṁ;"
    },
    {
      "id": "tha-ap299:2.3",
      "pali": "Pasannacittaṁ maṁ ñatvā,"
    },
    {
      "id": "tha-ap299:2.4",
      "pali": "buddho antaradhāyatha."
    },
    {
      "id": "tha-ap299:3.1",
      "pali": "Kānanā abhinikkhamma,"
    },
    {
      "id": "tha-ap299:3.2",
      "pali": "buddhaseṭṭhamanussariṁ;"
    },
    {
      "id": "tha-ap299:3.3",
      "pali": "Taṁ desaṁ kittayitvāna,"
    },
    {
      "id": "tha-ap299:3.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap299:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap299:4.2",
      "pali": "yaṁ desamabhikittayiṁ;"
    },
    {
      "id": "tha-ap299:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap299:4.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap299:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap299:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap299:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap299:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā desakittako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap299:7.1",
      "pali": "Desakittakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
