{
  "uid": "thag5.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.8:1.1",
      "pali": "“Vātarogābhinīto tvaṁ,"
    },
    {
      "id": "thag5.8:1.2",
      "pali": "viharaṁ kānane vane;"
    },
    {
      "id": "thag5.8:1.3",
      "pali": "Paviṭṭhagocare lūkhe,"
    },
    {
      "id": "thag5.8:1.4",
      "pali": "kathaṁ bhikkhu karissasi”."
    },
    {
      "id": "thag5.8:2.1",
      "pali": "“Pītisukhena vipulena,"
    },
    {
      "id": "thag5.8:2.2",
      "pali": "pharamāno samussayaṁ;"
    },
    {
      "id": "thag5.8:2.3",
      "pali": "Lūkhampi abhisambhonto,"
    },
    {
      "id": "thag5.8:2.4",
      "pali": "viharissāmi kānane."
    },
    {
      "id": "thag5.8:3.1",
      "pali": "Bhāvento satipaṭṭhāne,"
    },
    {
      "id": "thag5.8:3.2",
      "pali": "indriyāni balāni ca;"
    },
    {
      "id": "thag5.8:3.3",
      "pali": "Bojjhaṅgāni ca bhāvento,"
    },
    {
      "id": "thag5.8:3.4",
      "pali": "viharissāmi kānane."
    },
    {
      "id": "thag5.8:4.1",
      "pali": "Āraddhavīriye pahitatte,"
    },
    {
      "id": "thag5.8:4.2",
      "pali": "Niccaṁ daḷhaparakkame;"
    },
    {
      "id": "thag5.8:4.3",
      "pali": "Samagge sahite disvā,"
    },
    {
      "id": "thag5.8:4.4",
      "pali": "Viharissāmi kānane."
    },
    {
      "id": "thag5.8:5.1",
      "pali": "Anussaranto sambuddhaṁ,"
    },
    {
      "id": "thag5.8:5.2",
      "pali": "aggaṁ dantaṁ samāhitaṁ;"
    },
    {
      "id": "thag5.8:5.3",
      "pali": "Atandito rattindivaṁ,"
    },
    {
      "id": "thag5.8:5.4",
      "pali": "viharissāmi kānane”ti."
    },
    {
      "id": "thag5.8:5.5",
      "pali": "… Vakkalitthero …."
    }
  ]
}
