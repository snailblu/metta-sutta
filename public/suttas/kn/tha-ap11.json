{
  "uid": "tha-ap11",
  "title": "Khadiravaniyarevatattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap11:1.1",
      "pali": "“Gaṅgā bhāgīrathī nāma,"
    },
    {
      "id": "tha-ap11:1.2",
      "pali": "himavantā pabhāvitā;"
    },
    {
      "id": "tha-ap11:1.3",
      "pali": "Kutitthe nāviko āsiṁ,"
    },
    {
      "id": "tha-ap11:1.4",
      "pali": "orime ca tariṁ ahaṁ."
    },
    {
      "id": "tha-ap11:2.1",
      "pali": "Padumuttaro nāyako,"
    },
    {
      "id": "tha-ap11:2.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "tha-ap11:2.3",
      "pali": "Vasī satasahassehi,"
    },
    {
      "id": "tha-ap11:2.4",
      "pali": "gaṅgātīramupāgato."
    },
    {
      "id": "tha-ap11:3.1",
      "pali": "Bahū nāvā samānetvā,"
    },
    {
      "id": "tha-ap11:3.2",
      "pali": "vaḍḍhakīhi susaṅkhataṁ;"
    },
    {
      "id": "tha-ap11:3.3",
      "pali": "Nāvāya chadanaṁ katvā,"
    },
    {
      "id": "tha-ap11:3.4",
      "pali": "paṭimāniṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap11:4.1",
      "pali": "Āgantvāna ca sambuddho,"
    },
    {
      "id": "tha-ap11:4.2",
      "pali": "ārūhi tañca nāvakaṁ;"
    },
    {
      "id": "tha-ap11:4.3",
      "pali": "Vārimajjhe ṭhito satthā,"
    },
    {
      "id": "tha-ap11:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap11:5.1",
      "pali": "‘Yo so tāresi sambuddhaṁ,"
    },
    {
      "id": "tha-ap11:5.2",
      "pali": "saṅghañcāpi anāsavaṁ;"
    },
    {
      "id": "tha-ap11:5.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap11:5.4",
      "pali": "devaloke ramissati."
    },
    {
      "id": "tha-ap11:6.1",
      "pali": "Nibbattissati te byamhaṁ,"
    },
    {
      "id": "tha-ap11:6.2",
      "pali": "sukataṁ nāvasaṇṭhitaṁ;"
    },
    {
      "id": "tha-ap11:6.3",
      "pali": "Ākāse pupphachadanaṁ,"
    },
    {
      "id": "tha-ap11:6.4",
      "pali": "dhārayissati sabbadā."
    },
    {
      "id": "tha-ap11:7.1",
      "pali": "Aṭṭhapaññāsakappamhi,"
    },
    {
      "id": "tha-ap11:7.2",
      "pali": "tārako nāma khattiyo;"
    },
    {
      "id": "tha-ap11:7.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap11:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap11:8.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap11:8.2",
      "pali": "cammako nāma khattiyo;"
    },
    {
      "id": "tha-ap11:8.3",
      "pali": "Uggacchantova sūriyo,"
    },
    {
      "id": "tha-ap11:8.4",
      "pali": "jotissati mahabbalo."
    },
    {
      "id": "tha-ap11:9.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap11:9.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap11:9.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap11:9.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap11:10.1",
      "pali": "Tidasā so cavitvāna,"
    },
    {
      "id": "tha-ap11:10.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap11:10.3",
      "pali": "Revato nāma nāmena,"
    },
    {
      "id": "tha-ap11:10.4",
      "pali": "brahmabandhu bhavissati."
    },
    {
      "id": "tha-ap11:11.1",
      "pali": "Agārā nikkhamitvāna,"
    },
    {
      "id": "tha-ap11:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap11:11.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap11:11.4",
      "pali": "sāsane pabbajissati."
    },
    {
      "id": "tha-ap11:12.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap11:12.2",
      "pali": "yuttayogo vipassako;"
    },
    {
      "id": "tha-ap11:12.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap11:12.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap11:13.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "tha-ap11:13.2",
      "pali": "Yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "tha-ap11:13.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap11:13.4",
      "pali": "Sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap11:14.1",
      "pali": "Satasahasse kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap11:14.2",
      "pali": "phalaṁ dassesi me idha;"
    },
    {
      "id": "tha-ap11:14.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap11:14.4",
      "pali": "kilese jhāpayī mama."
    },
    {
      "id": "tha-ap11:15.1",
      "pali": "Tato maṁ vananirataṁ,"
    },
    {
      "id": "tha-ap11:15.2",
      "pali": "disvā lokantagū muni;"
    },
    {
      "id": "tha-ap11:15.3",
      "pali": "Vanavāsibhikkhūnaggaṁ,"
    },
    {
      "id": "tha-ap11:15.4",
      "pali": "paññapesi mahāmati."
    },
    {
      "id": "tha-ap11:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap11:16.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap11:16.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap11:16.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap11:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā khadiravaniyo revato thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap11:18.1",
      "pali": "Khadiravaniyarevatattherassāpadānaṁ navamaṁ."
    }
  ]
}
