{
  "uid": "thag1.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.9:1.1",
      "pali": "“Svāgataṁ na durāgataṁ,"
    },
    {
      "id": "thag1.9:1.2",
      "pali": "Nayidaṁ dumantitaṁ mama;"
    },
    {
      "id": "thag1.9:1.3",
      "pali": "Saṁvibhattesu dhammesu,"
    },
    {
      "id": "thag1.9:1.4",
      "pali": "Yaṁ seṭṭhaṁ tadupāgamin”ti."
    },
    {
      "id": "thag1.9:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā pilindavaccho thero gāthaṁ abhāsitthāti."
    }
  ]
}
