{
  "uid": "ja241",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja241:1.1",
      "pali": "“Siṅgālo mānathaddho ca,"
    },
    {
      "id": "ja241:1.2",
      "pali": "parivārena atthiko;"
    },
    {
      "id": "ja241:1.3",
      "pali": "Pāpuṇi mahatiṁ bhūmiṁ,"
    },
    {
      "id": "ja241:1.4",
      "pali": "rājāsi sabbadāṭhinaṁ."
    },
    {
      "id": "ja241:2.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja241:2.2",
      "pali": "yo hoti parivāravā;"
    },
    {
      "id": "ja241:2.3",
      "pali": "So hi tattha mahā hoti,"
    },
    {
      "id": "ja241:2.4",
      "pali": "siṅgālo viya dāṭhinan”ti."
    },
    {
      "id": "ja241:3.1",
      "pali": "Sabbadāṭhijātakaṁ paṭhamaṁ."
    }
  ]
}
