{
  "uid": "iti101",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti101:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti101:2.1",
      "pali": "“Cattārimāni, bhikkhave, appāni ceva sulabhāni ca, tāni ca anavajjāni."
    },
    {
      "id": "iti101:2.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "iti101:2.3",
      "pali": "Paṁsukūlaṁ, bhikkhave, cīvarānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "iti101:2.4",
      "pali": "Piṇḍiyālopo, bhikkhave, bhojanānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "iti101:2.5",
      "pali": "Rukkhamūlaṁ, bhikkhave, senāsanānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "iti101:2.6",
      "pali": "Pūtimuttaṁ, bhikkhave, bhesajjānaṁ appañca sulabhañca tañca anavajjaṁ."
    },
    {
      "id": "iti101:2.7",
      "pali": "Imāni kho, bhikkhave, cattāri appāni ceva sulabhāni ca, tāni ca anavajjāni."
    },
    {
      "id": "iti101:2.8",
      "pali": "Yato kho, bhikkhave, bhikkhu appena ca tuṭṭho hoti sulabhena ca anavajjena ca, idamassāhaṁ aññataraṁ sāmaññaṅganti vadāmī”ti."
    },
    {
      "id": "iti101:2.9",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti101:2.10",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti101:3.1",
      "pali": "“Anavajjena tuṭṭhassa,"
    },
    {
      "id": "iti101:3.2",
      "pali": "appena sulabhena ca;"
    },
    {
      "id": "iti101:3.3",
      "pali": "Na senāsanamārabbha,"
    },
    {
      "id": "iti101:3.4",
      "pali": "cīvaraṁ pānabhojanaṁ;"
    },
    {
      "id": "iti101:3.5",
      "pali": "Vighāto hoti cittassa,"
    },
    {
      "id": "iti101:3.6",
      "pali": "disā nappaṭihaññati."
    },
    {
      "id": "iti101:4.1",
      "pali": "Ye cassa dhammā akkhātā,"
    },
    {
      "id": "iti101:4.2",
      "pali": "sāmaññassānulomikā;"
    },
    {
      "id": "iti101:4.3",
      "pali": "Adhiggahitā tuṭṭhassa,"
    },
    {
      "id": "iti101:4.4",
      "pali": "appamattassa bhikkhuno”ti."
    },
    {
      "id": "iti101:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti101:5.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
