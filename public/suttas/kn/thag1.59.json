{
  "uid": "thag1.59",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.59:1.1",
      "pali": "“Saddhāyāhaṁ pabbajito,"
    },
    {
      "id": "thag1.59:1.2",
      "pali": "araññe me kuṭikā katā;"
    },
    {
      "id": "thag1.59:1.3",
      "pali": "Appamatto ca ātāpī,"
    },
    {
      "id": "thag1.59:1.4",
      "pali": "sampajāno patissato”ti."
    },
    {
      "id": "thag1.59:1.5",
      "pali": "… Kosalavihāritthero …."
    }
  ]
}
