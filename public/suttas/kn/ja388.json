{
  "uid": "ja388",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja388:1.1",
      "pali": "“Navachannake dāni diyyati,"
    },
    {
      "id": "ja388:1.2",
      "pali": "Puṇṇāyaṁ doṇi suvāminī ṭhitā;"
    },
    {
      "id": "ja388:1.3",
      "pali": "Bahuke jane pāsapāṇike,"
    },
    {
      "id": "ja388:1.4",
      "pali": "No ca kho me paṭibhāti bhuñjituṁ”."
    },
    {
      "id": "ja388:2.1",
      "pali": "“Tasasi bhamasi leṇamicchasi,"
    },
    {
      "id": "ja388:2.2",
      "pali": "Attāṇosi kuhiṁ gamissasi;"
    },
    {
      "id": "ja388:2.3",
      "pali": "Appossukko bhuñja tuṇḍila,"
    },
    {
      "id": "ja388:2.4",
      "pali": "Maṁsatthāya hi positāmhase."
    },
    {
      "id": "ja388:3.1",
      "pali": "Ogaha rahadaṁ akaddamaṁ,"
    },
    {
      "id": "ja388:3.2",
      "pali": "Sabbaṁ sedamalaṁ pavāhaya;"
    },
    {
      "id": "ja388:3.3",
      "pali": "Gaṇhāhi navaṁ vilepanaṁ,"
    },
    {
      "id": "ja388:3.4",
      "pali": "Yassa gandho na kadāci chijjati”."
    },
    {
      "id": "ja388:4.1",
      "pali": "“Katamo rahado akaddamo,"
    },
    {
      "id": "ja388:4.2",
      "pali": "Kiṁsu sedamalanti vuccati;"
    },
    {
      "id": "ja388:4.3",
      "pali": "Katamañca navaṁ vilepanaṁ,"
    },
    {
      "id": "ja388:4.4",
      "pali": "Yassa gandho na kadāci chijjati”."
    },
    {
      "id": "ja388:5.1",
      "pali": "“Dhammo rahado akaddamo,"
    },
    {
      "id": "ja388:5.2",
      "pali": "Pāpaṁ sedamalanti vuccati;"
    },
    {
      "id": "ja388:5.3",
      "pali": "Sīlañca navaṁ vilepanaṁ,"
    },
    {
      "id": "ja388:5.4",
      "pali": "Tassa gandho na kadāci chijjati."
    },
    {
      "id": "ja388:6.1",
      "pali": "Nandanti sarīraghātino,"
    },
    {
      "id": "ja388:6.2",
      "pali": "Na ca nandanti sarīradhārino;"
    },
    {
      "id": "ja388:6.3",
      "pali": "Puṇṇāya ca puṇṇamāsiyā,"
    },
    {
      "id": "ja388:6.4",
      "pali": "Ramamānāva jahanti jīvitan”ti."
    },
    {
      "id": "ja388:7.1",
      "pali": "Tuṇḍilajātakaṁ tatiyaṁ."
    }
  ]
}
