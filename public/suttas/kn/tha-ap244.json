{
  "uid": "tha-ap244",
  "title": "Nāgakesariyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap244:1.1",
      "pali": "“Dhanuṁ advejjhaṁ katvāna,"
    },
    {
      "id": "tha-ap244:1.2",
      "pali": "vanamajjhogahiṁ ahaṁ;"
    },
    {
      "id": "tha-ap244:1.3",
      "pali": "Kesaraṁ ogataṁ disvā,"
    },
    {
      "id": "tha-ap244:1.4",
      "pali": "patapattaṁ samuṭṭhitaṁ."
    },
    {
      "id": "tha-ap244:2.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap244:2.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap244:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap244:2.4",
      "pali": "tissassa lokabandhuno."
    },
    {
      "id": "tha-ap244:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap244:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap244:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap244:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap244:4.1",
      "pali": "Tesattatimhi kappamhi,"
    },
    {
      "id": "tha-ap244:4.2",
      "pali": "satta kesaranāmakā;"
    },
    {
      "id": "tha-ap244:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap244:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap244:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap244:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap244:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap244:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāgakesariyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap244:7.1",
      "pali": "Nāgakesariyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
