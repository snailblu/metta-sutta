{
  "uid": "vv70",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv70:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv70:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv70:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv70:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv70:2.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv70:2.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv70:2.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv70:2.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv70:3.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv70:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv70:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv70:4.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv70:4.2",
      "pali": "Disvāna bhikkhuṁ tasitaṁ kilantaṁ;"
    },
    {
      "id": "vv70:4.3",
      "pali": "Ekāhaṁ bhikkhaṁ paṭipādayissaṁ,"
    },
    {
      "id": "vv70:4.4",
      "pali": "Samaṅgi bhattena tadā akāsiṁ."
    },
    {
      "id": "vv70:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv70:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv70:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv70:6.1",
      "pali": "Bhikkhādāyakavimānaṁ chaṭṭhaṁ."
    }
  ]
}
