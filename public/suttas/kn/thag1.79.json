{
  "uid": "thag1.79",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.79:1.1",
      "pali": "“Sabbo rāgo pahīno me,"
    },
    {
      "id": "thag1.79:1.2",
      "pali": "sabbo doso samūhato;"
    },
    {
      "id": "thag1.79:1.3",
      "pali": "Sabbo me vigato moho,"
    },
    {
      "id": "thag1.79:1.4",
      "pali": "sītibhūtosmi nibbuto”ti."
    },
    {
      "id": "thag1.79:1.5",
      "pali": "… Rakkhito thero …."
    }
  ]
}
