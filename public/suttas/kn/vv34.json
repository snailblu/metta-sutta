{
  "uid": "vv34",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv34:1.1",
      "pali": "“Daddallamānā vaṇṇena,"
    },
    {
      "id": "vv34:1.2",
      "pali": "yasasā ca yasassinī;"
    },
    {
      "id": "vv34:1.3",
      "pali": "Sabbe deve tāvatiṁse,"
    },
    {
      "id": "vv34:1.4",
      "pali": "vaṇṇena atirocasi."
    },
    {
      "id": "vv34:2.1",
      "pali": "Dassanaṁ nābhijānāmi,"
    },
    {
      "id": "vv34:2.2",
      "pali": "idaṁ paṭhamadassanaṁ;"
    },
    {
      "id": "vv34:2.3",
      "pali": "Kasmā kāyā nu āgamma,"
    },
    {
      "id": "vv34:2.4",
      "pali": "nāmena bhāsase maman”ti."
    },
    {
      "id": "vv34:3.1",
      "pali": "“Ahaṁ bhadde subhaddāsiṁ,"
    },
    {
      "id": "vv34:3.2",
      "pali": "pubbe mānusake bhave;"
    },
    {
      "id": "vv34:3.3",
      "pali": "Sahabhariyā ca te āsiṁ,"
    },
    {
      "id": "vv34:3.4",
      "pali": "bhaginī ca kaniṭṭhikā."
    },
    {
      "id": "vv34:4.1",
      "pali": "Sā ahaṁ kāyassa bhedā,"
    },
    {
      "id": "vv34:4.2",
      "pali": "vippamuttā tato cutā;"
    },
    {
      "id": "vv34:4.3",
      "pali": "Nimmānaratīnaṁ devānaṁ,"
    },
    {
      "id": "vv34:4.4",
      "pali": "upapannā sahabyatan”ti."
    },
    {
      "id": "vv34:5.1",
      "pali": "“Pahūtakatakalyāṇā,"
    },
    {
      "id": "vv34:5.2",
      "pali": "te deve yanti pāṇino;"
    },
    {
      "id": "vv34:5.3",
      "pali": "Yesaṁ tvaṁ kittayissasi,"
    },
    {
      "id": "vv34:5.4",
      "pali": "subhadde jātimattano."
    },
    {
      "id": "vv34:6.1",
      "pali": "Atha tvaṁ kena vaṇṇena,"
    },
    {
      "id": "vv34:6.2",
      "pali": "kena vā anusāsitā;"
    },
    {
      "id": "vv34:6.3",
      "pali": "Kīdiseneva dānena,"
    },
    {
      "id": "vv34:6.4",
      "pali": "subbatena yasassinī."
    },
    {
      "id": "vv34:7.1",
      "pali": "Yasaṁ etādisaṁ pattā,"
    },
    {
      "id": "vv34:7.2",
      "pali": "visesaṁ vipulamajjhagā;"
    },
    {
      "id": "vv34:7.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv34:7.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv34:8.1",
      "pali": "“Aṭṭheva piṇḍapātāni,"
    },
    {
      "id": "vv34:8.2",
      "pali": "yaṁ dānaṁ adadaṁ pure;"
    },
    {
      "id": "vv34:8.3",
      "pali": "Dakkhiṇeyyassa saṅghassa,"
    },
    {
      "id": "vv34:8.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv34:9.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv34:9.2",
      "pali": "…pe…"
    },
    {
      "id": "vv34:9.3",
      "pali": "vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv34:10.1",
      "pali": "“Ahaṁ tayā bahutare bhikkhū,"
    },
    {
      "id": "vv34:10.2",
      "pali": "Saññate brahmacārayo;"
    },
    {
      "id": "vv34:10.3",
      "pali": "Tappesiṁ annapānena,"
    },
    {
      "id": "vv34:10.4",
      "pali": "Pasannā sehi pāṇibhi."
    },
    {
      "id": "vv34:11.1",
      "pali": "Tayā bahutaraṁ datvā,"
    },
    {
      "id": "vv34:11.2",
      "pali": "hīnakāyūpagā ahaṁ;"
    },
    {
      "id": "vv34:11.3",
      "pali": "Kathaṁ tvaṁ appataraṁ datvā,"
    },
    {
      "id": "vv34:11.4",
      "pali": "visesaṁ vipulamajjhagā;"
    },
    {
      "id": "vv34:11.5",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv34:11.6",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv34:12.1",
      "pali": "“Manobhāvanīyo bhikkhu,"
    },
    {
      "id": "vv34:12.2",
      "pali": "sandiṭṭho me pure ahu;"
    },
    {
      "id": "vv34:12.3",
      "pali": "Tāhaṁ bhattena nimantesiṁ,"
    },
    {
      "id": "vv34:12.4",
      "pali": "revataṁ attanaṭṭhamaṁ."
    },
    {
      "id": "vv34:13.1",
      "pali": "So me atthapurekkhāro,"
    },
    {
      "id": "vv34:13.2",
      "pali": "anukampāya revato;"
    },
    {
      "id": "vv34:13.3",
      "pali": "Saṅghe dehīti maṁvoca,"
    },
    {
      "id": "vv34:13.4",
      "pali": "tassāhaṁ vacanaṁ kariṁ."
    },
    {
      "id": "vv34:14.1",
      "pali": "Sā dakkhiṇā saṅghagatā,"
    },
    {
      "id": "vv34:14.2",
      "pali": "appameyye patiṭṭhitā;"
    },
    {
      "id": "vv34:14.3",
      "pali": "Puggalesu tayā dinnaṁ,"
    },
    {
      "id": "vv34:14.4",
      "pali": "na taṁ tava mahapphalan”ti."
    },
    {
      "id": "vv34:15.1",
      "pali": "“Idānevāhaṁ jānāmi,"
    },
    {
      "id": "vv34:15.2",
      "pali": "saṅghe dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "vv34:15.3",
      "pali": "Sāhaṁ gantvā manussattaṁ,"
    },
    {
      "id": "vv34:15.4",
      "pali": "vadaññū vītamaccharā;"
    },
    {
      "id": "vv34:15.5",
      "pali": "Saṅghe dānāni dassāmi,"
    },
    {
      "id": "vv34:15.6",
      "pali": "appamattā punappunan”ti."
    },
    {
      "id": "vv34:16.1",
      "pali": "“Kā esā devatā bhadde,"
    },
    {
      "id": "vv34:16.2",
      "pali": "tayā mantayate saha;"
    },
    {
      "id": "vv34:16.3",
      "pali": "Sabbe deve tāvatiṁse,"
    },
    {
      "id": "vv34:16.4",
      "pali": "vaṇṇena atirocatī”ti."
    },
    {
      "id": "vv34:17.1",
      "pali": "“Manussabhūtā devinda,"
    },
    {
      "id": "vv34:17.2",
      "pali": "pubbe mānusake bhave;"
    },
    {
      "id": "vv34:17.3",
      "pali": "Sahabhariyā ca me āsi,"
    },
    {
      "id": "vv34:17.4",
      "pali": "bhaginī ca kaniṭṭhikā;"
    },
    {
      "id": "vv34:17.5",
      "pali": "Saṅghe dānāni datvāna,"
    },
    {
      "id": "vv34:17.6",
      "pali": "katapuññā virocatī”ti."
    },
    {
      "id": "vv34:18.1",
      "pali": "“Dhammena pubbe bhaginī,"
    },
    {
      "id": "vv34:18.2",
      "pali": "tayā bhadde virocati;"
    },
    {
      "id": "vv34:18.3",
      "pali": "Yaṁ saṅghamhi appameyye,"
    },
    {
      "id": "vv34:18.4",
      "pali": "patiṭṭhāpesi dakkhiṇaṁ”."
    },
    {
      "id": "vv34:19.1",
      "pali": "“Pucchito hi mayā buddho,"
    },
    {
      "id": "vv34:19.2",
      "pali": "gijjhakūṭamhi pabbate;"
    },
    {
      "id": "vv34:19.3",
      "pali": "Vipākaṁ saṁvibhāgassa,"
    },
    {
      "id": "vv34:19.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv34:20.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "vv34:20.2",
      "pali": "puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "vv34:20.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "vv34:20.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv34:21.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "vv34:21.2",
      "pali": "jānaṁ kammaphalaṁ sakaṁ;"
    },
    {
      "id": "vv34:21.3",
      "pali": "Vipākaṁ saṁvibhāgassa,"
    },
    {
      "id": "vv34:21.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv34:22.1",
      "pali": "Cattāro ca paṭipannā,"
    },
    {
      "id": "vv34:22.2",
      "pali": "cattāro ca phale ṭhitā;"
    },
    {
      "id": "vv34:22.3",
      "pali": "Esa saṅgho ujubhūto,"
    },
    {
      "id": "vv34:22.4",
      "pali": "paññāsīlasamāhito."
    },
    {
      "id": "vv34:23.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "vv34:23.2",
      "pali": "puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "vv34:23.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "vv34:23.4",
      "pali": "saṅghe dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv34:24.1",
      "pali": "Eso hi saṅgho vipulo mahaggato,"
    },
    {
      "id": "vv34:24.2",
      "pali": "Esappameyyo udadhīva sāgaro;"
    },
    {
      "id": "vv34:24.3",
      "pali": "Ete hi seṭṭhā naravīrasāvakā,"
    },
    {
      "id": "vv34:24.4",
      "pali": "Pabhaṅkarā dhammamudīrayanti."
    },
    {
      "id": "vv34:25.1",
      "pali": "Tesaṁ sudinnaṁ suhutaṁ suyiṭṭhaṁ,"
    },
    {
      "id": "vv34:25.2",
      "pali": "Ye saṅghamuddissa dadanti dānaṁ;"
    },
    {
      "id": "vv34:25.3",
      "pali": "Sā dakkhiṇā saṅghagatā patiṭṭhitā,"
    },
    {
      "id": "vv34:25.4",
      "pali": "Mahapphalā lokavidūna vaṇṇitā."
    },
    {
      "id": "vv34:26.1",
      "pali": "Etādisaṁ yaññamanussarantā,"
    },
    {
      "id": "vv34:26.2",
      "pali": "Ye vedajātā vicaranti loke;"
    },
    {
      "id": "vv34:26.3",
      "pali": "Vineyya maccheramalaṁ samūlaṁ,"
    },
    {
      "id": "vv34:26.4",
      "pali": "Aninditā saggamupenti ṭhānan”ti."
    },
    {
      "id": "vv34:27.1",
      "pali": "Daddallavimānaṁ chaṭṭhaṁ."
    }
  ]
}
