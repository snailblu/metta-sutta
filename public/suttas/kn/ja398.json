{
  "uid": "ja398",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja398:1.1",
      "pali": "“Rājā te bhattaṁ pāhesi,"
    },
    {
      "id": "ja398:1.2",
      "pali": "Suciṁ maṁsūpasecanaṁ;"
    },
    {
      "id": "ja398:1.3",
      "pali": "Maghadevasmiṁ adhivatthe,"
    },
    {
      "id": "ja398:1.4",
      "pali": "Ehi nikkhamma bhuñjasu”."
    },
    {
      "id": "ja398:2.1",
      "pali": "“Ehi māṇava orena,"
    },
    {
      "id": "ja398:2.2",
      "pali": "bhikkhamādāya sūpitaṁ;"
    },
    {
      "id": "ja398:2.3",
      "pali": "Tvañca māṇava bhikkhā ca,"
    },
    {
      "id": "ja398:2.4",
      "pali": "ubho bhakkhā bhavissatha”."
    },
    {
      "id": "ja398:3.1",
      "pali": "“Appakena tuvaṁ yakkha,"
    },
    {
      "id": "ja398:3.2",
      "pali": "thullamatthaṁ jahissasi;"
    },
    {
      "id": "ja398:3.3",
      "pali": "Bhikkhaṁ te nāharissanti,"
    },
    {
      "id": "ja398:3.4",
      "pali": "janā maraṇasaññino."
    },
    {
      "id": "ja398:4.1",
      "pali": "Laddhāya yakkhā tava niccabhikkhaṁ,"
    },
    {
      "id": "ja398:4.2",
      "pali": "Suciṁ paṇītaṁ rasasā upetaṁ;"
    },
    {
      "id": "ja398:4.3",
      "pali": "Bhikkhañca te āhariyo naro idha,"
    },
    {
      "id": "ja398:4.4",
      "pali": "Sudullabho hehiti bhakkhite mayi”."
    },
    {
      "id": "ja398:5.1",
      "pali": "“Mameva sutano attho,"
    },
    {
      "id": "ja398:5.2",
      "pali": "yathā bhāsasi māṇava;"
    },
    {
      "id": "ja398:5.3",
      "pali": "Mayā tvaṁ samanuññāto,"
    },
    {
      "id": "ja398:5.4",
      "pali": "sotthiṁ passāhi mātaraṁ."
    },
    {
      "id": "ja398:6.1",
      "pali": "Khaggaṁ chattañca pātiñca,"
    },
    {
      "id": "ja398:6.2",
      "pali": "gacchamādāya māṇava;"
    },
    {
      "id": "ja398:6.3",
      "pali": "Sotthiṁ passatu te mātā,"
    },
    {
      "id": "ja398:6.4",
      "pali": "tvañca passāhi mātaraṁ”."
    },
    {
      "id": "ja398:7.1",
      "pali": "“Evaṁ yakkha sukhī hohi,"
    },
    {
      "id": "ja398:7.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja398:7.3",
      "pali": "Dhanañca me adhigataṁ,"
    },
    {
      "id": "ja398:7.4",
      "pali": "rañño ca vacanaṁ katan”ti."
    },
    {
      "id": "ja398:8.1",
      "pali": "Sutanujātakaṁ tatiyaṁ."
    }
  ]
}
