{
  "uid": "thig3.2",
  "title": "Uttamātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.2:1.1",
      "pali": "“Catukkhattuṁ pañcakkhattuṁ,"
    },
    {
      "id": "thig3.2:1.2",
      "pali": "vihārā upanikkhamiṁ;"
    },
    {
      "id": "thig3.2:1.3",
      "pali": "Aladdhā cetaso santiṁ,"
    },
    {
      "id": "thig3.2:1.4",
      "pali": "citte avasavattinī."
    },
    {
      "id": "thig3.2:2.1",
      "pali": "Sā bhikkhuniṁ upagacchiṁ,"
    },
    {
      "id": "thig3.2:2.2",
      "pali": "yā me saddhāyikā ahu;"
    },
    {
      "id": "thig3.2:2.3",
      "pali": "Sā me dhammamadesesi,"
    },
    {
      "id": "thig3.2:2.4",
      "pali": "khandhāyatanadhātuyo."
    },
    {
      "id": "thig3.2:3.1",
      "pali": "Tassā dhammaṁ suṇitvāna,"
    },
    {
      "id": "thig3.2:3.2",
      "pali": "Yathā maṁ anusāsi sā;"
    },
    {
      "id": "thig3.2:3.3",
      "pali": "Sattāhaṁ ekapallaṅkena,"
    },
    {
      "id": "thig3.2:3.4",
      "pali": "Nisīdiṁ pītisukhasamappitā;"
    },
    {
      "id": "thig3.2:3.5",
      "pali": "Aṭṭhamiyā pāde pasāresiṁ,"
    },
    {
      "id": "thig3.2:3.6",
      "pali": "Tamokhandhaṁ padāliyā”ti."
    },
    {
      "id": "thig3.2:4.1",
      "pali": "… Uttamā therī …."
    }
  ]
}
