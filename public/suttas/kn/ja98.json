{
  "uid": "ja98",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja98:1.1",
      "pali": "“Sādhu kho paṇḍito nāma,"
    },
    {
      "id": "ja98:1.2",
      "pali": "na tveva atipaṇḍito;"
    },
    {
      "id": "ja98:1.3",
      "pali": "Atipaṇḍitena puttena,"
    },
    {
      "id": "ja98:1.4",
      "pali": "manamhi upakūḷitoti."
    },
    {
      "id": "ja98:2.1",
      "pali": "Kūṭavāṇijajātakaṁ aṭṭhamaṁ."
    }
  ]
}
