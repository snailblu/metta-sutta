{
  "uid": "ja371",
  "title": "Aḍḍhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja371:1.1",
      "pali": "“Evaṁbhūtassa te rāja,"
    },
    {
      "id": "ja371:1.2",
      "pali": "āgatassa vase mama;"
    },
    {
      "id": "ja371:1.3",
      "pali": "Atthi nu koci pariyāyo,"
    },
    {
      "id": "ja371:1.4",
      "pali": "yo taṁ dukkhā pamocaye”."
    },
    {
      "id": "ja371:2.1",
      "pali": "“Evaṁbhūtassa me tāta,"
    },
    {
      "id": "ja371:2.2",
      "pali": "āgatassa vase tava;"
    },
    {
      "id": "ja371:2.3",
      "pali": "Natthi no koci pariyāyo,"
    },
    {
      "id": "ja371:2.4",
      "pali": "yo maṁ dukkhā pamocaye”."
    },
    {
      "id": "ja371:3.1",
      "pali": "“Nāññaṁ sucaritaṁ rāja,"
    },
    {
      "id": "ja371:3.2",
      "pali": "nāññaṁ rāja subhāsitaṁ;"
    },
    {
      "id": "ja371:3.3",
      "pali": "Tāyate maraṇakāle,"
    },
    {
      "id": "ja371:3.4",
      "pali": "evamevitaraṁ dhanaṁ."
    },
    {
      "id": "ja371:4.1",
      "pali": "Akkocchi maṁ avadhi maṁ,"
    },
    {
      "id": "ja371:4.2",
      "pali": "ajini maṁ ahāsi me;"
    },
    {
      "id": "ja371:4.3",
      "pali": "Ye ca taṁ upanayhanti,"
    },
    {
      "id": "ja371:4.4",
      "pali": "veraṁ tesaṁ na sammati."
    },
    {
      "id": "ja371:5.1",
      "pali": "Akkocchi maṁ avadhi maṁ,"
    },
    {
      "id": "ja371:5.2",
      "pali": "ajini maṁ ahāsi me;"
    },
    {
      "id": "ja371:5.3",
      "pali": "Ye ca taṁ nupanayhanti,"
    },
    {
      "id": "ja371:5.4",
      "pali": "veraṁ tesūpasammati."
    },
    {
      "id": "ja371:6.1",
      "pali": "Na hi verena verāni,"
    },
    {
      "id": "ja371:6.2",
      "pali": "sammantīdha kudācanaṁ;"
    },
    {
      "id": "ja371:6.3",
      "pali": "Averena ca sammanti,"
    },
    {
      "id": "ja371:6.4",
      "pali": "esa dhammo sanantano”ti."
    },
    {
      "id": "ja371:7.1",
      "pali": "Dīghītikosalajātakaṁ paṭhamaṁ."
    }
  ]
}
