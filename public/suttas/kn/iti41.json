{
  "uid": "iti41",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti41:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti41:2.1",
      "pali": "“Te, bhikkhave, sattā suparihīnā ye ariyāya paññāya parihīnā."
    },
    {
      "id": "iti41:2.2",
      "pali": "Te diṭṭheva dhamme dukkhaṁ viharanti savighātaṁ saupāyāsaṁ sapariḷāhaṁ;"
    },
    {
      "id": "iti41:2.3",
      "pali": "kāyassa bhedā paraṁ maraṇā duggati pāṭikaṅkhā."
    },
    {
      "id": "iti41:2.4",
      "pali": "Te, bhikkhave, sattā aparihīnā ye ariyāya paññāya aparihīnā."
    },
    {
      "id": "iti41:2.5",
      "pali": "Te diṭṭheva dhamme sukhaṁ viharanti avighātaṁ anupāyāsaṁ apariḷāhaṁ;"
    },
    {
      "id": "iti41:2.6",
      "pali": "kāyassa bhedā paraṁ maraṇā sugati pāṭikaṅkhā”ti."
    },
    {
      "id": "iti41:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti41:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti41:3.1",
      "pali": "“Paññāya parihānena,"
    },
    {
      "id": "iti41:3.2",
      "pali": "passa lokaṁ sadevakaṁ;"
    },
    {
      "id": "iti41:3.3",
      "pali": "Niviṭṭhaṁ nāmarūpasmiṁ,"
    },
    {
      "id": "iti41:3.4",
      "pali": "idaṁ saccanti maññati."
    },
    {
      "id": "iti41:4.1",
      "pali": "Paññā hi seṭṭhā lokasmiṁ,"
    },
    {
      "id": "iti41:4.2",
      "pali": "yāyaṁ nibbedhagāminī;"
    },
    {
      "id": "iti41:4.3",
      "pali": "Yāya sammā pajānāti,"
    },
    {
      "id": "iti41:4.4",
      "pali": "jātibhavaparikkhayaṁ."
    },
    {
      "id": "iti41:5.1",
      "pali": "Tesaṁ devā manussā ca,"
    },
    {
      "id": "iti41:5.2",
      "pali": "sambuddhānaṁ satīmataṁ;"
    },
    {
      "id": "iti41:5.3",
      "pali": "Pihayanti hāsapaññānaṁ,"
    },
    {
      "id": "iti41:5.4",
      "pali": "sarīrantimadhārinan”ti."
    },
    {
      "id": "iti41:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti41:6.2",
      "pali": "Catutthaṁ."
    }
  ]
}
