{
  "uid": "tha-ap149",
  "title": "Maggadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap149:1.1",
      "pali": "“Uttaritvāna nadikaṁ,"
    },
    {
      "id": "tha-ap149:1.2",
      "pali": "vanaṁ gacchati cakkhumā;"
    },
    {
      "id": "tha-ap149:1.3",
      "pali": "Tamaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap149:1.4",
      "pali": "siddhatthaṁ varalakkhaṇaṁ."
    },
    {
      "id": "tha-ap149:2.1",
      "pali": "Kudāla piṭakamādāya,"
    },
    {
      "id": "tha-ap149:2.2",
      "pali": "samaṁ katvāna taṁ pathaṁ;"
    },
    {
      "id": "tha-ap149:2.3",
      "pali": "Satthāraṁ abhivādetvā,"
    },
    {
      "id": "tha-ap149:2.4",
      "pali": "sakaṁ cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap149:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap149:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap149:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap149:3.4",
      "pali": "maggadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap149:4.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap149:4.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap149:4.3",
      "pali": "Nāmena suppabuddhoti,"
    },
    {
      "id": "tha-ap149:4.4",
      "pali": "nāyako so narissaro."
    },
    {
      "id": "tha-ap149:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap149:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap149:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap149:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā maggadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap149:7.1",
      "pali": "Maggadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
