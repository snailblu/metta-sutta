{
  "uid": "ja105",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja105:1.1",
      "pali": "“Bahumpetaṁ vane kaṭṭhaṁ,"
    },
    {
      "id": "ja105:1.2",
      "pali": "vāto bhañjati dubbalaṁ;"
    },
    {
      "id": "ja105:1.3",
      "pali": "Tassa ce bhāyasī nāga,"
    },
    {
      "id": "ja105:1.4",
      "pali": "kiso nūna bhavissasī”ti."
    },
    {
      "id": "ja105:2.1",
      "pali": "Dubbalakaṭṭhajātakaṁ pañcamaṁ."
    }
  ]
}
