{
  "uid": "ja288",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja288:1.1",
      "pali": "“Agghanti macchā adhikaṁ sahassaṁ,"
    },
    {
      "id": "ja288:1.2",
      "pali": "Na so atthi yo imaṁ saddaheyya;"
    },
    {
      "id": "ja288:1.3",
      "pali": "Mayhañca assu idha satta māsā,"
    },
    {
      "id": "ja288:1.4",
      "pali": "Ahampi taṁ macchuddānaṁ kiṇeyyaṁ”."
    },
    {
      "id": "ja288:2.1",
      "pali": "“Macchānaṁ bhojanaṁ datvā,"
    },
    {
      "id": "ja288:2.2",
      "pali": "mama dakkhiṇamādisi;"
    },
    {
      "id": "ja288:2.3",
      "pali": "Taṁ dakkhiṇaṁ sarantiyā,"
    },
    {
      "id": "ja288:2.4",
      "pali": "kataṁ apacitiṁ tayā”."
    },
    {
      "id": "ja288:3.1",
      "pali": "“Paduṭṭhacittassa na phāti hoti,"
    },
    {
      "id": "ja288:3.2",
      "pali": "Na cāpi taṁ devatā pūjayanti;"
    },
    {
      "id": "ja288:3.3",
      "pali": "Yo bhātaraṁ pettikaṁ sāpateyyaṁ,"
    },
    {
      "id": "ja288:3.4",
      "pali": "Avañcayī dukkaṭakammakārī”ti."
    },
    {
      "id": "ja288:4.1",
      "pali": "Macchuddānajātakaṁ aṭṭhamaṁ."
    }
  ]
}
