{
  "uid": "tha-ap388",
  "title": "Valliphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap388:1.1",
      "pali": "“Sabbe janā samāgamma,"
    },
    {
      "id": "tha-ap388:1.2",
      "pali": "agamiṁsu vanaṁ tadā;"
    },
    {
      "id": "tha-ap388:1.3",
      "pali": "Phalamanvesamānā te,"
    },
    {
      "id": "tha-ap388:1.4",
      "pali": "alabhiṁsu phalaṁ tadā."
    },
    {
      "id": "tha-ap388:2.1",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap388:2.2",
      "pali": "sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap388:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap388:2.4",
      "pali": "valliphalamadāsahaṁ."
    },
    {
      "id": "tha-ap388:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap388:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap388:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap388:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap388:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap388:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap388:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap388:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap388:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap388:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap388:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap388:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap388:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap388:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā valliphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap388:8.1",
      "pali": "Valliphaladāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
