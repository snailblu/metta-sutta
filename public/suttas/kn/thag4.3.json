{
  "uid": "thag4.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.3:1.1",
      "pali": "“Pare ca na vijānanti,"
    },
    {
      "id": "thag4.3:1.2",
      "pali": "mayamettha yamāmase;"
    },
    {
      "id": "thag4.3:1.3",
      "pali": "Ye ca tattha vijānanti,"
    },
    {
      "id": "thag4.3:1.4",
      "pali": "tato sammanti medhagā."
    },
    {
      "id": "thag4.3:2.1",
      "pali": "Yadā ca avijānantā,"
    },
    {
      "id": "thag4.3:2.2",
      "pali": "iriyantyamarā viya;"
    },
    {
      "id": "thag4.3:2.3",
      "pali": "Vijānanti ca ye dhammaṁ,"
    },
    {
      "id": "thag4.3:2.4",
      "pali": "āturesu anāturā."
    },
    {
      "id": "thag4.3:3.1",
      "pali": "Yaṁ kiñci sithilaṁ kammaṁ,"
    },
    {
      "id": "thag4.3:3.2",
      "pali": "saṅkiliṭṭhañca yaṁ vataṁ;"
    },
    {
      "id": "thag4.3:3.3",
      "pali": "Saṅkassaraṁ brahmacariyaṁ,"
    },
    {
      "id": "thag4.3:3.4",
      "pali": "na taṁ hoti mahapphalaṁ."
    },
    {
      "id": "thag4.3:4.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag4.3:4.2",
      "pali": "gāravo nūpalabbhati;"
    },
    {
      "id": "thag4.3:4.3",
      "pali": "Ārakā hoti saddhammā,"
    },
    {
      "id": "thag4.3:4.4",
      "pali": "nabhaṁ puthaviyā yathā”ti."
    },
    {
      "id": "thag4.3:4.5",
      "pali": "… Sabhiyo thero …."
    }
  ]
}
