{
  "uid": "iti77",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti77:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti77:2.1",
      "pali": "“Bhidurāyaṁ, bhikkhave, kāyo, viññāṇaṁ virāgadhammaṁ, sabbe upadhī aniccā dukkhā vipariṇāmadhammā”ti."
    },
    {
      "id": "iti77:2.2",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti77:2.3",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti77:3.1",
      "pali": "“Kāyañca bhiduraṁ ñatvā,"
    },
    {
      "id": "iti77:3.2",
      "pali": "Viññāṇañca virāgunaṁ;"
    },
    {
      "id": "iti77:3.3",
      "pali": "Upadhīsu bhayaṁ disvā,"
    },
    {
      "id": "iti77:3.4",
      "pali": "Jātimaraṇamaccagā;"
    },
    {
      "id": "iti77:3.5",
      "pali": "Sampatvā paramaṁ santiṁ,"
    },
    {
      "id": "iti77:3.6",
      "pali": "Kālaṁ kaṅkhati bhāvitatto”ti."
    },
    {
      "id": "iti77:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti77:4.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
