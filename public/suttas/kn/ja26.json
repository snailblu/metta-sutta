{
  "uid": "ja26",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja26:1.1",
      "pali": "“Purāṇacorāna vaco nisamma,"
    },
    {
      "id": "ja26:1.2",
      "pali": "Mahiḷāmukho pothayamanvacārī;"
    },
    {
      "id": "ja26:1.3",
      "pali": "Susaññatānañhi vaco nisamma,"
    },
    {
      "id": "ja26:1.4",
      "pali": "Gajuttamo sabbaguṇesu aṭṭhā”ti."
    },
    {
      "id": "ja26:2.1",
      "pali": "Mahiḷāmukhajātakaṁ chaṭṭhaṁ."
    }
  ]
}
