{
  "uid": "thag1.76",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.76:1.1",
      "pali": "“Uppatantesu nipate,"
    },
    {
      "id": "thag1.76:1.2",
      "pali": "nipatantesu uppate;"
    },
    {
      "id": "thag1.76:1.3",
      "pali": "Vase avasamānesu,"
    },
    {
      "id": "thag1.76:1.4",
      "pali": "ramamānesu no rame”ti."
    },
    {
      "id": "thag1.76:1.5",
      "pali": "… Piyañjaho thero …."
    }
  ]
}
