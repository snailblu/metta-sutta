{
  "uid": "tha-ap527",
  "title": "Supaṭadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap527:1.1",
      "pali": "“Divāvihārā nikkhanto,"
    },
    {
      "id": "tha-ap527:1.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "tha-ap527:1.3",
      "pali": "Lahuṁ supaṭakaṁ datvā,"
    },
    {
      "id": "tha-ap527:1.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap527:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap527:2.2",
      "pali": "supaṭakamadāsahaṁ;"
    },
    {
      "id": "tha-ap527:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap527:2.4",
      "pali": "supaṭassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap527:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap527:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap527:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap527:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap527:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap527:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap527:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap527:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap527:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap527:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā supaṭadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap527:7.1",
      "pali": "Supaṭadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
