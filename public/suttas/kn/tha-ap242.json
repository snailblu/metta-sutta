{
  "uid": "tha-ap242",
  "title": "Vāsidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap242:1.1",
      "pali": "“Kammārohaṁ pure āsiṁ,"
    },
    {
      "id": "tha-ap242:1.2",
      "pali": "tivarāyaṁ puruttame;"
    },
    {
      "id": "tha-ap242:1.3",
      "pali": "Ekā vāsi mayā dinnā,"
    },
    {
      "id": "tha-ap242:1.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "tha-ap242:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap242:2.2",
      "pali": "yaṁ vāsimadadiṁ tadā;"
    },
    {
      "id": "tha-ap242:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap242:2.4",
      "pali": "vāsidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap242:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap242:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap242:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap242:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā vāsidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap242:5.1",
      "pali": "Vāsidāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap242:6.1",
      "pali": "Udakāsanavaggo catuvīsatimo."
    },
    {
      "id": "tha-ap242:7.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap242:8.1",
      "pali": "Udakāsanabhājanaṁ,"
    },
    {
      "id": "tha-ap242:8.2",
      "pali": "sālapupphī kilañjako;"
    },
    {
      "id": "tha-ap242:8.3",
      "pali": "Vedikā vaṇṇakāro ca,"
    },
    {
      "id": "tha-ap242:8.4",
      "pali": "piyālaambayāgado;"
    },
    {
      "id": "tha-ap242:8.5",
      "pali": "Jagatī vāsidātā ca,"
    },
    {
      "id": "tha-ap242:8.6",
      "pali": "gāthā tiṁsa ca aṭṭha ca."
    }
  ]
}
