{
  "uid": "thag4.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.2:1.1",
      "pali": "“Ahaṁ middhena pakato,"
    },
    {
      "id": "thag4.2:1.2",
      "pali": "vihārā upanikkhamiṁ;"
    },
    {
      "id": "thag4.2:1.3",
      "pali": "Caṅkamaṁ abhiruhanto,"
    },
    {
      "id": "thag4.2:1.4",
      "pali": "tattheva papatiṁ chamā."
    },
    {
      "id": "thag4.2:2.1",
      "pali": "Gattāni parimajjitvā,"
    },
    {
      "id": "thag4.2:2.2",
      "pali": "punapāruyha caṅkamaṁ;"
    },
    {
      "id": "thag4.2:2.3",
      "pali": "Caṅkame caṅkamiṁ sohaṁ,"
    },
    {
      "id": "thag4.2:2.4",
      "pali": "ajjhattaṁ susamāhito."
    },
    {
      "id": "thag4.2:3.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag4.2:3.2",
      "pali": "yoniso udapajjatha;"
    },
    {
      "id": "thag4.2:3.3",
      "pali": "Ādīnavo pāturahu,"
    },
    {
      "id": "thag4.2:3.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag4.2:4.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag4.2:4.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag4.2:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag4.2:4.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag4.2:4.5",
      "pali": "… Bhagutthero …."
    }
  ]
}
