{
  "uid": "ja323",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja323:1.1",
      "pali": "“Dvayaṁ yācanako rāja,"
    },
    {
      "id": "ja323:1.2",
      "pali": "brahmadatta nigacchati;"
    },
    {
      "id": "ja323:1.3",
      "pali": "Alābhaṁ dhanalābhaṁ vā,"
    },
    {
      "id": "ja323:1.4",
      "pali": "evaṁ dhammā hi yācanā."
    },
    {
      "id": "ja323:2.1",
      "pali": "Yācanaṁ rodanaṁ āhu,"
    },
    {
      "id": "ja323:2.2",
      "pali": "pañcālānaṁ rathesabha;"
    },
    {
      "id": "ja323:2.3",
      "pali": "Yo yācanaṁ paccakkhāti,"
    },
    {
      "id": "ja323:2.4",
      "pali": "tamāhu paṭirodanaṁ."
    },
    {
      "id": "ja323:3.1",
      "pali": "Mā maddasaṁsu rodantaṁ,"
    },
    {
      "id": "ja323:3.2",
      "pali": "pañcālā susamāgatā;"
    },
    {
      "id": "ja323:3.3",
      "pali": "Tuvaṁ vā paṭirodantaṁ,"
    },
    {
      "id": "ja323:3.4",
      "pali": "tasmā icchāmahaṁ raho”."
    },
    {
      "id": "ja323:4.1",
      "pali": "“Dadāmi te brāhmaṇa rohiṇīnaṁ,"
    },
    {
      "id": "ja323:4.2",
      "pali": "Gavaṁ sahassaṁ saha puṅgavena;"
    },
    {
      "id": "ja323:4.3",
      "pali": "Ariyo hi ariyassa kathaṁ na dajjā,"
    },
    {
      "id": "ja323:4.4",
      "pali": "Sutvāna gāthā tava dhammayuttā”ti."
    },
    {
      "id": "ja323:5.1",
      "pali": "Brahmadattajātakaṁ tatiyaṁ."
    }
  ]
}
