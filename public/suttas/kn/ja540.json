{
  "uid": "ja540",
  "title": "Mūgapakkhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja540:1.1",
      "pali": "“Ko nu maṁ usunā vijjhi,"
    },
    {
      "id": "ja540:1.2",
      "pali": "pamattaṁ udahārakaṁ;"
    },
    {
      "id": "ja540:1.3",
      "pali": "Khattiyo brāhmaṇo vesso,"
    },
    {
      "id": "ja540:1.4",
      "pali": "ko maṁ viddhā nilīyasi."
    },
    {
      "id": "ja540:2.1",
      "pali": "Na me maṁsāni khajjāni,"
    },
    {
      "id": "ja540:2.2",
      "pali": "Cammenattho na vijjati;"
    },
    {
      "id": "ja540:2.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja540:2.4",
      "pali": "Viddheyyaṁ maṁ amaññatha."
    },
    {
      "id": "ja540:3.1",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "ja540:3.2",
      "pali": "kathaṁ jānemu taṁ mayaṁ;"
    },
    {
      "id": "ja540:3.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja540:3.4",
      "pali": "kiṁ maṁ viddhā nilīyasi”."
    },
    {
      "id": "ja540:4.1",
      "pali": "“Rājāhamasmi kāsīnaṁ,"
    },
    {
      "id": "ja540:4.2",
      "pali": "pīḷiyakkhoti maṁ vidū;"
    },
    {
      "id": "ja540:4.3",
      "pali": "Lobhā raṭṭhaṁ pahitvāna,"
    },
    {
      "id": "ja540:4.4",
      "pali": "migamesaṁ carāmahaṁ."
    },
    {
      "id": "ja540:5.1",
      "pali": "Issatthe casmi kusalo,"
    },
    {
      "id": "ja540:5.2",
      "pali": "daḷhadhammoti vissuto;"
    },
    {
      "id": "ja540:5.3",
      "pali": "Nāgopi me na mucceyya,"
    },
    {
      "id": "ja540:5.4",
      "pali": "āgato usupātanaṁ."
    },
    {
      "id": "ja540:6.1",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "ja540:6.2",
      "pali": "kathaṁ jānemu taṁ mayaṁ;"
    },
    {
      "id": "ja540:6.3",
      "pali": "Pituno attano cāpi,"
    },
    {
      "id": "ja540:6.4",
      "pali": "nāmagottaṁ pavedaya”."
    },
    {
      "id": "ja540:7.1",
      "pali": "“Nesādaputto bhaddante,"
    },
    {
      "id": "ja540:7.2",
      "pali": "sāmo iti maṁ ñātayo;"
    },
    {
      "id": "ja540:7.3",
      "pali": "Āmantayiṁsu jīvantaṁ,"
    },
    {
      "id": "ja540:7.4",
      "pali": "svajjevāhaṁ gato saye."
    },
    {
      "id": "ja540:8.1",
      "pali": "Viddhosmi puthusallena,"
    },
    {
      "id": "ja540:8.2",
      "pali": "savisena yathā migo;"
    },
    {
      "id": "ja540:8.3",
      "pali": "Sakamhi lohite rāja,"
    },
    {
      "id": "ja540:8.4",
      "pali": "passa semi paripluto."
    },
    {
      "id": "ja540:9.1",
      "pali": "Paṭivāmagataṁ sallaṁ,"
    },
    {
      "id": "ja540:9.2",
      "pali": "passa dhimhāmi lohitaṁ;"
    },
    {
      "id": "ja540:9.3",
      "pali": "Āturo tyānupucchāmi,"
    },
    {
      "id": "ja540:9.4",
      "pali": "kiṁ maṁ viddhā nilīyasi."
    },
    {
      "id": "ja540:10.1",
      "pali": "Ajinamhi haññate dīpi,"
    },
    {
      "id": "ja540:10.2",
      "pali": "nāgo dantehi haññate;"
    },
    {
      "id": "ja540:10.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja540:10.4",
      "pali": "viddheyyaṁ maṁ amaññatha”."
    },
    {
      "id": "ja540:11.1",
      "pali": "“Migo upaṭṭhito āsi,"
    },
    {
      "id": "ja540:11.2",
      "pali": "āgato usupātanaṁ;"
    },
    {
      "id": "ja540:11.3",
      "pali": "Taṁ disvā ubbijī sāma,"
    },
    {
      "id": "ja540:11.4",
      "pali": "tena kodho mamāvisi”."
    },
    {
      "id": "ja540:12.1",
      "pali": "“Yato sarāmi attānaṁ,"
    },
    {
      "id": "ja540:12.2",
      "pali": "yato pattosmi viññutaṁ;"
    },
    {
      "id": "ja540:12.3",
      "pali": "Na maṁ migā uttasanti,"
    },
    {
      "id": "ja540:12.4",
      "pali": "araññe sāpadānipi."
    },
    {
      "id": "ja540:13.1",
      "pali": "Yato nidhiṁ parihariṁ,"
    },
    {
      "id": "ja540:13.2",
      "pali": "yato pattosmi yobbanaṁ;"
    },
    {
      "id": "ja540:13.3",
      "pali": "Na maṁ migā uttasanti,"
    },
    {
      "id": "ja540:13.4",
      "pali": "araññe sāpadānipi."
    },
    {
      "id": "ja540:14.1",
      "pali": "Bhīrū kimpurisā rāja,"
    },
    {
      "id": "ja540:14.2",
      "pali": "pabbate gandhamādane;"
    },
    {
      "id": "ja540:14.3",
      "pali": "Sammodamānā gacchāma,"
    },
    {
      "id": "ja540:14.4",
      "pali": "pabbatāni vanāni ca."
    },
    {
      "id": "ja540:15.1",
      "pali": "Na maṁ migā uttasanti,"
    },
    {
      "id": "ja540:15.2",
      "pali": "araññe sāpadānipi;"
    },
    {
      "id": "ja540:15.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja540:15.4",
      "pali": "utrāsanti migā mamaṁ”."
    },
    {
      "id": "ja540:16.1",
      "pali": "“Na taṁ tasa migo sāma,"
    },
    {
      "id": "ja540:16.2",
      "pali": "kiṁ tāhaṁ alikaṁ bhaṇe;"
    },
    {
      "id": "ja540:16.3",
      "pali": "Kodhalobhābhibhūtāhaṁ,"
    },
    {
      "id": "ja540:16.4",
      "pali": "usuṁ te taṁ avassajiṁ."
    },
    {
      "id": "ja540:17.1",
      "pali": "Kuto nu sāma āgamma,"
    },
    {
      "id": "ja540:17.2",
      "pali": "kassa vā pahito tuvaṁ;"
    },
    {
      "id": "ja540:17.3",
      "pali": "Udahāro nadiṁ gaccha,"
    },
    {
      "id": "ja540:17.4",
      "pali": "āgato migasammataṁ”."
    },
    {
      "id": "ja540:18.1",
      "pali": "“Andhā mātāpitā mayhaṁ,"
    },
    {
      "id": "ja540:18.2",
      "pali": "te bharāmi brahāvane;"
    },
    {
      "id": "ja540:18.3",
      "pali": "Tesāhaṁ udakāhāro,"
    },
    {
      "id": "ja540:18.4",
      "pali": "āgato migasammataṁ."
    },
    {
      "id": "ja540:19.1",
      "pali": "Atthi nesaṁ usāmattaṁ,"
    },
    {
      "id": "ja540:19.2",
      "pali": "atha sāhassa jīvitaṁ;"
    },
    {
      "id": "ja540:19.3",
      "pali": "Udakassa alābhena,"
    },
    {
      "id": "ja540:19.4",
      "pali": "maññe andhā marissare."
    },
    {
      "id": "ja540:20.1",
      "pali": "Na me idaṁ tathā dukkhaṁ,"
    },
    {
      "id": "ja540:20.2",
      "pali": "labbhā hi pumunā idaṁ;"
    },
    {
      "id": "ja540:20.3",
      "pali": "Yañca ammaṁ na passāmi,"
    },
    {
      "id": "ja540:20.4",
      "pali": "taṁ me dukkhataraṁ ito."
    },
    {
      "id": "ja540:21.1",
      "pali": "Na me idaṁ tathā dukkhaṁ,"
    },
    {
      "id": "ja540:21.2",
      "pali": "labbhā hi pumunā idaṁ;"
    },
    {
      "id": "ja540:21.3",
      "pali": "Yañca tātaṁ na passāmi,"
    },
    {
      "id": "ja540:21.4",
      "pali": "taṁ me dukkhataraṁ ito."
    },
    {
      "id": "ja540:22.1",
      "pali": "Sā nūna kapaṇā ammā,"
    },
    {
      "id": "ja540:22.2",
      "pali": "cirarattāya rucchati;"
    },
    {
      "id": "ja540:22.3",
      "pali": "Aḍḍharatte va ratte vā,"
    },
    {
      "id": "ja540:22.4",
      "pali": "nadīva avasucchati."
    },
    {
      "id": "ja540:23.1",
      "pali": "So nūna kapaṇo tāto,"
    },
    {
      "id": "ja540:23.2",
      "pali": "cirarattāya rucchati;"
    },
    {
      "id": "ja540:23.3",
      "pali": "Aḍḍharatte va ratte vā,"
    },
    {
      "id": "ja540:23.4",
      "pali": "nadīva avasucchati."
    },
    {
      "id": "ja540:24.1",
      "pali": "Uṭṭhānapādacariyāya,"
    },
    {
      "id": "ja540:24.2",
      "pali": "pādasambāhanassa ca;"
    },
    {
      "id": "ja540:24.3",
      "pali": "Sāma tāta vilapantā,"
    },
    {
      "id": "ja540:24.4",
      "pali": "hiṇḍissanti brahāvane."
    },
    {
      "id": "ja540:25.1",
      "pali": "Idampi dutiyaṁ sallaṁ,"
    },
    {
      "id": "ja540:25.2",
      "pali": "kampeti hadayaṁ mamaṁ;"
    },
    {
      "id": "ja540:25.3",
      "pali": "Yañca andhe na passāmi,"
    },
    {
      "id": "ja540:25.4",
      "pali": "maññe hissāmi jīvitaṁ”."
    },
    {
      "id": "ja540:26.1",
      "pali": "“Mā bāḷhaṁ paridevesi,"
    },
    {
      "id": "ja540:26.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:26.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:26.4",
      "pali": "bharissaṁ te brahāvane."
    },
    {
      "id": "ja540:27.1",
      "pali": "Issatthe casmi kusalo,"
    },
    {
      "id": "ja540:27.2",
      "pali": "daḷhadhammoti vissuto;"
    },
    {
      "id": "ja540:27.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:27.4",
      "pali": "bharissaṁ te brahāvane."
    },
    {
      "id": "ja540:28.1",
      "pali": "Migānaṁ vighāsamanvesaṁ,"
    },
    {
      "id": "ja540:28.2",
      "pali": "Vanamūlaphalāni ca;"
    },
    {
      "id": "ja540:28.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:28.4",
      "pali": "Bharissaṁ te brahāvane."
    },
    {
      "id": "ja540:29.1",
      "pali": "Katamaṁ taṁ vanaṁ sāma,"
    },
    {
      "id": "ja540:29.2",
      "pali": "yattha mātāpitā tava;"
    },
    {
      "id": "ja540:29.3",
      "pali": "Ahaṁ te tathā bharissaṁ,"
    },
    {
      "id": "ja540:29.4",
      "pali": "yathā te abharī tuvaṁ”."
    },
    {
      "id": "ja540:30.1",
      "pali": "“Ayaṁ ekapadī rāja,"
    },
    {
      "id": "ja540:30.2",
      "pali": "yoyaṁ ussīsake mama;"
    },
    {
      "id": "ja540:30.3",
      "pali": "Ito gantvā aḍḍhakosaṁ,"
    },
    {
      "id": "ja540:30.4",
      "pali": "tattha nesaṁ agārakaṁ;"
    },
    {
      "id": "ja540:30.5",
      "pali": "Yattha mātāpitā mayhaṁ,"
    },
    {
      "id": "ja540:30.6",
      "pali": "te bharassu ito gato."
    },
    {
      "id": "ja540:31.1",
      "pali": "Namo te kāsirājatthu,"
    },
    {
      "id": "ja540:31.2",
      "pali": "namo te kāsivaḍḍhana;"
    },
    {
      "id": "ja540:31.3",
      "pali": "Andhā mātāpitā mayhaṁ,"
    },
    {
      "id": "ja540:31.4",
      "pali": "te bharassu brahāvane."
    },
    {
      "id": "ja540:32.1",
      "pali": "Añjaliṁ te paggaṇhāmi,"
    },
    {
      "id": "ja540:32.2",
      "pali": "kāsirāja namatthu te;"
    },
    {
      "id": "ja540:32.3",
      "pali": "Mātaraṁ pitaraṁ mayhaṁ,"
    },
    {
      "id": "ja540:32.4",
      "pali": "vutto vajjāsi vandanaṁ”."
    },
    {
      "id": "ja540:33.1",
      "pali": "Idaṁ vatvāna so sāmo,"
    },
    {
      "id": "ja540:33.2",
      "pali": "yuvā kalyāṇadassano;"
    },
    {
      "id": "ja540:33.3",
      "pali": "Mucchito visavegena,"
    },
    {
      "id": "ja540:33.4",
      "pali": "visaññī samapajjatha."
    },
    {
      "id": "ja540:34.1",
      "pali": "Sa rājā paridevesi,"
    },
    {
      "id": "ja540:34.2",
      "pali": "bahuṁ kāruññasañhitaṁ;"
    },
    {
      "id": "ja540:34.3",
      "pali": "“Ajarāmarohaṁ āsiṁ,"
    },
    {
      "id": "ja540:34.4",
      "pali": "ajjetaṁ ñāmi no pure;"
    },
    {
      "id": "ja540:34.5",
      "pali": "Sāmaṁ kālaṅkataṁ disvā,"
    },
    {
      "id": "ja540:34.6",
      "pali": "natthi maccussa nāgamo."
    },
    {
      "id": "ja540:35.1",
      "pali": "Yassu maṁ paṭimanteti,"
    },
    {
      "id": "ja540:35.2",
      "pali": "savisena samappito;"
    },
    {
      "id": "ja540:35.3",
      "pali": "Svajja evaṁ gate kāle,"
    },
    {
      "id": "ja540:35.4",
      "pali": "na kiñci mabhibhāsati."
    },
    {
      "id": "ja540:36.1",
      "pali": "Nirayaṁ nūna gacchāmi,"
    },
    {
      "id": "ja540:36.2",
      "pali": "ettha me natthi saṁsayo;"
    },
    {
      "id": "ja540:36.3",
      "pali": "Tadā hi pakataṁ pāpaṁ,"
    },
    {
      "id": "ja540:36.4",
      "pali": "cirarattāya kibbisaṁ."
    },
    {
      "id": "ja540:37.1",
      "pali": "Bhavanti tassa vattāro,"
    },
    {
      "id": "ja540:37.2",
      "pali": "gāme kibbisakārako;"
    },
    {
      "id": "ja540:37.3",
      "pali": "Araññe nimmanussamhi,"
    },
    {
      "id": "ja540:37.4",
      "pali": "ko maṁ vattumarahati."
    },
    {
      "id": "ja540:38.1",
      "pali": "Sārayanti hi kammāni,"
    },
    {
      "id": "ja540:38.2",
      "pali": "gāme saṅgaccha māṇavā;"
    },
    {
      "id": "ja540:38.3",
      "pali": "Araññe nimmanussamhi,"
    },
    {
      "id": "ja540:38.4",
      "pali": "ko nu maṁ sārayissati”."
    },
    {
      "id": "ja540:39.1",
      "pali": "Sā devatā antarahitā,"
    },
    {
      "id": "ja540:39.2",
      "pali": "pabbate gandhamādane;"
    },
    {
      "id": "ja540:39.3",
      "pali": "Raññova anukampāya,"
    },
    {
      "id": "ja540:39.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "ja540:40.1",
      "pali": "“Āguṁ kira mahārāja,"
    },
    {
      "id": "ja540:40.2",
      "pali": "akari kamma dukkaṭaṁ;"
    },
    {
      "id": "ja540:40.3",
      "pali": "Adūsakā pitāputtā,"
    },
    {
      "id": "ja540:40.4",
      "pali": "tayo ekūsunā hatā."
    },
    {
      "id": "ja540:41.1",
      "pali": "Ehi taṁ anusikkhāmi,"
    },
    {
      "id": "ja540:41.2",
      "pali": "yathā te sugatī siyā;"
    },
    {
      "id": "ja540:41.3",
      "pali": "Dhammenandhe vane posa,"
    },
    {
      "id": "ja540:41.4",
      "pali": "maññehaṁ sugatī tayā”."
    },
    {
      "id": "ja540:42.1",
      "pali": "Sa rājā paridevitvā,"
    },
    {
      "id": "ja540:42.2",
      "pali": "bahuṁ kāruññasañhitaṁ;"
    },
    {
      "id": "ja540:42.3",
      "pali": "Udakakumbhamādāya,"
    },
    {
      "id": "ja540:42.4",
      "pali": "pakkāmi dakkhiṇāmukho."
    },
    {
      "id": "ja540:43.1",
      "pali": "“Kassa nu eso padasaddo,"
    },
    {
      "id": "ja540:43.2",
      "pali": "manussasseva āgato;"
    },
    {
      "id": "ja540:43.3",
      "pali": "Neso sāmassa nigghoso,"
    },
    {
      "id": "ja540:43.4",
      "pali": "ko nu tvamasi mārisa."
    },
    {
      "id": "ja540:44.1",
      "pali": "Santañhi sāmo vajati,"
    },
    {
      "id": "ja540:44.2",
      "pali": "santaṁ pādāni neyati;"
    },
    {
      "id": "ja540:44.3",
      "pali": "Neso sāmassa nigghoso,"
    },
    {
      "id": "ja540:44.4",
      "pali": "ko nu tvamasi mārisa”."
    },
    {
      "id": "ja540:45.1",
      "pali": "“Rājāhamasmi kāsīnaṁ,"
    },
    {
      "id": "ja540:45.2",
      "pali": "pīḷiyakkhoti maṁ vidū;"
    },
    {
      "id": "ja540:45.3",
      "pali": "Lobhā raṭṭhaṁ pahitvāna,"
    },
    {
      "id": "ja540:45.4",
      "pali": "migamesaṁ carāmahaṁ."
    },
    {
      "id": "ja540:46.1",
      "pali": "Issatthe casmi kusalo,"
    },
    {
      "id": "ja540:46.2",
      "pali": "daḷhadhammoti vissuto;"
    },
    {
      "id": "ja540:46.3",
      "pali": "Nāgopi me na mucceyya,"
    },
    {
      "id": "ja540:46.4",
      "pali": "āgato usupātanaṁ”."
    },
    {
      "id": "ja540:47.1",
      "pali": "“Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja540:47.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja540:47.3",
      "pali": "Issarosi anuppatto,"
    },
    {
      "id": "ja540:47.4",
      "pali": "yaṁ idhatthi pavedaya."
    },
    {
      "id": "ja540:48.1",
      "pali": "Tindukāni piyālāni,"
    },
    {
      "id": "ja540:48.2",
      "pali": "madhuke kāsumāriyo;"
    },
    {
      "id": "ja540:48.3",
      "pali": "Phalāni khuddakappāni,"
    },
    {
      "id": "ja540:48.4",
      "pali": "bhuñja rāja varaṁ varaṁ."
    },
    {
      "id": "ja540:49.1",
      "pali": "Idampi pānīyaṁ sītaṁ,"
    },
    {
      "id": "ja540:49.2",
      "pali": "ābhataṁ girigabbharā;"
    },
    {
      "id": "ja540:49.3",
      "pali": "Tato piva mahārāja,"
    },
    {
      "id": "ja540:49.4",
      "pali": "sace tvaṁ abhikaṅkhasi”."
    },
    {
      "id": "ja540:50.1",
      "pali": "“Nālaṁ andhā vane daṭṭhuṁ,"
    },
    {
      "id": "ja540:50.2",
      "pali": "ko nu vo phalamāhari;"
    },
    {
      "id": "ja540:50.3",
      "pali": "Anandhassevayaṁ sammā,"
    },
    {
      "id": "ja540:50.4",
      "pali": "nivāpo mayha khāyati”."
    },
    {
      "id": "ja540:51.1",
      "pali": "“Daharo yuvā nātibrahā,"
    },
    {
      "id": "ja540:51.2",
      "pali": "sāmo kalyāṇadassano;"
    },
    {
      "id": "ja540:51.3",
      "pali": "Dīghassa kesā asitā,"
    },
    {
      "id": "ja540:51.4",
      "pali": "atho sūnaggavellitā."
    },
    {
      "id": "ja540:52.1",
      "pali": "So have phalamāharitvā,"
    },
    {
      "id": "ja540:52.2",
      "pali": "ito ādāya kamaṇḍaluṁ;"
    },
    {
      "id": "ja540:52.3",
      "pali": "Nadiṁ gato udahāro,"
    },
    {
      "id": "ja540:52.4",
      "pali": "maññe na dūramāgato”."
    },
    {
      "id": "ja540:53.1",
      "pali": "“Ahaṁ taṁ avadhiṁ sāmaṁ,"
    },
    {
      "id": "ja540:53.2",
      "pali": "yo tuyhaṁ paricārako;"
    },
    {
      "id": "ja540:53.3",
      "pali": "Yaṁ kumāraṁ pavedetha,"
    },
    {
      "id": "ja540:53.4",
      "pali": "sāmaṁ kalyāṇadassanaṁ."
    },
    {
      "id": "ja540:54.1",
      "pali": "Dīghassa kesā asitā,"
    },
    {
      "id": "ja540:54.2",
      "pali": "atho sūnaggavellitā;"
    },
    {
      "id": "ja540:54.3",
      "pali": "Tesu lohitalittesu,"
    },
    {
      "id": "ja540:54.4",
      "pali": "seti sāmo mayā hato”."
    },
    {
      "id": "ja540:55.1",
      "pali": "“Kena dukūla mantesi,"
    },
    {
      "id": "ja540:55.2",
      "pali": "hato sāmoti vādinā;"
    },
    {
      "id": "ja540:55.3",
      "pali": "Hato sāmoti sutvāna,"
    },
    {
      "id": "ja540:55.4",
      "pali": "hadayaṁ me pavedhati."
    },
    {
      "id": "ja540:56.1",
      "pali": "Assatthasseva taruṇaṁ,"
    },
    {
      "id": "ja540:56.2",
      "pali": "pavāḷaṁ māluteritaṁ;"
    },
    {
      "id": "ja540:56.3",
      "pali": "Hato sāmoti sutvāna,"
    },
    {
      "id": "ja540:56.4",
      "pali": "hadayaṁ me pavedhati”."
    },
    {
      "id": "ja540:57.1",
      "pali": "“Pārike kāsirājāyaṁ,"
    },
    {
      "id": "ja540:57.2",
      "pali": "so sāmaṁ migasammate;"
    },
    {
      "id": "ja540:57.3",
      "pali": "Kodhasā usunā vijjhi,"
    },
    {
      "id": "ja540:57.4",
      "pali": "tassa mā pāpamicchimhā”."
    },
    {
      "id": "ja540:58.1",
      "pali": "“Kicchā laddho piyo putto,"
    },
    {
      "id": "ja540:58.2",
      "pali": "yo andhe abharī vane;"
    },
    {
      "id": "ja540:58.3",
      "pali": "Taṁ ekaputtaṁ ghātimhi,"
    },
    {
      "id": "ja540:58.4",
      "pali": "kathaṁ cittaṁ na kopaye”."
    },
    {
      "id": "ja540:59.1",
      "pali": "“Kicchā laddho piyo putto,"
    },
    {
      "id": "ja540:59.2",
      "pali": "yo andhe abharī vane;"
    },
    {
      "id": "ja540:59.3",
      "pali": "Taṁ ekaputtaṁ ghātimhi,"
    },
    {
      "id": "ja540:59.4",
      "pali": "akkodhaṁ āhu paṇḍitā”."
    },
    {
      "id": "ja540:60.1",
      "pali": "“Mā bāḷhaṁ paridevetha,"
    },
    {
      "id": "ja540:60.2",
      "pali": "hato sāmoti vādinā;"
    },
    {
      "id": "ja540:60.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:60.4",
      "pali": "bharissāmi brahāvane."
    },
    {
      "id": "ja540:61.1",
      "pali": "Issatthe casmi kusalo,"
    },
    {
      "id": "ja540:61.2",
      "pali": "daḷhadhammoti vissuto;"
    },
    {
      "id": "ja540:61.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:61.4",
      "pali": "bharissāmi brahāvane."
    },
    {
      "id": "ja540:62.1",
      "pali": "Migānaṁ vighāsamanvesaṁ,"
    },
    {
      "id": "ja540:62.2",
      "pali": "vanamūlaphalāni ca;"
    },
    {
      "id": "ja540:62.3",
      "pali": "Ahaṁ kammakaro hutvā,"
    },
    {
      "id": "ja540:62.4",
      "pali": "bharissāmi brahāvane”."
    },
    {
      "id": "ja540:63.1",
      "pali": "“Nesa dhammo mahārāja,"
    },
    {
      "id": "ja540:63.2",
      "pali": "netaṁ amhesu kappati;"
    },
    {
      "id": "ja540:63.3",
      "pali": "Rājā tvamasi amhākaṁ,"
    },
    {
      "id": "ja540:63.4",
      "pali": "pāde vandāma te mayaṁ”."
    },
    {
      "id": "ja540:64.1",
      "pali": "“Dhammaṁ nesādā bhaṇatha,"
    },
    {
      "id": "ja540:64.2",
      "pali": "katā apacitī tayā;"
    },
    {
      "id": "ja540:64.3",
      "pali": "Pitā tvamasi amhākaṁ,"
    },
    {
      "id": "ja540:64.4",
      "pali": "mātā tvamasi pārike”."
    },
    {
      "id": "ja540:65.1",
      "pali": "“Namo te kāsirājatthu,"
    },
    {
      "id": "ja540:65.2",
      "pali": "namo te kāsivaḍḍhana;"
    },
    {
      "id": "ja540:65.3",
      "pali": "Añjaliṁ te paggaṇhāma,"
    },
    {
      "id": "ja540:65.4",
      "pali": "yāva sāmānupāpaya."
    },
    {
      "id": "ja540:66.1",
      "pali": "Tassa pāde samajjantā,"
    },
    {
      "id": "ja540:66.2",
      "pali": "mukhañca bhujadassanaṁ;"
    },
    {
      "id": "ja540:66.3",
      "pali": "Saṁsumbhamānā attānaṁ,"
    },
    {
      "id": "ja540:66.4",
      "pali": "kālamāgamayāmase”."
    },
    {
      "id": "ja540:67.1",
      "pali": "“Brahā vāḷamigākiṇṇaṁ,"
    },
    {
      "id": "ja540:67.2",
      "pali": "ākāsantaṁva dissati;"
    },
    {
      "id": "ja540:67.3",
      "pali": "Yattha sāmo hato seti,"
    },
    {
      "id": "ja540:67.4",
      "pali": "candova patito chamā."
    },
    {
      "id": "ja540:68.1",
      "pali": "Brahā vāḷamigākiṇṇaṁ,"
    },
    {
      "id": "ja540:68.2",
      "pali": "ākāsantaṁva dissati;"
    },
    {
      "id": "ja540:68.3",
      "pali": "Yattha sāmo hato seti,"
    },
    {
      "id": "ja540:68.4",
      "pali": "sūriyova patito chamā."
    },
    {
      "id": "ja540:69.1",
      "pali": "Brahā vāḷamigākiṇṇaṁ,"
    },
    {
      "id": "ja540:69.2",
      "pali": "ākāsantaṁva dissati;"
    },
    {
      "id": "ja540:69.3",
      "pali": "Yattha sāmo hato seti,"
    },
    {
      "id": "ja540:69.4",
      "pali": "paṁsunā patikunthito."
    },
    {
      "id": "ja540:70.1",
      "pali": "Brahā vāḷamigākiṇṇaṁ,"
    },
    {
      "id": "ja540:70.2",
      "pali": "ākāsantaṁva dissati;"
    },
    {
      "id": "ja540:70.3",
      "pali": "Yattha sāmo hato seti,"
    },
    {
      "id": "ja540:70.4",
      "pali": "idheva vasathassame”."
    },
    {
      "id": "ja540:71.1",
      "pali": "“Yadi tattha sahassāni,"
    },
    {
      "id": "ja540:71.2",
      "pali": "satāni niyutāni ca;"
    },
    {
      "id": "ja540:71.3",
      "pali": "Nevamhākaṁ bhayaṁ koci,"
    },
    {
      "id": "ja540:71.4",
      "pali": "vane vāḷesu vijjati”."
    },
    {
      "id": "ja540:72.1",
      "pali": "Tato andhānamādāya,"
    },
    {
      "id": "ja540:72.2",
      "pali": "kāsirājā brahāvane;"
    },
    {
      "id": "ja540:72.3",
      "pali": "Hatthe gahetvā pakkāmi,"
    },
    {
      "id": "ja540:72.4",
      "pali": "yattha sāmo hato ahu."
    },
    {
      "id": "ja540:73.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:73.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:73.3",
      "pali": "Apaviddhaṁ brahāraññe,"
    },
    {
      "id": "ja540:73.4",
      "pali": "candaṁva patitaṁ chamā."
    },
    {
      "id": "ja540:74.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:74.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:74.3",
      "pali": "Apaviddhaṁ brahāraññe,"
    },
    {
      "id": "ja540:74.4",
      "pali": "sūriyaṁva patitaṁ chamā."
    },
    {
      "id": "ja540:75.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:75.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:75.3",
      "pali": "Apaviddhaṁ brahāraññe,"
    },
    {
      "id": "ja540:75.4",
      "pali": "kalūnaṁ paridevayuṁ."
    },
    {
      "id": "ja540:76.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:76.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:76.3",
      "pali": "Bāhā paggayha pakkanduṁ,"
    },
    {
      "id": "ja540:76.4",
      "pali": "“adhammo kira bho iti."
    },
    {
      "id": "ja540:77.1",
      "pali": "Bāḷhaṁ kho tvaṁ pamattosi,"
    },
    {
      "id": "ja540:77.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:77.3",
      "pali": "Yo ajjevaṁ gate kāle,"
    },
    {
      "id": "ja540:77.4",
      "pali": "na kiñci mabhibhāsasi."
    },
    {
      "id": "ja540:78.1",
      "pali": "Bāḷhaṁ kho tvaṁ padittosi,"
    },
    {
      "id": "ja540:78.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:78.3",
      "pali": "Yo ajjevaṁ gate kāle,"
    },
    {
      "id": "ja540:78.4",
      "pali": "na kiñci mabhibhāsasi."
    },
    {
      "id": "ja540:79.1",
      "pali": "Bāḷhaṁ kho tvaṁ pakuddhosi,"
    },
    {
      "id": "ja540:79.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:79.3",
      "pali": "Yo ajjevaṁ gate kāle,"
    },
    {
      "id": "ja540:79.4",
      "pali": "na kiñci mabhibhāsasi."
    },
    {
      "id": "ja540:80.1",
      "pali": "Bāḷhaṁ kho tvaṁ pasuttosi,"
    },
    {
      "id": "ja540:80.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:80.3",
      "pali": "Yo ajjevaṁ gate kāle,"
    },
    {
      "id": "ja540:80.4",
      "pali": "na kiñci mabhibhāsasi."
    },
    {
      "id": "ja540:81.1",
      "pali": "Bāḷhaṁ kho tvaṁ vimanosi,"
    },
    {
      "id": "ja540:81.2",
      "pali": "sāma kalyāṇadassana;"
    },
    {
      "id": "ja540:81.3",
      "pali": "Yo ajjevaṁ gate kāle,"
    },
    {
      "id": "ja540:81.4",
      "pali": "na kiñci mabhibhāsasi."
    },
    {
      "id": "ja540:82.1",
      "pali": "Jaṭaṁ valinaṁ paṁsugataṁ,"
    },
    {
      "id": "ja540:82.2",
      "pali": "ko dāni saṇṭhapessati;"
    },
    {
      "id": "ja540:82.3",
      "pali": "Sāmo ayaṁ kālaṅkato,"
    },
    {
      "id": "ja540:82.4",
      "pali": "andhānaṁ paricārako."
    },
    {
      "id": "ja540:83.1",
      "pali": "Ko me sammajjamādāya,"
    },
    {
      "id": "ja540:83.2",
      "pali": "sammajjissati assamaṁ;"
    },
    {
      "id": "ja540:83.3",
      "pali": "Sāmo ayaṁ kālaṅkato,"
    },
    {
      "id": "ja540:83.4",
      "pali": "andhānaṁ paricārako."
    },
    {
      "id": "ja540:84.1",
      "pali": "Ko dāni nhāpayissati,"
    },
    {
      "id": "ja540:84.2",
      "pali": "sītenuṇhodakena ca;"
    },
    {
      "id": "ja540:84.3",
      "pali": "Sāmo ayaṁ kālaṅkato,"
    },
    {
      "id": "ja540:84.4",
      "pali": "andhānaṁ paricārako."
    },
    {
      "id": "ja540:85.1",
      "pali": "Ko dāni bhojayissati,"
    },
    {
      "id": "ja540:85.2",
      "pali": "vanamūlaphalāni ca;"
    },
    {
      "id": "ja540:85.3",
      "pali": "Sāmo ayaṁ kālaṅkato,"
    },
    {
      "id": "ja540:85.4",
      "pali": "andhānaṁ paricārako”."
    },
    {
      "id": "ja540:86.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:86.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:86.3",
      "pali": "Aṭṭitā puttasokena,"
    },
    {
      "id": "ja540:86.4",
      "pali": "mātā saccaṁ abhāsatha."
    },
    {
      "id": "ja540:87.1",
      "pali": "“Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:87.2",
      "pali": "dhammacārī pure ahu;"
    },
    {
      "id": "ja540:87.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:87.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:88.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:88.2",
      "pali": "brahmacārī pure ahu;"
    },
    {
      "id": "ja540:88.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:88.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:89.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:89.2",
      "pali": "saccavādī pure ahu;"
    },
    {
      "id": "ja540:89.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:89.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:90.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:90.2",
      "pali": "mātāpettibharo ahu;"
    },
    {
      "id": "ja540:90.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:90.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:91.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:91.2",
      "pali": "kule jeṭṭhāpacāyiko;"
    },
    {
      "id": "ja540:91.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:91.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:92.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:92.2",
      "pali": "pāṇā piyataro mama;"
    },
    {
      "id": "ja540:92.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:92.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:93.1",
      "pali": "Yaṁ kiñcitthi kataṁ puññaṁ,"
    },
    {
      "id": "ja540:93.2",
      "pali": "Mayhañceva pitucca te;"
    },
    {
      "id": "ja540:93.3",
      "pali": "Sabbena tena kusalena,"
    },
    {
      "id": "ja540:93.4",
      "pali": "Visaṁ sāmassa haññatu”."
    },
    {
      "id": "ja540:94.1",
      "pali": "Disvāna patitaṁ sāmaṁ,"
    },
    {
      "id": "ja540:94.2",
      "pali": "puttakaṁ paṁsukunthitaṁ;"
    },
    {
      "id": "ja540:94.3",
      "pali": "Aṭṭito puttasokena,"
    },
    {
      "id": "ja540:94.4",
      "pali": "pitā saccaṁ abhāsatha."
    },
    {
      "id": "ja540:95.1",
      "pali": "“Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:95.2",
      "pali": "dhammacārī pure ahu;"
    },
    {
      "id": "ja540:95.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:95.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:96.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:96.2",
      "pali": "brahmacārī pure ahu;"
    },
    {
      "id": "ja540:96.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:96.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:97.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:97.2",
      "pali": "saccavādī pure ahu;"
    },
    {
      "id": "ja540:97.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:97.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:98.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:98.2",
      "pali": "mātāpettibharo ahu;"
    },
    {
      "id": "ja540:98.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:98.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:99.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:99.2",
      "pali": "kule jeṭṭhāpacāyiko;"
    },
    {
      "id": "ja540:99.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:99.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:100.1",
      "pali": "Yena saccenayaṁ sāmo,"
    },
    {
      "id": "ja540:100.2",
      "pali": "pāṇā piyataro mama;"
    },
    {
      "id": "ja540:100.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:100.4",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:101.1",
      "pali": "Yaṁ kiñcitthi kataṁ puññaṁ,"
    },
    {
      "id": "ja540:101.2",
      "pali": "Mayhañceva mātucca te;"
    },
    {
      "id": "ja540:101.3",
      "pali": "Sabbena tena kusalena,"
    },
    {
      "id": "ja540:101.4",
      "pali": "Visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:102.1",
      "pali": "Sā devatā antarahitā,"
    },
    {
      "id": "ja540:102.2",
      "pali": "pabbate gandhamādane;"
    },
    {
      "id": "ja540:102.3",
      "pali": "Sāmassa anukampāya,"
    },
    {
      "id": "ja540:102.4",
      "pali": "imaṁ saccaṁ abhāsatha."
    },
    {
      "id": "ja540:103.1",
      "pali": "Pabbatyāhaṁ gandhamādane,"
    },
    {
      "id": "ja540:103.2",
      "pali": "cirarattanivāsinī;"
    },
    {
      "id": "ja540:103.3",
      "pali": "Na me piyataro koci,"
    },
    {
      "id": "ja540:103.4",
      "pali": "añño sāmena vijjati;"
    },
    {
      "id": "ja540:103.5",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:103.6",
      "pali": "visaṁ sāmassa haññatu."
    },
    {
      "id": "ja540:104.1",
      "pali": "Sabbe vanā gandhamayā,"
    },
    {
      "id": "ja540:104.2",
      "pali": "pabbate gandhamādane;"
    },
    {
      "id": "ja540:104.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja540:104.4",
      "pali": "visaṁ sāmassa haññatu”."
    },
    {
      "id": "ja540:105.1",
      "pali": "Tesaṁ lālappamānānaṁ,"
    },
    {
      "id": "ja540:105.2",
      "pali": "bahuṁ kāruññasañhitaṁ;"
    },
    {
      "id": "ja540:105.3",
      "pali": "Khippaṁ sāmo samuṭṭhāsi,"
    },
    {
      "id": "ja540:105.4",
      "pali": "yuvā kalyāṇadassano."
    },
    {
      "id": "ja540:106.1",
      "pali": "“Sāmohamasmi bhaddaṁ vo,"
    },
    {
      "id": "ja540:106.2",
      "pali": "Sotthināmhi samuṭṭhito;"
    },
    {
      "id": "ja540:106.3",
      "pali": "Mā bāḷhaṁ paridevetha,"
    },
    {
      "id": "ja540:106.4",
      "pali": "Mañjunābhivadetha maṁ”."
    },
    {
      "id": "ja540:107.1",
      "pali": "“Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja540:107.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja540:107.3",
      "pali": "Issarosi anuppatto,"
    },
    {
      "id": "ja540:107.4",
      "pali": "yaṁ idhatthi pavedaya."
    },
    {
      "id": "ja540:108.1",
      "pali": "Tindukāni piyālāni,"
    },
    {
      "id": "ja540:108.2",
      "pali": "madhuke kāsumāriyo;"
    },
    {
      "id": "ja540:108.3",
      "pali": "Phalāni khuddakappāni,"
    },
    {
      "id": "ja540:108.4",
      "pali": "bhuñja rāja varaṁ varaṁ."
    },
    {
      "id": "ja540:109.1",
      "pali": "Atthi me pānīyaṁ sītaṁ,"
    },
    {
      "id": "ja540:109.2",
      "pali": "ābhataṁ girigabbharā;"
    },
    {
      "id": "ja540:109.3",
      "pali": "Tato piva mahārāja,"
    },
    {
      "id": "ja540:109.4",
      "pali": "sace tvaṁ abhikaṅkhasi”."
    },
    {
      "id": "ja540:110.1",
      "pali": "“Sammuyhāmi pamuyhāmi,"
    },
    {
      "id": "ja540:110.2",
      "pali": "sabbā muyhanti me disā;"
    },
    {
      "id": "ja540:110.3",
      "pali": "Petaṁ taṁ sāma maddakkhiṁ,"
    },
    {
      "id": "ja540:110.4",
      "pali": "ko nu tvaṁ sāma jīvasi”."
    },
    {
      "id": "ja540:111.1",
      "pali": "“Api jīvaṁ mahārāja,"
    },
    {
      "id": "ja540:111.2",
      "pali": "purisaṁ gāḷhavedanaṁ;"
    },
    {
      "id": "ja540:111.3",
      "pali": "Upanītamanasaṅkappaṁ,"
    },
    {
      "id": "ja540:111.4",
      "pali": "jīvantaṁ maññate mataṁ."
    },
    {
      "id": "ja540:112.1",
      "pali": "Api jīvaṁ mahārāja,"
    },
    {
      "id": "ja540:112.2",
      "pali": "purisaṁ gāḷhavedanaṁ;"
    },
    {
      "id": "ja540:112.3",
      "pali": "Taṁ nirodhagataṁ santaṁ,"
    },
    {
      "id": "ja540:112.4",
      "pali": "jīvantaṁ maññate mataṁ."
    },
    {
      "id": "ja540:113.1",
      "pali": "Yo mātaraṁ pitaraṁ vā,"
    },
    {
      "id": "ja540:113.2",
      "pali": "macco dhammena posati;"
    },
    {
      "id": "ja540:113.3",
      "pali": "Devāpi naṁ tikicchanti,"
    },
    {
      "id": "ja540:113.4",
      "pali": "mātāpettibharaṁ naraṁ."
    },
    {
      "id": "ja540:114.1",
      "pali": "Yo mātaraṁ pitaraṁ vā,"
    },
    {
      "id": "ja540:114.2",
      "pali": "macco dhammena posati;"
    },
    {
      "id": "ja540:114.3",
      "pali": "Idheva naṁ pasaṁsanti,"
    },
    {
      "id": "ja540:114.4",
      "pali": "pecca sagge pamodati”."
    },
    {
      "id": "ja540:115.1",
      "pali": "“Esa bhiyyo pamuyhāmi,"
    },
    {
      "id": "ja540:115.2",
      "pali": "Sabbā muyhanti me disā;"
    },
    {
      "id": "ja540:115.3",
      "pali": "Saraṇaṁ taṁ sāma gacchāmi,"
    },
    {
      "id": "ja540:115.4",
      "pali": "Tvañca me saraṇaṁ bhava”."
    },
    {
      "id": "ja540:116.1",
      "pali": "“Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:116.2",
      "pali": "mātāpitūsu khattiya;"
    },
    {
      "id": "ja540:116.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:116.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:117.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:117.2",
      "pali": "puttadāresu khattiya;"
    },
    {
      "id": "ja540:117.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:117.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:118.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:118.2",
      "pali": "mittāmaccesu khattiya;"
    },
    {
      "id": "ja540:118.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:118.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:119.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:119.2",
      "pali": "vāhanesu balesu ca;"
    },
    {
      "id": "ja540:119.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:119.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:120.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:120.2",
      "pali": "gāmesu nigamesu ca;"
    },
    {
      "id": "ja540:120.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:120.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:121.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:121.2",
      "pali": "raṭṭhesu janapadesu ca;"
    },
    {
      "id": "ja540:121.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:121.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:122.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:122.2",
      "pali": "samaṇabrāhmaṇesu ca;"
    },
    {
      "id": "ja540:122.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:122.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:123.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:123.2",
      "pali": "migapakkhīsu khattiya;"
    },
    {
      "id": "ja540:123.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:123.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:124.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:124.2",
      "pali": "dhammo ciṇṇo sukhāvaho;"
    },
    {
      "id": "ja540:124.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja540:124.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja540:125.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja540:125.2",
      "pali": "saindā devā sabrahmakā;"
    },
    {
      "id": "ja540:125.3",
      "pali": "Suciṇṇena divaṁ pattā,"
    },
    {
      "id": "ja540:125.4",
      "pali": "mā dhammaṁ rāja pāmado”ti."
    },
    {
      "id": "ja540:126.1",
      "pali": "Suvaṇṇasāmajātakaṁ tatiyaṁ."
    }
  ]
}
