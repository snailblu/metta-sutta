{
  "uid": "ja437",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja437:1.1",
      "pali": "“Na kho me ruccati āḷi,"
    },
    {
      "id": "ja437:1.2",
      "pali": "pūtimaṁsassa pekkhanā;"
    },
    {
      "id": "ja437:1.3",
      "pali": "Etādisā sakhārasmā,"
    },
    {
      "id": "ja437:1.4",
      "pali": "ārakā parivajjaye”."
    },
    {
      "id": "ja437:2.1",
      "pali": "“Ummattikā ayaṁ veṇī,"
    },
    {
      "id": "ja437:2.2",
      "pali": "vaṇṇeti patino sakhiṁ;"
    },
    {
      "id": "ja437:2.3",
      "pali": "Pajjhāyi paṭigacchantiṁ,"
    },
    {
      "id": "ja437:2.4",
      "pali": "āgataṁ meṇḍamātaraṁ”."
    },
    {
      "id": "ja437:3.1",
      "pali": "“Tvaṁ khosi samma ummatto,"
    },
    {
      "id": "ja437:3.2",
      "pali": "dummedho avicakkhaṇo;"
    },
    {
      "id": "ja437:3.3",
      "pali": "Yo tvaṁ matālayaṁ katvā,"
    },
    {
      "id": "ja437:3.4",
      "pali": "akālena vipekkhasi”."
    },
    {
      "id": "ja437:4.1",
      "pali": "“Na akāle vipekkheyya,"
    },
    {
      "id": "ja437:4.2",
      "pali": "kāle pekkheyya paṇḍito;"
    },
    {
      "id": "ja437:4.3",
      "pali": "Pūtimaṁsova pajjhāyi,"
    },
    {
      "id": "ja437:4.4",
      "pali": "yo akāle vipekkhati”."
    },
    {
      "id": "ja437:5.1",
      "pali": "“Piyaṁ kho āḷi me hotu,"
    },
    {
      "id": "ja437:5.2",
      "pali": "puṇṇapattaṁ dadāhi me;"
    },
    {
      "id": "ja437:5.3",
      "pali": "Pati sañjīvito mayhaṁ,"
    },
    {
      "id": "ja437:5.4",
      "pali": "eyyāsi piyapucchikā”."
    },
    {
      "id": "ja437:6.1",
      "pali": "“Piyaṁ kho āḷi te hotu,"
    },
    {
      "id": "ja437:6.2",
      "pali": "puṇṇapattaṁ dadāmi te;"
    },
    {
      "id": "ja437:6.3",
      "pali": "Mahatā parivārena,"
    },
    {
      "id": "ja437:6.4",
      "pali": "essaṁ kayirāhi bhojanaṁ”."
    },
    {
      "id": "ja437:7.1",
      "pali": "“Kīdiso tuyhaṁ parivāro,"
    },
    {
      "id": "ja437:7.2",
      "pali": "yesaṁ kāhāmi bhojanaṁ;"
    },
    {
      "id": "ja437:7.3",
      "pali": "Kiṁnāmakā ca te sabbe,"
    },
    {
      "id": "ja437:7.4",
      "pali": "taṁ me akkhāhi pucchitā”."
    },
    {
      "id": "ja437:8.1",
      "pali": "“Māliyo caturakkho ca,"
    },
    {
      "id": "ja437:8.2",
      "pali": "piṅgiyo atha jambuko;"
    },
    {
      "id": "ja437:8.3",
      "pali": "Ediso mayhaṁ parivāro,"
    },
    {
      "id": "ja437:8.4",
      "pali": "tesaṁ kayirāhi bhojanaṁ”."
    },
    {
      "id": "ja437:9.1",
      "pali": "“Nikkhantāya agārasmā,"
    },
    {
      "id": "ja437:9.2",
      "pali": "bhaṇḍakampi vinassati;"
    },
    {
      "id": "ja437:9.3",
      "pali": "Ārogyaṁ āḷino vajjaṁ,"
    },
    {
      "id": "ja437:9.4",
      "pali": "idheva vasa māgamā”ti."
    },
    {
      "id": "ja437:10.1",
      "pali": "Pūtimaṁsajātakaṁ ekādasamaṁ."
    }
  ]
}
