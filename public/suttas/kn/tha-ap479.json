{
  "uid": "tha-ap479",
  "title": "Giripunnāgiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap479:1.1",
      "pali": "“Sobhito nāma sambuddho,"
    },
    {
      "id": "tha-ap479:1.2",
      "pali": "cittakūṭe vasī tadā;"
    },
    {
      "id": "tha-ap479:1.3",
      "pali": "Gahetvā giripunnāgaṁ,"
    },
    {
      "id": "tha-ap479:1.4",
      "pali": "sayambhuṁ abhipūjayiṁ."
    },
    {
      "id": "tha-ap479:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap479:2.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap479:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap479:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap479:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap479:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap479:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap479:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap479:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap479:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap479:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap479:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap479:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap479:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā giripunnāgiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap479:7.1",
      "pali": "Giripunnāgiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
