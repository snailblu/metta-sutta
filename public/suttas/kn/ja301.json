{
  "uid": "ja301",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja301:1.1",
      "pali": "“Vivarathimāsaṁ dvāraṁ,"
    },
    {
      "id": "ja301:1.2",
      "pali": "Nagaraṁ pavisantu aruṇarājassa;"
    },
    {
      "id": "ja301:1.3",
      "pali": "Sīhena susiṭṭhena,"
    },
    {
      "id": "ja301:1.4",
      "pali": "Surakkhitaṁ nandisenena”."
    },
    {
      "id": "ja301:2.1",
      "pali": "“Jayo kaliṅgānamasayhasāhinaṁ,"
    },
    {
      "id": "ja301:2.2",
      "pali": "Parājayo anayo assakānaṁ;"
    },
    {
      "id": "ja301:2.3",
      "pali": "Icceva te bhāsitaṁ brahmacāri,"
    },
    {
      "id": "ja301:2.4",
      "pali": "Na ujjubhūtā vitathaṁ bhaṇanti”."
    },
    {
      "id": "ja301:3.1",
      "pali": "“Devā musāvādamupātivattā,"
    },
    {
      "id": "ja301:3.2",
      "pali": "Saccaṁ dhanaṁ paramaṁ tesu sakka;"
    },
    {
      "id": "ja301:3.3",
      "pali": "Taṁ te musā bhāsitaṁ devarāja,"
    },
    {
      "id": "ja301:3.4",
      "pali": "Kiṁ vā paṭicca maghavā mahinda”."
    },
    {
      "id": "ja301:4.1",
      "pali": "“Nanu te sutaṁ brāhmaṇa bhaññamāne,"
    },
    {
      "id": "ja301:4.2",
      "pali": "Devā na issanti purisaparakkamassa;"
    },
    {
      "id": "ja301:4.3",
      "pali": "Damo samādhi manaso abhejjo,"
    },
    {
      "id": "ja301:4.4",
      "pali": "Abyaggatā nikkamanañca kāle;"
    },
    {
      "id": "ja301:4.5",
      "pali": "Daḷhañca viriyaṁ purisaparakkamo ca,"
    },
    {
      "id": "ja301:4.6",
      "pali": "Teneva āsi vijayo assakānan”ti."
    },
    {
      "id": "ja301:5.1",
      "pali": "Cūḷakāliṅgajātakaṁ paṭhamaṁ."
    }
  ]
}
