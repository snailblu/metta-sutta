{
  "uid": "ne32",
  "title": "Sampāta 13",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne32:1.1",
      "pali": "Tattha katamo sodhano hārasampāto?"
    },
    {
      "id": "ne32:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne32:2.2",
      "pali": "Yattha ārambho suddho, so pañho visajjito bhavati."
    },
    {
      "id": "ne32:2.3",
      "pali": "Yattha pana ārambho na suddho, na tāva so pañho visajjito bhavati."
    },
    {
      "id": "ne32:2.4",
      "pali": "Niyutto sodhano hārasampāto."
    }
  ]
}
