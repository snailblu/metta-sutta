{
  "uid": "tha-ap311",
  "title": "9 Buddhasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap311:1.1",
      "pali": "“Udentaṁ sataraṁsiṁva,"
    },
    {
      "id": "tha-ap311:1.2",
      "pali": "pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap311:1.3",
      "pali": "Vanantaragataṁ santaṁ,"
    },
    {
      "id": "tha-ap311:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap311:2.1",
      "pali": "Addasaṁ supinantena,"
    },
    {
      "id": "tha-ap311:2.2",
      "pali": "siddhatthaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap311:2.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap311:2.4",
      "pali": "sugatiṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap311:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap311:3.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap311:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap311:3.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap311:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap311:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap311:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap311:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap311:6.1",
      "pali": "Buddhasaññakattherassāpadānaṁ navamaṁ."
    }
  ]
}
