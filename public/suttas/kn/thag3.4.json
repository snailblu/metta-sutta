{
  "uid": "thag3.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.4:1.1",
      "pali": "“Sukhañce jīvituṁ icche,"
    },
    {
      "id": "thag3.4:1.2",
      "pali": "sāmaññasmiṁ apekkhavā;"
    },
    {
      "id": "thag3.4:1.3",
      "pali": "Saṅghikaṁ nātimaññeyya,"
    },
    {
      "id": "thag3.4:1.4",
      "pali": "cīvaraṁ pānabhojanaṁ."
    },
    {
      "id": "thag3.4:2.1",
      "pali": "Sukhañce jīvituṁ icche,"
    },
    {
      "id": "thag3.4:2.2",
      "pali": "sāmaññasmiṁ apekkhavā;"
    },
    {
      "id": "thag3.4:2.3",
      "pali": "Ahi mūsikasobbhaṁva,"
    },
    {
      "id": "thag3.4:2.4",
      "pali": "sevetha sayanāsanaṁ."
    },
    {
      "id": "thag3.4:3.1",
      "pali": "Sukhañce jīvituṁ icche,"
    },
    {
      "id": "thag3.4:3.2",
      "pali": "sāmaññasmiṁ apekkhavā;"
    },
    {
      "id": "thag3.4:3.3",
      "pali": "Itarītarena tusseyya,"
    },
    {
      "id": "thag3.4:3.4",
      "pali": "ekadhammañca bhāvaye”ti."
    },
    {
      "id": "thag3.4:3.5",
      "pali": "… Dhaniyo thero …."
    }
  ]
}
