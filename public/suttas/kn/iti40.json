{
  "uid": "iti40",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti40:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti40:2.1",
      "pali": "“Avijjā, bhikkhave, pubbaṅgamā akusalānaṁ dhammānaṁ samāpattiyā anvadeva ahirikaṁ anottappaṁ;"
    },
    {
      "id": "iti40:2.2",
      "pali": "vijjā ca kho, bhikkhave, pubbaṅgamā kusalānaṁ dhammānaṁ samāpattiyā anvadeva hirottappan”ti."
    },
    {
      "id": "iti40:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti40:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti40:3.1",
      "pali": "“Yā kācimā duggatiyo,"
    },
    {
      "id": "iti40:3.2",
      "pali": "asmiṁ loke paramhi ca;"
    },
    {
      "id": "iti40:3.3",
      "pali": "Avijjāmūlikā sabbā,"
    },
    {
      "id": "iti40:3.4",
      "pali": "icchālobhasamussayā."
    },
    {
      "id": "iti40:4.1",
      "pali": "Yato ca hoti pāpiccho,"
    },
    {
      "id": "iti40:4.2",
      "pali": "ahirīko anādaro;"
    },
    {
      "id": "iti40:4.3",
      "pali": "Tato pāpaṁ pasavati,"
    },
    {
      "id": "iti40:4.4",
      "pali": "apāyaṁ tena gacchati."
    },
    {
      "id": "iti40:5.1",
      "pali": "Tasmā chandañca lobhañca,"
    },
    {
      "id": "iti40:5.2",
      "pali": "avijjañca virājayaṁ;"
    },
    {
      "id": "iti40:5.3",
      "pali": "Vijjaṁ uppādayaṁ bhikkhu,"
    },
    {
      "id": "iti40:5.4",
      "pali": "sabbā duggatiyo jahe”ti."
    },
    {
      "id": "iti40:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti40:6.2",
      "pali": "Tatiyaṁ."
    },
    {
      "id": "iti40:6.3",
      "pali": "Paṭhamabhāṇavāro."
    }
  ]
}
