{
  "uid": "ja67",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja67:1.1",
      "pali": "“Ucchaṅge deva me putto,"
    },
    {
      "id": "ja67:1.2",
      "pali": "Pathe dhāvantiyā pati;"
    },
    {
      "id": "ja67:1.3",
      "pali": "Tañca desaṁ na passāmi,"
    },
    {
      "id": "ja67:1.4",
      "pali": "Yato sodariyamānayeti."
    },
    {
      "id": "ja67:2.1",
      "pali": "Ucchaṅgajātakaṁ sattamaṁ."
    }
  ]
}
