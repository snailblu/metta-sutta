{
  "uid": "ja231",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja231:1.1",
      "pali": "“Yathāpi kītā purisassupāhanā,"
    },
    {
      "id": "ja231:1.2",
      "pali": "Sukhassa atthāya dukhaṁ udabbahe;"
    },
    {
      "id": "ja231:1.3",
      "pali": "Ghammābhitattā thalasā papīḷitā,"
    },
    {
      "id": "ja231:1.4",
      "pali": "Tasseva pāde purisassa khādare."
    },
    {
      "id": "ja231:2.1",
      "pali": "Evameva yo dukkulīno anariyo,"
    },
    {
      "id": "ja231:2.2",
      "pali": "Tammāka vijjañca sutañca ādiya;"
    },
    {
      "id": "ja231:2.3",
      "pali": "Tameva so tattha sutena khādati,"
    },
    {
      "id": "ja231:2.4",
      "pali": "Anariyo vuccati dupāhanūpamo”ti."
    },
    {
      "id": "ja231:3.1",
      "pali": "Upāhanajātakaṁ paṭhamaṁ."
    }
  ]
}
