{
  "uid": "ja477",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja477:1.1",
      "pali": "“Na te kaṭṭhāni bhinnāni,"
    },
    {
      "id": "ja477:1.2",
      "pali": "na te udakamābhataṁ;"
    },
    {
      "id": "ja477:1.3",
      "pali": "Aggīpi te na hāpito,"
    },
    {
      "id": "ja477:1.4",
      "pali": "kiṁ nu mandova jhāyasi”."
    },
    {
      "id": "ja477:2.1",
      "pali": "“Na ussahe vane vatthuṁ,"
    },
    {
      "id": "ja477:2.2",
      "pali": "kassapāmantayāmi taṁ;"
    },
    {
      "id": "ja477:2.3",
      "pali": "Dukkho vāso araññasmiṁ,"
    },
    {
      "id": "ja477:2.4",
      "pali": "raṭṭhaṁ icchāmi gantave."
    },
    {
      "id": "ja477:3.1",
      "pali": "Yathā ahaṁ ito gantvā,"
    },
    {
      "id": "ja477:3.2",
      "pali": "Yasmiṁ janapade vasaṁ;"
    },
    {
      "id": "ja477:3.3",
      "pali": "Ācāraṁ brahme sikkheyyaṁ,"
    },
    {
      "id": "ja477:3.4",
      "pali": "Taṁ dhammaṁ anusāsa maṁ”."
    },
    {
      "id": "ja477:4.1",
      "pali": "“Sace araññaṁ hitvāna,"
    },
    {
      "id": "ja477:4.2",
      "pali": "vanamūlaphalāni ca;"
    },
    {
      "id": "ja477:4.3",
      "pali": "Raṭṭhe rocayase vāsaṁ,"
    },
    {
      "id": "ja477:4.4",
      "pali": "taṁ dhammaṁ nisāmehi me."
    },
    {
      "id": "ja477:5.1",
      "pali": "Visaṁ mā paṭisevittho,"
    },
    {
      "id": "ja477:5.2",
      "pali": "papātaṁ parivajjaya;"
    },
    {
      "id": "ja477:5.3",
      "pali": "Paṅke ca mā visīdittho,"
    },
    {
      "id": "ja477:5.4",
      "pali": "yatto cāsīvise care”."
    },
    {
      "id": "ja477:6.1",
      "pali": "“Kiṁ nu visaṁ papāto vā,"
    },
    {
      "id": "ja477:6.2",
      "pali": "paṅko vā brahmacārinaṁ;"
    },
    {
      "id": "ja477:6.3",
      "pali": "Kaṁ tvaṁ āsīvisaṁ brūsi,"
    },
    {
      "id": "ja477:6.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja477:7.1",
      "pali": "“Āsavo tāta lokasmiṁ,"
    },
    {
      "id": "ja477:7.2",
      "pali": "surā nāma pavuccati;"
    },
    {
      "id": "ja477:7.3",
      "pali": "Manuñño surabhī vaggu,"
    },
    {
      "id": "ja477:7.4",
      "pali": "sādu khuddarasūpamo;"
    },
    {
      "id": "ja477:7.5",
      "pali": "Visaṁ tadāhu ariyā se,"
    },
    {
      "id": "ja477:7.6",
      "pali": "brahmacariyassa nārada."
    },
    {
      "id": "ja477:8.1",
      "pali": "Itthiyo tāta lokasmiṁ,"
    },
    {
      "id": "ja477:8.2",
      "pali": "pamattaṁ pamathenti tā;"
    },
    {
      "id": "ja477:8.3",
      "pali": "Haranti yuvino cittaṁ,"
    },
    {
      "id": "ja477:8.4",
      "pali": "tūlaṁ bhaṭṭhaṁva māluto;"
    },
    {
      "id": "ja477:8.5",
      "pali": "Papāto eso akkhāto,"
    },
    {
      "id": "ja477:8.6",
      "pali": "brahmacariyassa nārada."
    },
    {
      "id": "ja477:9.1",
      "pali": "Lābho siloko sakkāro,"
    },
    {
      "id": "ja477:9.2",
      "pali": "pūjā parakulesu ca;"
    },
    {
      "id": "ja477:9.3",
      "pali": "Paṅko eso ca akkhāto,"
    },
    {
      "id": "ja477:9.4",
      "pali": "brahmacariyassa nārada."
    },
    {
      "id": "ja477:10.1",
      "pali": "Sasatthā tāta rājāno,"
    },
    {
      "id": "ja477:10.2",
      "pali": "āvasanti mahiṁ imaṁ;"
    },
    {
      "id": "ja477:10.3",
      "pali": "Te tādise manussinde,"
    },
    {
      "id": "ja477:10.4",
      "pali": "mahante tāta nārada."
    },
    {
      "id": "ja477:11.1",
      "pali": "Issarānaṁ adhipatīnaṁ,"
    },
    {
      "id": "ja477:11.2",
      "pali": "na tesaṁ pādato care;"
    },
    {
      "id": "ja477:11.3",
      "pali": "Āsīvisoti akkhāto,"
    },
    {
      "id": "ja477:11.4",
      "pali": "brahmacariyassa nārada."
    },
    {
      "id": "ja477:12.1",
      "pali": "Bhattattho bhattakāle ca,"
    },
    {
      "id": "ja477:12.2",
      "pali": "yaṁ gehamupasaṅkame;"
    },
    {
      "id": "ja477:12.3",
      "pali": "Yadettha kusalaṁ jaññā,"
    },
    {
      "id": "ja477:12.4",
      "pali": "tattha ghāsesanaṁ care."
    },
    {
      "id": "ja477:13.1",
      "pali": "Pavisitvā parakulaṁ,"
    },
    {
      "id": "ja477:13.2",
      "pali": "pānatthaṁ bhojanāya vā;"
    },
    {
      "id": "ja477:13.3",
      "pali": "Mitaṁ khāde mitaṁ bhuñje,"
    },
    {
      "id": "ja477:13.4",
      "pali": "na ca rūpe manaṁ kare."
    },
    {
      "id": "ja477:14.1",
      "pali": "Goṭṭhaṁ majjaṁ kirāṭañca,"
    },
    {
      "id": "ja477:14.2",
      "pali": "sabhā nikiraṇāni ca;"
    },
    {
      "id": "ja477:14.3",
      "pali": "Ārakā parivajjehi,"
    },
    {
      "id": "ja477:14.4",
      "pali": "yānīva visamaṁ pathan”ti."
    },
    {
      "id": "ja477:15.1",
      "pali": "Cūḷanāradajātakaṁ catutthaṁ."
    }
  ]
}
