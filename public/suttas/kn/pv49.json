{
  "uid": "pv49",
  "title": "14. Bhogasaṁharaṇapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv49:1.1",
      "pali": "“Mayaṁ bhoge saṁharimhā,"
    },
    {
      "id": "pv49:1.2",
      "pali": "samena visamena ca;"
    },
    {
      "id": "pv49:1.3",
      "pali": "Te aññe paribhuñjanti,"
    },
    {
      "id": "pv49:1.4",
      "pali": "mayaṁ dukkhassa bhāginī”ti."
    },
    {
      "id": "pv49:2.1",
      "pali": "Bhogasaṁharaṇapetavatthu cuddasamaṁ."
    }
  ]
}
