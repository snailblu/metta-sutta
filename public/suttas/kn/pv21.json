{
  "uid": "pv21",
  "title": "9. Aṅkurapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv21:1.1",
      "pali": "“Yassa atthāya gacchāma,"
    },
    {
      "id": "pv21:1.2",
      "pali": "kambojaṁ dhanahārakā;"
    },
    {
      "id": "pv21:1.3",
      "pali": "Ayaṁ kāmadado yakkho,"
    },
    {
      "id": "pv21:1.4",
      "pali": "imaṁ yakkhaṁ nayāmase."
    },
    {
      "id": "pv21:2.1",
      "pali": "Imaṁ yakkhaṁ gahetvāna,"
    },
    {
      "id": "pv21:2.2",
      "pali": "Sādhukena pasayha vā;"
    },
    {
      "id": "pv21:2.3",
      "pali": "Yānaṁ āropayitvāna,"
    },
    {
      "id": "pv21:2.4",
      "pali": "Khippaṁ gacchāma dvārakan”ti."
    },
    {
      "id": "pv21:3.1",
      "pali": "“Yassa rukkhassa chāyāya,"
    },
    {
      "id": "pv21:3.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "pv21:3.3",
      "pali": "Na tassa sākhaṁ bhañjeyya,"
    },
    {
      "id": "pv21:3.4",
      "pali": "mittadubbho hi pāpako”ti."
    },
    {
      "id": "pv21:4.1",
      "pali": "“Yassa rukkhassa chāyāya,"
    },
    {
      "id": "pv21:4.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "pv21:4.3",
      "pali": "Khandhampi tassa chindeyya,"
    },
    {
      "id": "pv21:4.4",
      "pali": "attho ce tādiso siyā”ti."
    },
    {
      "id": "pv21:5.1",
      "pali": "“Yassa rukkhassa chāyāya,"
    },
    {
      "id": "pv21:5.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "pv21:5.3",
      "pali": "Na tassa pattaṁ bhindeyya,"
    },
    {
      "id": "pv21:5.4",
      "pali": "mittadubbho hi pāpako”ti."
    },
    {
      "id": "pv21:6.1",
      "pali": "“Yassa rukkhassa chāyāya,"
    },
    {
      "id": "pv21:6.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "pv21:6.3",
      "pali": "Samūlampi taṁ abbuhe,"
    },
    {
      "id": "pv21:6.4",
      "pali": "attho ce tādiso siyā”ti."
    },
    {
      "id": "pv21:7.1",
      "pali": "“Yassekarattimpi ghare vaseyya,"
    },
    {
      "id": "pv21:7.2",
      "pali": "Yatthannapānaṁ puriso labhetha;"
    },
    {
      "id": "pv21:7.3",
      "pali": "Na tassa pāpaṁ manasāpi cintaye,"
    },
    {
      "id": "pv21:7.4",
      "pali": "Kataññutā sappurisehi vaṇṇitā."
    },
    {
      "id": "pv21:8.1",
      "pali": "Yassekarattimpi ghare vaseyya,"
    },
    {
      "id": "pv21:8.2",
      "pali": "Annena pānena upaṭṭhito siyā;"
    },
    {
      "id": "pv21:8.3",
      "pali": "Na tassa pāpaṁ manasāpi cintaye,"
    },
    {
      "id": "pv21:8.4",
      "pali": "Adubbhapāṇī dahate mittadubbhiṁ."
    },
    {
      "id": "pv21:9.1",
      "pali": "Yo pubbe katakalyāṇo,"
    },
    {
      "id": "pv21:9.2",
      "pali": "pacchā pāpena hiṁsati;"
    },
    {
      "id": "pv21:9.3",
      "pali": "Allapāṇihato poso,"
    },
    {
      "id": "pv21:9.4",
      "pali": "na so bhadrāni passatī”ti."
    },
    {
      "id": "pv21:10.1",
      "pali": "“Nāhaṁ devena vā manussena vā,"
    },
    {
      "id": "pv21:10.2",
      "pali": "Issariyena vāhaṁ suppasayho;"
    },
    {
      "id": "pv21:10.3",
      "pali": "Yakkhohamasmi paramiddhipatto,"
    },
    {
      "id": "pv21:10.4",
      "pali": "Dūraṅgamo vaṇṇabalūpapanno”ti."
    },
    {
      "id": "pv21:11.1",
      "pali": "“Pāṇi te sabbaso vaṇṇo,"
    },
    {
      "id": "pv21:11.2",
      "pali": "pañcadhāro madhussavo;"
    },
    {
      "id": "pv21:11.3",
      "pali": "Nānārasā paggharanti,"
    },
    {
      "id": "pv21:11.4",
      "pali": "maññehaṁ taṁ purindadan”ti."
    },
    {
      "id": "pv21:12.1",
      "pali": "“Nāmhi devo na gandhabbo,"
    },
    {
      "id": "pv21:12.2",
      "pali": "nāpi sakko purindado;"
    },
    {
      "id": "pv21:12.3",
      "pali": "Petaṁ maṁ aṅkura jānāhi,"
    },
    {
      "id": "pv21:12.4",
      "pali": "roruvamhā idhāgatan”ti."
    },
    {
      "id": "pv21:13.1",
      "pali": "“Kiṁsīlo kiṁsamācāro,"
    },
    {
      "id": "pv21:13.2",
      "pali": "roruvasmiṁ pure tuvaṁ;"
    },
    {
      "id": "pv21:13.3",
      "pali": "Kena te brahmacariyena,"
    },
    {
      "id": "pv21:13.4",
      "pali": "puññaṁ pāṇimhi ijjhatī”ti."
    },
    {
      "id": "pv21:14.1",
      "pali": "“Tunnavāyo pure āsiṁ,"
    },
    {
      "id": "pv21:14.2",
      "pali": "roruvasmiṁ tadā ahaṁ;"
    },
    {
      "id": "pv21:14.3",
      "pali": "Sukicchavutti kapaṇo,"
    },
    {
      "id": "pv21:14.4",
      "pali": "na me vijjati dātave."
    },
    {
      "id": "pv21:15.1",
      "pali": "Nivesanañca me āsi,"
    },
    {
      "id": "pv21:15.2",
      "pali": "asayhassa upantike;"
    },
    {
      "id": "pv21:15.3",
      "pali": "Saddhassa dānapatino,"
    },
    {
      "id": "pv21:15.4",
      "pali": "katapuññassa lajjino."
    },
    {
      "id": "pv21:16.1",
      "pali": "Tattha yācanakāyanti,"
    },
    {
      "id": "pv21:16.2",
      "pali": "nānāgottā vanibbakā;"
    },
    {
      "id": "pv21:16.3",
      "pali": "Te ca maṁ tattha pucchanti,"
    },
    {
      "id": "pv21:16.4",
      "pali": "asayhassa nivesanaṁ."
    },
    {
      "id": "pv21:17.1",
      "pali": "Kattha gacchāma bhaddaṁ vo,"
    },
    {
      "id": "pv21:17.2",
      "pali": "kattha dānaṁ padīyati;"
    },
    {
      "id": "pv21:17.3",
      "pali": "Tesāhaṁ puṭṭho akkhāmi,"
    },
    {
      "id": "pv21:17.4",
      "pali": "asayhassa nivesanaṁ."
    },
    {
      "id": "pv21:18.1",
      "pali": "Paggayha dakkhiṇaṁ bāhuṁ,"
    },
    {
      "id": "pv21:18.2",
      "pali": "ettha gacchatha bhaddaṁ vo;"
    },
    {
      "id": "pv21:18.3",
      "pali": "Ettha dānaṁ padīyati,"
    },
    {
      "id": "pv21:18.4",
      "pali": "asayhassa nivesane."
    },
    {
      "id": "pv21:19.1",
      "pali": "Tena pāṇi kāmadado,"
    },
    {
      "id": "pv21:19.2",
      "pali": "tena pāṇi madhussavo;"
    },
    {
      "id": "pv21:19.3",
      "pali": "Tena me brahmacariyena,"
    },
    {
      "id": "pv21:19.4",
      "pali": "puññaṁ pāṇimhi ijjhatī”ti."
    },
    {
      "id": "pv21:20.1",
      "pali": "“Na kira tvaṁ adā dānaṁ,"
    },
    {
      "id": "pv21:20.2",
      "pali": "Sakapāṇīhi kassaci;"
    },
    {
      "id": "pv21:20.3",
      "pali": "Parassa dānaṁ anumodamāno,"
    },
    {
      "id": "pv21:20.4",
      "pali": "Pāṇiṁ paggayha pāvadi."
    },
    {
      "id": "pv21:21.1",
      "pali": "Tena pāṇi kāmadado,"
    },
    {
      "id": "pv21:21.2",
      "pali": "tena pāṇi madhussavo;"
    },
    {
      "id": "pv21:21.3",
      "pali": "Tena te brahmacariyena,"
    },
    {
      "id": "pv21:21.4",
      "pali": "puññaṁ pāṇimhi ijjhati."
    },
    {
      "id": "pv21:22.1",
      "pali": "Yo so dānamadā bhante,"
    },
    {
      "id": "pv21:22.2",
      "pali": "pasanno sakapāṇibhi;"
    },
    {
      "id": "pv21:22.3",
      "pali": "So hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "pv21:22.4",
      "pali": "kiṁ nu so disataṁ gato”ti."
    },
    {
      "id": "pv21:23.1",
      "pali": "“Nāhaṁ pajānāmi asayhasāhino,"
    },
    {
      "id": "pv21:23.2",
      "pali": "Aṅgīrasassa gatiṁ āgatiṁ vā;"
    },
    {
      "id": "pv21:23.3",
      "pali": "Sutañca me vessavaṇassa santike,"
    },
    {
      "id": "pv21:23.4",
      "pali": "Sakkassa sahabyataṁ gato asayho”ti."
    },
    {
      "id": "pv21:24.1",
      "pali": "“Alameva kātuṁ kalyāṇaṁ,"
    },
    {
      "id": "pv21:24.2",
      "pali": "dānaṁ dātuṁ yathārahaṁ;"
    },
    {
      "id": "pv21:24.3",
      "pali": "Pāṇiṁ kāmadadaṁ disvā,"
    },
    {
      "id": "pv21:24.4",
      "pali": "ko puññaṁ na karissati."
    },
    {
      "id": "pv21:25.1",
      "pali": "So hi nūna ito gantvā,"
    },
    {
      "id": "pv21:25.2",
      "pali": "anuppatvāna dvārakaṁ;"
    },
    {
      "id": "pv21:25.3",
      "pali": "Dānaṁ paṭṭhapayissāmi,"
    },
    {
      "id": "pv21:25.4",
      "pali": "yaṁ mamassa sukhāvahaṁ."
    },
    {
      "id": "pv21:26.1",
      "pali": "Dassāmannañca pānañca,"
    },
    {
      "id": "pv21:26.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "pv21:26.3",
      "pali": "Papañca udapānañca,"
    },
    {
      "id": "pv21:26.4",
      "pali": "dugge saṅkamanāni cā”ti."
    },
    {
      "id": "pv21:27.1",
      "pali": "“Kena te aṅgulī kuṇā,"
    },
    {
      "id": "pv21:27.2",
      "pali": "mukhañca kuṇalīkataṁ;"
    },
    {
      "id": "pv21:27.3",
      "pali": "Akkhīni ca paggharanti,"
    },
    {
      "id": "pv21:27.4",
      "pali": "kiṁ pāpaṁ pakataṁ tayā”ti."
    },
    {
      "id": "pv21:28.1",
      "pali": "“Aṅgīrasassa gahapatino,"
    },
    {
      "id": "pv21:28.2",
      "pali": "Saddhassa gharamesino;"
    },
    {
      "id": "pv21:28.3",
      "pali": "Tassāhaṁ dānavissagge,"
    },
    {
      "id": "pv21:28.4",
      "pali": "Dāne adhikato ahuṁ."
    },
    {
      "id": "pv21:29.1",
      "pali": "Tattha yācanake disvā,"
    },
    {
      "id": "pv21:29.2",
      "pali": "āgate bhojanatthike;"
    },
    {
      "id": "pv21:29.3",
      "pali": "Ekamantaṁ apakkamma,"
    },
    {
      "id": "pv21:29.4",
      "pali": "akāsiṁ kuṇaliṁ mukhaṁ."
    },
    {
      "id": "pv21:30.1",
      "pali": "Tena me aṅgulī kuṇā,"
    },
    {
      "id": "pv21:30.2",
      "pali": "mukhañca kuṇalīkataṁ;"
    },
    {
      "id": "pv21:30.3",
      "pali": "Akkhīni me paggharanti,"
    },
    {
      "id": "pv21:30.4",
      "pali": "taṁ pāpaṁ pakataṁ mayā”ti."
    },
    {
      "id": "pv21:31.1",
      "pali": "“Dhammena te kāpurisa,"
    },
    {
      "id": "pv21:31.2",
      "pali": "mukhañca kuṇalīkataṁ;"
    },
    {
      "id": "pv21:31.3",
      "pali": "Akkhīni ca paggharanti,"
    },
    {
      "id": "pv21:31.4",
      "pali": "yaṁ taṁ parassa dānassa;"
    },
    {
      "id": "pv21:31.5",
      "pali": "Akāsi kuṇaliṁ mukhaṁ."
    },
    {
      "id": "pv21:32.1",
      "pali": "Kathaṁ hi dānaṁ dadamāno,"
    },
    {
      "id": "pv21:32.2",
      "pali": "kareyya parapattiyaṁ;"
    },
    {
      "id": "pv21:32.3",
      "pali": "Annaṁ pānaṁ khādanīyaṁ,"
    },
    {
      "id": "pv21:32.4",
      "pali": "vatthasenāsanāni ca."
    },
    {
      "id": "pv21:33.1",
      "pali": "So hi nūna ito gantvā,"
    },
    {
      "id": "pv21:33.2",
      "pali": "anuppatvāna dvārakaṁ;"
    },
    {
      "id": "pv21:33.3",
      "pali": "Dānaṁ paṭṭhapayissāmi,"
    },
    {
      "id": "pv21:33.4",
      "pali": "yaṁ mamassa sukhāvahaṁ."
    },
    {
      "id": "pv21:34.1",
      "pali": "Dassāmannañca pānañca,"
    },
    {
      "id": "pv21:34.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "pv21:34.3",
      "pali": "Papañca udapānañca,"
    },
    {
      "id": "pv21:34.4",
      "pali": "dugge saṅkamanāni cā”ti."
    },
    {
      "id": "pv21:35.1",
      "pali": "Tato hi so nivattitvā,"
    },
    {
      "id": "pv21:35.2",
      "pali": "anuppatvāna dvārakaṁ;"
    },
    {
      "id": "pv21:35.3",
      "pali": "Dānaṁ paṭṭhapayi aṅkuro,"
    },
    {
      "id": "pv21:35.4",
      "pali": "yaṁtumassa sukhāvahaṁ."
    },
    {
      "id": "pv21:36.1",
      "pali": "Adā annañca pānañca,"
    },
    {
      "id": "pv21:36.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "pv21:36.3",
      "pali": "Papañca udapānañca,"
    },
    {
      "id": "pv21:36.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "pv21:37.1",
      "pali": "Ko chāto ko ca tasito,"
    },
    {
      "id": "pv21:37.2",
      "pali": "ko vatthaṁ paridahissati;"
    },
    {
      "id": "pv21:37.3",
      "pali": "Kassa santāni yoggāni,"
    },
    {
      "id": "pv21:37.4",
      "pali": "ito yojentu vāhanaṁ."
    },
    {
      "id": "pv21:38.1",
      "pali": "Ko chatticchati gandhañca,"
    },
    {
      "id": "pv21:38.2",
      "pali": "ko mālaṁ ko upāhanaṁ;"
    },
    {
      "id": "pv21:38.3",
      "pali": "Itissu tattha ghosenti,"
    },
    {
      "id": "pv21:38.4",
      "pali": "kappakā sūdamāgadhā;"
    },
    {
      "id": "pv21:38.5",
      "pali": "Sadā sāyañca pāto ca,"
    },
    {
      "id": "pv21:38.6",
      "pali": "aṅkurassa nivesane."
    },
    {
      "id": "pv21:39.1",
      "pali": "“‘Sukhaṁ supati aṅkuro’,"
    },
    {
      "id": "pv21:39.2",
      "pali": "iti jānāti maṁ jano;"
    },
    {
      "id": "pv21:39.3",
      "pali": "Dukkhaṁ supāmi sindhaka,"
    },
    {
      "id": "pv21:39.4",
      "pali": "yaṁ na passāmi yācake."
    },
    {
      "id": "pv21:40.1",
      "pali": "‘Sukhaṁ supati aṅkuro’,"
    },
    {
      "id": "pv21:40.2",
      "pali": "iti jānāti maṁ jano;"
    },
    {
      "id": "pv21:40.3",
      "pali": "Dukkhaṁ sindhaka supāmi,"
    },
    {
      "id": "pv21:40.4",
      "pali": "appake su vanibbake”ti."
    },
    {
      "id": "pv21:41.1",
      "pali": "“Sakko ce te varaṁ dajjā,"
    },
    {
      "id": "pv21:41.2",
      "pali": "tāvatiṁsānamissaro;"
    },
    {
      "id": "pv21:41.3",
      "pali": "Kissa sabbassa lokassa,"
    },
    {
      "id": "pv21:41.4",
      "pali": "varamāno varaṁ vare”ti."
    },
    {
      "id": "pv21:42.1",
      "pali": "“Sakko ce me varaṁ dajjā,"
    },
    {
      "id": "pv21:42.2",
      "pali": "tāvatiṁsānamissaro;"
    },
    {
      "id": "pv21:42.3",
      "pali": "Kāluṭṭhitassa me sato,"
    },
    {
      "id": "pv21:42.4",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "pv21:42.5",
      "pali": "Dibbā bhakkhā pātubhaveyyuṁ,"
    },
    {
      "id": "pv21:42.6",
      "pali": "sīlavanto ca yācakā."
    },
    {
      "id": "pv21:43.1",
      "pali": "Dadato me na khīyetha,"
    },
    {
      "id": "pv21:43.2",
      "pali": "datvā nānutapeyyahaṁ;"
    },
    {
      "id": "pv21:43.3",
      "pali": "Dadaṁ cittaṁ pasādeyyaṁ,"
    },
    {
      "id": "pv21:43.4",
      "pali": "etaṁ sakkaṁ varaṁ vare”ti."
    },
    {
      "id": "pv21:44.1",
      "pali": "“Na sabbavittāni pare pavecche,"
    },
    {
      "id": "pv21:44.2",
      "pali": "Dadeyya dānañca dhanañca rakkhe;"
    },
    {
      "id": "pv21:44.3",
      "pali": "Tasmā hi dānā dhanameva seyyo,"
    },
    {
      "id": "pv21:44.4",
      "pali": "Atippadānena kulā na honti."
    },
    {
      "id": "pv21:45.1",
      "pali": "Adānamatidānañca,"
    },
    {
      "id": "pv21:45.2",
      "pali": "Nappasaṁsanti paṇḍitā;"
    },
    {
      "id": "pv21:45.3",
      "pali": "Tasmā hi dānā dhanameva seyyo,"
    },
    {
      "id": "pv21:45.4",
      "pali": "Samena vatteyya sa dhīradhammo”ti."
    },
    {
      "id": "pv21:46.1",
      "pali": "“Aho vata re ahameva dajjaṁ,"
    },
    {
      "id": "pv21:46.2",
      "pali": "Santo ca maṁ sappurisā bhajeyyuṁ;"
    },
    {
      "id": "pv21:46.3",
      "pali": "Meghova ninnāni paripūrayanto,"
    },
    {
      "id": "pv21:46.4",
      "pali": "Santappaye sabbavanibbakānaṁ."
    },
    {
      "id": "pv21:47.1",
      "pali": "Yassa yācanake disvā,"
    },
    {
      "id": "pv21:47.2",
      "pali": "mukhavaṇṇo pasīdati;"
    },
    {
      "id": "pv21:47.3",
      "pali": "Datvā attamano hoti,"
    },
    {
      "id": "pv21:47.4",
      "pali": "taṁ gharaṁ vasato sukhaṁ."
    },
    {
      "id": "pv21:48.1",
      "pali": "Yassa yācanake disvā,"
    },
    {
      "id": "pv21:48.2",
      "pali": "mukhavaṇṇo pasīdati;"
    },
    {
      "id": "pv21:48.3",
      "pali": "Datvā attamano hoti,"
    },
    {
      "id": "pv21:48.4",
      "pali": "esā yaññassa sampadā."
    },
    {
      "id": "pv21:49.1",
      "pali": "Pubbeva dānā sumano,"
    },
    {
      "id": "pv21:49.2",
      "pali": "dadaṁ cittaṁ pasādaye;"
    },
    {
      "id": "pv21:49.3",
      "pali": "Datvā attamano hoti,"
    },
    {
      "id": "pv21:49.4",
      "pali": "esā yaññassa sampadā”ti."
    },
    {
      "id": "pv21:50.1",
      "pali": "Saṭṭhi vāhasahassāni,"
    },
    {
      "id": "pv21:50.2",
      "pali": "aṅkurassa nivesane;"
    },
    {
      "id": "pv21:50.3",
      "pali": "Bhojanaṁ dīyate niccaṁ,"
    },
    {
      "id": "pv21:50.4",
      "pali": "puññapekkhassa jantuno."
    },
    {
      "id": "pv21:51.1",
      "pali": "Tisahassāni sūdāni hi,"
    },
    {
      "id": "pv21:51.2",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "pv21:51.3",
      "pali": "Aṅkuraṁ upajīvanti,"
    },
    {
      "id": "pv21:51.4",
      "pali": "dāne yaññassa vāvaṭā."
    },
    {
      "id": "pv21:52.1",
      "pali": "Saṭṭhi purisasahassāni,"
    },
    {
      "id": "pv21:52.2",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "pv21:52.3",
      "pali": "Aṅkurassa mahādāne,"
    },
    {
      "id": "pv21:52.4",
      "pali": "kaṭṭhaṁ phālenti māṇavā."
    },
    {
      "id": "pv21:53.1",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "pv21:53.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "pv21:53.3",
      "pali": "Aṅkurassa mahādāne,"
    },
    {
      "id": "pv21:53.4",
      "pali": "vidhā piṇḍenti nāriyo."
    },
    {
      "id": "pv21:54.1",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "pv21:54.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "pv21:54.3",
      "pali": "Aṅkurassa mahādāne,"
    },
    {
      "id": "pv21:54.4",
      "pali": "dabbigāhā upaṭṭhitā."
    },
    {
      "id": "pv21:55.1",
      "pali": "Bahuṁ bahūnaṁ pādāsi,"
    },
    {
      "id": "pv21:55.2",
      "pali": "ciraṁ pādāsi khattiyo;"
    },
    {
      "id": "pv21:55.3",
      "pali": "Sakkaccañca sahatthā ca,"
    },
    {
      "id": "pv21:55.4",
      "pali": "cittīkatvā punappunaṁ."
    },
    {
      "id": "pv21:56.1",
      "pali": "Bahū māse ca pakkhe ca,"
    },
    {
      "id": "pv21:56.2",
      "pali": "utusaṁvaccharāni ca;"
    },
    {
      "id": "pv21:56.3",
      "pali": "Mahādānaṁ pavattesi,"
    },
    {
      "id": "pv21:56.4",
      "pali": "aṅkuro dīghamantaraṁ."
    },
    {
      "id": "pv21:57.1",
      "pali": "Evaṁ datvā yajitvā ca,"
    },
    {
      "id": "pv21:57.2",
      "pali": "aṅkuro dīghamantaraṁ;"
    },
    {
      "id": "pv21:57.3",
      "pali": "So hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "pv21:57.4",
      "pali": "tāvatiṁsūpago ahu."
    },
    {
      "id": "pv21:58.1",
      "pali": "Kaṭacchubhikkhaṁ datvāna,"
    },
    {
      "id": "pv21:58.2",
      "pali": "anuruddhassa indako;"
    },
    {
      "id": "pv21:58.3",
      "pali": "So hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "pv21:58.4",
      "pali": "tāvatiṁsūpago ahu."
    },
    {
      "id": "pv21:59.1",
      "pali": "Dasahi ṭhānehi aṅkuraṁ,"
    },
    {
      "id": "pv21:59.2",
      "pali": "indako atirocati;"
    },
    {
      "id": "pv21:59.3",
      "pali": "Rūpe sadde rase gandhe,"
    },
    {
      "id": "pv21:59.4",
      "pali": "phoṭṭhabbe ca manorame."
    },
    {
      "id": "pv21:60.1",
      "pali": "Āyunā yasasā ceva,"
    },
    {
      "id": "pv21:60.2",
      "pali": "vaṇṇena ca sukhena ca;"
    },
    {
      "id": "pv21:60.3",
      "pali": "Ādhipaccena aṅkuraṁ,"
    },
    {
      "id": "pv21:60.4",
      "pali": "indako atirocati."
    },
    {
      "id": "pv21:61.1",
      "pali": "(…)"
    },
    {
      "id": "pv21:62.1",
      "pali": "Tāvatiṁse yadā buddho,"
    },
    {
      "id": "pv21:62.2",
      "pali": "silāyaṁ paṇḍukambale;"
    },
    {
      "id": "pv21:62.3",
      "pali": "Pāricchattakamūlamhi,"
    },
    {
      "id": "pv21:62.4",
      "pali": "vihāsi purisuttamo."
    },
    {
      "id": "pv21:63.1",
      "pali": "Dasasu lokadhātūsu,"
    },
    {
      "id": "pv21:63.2",
      "pali": "sannipatitvāna devatā;"
    },
    {
      "id": "pv21:63.3",
      "pali": "Payirupāsanti sambuddhaṁ,"
    },
    {
      "id": "pv21:63.4",
      "pali": "vasantaṁ nagamuddhani."
    },
    {
      "id": "pv21:64.1",
      "pali": "Na koci devo vaṇṇena,"
    },
    {
      "id": "pv21:64.2",
      "pali": "sambuddhaṁ atirocati;"
    },
    {
      "id": "pv21:64.3",
      "pali": "Sabbe deve atikkamma,"
    },
    {
      "id": "pv21:64.4",
      "pali": "sambuddhova virocati."
    },
    {
      "id": "pv21:65.1",
      "pali": "Yojanāni dasa dve ca,"
    },
    {
      "id": "pv21:65.2",
      "pali": "aṅkuroyaṁ tadā ahu;"
    },
    {
      "id": "pv21:65.3",
      "pali": "Avidūreva buddhassa,"
    },
    {
      "id": "pv21:65.4",
      "pali": "indako atirocati."
    },
    {
      "id": "pv21:66.1",
      "pali": "Oloketvāna sambuddho,"
    },
    {
      "id": "pv21:66.2",
      "pali": "Aṅkurañcāpi indakaṁ;"
    },
    {
      "id": "pv21:66.3",
      "pali": "Dakkhiṇeyyaṁ sambhāvento,"
    },
    {
      "id": "pv21:66.4",
      "pali": "Idaṁ vacanamabravi."
    },
    {
      "id": "pv21:67.1",
      "pali": "“Mahādānaṁ tayā dinnaṁ,"
    },
    {
      "id": "pv21:67.2",
      "pali": "aṅkura dīghamantaraṁ;"
    },
    {
      "id": "pv21:67.3",
      "pali": "Atidūre nisinnosi,"
    },
    {
      "id": "pv21:67.4",
      "pali": "āgaccha mama santike”ti."
    },
    {
      "id": "pv21:68.1",
      "pali": "Codito bhāvitattena,"
    },
    {
      "id": "pv21:68.2",
      "pali": "aṅkuro idamabravi;"
    },
    {
      "id": "pv21:68.3",
      "pali": "“Kiṁ mayhaṁ tena dānena,"
    },
    {
      "id": "pv21:68.4",
      "pali": "dakkhiṇeyyena suññataṁ."
    },
    {
      "id": "pv21:69.1",
      "pali": "Ayaṁ so indako yakkho,"
    },
    {
      "id": "pv21:69.2",
      "pali": "dajjā dānaṁ parittakaṁ;"
    },
    {
      "id": "pv21:69.3",
      "pali": "Atirocati amhehi,"
    },
    {
      "id": "pv21:69.4",
      "pali": "cando tāragaṇe yathā”ti."
    },
    {
      "id": "pv21:70.1",
      "pali": "“Ujjaṅgale yathā khette,"
    },
    {
      "id": "pv21:70.2",
      "pali": "bījaṁ bahumpi ropitaṁ;"
    },
    {
      "id": "pv21:70.3",
      "pali": "Na vipulaphalaṁ hoti,"
    },
    {
      "id": "pv21:70.4",
      "pali": "napi toseti kassakaṁ."
    },
    {
      "id": "pv21:71.1",
      "pali": "Tatheva dānaṁ bahukaṁ,"
    },
    {
      "id": "pv21:71.2",
      "pali": "dussīlesu patiṭṭhitaṁ;"
    },
    {
      "id": "pv21:71.3",
      "pali": "Na vipulaphalaṁ hoti,"
    },
    {
      "id": "pv21:71.4",
      "pali": "napi toseti dāyakaṁ."
    },
    {
      "id": "pv21:72.1",
      "pali": "Yathāpi bhaddake khette,"
    },
    {
      "id": "pv21:72.2",
      "pali": "bījaṁ appampi ropitaṁ;"
    },
    {
      "id": "pv21:72.3",
      "pali": "Sammā dhāraṁ pavecchante,"
    },
    {
      "id": "pv21:72.4",
      "pali": "phalaṁ toseti kassakaṁ."
    },
    {
      "id": "pv21:73.1",
      "pali": "Tatheva sīlavantesu,"
    },
    {
      "id": "pv21:73.2",
      "pali": "guṇavantesu tādisu;"
    },
    {
      "id": "pv21:73.3",
      "pali": "Appakampi kataṁ kāraṁ,"
    },
    {
      "id": "pv21:73.4",
      "pali": "puññaṁ hoti mahapphalan”ti."
    },
    {
      "id": "pv21:74.1",
      "pali": "Viceyya dānaṁ dātabbaṁ,"
    },
    {
      "id": "pv21:74.2",
      "pali": "yattha dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "pv21:74.3",
      "pali": "Viceyya dānaṁ datvāna,"
    },
    {
      "id": "pv21:74.4",
      "pali": "saggaṁ gacchanti dāyakā."
    },
    {
      "id": "pv21:75.1",
      "pali": "Viceyya dānaṁ sugatappasatthaṁ,"
    },
    {
      "id": "pv21:75.2",
      "pali": "Ye dakkhiṇeyyā idha jīvaloke;"
    },
    {
      "id": "pv21:75.3",
      "pali": "Etesu dinnāni mahapphalāni,"
    },
    {
      "id": "pv21:75.4",
      "pali": "Bījāni vuttāni yathā sukhetteti."
    },
    {
      "id": "pv21:76.1",
      "pali": "Aṅkurapetavatthu navamaṁ."
    }
  ]
}
