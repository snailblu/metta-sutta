{
  "uid": "ja433",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja433:1.1",
      "pali": "“Assa indasamo rāja,"
    },
    {
      "id": "ja433:1.2",
      "pali": "accantaṁ ajarāmaro;"
    },
    {
      "id": "ja433:1.3",
      "pali": "Sace tvaṁ yaññaṁ yājeyya,"
    },
    {
      "id": "ja433:1.4",
      "pali": "isiṁ lomasakassapaṁ”."
    },
    {
      "id": "ja433:2.1",
      "pali": "“Sasamuddapariyāyaṁ,"
    },
    {
      "id": "ja433:2.2",
      "pali": "mahiṁ sāgarakuṇḍalaṁ;"
    },
    {
      "id": "ja433:2.3",
      "pali": "Na icche saha nindāya,"
    },
    {
      "id": "ja433:2.4",
      "pali": "evaṁ seyya vijānahi."
    },
    {
      "id": "ja433:3.1",
      "pali": "Dhiratthu taṁ yasalābhaṁ,"
    },
    {
      "id": "ja433:3.2",
      "pali": "dhanalābhañca brāhmaṇa;"
    },
    {
      "id": "ja433:3.3",
      "pali": "Yā vutti vinipātena,"
    },
    {
      "id": "ja433:3.4",
      "pali": "adhammacaraṇena vā."
    },
    {
      "id": "ja433:4.1",
      "pali": "Api ce pattamādāya,"
    },
    {
      "id": "ja433:4.2",
      "pali": "anagāro paribbaje;"
    },
    {
      "id": "ja433:4.3",
      "pali": "Sāyeva jīvikā seyyo,"
    },
    {
      "id": "ja433:4.4",
      "pali": "yā cādhammena esanā."
    },
    {
      "id": "ja433:5.1",
      "pali": "Api ce pattamādāya,"
    },
    {
      "id": "ja433:5.2",
      "pali": "anagāro paribbaje;"
    },
    {
      "id": "ja433:5.3",
      "pali": "Aññaṁ ahiṁsayaṁ loke,"
    },
    {
      "id": "ja433:5.4",
      "pali": "api rajjena taṁ varaṁ”."
    },
    {
      "id": "ja433:6.1",
      "pali": "“Balaṁ cando balaṁ suriyo,"
    },
    {
      "id": "ja433:6.2",
      "pali": "balaṁ samaṇabrāhmaṇā;"
    },
    {
      "id": "ja433:6.3",
      "pali": "Balaṁ velā samuddassa,"
    },
    {
      "id": "ja433:6.4",
      "pali": "balātibalamitthiyo."
    },
    {
      "id": "ja433:7.1",
      "pali": "Yathā uggatapaṁ santaṁ,"
    },
    {
      "id": "ja433:7.2",
      "pali": "isiṁ lomasakassapaṁ;"
    },
    {
      "id": "ja433:7.3",
      "pali": "Pitu atthā candavatī,"
    },
    {
      "id": "ja433:7.4",
      "pali": "vājapeyyaṁ ayājayi”."
    },
    {
      "id": "ja433:8.1",
      "pali": "“Taṁ lobhapakataṁ kammaṁ,"
    },
    {
      "id": "ja433:8.2",
      "pali": "Kaṭukaṁ kāmahetukaṁ;"
    },
    {
      "id": "ja433:8.3",
      "pali": "Tassa mūlaṁ gavesissaṁ,"
    },
    {
      "id": "ja433:8.4",
      "pali": "Checchaṁ rāgaṁ sabandhanaṁ."
    },
    {
      "id": "ja433:9.1",
      "pali": "Dhiratthu kāme subahūpi loke,"
    },
    {
      "id": "ja433:9.2",
      "pali": "Tapova seyyo kāmaguṇehi rāja;"
    },
    {
      "id": "ja433:9.3",
      "pali": "Tapo karissāmi pahāya kāme,"
    },
    {
      "id": "ja433:9.4",
      "pali": "Taveva raṭṭhaṁ candavatī ca hotū”ti."
    },
    {
      "id": "ja433:10.1",
      "pali": "Lomasakassapajātakaṁ sattamaṁ."
    }
  ]
}
