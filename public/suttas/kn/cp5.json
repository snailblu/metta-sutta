{
  "uid": "cp5",
  "title": "Dānapāramī 5",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp5:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp5:1.2",
      "pali": "sattarājapurohito;"
    },
    {
      "id": "cp5:1.3",
      "pali": "Pūjito naradevehi,"
    },
    {
      "id": "cp5:1.4",
      "pali": "mahāgovindabrāhmaṇo."
    },
    {
      "id": "cp5:2.1",
      "pali": "Tadāhaṁ sattarajjesu,"
    },
    {
      "id": "cp5:2.2",
      "pali": "Yaṁ me āsi upāyanaṁ;"
    },
    {
      "id": "cp5:2.3",
      "pali": "Tena demi mahādānaṁ,"
    },
    {
      "id": "cp5:2.4",
      "pali": "Akkhobbhaṁ sāgarūpamaṁ."
    },
    {
      "id": "cp5:3.1",
      "pali": "Na me dessaṁ dhanaṁ dhaññaṁ,"
    },
    {
      "id": "cp5:3.2",
      "pali": "Napi natthi nicayo mayi;"
    },
    {
      "id": "cp5:3.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp5:3.4",
      "pali": "Tasmā demi varaṁ dhanan”ti."
    },
    {
      "id": "cp5:4.1",
      "pali": "Mahāgovindacariyaṁ pañcamaṁ."
    }
  ]
}
