{
  "uid": "tha-ap117",
  "title": "Suvaṇṇapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap117:1.1",
      "pali": "“Vipassī nāma bhagavā,"
    },
    {
      "id": "tha-ap117:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap117:1.3",
      "pali": "Nisinno janakāyassa,"
    },
    {
      "id": "tha-ap117:1.4",
      "pali": "desesi amataṁ padaṁ."
    },
    {
      "id": "tha-ap117:2.1",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "tha-ap117:2.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap117:2.3",
      "pali": "Soṇṇapupphāni cattāri,"
    },
    {
      "id": "tha-ap117:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap117:3.1",
      "pali": "Suvaṇṇacchadanaṁ āsi,"
    },
    {
      "id": "tha-ap117:3.2",
      "pali": "yāvatā parisā tadā;"
    },
    {
      "id": "tha-ap117:3.3",
      "pali": "Buddhābhā ca suvaṇṇābhā,"
    },
    {
      "id": "tha-ap117:3.4",
      "pali": "āloko vipulo ahu."
    },
    {
      "id": "tha-ap117:4.1",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap117:4.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap117:4.3",
      "pali": "Vittisañjanano tesaṁ,"
    },
    {
      "id": "tha-ap117:4.4",
      "pali": "diṭṭhadhammasukhāvaho."
    },
    {
      "id": "tha-ap117:5.1",
      "pali": "Āyācitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap117:5.2",
      "pali": "vanditvāna ca subbataṁ;"
    },
    {
      "id": "tha-ap117:5.3",
      "pali": "Pāmojjaṁ janayitvāna,"
    },
    {
      "id": "tha-ap117:5.4",
      "pali": "sakaṁ bhavanupāgamiṁ."
    },
    {
      "id": "tha-ap117:6.1",
      "pali": "Bhavane upaviṭṭhohaṁ,"
    },
    {
      "id": "tha-ap117:6.2",
      "pali": "buddhaseṭṭhaṁ anussariṁ;"
    },
    {
      "id": "tha-ap117:6.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap117:6.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap117:7.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap117:7.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap117:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap117:7.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap117:8.1",
      "pali": "Soḷasāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap117:8.2",
      "pali": "nemisammatanāmakā;"
    },
    {
      "id": "tha-ap117:8.3",
      "pali": "Tetālīse ito kappe,"
    },
    {
      "id": "tha-ap117:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap117:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap117:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap117:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap117:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā suvaṇṇapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap117:11.1",
      "pali": "Suvaṇṇapupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
