{
  "uid": "iti59",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti59:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti59:2.1",
      "pali": "“Tīhi, bhikkhave, dhammehi samannāgato bhikkhu atikkamma māradheyyaṁ ādiccova virocati."
    },
    {
      "id": "iti59:2.2",
      "pali": "Katamehi tīhi?"
    },
    {
      "id": "iti59:2.3",
      "pali": "Idha, bhikkhave, bhikkhu asekhena sīlakkhandhena samannāgato hoti, asekhena samādhikkhandhena samannāgato hoti, asekhena paññākkhandhena samannāgato hoti—"
    },
    {
      "id": "iti59:2.4",
      "pali": "imehi kho, bhikkhave, tīhi dhammehi samannāgato bhikkhu atikkamma māradheyyaṁ ādiccova virocatī”ti."
    },
    {
      "id": "iti59:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti59:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti59:3.1",
      "pali": "“Sīlaṁ samādhi paññā ca,"
    },
    {
      "id": "iti59:3.2",
      "pali": "yassa ete subhāvitā;"
    },
    {
      "id": "iti59:3.3",
      "pali": "Atikkamma māradheyyaṁ,"
    },
    {
      "id": "iti59:3.4",
      "pali": "ādiccova virocatī”ti."
    },
    {
      "id": "iti59:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti59:4.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti59:4.3",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "iti59:5.1",
      "pali": "Mūladhātu atha vedanā duve,"
    },
    {
      "id": "iti59:5.2",
      "pali": "Esanā ca duve āsavā duve;"
    },
    {
      "id": "iti59:5.3",
      "pali": "Taṇhāto ca atha māradheyyato,"
    },
    {
      "id": "iti59:5.4",
      "pali": "Vaggamāhu paṭhamanti muttamanti."
    }
  ]
}
