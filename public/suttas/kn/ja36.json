{
  "uid": "ja36",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja36:1.1",
      "pali": "“Yaṁ nissitā jagatiruhaṁ vihaṅgamā,"
    },
    {
      "id": "ja36:1.2",
      "pali": "Svāyaṁ aggiṁ pamuñcati;"
    },
    {
      "id": "ja36:1.3",
      "pali": "Disā bhajatha vakkaṅgā,"
    },
    {
      "id": "ja36:1.4",
      "pali": "Jātaṁ saraṇato bhayan”ti."
    },
    {
      "id": "ja36:2.1",
      "pali": "Sakuṇajātakaṁ chaṭṭhaṁ."
    }
  ]
}
