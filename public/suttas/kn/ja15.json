{
  "uid": "ja15",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja15:1.1",
      "pali": "“Aṭṭhakkhuraṁ kharādiye,"
    },
    {
      "id": "ja15:1.2",
      "pali": "migaṁ vaṅkātivaṅkinaṁ;"
    },
    {
      "id": "ja15:1.3",
      "pali": "Sattahi kālātikkantaṁ,"
    },
    {
      "id": "ja15:1.4",
      "pali": "na naṁ ovaditussahe”ti."
    },
    {
      "id": "ja15:2.1",
      "pali": "Kharādiyajātakaṁ pañcamaṁ."
    }
  ]
}
