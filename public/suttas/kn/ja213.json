{
  "uid": "ja213",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja213:1.1",
      "pali": "“Isīnamantaraṁ katvā,"
    },
    {
      "id": "ja213:1.2",
      "pali": "bharurājāti me sutaṁ;"
    },
    {
      "id": "ja213:1.3",
      "pali": "Ucchinno saha raṭṭhehi,"
    },
    {
      "id": "ja213:1.4",
      "pali": "sarājā vibhavaṅgato."
    },
    {
      "id": "ja213:2.1",
      "pali": "Tasmā hi chandāgamanaṁ,"
    },
    {
      "id": "ja213:2.2",
      "pali": "nappasaṁsanti paṇḍitā;"
    },
    {
      "id": "ja213:2.3",
      "pali": "Aduṭṭhacitto bhāseyya,"
    },
    {
      "id": "ja213:2.4",
      "pali": "giraṁ saccupasaṁhitan”ti."
    },
    {
      "id": "ja213:3.1",
      "pali": "Bharujātakaṁ tatiyaṁ."
    }
  ]
}
