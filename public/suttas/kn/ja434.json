{
  "uid": "ja434",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja434:1.1",
      "pali": "“Kāsāyavatthe sakuṇe vadāmi,"
    },
    {
      "id": "ja434:1.2",
      "pali": "Duve duve nandamane carante;"
    },
    {
      "id": "ja434:1.3",
      "pali": "Kaṁ aṇḍajaṁ aṇḍajā mānusesu,"
    },
    {
      "id": "ja434:1.4",
      "pali": "Jātiṁ pasaṁsanti tadiṅgha brūtha”."
    },
    {
      "id": "ja434:2.1",
      "pali": "“Amhe manussesu manussahiṁsa,"
    },
    {
      "id": "ja434:2.2",
      "pali": "Anubbate cakkavāke vadanti;"
    },
    {
      "id": "ja434:2.3",
      "pali": "Kalyāṇabhāvamhe dijesu sammatā,"
    },
    {
      "id": "ja434:2.4",
      "pali": "Abhirūpā vicarāma aṇṇave”."
    },
    {
      "id": "ja434:2.5",
      "pali": "(…)"
    },
    {
      "id": "ja434:3.1",
      "pali": "“Kiṁ aṇṇave kāni phalāni bhuñje,"
    },
    {
      "id": "ja434:3.2",
      "pali": "Maṁsaṁ kuto khādatha cakkavākā;"
    },
    {
      "id": "ja434:3.3",
      "pali": "Kiṁ bhojanaṁ bhuñjatha vo anomā,"
    },
    {
      "id": "ja434:3.4",
      "pali": "Balañca vaṇṇo ca anapparūpā”."
    },
    {
      "id": "ja434:4.1",
      "pali": "“Na aṇṇave santi phalāni dhaṅka,"
    },
    {
      "id": "ja434:4.2",
      "pali": "Maṁsaṁ kuto khādituṁ cakkavāke;"
    },
    {
      "id": "ja434:4.3",
      "pali": "Sevālabhakkhamha apāṇabhojanā,"
    },
    {
      "id": "ja434:4.4",
      "pali": "Na ghāsahetūpi karoma pāpaṁ”."
    },
    {
      "id": "ja434:5.1",
      "pali": "“Na me idaṁ ruccati cakkavāka,"
    },
    {
      "id": "ja434:5.2",
      "pali": "Asmiṁ bhave bhojanasannikāso;"
    },
    {
      "id": "ja434:5.3",
      "pali": "Ahosi pubbe tato me aññathā,"
    },
    {
      "id": "ja434:5.4",
      "pali": "Icceva me vimati ettha jātā."
    },
    {
      "id": "ja434:6.1",
      "pali": "Ahampi maṁsāni phalāni bhuñje,"
    },
    {
      "id": "ja434:6.2",
      "pali": "Annāni ca loṇiyateliyāni;"
    },
    {
      "id": "ja434:6.3",
      "pali": "Rasaṁ manussesu labhāmi bhottuṁ,"
    },
    {
      "id": "ja434:6.4",
      "pali": "Sūrova saṅgāmamukhaṁ vijetvā;"
    },
    {
      "id": "ja434:6.5",
      "pali": "Na ca me tādiso vaṇṇo,"
    },
    {
      "id": "ja434:6.6",
      "pali": "Cakkavāka yathā tava”."
    },
    {
      "id": "ja434:7.1",
      "pali": "“Asuddhabhakkhosi khaṇānupātī,"
    },
    {
      "id": "ja434:7.2",
      "pali": "Kicchena te labbhati annapānaṁ;"
    },
    {
      "id": "ja434:7.3",
      "pali": "Na tussasī rukkhaphalehi dhaṅka,"
    },
    {
      "id": "ja434:7.4",
      "pali": "Maṁsāni vā yāni susānamajjhe."
    },
    {
      "id": "ja434:8.1",
      "pali": "Yo sāhasena adhigamma bhoge,"
    },
    {
      "id": "ja434:8.2",
      "pali": "Paribhuñjati dhaṅka khaṇānupātī;"
    },
    {
      "id": "ja434:8.3",
      "pali": "Tato upakkosati naṁ sabhāvo,"
    },
    {
      "id": "ja434:8.4",
      "pali": "Upakkuṭṭho vaṇṇabalaṁ jahāti."
    },
    {
      "id": "ja434:9.1",
      "pali": "Appampi ce nibbutiṁ bhuñjatī yadi,"
    },
    {
      "id": "ja434:9.2",
      "pali": "Asāhasena aparūpaghātī;"
    },
    {
      "id": "ja434:9.3",
      "pali": "Balañca vaṇṇo ca tadassa hoti,"
    },
    {
      "id": "ja434:9.4",
      "pali": "Na hi sabbo āhāramayena vaṇṇo”ti."
    },
    {
      "id": "ja434:10.1",
      "pali": "Cakkavākajātakaṁ aṭṭhamaṁ."
    }
  ]
}
