{
  "uid": "ja132",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja132:1.1",
      "pali": "“Kusalūpadese dhitiyā daḷhāya ca,"
    },
    {
      "id": "ja132:1.2",
      "pali": "Anivattitattābhayabhīrutāya ca;"
    },
    {
      "id": "ja132:1.3",
      "pali": "Na rakkhasīnaṁ vasamāgamimhase,"
    },
    {
      "id": "ja132:1.4",
      "pali": "Sa sotthibhāvo mahatā bhayena me”ti."
    },
    {
      "id": "ja132:2.1",
      "pali": "Bhīrukajātakaṁ dutiyaṁ."
    }
  ]
}
