{
  "uid": "thi-ap34",
  "title": "4 Siṅgālamātutherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap34:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap34:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap34:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap34:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap34:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap34:2.2",
      "pali": "jātāmaccakule ahuṁ;"
    },
    {
      "id": "thi-ap34:2.3",
      "pali": "Nānāratanapajjote,"
    },
    {
      "id": "thi-ap34:2.4",
      "pali": "iddhe phīte mahaddhane."
    },
    {
      "id": "thi-ap34:3.1",
      "pali": "Pitunā saha gantvāna,"
    },
    {
      "id": "thi-ap34:3.2",
      "pali": "mahājanapurakkhatā;"
    },
    {
      "id": "thi-ap34:3.3",
      "pali": "Dhammaṁ buddhassa sutvāna,"
    },
    {
      "id": "thi-ap34:3.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap34:4.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "thi-ap34:4.2",
      "pali": "pāpakammaṁ vivajjayiṁ;"
    },
    {
      "id": "thi-ap34:4.3",
      "pali": "Vacīduccaritaṁ hitvā,"
    },
    {
      "id": "thi-ap34:4.4",
      "pali": "ājīvaṁ parisodhayiṁ."
    },
    {
      "id": "thi-ap34:5.1",
      "pali": "Buddhe pasannā dhamme ca,"
    },
    {
      "id": "thi-ap34:5.2",
      "pali": "saṅghe ca tibbagāravā;"
    },
    {
      "id": "thi-ap34:5.3",
      "pali": "Saddhammassavane yuttā,"
    },
    {
      "id": "thi-ap34:5.4",
      "pali": "buddhadassanalālasā."
    },
    {
      "id": "thi-ap34:6.1",
      "pali": "Aggaṁ saddhādhimuttānaṁ,"
    },
    {
      "id": "thi-ap34:6.2",
      "pali": "assosiṁ bhikkhuniṁ tadā;"
    },
    {
      "id": "thi-ap34:6.3",
      "pali": "Taṁ ṭhānaṁ patthayitvāna,"
    },
    {
      "id": "thi-ap34:6.4",
      "pali": "tisso sikkhā apūrayiṁ."
    },
    {
      "id": "thi-ap34:7.1",
      "pali": "Tato maṁ sugato āha,"
    },
    {
      "id": "thi-ap34:7.2",
      "pali": "karuṇānugatāsayo;"
    },
    {
      "id": "thi-ap34:7.3",
      "pali": "‘Yassa saddhā tathāgate,"
    },
    {
      "id": "thi-ap34:7.4",
      "pali": "acalā suppatiṭṭhitā;"
    },
    {
      "id": "thi-ap34:7.5",
      "pali": "Sīlañca yassa kalyāṇaṁ,"
    },
    {
      "id": "thi-ap34:7.6",
      "pali": "ariyakantaṁ pasaṁsitaṁ."
    },
    {
      "id": "thi-ap34:8.1",
      "pali": "Saṅghe pasādo yassatthi,"
    },
    {
      "id": "thi-ap34:8.2",
      "pali": "ujubhūtañca dassanaṁ;"
    },
    {
      "id": "thi-ap34:8.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "thi-ap34:8.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "thi-ap34:9.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "thi-ap34:9.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "thi-ap34:9.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "thi-ap34:9.4",
      "pali": "saraṁ buddhāna sāsanaṁ’."
    },
    {
      "id": "thi-ap34:10.1",
      "pali": "Taṁ sutvāhaṁ pamuditā,"
    },
    {
      "id": "thi-ap34:10.2",
      "pali": "apucchiṁ paṇidhiṁ mama;"
    },
    {
      "id": "thi-ap34:10.3",
      "pali": "Tadā anomo amito,"
    },
    {
      "id": "thi-ap34:10.4",
      "pali": "byākarittha vināyako;"
    },
    {
      "id": "thi-ap34:10.5",
      "pali": "‘Buddhe pasannā kalyāṇī,"
    },
    {
      "id": "thi-ap34:10.6",
      "pali": "lacchase taṁ supatthitaṁ."
    },
    {
      "id": "thi-ap34:11.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap34:11.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap34:11.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap34:11.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap34:12.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap34:12.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap34:12.3",
      "pali": "Siṅgālakassa mātāti,"
    },
    {
      "id": "thi-ap34:12.4",
      "pali": "hessati satthu sāvikā’."
    },
    {
      "id": "thi-ap34:13.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap34:13.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "thi-ap34:13.3",
      "pali": "Mettacittā paricariṁ,"
    },
    {
      "id": "thi-ap34:13.4",
      "pali": "paṭipattīhi nāyakaṁ."
    },
    {
      "id": "thi-ap34:14.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap34:14.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap34:14.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap34:14.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap34:15.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap34:15.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "thi-ap34:15.3",
      "pali": "Jātā seṭṭhikule phīte,"
    },
    {
      "id": "thi-ap34:15.4",
      "pali": "mahāratanasañcaye."
    },
    {
      "id": "thi-ap34:16.1",
      "pali": "Putto siṅgālako nāma,"
    },
    {
      "id": "thi-ap34:16.2",
      "pali": "mamāsi vipathe rato;"
    },
    {
      "id": "thi-ap34:16.3",
      "pali": "Diṭṭhigahanapakkhando,"
    },
    {
      "id": "thi-ap34:16.4",
      "pali": "disāpūjanatapparo."
    },
    {
      "id": "thi-ap34:17.1",
      "pali": "Nānādisā namassantaṁ,"
    },
    {
      "id": "thi-ap34:17.2",
      "pali": "piṇḍāya nagaraṁ vajaṁ;"
    },
    {
      "id": "thi-ap34:17.3",
      "pali": "Taṁ disvā ovadī buddho,"
    },
    {
      "id": "thi-ap34:17.4",
      "pali": "magge ṭhatvā vināyako."
    },
    {
      "id": "thi-ap34:18.1",
      "pali": "Tassa desayato dhammaṁ,"
    },
    {
      "id": "thi-ap34:18.2",
      "pali": "panādo vimhayo ahu;"
    },
    {
      "id": "thi-ap34:18.3",
      "pali": "Dvekoṭinaranārīnaṁ,"
    },
    {
      "id": "thi-ap34:18.4",
      "pali": "dhammābhisamayo ahu."
    },
    {
      "id": "thi-ap34:19.1",
      "pali": "Tadāhaṁ parisaṁ gantvā,"
    },
    {
      "id": "thi-ap34:19.2",
      "pali": "sutvā sugatabhāsitaṁ;"
    },
    {
      "id": "thi-ap34:19.3",
      "pali": "Sotāpattiphalaṁ pattā,"
    },
    {
      "id": "thi-ap34:19.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap34:20.1",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "thi-ap34:20.2",
      "pali": "buddhadassanalālasā;"
    },
    {
      "id": "thi-ap34:20.3",
      "pali": "Anussatiṁ taṁ bhāvetvā,"
    },
    {
      "id": "thi-ap34:20.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap34:21.1",
      "pali": "Dassanatthāya buddhassa,"
    },
    {
      "id": "thi-ap34:21.2",
      "pali": "sabbadā ca vajāmahaṁ;"
    },
    {
      "id": "thi-ap34:21.3",
      "pali": "Atittāyeva passāmi,"
    },
    {
      "id": "thi-ap34:21.4",
      "pali": "rūpaṁ nayananandanaṁ."
    },
    {
      "id": "thi-ap34:22.1",
      "pali": "Sabbapāramisambhūtaṁ,"
    },
    {
      "id": "thi-ap34:22.2",
      "pali": "lakkhīnilayanaṁ varaṁ;"
    },
    {
      "id": "thi-ap34:22.3",
      "pali": "Rūpaṁ sabbasubhākiṇṇaṁ,"
    },
    {
      "id": "thi-ap34:22.4",
      "pali": "atittā viharāmahaṁ."
    },
    {
      "id": "thi-ap34:23.1",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "thi-ap34:23.2",
      "pali": "etadagge ṭhapesi maṁ;"
    },
    {
      "id": "thi-ap34:23.3",
      "pali": "‘Siṅgālakassa yā mātā,"
    },
    {
      "id": "thi-ap34:23.4",
      "pali": "aggā saddhādhimuttikā’."
    },
    {
      "id": "thi-ap34:24.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap34:24.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap34:24.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap34:24.4",
      "pali": "vasī homi mahāmuni."
    },
    {
      "id": "thi-ap34:25.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap34:25.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap34:25.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap34:25.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap34:26.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap34:26.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap34:26.3",
      "pali": "Ñāṇaṁ mama mahāvīra,"
    },
    {
      "id": "thi-ap34:26.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap34:27.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap34:27.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap34:27.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap34:28.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap34:28.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap34:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap34:29.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap34:29.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap34:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap34:30.1",
      "pali": "Itthaṁ sudaṁ siṅgālamātā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap34:31.1",
      "pali": "Siṅgālamātutheriyāpadānaṁ catutthaṁ."
    }
  ]
}
