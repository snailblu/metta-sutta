{
  "uid": "thag2.45",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.45:1.1",
      "pali": "“Na ukkhipe no ca parikkhipe pare,"
    },
    {
      "id": "thag2.45:1.2",
      "pali": "Na okkhipe pāragataṁ na eraye;"
    },
    {
      "id": "thag2.45:1.3",
      "pali": "Na cattavaṇṇaṁ parisāsu byāhare,"
    },
    {
      "id": "thag2.45:1.4",
      "pali": "Anuddhato sammitabhāṇi subbato."
    },
    {
      "id": "thag2.45:2.1",
      "pali": "Susukhumanipuṇatthadassinā,"
    },
    {
      "id": "thag2.45:2.2",
      "pali": "Matikusalena nivātavuttinā;"
    },
    {
      "id": "thag2.45:2.3",
      "pali": "Saṁsevitavuddhasīlinā,"
    },
    {
      "id": "thag2.45:2.4",
      "pali": "Nibbānaṁ na hi tena dullabhan”ti."
    },
    {
      "id": "thag2.45:2.5",
      "pali": "… Visākho pañcālaputto thero …."
    }
  ]
}
