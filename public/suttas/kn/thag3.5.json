{
  "uid": "thag3.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.5:1.1",
      "pali": "“Atisītaṁ atiuṇhaṁ,"
    },
    {
      "id": "thag3.5:1.2",
      "pali": "atisāyamidaṁ ahu;"
    },
    {
      "id": "thag3.5:1.3",
      "pali": "Iti vissaṭṭhakammante,"
    },
    {
      "id": "thag3.5:1.4",
      "pali": "khaṇā accenti māṇave."
    },
    {
      "id": "thag3.5:2.1",
      "pali": "Yo ca sītañca uṇhañca,"
    },
    {
      "id": "thag3.5:2.2",
      "pali": "tiṇā bhiyyo na maññati;"
    },
    {
      "id": "thag3.5:2.3",
      "pali": "Karaṁ purisakiccāni,"
    },
    {
      "id": "thag3.5:2.4",
      "pali": "so sukhā na vihāyati."
    },
    {
      "id": "thag3.5:3.1",
      "pali": "Dabbaṁ kusaṁ poṭakilaṁ,"
    },
    {
      "id": "thag3.5:3.2",
      "pali": "usīraṁ muñjapabbajaṁ;"
    },
    {
      "id": "thag3.5:3.3",
      "pali": "Urasā panudissāmi,"
    },
    {
      "id": "thag3.5:3.4",
      "pali": "vivekamanubrūhayan”ti."
    },
    {
      "id": "thag3.5:3.5",
      "pali": "… Mātaṅgaputto thero …."
    }
  ]
}
