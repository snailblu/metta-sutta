{
  "uid": "ja168",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja168:1.1",
      "pali": "“Seno balasā patamāno,"
    },
    {
      "id": "ja168:1.2",
      "pali": "lāpaṁ gocaraṭhāyinaṁ;"
    },
    {
      "id": "ja168:1.3",
      "pali": "Sahasā ajjhappattova,"
    },
    {
      "id": "ja168:1.4",
      "pali": "maraṇaṁ tenupāgami."
    },
    {
      "id": "ja168:2.1",
      "pali": "Sohaṁ nayena sampanno,"
    },
    {
      "id": "ja168:2.2",
      "pali": "pettike gocare rato;"
    },
    {
      "id": "ja168:2.3",
      "pali": "Apetasattu modāmi,"
    },
    {
      "id": "ja168:2.4",
      "pali": "sampassaṁ atthamattano”ti."
    },
    {
      "id": "ja168:3.1",
      "pali": "Sakuṇagghijātakaṁ aṭṭhamaṁ."
    }
  ]
}
