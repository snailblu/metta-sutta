{
  "uid": "vv51",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv51:1.1",
      "pali": "“Ko me vandati pādāni,"
    },
    {
      "id": "vv51:1.2",
      "pali": "iddhiyā yasasā jalaṁ;"
    },
    {
      "id": "vv51:1.3",
      "pali": "Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv51:1.4",
      "pali": "sabbā obhāsayaṁ disā”ti."
    },
    {
      "id": "vv51:2.1",
      "pali": "“Maṇḍūkohaṁ pure āsiṁ,"
    },
    {
      "id": "vv51:2.2",
      "pali": "udake vārigocaro;"
    },
    {
      "id": "vv51:2.3",
      "pali": "Tava dhammaṁ suṇantassa,"
    },
    {
      "id": "vv51:2.4",
      "pali": "avadhī vacchapālako."
    },
    {
      "id": "vv51:3.1",
      "pali": "Muhuttaṁ cittapasādassa,"
    },
    {
      "id": "vv51:3.2",
      "pali": "iddhiṁ passa yasañca me;"
    },
    {
      "id": "vv51:3.3",
      "pali": "Ānubhāvañca me passa,"
    },
    {
      "id": "vv51:3.4",
      "pali": "vaṇṇaṁ passa jutiñca me."
    },
    {
      "id": "vv51:4.1",
      "pali": "Ye ca te dīghamaddhānaṁ,"
    },
    {
      "id": "vv51:4.2",
      "pali": "dhammaṁ assosuṁ gotama;"
    },
    {
      "id": "vv51:4.3",
      "pali": "Pattā te acalaṭṭhānaṁ,"
    },
    {
      "id": "vv51:4.4",
      "pali": "yattha gantvā na socare”ti."
    },
    {
      "id": "vv51:5.1",
      "pali": "Maṇḍūkadevaputtavimānaṁ paṭhamaṁ."
    }
  ]
}
