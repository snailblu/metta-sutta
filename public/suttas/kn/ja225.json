{
  "uid": "ja225",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja225:1.1",
      "pali": "“Atthi me puriso deva,"
    },
    {
      "id": "ja225:1.2",
      "pali": "sabbakiccesu byāvaṭo;"
    },
    {
      "id": "ja225:1.3",
      "pali": "Tassa cekoparādhatthi,"
    },
    {
      "id": "ja225:1.4",
      "pali": "tattha tvaṁ kinti maññasi”."
    },
    {
      "id": "ja225:2.1",
      "pali": "“Amhākampatthi puriso,"
    },
    {
      "id": "ja225:2.2",
      "pali": "ediso idha vijjati;"
    },
    {
      "id": "ja225:2.3",
      "pali": "Dullabho aṅgasampanno,"
    },
    {
      "id": "ja225:2.4",
      "pali": "khantirasmāka ruccatī”ti."
    },
    {
      "id": "ja225:3.1",
      "pali": "Khantivaṇṇajātakaṁ pañcamaṁ."
    }
  ]
}
