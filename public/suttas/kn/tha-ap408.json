{
  "uid": "tha-ap408",
  "title": "Nandakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap408:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap408:1.2",
      "pali": "Araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap408:1.3",
      "pali": "Pasadaṁ migamesanto,"
    },
    {
      "id": "tha-ap408:1.4",
      "pali": "Sayambhuṁ addasaṁ ahaṁ."
    },
    {
      "id": "tha-ap408:2.1",
      "pali": "Anuruddho nāma sambuddho,"
    },
    {
      "id": "tha-ap408:2.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap408:2.3",
      "pali": "Vivekakāmo so dhīro,"
    },
    {
      "id": "tha-ap408:2.4",
      "pali": "vanamajjhogahī tadā."
    },
    {
      "id": "tha-ap408:3.1",
      "pali": "Catudaṇḍe gahetvāna,"
    },
    {
      "id": "tha-ap408:3.2",
      "pali": "catuṭṭhāne ṭhapesahaṁ;"
    },
    {
      "id": "tha-ap408:3.3",
      "pali": "Maṇḍapaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap408:3.4",
      "pali": "padmapupphehi chādayiṁ."
    },
    {
      "id": "tha-ap408:4.1",
      "pali": "Maṇḍapaṁ chādayitvāna,"
    },
    {
      "id": "tha-ap408:4.2",
      "pali": "sayambhuṁ abhivādayiṁ;"
    },
    {
      "id": "tha-ap408:4.3",
      "pali": "Dhanuṁ tattheva nikkhippa,"
    },
    {
      "id": "tha-ap408:4.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap408:5.1",
      "pali": "Naciraṁ pabbajitassa,"
    },
    {
      "id": "tha-ap408:5.2",
      "pali": "byādhi me udapajjatha;"
    },
    {
      "id": "tha-ap408:5.3",
      "pali": "Pubbakammaṁ saritvāna,"
    },
    {
      "id": "tha-ap408:5.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap408:6.1",
      "pali": "Pubbakammena saṁyutto,"
    },
    {
      "id": "tha-ap408:6.2",
      "pali": "tusitaṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap408:6.3",
      "pali": "Tattha soṇṇamayaṁ byamhaṁ,"
    },
    {
      "id": "tha-ap408:6.4",
      "pali": "nibbattati yadicchakaṁ."
    },
    {
      "id": "tha-ap408:7.1",
      "pali": "Sahassayuttaṁ hayavāhiṁ,"
    },
    {
      "id": "tha-ap408:7.2",
      "pali": "dibbayānamadhiṭṭhito;"
    },
    {
      "id": "tha-ap408:7.3",
      "pali": "Āruhitvāna taṁ yānaṁ,"
    },
    {
      "id": "tha-ap408:7.4",
      "pali": "gacchāmahaṁ yadicchakaṁ."
    },
    {
      "id": "tha-ap408:8.1",
      "pali": "Tato me niyyamānassa,"
    },
    {
      "id": "tha-ap408:8.2",
      "pali": "devabhūtassa me sato;"
    },
    {
      "id": "tha-ap408:8.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap408:8.4",
      "pali": "maṇḍapo me dharīyati."
    },
    {
      "id": "tha-ap408:9.1",
      "pali": "Sayanehaṁ tuvaṭṭāmi,"
    },
    {
      "id": "tha-ap408:9.2",
      "pali": "acchanne pupphasanthate;"
    },
    {
      "id": "tha-ap408:9.3",
      "pali": "Antalikkhā ca padumā,"
    },
    {
      "id": "tha-ap408:9.4",
      "pali": "vassante niccakālikaṁ."
    },
    {
      "id": "tha-ap408:10.1",
      "pali": "Marīcike phandamāne,"
    },
    {
      "id": "tha-ap408:10.2",
      "pali": "tappamāne ca ātape;"
    },
    {
      "id": "tha-ap408:10.3",
      "pali": "Na maṁ tāpeti ātāpo,"
    },
    {
      "id": "tha-ap408:10.4",
      "pali": "maṇḍapassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:11.1",
      "pali": "Duggatiṁ samatikkanto,"
    },
    {
      "id": "tha-ap408:11.2",
      "pali": "apāyā pihitā mama;"
    },
    {
      "id": "tha-ap408:11.3",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "tha-ap408:11.4",
      "pali": "santāpo me na vijjati."
    },
    {
      "id": "tha-ap408:12.1",
      "pali": "Mahīsaññaṁ adhiṭṭhāya,"
    },
    {
      "id": "tha-ap408:12.2",
      "pali": "loṇatoyaṁ tarāmahaṁ;"
    },
    {
      "id": "tha-ap408:12.3",
      "pali": "Tassa me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap408:12.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:13.1",
      "pali": "Apathampi pathaṁ katvā,"
    },
    {
      "id": "tha-ap408:13.2",
      "pali": "gacchāmi anilañjase;"
    },
    {
      "id": "tha-ap408:13.3",
      "pali": "Aho me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap408:13.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:14.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "tha-ap408:14.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "tha-ap408:14.3",
      "pali": "Āsavā me parikkhīṇā,"
    },
    {
      "id": "tha-ap408:14.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:15.1",
      "pali": "Jahitā purimā jāti,"
    },
    {
      "id": "tha-ap408:15.2",
      "pali": "buddhassa oraso ahaṁ;"
    },
    {
      "id": "tha-ap408:15.3",
      "pali": "Dāyādomhi ca saddhamme,"
    },
    {
      "id": "tha-ap408:15.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:16.1",
      "pali": "Ārādhitomhi sugataṁ,"
    },
    {
      "id": "tha-ap408:16.2",
      "pali": "Gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap408:16.3",
      "pali": "Dhammadhajo dhammadāyādo,"
    },
    {
      "id": "tha-ap408:16.4",
      "pali": "Buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap408:17.1",
      "pali": "Upaṭṭhitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap408:17.2",
      "pali": "gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap408:17.3",
      "pali": "Pāraṅgamaniyaṁ maggaṁ,"
    },
    {
      "id": "tha-ap408:17.4",
      "pali": "apucchiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap408:18.1",
      "pali": "Ajjhiṭṭho kathayī buddho,"
    },
    {
      "id": "tha-ap408:18.2",
      "pali": "gambhīraṁ nipuṇaṁ padaṁ;"
    },
    {
      "id": "tha-ap408:18.3",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "tha-ap408:18.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap408:19.1",
      "pali": "Aho me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap408:19.2",
      "pali": "parimuttomhi jātiyā;"
    },
    {
      "id": "tha-ap408:19.3",
      "pali": "Sabbāsavaparikkhīṇo,"
    },
    {
      "id": "tha-ap408:19.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap408:20.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap408:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap408:20.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap408:21.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap408:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap408:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap408:22.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap408:22.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap408:22.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap408:23.1",
      "pali": "Itthaṁ sudaṁ āyasmā nandako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap408:24.1",
      "pali": "Nandakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
