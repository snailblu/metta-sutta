{
  "uid": "tha-ap72",
  "title": "Pupphacaṅkoṭiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap72:1.1",
      "pali": "“Abhītarūpaṁ sīhaṁva,"
    },
    {
      "id": "tha-ap72:1.2",
      "pali": "garuḷaggaṁva pakkhinaṁ;"
    },
    {
      "id": "tha-ap72:1.3",
      "pali": "Byagghūsabhaṁva pavaraṁ,"
    },
    {
      "id": "tha-ap72:1.4",
      "pali": "abhijātaṁva kesariṁ."
    },
    {
      "id": "tha-ap72:2.1",
      "pali": "Sikhiṁ tilokasaraṇaṁ,"
    },
    {
      "id": "tha-ap72:2.2",
      "pali": "anejaṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap72:2.3",
      "pali": "Nisinnaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap72:2.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap72:3.1",
      "pali": "Caṅkoṭake ṭhapetvāna,"
    },
    {
      "id": "tha-ap72:3.2",
      "pali": "anojaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap72:3.3",
      "pali": "Saha caṅkoṭakeneva,"
    },
    {
      "id": "tha-ap72:3.4",
      "pali": "buddhaseṭṭhaṁ samokiriṁ."
    },
    {
      "id": "tha-ap72:4.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap72:4.2",
      "pali": "dvipadinda narāsabha;"
    },
    {
      "id": "tha-ap72:4.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap72:4.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap72:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap72:5.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap72:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap72:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap72:6.1",
      "pali": "Sampuṇṇe tiṁsakappamhi,"
    },
    {
      "id": "tha-ap72:6.2",
      "pali": "devabhūtisanāmakā;"
    },
    {
      "id": "tha-ap72:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap72:6.4",
      "pali": "pañcāsuṁ cakkavattino."
    },
    {
      "id": "tha-ap72:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap72:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap72:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap72:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphacaṅkoṭiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap72:9.1",
      "pali": "Pupphacaṅkoṭiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap72:10.1",
      "pali": "Sakacintaniyavaggo sattamo."
    },
    {
      "id": "tha-ap72:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap72:12.1",
      "pali": "Sakacintī avopupphī,"
    },
    {
      "id": "tha-ap72:12.2",
      "pali": "sapaccāgamanena ca;"
    },
    {
      "id": "tha-ap72:12.3",
      "pali": "Parappasādī bhisado,"
    },
    {
      "id": "tha-ap72:12.4",
      "pali": "sucinti vatthadāyako."
    },
    {
      "id": "tha-ap72:13.1",
      "pali": "Ambadāyī ca sumano,"
    },
    {
      "id": "tha-ap72:13.2",
      "pali": "pupphacaṅkoṭakīpi ca;"
    },
    {
      "id": "tha-ap72:13.3",
      "pali": "Gāthekasattati vuttā,"
    },
    {
      "id": "tha-ap72:13.4",
      "pali": "gaṇitā atthadassibhi."
    }
  ]
}
