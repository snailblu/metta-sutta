{
  "uid": "tha-ap330",
  "title": "8 Sumanāveḷiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap330:1.1",
      "pali": "“Vessabhussa bhagavato,"
    },
    {
      "id": "tha-ap330:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap330:1.3",
      "pali": "Sabbe janā samāgamma,"
    },
    {
      "id": "tha-ap330:1.4",
      "pali": "mahāpūjaṁ karonti te."
    },
    {
      "id": "tha-ap330:2.1",
      "pali": "Sudhāya piṇḍaṁ katvāna,"
    },
    {
      "id": "tha-ap330:2.2",
      "pali": "āveḷaṁ sumanāyahaṁ;"
    },
    {
      "id": "tha-ap330:2.3",
      "pali": "Sīhāsanassa purato,"
    },
    {
      "id": "tha-ap330:2.4",
      "pali": "abhiropesahaṁ tadā."
    },
    {
      "id": "tha-ap330:3.1",
      "pali": "Sabbe janā samāgamma,"
    },
    {
      "id": "tha-ap330:3.2",
      "pali": "pekkhanti pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap330:3.3",
      "pali": "Kenidaṁ pūjitaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap330:3.4",
      "pali": "buddhaseṭṭhassa tādino."
    },
    {
      "id": "tha-ap330:4.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap330:4.2",
      "pali": "nimmānaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap330:4.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap330:4.4",
      "pali": "pubbe sukatamattano."
    },
    {
      "id": "tha-ap330:5.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap330:5.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap330:5.3",
      "pali": "Sabbesānaṁ piyo homi,"
    },
    {
      "id": "tha-ap330:5.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap330:6.1",
      "pali": "Nābhijānāmi kāyena,"
    },
    {
      "id": "tha-ap330:6.2",
      "pali": "vācāya uda cetasā;"
    },
    {
      "id": "tha-ap330:6.3",
      "pali": "Saṁyatānaṁ tapassīnaṁ,"
    },
    {
      "id": "tha-ap330:6.4",
      "pali": "kataṁ akkositaṁ mayā."
    },
    {
      "id": "tha-ap330:7.1",
      "pali": "Tena sucaritenāhaṁ,"
    },
    {
      "id": "tha-ap330:7.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap330:7.3",
      "pali": "Sabbesaṁ pūjito homi,"
    },
    {
      "id": "tha-ap330:7.4",
      "pali": "anakkosassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap330:8.1",
      "pali": "Ito ekādase kappe,"
    },
    {
      "id": "tha-ap330:8.2",
      "pali": "sahassārosi khattiyo;"
    },
    {
      "id": "tha-ap330:8.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap330:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap330:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap330:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap330:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap330:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumanāveḷiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap330:11.1",
      "pali": "Sumanāveḷiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
