{
  "uid": "ja492",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja492:1.1",
      "pali": "“Yadesamānā vicarimha,"
    },
    {
      "id": "ja492:1.2",
      "pali": "pabbatāni vanāni ca;"
    },
    {
      "id": "ja492:1.3",
      "pali": "Anvesaṁ vicariṁ ñātī,"
    },
    {
      "id": "ja492:1.4",
      "pali": "teme adhigatā mayā."
    },
    {
      "id": "ja492:2.1",
      "pali": "Bahuñcidaṁ mūlaphalaṁ,"
    },
    {
      "id": "ja492:2.2",
      "pali": "bhakkho cāyaṁ anappako;"
    },
    {
      "id": "ja492:2.3",
      "pali": "Rammā cimā girīnajjo,"
    },
    {
      "id": "ja492:2.4",
      "pali": "phāsuvāso bhavissati."
    },
    {
      "id": "ja492:3.1",
      "pali": "Idhevāhaṁ vasissāmi,"
    },
    {
      "id": "ja492:3.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja492:3.3",
      "pali": "Appossukko nirāsaṅkī,"
    },
    {
      "id": "ja492:3.4",
      "pali": "asoko akutobhayo”."
    },
    {
      "id": "ja492:4.1",
      "pali": "“Aññampi leṇaṁ pariyesa,"
    },
    {
      "id": "ja492:4.2",
      "pali": "sattu no idha vijjati;"
    },
    {
      "id": "ja492:4.3",
      "pali": "So taccha sūkare hanti,"
    },
    {
      "id": "ja492:4.4",
      "pali": "idhāgantvā varaṁ varaṁ”."
    },
    {
      "id": "ja492:5.1",
      "pali": "“Ko numhākaṁ idha sattu,"
    },
    {
      "id": "ja492:5.2",
      "pali": "ko ñātī susamāgate;"
    },
    {
      "id": "ja492:5.3",
      "pali": "Duppadhaṁse padhaṁseti,"
    },
    {
      "id": "ja492:5.4",
      "pali": "taṁ me akkhātha pucchitā”."
    },
    {
      "id": "ja492:6.1",
      "pali": "“Uddhaggarājī migarājā,"
    },
    {
      "id": "ja492:6.2",
      "pali": "balī dāṭhāvudho migo;"
    },
    {
      "id": "ja492:6.3",
      "pali": "So taccha sūkare hanti,"
    },
    {
      "id": "ja492:6.4",
      "pali": "idhāgantvā varaṁ varaṁ”."
    },
    {
      "id": "ja492:7.1",
      "pali": "“Na no dāṭhā na vijjanti,"
    },
    {
      "id": "ja492:7.2",
      "pali": "balaṁ kāye samohitaṁ;"
    },
    {
      "id": "ja492:7.3",
      "pali": "Sabbe samaggā hutvāna,"
    },
    {
      "id": "ja492:7.4",
      "pali": "vasaṁ kāhāma ekakaṁ”."
    },
    {
      "id": "ja492:8.1",
      "pali": "“Hadayaṅgamaṁ kaṇṇasukhaṁ,"
    },
    {
      "id": "ja492:8.2",
      "pali": "Vācaṁ bhāsasi tacchaka;"
    },
    {
      "id": "ja492:8.3",
      "pali": "Yopi yuddhe palāyeyya,"
    },
    {
      "id": "ja492:8.4",
      "pali": "Tampi pacchā hanāmase”."
    },
    {
      "id": "ja492:9.1",
      "pali": "“Pāṇātipātā virato nu ajja,"
    },
    {
      "id": "ja492:9.2",
      "pali": "Abhayaṁ nu te sabbabhūtesu dinnaṁ;"
    },
    {
      "id": "ja492:9.3",
      "pali": "Dāṭhā nu te migavadhāya na santi,"
    },
    {
      "id": "ja492:9.4",
      "pali": "Yo saṅghapatto kapaṇova jhāyasi”."
    },
    {
      "id": "ja492:10.1",
      "pali": "“Na me dāṭhā na vijjanti,"
    },
    {
      "id": "ja492:10.2",
      "pali": "Balaṁ kāye samohitaṁ;"
    },
    {
      "id": "ja492:10.3",
      "pali": "Ñātī ca disvāna sāmaggī ekato,"
    },
    {
      "id": "ja492:10.4",
      "pali": "Tasmā ca jhāyāmi vanamhi ekako."
    },
    {
      "id": "ja492:11.1",
      "pali": "Imassudaṁ yanti disodisaṁ pure,"
    },
    {
      "id": "ja492:11.2",
      "pali": "Bhayaṭṭitā leṇagavesino puthu;"
    },
    {
      "id": "ja492:11.3",
      "pali": "Te dāni saṅgamma vasanti ekato,"
    },
    {
      "id": "ja492:11.4",
      "pali": "Yatthaṭṭhitā duppasahajja te mayā."
    },
    {
      "id": "ja492:12.1",
      "pali": "Pariṇāyakasampannā,"
    },
    {
      "id": "ja492:12.2",
      "pali": "sahitā ekavādino;"
    },
    {
      "id": "ja492:12.3",
      "pali": "Te maṁ samaggā hiṁseyyuṁ,"
    },
    {
      "id": "ja492:12.4",
      "pali": "tasmā nesaṁ na patthaye”."
    },
    {
      "id": "ja492:13.1",
      "pali": "“Ekova indo asure jināti,"
    },
    {
      "id": "ja492:13.2",
      "pali": "Ekova seno hanti dije pasayha;"
    },
    {
      "id": "ja492:13.3",
      "pali": "Ekova byaggho migasaṅghapatto,"
    },
    {
      "id": "ja492:13.4",
      "pali": "Varaṁ varaṁ hanti balañhi tādisaṁ”."
    },
    {
      "id": "ja492:14.1",
      "pali": "“Na heva indo na seno,"
    },
    {
      "id": "ja492:14.2",
      "pali": "napi byaggho migādhipo;"
    },
    {
      "id": "ja492:14.3",
      "pali": "Samagge sahite ñātī,"
    },
    {
      "id": "ja492:14.4",
      "pali": "na byagghe kurute vase”."
    },
    {
      "id": "ja492:15.1",
      "pali": "“Kumbhīlakā sakuṇakā,"
    },
    {
      "id": "ja492:15.2",
      "pali": "saṅghino gaṇacārino;"
    },
    {
      "id": "ja492:15.3",
      "pali": "Sammodamānā ekajjhaṁ,"
    },
    {
      "id": "ja492:15.4",
      "pali": "uppatanti ḍayanti ca."
    },
    {
      "id": "ja492:16.1",
      "pali": "Tesañca ḍayamānānaṁ,"
    },
    {
      "id": "ja492:16.2",
      "pali": "ekettha apasakkati;"
    },
    {
      "id": "ja492:16.3",
      "pali": "Tañca seno nitāḷeti,"
    },
    {
      "id": "ja492:16.4",
      "pali": "veyyagghiyeva sā gati”."
    },
    {
      "id": "ja492:17.1",
      "pali": "“Ussāhito jaṭilena,"
    },
    {
      "id": "ja492:17.2",
      "pali": "luddenāmisacakkhunā;"
    },
    {
      "id": "ja492:17.3",
      "pali": "Dāṭhī dāṭhīsu pakkhandi,"
    },
    {
      "id": "ja492:17.4",
      "pali": "maññamāno yathā pure”."
    },
    {
      "id": "ja492:18.1",
      "pali": "“Sādhu sambahulā ñātī,"
    },
    {
      "id": "ja492:18.2",
      "pali": "api rukkhā araññajā;"
    },
    {
      "id": "ja492:18.3",
      "pali": "Sūkarehi samaggehi,"
    },
    {
      "id": "ja492:18.4",
      "pali": "byaggho ekāyane hato”."
    },
    {
      "id": "ja492:19.1",
      "pali": "Brāhmaṇañceva byagghañca,"
    },
    {
      "id": "ja492:19.2",
      "pali": "ubho hantvāna sūkarā."
    },
    {
      "id": "ja492:19.3",
      "pali": "Ānandino pamuditā,"
    },
    {
      "id": "ja492:19.4",
      "pali": "mahānādaṁ panādisuṁ."
    },
    {
      "id": "ja492:20.1",
      "pali": "Te su udumbaramūlasmiṁ,"
    },
    {
      "id": "ja492:20.2",
      "pali": "sūkarā susamāgatā;"
    },
    {
      "id": "ja492:20.3",
      "pali": "Tacchakaṁ abhisiñciṁsu,"
    },
    {
      "id": "ja492:20.4",
      "pali": "“tvaṁ no rājāsi issaro”ti."
    },
    {
      "id": "ja492:21.1",
      "pali": "Tacchasūkarajātakaṁ navamaṁ."
    }
  ]
}
