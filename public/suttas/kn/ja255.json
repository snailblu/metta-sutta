{
  "uid": "ja255",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja255:1.1",
      "pali": "“Yāva so mattamaññāsi,"
    },
    {
      "id": "ja255:1.2",
      "pali": "bhojanasmiṁ vihaṅgamo;"
    },
    {
      "id": "ja255:1.3",
      "pali": "Tāva addhānamāpādi,"
    },
    {
      "id": "ja255:1.4",
      "pali": "mātarañca aposayi."
    },
    {
      "id": "ja255:2.1",
      "pali": "Yato ca kho bahutaraṁ,"
    },
    {
      "id": "ja255:2.2",
      "pali": "bhojanaṁ ajjhavāhari;"
    },
    {
      "id": "ja255:2.3",
      "pali": "Tato tattheva saṁsīdi,"
    },
    {
      "id": "ja255:2.4",
      "pali": "amattaññū hi so ahu."
    },
    {
      "id": "ja255:3.1",
      "pali": "Tasmā mattaññutā sādhu,"
    },
    {
      "id": "ja255:3.2",
      "pali": "bhojanasmiṁ agiddhatā;"
    },
    {
      "id": "ja255:3.3",
      "pali": "Amattaññū hi sīdanti,"
    },
    {
      "id": "ja255:3.4",
      "pali": "mattaññū ca na sīdare”ti."
    },
    {
      "id": "ja255:4.1",
      "pali": "Sukajātakaṁ pañcamaṁ."
    }
  ]
}
