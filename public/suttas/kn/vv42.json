{
  "uid": "vv42",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv42:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv42:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv42:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv42:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv42:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv42:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv42:2.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv42:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv42:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv42:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv42:4.1",
      "pali": "“Ahañca bārāṇasiyaṁ,"
    },
    {
      "id": "vv42:4.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "vv42:4.3",
      "pali": "Adāsiṁ sukkhakummāsaṁ,"
    },
    {
      "id": "vv42:4.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv42:5.1",
      "pali": "Sukkhāya aloṇikāya ca,"
    },
    {
      "id": "vv42:5.2",
      "pali": "Passa phalaṁ kummāsapiṇḍiyā;"
    },
    {
      "id": "vv42:5.3",
      "pali": "Alomaṁ sukhitaṁ disvā,"
    },
    {
      "id": "vv42:5.4",
      "pali": "Ko puññaṁ na karissati."
    },
    {
      "id": "vv42:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv42:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv42:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv42:7.1",
      "pali": "Alomavimānaṁ catutthaṁ."
    }
  ]
}
