{
  "uid": "pv8",
  "title": "8. Goṇapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv8:1.1",
      "pali": "“Kiṁ nu ummattarūpova,"
    },
    {
      "id": "pv8:1.2",
      "pali": "lāyitvā haritaṁ tiṇaṁ;"
    },
    {
      "id": "pv8:1.3",
      "pali": "Khāda khādāti lapasi,"
    },
    {
      "id": "pv8:1.4",
      "pali": "gatasattaṁ jaraggavaṁ."
    },
    {
      "id": "pv8:2.1",
      "pali": "Na hi annena pānena,"
    },
    {
      "id": "pv8:2.2",
      "pali": "mato goṇo samuṭṭhahe;"
    },
    {
      "id": "pv8:2.3",
      "pali": "Tvaṁsi bālo ca dummedho,"
    },
    {
      "id": "pv8:2.4",
      "pali": "yathā taññova dummatī”ti."
    },
    {
      "id": "pv8:3.1",
      "pali": "“Ime pādā idaṁ sīsaṁ,"
    },
    {
      "id": "pv8:3.2",
      "pali": "ayaṁ kāyo savāladhi;"
    },
    {
      "id": "pv8:3.3",
      "pali": "Nettā tatheva tiṭṭhanti,"
    },
    {
      "id": "pv8:3.4",
      "pali": "ayaṁ goṇo samuṭṭhahe."
    },
    {
      "id": "pv8:4.1",
      "pali": "Nāyyakassa hatthapādā,"
    },
    {
      "id": "pv8:4.2",
      "pali": "kāyo sīsañca dissati;"
    },
    {
      "id": "pv8:4.3",
      "pali": "Rudaṁ mattikathūpasmiṁ,"
    },
    {
      "id": "pv8:4.4",
      "pali": "nanu tvaññeva dummatī”ti."
    },
    {
      "id": "pv8:5.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "pv8:5.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "pv8:5.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "pv8:5.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "pv8:6.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "pv8:6.2",
      "pali": "sokaṁ hadayanissitaṁ;"
    },
    {
      "id": "pv8:6.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "pv8:6.4",
      "pali": "pitusokaṁ apānudi."
    },
    {
      "id": "pv8:7.1",
      "pali": "Svāhaṁ abbūḷhasallosmi,"
    },
    {
      "id": "pv8:7.2",
      "pali": "sītibhūtosmi nibbuto;"
    },
    {
      "id": "pv8:7.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "pv8:7.4",
      "pali": "tava sutvāna māṇava”."
    },
    {
      "id": "pv8:8.1",
      "pali": "Evaṁ karonti sappaññā,"
    },
    {
      "id": "pv8:8.2",
      "pali": "ye honti anukampakā;"
    },
    {
      "id": "pv8:8.3",
      "pali": "Vinivattayanti sokamhā,"
    },
    {
      "id": "pv8:8.4",
      "pali": "sujāto pitaraṁ yathāti."
    },
    {
      "id": "pv8:9.1",
      "pali": "Goṇapetavatthu aṭṭhamaṁ."
    }
  ]
}
