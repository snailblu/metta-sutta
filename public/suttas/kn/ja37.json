{
  "uid": "ja37",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja37:1.1",
      "pali": "“Ye vuḍḍhamapacāyanti,"
    },
    {
      "id": "ja37:1.2",
      "pali": "narā dhammassa kovidā;"
    },
    {
      "id": "ja37:1.3",
      "pali": "Diṭṭheva dhamme pāsaṁsā,"
    },
    {
      "id": "ja37:1.4",
      "pali": "samparāye ca suggatī”ti."
    },
    {
      "id": "ja37:2.1",
      "pali": "Tittirajātakaṁ sattamaṁ."
    }
  ]
}
