{
  "uid": "iti17",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti17:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti17:2.1",
      "pali": "“Sekhassa, bhikkhave, bhikkhuno appattamānasassa anuttaraṁ yogakkhemaṁ patthayamānassa viharato bāhiraṁ aṅganti karitvā nāññaṁ ekaṅgampi samanupassāmi yaṁ evaṁ bahūpakāraṁ yathayidaṁ, bhikkhave, kalyāṇamittatā."
    },
    {
      "id": "iti17:2.2",
      "pali": "Kalyāṇamitto, bhikkhave, bhikkhu akusalaṁ pajahati, kusalaṁ bhāvetī”ti."
    },
    {
      "id": "iti17:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti17:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti17:3.1",
      "pali": "“Kalyāṇamitto yo bhikkhu,"
    },
    {
      "id": "iti17:3.2",
      "pali": "sappatisso sagāravo;"
    },
    {
      "id": "iti17:3.3",
      "pali": "Karaṁ mittānaṁ vacanaṁ,"
    },
    {
      "id": "iti17:3.4",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "iti17:3.5",
      "pali": "Pāpuṇe anupubbena,"
    },
    {
      "id": "iti17:3.6",
      "pali": "sabbasaṁyojanakkhayan”ti."
    },
    {
      "id": "iti17:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti17:4.2",
      "pali": "Sattamaṁ."
    }
  ]
}
