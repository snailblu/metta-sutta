{
  "uid": "tha-ap150",
  "title": "Phalakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap150:1.1",
      "pali": "“Yānakāro pure āsiṁ,"
    },
    {
      "id": "tha-ap150:1.2",
      "pali": "dārukamme susikkhito;"
    },
    {
      "id": "tha-ap150:1.3",
      "pali": "Candanaṁ phalakaṁ katvā,"
    },
    {
      "id": "tha-ap150:1.4",
      "pali": "adāsiṁ lokabandhuno."
    },
    {
      "id": "tha-ap150:2.1",
      "pali": "Pabhāsati idaṁ byamhaṁ,"
    },
    {
      "id": "tha-ap150:2.2",
      "pali": "suvaṇṇassa sunimmitaṁ;"
    },
    {
      "id": "tha-ap150:2.3",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap150:2.4",
      "pali": "dibbayānaṁ upaṭṭhitaṁ."
    },
    {
      "id": "tha-ap150:3.1",
      "pali": "Pāsādā sivikā ceva,"
    },
    {
      "id": "tha-ap150:3.2",
      "pali": "Nibbattanti yadicchakaṁ;"
    },
    {
      "id": "tha-ap150:3.3",
      "pali": "Akkhobhaṁ ratanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap150:3.4",
      "pali": "Phalakassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap150:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap150:4.2",
      "pali": "phalakaṁ yamahaṁ dadiṁ;"
    },
    {
      "id": "tha-ap150:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap150:4.4",
      "pali": "phalakassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap150:5.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap150:5.2",
      "pali": "caturo nimmitāvhayā;"
    },
    {
      "id": "tha-ap150:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap150:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap150:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap150:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap150:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap150:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā phalakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap150:8.1",
      "pali": "Phalakadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
