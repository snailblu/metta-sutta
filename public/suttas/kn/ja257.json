{
  "uid": "ja257",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja257:1.1",
      "pali": "“Nāyaṁ gharānaṁ kusalo,"
    },
    {
      "id": "ja257:1.2",
      "pali": "lolo ayaṁ valīmukho;"
    },
    {
      "id": "ja257:1.3",
      "pali": "Kataṁ kataṁ kho dūseyya,"
    },
    {
      "id": "ja257:1.4",
      "pali": "evaṁdhammamidaṁ kulaṁ."
    },
    {
      "id": "ja257:2.1",
      "pali": "Nayidaṁ cittavato lomaṁ,"
    },
    {
      "id": "ja257:2.2",
      "pali": "nāyaṁ assāsiko migo;"
    },
    {
      "id": "ja257:2.3",
      "pali": "Siṭṭhaṁ me janasandhena,"
    },
    {
      "id": "ja257:2.4",
      "pali": "nāyaṁ kiñci vijānati."
    },
    {
      "id": "ja257:3.1",
      "pali": "Na mātaraṁ pitaraṁ vā,"
    },
    {
      "id": "ja257:3.2",
      "pali": "bhātaraṁ bhaginiṁ sakaṁ;"
    },
    {
      "id": "ja257:3.3",
      "pali": "Bhareyya tādiso poso,"
    },
    {
      "id": "ja257:3.4",
      "pali": "siṭṭhaṁ dasarathena me”ti."
    },
    {
      "id": "ja257:4.1",
      "pali": "Gāmaṇicanda jātakaṁ sattamaṁ."
    }
  ]
}
