{
  "uid": "tha-ap406",
  "title": "Dhotakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap406:1.1",
      "pali": "“Gaṅgā bhāgīrathī nāma,"
    },
    {
      "id": "tha-ap406:1.2",
      "pali": "himavantā pabhāvitā;"
    },
    {
      "id": "tha-ap406:1.3",
      "pali": "Haṁsavatiyā dvārena,"
    },
    {
      "id": "tha-ap406:1.4",
      "pali": "anusandati tāvade."
    },
    {
      "id": "tha-ap406:2.1",
      "pali": "Sobhito nāma ārāmo,"
    },
    {
      "id": "tha-ap406:2.2",
      "pali": "gaṅgākūle sumāpito;"
    },
    {
      "id": "tha-ap406:2.3",
      "pali": "Tattha padumuttaro buddho,"
    },
    {
      "id": "tha-ap406:2.4",
      "pali": "vasate lokanāyako."
    },
    {
      "id": "tha-ap406:3.1",
      "pali": "Tidasehi yathā indo,"
    },
    {
      "id": "tha-ap406:3.2",
      "pali": "manujehi purakkhato;"
    },
    {
      "id": "tha-ap406:3.3",
      "pali": "Nisīdi tattha bhagavā,"
    },
    {
      "id": "tha-ap406:3.4",
      "pali": "asambhītova kesarī."
    },
    {
      "id": "tha-ap406:4.1",
      "pali": "Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap406:4.2",
      "pali": "vasāmi brāhmaṇo ahaṁ;"
    },
    {
      "id": "tha-ap406:4.3",
      "pali": "Chaḷaṅgo nāma nāmena,"
    },
    {
      "id": "tha-ap406:4.4",
      "pali": "evaṁnāmo mahāmuni."
    },
    {
      "id": "tha-ap406:5.1",
      "pali": "Aṭṭhārasa sissasatā,"
    },
    {
      "id": "tha-ap406:5.2",
      "pali": "parivārenti maṁ tadā;"
    },
    {
      "id": "tha-ap406:5.3",
      "pali": "Tehi sissehi samito,"
    },
    {
      "id": "tha-ap406:5.4",
      "pali": "gaṅgātīraṁ upāgamiṁ."
    },
    {
      "id": "tha-ap406:6.1",
      "pali": "Tatthaddasāsiṁ samaṇe,"
    },
    {
      "id": "tha-ap406:6.2",
      "pali": "nikkuhe dhotapāpake;"
    },
    {
      "id": "tha-ap406:6.3",
      "pali": "Bhāgīrathiṁ tarantehaṁ,"
    },
    {
      "id": "tha-ap406:6.4",
      "pali": "evaṁ cintesi tāvade."
    },
    {
      "id": "tha-ap406:7.1",
      "pali": "‘Sāyaṁ pātaṁ tarantāme,"
    },
    {
      "id": "tha-ap406:7.2",
      "pali": "buddhaputtā mahāyasā;"
    },
    {
      "id": "tha-ap406:7.3",
      "pali": "Vihesayanti attānaṁ,"
    },
    {
      "id": "tha-ap406:7.4",
      "pali": "tesaṁ attā vihaññati."
    },
    {
      "id": "tha-ap406:8.1",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "tha-ap406:8.2",
      "pali": "buddho aggo pavuccati;"
    },
    {
      "id": "tha-ap406:8.3",
      "pali": "Natthi me dakkhiṇe kāraṁ,"
    },
    {
      "id": "tha-ap406:8.4",
      "pali": "gatimaggavisodhanaṁ."
    },
    {
      "id": "tha-ap406:9.1",
      "pali": "Yannūna buddhaseṭṭhassa,"
    },
    {
      "id": "tha-ap406:9.2",
      "pali": "setuṁ gaṅgāya kāraye;"
    },
    {
      "id": "tha-ap406:9.3",
      "pali": "Kārāpetvā imaṁ kammaṁ,"
    },
    {
      "id": "tha-ap406:9.4",
      "pali": "santarāmi imaṁ bhavaṁ’."
    },
    {
      "id": "tha-ap406:10.1",
      "pali": "Satasahassaṁ datvāna,"
    },
    {
      "id": "tha-ap406:10.2",
      "pali": "setuṁ kārāpayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap406:10.3",
      "pali": "Saddahanto kataṁ kāraṁ,"
    },
    {
      "id": "tha-ap406:10.4",
      "pali": "vipulaṁ me bhavissati."
    },
    {
      "id": "tha-ap406:11.1",
      "pali": "Kārāpetvāna taṁ setuṁ,"
    },
    {
      "id": "tha-ap406:11.2",
      "pali": "upesiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap406:11.3",
      "pali": "Sirasi añjaliṁ katvā,"
    },
    {
      "id": "tha-ap406:11.4",
      "pali": "imaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap406:12.1",
      "pali": "‘Satasahassassa vayaṁ,"
    },
    {
      "id": "tha-ap406:12.2",
      "pali": "datvā kārāpito mayā;"
    },
    {
      "id": "tha-ap406:12.3",
      "pali": "Tavatthāya mahāsetu,"
    },
    {
      "id": "tha-ap406:12.4",
      "pali": "paṭiggaṇha mahāmune’."
    },
    {
      "id": "tha-ap406:13.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap406:13.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap406:13.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap406:13.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap406:14.1",
      "pali": "‘Yo me setuṁ akāresi,"
    },
    {
      "id": "tha-ap406:14.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap406:14.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap406:14.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap406:15.1",
      "pali": "Darito pabbatato vā,"
    },
    {
      "id": "tha-ap406:15.2",
      "pali": "rukkhato patitopiyaṁ;"
    },
    {
      "id": "tha-ap406:15.3",
      "pali": "Cutopi lacchatī ṭhānaṁ,"
    },
    {
      "id": "tha-ap406:15.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap406:16.1",
      "pali": "Virūḷhamūlasantānaṁ,"
    },
    {
      "id": "tha-ap406:16.2",
      "pali": "nigrodhamiva māluto;"
    },
    {
      "id": "tha-ap406:16.3",
      "pali": "Amittā nappasahanti,"
    },
    {
      "id": "tha-ap406:16.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap406:17.1",
      "pali": "Nāssa corā pasahanti,"
    },
    {
      "id": "tha-ap406:17.2",
      "pali": "nātimaññanti khattiyā;"
    },
    {
      "id": "tha-ap406:17.3",
      "pali": "Sabbe tarissatāmitte,"
    },
    {
      "id": "tha-ap406:17.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap406:18.1",
      "pali": "Abbhokāsagataṁ santaṁ,"
    },
    {
      "id": "tha-ap406:18.2",
      "pali": "kaṭhinātapatāpitaṁ;"
    },
    {
      "id": "tha-ap406:18.3",
      "pali": "Puññakammena saṁyuttaṁ,"
    },
    {
      "id": "tha-ap406:18.4",
      "pali": "na bhavissati vedanā."
    },
    {
      "id": "tha-ap406:19.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap406:19.2",
      "pali": "hatthiyānaṁ sunimmitaṁ;"
    },
    {
      "id": "tha-ap406:19.3",
      "pali": "Tassa saṅkappamaññāya,"
    },
    {
      "id": "tha-ap406:19.4",
      "pali": "nibbattissati tāvade."
    },
    {
      "id": "tha-ap406:20.1",
      "pali": "Sahassassā vātajavā,"
    },
    {
      "id": "tha-ap406:20.2",
      "pali": "sindhavā sīghavāhanā;"
    },
    {
      "id": "tha-ap406:20.3",
      "pali": "Sāyaṁ pātaṁ upessanti,"
    },
    {
      "id": "tha-ap406:20.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap406:21.1",
      "pali": "Āgantvāna manussattaṁ,"
    },
    {
      "id": "tha-ap406:21.2",
      "pali": "sukhitoyaṁ bhavissati;"
    },
    {
      "id": "tha-ap406:21.3",
      "pali": "Vehāsaṁ manujasseva,"
    },
    {
      "id": "tha-ap406:21.4",
      "pali": "hatthiyānaṁ bhavissati."
    },
    {
      "id": "tha-ap406:22.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap406:22.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap406:22.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap406:22.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap406:23.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap406:23.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap406:23.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap406:23.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap406:24.1",
      "pali": "Aho me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap406:24.2",
      "pali": "jalajuttamanāmake;"
    },
    {
      "id": "tha-ap406:24.3",
      "pali": "Tattha kāraṁ karitvāna,"
    },
    {
      "id": "tha-ap406:24.4",
      "pali": "pattohaṁ āsavakkhayaṁ."
    },
    {
      "id": "tha-ap406:25.1",
      "pali": "Padhānaṁ pahitattomhi,"
    },
    {
      "id": "tha-ap406:25.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap406:25.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap406:25.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap406:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap406:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap406:26.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap406:27.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap406:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap406:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap406:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap406:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap406:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap406:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhotako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap406:30.1",
      "pali": "Dhotakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
