{
  "uid": "cp27",
  "title": "Saccapāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp27:1.1",
      "pali": "“Yadā ahaṁ kapi āsiṁ,"
    },
    {
      "id": "cp27:1.2",
      "pali": "nadīkūle darīsaye;"
    },
    {
      "id": "cp27:1.3",
      "pali": "Pīḷito susumārena,"
    },
    {
      "id": "cp27:1.4",
      "pali": "gamanaṁ na labhāmahaṁ."
    },
    {
      "id": "cp27:2.1",
      "pali": "Yamhokāse ahaṁ ṭhatvā,"
    },
    {
      "id": "cp27:2.2",
      "pali": "orā pāraṁ patāmahaṁ;"
    },
    {
      "id": "cp27:2.3",
      "pali": "Tatthacchi sattu vadhako,"
    },
    {
      "id": "cp27:2.4",
      "pali": "kumbhīlo luddadassano."
    },
    {
      "id": "cp27:3.1",
      "pali": "So maṁ asaṁsi ‘ehī’ti,"
    },
    {
      "id": "cp27:3.2",
      "pali": "‘ahampemī’ti taṁ vatiṁ;"
    },
    {
      "id": "cp27:3.3",
      "pali": "Tassa matthakamakkamma,"
    },
    {
      "id": "cp27:3.4",
      "pali": "parakūle patiṭṭhahiṁ."
    },
    {
      "id": "cp27:4.1",
      "pali": "Na tassa alikaṁ bhaṇitaṁ,"
    },
    {
      "id": "cp27:4.2",
      "pali": "yathā vācaṁ akāsahaṁ;"
    },
    {
      "id": "cp27:4.3",
      "pali": "Saccena me samo natthi,"
    },
    {
      "id": "cp27:4.4",
      "pali": "esā me saccapāramī”ti."
    },
    {
      "id": "cp27:4.5",
      "pali": "Kapirājacariyaṁ sattamaṁ."
    }
  ]
}
