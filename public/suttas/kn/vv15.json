{
  "uid": "vv15",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv15:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv15:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv15:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv15:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv15:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv15:2.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv15:2.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv15:2.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv15:3.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv15:3.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv15:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv15:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv15:4.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv15:4.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv15:4.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv15:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv15:5.1",
      "pali": "“Issā ca maccheramatho paḷāso,"
    },
    {
      "id": "vv15:5.2",
      "pali": "Nāhosi mayhaṁ gharamāvasantiyā;"
    },
    {
      "id": "vv15:5.3",
      "pali": "Akkodhanā bhattu vasānuvattinī,"
    },
    {
      "id": "vv15:5.4",
      "pali": "Uposathe niccahamappamattā."
    },
    {
      "id": "vv15:6.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv15:6.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv15:6.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv15:6.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "vv15:7.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "vv15:7.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "vv15:7.3",
      "pali": "Saññamā saṁvibhāgā ca,"
    },
    {
      "id": "vv15:7.4",
      "pali": "vimānaṁ āvasāmahaṁ."
    },
    {
      "id": "vv15:8.1",
      "pali": "Pāṇātipātā viratā,"
    },
    {
      "id": "vv15:8.2",
      "pali": "musāvādā ca saññatā;"
    },
    {
      "id": "vv15:8.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv15:8.4",
      "pali": "majjapānā ca ārakā."
    },
    {
      "id": "vv15:9.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv15:9.2",
      "pali": "ariyasaccāna kovidā;"
    },
    {
      "id": "vv15:9.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv15:9.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv15:10.1",
      "pali": "Sāhaṁ sakena sīlena,"
    },
    {
      "id": "vv15:10.2",
      "pali": "yasasā ca yasassinī;"
    },
    {
      "id": "vv15:10.3",
      "pali": "Anubhomi sakaṁ puññaṁ,"
    },
    {
      "id": "vv15:10.4",
      "pali": "sukhitā camhināmayā."
    },
    {
      "id": "vv15:11.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv15:11.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv15:11.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv15:11.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv15:12.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv15:12.2",
      "pali": "Manussabhūtā yamahaṁ akāsiṁ;"
    },
    {
      "id": "vv15:12.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv15:12.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatīti."
    },
    {
      "id": "vv15:13.1",
      "pali": "Mama ca, bhante, vacanena bhagavato pāde sirasā vandeyyāsi—"
    },
    {
      "id": "vv15:13.2",
      "pali": "‘uttarā nāma, bhante, upāsikā bhagavato pāde sirasā vandatī’ti."
    },
    {
      "id": "vv15:13.3",
      "pali": "Anacchariyaṁ kho panetaṁ, bhante, yaṁ maṁ bhagavā aññatarasmiṁ sāmaññaphale byākareyya, taṁ bhagavā sakadāgāmiphale byākāsī”ti."
    },
    {
      "id": "vv15:14.1",
      "pali": "Uttarāvimānaṁ pannarasamaṁ."
    }
  ]
}
