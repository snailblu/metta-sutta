{
  "uid": "tha-ap82",
  "title": "10 Tipadumiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap82:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap82:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap82:1.3",
      "pali": "Danto dantaparivuto,"
    },
    {
      "id": "tha-ap82:1.4",
      "pali": "nagarā nikkhamī tadā."
    },
    {
      "id": "tha-ap82:2.1",
      "pali": "Nagare haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap82:2.2",
      "pali": "ahosiṁ māliko tadā;"
    },
    {
      "id": "tha-ap82:2.3",
      "pali": "Yaṁ tattha uttamaṁ tīṇi,"
    },
    {
      "id": "tha-ap82:2.4",
      "pali": "padmapupphāni aggahiṁ."
    },
    {
      "id": "tha-ap82:3.1",
      "pali": "‘Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap82:3.2",
      "pali": "paṭimaggantarāpaṇe;"
    },
    {
      "id": "tha-ap82:3.3",
      "pali": "Saha disvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap82:3.4",
      "pali": "evaṁ cintesahaṁ tadā."
    },
    {
      "id": "tha-ap82:4.1",
      "pali": "Kiṁ me imehi pupphehi,"
    },
    {
      "id": "tha-ap82:4.2",
      "pali": "rañño upanitehi me;"
    },
    {
      "id": "tha-ap82:4.3",
      "pali": "Gāmaṁ vā gāmakhettaṁ vā,"
    },
    {
      "id": "tha-ap82:4.4",
      "pali": "sahassaṁ vā labheyyahaṁ."
    },
    {
      "id": "tha-ap82:5.1",
      "pali": "Adantadamanaṁ vīraṁ,"
    },
    {
      "id": "tha-ap82:5.2",
      "pali": "sabbasattasukhāvahaṁ;"
    },
    {
      "id": "tha-ap82:5.3",
      "pali": "Lokanāthaṁ pūjayitvā,"
    },
    {
      "id": "tha-ap82:5.4",
      "pali": "lacchāmi amataṁ dhanaṁ’."
    },
    {
      "id": "tha-ap82:6.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "tha-ap82:6.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap82:6.3",
      "pali": "Tīṇi lohitake gayha,"
    },
    {
      "id": "tha-ap82:6.4",
      "pali": "ākāse ukkhipiṁ tadā."
    },
    {
      "id": "tha-ap82:7.1",
      "pali": "Mayā ukkhittamattamhi,"
    },
    {
      "id": "tha-ap82:7.2",
      "pali": "ākāse patthariṁsu te;"
    },
    {
      "id": "tha-ap82:7.3",
      "pali": "Dhāriṁsu matthake tattha,"
    },
    {
      "id": "tha-ap82:7.4",
      "pali": "uddhaṁvaṇṭā adhomukhā."
    },
    {
      "id": "tha-ap82:8.1",
      "pali": "Ye keci manujā disvā,"
    },
    {
      "id": "tha-ap82:8.2",
      "pali": "ukkuṭṭhiṁ sampavattayuṁ;"
    },
    {
      "id": "tha-ap82:8.3",
      "pali": "Devatā antalikkhamhi,"
    },
    {
      "id": "tha-ap82:8.4",
      "pali": "sādhukāraṁ pavattayuṁ."
    },
    {
      "id": "tha-ap82:9.1",
      "pali": "Accheraṁ loke uppannaṁ,"
    },
    {
      "id": "tha-ap82:9.2",
      "pali": "buddhaseṭṭhassa vāhasā;"
    },
    {
      "id": "tha-ap82:9.3",
      "pali": "Sabbe dhammaṁ suṇissāma,"
    },
    {
      "id": "tha-ap82:9.4",
      "pali": "pupphānaṁ vāhasā mayaṁ."
    },
    {
      "id": "tha-ap82:10.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap82:10.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap82:10.3",
      "pali": "Vīthiyañhi ṭhito santo,"
    },
    {
      "id": "tha-ap82:10.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap82:11.1",
      "pali": "‘Yo so buddhaṁ apūjesi,"
    },
    {
      "id": "tha-ap82:11.2",
      "pali": "rattapadmehi māṇavo;"
    },
    {
      "id": "tha-ap82:11.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap82:11.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap82:12.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap82:12.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap82:12.3",
      "pali": "Tiṁsakappāni devindo,"
    },
    {
      "id": "tha-ap82:12.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap82:13.1",
      "pali": "Mahāvitthārikaṁ nāma,"
    },
    {
      "id": "tha-ap82:13.2",
      "pali": "byamhaṁ hessati tāvade;"
    },
    {
      "id": "tha-ap82:13.3",
      "pali": "Tiyojanasatubbiddhaṁ,"
    },
    {
      "id": "tha-ap82:13.4",
      "pali": "diyaḍḍhasatavitthataṁ."
    },
    {
      "id": "tha-ap82:14.1",
      "pali": "Cattārisatasahassāni,"
    },
    {
      "id": "tha-ap82:14.2",
      "pali": "niyyūhā ca sumāpitā;"
    },
    {
      "id": "tha-ap82:14.3",
      "pali": "Kūṭāgāravarūpetā,"
    },
    {
      "id": "tha-ap82:14.4",
      "pali": "mahāsayanamaṇḍitā."
    },
    {
      "id": "tha-ap82:15.1",
      "pali": "Koṭisatasahassiyo,"
    },
    {
      "id": "tha-ap82:15.2",
      "pali": "parivāressanti accharā;"
    },
    {
      "id": "tha-ap82:15.3",
      "pali": "Kusalā naccagītassa,"
    },
    {
      "id": "tha-ap82:15.4",
      "pali": "vāditepi padakkhiṇā."
    },
    {
      "id": "tha-ap82:16.1",
      "pali": "Etādise byamhavare,"
    },
    {
      "id": "tha-ap82:16.2",
      "pali": "nārīgaṇasamākule;"
    },
    {
      "id": "tha-ap82:16.3",
      "pali": "Vassissati pupphavasso,"
    },
    {
      "id": "tha-ap82:16.4",
      "pali": "dibbo lohitako sadā."
    },
    {
      "id": "tha-ap82:17.1",
      "pali": "Bhittikhīle nāgadante,"
    },
    {
      "id": "tha-ap82:17.2",
      "pali": "dvārabāhāya toraṇe;"
    },
    {
      "id": "tha-ap82:17.3",
      "pali": "Cakkamattā lohitakā,"
    },
    {
      "id": "tha-ap82:17.4",
      "pali": "olambissanti tāvade."
    },
    {
      "id": "tha-ap82:18.1",
      "pali": "Pattena pattasañchanne,"
    },
    {
      "id": "tha-ap82:18.2",
      "pali": "antobyamhavare imaṁ;"
    },
    {
      "id": "tha-ap82:18.3",
      "pali": "Attharitvā pārupitvā,"
    },
    {
      "id": "tha-ap82:18.4",
      "pali": "tuvaṭṭissanti tāvade."
    },
    {
      "id": "tha-ap82:19.1",
      "pali": "Bhavanaṁ parivāretvā,"
    },
    {
      "id": "tha-ap82:19.2",
      "pali": "samantā satayojane;"
    },
    {
      "id": "tha-ap82:19.3",
      "pali": "Tepi padmā lohitakā,"
    },
    {
      "id": "tha-ap82:19.4",
      "pali": "dibbagandhaṁ pavāyare."
    },
    {
      "id": "tha-ap82:20.1",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap82:20.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap82:20.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap82:20.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap82:21.1",
      "pali": "Sampattiyo duve bhutvā,"
    },
    {
      "id": "tha-ap82:21.2",
      "pali": "anīti anupaddavo;"
    },
    {
      "id": "tha-ap82:21.3",
      "pali": "Sampatte pariyosāne,"
    },
    {
      "id": "tha-ap82:21.4",
      "pali": "nibbānaṁ pāpuṇissati’."
    },
    {
      "id": "tha-ap82:22.1",
      "pali": "Sudiṭṭho vata me buddho,"
    },
    {
      "id": "tha-ap82:22.2",
      "pali": "vāṇijjaṁ supayojitaṁ;"
    },
    {
      "id": "tha-ap82:22.3",
      "pali": "Padmāni tīṇi pūjetvā,"
    },
    {
      "id": "tha-ap82:22.4",
      "pali": "anubhosiṁ tisampadā."
    },
    {
      "id": "tha-ap82:23.1",
      "pali": "Ajja me dhammappattassa,"
    },
    {
      "id": "tha-ap82:23.2",
      "pali": "vippamuttassa sabbaso;"
    },
    {
      "id": "tha-ap82:23.3",
      "pali": "Supupphitaṁ lohitakaṁ,"
    },
    {
      "id": "tha-ap82:23.4",
      "pali": "dhārayissati matthake."
    },
    {
      "id": "tha-ap82:24.1",
      "pali": "Mama kammaṁ kathentassa,"
    },
    {
      "id": "tha-ap82:24.2",
      "pali": "padumuttarasatthuno;"
    },
    {
      "id": "tha-ap82:24.3",
      "pali": "Satapāṇasahassānaṁ,"
    },
    {
      "id": "tha-ap82:24.4",
      "pali": "dhammābhisamayo ahu."
    },
    {
      "id": "tha-ap82:25.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap82:25.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap82:25.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap82:25.4",
      "pali": "tipadumānidaṁ phalaṁ."
    },
    {
      "id": "tha-ap82:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap82:26.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap82:26.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap82:26.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap82:27.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap82:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap82:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap82:28.1",
      "pali": "Itthaṁ sudaṁ āyasmā tipadumiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap82:29.1",
      "pali": "Tipadumiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap82:30.1",
      "pali": "Nāgasamālavaggo aṭṭhamo."
    },
    {
      "id": "tha-ap82:31.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap82:32.1",
      "pali": "Nāgasamālo padasaññī,"
    },
    {
      "id": "tha-ap82:32.2",
      "pali": "saññakāluvadāyako;"
    },
    {
      "id": "tha-ap82:32.3",
      "pali": "Ekasaññī tiṇasanthāro,"
    },
    {
      "id": "tha-ap82:32.4",
      "pali": "sūcipāṭalipupphiyo;"
    },
    {
      "id": "tha-ap82:32.5",
      "pali": "Ṭhitañjalī tipadumī,"
    },
    {
      "id": "tha-ap82:32.6",
      "pali": "gāthāyo pañcasattati."
    }
  ]
}
