{
  "uid": "thi-ap40",
  "title": "10 Pesalātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap40:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap40:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap40:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap40:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap40:2.1",
      "pali": "Sāvatthiyaṁ pure vare,"
    },
    {
      "id": "thi-ap40:2.2",
      "pali": "upāsakakule ahaṁ;"
    },
    {
      "id": "thi-ap40:2.3",
      "pali": "Pasūtā taṁ jinavaraṁ,"
    },
    {
      "id": "thi-ap40:2.4",
      "pali": "disvā sutvā ca desanaṁ."
    },
    {
      "id": "thi-ap40:3.1",
      "pali": "Taṁ vīraṁ saraṇaṁ gantvā,"
    },
    {
      "id": "thi-ap40:3.2",
      "pali": "sīlāni ca samādiyiṁ;"
    },
    {
      "id": "thi-ap40:3.3",
      "pali": "Kadāci so mahāvīro,"
    },
    {
      "id": "thi-ap40:3.4",
      "pali": "mahājanasamāgame."
    },
    {
      "id": "thi-ap40:4.1",
      "pali": "Attano abhisambodhiṁ,"
    },
    {
      "id": "thi-ap40:4.2",
      "pali": "pakāsesi narāsabho;"
    },
    {
      "id": "thi-ap40:4.3",
      "pali": "Ananussutadhammesu,"
    },
    {
      "id": "thi-ap40:4.4",
      "pali": "pubbe dukkhādikesu ca."
    },
    {
      "id": "thi-ap40:5.1",
      "pali": "Cakkhu ñāṇañca paññā ca,"
    },
    {
      "id": "thi-ap40:5.2",
      "pali": "vijjāloko ca āsi me;"
    },
    {
      "id": "thi-ap40:5.3",
      "pali": "Taṁ sutvā uggahetvāna,"
    },
    {
      "id": "thi-ap40:5.4",
      "pali": "paripucchiñca bhikkhavo."
    },
    {
      "id": "thi-ap40:6.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap40:6.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap40:6.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap40:6.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap40:7.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap40:7.2",
      "pali": "Jātā seṭṭhimahākule;"
    },
    {
      "id": "thi-ap40:7.3",
      "pali": "Upecca buddhaṁ saddhammaṁ,"
    },
    {
      "id": "thi-ap40:7.4",
      "pali": "Sutvā saccūpasaṁhitaṁ."
    },
    {
      "id": "thi-ap40:8.1",
      "pali": "Pabbajitvācireneva,"
    },
    {
      "id": "thi-ap40:8.2",
      "pali": "saccatthāni vicintayaṁ;"
    },
    {
      "id": "thi-ap40:8.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thi-ap40:8.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap40:9.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap40:9.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap40:9.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap40:9.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap40:10.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap40:10.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap40:10.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap40:10.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap40:11.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap40:11.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap40:11.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap40:11.4",
      "pali": "buddhaseṭṭhassa vāhasā."
    },
    {
      "id": "thi-ap40:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap40:12.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap40:12.3",
      "pali": "Nāgīva bandhanaṁ chetvā,"
    },
    {
      "id": "thi-ap40:12.4",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap40:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap40:13.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "thi-ap40:13.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thi-ap40:13.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap40:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap40:14.2",
      "pali": "Vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "thi-ap40:14.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thi-ap40:14.4",
      "pali": "Kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap40:15.1",
      "pali": "Itthaṁ sudaṁ pesalā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap40:16.1",
      "pali": "Pesalātheriyāpadānaṁ dasamaṁ."
    },
    {
      "id": "thi-ap40:16.2",
      "pali": "Khattiyāvaggo catuttho."
    },
    {
      "id": "thi-ap40:17.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "thi-ap40:18.1",
      "pali": "Khattiyā brāhmaṇī ceva,"
    },
    {
      "id": "thi-ap40:18.2",
      "pali": "tathā uppaladāyikā;"
    },
    {
      "id": "thi-ap40:18.3",
      "pali": "Siṅgālamātā sukkā ca,"
    },
    {
      "id": "thi-ap40:18.4",
      "pali": "abhirūpā aḍḍhakāsikā."
    },
    {
      "id": "thi-ap40:19.1",
      "pali": "Puṇṇā ca ambapālī ca,"
    },
    {
      "id": "thi-ap40:19.2",
      "pali": "pesalāti ca tā dasa;"
    },
    {
      "id": "thi-ap40:19.3",
      "pali": "Gāthāyo dvisatānettha,"
    },
    {
      "id": "thi-ap40:19.4",
      "pali": "dvicattālīsa cuttari."
    },
    {
      "id": "thi-ap40:20.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "thi-ap40:21.1",
      "pali": "Sumedhā ekūposathā,"
    },
    {
      "id": "thi-ap40:21.2",
      "pali": "kuṇḍalakesī khattiyā;"
    },
    {
      "id": "thi-ap40:21.3",
      "pali": "Sahassaṁ tisatā gāthā,"
    },
    {
      "id": "thi-ap40:21.4",
      "pali": "sattatālīsa piṇḍitā."
    },
    {
      "id": "thi-ap40:22.1",
      "pali": "Saha uddānagāthāhi,"
    },
    {
      "id": "thi-ap40:22.2",
      "pali": "gaṇitāyo vibhāvibhi;"
    },
    {
      "id": "thi-ap40:22.3",
      "pali": "Sahassaṁ tisataṁ gāthā,"
    },
    {
      "id": "thi-ap40:22.4",
      "pali": "sattapaññāsameva cāti."
    },
    {
      "id": "thi-ap40:23.1",
      "pali": "Therikāpadānaṁ samattaṁ."
    },
    {
      "id": "thi-ap40:24.1",
      "pali": "Apadānapāḷi samattā."
    }
  ]
}
