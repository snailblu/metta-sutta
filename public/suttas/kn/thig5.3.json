{
  "uid": "thig5.3",
  "title": "Sīhātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.3:1.1",
      "pali": "“Ayoniso manasikārā,"
    },
    {
      "id": "thig5.3:1.2",
      "pali": "kāmarāgena aṭṭitā;"
    },
    {
      "id": "thig5.3:1.3",
      "pali": "Ahosiṁ uddhatā pubbe,"
    },
    {
      "id": "thig5.3:1.4",
      "pali": "citte avasavattinī."
    },
    {
      "id": "thig5.3:2.1",
      "pali": "Pariyuṭṭhitā klesehi,"
    },
    {
      "id": "thig5.3:2.2",
      "pali": "subhasaññānuvattinī;"
    },
    {
      "id": "thig5.3:2.3",
      "pali": "Samaṁ cittassa na labhiṁ,"
    },
    {
      "id": "thig5.3:2.4",
      "pali": "rāgacittavasānugā."
    },
    {
      "id": "thig5.3:3.1",
      "pali": "Kisā paṇḍu vivaṇṇā ca,"
    },
    {
      "id": "thig5.3:3.2",
      "pali": "satta vassāni cārihaṁ;"
    },
    {
      "id": "thig5.3:3.3",
      "pali": "Nāhaṁ divā vā rattiṁ vā,"
    },
    {
      "id": "thig5.3:3.4",
      "pali": "sukhaṁ vindiṁ sudukkhitā."
    },
    {
      "id": "thig5.3:4.1",
      "pali": "Tato rajjuṁ gahetvāna,"
    },
    {
      "id": "thig5.3:4.2",
      "pali": "pāvisiṁ vanamantaraṁ;"
    },
    {
      "id": "thig5.3:4.3",
      "pali": "Varaṁ me idha ubbandhaṁ,"
    },
    {
      "id": "thig5.3:4.4",
      "pali": "yañca hīnaṁ punācare."
    },
    {
      "id": "thig5.3:5.1",
      "pali": "Daḷhapāsaṁ karitvāna,"
    },
    {
      "id": "thig5.3:5.2",
      "pali": "rukkhasākhāya bandhiya;"
    },
    {
      "id": "thig5.3:5.3",
      "pali": "Pakkhipiṁ pāsaṁ gīvāyaṁ,"
    },
    {
      "id": "thig5.3:5.4",
      "pali": "atha cittaṁ vimucci me”ti."
    },
    {
      "id": "thig5.3:6.1",
      "pali": "… Sīhā therī …."
    }
  ]
}
