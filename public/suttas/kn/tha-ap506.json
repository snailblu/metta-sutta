{
  "uid": "tha-ap506",
  "title": "Avaṭaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap506:1.1",
      "pali": "“Sahassaraṁsī bhagavā,"
    },
    {
      "id": "tha-ap506:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap506:1.3",
      "pali": "Vivekā vuṭṭhahitvāna,"
    },
    {
      "id": "tha-ap506:1.4",
      "pali": "gocarāyābhinikkhami."
    },
    {
      "id": "tha-ap506:2.1",
      "pali": "Phalahattho ahaṁ disvā,"
    },
    {
      "id": "tha-ap506:2.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap506:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap506:2.4",
      "pali": "avaṭaṁ adadiṁ phalaṁ."
    },
    {
      "id": "tha-ap506:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap506:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap506:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap506:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap506:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap506:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap506:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap506:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap506:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap506:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap506:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap506:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap506:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap506:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā avaṭaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap506:8.1",
      "pali": "Avaṭaphaliyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
