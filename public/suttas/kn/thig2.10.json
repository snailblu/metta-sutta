{
  "uid": "thig2.10",
  "title": "Sāmātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.10:1.1",
      "pali": "“Catukkhattuṁ pañcakkhattuṁ,"
    },
    {
      "id": "thig2.10:1.2",
      "pali": "vihārā upanikkhamiṁ;"
    },
    {
      "id": "thig2.10:1.3",
      "pali": "Aladdhā cetaso santiṁ,"
    },
    {
      "id": "thig2.10:1.4",
      "pali": "citte avasavattinī;"
    },
    {
      "id": "thig2.10:1.5",
      "pali": "Tassā me aṭṭhamī ratti,"
    },
    {
      "id": "thig2.10:1.6",
      "pali": "yato taṇhā samūhatā."
    },
    {
      "id": "thig2.10:2.1",
      "pali": "Bahūhi dukkhadhammehi,"
    },
    {
      "id": "thig2.10:2.2",
      "pali": "appamādaratāya me;"
    },
    {
      "id": "thig2.10:2.3",
      "pali": "Taṇhakkhayo anuppatto,"
    },
    {
      "id": "thig2.10:2.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig2.10:3.1",
      "pali": "… Sāmā therī …."
    },
    {
      "id": "thig2.10:4.1",
      "pali": "Dukanipāto niṭṭhito."
    }
  ]
}
