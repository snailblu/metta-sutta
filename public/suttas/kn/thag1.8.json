{
  "uid": "thag1.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.8:1.1",
      "pali": "“Yo duddamiyo damena danto,"
    },
    {
      "id": "thag1.8:1.2",
      "pali": "Vīro santusito vitiṇṇakaṅkho;"
    },
    {
      "id": "thag1.8:1.3",
      "pali": "Vijitāvī apetalomahaṁso,"
    },
    {
      "id": "thag1.8:1.4",
      "pali": "Vīro so parinibbuto ṭhitatto”ti."
    },
    {
      "id": "thag1.8:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā vīro thero gāthaṁ abhāsitthāti."
    }
  ]
}
