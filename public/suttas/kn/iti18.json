{
  "uid": "iti18",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti18:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti18:2.1",
      "pali": "“Ekadhammo, bhikkhave, loke uppajjamāno uppajjati bahujanāhitāya bahujanāsukhāya bahuno janassa anatthāya ahitāya dukkhāya devamanussānaṁ."
    },
    {
      "id": "iti18:2.2",
      "pali": "Katamo ekadhammo?"
    },
    {
      "id": "iti18:2.3",
      "pali": "Saṅghabhedo."
    },
    {
      "id": "iti18:2.4",
      "pali": "Saṅghe kho pana, bhikkhave, bhinne aññamaññaṁ bhaṇḍanāni ceva honti, aññamaññaṁ paribhāsā ca honti, aññamaññaṁ parikkhepā ca honti, aññamaññaṁ pariccajanā ca honti."
    },
    {
      "id": "iti18:2.5",
      "pali": "Tattha appasannā ceva nappasīdanti, pasannānañca ekaccānaṁ aññathattaṁ hotī”ti."
    },
    {
      "id": "iti18:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti18:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti18:3.1",
      "pali": "“Āpāyiko nerayiko,"
    },
    {
      "id": "iti18:3.2",
      "pali": "Kappaṭṭho saṅghabhedako;"
    },
    {
      "id": "iti18:3.3",
      "pali": "Vaggārāmo adhammaṭṭho,"
    },
    {
      "id": "iti18:3.4",
      "pali": "Yogakkhemā padhaṁsati;"
    },
    {
      "id": "iti18:3.5",
      "pali": "Saṅghaṁ samaggaṁ bhetvāna,"
    },
    {
      "id": "iti18:3.6",
      "pali": "Kappaṁ nirayamhi paccatī”ti."
    },
    {
      "id": "iti18:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti18:4.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
