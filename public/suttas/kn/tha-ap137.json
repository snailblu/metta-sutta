{
  "uid": "tha-ap137",
  "title": "5 Rahosaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap137:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap137:1.2",
      "pali": "vasabho nāma pabbato;"
    },
    {
      "id": "tha-ap137:1.3",
      "pali": "Tasmiṁ pabbatapādamhi,"
    },
    {
      "id": "tha-ap137:1.4",
      "pali": "assamo āsi māpito."
    },
    {
      "id": "tha-ap137:2.1",
      "pali": "Tīṇi sissasahassāni,"
    },
    {
      "id": "tha-ap137:2.2",
      "pali": "vācesiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap137:2.3",
      "pali": "Saṁharitvāna te sisse,"
    },
    {
      "id": "tha-ap137:2.4",
      "pali": "ekamantaṁ upāvisiṁ."
    },
    {
      "id": "tha-ap137:3.1",
      "pali": "Ekamantaṁ nisīditvā,"
    },
    {
      "id": "tha-ap137:3.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap137:3.3",
      "pali": "Buddhavedaṁ gavesanto,"
    },
    {
      "id": "tha-ap137:3.4",
      "pali": "ñāṇe cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap137:4.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap137:4.2",
      "pali": "nisīdiṁ paṇṇasanthare;"
    },
    {
      "id": "tha-ap137:4.3",
      "pali": "Pallaṅkaṁ ābhujitvāna,"
    },
    {
      "id": "tha-ap137:4.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap137:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap137:5.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap137:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap137:5.4",
      "pali": "ñāṇasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap137:6.1",
      "pali": "Sattavīsatikappamhi,"
    },
    {
      "id": "tha-ap137:6.2",
      "pali": "rājā siridharo ahu;"
    },
    {
      "id": "tha-ap137:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap137:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap137:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap137:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap137:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap137:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā rahosaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap137:9.1",
      "pali": "Rahosaññakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
