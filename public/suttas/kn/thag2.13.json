{
  "uid": "thag2.13",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.13:1.1",
      "pali": "“Accayanti ahorattā,"
    },
    {
      "id": "thag2.13:1.2",
      "pali": "jīvitaṁ uparujjhati;"
    },
    {
      "id": "thag2.13:1.3",
      "pali": "Āyu khīyati maccānaṁ,"
    },
    {
      "id": "thag2.13:1.4",
      "pali": "kunnadīnaṁva odakaṁ."
    },
    {
      "id": "thag2.13:2.1",
      "pali": "Atha pāpāni kammāni,"
    },
    {
      "id": "thag2.13:2.2",
      "pali": "karaṁ bālo na bujjhati;"
    },
    {
      "id": "thag2.13:2.3",
      "pali": "Pacchāssa kaṭukaṁ hoti,"
    },
    {
      "id": "thag2.13:2.4",
      "pali": "vipāko hissa pāpako”ti."
    },
    {
      "id": "thag2.13:2.5",
      "pali": "… Heraññakānitthero …."
    }
  ]
}
