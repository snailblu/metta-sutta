{
  "uid": "pv5",
  "title": "5. Tirokuṭṭapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv5:1.1",
      "pali": "“Tirokuṭṭesu tiṭṭhanti,"
    },
    {
      "id": "pv5:1.2",
      "pali": "sandhisiṅghāṭakesu ca;"
    },
    {
      "id": "pv5:1.3",
      "pali": "Dvārabāhāsu tiṭṭhanti,"
    },
    {
      "id": "pv5:1.4",
      "pali": "āgantvāna sakaṁ gharaṁ."
    },
    {
      "id": "pv5:2.1",
      "pali": "Pahūte annapānamhi,"
    },
    {
      "id": "pv5:2.2",
      "pali": "khajjabhojje upaṭṭhite;"
    },
    {
      "id": "pv5:2.3",
      "pali": "Na tesaṁ koci sarati,"
    },
    {
      "id": "pv5:2.4",
      "pali": "sattānaṁ kammapaccayā."
    },
    {
      "id": "pv5:3.1",
      "pali": "Evaṁ dadanti ñātīnaṁ,"
    },
    {
      "id": "pv5:3.2",
      "pali": "ye honti anukampakā;"
    },
    {
      "id": "pv5:3.3",
      "pali": "Suciṁ paṇītaṁ kālena,"
    },
    {
      "id": "pv5:3.4",
      "pali": "kappiyaṁ pānabhojanaṁ;"
    },
    {
      "id": "pv5:3.5",
      "pali": "‘Idaṁ vo ñātīnaṁ hotu,"
    },
    {
      "id": "pv5:3.6",
      "pali": "sukhitā hontu ñātayo’."
    },
    {
      "id": "pv5:4.1",
      "pali": "Te ca tattha samāgantvā,"
    },
    {
      "id": "pv5:4.2",
      "pali": "ñātipetā samāgatā;"
    },
    {
      "id": "pv5:4.3",
      "pali": "Pahūte annapānamhi,"
    },
    {
      "id": "pv5:4.4",
      "pali": "sakkaccaṁ anumodare."
    },
    {
      "id": "pv5:5.1",
      "pali": "‘Ciraṁ jīvantu no ñātī,"
    },
    {
      "id": "pv5:5.2",
      "pali": "yesaṁ hetu labhāmase;"
    },
    {
      "id": "pv5:5.3",
      "pali": "Amhākañca katā pūjā,"
    },
    {
      "id": "pv5:5.4",
      "pali": "dāyakā ca anipphalā’."
    },
    {
      "id": "pv5:6.1",
      "pali": "Na hi tattha kasī atthi,"
    },
    {
      "id": "pv5:6.2",
      "pali": "gorakkhettha na vijjati;"
    },
    {
      "id": "pv5:6.3",
      "pali": "Vaṇijjā tādisī natthi,"
    },
    {
      "id": "pv5:6.4",
      "pali": "hiraññena kayākayaṁ;"
    },
    {
      "id": "pv5:6.5",
      "pali": "Ito dinnena yāpenti,"
    },
    {
      "id": "pv5:6.6",
      "pali": "petā kālagatā tahiṁ."
    },
    {
      "id": "pv5:7.1",
      "pali": "Unname udakaṁ vuṭṭhaṁ,"
    },
    {
      "id": "pv5:7.2",
      "pali": "yathā ninnaṁ pavattati;"
    },
    {
      "id": "pv5:7.3",
      "pali": "Evamevaṁ ito dinnaṁ,"
    },
    {
      "id": "pv5:7.4",
      "pali": "petānaṁ upakappati."
    },
    {
      "id": "pv5:8.1",
      "pali": "Yathā vārivahā pūrā,"
    },
    {
      "id": "pv5:8.2",
      "pali": "paripūrenti sāgaraṁ;"
    },
    {
      "id": "pv5:8.3",
      "pali": "Evamevaṁ ito dinnaṁ,"
    },
    {
      "id": "pv5:8.4",
      "pali": "petānaṁ upakappati."
    },
    {
      "id": "pv5:9.1",
      "pali": "‘Adāsi me akāsi me,"
    },
    {
      "id": "pv5:9.2",
      "pali": "ñāti mittā sakhā ca me’;"
    },
    {
      "id": "pv5:9.3",
      "pali": "Petānaṁ dakkhiṇaṁ dajjā,"
    },
    {
      "id": "pv5:9.4",
      "pali": "pubbe katamanussaraṁ."
    },
    {
      "id": "pv5:10.1",
      "pali": "Na hi ruṇṇaṁ vā soko vā,"
    },
    {
      "id": "pv5:10.2",
      "pali": "yā caññā paridevanā;"
    },
    {
      "id": "pv5:10.3",
      "pali": "Na taṁ petānamatthāya,"
    },
    {
      "id": "pv5:10.4",
      "pali": "evaṁ tiṭṭhanti ñātayo."
    },
    {
      "id": "pv5:11.1",
      "pali": "Ayañca kho dakkhiṇā dinnā,"
    },
    {
      "id": "pv5:11.2",
      "pali": "saṅghamhi suppatiṭṭhitā;"
    },
    {
      "id": "pv5:11.3",
      "pali": "Dīgharattaṁ hitāyassa,"
    },
    {
      "id": "pv5:11.4",
      "pali": "ṭhānaso upakappati."
    },
    {
      "id": "pv5:12.1",
      "pali": "So ñātidhammo ca ayaṁ nidassito,"
    },
    {
      "id": "pv5:12.2",
      "pali": "Petāna pūjā ca katā uḷārā;"
    },
    {
      "id": "pv5:12.3",
      "pali": "Balañca bhikkhūnamanuppadinnaṁ,"
    },
    {
      "id": "pv5:12.4",
      "pali": "Tumhehi puññaṁ pasutaṁ anappakan”ti."
    },
    {
      "id": "pv5:13.1",
      "pali": "Tirokuṭṭapetavatthu pañcamaṁ."
    }
  ]
}
