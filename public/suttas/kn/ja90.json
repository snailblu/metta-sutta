{
  "uid": "ja90",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja90:1.1",
      "pali": "“Yo pubbe katakalyāṇo,"
    },
    {
      "id": "ja90:1.2",
      "pali": "katattho nāvabujjhati;"
    },
    {
      "id": "ja90:1.3",
      "pali": "Pacchā kicce samuppanne,"
    },
    {
      "id": "ja90:1.4",
      "pali": "kattāraṁ nādhigacchatī”ti."
    },
    {
      "id": "ja90:2.1",
      "pali": "Akataññujātakaṁ dasamaṁ."
    },
    {
      "id": "ja90:2.2",
      "pali": "Apāyimhavaggo navamo."
    },
    {
      "id": "ja90:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja90:4.1",
      "pali": "Apāyimha ca dūbhaka sattapadaṁ,"
    },
    {
      "id": "ja90:4.2",
      "pali": "Chaḷadvara ca āyatinā ca puna;"
    },
    {
      "id": "ja90:4.3",
      "pali": "Ahisīlava maṅgali pāpikassā,"
    },
    {
      "id": "ja90:4.4",
      "pali": "Sataṁnikkha katatthavarena dasāti."
    }
  ]
}
