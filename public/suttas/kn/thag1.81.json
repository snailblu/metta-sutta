{
  "uid": "thag1.81",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.81:1.1",
      "pali": "“Yaṁ mayā pakataṁ pāpaṁ,"
    },
    {
      "id": "thag1.81:1.2",
      "pali": "pubbe aññāsu jātisu;"
    },
    {
      "id": "thag1.81:1.3",
      "pali": "Idheva taṁ vedanīyaṁ,"
    },
    {
      "id": "thag1.81:1.4",
      "pali": "vatthu aññaṁ na vijjatī”ti."
    },
    {
      "id": "thag1.81:1.5",
      "pali": "… Samitigutto thero …."
    }
  ]
}
