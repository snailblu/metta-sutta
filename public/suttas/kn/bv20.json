{
  "uid": "bv20",
  "title": "20. Phussabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv20:1.1",
      "pali": "“Tattheva maṇḍakappamhi,"
    },
    {
      "id": "bv20:1.2",
      "pali": "ahu satthā anuttaro;"
    },
    {
      "id": "bv20:1.3",
      "pali": "Anūpamo asamasamo,"
    },
    {
      "id": "bv20:1.4",
      "pali": "phusso lokagganāyako."
    },
    {
      "id": "bv20:2.1",
      "pali": "Sopi sabbaṁ tamaṁ hantvā,"
    },
    {
      "id": "bv20:2.2",
      "pali": "vijaṭetvā mahājaṭaṁ;"
    },
    {
      "id": "bv20:2.3",
      "pali": "Sadevakaṁ tappayanto,"
    },
    {
      "id": "bv20:2.4",
      "pali": "abhivassi amatambunā."
    },
    {
      "id": "bv20:3.1",
      "pali": "Dhammacakkaṁ pavattente,"
    },
    {
      "id": "bv20:3.2",
      "pali": "phusse nakkhattamaṅgale;"
    },
    {
      "id": "bv20:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv20:3.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv20:4.1",
      "pali": "Navutisatasahassānaṁ,"
    },
    {
      "id": "bv20:4.2",
      "pali": "dutiyābhisamayo ahu;"
    },
    {
      "id": "bv20:4.3",
      "pali": "Asītisatasahassānaṁ,"
    },
    {
      "id": "bv20:4.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv20:5.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv20:5.2",
      "pali": "phussassāpi mahesino;"
    },
    {
      "id": "bv20:5.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv20:5.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv20:6.1",
      "pali": "Saṭṭhisatasahassānaṁ,"
    },
    {
      "id": "bv20:6.2",
      "pali": "paṭhamo āsi samāgamo;"
    },
    {
      "id": "bv20:6.3",
      "pali": "Paññāsasatasahassānaṁ,"
    },
    {
      "id": "bv20:6.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv20:7.1",
      "pali": "Cattārīsasatasahassānaṁ,"
    },
    {
      "id": "bv20:7.2",
      "pali": "Tatiyo āsi samāgamo;"
    },
    {
      "id": "bv20:7.3",
      "pali": "Anupādā vimuttānaṁ,"
    },
    {
      "id": "bv20:7.4",
      "pali": "Vocchinnapaṭisandhinaṁ."
    },
    {
      "id": "bv20:8.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv20:8.2",
      "pali": "vijitāvī nāma khattiyo;"
    },
    {
      "id": "bv20:8.3",
      "pali": "Chaḍḍayitvā mahārajjaṁ,"
    },
    {
      "id": "bv20:8.4",
      "pali": "pabbajiṁ tassa santike."
    },
    {
      "id": "bv20:9.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv20:9.2",
      "pali": "phusso lokagganāyako;"
    },
    {
      "id": "bv20:9.3",
      "pali": "‘Dvenavute ito kappe,"
    },
    {
      "id": "bv20:9.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv20:10.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv20:10.2",
      "pali": "…pe…"
    },
    {
      "id": "bv20:10.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv20:11.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv20:11.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv20:11.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv20:11.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv20:12.1",
      "pali": "Suttantaṁ vinayañcāpi,"
    },
    {
      "id": "bv20:12.2",
      "pali": "navaṅgaṁ satthusāsanaṁ;"
    },
    {
      "id": "bv20:12.3",
      "pali": "Sabbaṁ pariyāpuṇitvā,"
    },
    {
      "id": "bv20:12.4",
      "pali": "sobhayiṁ jinasāsanaṁ."
    },
    {
      "id": "bv20:13.1",
      "pali": "Tatthappamatto viharanto,"
    },
    {
      "id": "bv20:13.2",
      "pali": "brahmaṁ bhāvetva bhāvanaṁ;"
    },
    {
      "id": "bv20:13.3",
      "pali": "Abhiññāsu pāramiṁ gantvā,"
    },
    {
      "id": "bv20:13.4",
      "pali": "brahmalokamagañchahaṁ."
    },
    {
      "id": "bv20:14.1",
      "pali": "Kāsikaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv20:14.2",
      "pali": "jayaseno nāma khattiyo;"
    },
    {
      "id": "bv20:14.3",
      "pali": "Sirimā nāma janikā,"
    },
    {
      "id": "bv20:14.4",
      "pali": "phussassāpi mahesino."
    },
    {
      "id": "bv20:15.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv20:15.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv20:15.3",
      "pali": "Garuḷapakkha haṁsa suvaṇṇabhārā,"
    },
    {
      "id": "bv20:15.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv20:16.1",
      "pali": "Tiṁsaitthisahassāni,"
    },
    {
      "id": "bv20:16.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv20:16.3",
      "pali": "Kisāgotamī nāma nārī,"
    },
    {
      "id": "bv20:16.4",
      "pali": "anūpamo nāma atrajo."
    },
    {
      "id": "bv20:17.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv20:17.2",
      "pali": "hatthiyānena nikkhami;"
    },
    {
      "id": "bv20:17.3",
      "pali": "Chamāsaṁ padhānacāraṁ,"
    },
    {
      "id": "bv20:17.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv20:18.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv20:18.2",
      "pali": "phusso lokagganāyako;"
    },
    {
      "id": "bv20:18.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv20:18.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv20:19.1",
      "pali": "Surakkhito dhammaseno,"
    },
    {
      "id": "bv20:19.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv20:19.3",
      "pali": "Sabhiyo nāmupaṭṭhāko,"
    },
    {
      "id": "bv20:19.4",
      "pali": "phussassāpi mahesino."
    },
    {
      "id": "bv20:20.1",
      "pali": "Cālā ca upacālā ca,"
    },
    {
      "id": "bv20:20.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv20:20.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv20:20.4",
      "pali": "āmaṇḍoti pavuccati."
    },
    {
      "id": "bv20:21.1",
      "pali": "Dhanañcayo visākho ca,"
    },
    {
      "id": "bv20:21.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv20:21.3",
      "pali": "Padumā ceva nāgā ca,"
    },
    {
      "id": "bv20:21.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv20:22.1",
      "pali": "Aṭṭhapaṇṇāsaratanaṁ,"
    },
    {
      "id": "bv20:22.2",
      "pali": "sopi accuggato muni;"
    },
    {
      "id": "bv20:22.3",
      "pali": "Sobhate sataraṁsīva,"
    },
    {
      "id": "bv20:22.4",
      "pali": "uḷurājāva pūrito."
    },
    {
      "id": "bv20:23.1",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv20:23.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv20:23.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv20:23.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv20:24.1",
      "pali": "Ovaditvā bahū satte,"
    },
    {
      "id": "bv20:24.2",
      "pali": "santāretvā bahū jane;"
    },
    {
      "id": "bv20:24.3",
      "pali": "Sopi satthā atulayaso,"
    },
    {
      "id": "bv20:24.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv20:25.1",
      "pali": "Phusso jinavaro satthā,"
    },
    {
      "id": "bv20:25.2",
      "pali": "Senārāmamhi nibbuto;"
    },
    {
      "id": "bv20:25.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv20:25.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv20:26.1",
      "pali": "Phussassa bhagavato vaṁso aṭṭhārasamo."
    }
  ]
}
