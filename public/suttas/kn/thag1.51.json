{
  "uid": "thag1.51",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.51:1.1",
      "pali": "“Vassati devo yathā sugītaṁ,"
    },
    {
      "id": "thag1.51:1.2",
      "pali": "Channā me kuṭikā sukhā nivātā;"
    },
    {
      "id": "thag1.51:1.3",
      "pali": "Cittaṁ susamāhitañca mayhaṁ,"
    },
    {
      "id": "thag1.51:1.4",
      "pali": "Atha ce patthayasi pavassa devā”ti."
    },
    {
      "id": "thag1.51:1.5",
      "pali": "… Godhiko thero …."
    }
  ]
}
