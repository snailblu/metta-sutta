{
  "uid": "ja25",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja25:1.1",
      "pali": "“Aññamaññehi titthehi,"
    },
    {
      "id": "ja25:1.2",
      "pali": "assaṁ pāyehi sārathi;"
    },
    {
      "id": "ja25:1.3",
      "pali": "Accāsanassa puriso,"
    },
    {
      "id": "ja25:1.4",
      "pali": "pāyāsassapi tappatī”ti."
    },
    {
      "id": "ja25:2.1",
      "pali": "Titthajātakaṁ pañcamaṁ."
    }
  ]
}
