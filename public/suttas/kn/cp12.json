{
  "uid": "cp12",
  "title": "Sīlapāramī 2",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp12:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp12:1.2",
      "pali": "bhūridatto mahiddhiko;"
    },
    {
      "id": "cp12:1.3",
      "pali": "Virūpakkhena mahāraññā,"
    },
    {
      "id": "cp12:1.4",
      "pali": "devalokamagañchahaṁ."
    },
    {
      "id": "cp12:2.1",
      "pali": "Tattha passitvāhaṁ deve,"
    },
    {
      "id": "cp12:2.2",
      "pali": "ekantaṁ sukhasamappite;"
    },
    {
      "id": "cp12:2.3",
      "pali": "Taṁ saggagamanatthāya,"
    },
    {
      "id": "cp12:2.4",
      "pali": "sīlabbataṁ samādiyiṁ."
    },
    {
      "id": "cp12:3.1",
      "pali": "Sarīrakiccaṁ katvāna,"
    },
    {
      "id": "cp12:3.2",
      "pali": "bhutvā yāpanamattakaṁ;"
    },
    {
      "id": "cp12:3.3",
      "pali": "Caturo aṅge adhiṭṭhāya,"
    },
    {
      "id": "cp12:3.4",
      "pali": "semi vammikamuddhani."
    },
    {
      "id": "cp12:4.1",
      "pali": "‘Chaviyā cammena maṁsena,"
    },
    {
      "id": "cp12:4.2",
      "pali": "Nahāruaṭṭhikehi vā;"
    },
    {
      "id": "cp12:4.3",
      "pali": "Yassa etena karaṇīyaṁ,"
    },
    {
      "id": "cp12:4.4",
      "pali": "Dinnaṁyeva harātu so’."
    },
    {
      "id": "cp12:5.1",
      "pali": "Saṁsito akataññunā,"
    },
    {
      "id": "cp12:5.2",
      "pali": "ālampāyano mamaggahi;"
    },
    {
      "id": "cp12:5.3",
      "pali": "Peḷāya pakkhipitvāna,"
    },
    {
      "id": "cp12:5.4",
      "pali": "kīḷeti maṁ tahiṁ tahiṁ."
    },
    {
      "id": "cp12:6.1",
      "pali": "Peḷāya pakkhipantepi,"
    },
    {
      "id": "cp12:6.2",
      "pali": "sammaddantepi pāṇinā;"
    },
    {
      "id": "cp12:6.3",
      "pali": "Ālampāyane na kuppāmi,"
    },
    {
      "id": "cp12:6.4",
      "pali": "sīlakhaṇḍabhayā mama."
    },
    {
      "id": "cp12:7.1",
      "pali": "Sakajīvitapariccāgo,"
    },
    {
      "id": "cp12:7.2",
      "pali": "tiṇato lahuko mama;"
    },
    {
      "id": "cp12:7.3",
      "pali": "Sīlavītikkamo mayhaṁ,"
    },
    {
      "id": "cp12:7.4",
      "pali": "pathavīuppatanaṁ viya."
    },
    {
      "id": "cp12:8.1",
      "pali": "Nirantaraṁ jātisataṁ,"
    },
    {
      "id": "cp12:8.2",
      "pali": "cajeyyaṁ mama jīvitaṁ;"
    },
    {
      "id": "cp12:8.3",
      "pali": "Neva sīlaṁ pabhindeyyaṁ,"
    },
    {
      "id": "cp12:8.4",
      "pali": "catuddīpāna hetupi."
    },
    {
      "id": "cp12:9.1",
      "pali": "Api cāhaṁ sīlarakkhāya,"
    },
    {
      "id": "cp12:9.2",
      "pali": "Sīlapāramipūriyā;"
    },
    {
      "id": "cp12:9.3",
      "pali": "Na karomi citte aññathattaṁ,"
    },
    {
      "id": "cp12:9.4",
      "pali": "Pakkhipantampi peḷake”ti."
    },
    {
      "id": "cp12:10.1",
      "pali": "Bhūridattacariyaṁ dutiyaṁ."
    }
  ]
}
