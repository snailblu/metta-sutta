{
  "uid": "tha-ap190",
  "title": "Tikaṇṇipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap190:1.1",
      "pali": "“Devabhūto ahaṁ santo,"
    },
    {
      "id": "tha-ap190:1.2",
      "pali": "accharāhi purakkhato;"
    },
    {
      "id": "tha-ap190:1.3",
      "pali": "Pubbakammaṁ saritvāna,"
    },
    {
      "id": "tha-ap190:1.4",
      "pali": "buddhaseṭṭhaṁ anussariṁ."
    },
    {
      "id": "tha-ap190:2.1",
      "pali": "Tikaṇṇipupphaṁ paggayha,"
    },
    {
      "id": "tha-ap190:2.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap190:2.3",
      "pali": "Buddhamhi abhiropesiṁ,"
    },
    {
      "id": "tha-ap190:2.4",
      "pali": "vipassimhi narāsabhe."
    },
    {
      "id": "tha-ap190:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap190:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap190:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap190:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap190:4.1",
      "pali": "Tesattatimhito kappe,"
    },
    {
      "id": "tha-ap190:4.2",
      "pali": "caturāsuṁ ramuttamā;"
    },
    {
      "id": "tha-ap190:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap190:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap190:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap190:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap190:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap190:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā tikaṇṇipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap190:7.1",
      "pali": "Tikaṇṇipupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
