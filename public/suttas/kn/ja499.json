{
  "uid": "ja499",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja499:1.1",
      "pali": "“Dūre apassaṁ therova,"
    },
    {
      "id": "ja499:1.2",
      "pali": "cakkhuṁ yācitumāgato;"
    },
    {
      "id": "ja499:1.3",
      "pali": "Ekanettā bhavissāma,"
    },
    {
      "id": "ja499:1.4",
      "pali": "cakkhuṁ me dehi yācito”."
    },
    {
      "id": "ja499:2.1",
      "pali": "“Kenānusiṭṭho idha māgatosi,"
    },
    {
      "id": "ja499:2.2",
      "pali": "Vanibbaka cakkhupathāni yācituṁ;"
    },
    {
      "id": "ja499:2.3",
      "pali": "Suduccajaṁ yācasi uttamaṅgaṁ,"
    },
    {
      "id": "ja499:2.4",
      "pali": "Yamāhu nettaṁ purisena duccajaṁ”."
    },
    {
      "id": "ja499:3.1",
      "pali": "“Yamāhu devesu sujampatīti,"
    },
    {
      "id": "ja499:3.2",
      "pali": "Maghavāti naṁ āhu manussaloke;"
    },
    {
      "id": "ja499:3.3",
      "pali": "Tenānusiṭṭho idha māgatosmi,"
    },
    {
      "id": "ja499:3.4",
      "pali": "Vanibbako cakkhupathāni yācituṁ."
    },
    {
      "id": "ja499:4.1",
      "pali": "Vanibbato mayha vaniṁ anuttaraṁ,"
    },
    {
      "id": "ja499:4.2",
      "pali": "Dadāhi te cakkhupathāni yācito;"
    },
    {
      "id": "ja499:4.3",
      "pali": "Dadāhi me cakkhupathaṁ anuttaraṁ,"
    },
    {
      "id": "ja499:4.4",
      "pali": "Yamāhu nettaṁ purisena duccajaṁ”."
    },
    {
      "id": "ja499:5.1",
      "pali": "“Yena atthena āgacchi,"
    },
    {
      "id": "ja499:5.2",
      "pali": "yamatthamabhipatthayaṁ;"
    },
    {
      "id": "ja499:5.3",
      "pali": "Te te ijjhantu saṅkappā,"
    },
    {
      "id": "ja499:5.4",
      "pali": "labha cakkhūni brāhmaṇa."
    },
    {
      "id": "ja499:6.1",
      "pali": "Ekaṁ te yācamānassa,"
    },
    {
      "id": "ja499:6.2",
      "pali": "Ubhayāni dadāmahaṁ;"
    },
    {
      "id": "ja499:6.3",
      "pali": "Sa cakkhumā gaccha janassa pekkhato,"
    },
    {
      "id": "ja499:6.4",
      "pali": "Yadicchase tvaṁ tadate samijjhatu”."
    },
    {
      "id": "ja499:7.1",
      "pali": "“Mā no deva adā cakkhuṁ,"
    },
    {
      "id": "ja499:7.2",
      "pali": "mā no sabbe parākari;"
    },
    {
      "id": "ja499:7.3",
      "pali": "Dhanaṁ dehi mahārāja,"
    },
    {
      "id": "ja499:7.4",
      "pali": "muttā veḷuriyā bahū."
    },
    {
      "id": "ja499:8.1",
      "pali": "Yutte deva rathe dehi,"
    },
    {
      "id": "ja499:8.2",
      "pali": "ājānīye calaṅkate;"
    },
    {
      "id": "ja499:8.3",
      "pali": "Nāge dehi mahārāja,"
    },
    {
      "id": "ja499:8.4",
      "pali": "hemakappanavāsase."
    },
    {
      "id": "ja499:9.1",
      "pali": "Yathā taṁ sivayo sabbe,"
    },
    {
      "id": "ja499:9.2",
      "pali": "sayoggā sarathā sadā;"
    },
    {
      "id": "ja499:9.3",
      "pali": "Samantā parikireyyuṁ,"
    },
    {
      "id": "ja499:9.4",
      "pali": "evaṁ dehi rathesabha”."
    },
    {
      "id": "ja499:10.1",
      "pali": "“Yo ve dassanti vatvāna,"
    },
    {
      "id": "ja499:10.2",
      "pali": "adāne kurute mano;"
    },
    {
      "id": "ja499:10.3",
      "pali": "Bhūmyaṁ so patitaṁ pāsaṁ,"
    },
    {
      "id": "ja499:10.4",
      "pali": "gīvāyaṁ paṭimuñcati."
    },
    {
      "id": "ja499:11.1",
      "pali": "Yo ve dassanti vatvāna,"
    },
    {
      "id": "ja499:11.2",
      "pali": "adāne kurute mano;"
    },
    {
      "id": "ja499:11.3",
      "pali": "Pāpā pāpataro hoti,"
    },
    {
      "id": "ja499:11.4",
      "pali": "sampatto yamasādhanaṁ."
    },
    {
      "id": "ja499:12.1",
      "pali": "Yañhi yāce tañhi dade,"
    },
    {
      "id": "ja499:12.2",
      "pali": "yaṁ na yāce na taṁ dade;"
    },
    {
      "id": "ja499:12.3",
      "pali": "Svāhaṁ tameva dassāmi,"
    },
    {
      "id": "ja499:12.4",
      "pali": "yaṁ maṁ yācati brāhmaṇo”."
    },
    {
      "id": "ja499:13.1",
      "pali": "“Āyuṁ nu vaṇṇaṁ nu sukhaṁ balaṁ nu,"
    },
    {
      "id": "ja499:13.2",
      "pali": "Kiṁ patthayāno nu janinda desi;"
    },
    {
      "id": "ja499:13.3",
      "pali": "Kathañhi rājā sivinaṁ anuttaro,"
    },
    {
      "id": "ja499:13.4",
      "pali": "Cakkhūni dajjā paralokahetu”."
    },
    {
      "id": "ja499:14.1",
      "pali": "“Na vāhametaṁ yasasā dadāmi,"
    },
    {
      "id": "ja499:14.2",
      "pali": "Na puttamicche na dhanaṁ na raṭṭhaṁ;"
    },
    {
      "id": "ja499:14.3",
      "pali": "Satañca dhammo carito purāṇo,"
    },
    {
      "id": "ja499:14.4",
      "pali": "Icceva dāne ramate mano mama”."
    },
    {
      "id": "ja499:14.5",
      "pali": "(…)"
    },
    {
      "id": "ja499:15.1",
      "pali": "“Sakhā ca mitto ca mamāsi sīvika,"
    },
    {
      "id": "ja499:15.2",
      "pali": "Susikkhito sādhu karohi me vaco;"
    },
    {
      "id": "ja499:15.3",
      "pali": "Uddharitvā cakkhūni mamaṁ jigīsato,"
    },
    {
      "id": "ja499:15.4",
      "pali": "Hatthesu ṭhapehi vanibbakassa”."
    },
    {
      "id": "ja499:16.1",
      "pali": "Codito sivirājena,"
    },
    {
      "id": "ja499:16.2",
      "pali": "sīviko vacanaṅkaro;"
    },
    {
      "id": "ja499:16.3",
      "pali": "Rañño cakkhūnuddharitvā,"
    },
    {
      "id": "ja499:16.4",
      "pali": "brāhmaṇassūpanāmayi;"
    },
    {
      "id": "ja499:16.5",
      "pali": "Sacakkhu brāhmaṇo āsi,"
    },
    {
      "id": "ja499:16.6",
      "pali": "andho rājā upāvisi."
    },
    {
      "id": "ja499:17.1",
      "pali": "Tato so katipāhassa,"
    },
    {
      "id": "ja499:17.2",
      "pali": "uparūḷhesu cakkhusu;"
    },
    {
      "id": "ja499:17.3",
      "pali": "Sūtaṁ āmantayī rājā,"
    },
    {
      "id": "ja499:17.4",
      "pali": "sivīnaṁ raṭṭhavaḍḍhano."
    },
    {
      "id": "ja499:18.1",
      "pali": "“Yojehi sārathi yānaṁ,"
    },
    {
      "id": "ja499:18.2",
      "pali": "yuttañca paṭivedaya;"
    },
    {
      "id": "ja499:18.3",
      "pali": "Uyyānabhūmiṁ gacchāma,"
    },
    {
      "id": "ja499:18.4",
      "pali": "pokkharañño vanāni ca”."
    },
    {
      "id": "ja499:19.1",
      "pali": "So ca pokkharaṇītīre,"
    },
    {
      "id": "ja499:19.2",
      "pali": "pallaṅkena upāvisi;"
    },
    {
      "id": "ja499:19.3",
      "pali": "Tassa sakko pāturahu,"
    },
    {
      "id": "ja499:19.4",
      "pali": "devarājā sujampati."
    },
    {
      "id": "ja499:20.1",
      "pali": "“Sakkohamasmi devindo,"
    },
    {
      "id": "ja499:20.2",
      "pali": "āgatosmi tavantike;"
    },
    {
      "id": "ja499:20.3",
      "pali": "Varaṁ varassu rājīsi,"
    },
    {
      "id": "ja499:20.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja499:21.1",
      "pali": "“Pahūtaṁ me dhanaṁ sakka,"
    },
    {
      "id": "ja499:21.2",
      "pali": "balaṁ koso canappako;"
    },
    {
      "id": "ja499:21.3",
      "pali": "Andhassa me sato dāni,"
    },
    {
      "id": "ja499:21.4",
      "pali": "maraṇaññeva ruccati”."
    },
    {
      "id": "ja499:22.1",
      "pali": "“Yāni saccāni dvipadinda,"
    },
    {
      "id": "ja499:22.2",
      "pali": "tāni bhāsassu khattiya;"
    },
    {
      "id": "ja499:22.3",
      "pali": "Saccaṁ te bhaṇamānassa,"
    },
    {
      "id": "ja499:22.4",
      "pali": "puna cakkhu bhavissati”."
    },
    {
      "id": "ja499:23.1",
      "pali": "“Ye maṁ yācitumāyanti,"
    },
    {
      "id": "ja499:23.2",
      "pali": "nānāgottā vanibbakā;"
    },
    {
      "id": "ja499:23.3",
      "pali": "Yopi maṁ yācate tattha,"
    },
    {
      "id": "ja499:23.4",
      "pali": "sopi me manaso piyo;"
    },
    {
      "id": "ja499:23.5",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja499:23.6",
      "pali": "cakkhu me upapajjatha."
    },
    {
      "id": "ja499:24.1",
      "pali": "Yaṁ maṁ so yācituṁ āgā,"
    },
    {
      "id": "ja499:24.2",
      "pali": "dehi cakkhunti brāhmaṇo;"
    },
    {
      "id": "ja499:24.3",
      "pali": "Tassa cakkhūni pādāsiṁ,"
    },
    {
      "id": "ja499:24.4",
      "pali": "brāhmaṇassa vanibbato."
    },
    {
      "id": "ja499:25.1",
      "pali": "Bhiyyo maṁ āvisī pīti,"
    },
    {
      "id": "ja499:25.2",
      "pali": "somanassañcanappakaṁ;"
    },
    {
      "id": "ja499:25.3",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja499:25.4",
      "pali": "dutiyaṁ me upapajjatha”."
    },
    {
      "id": "ja499:26.1",
      "pali": "“Dhammena bhāsitā gāthā,"
    },
    {
      "id": "ja499:26.2",
      "pali": "sivīnaṁ raṭṭhavaḍḍhana;"
    },
    {
      "id": "ja499:26.3",
      "pali": "Etāni tava nettāni,"
    },
    {
      "id": "ja499:26.4",
      "pali": "dibbāni paṭidissare."
    },
    {
      "id": "ja499:27.1",
      "pali": "Tirokuṭṭaṁ tiroselaṁ,"
    },
    {
      "id": "ja499:27.2",
      "pali": "samatiggayha pabbataṁ;"
    },
    {
      "id": "ja499:27.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "ja499:27.4",
      "pali": "dassanaṁ anubhontu te”."
    },
    {
      "id": "ja499:28.1",
      "pali": "“Ko nīdha vittaṁ na dadeyya yācito,"
    },
    {
      "id": "ja499:28.2",
      "pali": "Api visiṭṭhaṁ supiyampi attano;"
    },
    {
      "id": "ja499:28.3",
      "pali": "Tadiṅgha sabbe sivayo samāgatā,"
    },
    {
      "id": "ja499:28.4",
      "pali": "Dibbāni nettāni mamajja passatha."
    },
    {
      "id": "ja499:29.1",
      "pali": "Tirokuṭṭaṁ tiroselaṁ,"
    },
    {
      "id": "ja499:29.2",
      "pali": "samatiggayha pabbataṁ;"
    },
    {
      "id": "ja499:29.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "ja499:29.4",
      "pali": "dassanaṁ anubhonti me."
    },
    {
      "id": "ja499:30.1",
      "pali": "Na cāgamattā paramatthi kiñci,"
    },
    {
      "id": "ja499:30.2",
      "pali": "Maccānaṁ idha jīvite;"
    },
    {
      "id": "ja499:30.3",
      "pali": "Datvāna mānusaṁ cakkhuṁ,"
    },
    {
      "id": "ja499:30.4",
      "pali": "Laddhaṁ me cakkhuṁ amānusaṁ."
    },
    {
      "id": "ja499:31.1",
      "pali": "Etampi disvā sivayo,"
    },
    {
      "id": "ja499:31.2",
      "pali": "Detha dānāni bhuñjatha;"
    },
    {
      "id": "ja499:31.3",
      "pali": "Datvā ca bhutvā ca yathānubhāvaṁ,"
    },
    {
      "id": "ja499:31.4",
      "pali": "Aninditā saggamupetha ṭhānan”ti."
    },
    {
      "id": "ja499:32.1",
      "pali": "Sivijātakaṁ tatiyaṁ."
    }
  ]
}
