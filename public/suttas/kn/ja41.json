{
  "uid": "ja41",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja41:1.1",
      "pali": "“Yo atthakāmassa hitānukampino,"
    },
    {
      "id": "ja41:1.2",
      "pali": "Ovajjamāno na karoti sāsanaṁ;"
    },
    {
      "id": "ja41:1.3",
      "pali": "Ajiyā pādamolamba,"
    },
    {
      "id": "ja41:1.4",
      "pali": "Mittako viya socatī”ti."
    },
    {
      "id": "ja41:2.1",
      "pali": "Losakajātakaṁ paṭhamaṁ."
    }
  ]
}
