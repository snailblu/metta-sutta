{
  "uid": "thag15.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag15.2:1.1",
      "pali": "“Manussabhūtaṁ sambuddhaṁ,"
    },
    {
      "id": "thag15.2:1.2",
      "pali": "Attadantaṁ samāhitaṁ;"
    },
    {
      "id": "thag15.2:1.3",
      "pali": "Iriyamānaṁ brahmapathe,"
    },
    {
      "id": "thag15.2:1.4",
      "pali": "Cittassūpasame rataṁ."
    },
    {
      "id": "thag15.2:2.1",
      "pali": "Yaṁ manussā namassanti,"
    },
    {
      "id": "thag15.2:2.2",
      "pali": "sabbadhammāna pāraguṁ;"
    },
    {
      "id": "thag15.2:2.3",
      "pali": "Devāpi taṁ namassanti,"
    },
    {
      "id": "thag15.2:2.4",
      "pali": "iti me arahato sutaṁ."
    },
    {
      "id": "thag15.2:3.1",
      "pali": "Sabbasaṁyojanātītaṁ,"
    },
    {
      "id": "thag15.2:3.2",
      "pali": "vanā nibbanamāgataṁ;"
    },
    {
      "id": "thag15.2:3.3",
      "pali": "Kāmehi nekkhammarataṁ,"
    },
    {
      "id": "thag15.2:3.4",
      "pali": "muttaṁ selāva kañcanaṁ."
    },
    {
      "id": "thag15.2:4.1",
      "pali": "Sa ve accaruci nāgo,"
    },
    {
      "id": "thag15.2:4.2",
      "pali": "himavāvaññe siluccaye;"
    },
    {
      "id": "thag15.2:4.3",
      "pali": "Sabbesaṁ nāganāmānaṁ,"
    },
    {
      "id": "thag15.2:4.4",
      "pali": "saccanāmo anuttaro."
    },
    {
      "id": "thag15.2:5.1",
      "pali": "Nāgaṁ vo kittayissāmi,"
    },
    {
      "id": "thag15.2:5.2",
      "pali": "na hi āguṁ karoti so;"
    },
    {
      "id": "thag15.2:5.3",
      "pali": "Soraccaṁ avihiṁsā ca,"
    },
    {
      "id": "thag15.2:5.4",
      "pali": "pādā nāgassa te duve."
    },
    {
      "id": "thag15.2:6.1",
      "pali": "Sati ca sampajaññañca,"
    },
    {
      "id": "thag15.2:6.2",
      "pali": "caraṇā nāgassa tepare;"
    },
    {
      "id": "thag15.2:6.3",
      "pali": "Saddhāhattho mahānāgo,"
    },
    {
      "id": "thag15.2:6.4",
      "pali": "upekkhāsetadantavā."
    },
    {
      "id": "thag15.2:7.1",
      "pali": "Sati gīvā siro paññā,"
    },
    {
      "id": "thag15.2:7.2",
      "pali": "vīmaṁsā dhammacintanā;"
    },
    {
      "id": "thag15.2:7.3",
      "pali": "Dhammakucchisamāvāso,"
    },
    {
      "id": "thag15.2:7.4",
      "pali": "viveko tassa vāladhi."
    },
    {
      "id": "thag15.2:8.1",
      "pali": "So jhāyī assāsarato,"
    },
    {
      "id": "thag15.2:8.2",
      "pali": "ajjhattaṁ susamāhito;"
    },
    {
      "id": "thag15.2:8.3",
      "pali": "Gacchaṁ samāhito nāgo,"
    },
    {
      "id": "thag15.2:8.4",
      "pali": "ṭhito nāgo samāhito."
    },
    {
      "id": "thag15.2:9.1",
      "pali": "Sayaṁ samāhito nāgo,"
    },
    {
      "id": "thag15.2:9.2",
      "pali": "nisinnopi samāhito;"
    },
    {
      "id": "thag15.2:9.3",
      "pali": "Sabbattha saṁvuto nāgo,"
    },
    {
      "id": "thag15.2:9.4",
      "pali": "esā nāgassa sampadā."
    },
    {
      "id": "thag15.2:10.1",
      "pali": "Bhuñjati anavajjāni,"
    },
    {
      "id": "thag15.2:10.2",
      "pali": "sāvajjāni na bhuñjati;"
    },
    {
      "id": "thag15.2:10.3",
      "pali": "Ghāsamacchādanaṁ laddhā,"
    },
    {
      "id": "thag15.2:10.4",
      "pali": "sannidhiṁ parivajjayaṁ."
    },
    {
      "id": "thag15.2:11.1",
      "pali": "Saṁyojanaṁ aṇuṁ thūlaṁ,"
    },
    {
      "id": "thag15.2:11.2",
      "pali": "sabbaṁ chetvāna bandhanaṁ;"
    },
    {
      "id": "thag15.2:11.3",
      "pali": "Yena yeneva gacchati,"
    },
    {
      "id": "thag15.2:11.4",
      "pali": "anapekkhova gacchati."
    },
    {
      "id": "thag15.2:12.1",
      "pali": "Yathāpi udake jātaṁ,"
    },
    {
      "id": "thag15.2:12.2",
      "pali": "puṇḍarīkaṁ pavaḍḍhati;"
    },
    {
      "id": "thag15.2:12.3",
      "pali": "Nopalippati toyena,"
    },
    {
      "id": "thag15.2:12.4",
      "pali": "sucigandhaṁ manoramaṁ."
    },
    {
      "id": "thag15.2:13.1",
      "pali": "Tatheva ca loke jāto,"
    },
    {
      "id": "thag15.2:13.2",
      "pali": "buddho loke viharati;"
    },
    {
      "id": "thag15.2:13.3",
      "pali": "Nopalippati lokena,"
    },
    {
      "id": "thag15.2:13.4",
      "pali": "toyena padumaṁ yathā."
    },
    {
      "id": "thag15.2:14.1",
      "pali": "Mahāgini pajjalito,"
    },
    {
      "id": "thag15.2:14.2",
      "pali": "anāhāropasammati;"
    },
    {
      "id": "thag15.2:14.3",
      "pali": "Aṅgāresu ca santesu,"
    },
    {
      "id": "thag15.2:14.4",
      "pali": "nibbutoti pavuccati."
    },
    {
      "id": "thag15.2:15.1",
      "pali": "Atthassāyaṁ viññāpanī,"
    },
    {
      "id": "thag15.2:15.2",
      "pali": "upamā viññūhi desitā;"
    },
    {
      "id": "thag15.2:15.3",
      "pali": "Viññissanti mahānāgā,"
    },
    {
      "id": "thag15.2:15.4",
      "pali": "nāgaṁ nāgena desitaṁ."
    },
    {
      "id": "thag15.2:16.1",
      "pali": "Vītarāgo vītadoso,"
    },
    {
      "id": "thag15.2:16.2",
      "pali": "Vītamoho anāsavo;"
    },
    {
      "id": "thag15.2:16.3",
      "pali": "Sarīraṁ vijahaṁ nāgo,"
    },
    {
      "id": "thag15.2:16.4",
      "pali": "Parinibbissatyanāsavo”ti."
    },
    {
      "id": "thag15.2:16.5",
      "pali": "… Udāyī thero …"
    },
    {
      "id": "thag15.2:16.6",
      "pali": "Soḷasakanipāto niṭṭhito."
    },
    {
      "id": "thag15.2:17.1",
      "pali": "Koṇḍañño ca udāyī ca,"
    },
    {
      "id": "thag15.2:17.2",
      "pali": "therā dve te mahiddhikā;"
    },
    {
      "id": "thag15.2:17.3",
      "pali": "Soḷasamhi nipātamhi,"
    },
    {
      "id": "thag15.2:17.4",
      "pali": "gāthāyo dve ca tiṁsa cāti."
    }
  ]
}
