{
  "uid": "pv42",
  "title": "7. Rājaputtapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv42:1.1",
      "pali": "Pubbe katānaṁ kammānaṁ,"
    },
    {
      "id": "pv42:1.2",
      "pali": "vipāko mathaye manaṁ;"
    },
    {
      "id": "pv42:1.3",
      "pali": "Rūpe sadde rase gandhe,"
    },
    {
      "id": "pv42:1.4",
      "pali": "phoṭṭhabbe ca manorame."
    },
    {
      "id": "pv42:2.1",
      "pali": "Naccaṁ gītaṁ ratiṁ khiḍḍaṁ,"
    },
    {
      "id": "pv42:2.2",
      "pali": "anubhutvā anappakaṁ;"
    },
    {
      "id": "pv42:2.3",
      "pali": "Uyyāne paricaritvā,"
    },
    {
      "id": "pv42:2.4",
      "pali": "pavisanto giribbajaṁ."
    },
    {
      "id": "pv42:3.1",
      "pali": "Isiṁ sunetta maddakkhi,"
    },
    {
      "id": "pv42:3.2",
      "pali": "attadantaṁ samāhitaṁ;"
    },
    {
      "id": "pv42:3.3",
      "pali": "Appicchaṁ hirisampannaṁ,"
    },
    {
      "id": "pv42:3.4",
      "pali": "uñche pattagate rataṁ."
    },
    {
      "id": "pv42:4.1",
      "pali": "Hatthikkhandhato oruyha,"
    },
    {
      "id": "pv42:4.2",
      "pali": "laddhā bhanteti cābravi;"
    },
    {
      "id": "pv42:4.3",
      "pali": "Tassa pattaṁ gahetvāna,"
    },
    {
      "id": "pv42:4.4",
      "pali": "uccaṁ paggayha khattiyo."
    },
    {
      "id": "pv42:5.1",
      "pali": "Thaṇḍile pattaṁ bhinditvā,"
    },
    {
      "id": "pv42:5.2",
      "pali": "hasamāno apakkami;"
    },
    {
      "id": "pv42:5.3",
      "pali": "“Rañño kitavassāhaṁ putto,"
    },
    {
      "id": "pv42:5.4",
      "pali": "kiṁ maṁ bhikkhu karissasi”."
    },
    {
      "id": "pv42:6.1",
      "pali": "Tassa kammassa pharusassa,"
    },
    {
      "id": "pv42:6.2",
      "pali": "vipāko kaṭuko ahu;"
    },
    {
      "id": "pv42:6.3",
      "pali": "Yaṁ rājaputto vedesi,"
    },
    {
      "id": "pv42:6.4",
      "pali": "nirayamhi samappito."
    },
    {
      "id": "pv42:7.1",
      "pali": "Chaḷeva caturāsīti,"
    },
    {
      "id": "pv42:7.2",
      "pali": "vassāni navutāni ca;"
    },
    {
      "id": "pv42:7.3",
      "pali": "Bhusaṁ dukkhaṁ nigacchittho,"
    },
    {
      "id": "pv42:7.4",
      "pali": "niraye katakibbiso."
    },
    {
      "id": "pv42:8.1",
      "pali": "Uttānopi ca paccittha,"
    },
    {
      "id": "pv42:8.2",
      "pali": "nikujjo vāmadakkhiṇo;"
    },
    {
      "id": "pv42:8.3",
      "pali": "Uddhampādo ṭhito ceva,"
    },
    {
      "id": "pv42:8.4",
      "pali": "ciraṁ bālo apaccatha."
    },
    {
      "id": "pv42:9.1",
      "pali": "Bahūni vassasahassāni,"
    },
    {
      "id": "pv42:9.2",
      "pali": "pūgāni nahutāni ca;"
    },
    {
      "id": "pv42:9.3",
      "pali": "Bhusaṁ dukkhaṁ nigacchittho,"
    },
    {
      "id": "pv42:9.4",
      "pali": "niraye katakibbiso."
    },
    {
      "id": "pv42:10.1",
      "pali": "Etādisaṁ kho kaṭukaṁ,"
    },
    {
      "id": "pv42:10.2",
      "pali": "appaduṭṭhappadosinaṁ;"
    },
    {
      "id": "pv42:10.3",
      "pali": "Paccanti pāpakammantā,"
    },
    {
      "id": "pv42:10.4",
      "pali": "isimāsajja subbataṁ."
    },
    {
      "id": "pv42:11.1",
      "pali": "So tattha bahuvassāni,"
    },
    {
      "id": "pv42:11.2",
      "pali": "vedayitvā bahuṁ dukhaṁ;"
    },
    {
      "id": "pv42:11.3",
      "pali": "Khuppipāsahato nāma,"
    },
    {
      "id": "pv42:11.4",
      "pali": "peto āsi tato cuto."
    },
    {
      "id": "pv42:12.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "pv42:12.2",
      "pali": "issaramadasambhavaṁ;"
    },
    {
      "id": "pv42:12.3",
      "pali": "Pahāya issaramadaṁ,"
    },
    {
      "id": "pv42:12.4",
      "pali": "nivātamanuvattaye."
    },
    {
      "id": "pv42:13.1",
      "pali": "Diṭṭheva dhamme pāsaṁso,"
    },
    {
      "id": "pv42:13.2",
      "pali": "yo buddhesu sagāravo;"
    },
    {
      "id": "pv42:13.3",
      "pali": "Kāyassa bhedā sappañño,"
    },
    {
      "id": "pv42:13.4",
      "pali": "saggaṁ so upapajjatīti."
    },
    {
      "id": "pv42:14.1",
      "pali": "Rājaputtapetavatthu sattamaṁ."
    }
  ]
}
