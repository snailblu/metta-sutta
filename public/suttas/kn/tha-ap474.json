{
  "uid": "tha-ap474",
  "title": "Maṇipūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap474:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap474:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap474:1.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap474:1.4",
      "pali": "gacchate anilañjase."
    },
    {
      "id": "tha-ap474:2.1",
      "pali": "Avidūre himavantassa,"
    },
    {
      "id": "tha-ap474:2.2",
      "pali": "mahājātassaro ahu;"
    },
    {
      "id": "tha-ap474:2.3",
      "pali": "Tattha me bhavanaṁ āsi,"
    },
    {
      "id": "tha-ap474:2.4",
      "pali": "puññakammena saṁyutaṁ."
    },
    {
      "id": "tha-ap474:3.1",
      "pali": "Bhavanā abhinikkhamma,"
    },
    {
      "id": "tha-ap474:3.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap474:3.3",
      "pali": "Indīvaraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap474:3.4",
      "pali": "ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap474:4.1",
      "pali": "Vicinaṁ naddasaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap474:4.2",
      "pali": "pūjayissanti nāyakaṁ;"
    },
    {
      "id": "tha-ap474:4.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap474:4.4",
      "pali": "avandiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap474:5.1",
      "pali": "Mama sīse maṇiṁ gayha,"
    },
    {
      "id": "tha-ap474:5.2",
      "pali": "pūjayiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap474:5.3",
      "pali": "Imāya maṇipūjāya,"
    },
    {
      "id": "tha-ap474:5.4",
      "pali": "vipāko hotu bhaddako."
    },
    {
      "id": "tha-ap474:6.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap474:6.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap474:6.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap474:6.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap474:7.1",
      "pali": "‘So te ijjhatu saṅkappo,"
    },
    {
      "id": "tha-ap474:7.2",
      "pali": "labhassu vipulaṁ sukhaṁ;"
    },
    {
      "id": "tha-ap474:7.3",
      "pali": "Imāya maṇipūjāya,"
    },
    {
      "id": "tha-ap474:7.4",
      "pali": "anubhohi mahāyasaṁ’."
    },
    {
      "id": "tha-ap474:8.1",
      "pali": "Idaṁ vatvāna bhagavā,"
    },
    {
      "id": "tha-ap474:8.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap474:8.3",
      "pali": "Agamāsi buddhaseṭṭho,"
    },
    {
      "id": "tha-ap474:8.4",
      "pali": "yattha cittaṁ paṇīhitaṁ."
    },
    {
      "id": "tha-ap474:9.1",
      "pali": "Saṭṭhikappāni devindo,"
    },
    {
      "id": "tha-ap474:9.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap474:9.3",
      "pali": "Anekasatakkhattuñca,"
    },
    {
      "id": "tha-ap474:9.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap474:10.1",
      "pali": "Pubbakammaṁ sarantassa,"
    },
    {
      "id": "tha-ap474:10.2",
      "pali": "devabhūtassa me sato;"
    },
    {
      "id": "tha-ap474:10.3",
      "pali": "Maṇi nibbattate mayhaṁ,"
    },
    {
      "id": "tha-ap474:10.4",
      "pali": "ālokakaraṇo mamaṁ."
    },
    {
      "id": "tha-ap474:11.1",
      "pali": "Chaḷasītisahassāni,"
    },
    {
      "id": "tha-ap474:11.2",
      "pali": "nāriyo me pariggahā;"
    },
    {
      "id": "tha-ap474:11.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "tha-ap474:11.4",
      "pali": "āmukkamaṇikuṇḍalā."
    },
    {
      "id": "tha-ap474:12.1",
      "pali": "Aḷārapamhā hasulā,"
    },
    {
      "id": "tha-ap474:12.2",
      "pali": "susaññā tanumajjhimā;"
    },
    {
      "id": "tha-ap474:12.3",
      "pali": "Parivārenti maṁ niccaṁ,"
    },
    {
      "id": "tha-ap474:12.4",
      "pali": "maṇipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap474:13.1",
      "pali": "Soṇṇamayā maṇimayā,"
    },
    {
      "id": "tha-ap474:13.2",
      "pali": "lohitaṅgamayā tathā;"
    },
    {
      "id": "tha-ap474:13.3",
      "pali": "Bhaṇḍā me sukatā honti,"
    },
    {
      "id": "tha-ap474:13.4",
      "pali": "yadicchasi piḷandhanā."
    },
    {
      "id": "tha-ap474:14.1",
      "pali": "Kūṭāgārā gahārammā,"
    },
    {
      "id": "tha-ap474:14.2",
      "pali": "sayanañca mahārahaṁ;"
    },
    {
      "id": "tha-ap474:14.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap474:14.4",
      "pali": "nibbattanti yadicchakaṁ."
    },
    {
      "id": "tha-ap474:15.1",
      "pali": "Lābhā tesaṁ suladdhañca,"
    },
    {
      "id": "tha-ap474:15.2",
      "pali": "ye labhanti upassutiṁ;"
    },
    {
      "id": "tha-ap474:15.3",
      "pali": "Puññakkhettaṁ manussānaṁ,"
    },
    {
      "id": "tha-ap474:15.4",
      "pali": "osadhaṁ sabbapāṇinaṁ."
    },
    {
      "id": "tha-ap474:16.1",
      "pali": "Mayhampi sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap474:16.2",
      "pali": "yohaṁ adakkhi nāyakaṁ;"
    },
    {
      "id": "tha-ap474:16.3",
      "pali": "Vinipātā pamuttomhi,"
    },
    {
      "id": "tha-ap474:16.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap474:17.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap474:17.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap474:17.3",
      "pali": "Divasañceva rattiñca,"
    },
    {
      "id": "tha-ap474:17.4",
      "pali": "āloko hoti me sadā."
    },
    {
      "id": "tha-ap474:18.1",
      "pali": "Tāyeva maṇipūjāya,"
    },
    {
      "id": "tha-ap474:18.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap474:18.3",
      "pali": "Ñāṇāloko mayā diṭṭho,"
    },
    {
      "id": "tha-ap474:18.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap474:19.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap474:19.2",
      "pali": "yaṁ maṇiṁ abhipūjayiṁ;"
    },
    {
      "id": "tha-ap474:19.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap474:19.4",
      "pali": "maṇipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap474:20.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap474:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap474:20.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap474:21.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap474:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap474:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap474:22.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap474:22.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap474:22.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap474:23.1",
      "pali": "Itthaṁ sudaṁ āyasmā maṇipūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap474:24.1",
      "pali": "Maṇipūjakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
