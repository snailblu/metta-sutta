{
  "uid": "snp3.6",
  "title": "Sabhiyasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp3.6:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp3.6:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "snp3.6:1.3",
      "pali": "Tena kho pana samayena sabhiyassa paribbājakassa purāṇasālohitāya devatāya pañhā uddiṭṭhā honti:"
    },
    {
      "id": "snp3.6:1.4",
      "pali": "“yo te, sabhiya, samaṇo vā brāhmaṇo vā ime pañhe puṭṭho byākaroti tassa santike brahmacariyaṁ careyyāsī”ti."
    },
    {
      "id": "snp3.6:2.1",
      "pali": "Atha kho sabhiyo paribbājako tassā devatāya santike te pañhe uggahetvā ye te samaṇabrāhmaṇā saṅghino gaṇino gaṇācariyā ñātā yasassino titthakarā sādhusammatā bahujanassa, seyyathidaṁ—"
    },
    {
      "id": "snp3.6:2.2",
      "pali": "pūraṇo kassapo makkhaligosālo ajito kesakambalo pakudho kaccāno sañcayo belaṭṭhaputto nigaṇṭho nāṭaputto—"
    },
    {
      "id": "snp3.6:2.3",
      "pali": "te upasaṅkamitvā te pañhe pucchati."
    },
    {
      "id": "snp3.6:2.4",
      "pali": "Te sabhiyena paribbājakena pañhe puṭṭhā na sampāyanti;"
    },
    {
      "id": "snp3.6:2.5",
      "pali": "asampāyantā kopañca dosañca appaccayañca pātukaronti."
    },
    {
      "id": "snp3.6:2.6",
      "pali": "Api ca sabhiyaṁyeva paribbājakaṁ paṭipucchanti."
    },
    {
      "id": "snp3.6:3.1",
      "pali": "Atha kho sabhiyassa paribbājakassa etadahosi:"
    },
    {
      "id": "snp3.6:3.2",
      "pali": "“ye kho te bhonto samaṇabrāhmaṇā saṅghino gaṇino gaṇācariyā ñātā yasassino titthakarā sādhusammatā bahujanassa, seyyathidaṁ—"
    },
    {
      "id": "snp3.6:3.3",
      "pali": "pūraṇo kassapo …pe… nigaṇṭho nāṭaputto—"
    },
    {
      "id": "snp3.6:3.4",
      "pali": "te mayā pañhe puṭṭhā na sampāyanti,"
    },
    {
      "id": "snp3.6:3.5",
      "pali": "asampāyantā kopañca dosañca appaccayañca pātukaronti;"
    },
    {
      "id": "snp3.6:3.6",
      "pali": "api ca maññevettha paṭipucchanti."
    },
    {
      "id": "snp3.6:3.7",
      "pali": "Yannūnāhaṁ hīnāyāvattitvā kāme paribhuñjeyyan”ti."
    },
    {
      "id": "snp3.6:4.1",
      "pali": "Atha kho sabhiyassa paribbājakassa etadahosi:"
    },
    {
      "id": "snp3.6:4.2",
      "pali": "“ayampi kho samaṇo gotamo saṅghī ceva gaṇī ca gaṇācariyo ca ñāto yasassī titthakaro sādhusammato bahujanassa;"
    },
    {
      "id": "snp3.6:4.3",
      "pali": "yannūnāhaṁ samaṇaṁ gotamaṁ upasaṅkamitvā ime pañhe puccheyyan”ti."
    },
    {
      "id": "snp3.6:5.1",
      "pali": "Atha kho sabhiyassa paribbājakassa etadahosi:"
    },
    {
      "id": "snp3.6:5.2",
      "pali": "“yepi kho te bhonto samaṇabrāhmaṇā jiṇṇā vuḍḍhā mahallakā addhagatā vayoanuppattā therā rattaññū cirapabbajitā saṅghino gaṇino gaṇācariyā ñātā yasassino titthakarā sādhusammatā bahujanassa, seyyathidaṁ—"
    },
    {
      "id": "snp3.6:5.3",
      "pali": "pūraṇo kassapo …pe… nigaṇṭho nāṭaputto—"
    },
    {
      "id": "snp3.6:5.4",
      "pali": "tepi mayā pañhe puṭṭhā na sampāyanti,"
    },
    {
      "id": "snp3.6:5.5",
      "pali": "asampāyantā kopañca dosañca appaccayañca pātukaronti, api ca maññevettha paṭipucchanti;"
    },
    {
      "id": "snp3.6:5.6",
      "pali": "kiṁ pana me samaṇo gotamo ime pañhe puṭṭho byākarissati."
    },
    {
      "id": "snp3.6:5.7",
      "pali": "Samaṇo hi gotamo daharo ceva jātiyā, navo ca pabbajjāyā”ti."
    },
    {
      "id": "snp3.6:6.1",
      "pali": "Atha kho sabhiyassa paribbājakassa etadahosi:"
    },
    {
      "id": "snp3.6:6.2",
      "pali": "“samaṇo kho daharoti na uññātabbo na paribhotabbo."
    },
    {
      "id": "snp3.6:6.3",
      "pali": "Daharopi cesa samaṇo gotamo mahiddhiko hoti mahānubhāvo, yannūnāhaṁ samaṇaṁ gotamaṁ upasaṅkamitvā ime pañhe puccheyyan”ti."
    },
    {
      "id": "snp3.6:7.1",
      "pali": "Atha kho sabhiyo paribbājako yena rājagahaṁ tena cārikaṁ pakkāmi."
    },
    {
      "id": "snp3.6:7.2",
      "pali": "Anupubbena cārikaṁ caramāno yena rājagahaṁ veḷuvanaṁ kalandakanivāpo, yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "snp3.6:7.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi."
    },
    {
      "id": "snp3.6:7.4",
      "pali": "Ekamantaṁ nisinno kho sabhiyo paribbājako bhagavantaṁ gāthāya ajjhabhāsi—"
    },
    {
      "id": "snp3.6:8.1",
      "pali": "“Kaṅkhī vecikicchī āgamaṁ,"
    },
    {
      "id": "snp3.6:8.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:8.3",
      "pali": "Pañhe pucchituṁ abhikaṅkhamāno;"
    },
    {
      "id": "snp3.6:8.4",
      "pali": "Tesantakaro bhavāhi pañhe me puṭṭho,"
    },
    {
      "id": "snp3.6:8.5",
      "pali": "Anupubbaṁ anudhammaṁ byākarohi me”."
    },
    {
      "id": "snp3.6:9.1",
      "pali": "“Dūrato āgatosi sabhiya,"
    },
    {
      "id": "snp3.6:9.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp3.6:9.3",
      "pali": "Pañhe pucchituṁ abhikaṅkhamāno;"
    },
    {
      "id": "snp3.6:9.4",
      "pali": "Tesantakaro bhavāmi pañhe te puṭṭho,"
    },
    {
      "id": "snp3.6:9.5",
      "pali": "Anupubbaṁ anudhammaṁ byākaromi te."
    },
    {
      "id": "snp3.6:10.1",
      "pali": "Puccha maṁ sabhiya pañhaṁ,"
    },
    {
      "id": "snp3.6:10.2",
      "pali": "Yaṁ kiñci manasicchasi;"
    },
    {
      "id": "snp3.6:10.3",
      "pali": "Tassa tasseva pañhassa,"
    },
    {
      "id": "snp3.6:10.4",
      "pali": "Ahaṁ antaṁ karomi te”ti."
    },
    {
      "id": "snp3.6:11.1",
      "pali": "Atha kho sabhiyassa paribbājakassa etadahosi:"
    },
    {
      "id": "snp3.6:11.2",
      "pali": "“acchariyaṁ vata bho, abbhutaṁ vata bho."
    },
    {
      "id": "snp3.6:11.3",
      "pali": "Yaṁ vatāhaṁ aññesu samaṇabrāhmaṇesu okāsakammamattampi nālatthaṁ taṁ me idaṁ samaṇena gotamena okāsakammaṁ katan”ti."
    },
    {
      "id": "snp3.6:11.4",
      "pali": "Attamano pamudito udaggo pītisomanassajāto bhagavantaṁ pañhaṁ apucchi—"
    },
    {
      "id": "snp3.6:12.1",
      "pali": "“Kiṁpattinamāhu bhikkhunaṁ,"
    },
    {
      "id": "snp3.6:12.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:12.3",
      "pali": "Sorataṁ kena kathañca dantamāhu;"
    },
    {
      "id": "snp3.6:12.4",
      "pali": "Buddhoti kathaṁ pavuccati,"
    },
    {
      "id": "snp3.6:12.5",
      "pali": "Puṭṭho me bhagavā byākarohi”."
    },
    {
      "id": "snp3.6:13.1",
      "pali": "“Pajjena katena attanā,"
    },
    {
      "id": "snp3.6:13.2",
      "pali": "(sabhiyāti bhagavā)"
    },
    {
      "id": "snp3.6:13.3",
      "pali": "Parinibbānagato vitiṇṇakaṅkho;"
    },
    {
      "id": "snp3.6:13.4",
      "pali": "Vibhavañca bhavañca vippahāya,"
    },
    {
      "id": "snp3.6:13.5",
      "pali": "Vusitavā khīṇapunabbhavo sa bhikkhu."
    },
    {
      "id": "snp3.6:14.1",
      "pali": "Sabbattha upekkhako satimā,"
    },
    {
      "id": "snp3.6:14.2",
      "pali": "Na so hiṁsati kañci sabbaloke;"
    },
    {
      "id": "snp3.6:14.3",
      "pali": "Tiṇṇo samaṇo anāvilo,"
    },
    {
      "id": "snp3.6:14.4",
      "pali": "Ussadā yassa na santi sorato so."
    },
    {
      "id": "snp3.6:15.1",
      "pali": "Yassindriyāni bhāvitāni,"
    },
    {
      "id": "snp3.6:15.2",
      "pali": "Ajjhattaṁ bahiddhā ca sabbaloke;"
    },
    {
      "id": "snp3.6:15.3",
      "pali": "Nibbijjha imaṁ parañca lokaṁ,"
    },
    {
      "id": "snp3.6:15.4",
      "pali": "Kālaṁ kaṅkhati bhāvito sa danto."
    },
    {
      "id": "snp3.6:16.1",
      "pali": "Kappāni viceyya kevalāni,"
    },
    {
      "id": "snp3.6:16.2",
      "pali": "Saṁsāraṁ dubhayaṁ cutūpapātaṁ;"
    },
    {
      "id": "snp3.6:16.3",
      "pali": "Vigatarajamanaṅgaṇaṁ visuddhaṁ,"
    },
    {
      "id": "snp3.6:16.4",
      "pali": "Pattaṁ jātikhayaṁ tamāhu buddhan”ti."
    },
    {
      "id": "snp3.6:17.1",
      "pali": "Atha kho sabhiyo paribbājako bhagavato bhāsitaṁ abhinanditvā anumoditvā attamano pamudito udaggo pītisomanassajāto bhagavantaṁ uttariṁ pañhaṁ apucchi—"
    },
    {
      "id": "snp3.6:18.1",
      "pali": "“Kiṁpattinamāhu brāhmaṇaṁ,"
    },
    {
      "id": "snp3.6:18.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:18.3",
      "pali": "Samaṇaṁ kena kathañca nhātakoti;"
    },
    {
      "id": "snp3.6:18.4",
      "pali": "Nāgoti kathaṁ pavuccati,"
    },
    {
      "id": "snp3.6:18.5",
      "pali": "Puṭṭho me bhagavā byākarohi”."
    },
    {
      "id": "snp3.6:19.1",
      "pali": "“Bāhitvā sabbapāpakāni,"
    },
    {
      "id": "snp3.6:19.2",
      "pali": "(sabhiyāti bhagavā)"
    },
    {
      "id": "snp3.6:19.3",
      "pali": "Vimalo sādhusamāhito ṭhitatto;"
    },
    {
      "id": "snp3.6:19.4",
      "pali": "Saṁsāramaticca kevalī so,"
    },
    {
      "id": "snp3.6:19.5",
      "pali": "Asito tādi pavuccate sa brahmā."
    },
    {
      "id": "snp3.6:20.1",
      "pali": "Samitāvi pahāya puññapāpaṁ,"
    },
    {
      "id": "snp3.6:20.2",
      "pali": "Virajo ñatvā imaṁ parañca lokaṁ;"
    },
    {
      "id": "snp3.6:20.3",
      "pali": "Jātimaraṇaṁ upātivatto,"
    },
    {
      "id": "snp3.6:20.4",
      "pali": "Samaṇo tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:21.1",
      "pali": "Ninhāya sabbapāpakāni,"
    },
    {
      "id": "snp3.6:21.2",
      "pali": "Ajjhattaṁ bahiddhā ca sabbaloke;"
    },
    {
      "id": "snp3.6:21.3",
      "pali": "Devamanussesu kappiyesu,"
    },
    {
      "id": "snp3.6:21.4",
      "pali": "Kappaṁ neti tamāhu nhātakoti."
    },
    {
      "id": "snp3.6:22.1",
      "pali": "Āguṁ na karoti kiñci loke,"
    },
    {
      "id": "snp3.6:22.2",
      "pali": "Sabbasaṁyoge visajja bandhanāni;"
    },
    {
      "id": "snp3.6:22.3",
      "pali": "Sabbattha na sajjatī vimutto,"
    },
    {
      "id": "snp3.6:22.4",
      "pali": "Nāgo tādi pavuccate tathattā”ti."
    },
    {
      "id": "snp3.6:23.1",
      "pali": "Atha kho sabhiyo paribbājako …pe… bhagavantaṁ uttariṁ pañhaṁ apucchi—"
    },
    {
      "id": "snp3.6:24.1",
      "pali": "“Kaṁ khettajinaṁ vadanti buddhā,"
    },
    {
      "id": "snp3.6:24.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:24.3",
      "pali": "Kusalaṁ kena kathañca paṇḍitoti;"
    },
    {
      "id": "snp3.6:24.4",
      "pali": "Muni nāma kathaṁ pavuccati,"
    },
    {
      "id": "snp3.6:24.5",
      "pali": "Puṭṭho me bhagavā byākarohi”."
    },
    {
      "id": "snp3.6:25.1",
      "pali": "“Khettāni viceyya kevalāni,"
    },
    {
      "id": "snp3.6:25.2",
      "pali": "(sabhiyāti bhagavā)"
    },
    {
      "id": "snp3.6:25.3",
      "pali": "Dibbaṁ mānusakañca brahmakhettaṁ;"
    },
    {
      "id": "snp3.6:25.4",
      "pali": "Sabbakhettamūlabandhanā pamutto,"
    },
    {
      "id": "snp3.6:25.5",
      "pali": "Khettajino tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:26.1",
      "pali": "Kosāni viceyya kevalāni,"
    },
    {
      "id": "snp3.6:26.2",
      "pali": "Dibbaṁ mānusakañca brahmakosaṁ;"
    },
    {
      "id": "snp3.6:26.3",
      "pali": "Sabbakosamūlabandhanā pamutto,"
    },
    {
      "id": "snp3.6:26.4",
      "pali": "Kusalo tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:27.1",
      "pali": "Dubhayāni viceyya paṇḍarāni,"
    },
    {
      "id": "snp3.6:27.2",
      "pali": "Ajjhattaṁ bahiddhā ca suddhipañño;"
    },
    {
      "id": "snp3.6:27.3",
      "pali": "Kaṇhaṁ sukkaṁ upātivatto,"
    },
    {
      "id": "snp3.6:27.4",
      "pali": "Paṇḍito tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:28.1",
      "pali": "Asatañca satañca ñatvā dhammaṁ,"
    },
    {
      "id": "snp3.6:28.2",
      "pali": "Ajjhattaṁ bahiddhā ca sabbaloke;"
    },
    {
      "id": "snp3.6:28.3",
      "pali": "Devamanussehi pūjanīyo,"
    },
    {
      "id": "snp3.6:28.4",
      "pali": "Saṅgaṁ jālamaticca so munī”ti."
    },
    {
      "id": "snp3.6:29.1",
      "pali": "Atha kho sabhiyo paribbājako …pe… bhagavantaṁ uttariṁ pañhaṁ apucchi—"
    },
    {
      "id": "snp3.6:30.1",
      "pali": "“Kiṁpattinamāhu vedaguṁ,"
    },
    {
      "id": "snp3.6:30.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:30.3",
      "pali": "Anuviditaṁ kena kathañca viriyavāti;"
    },
    {
      "id": "snp3.6:30.4",
      "pali": "Ājāniyo kinti nāma hoti,"
    },
    {
      "id": "snp3.6:30.5",
      "pali": "Puṭṭho me bhagavā byākarohi”."
    },
    {
      "id": "snp3.6:31.1",
      "pali": "“Vedāni viceyya kevalāni,"
    },
    {
      "id": "snp3.6:31.2",
      "pali": "(sabhiyāti bhagavā)"
    },
    {
      "id": "snp3.6:31.3",
      "pali": "Samaṇānaṁ yānidhatthi brāhmaṇānaṁ;"
    },
    {
      "id": "snp3.6:31.4",
      "pali": "Sabbavedanāsu vītarāgo,"
    },
    {
      "id": "snp3.6:31.5",
      "pali": "Sabbaṁ vedamaticca vedagū so."
    },
    {
      "id": "snp3.6:32.1",
      "pali": "Anuvicca papañcanāmarūpaṁ,"
    },
    {
      "id": "snp3.6:32.2",
      "pali": "Ajjhattaṁ bahiddhā ca rogamūlaṁ;"
    },
    {
      "id": "snp3.6:32.3",
      "pali": "Sabbarogamūlabandhanā pamutto,"
    },
    {
      "id": "snp3.6:32.4",
      "pali": "Anuvidito tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:33.1",
      "pali": "Virato idha sabbapāpakehi,"
    },
    {
      "id": "snp3.6:33.2",
      "pali": "Nirayadukkhaṁ aticca viriyavāso;"
    },
    {
      "id": "snp3.6:33.3",
      "pali": "So vīriyavā padhānavā,"
    },
    {
      "id": "snp3.6:33.4",
      "pali": "Dhīro tādi pavuccate tathattā."
    },
    {
      "id": "snp3.6:34.1",
      "pali": "Yassassu lunāni bandhanāni,"
    },
    {
      "id": "snp3.6:34.2",
      "pali": "Ajjhattaṁ bahiddhā ca saṅgamūlaṁ;"
    },
    {
      "id": "snp3.6:34.3",
      "pali": "Sabbasaṅgamūlabandhanā pamutto,"
    },
    {
      "id": "snp3.6:34.4",
      "pali": "Ājāniyo tādi pavuccate tathattā”ti."
    },
    {
      "id": "snp3.6:35.1",
      "pali": "Atha kho sabhiyo paribbājako …pe… bhagavantaṁ uttariṁ pañhaṁ apucchi—"
    },
    {
      "id": "snp3.6:36.1",
      "pali": "“Kiṁpattinamāhu sottiyaṁ,"
    },
    {
      "id": "snp3.6:36.2",
      "pali": "(iti sabhiyo)"
    },
    {
      "id": "snp3.6:36.3",
      "pali": "Ariyaṁ kena kathañca caraṇavāti;"
    },
    {
      "id": "snp3.6:36.4",
      "pali": "Paribbājako kinti nāma hoti,"
    },
    {
      "id": "snp3.6:36.5",
      "pali": "Puṭṭho me bhagavā byākarohi”."
    },
    {
      "id": "snp3.6:37.1",
      "pali": "“Sutvā sabbadhammaṁ abhiññāya loke,"
    },
    {
      "id": "snp3.6:37.2",
      "pali": "(sabhiyāti bhagavā)"
    },
    {
      "id": "snp3.6:37.3",
      "pali": "Sāvajjānavajjaṁ yadatthi kiñci;"
    },
    {
      "id": "snp3.6:37.4",
      "pali": "Abhibhuṁ akathaṅkathiṁ vimuttaṁ,"
    },
    {
      "id": "snp3.6:37.5",
      "pali": "Anighaṁ sabbadhimāhu sottiyoti."
    },
    {
      "id": "snp3.6:38.1",
      "pali": "Chetvā āsavāni ālayāni,"
    },
    {
      "id": "snp3.6:38.2",
      "pali": "Vidvā so na upeti gabbhaseyyaṁ;"
    },
    {
      "id": "snp3.6:38.3",
      "pali": "Saññaṁ tividhaṁ panujja paṅkaṁ,"
    },
    {
      "id": "snp3.6:38.4",
      "pali": "Kappaṁ neti tamāhu ariyoti."
    },
    {
      "id": "snp3.6:39.1",
      "pali": "Yo idha caraṇesu pattipatto,"
    },
    {
      "id": "snp3.6:39.2",
      "pali": "Kusalo sabbadā ājānāti dhammaṁ;"
    },
    {
      "id": "snp3.6:39.3",
      "pali": "Sabbattha na sajjati vimuttacitto,"
    },
    {
      "id": "snp3.6:39.4",
      "pali": "Paṭighā yassa na santi caraṇavā so."
    },
    {
      "id": "snp3.6:40.1",
      "pali": "Dukkhavepakkaṁ yadatthi kammaṁ,"
    },
    {
      "id": "snp3.6:40.2",
      "pali": "Uddhamadho tiriyaṁ vāpi majjhe;"
    },
    {
      "id": "snp3.6:40.3",
      "pali": "Paribbājayitvā pariññacārī,"
    },
    {
      "id": "snp3.6:40.4",
      "pali": "Māyaṁ mānamathopi lobhakodhaṁ;"
    },
    {
      "id": "snp3.6:40.5",
      "pali": "Pariyantamakāsi nāmarūpaṁ,"
    },
    {
      "id": "snp3.6:40.6",
      "pali": "Taṁ paribbājakamāhu pattipattan”ti."
    },
    {
      "id": "snp3.6:41.1",
      "pali": "Atha kho sabhiyo paribbājako bhagavato bhāsitaṁ abhinanditvā anumoditvā attamano pamudito udaggo pītisomanassajāto uṭṭhāyāsanā ekaṁsaṁ uttarāsaṅgaṁ karitvā yena bhagavā tenañjaliṁ paṇāmetvā bhagavantaṁ sammukhā sāruppāhi gāthāhi abhitthavi:"
    },
    {
      "id": "snp3.6:42.1",
      "pali": "“Yāni ca tīṇi yāni ca saṭṭhi,"
    },
    {
      "id": "snp3.6:42.2",
      "pali": "Samaṇappavādasitāni bhūripañña;"
    },
    {
      "id": "snp3.6:42.3",
      "pali": "Saññakkharasaññanissitāni,"
    },
    {
      "id": "snp3.6:42.4",
      "pali": "Osaraṇāni vineyya oghatamagā."
    },
    {
      "id": "snp3.6:43.1",
      "pali": "Antagūsi pāragū dukkhassa,"
    },
    {
      "id": "snp3.6:43.2",
      "pali": "Arahāsi sammāsambuddho khīṇāsavaṁ taṁ maññe;"
    },
    {
      "id": "snp3.6:43.3",
      "pali": "Jutimā mutimā pahūtapañño,"
    },
    {
      "id": "snp3.6:43.4",
      "pali": "Dukkhassantakara atāresi maṁ."
    },
    {
      "id": "snp3.6:44.1",
      "pali": "Yaṁ me kaṅkhitamaññāsi,"
    },
    {
      "id": "snp3.6:44.2",
      "pali": "Vicikicchā maṁ tārayi namo te;"
    },
    {
      "id": "snp3.6:44.3",
      "pali": "Muni monapathesu pattipatta,"
    },
    {
      "id": "snp3.6:44.4",
      "pali": "Akhila ādiccabandhu soratosi."
    },
    {
      "id": "snp3.6:45.1",
      "pali": "Yā me kaṅkhā pure āsi,"
    },
    {
      "id": "snp3.6:45.2",
      "pali": "Taṁ me byākāsi cakkhumā;"
    },
    {
      "id": "snp3.6:45.3",
      "pali": "Addhā munīsi sambuddho,"
    },
    {
      "id": "snp3.6:45.4",
      "pali": "Natthi nīvaraṇā tava."
    },
    {
      "id": "snp3.6:46.1",
      "pali": "Upāyāsā ca te sabbe,"
    },
    {
      "id": "snp3.6:46.2",
      "pali": "Viddhastā vinaḷīkatā;"
    },
    {
      "id": "snp3.6:46.3",
      "pali": "Sītibhūto damappatto,"
    },
    {
      "id": "snp3.6:46.4",
      "pali": "Dhitimā saccanikkamo."
    },
    {
      "id": "snp3.6:47.1",
      "pali": "Tassa te nāganāgassa,"
    },
    {
      "id": "snp3.6:47.2",
      "pali": "Mahāvīrassa bhāsato;"
    },
    {
      "id": "snp3.6:47.3",
      "pali": "Sabbe devānumodanti,"
    },
    {
      "id": "snp3.6:47.4",
      "pali": "Ubho nāradapabbatā."
    },
    {
      "id": "snp3.6:48.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "snp3.6:48.2",
      "pali": "Namo te purisuttama;"
    },
    {
      "id": "snp3.6:48.3",
      "pali": "Sadevakasmiṁ lokasmiṁ,"
    },
    {
      "id": "snp3.6:48.4",
      "pali": "Natthi te paṭipuggalo."
    },
    {
      "id": "snp3.6:49.1",
      "pali": "Tuvaṁ buddho tuvaṁ satthā,"
    },
    {
      "id": "snp3.6:49.2",
      "pali": "Tuvaṁ mārābhibhū muni;"
    },
    {
      "id": "snp3.6:49.3",
      "pali": "Tuvaṁ anusaye chetvā,"
    },
    {
      "id": "snp3.6:49.4",
      "pali": "Tiṇṇo tāresimaṁ pajaṁ."
    },
    {
      "id": "snp3.6:50.1",
      "pali": "Upadhī te samatikkantā,"
    },
    {
      "id": "snp3.6:50.2",
      "pali": "Āsavā te padālitā;"
    },
    {
      "id": "snp3.6:50.3",
      "pali": "Sīhosi anupādāno,"
    },
    {
      "id": "snp3.6:50.4",
      "pali": "Pahīnabhayabheravo."
    },
    {
      "id": "snp3.6:51.1",
      "pali": "Puṇḍarīkaṁ yathā vaggu,"
    },
    {
      "id": "snp3.6:51.2",
      "pali": "Toye na upalimpati;"
    },
    {
      "id": "snp3.6:51.3",
      "pali": "Evaṁ puññe ca pāpe ca,"
    },
    {
      "id": "snp3.6:51.4",
      "pali": "Ubhaye tvaṁ na limpasi;"
    },
    {
      "id": "snp3.6:51.5",
      "pali": "Pāde vīra pasārehi,"
    },
    {
      "id": "snp3.6:51.6",
      "pali": "Sabhiyo vandati satthuno”ti."
    },
    {
      "id": "snp3.6:52.1",
      "pali": "Atha kho sabhiyo paribbājako bhagavato pādesu sirasā nipatitvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.6:52.2",
      "pali": "“abhikkantaṁ, bhante …pe…"
    },
    {
      "id": "snp3.6:52.3",
      "pali": "esāhaṁ bhagavantaṁ saraṇaṁ gacchāmi dhammañca bhikkhusaṅghañca;"
    },
    {
      "id": "snp3.6:52.4",
      "pali": "labheyyāhaṁ, bhante, bhagavato santike pabbajjaṁ, labheyyaṁ upasampadan”ti."
    },
    {
      "id": "snp3.6:53.1",
      "pali": "“Yo kho, sabhiya, aññatitthiyapubbo imasmiṁ dhammavinaye ākaṅkhati pabbajjaṁ, ākaṅkhati upasampadaṁ, so cattāro māse parivasati; catunnaṁ māsānaṁ accayena āraddhacittā bhikkhū pabbājenti, upasampādenti bhikkhubhāvāya."
    },
    {
      "id": "snp3.6:53.2",
      "pali": "Api ca mettha puggalavemattatā viditā”ti."
    },
    {
      "id": "snp3.6:54.1",
      "pali": "“Sace, bhante, aññatitthiyapubbā imasmiṁ dhammavinaye ākaṅkhantā pabbajjaṁ, ākaṅkhantā upasampadaṁ cattāro māse parivasanti, catunnaṁ māsānaṁ accayena āraddhacittā bhikkhū pabbājenti, upasampādenti bhikkhubhāvāya, ahaṁ cattāri vassāni parivasissāmi; catunnaṁ vassānaṁ accayena āraddhacittā bhikkhū pabbājentu upasampādentu bhikkhubhāvāyā”ti."
    },
    {
      "id": "snp3.6:54.2",
      "pali": "Alattha kho sabhiyo paribbājako bhagavato santike pabbajjaṁ alattha upasampadaṁ …pe…"
    },
    {
      "id": "snp3.6:54.3",
      "pali": "aññataro kho panāyasmā sabhiyo arahataṁ ahosīti."
    },
    {
      "id": "snp3.6:54.4",
      "pali": "Sabhiyasuttaṁ chaṭṭhaṁ."
    }
  ]
}
