{
  "uid": "ja319",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja319:1.1",
      "pali": "“Susukhaṁ vata jīvāmi,"
    },
    {
      "id": "ja319:1.2",
      "pali": "labhāmi ceva bhuñjituṁ;"
    },
    {
      "id": "ja319:1.3",
      "pali": "Paripanthe ca tiṭṭhāmi,"
    },
    {
      "id": "ja319:1.4",
      "pali": "kā nu bhante gatī mama”."
    },
    {
      "id": "ja319:2.1",
      "pali": "“Mano ce te nappaṇamati,"
    },
    {
      "id": "ja319:2.2",
      "pali": "pakkhi pāpassa kammuno;"
    },
    {
      "id": "ja319:2.3",
      "pali": "Abyāvaṭassa bhadrassa,"
    },
    {
      "id": "ja319:2.4",
      "pali": "na pāpamupalimpati”."
    },
    {
      "id": "ja319:3.1",
      "pali": "“Ñātako no nisinnoti,"
    },
    {
      "id": "ja319:3.2",
      "pali": "bahu āgacchate jano;"
    },
    {
      "id": "ja319:3.3",
      "pali": "Paṭicca kammaṁ phusati,"
    },
    {
      "id": "ja319:3.4",
      "pali": "tasmiṁ me saṅkate mano”."
    },
    {
      "id": "ja319:4.1",
      "pali": "“Na paṭicca kammaṁ phusati,"
    },
    {
      "id": "ja319:4.2",
      "pali": "mano ce nappadussati;"
    },
    {
      "id": "ja319:4.3",
      "pali": "Appossukkassa bhadrassa,"
    },
    {
      "id": "ja319:4.4",
      "pali": "na pāpamupalimpatī”ti."
    },
    {
      "id": "ja319:5.1",
      "pali": "Tittirajātakaṁ navamaṁ."
    }
  ]
}
