{
  "uid": "thag1.57",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.57:1.1",
      "pali": "“Ayamāhu purāṇiyā kuṭi,"
    },
    {
      "id": "thag1.57:1.2",
      "pali": "Aññaṁ patthayase navaṁ kuṭiṁ;"
    },
    {
      "id": "thag1.57:1.3",
      "pali": "Āsaṁ kuṭiyā virājaya,"
    },
    {
      "id": "thag1.57:1.4",
      "pali": "Dukkhā bhikkhu puna navā kuṭī”ti."
    },
    {
      "id": "thag1.57:1.5",
      "pali": "… Dutiyakuṭivihāritthero …."
    }
  ]
}
