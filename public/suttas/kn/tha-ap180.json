{
  "uid": "tha-ap180",
  "title": "Maṇipūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap180:1.1",
      "pali": "“Orena himavantassa,"
    },
    {
      "id": "tha-ap180:1.2",
      "pali": "nadikā sampavattatha;"
    },
    {
      "id": "tha-ap180:1.3",
      "pali": "Tassā cānupakhettamhi,"
    },
    {
      "id": "tha-ap180:1.4",
      "pali": "sayambhū vasate tadā."
    },
    {
      "id": "tha-ap180:2.1",
      "pali": "Maṇiṁ paggayha pallaṅkaṁ,"
    },
    {
      "id": "tha-ap180:2.2",
      "pali": "sādhucittaṁ manoramaṁ;"
    },
    {
      "id": "tha-ap180:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap180:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap180:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap180:3.2",
      "pali": "yaṁ maṇiṁ abhiropayiṁ;"
    },
    {
      "id": "tha-ap180:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap180:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap180:4.1",
      "pali": "Ito ca dvādase kappe,"
    },
    {
      "id": "tha-ap180:4.2",
      "pali": "sataraṁsīsanāmakā;"
    },
    {
      "id": "tha-ap180:4.3",
      "pali": "Aṭṭha te āsuṁ rājāno,"
    },
    {
      "id": "tha-ap180:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap180:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap180:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap180:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap180:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā maṇipūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap180:7.1",
      "pali": "Maṇipūjakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
