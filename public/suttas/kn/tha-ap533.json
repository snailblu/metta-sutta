{
  "uid": "tha-ap533",
  "title": "1 Mahākaccāyanattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap533:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap533:1.2",
      "pali": "anejo ajitaṁ jayo;"
    },
    {
      "id": "tha-ap533:1.3",
      "pali": "Satasahasse kappānaṁ,"
    },
    {
      "id": "tha-ap533:1.4",
      "pali": "ito uppajji nāyako."
    },
    {
      "id": "tha-ap533:2.1",
      "pali": "Vīro kamalapattakkho,"
    },
    {
      "id": "tha-ap533:2.2",
      "pali": "sasaṅkavimalānano;"
    },
    {
      "id": "tha-ap533:2.3",
      "pali": "Kanakācalasaṅkāso,"
    },
    {
      "id": "tha-ap533:2.4",
      "pali": "ravidittisamappabho."
    },
    {
      "id": "tha-ap533:3.1",
      "pali": "Sattanettamanohārī,"
    },
    {
      "id": "tha-ap533:3.2",
      "pali": "varalakkhaṇabhūsito;"
    },
    {
      "id": "tha-ap533:3.3",
      "pali": "Sabbavākyapathātīto,"
    },
    {
      "id": "tha-ap533:3.4",
      "pali": "manujāmarasakkato."
    },
    {
      "id": "tha-ap533:4.1",
      "pali": "Sambuddho bodhayaṁ satte,"
    },
    {
      "id": "tha-ap533:4.2",
      "pali": "vāgīso madhurassaro;"
    },
    {
      "id": "tha-ap533:4.3",
      "pali": "Karuṇānibandhasantāno,"
    },
    {
      "id": "tha-ap533:4.4",
      "pali": "parisāsu visārado."
    },
    {
      "id": "tha-ap533:5.1",
      "pali": "Deseti madhuraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap533:5.2",
      "pali": "catusaccūpasaṁhitaṁ;"
    },
    {
      "id": "tha-ap533:5.3",
      "pali": "Nimugge mohapaṅkamhi,"
    },
    {
      "id": "tha-ap533:5.4",
      "pali": "samuddharati pāṇine."
    },
    {
      "id": "tha-ap533:6.1",
      "pali": "Tadā ekacaro hutvā,"
    },
    {
      "id": "tha-ap533:6.2",
      "pali": "tāpaso himavālayo;"
    },
    {
      "id": "tha-ap533:6.3",
      "pali": "Nabhasā mānusaṁ lokaṁ,"
    },
    {
      "id": "tha-ap533:6.4",
      "pali": "gacchanto jinamaddasaṁ."
    },
    {
      "id": "tha-ap533:7.1",
      "pali": "Upecca santikaṁ tassa,"
    },
    {
      "id": "tha-ap533:7.2",
      "pali": "assosiṁ dhammadesanaṁ;"
    },
    {
      "id": "tha-ap533:7.3",
      "pali": "Vaṇṇayantassa vīrassa,"
    },
    {
      "id": "tha-ap533:7.4",
      "pali": "sāvakassa mahāguṇaṁ."
    },
    {
      "id": "tha-ap533:8.1",
      "pali": "‘Saṅkhittena mayā vuttaṁ,"
    },
    {
      "id": "tha-ap533:8.2",
      "pali": "vitthārena pakāsayaṁ;"
    },
    {
      "id": "tha-ap533:8.3",
      "pali": "Parisaṁ mañca toseti,"
    },
    {
      "id": "tha-ap533:8.4",
      "pali": "yathā kaccāyano ayaṁ."
    },
    {
      "id": "tha-ap533:9.1",
      "pali": "Nāhaṁ evamidhekaccaṁ,"
    },
    {
      "id": "tha-ap533:9.2",
      "pali": "aññaṁ passāmi sāvakaṁ;"
    },
    {
      "id": "tha-ap533:9.3",
      "pali": "Tasmātadagge esaggo,"
    },
    {
      "id": "tha-ap533:9.4",
      "pali": "evaṁ dhāretha bhikkhavo’."
    },
    {
      "id": "tha-ap533:10.1",
      "pali": "Tadāhaṁ vimhito hutvā,"
    },
    {
      "id": "tha-ap533:10.2",
      "pali": "sutvā vākyaṁ manoramaṁ;"
    },
    {
      "id": "tha-ap533:10.3",
      "pali": "Himavantaṁ gamitvāna,"
    },
    {
      "id": "tha-ap533:10.4",
      "pali": "āhitvā pupphasañcayaṁ."
    },
    {
      "id": "tha-ap533:11.1",
      "pali": "Pūjetvā lokasaraṇaṁ,"
    },
    {
      "id": "tha-ap533:11.2",
      "pali": "taṁ ṭhānamabhipatthayiṁ;"
    },
    {
      "id": "tha-ap533:11.3",
      "pali": "Tadā mamāsayaṁ ñatvā,"
    },
    {
      "id": "tha-ap533:11.4",
      "pali": "byākāsi sa raṇañjaho."
    },
    {
      "id": "tha-ap533:12.1",
      "pali": "‘Passathetaṁ isivaraṁ,"
    },
    {
      "id": "tha-ap533:12.2",
      "pali": "niddhantakanakattacaṁ;"
    },
    {
      "id": "tha-ap533:12.3",
      "pali": "Uddhaggalomaṁ pīṇaṁsaṁ,"
    },
    {
      "id": "tha-ap533:12.4",
      "pali": "acalaṁ pañjaliṁ ṭhitaṁ."
    },
    {
      "id": "tha-ap533:13.1",
      "pali": "Hāsaṁ supuṇṇanayanaṁ,"
    },
    {
      "id": "tha-ap533:13.2",
      "pali": "buddhavaṇṇagatāsayaṁ;"
    },
    {
      "id": "tha-ap533:13.3",
      "pali": "Dhammajaṁ uggahadayaṁ,"
    },
    {
      "id": "tha-ap533:13.4",
      "pali": "amatāsittasannibhaṁ’."
    },
    {
      "id": "tha-ap533:14.1",
      "pali": "Kaccānassa guṇaṁ sutvā,"
    },
    {
      "id": "tha-ap533:14.2",
      "pali": "taṁ ṭhānaṁ patthayaṁ ṭhito;"
    },
    {
      "id": "tha-ap533:14.3",
      "pali": "Anāgatamhi addhāne,"
    },
    {
      "id": "tha-ap533:14.4",
      "pali": "gotamassa mahāmune."
    },
    {
      "id": "tha-ap533:15.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap533:15.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap533:15.3",
      "pali": "Kaccāno nāma nāmena,"
    },
    {
      "id": "tha-ap533:15.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap533:16.1",
      "pali": "Bahussuto mahāñāṇī,"
    },
    {
      "id": "tha-ap533:16.2",
      "pali": "adhippāyavidū mune;"
    },
    {
      "id": "tha-ap533:16.3",
      "pali": "Pāpuṇissati taṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap533:16.4",
      "pali": "yathāyaṁ byākato mayā."
    },
    {
      "id": "tha-ap533:17.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap533:17.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap533:17.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap533:17.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap533:18.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap533:18.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap533:18.3",
      "pali": "Aññaṁ gatiṁ na gacchāmi,"
    },
    {
      "id": "tha-ap533:18.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap533:19.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap533:19.2",
      "pali": "khattiye atha brāhmaṇe;"
    },
    {
      "id": "tha-ap533:19.3",
      "pali": "Nīce kule na jāyāmi,"
    },
    {
      "id": "tha-ap533:19.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap533:20.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap533:20.2",
      "pali": "jāto ujjeniyaṁ pure;"
    },
    {
      "id": "tha-ap533:20.3",
      "pali": "Pajjotassa ca caṇḍassa,"
    },
    {
      "id": "tha-ap533:20.4",
      "pali": "purohitadijādhino."
    },
    {
      "id": "tha-ap533:21.1",
      "pali": "Putto tiriṭivacchassa,"
    },
    {
      "id": "tha-ap533:21.2",
      "pali": "nipuṇo vedapāragū;"
    },
    {
      "id": "tha-ap533:21.3",
      "pali": "Mātā ca candimā nāma,"
    },
    {
      "id": "tha-ap533:21.4",
      "pali": "kaccānohaṁ varattaco."
    },
    {
      "id": "tha-ap533:22.1",
      "pali": "Vīmaṁsanatthaṁ buddhassa,"
    },
    {
      "id": "tha-ap533:22.2",
      "pali": "bhūmipālena pesito;"
    },
    {
      "id": "tha-ap533:22.3",
      "pali": "Disvā mokkhapuradvāraṁ,"
    },
    {
      "id": "tha-ap533:22.4",
      "pali": "nāyakaṁ guṇasañcayaṁ."
    },
    {
      "id": "tha-ap533:23.1",
      "pali": "Sutvā ca vimalaṁ vākyaṁ,"
    },
    {
      "id": "tha-ap533:23.2",
      "pali": "gatipaṅkavisosanaṁ;"
    },
    {
      "id": "tha-ap533:23.3",
      "pali": "Pāpuṇiṁ amataṁ santaṁ,"
    },
    {
      "id": "tha-ap533:23.4",
      "pali": "sesehi saha sattahi."
    },
    {
      "id": "tha-ap533:24.1",
      "pali": "Adhippāyavidū jāto,"
    },
    {
      "id": "tha-ap533:24.2",
      "pali": "sugatassa mahāmate;"
    },
    {
      "id": "tha-ap533:24.3",
      "pali": "Ṭhapito etadagge ca,"
    },
    {
      "id": "tha-ap533:24.4",
      "pali": "susamiddhamanoratho."
    },
    {
      "id": "tha-ap533:25.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap533:25.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap533:25.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap533:25.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap533:26.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap533:26.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap533:26.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap533:26.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap533:27.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap533:27.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap533:27.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap533:27.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap533:28.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahākaccāyano thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap533:29.1",
      "pali": "Mahākaccāyanattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
