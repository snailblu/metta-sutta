{
  "uid": "thag1.60",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.60:1.1",
      "pali": "“Te me ijjhiṁsu saṅkappā,"
    },
    {
      "id": "thag1.60:1.2",
      "pali": "yadattho pāvisiṁ kuṭiṁ;"
    },
    {
      "id": "thag1.60:1.3",
      "pali": "Vijjāvimuttiṁ paccesaṁ,"
    },
    {
      "id": "thag1.60:1.4",
      "pali": "mānānusayamujjahan”ti."
    },
    {
      "id": "thag1.60:1.5",
      "pali": "… Sīvalitthero …"
    },
    {
      "id": "thag1.60:1.6",
      "pali": "vaggo chaṭṭho."
    },
    {
      "id": "thag1.60:2.1",
      "pali": "Godhiko ca subāhu ca,"
    },
    {
      "id": "thag1.60:2.2",
      "pali": "valliyo uttiyo isi;"
    },
    {
      "id": "thag1.60:2.3",
      "pali": "Añjanavaniyo thero,"
    },
    {
      "id": "thag1.60:2.4",
      "pali": "duve kuṭivihārino;"
    },
    {
      "id": "thag1.60:2.5",
      "pali": "Ramaṇīyakuṭiko ca,"
    },
    {
      "id": "thag1.60:2.6",
      "pali": "kosalavhayasīvalīti."
    }
  ]
}
