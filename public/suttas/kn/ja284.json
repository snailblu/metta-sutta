{
  "uid": "ja284",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja284:1.1",
      "pali": "“Yaṁ ussukā saṅgharanti,"
    },
    {
      "id": "ja284:1.2",
      "pali": "alakkhikā bahuṁ dhanaṁ;"
    },
    {
      "id": "ja284:1.3",
      "pali": "Sippavanto asippā ca,"
    },
    {
      "id": "ja284:1.4",
      "pali": "lakkhivā tāni bhuñjati."
    },
    {
      "id": "ja284:2.1",
      "pali": "Sabbattha katapuññassa,"
    },
    {
      "id": "ja284:2.2",
      "pali": "aticcaññeva pāṇino;"
    },
    {
      "id": "ja284:2.3",
      "pali": "Uppajjanti bahū bhogā,"
    },
    {
      "id": "ja284:2.4",
      "pali": "appanāyatanesupi."
    },
    {
      "id": "ja284:3.1",
      "pali": "Kukkuṭo maṇayo daṇḍo,"
    },
    {
      "id": "ja284:3.2",
      "pali": "thiyo ca puññalakkhaṇā;"
    },
    {
      "id": "ja284:3.3",
      "pali": "Uppajjanti apāpassa,"
    },
    {
      "id": "ja284:3.4",
      "pali": "katapuññassa jantuno”ti."
    },
    {
      "id": "ja284:4.1",
      "pali": "Sirijātakaṁ catutthaṁ."
    }
  ]
}
