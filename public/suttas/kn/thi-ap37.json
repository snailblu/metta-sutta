{
  "uid": "thi-ap37",
  "title": "7 Aḍḍhakāsitherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap37:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap37:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap37:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap37:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap37:2.1",
      "pali": "Tadāhaṁ pabbajitvāna,"
    },
    {
      "id": "thi-ap37:2.2",
      "pali": "tassa buddhassa sāsane;"
    },
    {
      "id": "thi-ap37:2.3",
      "pali": "Saṁvutā pātimokkhamhi,"
    },
    {
      "id": "thi-ap37:2.4",
      "pali": "indriyesu ca pañcasu."
    },
    {
      "id": "thi-ap37:3.1",
      "pali": "Mattaññunī ca asane,"
    },
    {
      "id": "thi-ap37:3.2",
      "pali": "yuttā jāgariyepi ca;"
    },
    {
      "id": "thi-ap37:3.3",
      "pali": "Vasantī yuttayogāhaṁ,"
    },
    {
      "id": "thi-ap37:3.4",
      "pali": "bhikkhuniṁ vigatāsavaṁ."
    },
    {
      "id": "thi-ap37:4.1",
      "pali": "Akkosiṁ duṭṭhacittāhaṁ,"
    },
    {
      "id": "thi-ap37:4.2",
      "pali": "gaṇiketi bhaṇiṁ tadā;"
    },
    {
      "id": "thi-ap37:4.3",
      "pali": "Tena pāpena kammena,"
    },
    {
      "id": "thi-ap37:4.4",
      "pali": "nirayamhi apaccisaṁ."
    },
    {
      "id": "thi-ap37:5.1",
      "pali": "Tena kammāvasesena,"
    },
    {
      "id": "thi-ap37:5.2",
      "pali": "ajāyiṁ gaṇikākule;"
    },
    {
      "id": "thi-ap37:5.3",
      "pali": "Bahusova parādhīnā,"
    },
    {
      "id": "thi-ap37:5.4",
      "pali": "pacchimāya ca jātiyaṁ."
    },
    {
      "id": "thi-ap37:6.1",
      "pali": "Kāsīsu seṭṭhikulajā,"
    },
    {
      "id": "thi-ap37:6.2",
      "pali": "brahmacārībalenahaṁ;"
    },
    {
      "id": "thi-ap37:6.3",
      "pali": "Accharā viya devesu,"
    },
    {
      "id": "thi-ap37:6.4",
      "pali": "ahosiṁ rūpasampadā."
    },
    {
      "id": "thi-ap37:7.1",
      "pali": "Disvāna dassanīyaṁ maṁ,"
    },
    {
      "id": "thi-ap37:7.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "thi-ap37:7.3",
      "pali": "Gaṇikatte nivesesuṁ,"
    },
    {
      "id": "thi-ap37:7.4",
      "pali": "akkosanabalena me."
    },
    {
      "id": "thi-ap37:8.1",
      "pali": "Sāhaṁ sutvāna saddhammaṁ,"
    },
    {
      "id": "thi-ap37:8.2",
      "pali": "buddhaseṭṭhena desitaṁ;"
    },
    {
      "id": "thi-ap37:8.3",
      "pali": "Pubbavāsanasampannā,"
    },
    {
      "id": "thi-ap37:8.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap37:9.1",
      "pali": "Tadūpasampadatthāya,"
    },
    {
      "id": "thi-ap37:9.2",
      "pali": "gacchantī jinasantikaṁ;"
    },
    {
      "id": "thi-ap37:9.3",
      "pali": "Magge dhutte ṭhite sutvā,"
    },
    {
      "id": "thi-ap37:9.4",
      "pali": "labhiṁ dūtopasampadaṁ."
    },
    {
      "id": "thi-ap37:10.1",
      "pali": "Sabbakammaṁ parikkhīṇaṁ,"
    },
    {
      "id": "thi-ap37:10.2",
      "pali": "puññaṁ pāpaṁ tatheva ca;"
    },
    {
      "id": "thi-ap37:10.3",
      "pali": "Sabbasaṁsāramuttiṇṇā,"
    },
    {
      "id": "thi-ap37:10.4",
      "pali": "gaṇikattañca khepitaṁ."
    },
    {
      "id": "thi-ap37:11.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap37:11.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap37:11.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap37:11.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap37:12.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap37:12.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap37:12.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap37:12.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap37:13.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap37:13.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap37:13.3",
      "pali": "Ñāṇaṁ mama mahāvīra,"
    },
    {
      "id": "thi-ap37:13.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap37:14.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap37:14.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap37:14.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap37:15.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap37:15.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap37:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap37:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap37:16.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap37:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap37:17.1",
      "pali": "Itthaṁ sudaṁ aḍḍhakāsi bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap37:18.1",
      "pali": "Aḍḍhakāsitheriyāpadānaṁ sattamaṁ."
    }
  ]
}
