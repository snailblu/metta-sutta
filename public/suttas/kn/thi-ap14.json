{
  "uid": "thi-ap14",
  "title": "Ekāsanadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap14:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "thi-ap14:1.2",
      "pali": "ahosiṁ bālikā tadā;"
    },
    {
      "id": "thi-ap14:1.3",
      "pali": "Mātā ca me pitā ceva,"
    },
    {
      "id": "thi-ap14:1.4",
      "pali": "kammantaṁ agamaṁsu te."
    },
    {
      "id": "thi-ap14:2.1",
      "pali": "Majjhanhikamhi sūriye,"
    },
    {
      "id": "thi-ap14:2.2",
      "pali": "addasaṁ samaṇaṁ ahaṁ;"
    },
    {
      "id": "thi-ap14:2.3",
      "pali": "Vīthiyā anugacchantaṁ,"
    },
    {
      "id": "thi-ap14:2.4",
      "pali": "āsanaṁ paññapesahaṁ."
    },
    {
      "id": "thi-ap14:3.1",
      "pali": "Gonakāvikatikāhi,"
    },
    {
      "id": "thi-ap14:3.2",
      "pali": "paññapetvā mamāsanaṁ;"
    },
    {
      "id": "thi-ap14:3.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "thi-ap14:3.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "thi-ap14:4.1",
      "pali": "‘Santattā kuthitā bhūmi,"
    },
    {
      "id": "thi-ap14:4.2",
      "pali": "sūro majjhanhike ṭhito;"
    },
    {
      "id": "thi-ap14:4.3",
      "pali": "Mālutā ca na vāyanti,"
    },
    {
      "id": "thi-ap14:4.4",
      "pali": "kālo cevettha mehiti."
    },
    {
      "id": "thi-ap14:5.1",
      "pali": "Paññattamāsanamidaṁ,"
    },
    {
      "id": "thi-ap14:5.2",
      "pali": "tavatthāya mahāmuni;"
    },
    {
      "id": "thi-ap14:5.3",
      "pali": "Anukampaṁ upādāya,"
    },
    {
      "id": "thi-ap14:5.4",
      "pali": "nisīda mama āsane’."
    },
    {
      "id": "thi-ap14:6.1",
      "pali": "Nisīdi tattha samaṇo,"
    },
    {
      "id": "thi-ap14:6.2",
      "pali": "sudanto suddhamānaso;"
    },
    {
      "id": "thi-ap14:6.3",
      "pali": "Tassa pattaṁ gahetvāna,"
    },
    {
      "id": "thi-ap14:6.4",
      "pali": "yathārandhaṁ adāsahaṁ."
    },
    {
      "id": "thi-ap14:7.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap14:7.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap14:7.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap14:7.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap14:8.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "thi-ap14:8.2",
      "pali": "āsanena sunimmitaṁ;"
    },
    {
      "id": "thi-ap14:8.3",
      "pali": "Saṭṭhiyojanamubbedhaṁ,"
    },
    {
      "id": "thi-ap14:8.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "thi-ap14:9.1",
      "pali": "Soṇṇamayā maṇimayā,"
    },
    {
      "id": "thi-ap14:9.2",
      "pali": "athopi phalikāmayā;"
    },
    {
      "id": "thi-ap14:9.3",
      "pali": "Lohitaṅgamayā ceva,"
    },
    {
      "id": "thi-ap14:9.4",
      "pali": "pallaṅkā vividhā mama."
    },
    {
      "id": "thi-ap14:10.1",
      "pali": "Tūlikāvikatikāhi,"
    },
    {
      "id": "thi-ap14:10.2",
      "pali": "kaṭṭissacittakāhi ca;"
    },
    {
      "id": "thi-ap14:10.3",
      "pali": "Uddaekantalomī ca,"
    },
    {
      "id": "thi-ap14:10.4",
      "pali": "pallaṅkā me susaṇṭhitā."
    },
    {
      "id": "thi-ap14:11.1",
      "pali": "Yadā icchāmi gamanaṁ,"
    },
    {
      "id": "thi-ap14:11.2",
      "pali": "hāsakhiḍḍasamappitā;"
    },
    {
      "id": "thi-ap14:11.3",
      "pali": "Saha pallaṅkaseṭṭhena,"
    },
    {
      "id": "thi-ap14:11.4",
      "pali": "gacchāmi mama patthitaṁ."
    },
    {
      "id": "thi-ap14:12.1",
      "pali": "Asīti devarājūnaṁ,"
    },
    {
      "id": "thi-ap14:12.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap14:12.3",
      "pali": "Sattati cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap14:12.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap14:13.1",
      "pali": "Bhavābhave saṁsarantī,"
    },
    {
      "id": "thi-ap14:13.2",
      "pali": "mahābhogaṁ labhāmahaṁ;"
    },
    {
      "id": "thi-ap14:13.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "thi-ap14:13.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:14.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "thi-ap14:14.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "thi-ap14:14.3",
      "pali": "Aññe bhave na jānāmi,"
    },
    {
      "id": "thi-ap14:14.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:15.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "thi-ap14:15.2",
      "pali": "khattiye cāpi brāhmaṇe;"
    },
    {
      "id": "thi-ap14:15.3",
      "pali": "Uccākulīnā sabbattha,"
    },
    {
      "id": "thi-ap14:15.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:16.1",
      "pali": "Domanassaṁ na jānāmi,"
    },
    {
      "id": "thi-ap14:16.2",
      "pali": "cittasantāpanaṁ mama;"
    },
    {
      "id": "thi-ap14:16.3",
      "pali": "Vevaṇṇiyaṁ na jānāmi,"
    },
    {
      "id": "thi-ap14:16.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:17.1",
      "pali": "Dhātiyo maṁ upaṭṭhanti,"
    },
    {
      "id": "thi-ap14:17.2",
      "pali": "khujjā celāpikā bahū;"
    },
    {
      "id": "thi-ap14:17.3",
      "pali": "Aṅkena aṅkaṁ gacchāmi,"
    },
    {
      "id": "thi-ap14:17.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:18.1",
      "pali": "Aññā nhāpenti bhojenti,"
    },
    {
      "id": "thi-ap14:18.2",
      "pali": "aññā ramenti maṁ sadā;"
    },
    {
      "id": "thi-ap14:18.3",
      "pali": "Aññā gandhaṁ vilimpanti,"
    },
    {
      "id": "thi-ap14:18.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:19.1",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "thi-ap14:19.2",
      "pali": "suññāgāre vasantiyā;"
    },
    {
      "id": "thi-ap14:19.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "thi-ap14:19.4",
      "pali": "pallaṅko upatiṭṭhati."
    },
    {
      "id": "thi-ap14:20.1",
      "pali": "Ayaṁ pacchimako mayhaṁ,"
    },
    {
      "id": "thi-ap14:20.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "thi-ap14:20.3",
      "pali": "Ajjāpi rajjaṁ chaḍḍetvā,"
    },
    {
      "id": "thi-ap14:20.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap14:21.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap14:21.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "thi-ap14:21.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap14:21.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap14:22.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap14:22.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap14:22.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap14:23.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap14:23.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap14:23.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap14:24.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap14:24.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap14:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap14:25.1",
      "pali": "Itthaṁ sudaṁ ekāsanadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap14:26.1",
      "pali": "Ekāsanadāyikātheriyāpadānaṁ catutthaṁ."
    }
  ]
}
