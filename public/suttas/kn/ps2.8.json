{
  "uid": "ps2.8",
  "title": "2.8. Lokuttarakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps2.8:1.1",
      "pali": "Katame dhammā lokuttarā?"
    },
    {
      "id": "ps2.8:1.2",
      "pali": "Cattāro satipaṭṭhānā, cattāro sammappadhānā, cattāro iddhipādā, pañcindriyāni, pañca balāni, satta bojjhaṅgā, ariyo aṭṭhaṅgiko maggo, cattāro ariyamaggā, cattāri ca sāmaññaphalāni, nibbānañca—"
    },
    {
      "id": "ps2.8:1.3",
      "pali": "ime dhammā lokuttarā."
    },
    {
      "id": "ps2.8:2.1",
      "pali": "<b>Lokuttarā</b>ti kenaṭṭhena lokuttarā?"
    },
    {
      "id": "ps2.8:2.2",
      "pali": "Lokaṁ tarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.3",
      "pali": "Lokā uttarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.4",
      "pali": "Lokato uttarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.5",
      "pali": "Lokamhā uttarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.6",
      "pali": "Lokaṁ atikkamantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.7",
      "pali": "Lokaṁ samatikkamantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.8",
      "pali": "Lokaṁ samatikkantāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.9",
      "pali": "Lokena atirekāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.10",
      "pali": "Lokantaṁ tarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.11",
      "pali": "Lokā nissarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.12",
      "pali": "Lokato nissarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.13",
      "pali": "Lokamhā nissarantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.14",
      "pali": "Lokā nissaṭāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.15",
      "pali": "Lokena nissaṭāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.16",
      "pali": "Lokamhā nissaṭāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.17",
      "pali": "Loke na tiṭṭhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.18",
      "pali": "Lokasmiṁ na tiṭṭhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.19",
      "pali": "Loke na limpantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.20",
      "pali": "Lokena na limpantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.21",
      "pali": "Loke asaṁlittāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.22",
      "pali": "Lokena asaṁlittāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.23",
      "pali": "Loke anupalittāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.24",
      "pali": "Lokena anupalittāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.25",
      "pali": "Loke vippamuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.26",
      "pali": "Lokena vippamuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.27",
      "pali": "Lokā vippamuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.28",
      "pali": "Lokato vippamuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.29",
      "pali": "Lokamhā vippamuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.30",
      "pali": "Loke visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.31",
      "pali": "Lokena visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.32",
      "pali": "Lokā visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.33",
      "pali": "Lokasmiṁ visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.34",
      "pali": "Lokato visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.35",
      "pali": "Lokamhā visaññuttāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.36",
      "pali": "Lokā sujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.37",
      "pali": "Lokato sujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.38",
      "pali": "Lokamhā sujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.39",
      "pali": "Lokā visujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.40",
      "pali": "Lokato visujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.41",
      "pali": "Lokamhā visujjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.42",
      "pali": "Lokā vuṭṭhahantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.43",
      "pali": "Lokato vuṭṭhahantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.44",
      "pali": "Lokamhā vuṭṭhahantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.45",
      "pali": "Lokā vivaṭṭantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.46",
      "pali": "Lokato vivaṭṭantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.47",
      "pali": "Lokamhā vivaṭṭantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.48",
      "pali": "Loke na sajjantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.49",
      "pali": "Loke na gayhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.50",
      "pali": "Loke na bajjhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.51",
      "pali": "Lokaṁ samucchindantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.52",
      "pali": "Lokaṁ samucchinnattāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.53",
      "pali": "Lokaṁ paṭippassambhentīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.54",
      "pali": "Lokaṁ paṭippassambhitattāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.55",
      "pali": "Lokassa apathāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.56",
      "pali": "Lokassa agatīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.57",
      "pali": "Lokassa avisayāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.58",
      "pali": "Lokassa asādhāraṇāti—lokuttarā."
    },
    {
      "id": "ps2.8:2.59",
      "pali": "Lokaṁ vamantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.60",
      "pali": "Lokaṁ na paccāvamantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.61",
      "pali": "Lokaṁ pajahantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.62",
      "pali": "Lokaṁ na upādiyantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.63",
      "pali": "Lokaṁ visinentīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.64",
      "pali": "Lokaṁ na ussinentīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.65",
      "pali": "Lokaṁ vidhūpentīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.66",
      "pali": "Lokaṁ na sandhūpentīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.67",
      "pali": "Lokaṁ samatikkamma abhibhuyya tiṭṭhantīti—lokuttarā."
    },
    {
      "id": "ps2.8:2.68",
      "pali": "Lokuttarakathā niṭṭhitā."
    }
  ]
}
