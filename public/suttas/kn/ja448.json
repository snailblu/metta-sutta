{
  "uid": "ja448",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja448:1.1",
      "pali": "“Nāsmase katapāpamhi,"
    },
    {
      "id": "ja448:1.2",
      "pali": "nāsmase alikavādine;"
    },
    {
      "id": "ja448:1.3",
      "pali": "Nāsmase attatthapaññamhi,"
    },
    {
      "id": "ja448:1.4",
      "pali": "atisantepi nāsmase."
    },
    {
      "id": "ja448:2.1",
      "pali": "Bhavanti heke purisā,"
    },
    {
      "id": "ja448:2.2",
      "pali": "gopipāsikajātikā;"
    },
    {
      "id": "ja448:2.3",
      "pali": "Ghasanti maññe mittāni,"
    },
    {
      "id": "ja448:2.4",
      "pali": "vācāya na ca kammunā."
    },
    {
      "id": "ja448:3.1",
      "pali": "Sukkhañjalipaggahitā,"
    },
    {
      "id": "ja448:3.2",
      "pali": "vācāya paliguṇṭhitā;"
    },
    {
      "id": "ja448:3.3",
      "pali": "Manussapheggū nāsīde,"
    },
    {
      "id": "ja448:3.4",
      "pali": "yasmiṁ natthi kataññutā."
    },
    {
      "id": "ja448:4.1",
      "pali": "Na hi aññaññacittānaṁ,"
    },
    {
      "id": "ja448:4.2",
      "pali": "itthīnaṁ purisāna vā;"
    },
    {
      "id": "ja448:4.3",
      "pali": "Nānāvikatvā saṁsaggaṁ,"
    },
    {
      "id": "ja448:4.4",
      "pali": "tādisampi ca nāsmase."
    },
    {
      "id": "ja448:5.1",
      "pali": "Anariyakammamokkantaṁ,"
    },
    {
      "id": "ja448:5.2",
      "pali": "athetaṁ sabbaghātinaṁ;"
    },
    {
      "id": "ja448:5.3",
      "pali": "Nisitaṁva paṭicchannaṁ,"
    },
    {
      "id": "ja448:5.4",
      "pali": "tādisampi ca nāsmase."
    },
    {
      "id": "ja448:6.1",
      "pali": "Mittarūpenidhekacce,"
    },
    {
      "id": "ja448:6.2",
      "pali": "sākhalyena acetasā;"
    },
    {
      "id": "ja448:6.3",
      "pali": "Vividhehi upāyanti,"
    },
    {
      "id": "ja448:6.4",
      "pali": "tādisampi ca nāsmase."
    },
    {
      "id": "ja448:7.1",
      "pali": "Āmisaṁ vā dhanaṁ vāpi,"
    },
    {
      "id": "ja448:7.2",
      "pali": "yattha passati tādiso;"
    },
    {
      "id": "ja448:7.3",
      "pali": "Dubbhiṁ karoti dummedho,"
    },
    {
      "id": "ja448:7.4",
      "pali": "tañca hantvāna gacchati”."
    },
    {
      "id": "ja448:8.1",
      "pali": "“Mittarūpena bahavo,"
    },
    {
      "id": "ja448:8.2",
      "pali": "channā sevanti sattavo;"
    },
    {
      "id": "ja448:8.3",
      "pali": "Jahe kāpurise hete,"
    },
    {
      "id": "ja448:8.4",
      "pali": "kukkuṭo viya senakaṁ."
    },
    {
      "id": "ja448:9.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja448:9.2",
      "pali": "na khippamanubujjhati;"
    },
    {
      "id": "ja448:9.3",
      "pali": "Amittavasamanveti,"
    },
    {
      "id": "ja448:9.4",
      "pali": "pacchā ca anutappati."
    },
    {
      "id": "ja448:10.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja448:10.2",
      "pali": "khippameva nibodhati;"
    },
    {
      "id": "ja448:10.3",
      "pali": "Muccate sattusambādhā,"
    },
    {
      "id": "ja448:10.4",
      "pali": "kukkuṭo viya senakā."
    },
    {
      "id": "ja448:11.1",
      "pali": "Taṁ tādisaṁ kūṭamivoḍḍitaṁ vane,"
    },
    {
      "id": "ja448:11.2",
      "pali": "Adhammikaṁ niccavidhaṁsakārinaṁ;"
    },
    {
      "id": "ja448:11.3",
      "pali": "Ārā vivajjeyya naro vicakkhaṇo,"
    },
    {
      "id": "ja448:11.4",
      "pali": "Senaṁ yathā kukkuṭo vaṁsakānane”ti."
    },
    {
      "id": "ja448:12.1",
      "pali": "Kukkuṭajātakaṁ dasamaṁ."
    }
  ]
}
