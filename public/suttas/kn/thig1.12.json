{
  "uid": "thig1.12",
  "title": "Dhammadinnātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.12:1.1",
      "pali": "“Chandajātā avasāyī,"
    },
    {
      "id": "thig1.12:1.2",
      "pali": "Manasā ca phuṭā siyā;"
    },
    {
      "id": "thig1.12:1.3",
      "pali": "Kāmesu appaṭibaddhacittā,"
    },
    {
      "id": "thig1.12:1.4",
      "pali": "Uddhaṁsotāti vuccatī”ti."
    },
    {
      "id": "thig1.12:2.1",
      "pali": "… Dhammadinnā therī …."
    }
  ]
}
