{
  "uid": "tha-ap92",
  "title": "Padumapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap92:1.1",
      "pali": "“Pokkharavanaṁ paviṭṭho,"
    },
    {
      "id": "tha-ap92:1.2",
      "pali": "Bhañjanto padumānihaṁ;"
    },
    {
      "id": "tha-ap92:1.3",
      "pali": "Tatthaddasaṁ phussaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap92:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap92:2.1",
      "pali": "Padumapupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap92:2.2",
      "pali": "ākāse ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap92:2.3",
      "pali": "Pāpakammaṁ saritvāna,"
    },
    {
      "id": "tha-ap92:2.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap92:3.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "tha-ap92:3.2",
      "pali": "manasā saṁvutena ca;"
    },
    {
      "id": "tha-ap92:3.3",
      "pali": "Vacīduccaritaṁ hitvā,"
    },
    {
      "id": "tha-ap92:3.4",
      "pali": "ājīvaṁ parisodhayiṁ."
    },
    {
      "id": "tha-ap92:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap92:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap92:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap92:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap92:5.1",
      "pali": "Padumābhāsanāmā ca,"
    },
    {
      "id": "tha-ap92:5.2",
      "pali": "aṭṭhārasa mahīpatī;"
    },
    {
      "id": "tha-ap92:5.3",
      "pali": "Aṭṭhārasesu kappesu,"
    },
    {
      "id": "tha-ap92:5.4",
      "pali": "aṭṭhatālīsamāsisuṁ."
    },
    {
      "id": "tha-ap92:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap92:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap92:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap92:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap92:8.1",
      "pali": "Padumapupphiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap92:9.1",
      "pali": "Timiravaggo navamo."
    },
    {
      "id": "tha-ap92:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap92:11.1",
      "pali": "Timiranaṅgalīpuppha,"
    },
    {
      "id": "tha-ap92:11.2",
      "pali": "nippannañjaliko adho;"
    },
    {
      "id": "tha-ap92:11.3",
      "pali": "Dve raṁsisaññī phalado,"
    },
    {
      "id": "tha-ap92:11.4",
      "pali": "saddasaññī ca secako;"
    },
    {
      "id": "tha-ap92:11.5",
      "pali": "Padmapupphī ca gāthāyo,"
    },
    {
      "id": "tha-ap92:11.6",
      "pali": "chappaññāsa pakittitā."
    }
  ]
}
