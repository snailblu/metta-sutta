{
  "uid": "cp14",
  "title": "Sīlapāramī 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp14:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp14:1.2",
      "pali": "cūḷabodhi susīlavā;"
    },
    {
      "id": "cp14:1.3",
      "pali": "Bhavaṁ disvāna bhayato,"
    },
    {
      "id": "cp14:1.4",
      "pali": "nekkhammaṁ abhinikkhamiṁ."
    },
    {
      "id": "cp14:2.1",
      "pali": "Yā me dutiyikā āsi,"
    },
    {
      "id": "cp14:2.2",
      "pali": "brāhmaṇī kanakasannibhā;"
    },
    {
      "id": "cp14:2.3",
      "pali": "Sāpi vaṭṭe anapekkhā,"
    },
    {
      "id": "cp14:2.4",
      "pali": "nekkhammaṁ abhinikkhami."
    },
    {
      "id": "cp14:3.1",
      "pali": "Nirālayā chinnabandhū,"
    },
    {
      "id": "cp14:3.2",
      "pali": "anapekkhā kule gaṇe;"
    },
    {
      "id": "cp14:3.3",
      "pali": "Carantā gāmanigamaṁ,"
    },
    {
      "id": "cp14:3.4",
      "pali": "bārāṇasimupāgamuṁ."
    },
    {
      "id": "cp14:4.1",
      "pali": "Tattha vasāma nipakā,"
    },
    {
      "id": "cp14:4.2",
      "pali": "asaṁsaṭṭhā kule gaṇe;"
    },
    {
      "id": "cp14:4.3",
      "pali": "Nirākule appasadde,"
    },
    {
      "id": "cp14:4.4",
      "pali": "rājuyyāne vasāmubho."
    },
    {
      "id": "cp14:5.1",
      "pali": "Uyyānadassanaṁ gantvā,"
    },
    {
      "id": "cp14:5.2",
      "pali": "rājā addasa brāhmaṇiṁ;"
    },
    {
      "id": "cp14:5.3",
      "pali": "Upagamma mamaṁ pucchi,"
    },
    {
      "id": "cp14:5.4",
      "pali": "‘tuyhesā kā kassa bhariyā’."
    },
    {
      "id": "cp14:6.1",
      "pali": "Evaṁ vutte, ahaṁ tassa,"
    },
    {
      "id": "cp14:6.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "cp14:6.3",
      "pali": "‘Na mayhaṁ bhariyā esā,"
    },
    {
      "id": "cp14:6.4",
      "pali": "sahadhammā ekasāsanī’."
    },
    {
      "id": "cp14:7.1",
      "pali": "Tissā sārattagadhito,"
    },
    {
      "id": "cp14:7.2",
      "pali": "gāhāpetvāna ceṭake;"
    },
    {
      "id": "cp14:7.3",
      "pali": "Nippīḷayanto balasā,"
    },
    {
      "id": "cp14:7.4",
      "pali": "antepuraṁ pavesayi."
    },
    {
      "id": "cp14:8.1",
      "pali": "Odapattakiyā mayhaṁ,"
    },
    {
      "id": "cp14:8.2",
      "pali": "sahajā ekasāsanī;"
    },
    {
      "id": "cp14:8.3",
      "pali": "Ākaḍḍhitvā nayantiyā,"
    },
    {
      "id": "cp14:8.4",
      "pali": "kopo me upapajjatha."
    },
    {
      "id": "cp14:9.1",
      "pali": "Saha kope samuppanne,"
    },
    {
      "id": "cp14:9.2",
      "pali": "sīlabbatamanussariṁ;"
    },
    {
      "id": "cp14:9.3",
      "pali": "Tattheva kopaṁ niggaṇhiṁ,"
    },
    {
      "id": "cp14:9.4",
      "pali": "nādāsiṁ vaḍḍhitūpari."
    },
    {
      "id": "cp14:10.1",
      "pali": "Yadi naṁ brāhmaṇiṁ koci,"
    },
    {
      "id": "cp14:10.2",
      "pali": "koṭṭeyya tiṇhasattiyā;"
    },
    {
      "id": "cp14:10.3",
      "pali": "Neva sīlaṁ pabhindeyyaṁ,"
    },
    {
      "id": "cp14:10.4",
      "pali": "bodhiyāyeva kāraṇā."
    },
    {
      "id": "cp14:11.1",
      "pali": "Na mesā brāhmaṇī dessā,"
    },
    {
      "id": "cp14:11.2",
      "pali": "napi me balaṁ na vijjati;"
    },
    {
      "id": "cp14:11.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp14:11.4",
      "pali": "tasmā sīlānurakkhisan”ti."
    },
    {
      "id": "cp14:12.1",
      "pali": "Cūḷabodhicariyaṁ catutthaṁ."
    }
  ]
}
