{
  "uid": "thag1.27",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.27:1.1",
      "pali": "“Dabbaṁ kusaṁ poṭakilaṁ,"
    },
    {
      "id": "thag1.27:1.2",
      "pali": "usīraṁ muñjapabbajaṁ;"
    },
    {
      "id": "thag1.27:1.3",
      "pali": "Urasā panudissāmi,"
    },
    {
      "id": "thag1.27:1.4",
      "pali": "vivekamanubrūhayan”ti."
    },
    {
      "id": "thag1.27:1.5",
      "pali": "… Lomasakaṅgiyo thero …."
    }
  ]
}
