{
  "uid": "thag3.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.1:1.1",
      "pali": "“Ayoni suddhimanvesaṁ,"
    },
    {
      "id": "thag3.1:1.2",
      "pali": "aggiṁ paricariṁ vane;"
    },
    {
      "id": "thag3.1:1.3",
      "pali": "Suddhimaggaṁ ajānanto,"
    },
    {
      "id": "thag3.1:1.4",
      "pali": "akāsiṁ amaraṁ tapaṁ."
    },
    {
      "id": "thag3.1:2.1",
      "pali": "Taṁ sukhena sukhaṁ laddhaṁ,"
    },
    {
      "id": "thag3.1:2.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag3.1:2.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag3.1:2.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag3.1:3.1",
      "pali": "Brahmabandhu pure āsiṁ,"
    },
    {
      "id": "thag3.1:3.2",
      "pali": "idāni khomhi brāhmaṇo;"
    },
    {
      "id": "thag3.1:3.3",
      "pali": "Tevijjo nhātako camhi,"
    },
    {
      "id": "thag3.1:3.4",
      "pali": "sottiyo camhi vedagū”ti."
    },
    {
      "id": "thag3.1:3.5",
      "pali": "… Aṅgaṇikabhāradvājo thero …."
    }
  ]
}
