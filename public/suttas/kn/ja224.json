{
  "uid": "ja224",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja224:1.1",
      "pali": "“Yassete caturo dhammā,"
    },
    {
      "id": "ja224:1.2",
      "pali": "vānarinda yathā tava;"
    },
    {
      "id": "ja224:1.3",
      "pali": "Saccaṁ dhammo dhiti cāgo,"
    },
    {
      "id": "ja224:1.4",
      "pali": "diṭṭhaṁ so ativattati."
    },
    {
      "id": "ja224:2.1",
      "pali": "Yassa cete na vijjanti,"
    },
    {
      "id": "ja224:2.2",
      "pali": "guṇā paramabhaddakā;"
    },
    {
      "id": "ja224:2.3",
      "pali": "Saccaṁ dhammo dhiti cāgo,"
    },
    {
      "id": "ja224:2.4",
      "pali": "diṭṭhaṁ so nātivattatī”ti."
    },
    {
      "id": "ja224:3.1",
      "pali": "Kumbhilajātakaṁ catutthaṁ."
    }
  ]
}
