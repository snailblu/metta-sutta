{
  "uid": "thi-ap5",
  "title": "Naḷamālikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap5:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "thi-ap5:1.2",
      "pali": "ahosiṁ kinnarī tadā;"
    },
    {
      "id": "thi-ap5:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "thi-ap5:1.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "thi-ap5:2.1",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "thi-ap5:2.2",
      "pali": "vedajātā katañjalī;"
    },
    {
      "id": "thi-ap5:2.3",
      "pali": "Naḷamālaṁ gahetvāna,"
    },
    {
      "id": "thi-ap5:2.4",
      "pali": "sayambhuṁ abhipūjayiṁ."
    },
    {
      "id": "thi-ap5:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap5:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap5:3.3",
      "pali": "Jahitvā kinnarīdehaṁ,"
    },
    {
      "id": "thi-ap5:3.4",
      "pali": "agacchiṁ tidasaṅgatiṁ."
    },
    {
      "id": "thi-ap5:4.1",
      "pali": "Chattiṁsadevarājūnaṁ,"
    },
    {
      "id": "thi-ap5:4.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap5:4.3",
      "pali": "Dasannaṁ cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap5:4.4",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap5:4.5",
      "pali": "Saṁvejetvāna me cittaṁ,"
    },
    {
      "id": "thi-ap5:4.6",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap5:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap5:5.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap5:5.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap5:5.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap5:6.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "thi-ap5:6.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "thi-ap5:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap5:6.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap5:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap5:7.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap5:7.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap5:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap5:8.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap5:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap5:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap5:9.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap5:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap5:10.1",
      "pali": "Itthaṁ sudaṁ naḷamālikā therī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap5:11.1",
      "pali": "Naḷamālikātheriyāpadānaṁ pañcamaṁ."
    }
  ]
}
