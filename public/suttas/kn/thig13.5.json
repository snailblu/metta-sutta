{
  "uid": "thig13.5",
  "title": "Subhākammāradhītutherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig13.5:1.1",
      "pali": "“Daharāhaṁ suddhavasanā,"
    },
    {
      "id": "thig13.5:1.2",
      "pali": "yaṁ pure dhammamassuṇiṁ;"
    },
    {
      "id": "thig13.5:1.3",
      "pali": "Tassā me appamattāya,"
    },
    {
      "id": "thig13.5:1.4",
      "pali": "saccābhisamayo ahu."
    },
    {
      "id": "thig13.5:2.1",
      "pali": "Tatohaṁ sabbakāmesu,"
    },
    {
      "id": "thig13.5:2.2",
      "pali": "bhusaṁ aratimajjhagaṁ;"
    },
    {
      "id": "thig13.5:2.3",
      "pali": "Sakkāyasmiṁ bhayaṁ disvā,"
    },
    {
      "id": "thig13.5:2.4",
      "pali": "nekkhammameva pīhaye."
    },
    {
      "id": "thig13.5:3.1",
      "pali": "Hitvānahaṁ ñātigaṇaṁ,"
    },
    {
      "id": "thig13.5:3.2",
      "pali": "dāsakammakarāni ca;"
    },
    {
      "id": "thig13.5:3.3",
      "pali": "Gāmakhettāni phītāni,"
    },
    {
      "id": "thig13.5:3.4",
      "pali": "ramaṇīye pamodite."
    },
    {
      "id": "thig13.5:4.1",
      "pali": "Pahāyahaṁ pabbajitā,"
    },
    {
      "id": "thig13.5:4.2",
      "pali": "sāpateyyamanappakaṁ;"
    },
    {
      "id": "thig13.5:4.3",
      "pali": "Evaṁ saddhāya nikkhamma,"
    },
    {
      "id": "thig13.5:4.4",
      "pali": "saddhamme suppavedite."
    },
    {
      "id": "thig13.5:5.1",
      "pali": "Netaṁ assa patirūpaṁ,"
    },
    {
      "id": "thig13.5:5.2",
      "pali": "Ākiñcaññañhi patthaye;"
    },
    {
      "id": "thig13.5:5.3",
      "pali": "Yo jātarūpaṁ rajataṁ,"
    },
    {
      "id": "thig13.5:5.4",
      "pali": "Chaḍḍetvā punarāgame."
    },
    {
      "id": "thig13.5:6.1",
      "pali": "Rajataṁ jātarūpaṁ vā,"
    },
    {
      "id": "thig13.5:6.2",
      "pali": "na bodhāya na santiyā;"
    },
    {
      "id": "thig13.5:6.3",
      "pali": "Netaṁ samaṇasāruppaṁ,"
    },
    {
      "id": "thig13.5:6.4",
      "pali": "na etaṁ ariyaddhanaṁ."
    },
    {
      "id": "thig13.5:7.1",
      "pali": "Lobhanaṁ madanañcetaṁ,"
    },
    {
      "id": "thig13.5:7.2",
      "pali": "mohanaṁ rajavaḍḍhanaṁ;"
    },
    {
      "id": "thig13.5:7.3",
      "pali": "Sāsaṅkaṁ bahuāyāsaṁ,"
    },
    {
      "id": "thig13.5:7.4",
      "pali": "natthi cettha dhuvaṁ ṭhiti."
    },
    {
      "id": "thig13.5:8.1",
      "pali": "Ettha rattā pamattā ca,"
    },
    {
      "id": "thig13.5:8.2",
      "pali": "saṅkiliṭṭhamanā narā;"
    },
    {
      "id": "thig13.5:8.3",
      "pali": "Aññamaññena byāruddhā,"
    },
    {
      "id": "thig13.5:8.4",
      "pali": "puthu kubbanti medhagaṁ."
    },
    {
      "id": "thig13.5:9.1",
      "pali": "Vadho bandho parikleso,"
    },
    {
      "id": "thig13.5:9.2",
      "pali": "jāni sokapariddavo;"
    },
    {
      "id": "thig13.5:9.3",
      "pali": "Kāmesu adhipannānaṁ,"
    },
    {
      "id": "thig13.5:9.4",
      "pali": "dissate byasanaṁ bahuṁ."
    },
    {
      "id": "thig13.5:10.1",
      "pali": "Taṁ maṁ ñātī amittāva,"
    },
    {
      "id": "thig13.5:10.2",
      "pali": "kiṁ vo kāmesu yuñjatha;"
    },
    {
      "id": "thig13.5:10.3",
      "pali": "Jānātha maṁ pabbajitaṁ,"
    },
    {
      "id": "thig13.5:10.4",
      "pali": "kāmesu bhayadassiniṁ."
    },
    {
      "id": "thig13.5:11.1",
      "pali": "Na hiraññasuvaṇṇena,"
    },
    {
      "id": "thig13.5:11.2",
      "pali": "parikkhīyanti āsavā;"
    },
    {
      "id": "thig13.5:11.3",
      "pali": "Amittā vadhakā kāmā,"
    },
    {
      "id": "thig13.5:11.4",
      "pali": "sapattā sallabandhanā."
    },
    {
      "id": "thig13.5:12.1",
      "pali": "Taṁ maṁ ñātī amittāva,"
    },
    {
      "id": "thig13.5:12.2",
      "pali": "kiṁ vo kāmesu yuñjatha;"
    },
    {
      "id": "thig13.5:12.3",
      "pali": "Jānātha maṁ pabbajitaṁ,"
    },
    {
      "id": "thig13.5:12.4",
      "pali": "muṇḍaṁ saṅghāṭipārutaṁ."
    },
    {
      "id": "thig13.5:13.1",
      "pali": "Uttiṭṭhapiṇḍo uñcho ca,"
    },
    {
      "id": "thig13.5:13.2",
      "pali": "paṁsukūlañca cīvaraṁ;"
    },
    {
      "id": "thig13.5:13.3",
      "pali": "Etaṁ kho mama sāruppaṁ,"
    },
    {
      "id": "thig13.5:13.4",
      "pali": "anagārūpanissayo."
    },
    {
      "id": "thig13.5:14.1",
      "pali": "Vantā mahesīhi kāmā,"
    },
    {
      "id": "thig13.5:14.2",
      "pali": "ye dibbā ye ca mānusā;"
    },
    {
      "id": "thig13.5:14.3",
      "pali": "Khemaṭṭhāne vimuttā te,"
    },
    {
      "id": "thig13.5:14.4",
      "pali": "pattā te acalaṁ sukhaṁ."
    },
    {
      "id": "thig13.5:15.1",
      "pali": "Māhaṁ kāmehi saṅgacchiṁ,"
    },
    {
      "id": "thig13.5:15.2",
      "pali": "yesu tāṇaṁ na vijjati;"
    },
    {
      "id": "thig13.5:15.3",
      "pali": "Amittā vadhakā kāmā,"
    },
    {
      "id": "thig13.5:15.4",
      "pali": "aggikkhandhūpamā dukhā."
    },
    {
      "id": "thig13.5:16.1",
      "pali": "Paripantho esa bhayo,"
    },
    {
      "id": "thig13.5:16.2",
      "pali": "savighāto sakaṇṭako;"
    },
    {
      "id": "thig13.5:16.3",
      "pali": "Gedho suvisamo ceso,"
    },
    {
      "id": "thig13.5:16.4",
      "pali": "mahanto mohanāmukho."
    },
    {
      "id": "thig13.5:17.1",
      "pali": "Upasaggo bhīmarūpo,"
    },
    {
      "id": "thig13.5:17.2",
      "pali": "kāmā sappasirūpamā;"
    },
    {
      "id": "thig13.5:17.3",
      "pali": "Ye bālā abhinandanti,"
    },
    {
      "id": "thig13.5:17.4",
      "pali": "andhabhūtā puthujjanā."
    },
    {
      "id": "thig13.5:18.1",
      "pali": "Kāmapaṅkena sattā hi,"
    },
    {
      "id": "thig13.5:18.2",
      "pali": "bahū loke aviddasū;"
    },
    {
      "id": "thig13.5:18.3",
      "pali": "Pariyantaṁ na jānanti,"
    },
    {
      "id": "thig13.5:18.4",
      "pali": "jātiyā maraṇassa ca."
    },
    {
      "id": "thig13.5:19.1",
      "pali": "Duggatigamanaṁ maggaṁ,"
    },
    {
      "id": "thig13.5:19.2",
      "pali": "manussā kāmahetukaṁ;"
    },
    {
      "id": "thig13.5:19.3",
      "pali": "Bahuṁ ve paṭipajjanti,"
    },
    {
      "id": "thig13.5:19.4",
      "pali": "attano rogamāvahaṁ."
    },
    {
      "id": "thig13.5:20.1",
      "pali": "Evaṁ amittajananā,"
    },
    {
      "id": "thig13.5:20.2",
      "pali": "tāpanā saṅkilesikā;"
    },
    {
      "id": "thig13.5:20.3",
      "pali": "Lokāmisā bandhanīyā,"
    },
    {
      "id": "thig13.5:20.4",
      "pali": "kāmā maraṇabandhanā."
    },
    {
      "id": "thig13.5:21.1",
      "pali": "Ummādanā ullapanā,"
    },
    {
      "id": "thig13.5:21.2",
      "pali": "kāmā cittappamaddino;"
    },
    {
      "id": "thig13.5:21.3",
      "pali": "Sattānaṁ saṅkilesāya,"
    },
    {
      "id": "thig13.5:21.4",
      "pali": "khippaṁ mārena oḍḍitaṁ."
    },
    {
      "id": "thig13.5:22.1",
      "pali": "Anantādīnavā kāmā,"
    },
    {
      "id": "thig13.5:22.2",
      "pali": "bahudukkhā mahāvisā;"
    },
    {
      "id": "thig13.5:22.3",
      "pali": "Appassādā raṇakarā,"
    },
    {
      "id": "thig13.5:22.4",
      "pali": "sukkapakkhavisosanā."
    },
    {
      "id": "thig13.5:23.1",
      "pali": "Sāhaṁ etādisaṁ katvā,"
    },
    {
      "id": "thig13.5:23.2",
      "pali": "byasanaṁ kāmahetukaṁ;"
    },
    {
      "id": "thig13.5:23.3",
      "pali": "Na taṁ paccāgamissāmi,"
    },
    {
      "id": "thig13.5:23.4",
      "pali": "nibbānābhiratā sadā."
    },
    {
      "id": "thig13.5:24.1",
      "pali": "Raṇaṁ karitvā kāmānaṁ,"
    },
    {
      "id": "thig13.5:24.2",
      "pali": "sītibhāvābhikaṅkhinī;"
    },
    {
      "id": "thig13.5:24.3",
      "pali": "Appamattā vihassāmi,"
    },
    {
      "id": "thig13.5:24.4",
      "pali": "sabbasaṁyojanakkhaye."
    },
    {
      "id": "thig13.5:25.1",
      "pali": "Asokaṁ virajaṁ khemaṁ,"
    },
    {
      "id": "thig13.5:25.2",
      "pali": "ariyaṭṭhaṅgikaṁ ujuṁ;"
    },
    {
      "id": "thig13.5:25.3",
      "pali": "Taṁ maggaṁ anugacchāmi,"
    },
    {
      "id": "thig13.5:25.4",
      "pali": "yena tiṇṇā mahesino”."
    },
    {
      "id": "thig13.5:26.1",
      "pali": "“Imaṁ passatha dhammaṭṭhaṁ,"
    },
    {
      "id": "thig13.5:26.2",
      "pali": "subhaṁ kammāradhītaraṁ;"
    },
    {
      "id": "thig13.5:26.3",
      "pali": "Anejaṁ upasampajja,"
    },
    {
      "id": "thig13.5:26.4",
      "pali": "rukkhamūlamhi jhāyati."
    },
    {
      "id": "thig13.5:27.1",
      "pali": "Ajjaṭṭhamī pabbajitā,"
    },
    {
      "id": "thig13.5:27.2",
      "pali": "saddhā saddhammasobhanā;"
    },
    {
      "id": "thig13.5:27.3",
      "pali": "Vinītuppalavaṇṇāya,"
    },
    {
      "id": "thig13.5:27.4",
      "pali": "tevijjā maccuhāyinī."
    },
    {
      "id": "thig13.5:28.1",
      "pali": "Sāyaṁ bhujissā anaṇā,"
    },
    {
      "id": "thig13.5:28.2",
      "pali": "bhikkhunī bhāvitindriyā;"
    },
    {
      "id": "thig13.5:28.3",
      "pali": "Sabbayogavisaṁyuttā,"
    },
    {
      "id": "thig13.5:28.4",
      "pali": "katakiccā anāsavā”."
    },
    {
      "id": "thig13.5:29.1",
      "pali": "Taṁ sakko devasaṅghena,"
    },
    {
      "id": "thig13.5:29.2",
      "pali": "upasaṅkamma iddhiyā;"
    },
    {
      "id": "thig13.5:29.3",
      "pali": "Namassati bhūtapati,"
    },
    {
      "id": "thig13.5:29.4",
      "pali": "subhaṁ kammāradhītaranti."
    },
    {
      "id": "thig13.5:30.1",
      "pali": "… Subhā kammāradhītā therī …."
    },
    {
      "id": "thig13.5:31.1",
      "pali": "Vīsatinipāto niṭṭhito."
    }
  ]
}
