{
  "uid": "tha-ap261",
  "title": "Kuṭidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap261:1.1",
      "pali": "“Vipinacārī sambuddho,"
    },
    {
      "id": "tha-ap261:1.2",
      "pali": "rukkhamūle vasī tadā;"
    },
    {
      "id": "tha-ap261:1.3",
      "pali": "Paṇṇasālaṁ karitvāna,"
    },
    {
      "id": "tha-ap261:1.4",
      "pali": "adāsiṁ aparājite."
    },
    {
      "id": "tha-ap261:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap261:2.2",
      "pali": "yaṁ paṇṇakuṭikaṁ adaṁ;"
    },
    {
      "id": "tha-ap261:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap261:2.4",
      "pali": "kuṭidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap261:3.1",
      "pali": "Aṭṭhavīse ito kappe,"
    },
    {
      "id": "tha-ap261:3.2",
      "pali": "soḷasāsiṁsu rājāno;"
    },
    {
      "id": "tha-ap261:3.3",
      "pali": "Sabbattha abhivassīti,"
    },
    {
      "id": "tha-ap261:3.4",
      "pali": "vuccare cakkavattino."
    },
    {
      "id": "tha-ap261:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap261:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap261:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap261:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kuṭidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap261:6.1",
      "pali": "Kuṭidāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
