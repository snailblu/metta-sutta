{
  "uid": "thig2.1",
  "title": "Abhirūpanandātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.1:1.1",
      "pali": "“Āturaṁ asuciṁ pūtiṁ,"
    },
    {
      "id": "thig2.1:1.2",
      "pali": "passa nande samussayaṁ;"
    },
    {
      "id": "thig2.1:1.3",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "thig2.1:1.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "thig2.1:2.1",
      "pali": "Animittañca bhāvehi,"
    },
    {
      "id": "thig2.1:2.2",
      "pali": "mānānusayamujjaha;"
    },
    {
      "id": "thig2.1:2.3",
      "pali": "Tato mānābhisamayā,"
    },
    {
      "id": "thig2.1:2.4",
      "pali": "upasantā carissasī”ti."
    },
    {
      "id": "thig2.1:3.1",
      "pali": "Itthaṁ sudaṁ abhirūpanandā therī gāthāyo abhāsitthāti."
    }
  ]
}
