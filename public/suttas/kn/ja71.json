{
  "uid": "ja71",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja71:1.1",
      "pali": "“Yo pubbe karaṇīyāni,"
    },
    {
      "id": "ja71:1.2",
      "pali": "pacchā so kātumicchati;"
    },
    {
      "id": "ja71:1.3",
      "pali": "Varuṇakaṭṭhabhañjova,"
    },
    {
      "id": "ja71:1.4",
      "pali": "sa pacchā manutappatī”ti."
    },
    {
      "id": "ja71:2.1",
      "pali": "Varuṇajātakaṁ paṭhamaṁ."
    }
  ]
}
