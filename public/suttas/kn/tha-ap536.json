{
  "uid": "tha-ap536",
  "title": "Dabbamallaputtattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap536:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap536:1.2",
      "pali": "sabbalokavidū muni;"
    },
    {
      "id": "tha-ap536:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap536:1.4",
      "pali": "kappe uppajji cakkhumā."
    },
    {
      "id": "tha-ap536:2.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "tha-ap536:2.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap536:2.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "tha-ap536:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap536:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap536:3.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap536:3.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "tha-ap536:3.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "tha-ap536:4.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "tha-ap536:4.2",
      "pali": "suññataṁ titthiyehi ca;"
    },
    {
      "id": "tha-ap536:4.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "tha-ap536:4.4",
      "pali": "vasībhūtehi tādibhi."
    },
    {
      "id": "tha-ap536:5.1",
      "pali": "Ratanānaṭṭhapaññāsaṁ,"
    },
    {
      "id": "tha-ap536:5.2",
      "pali": "uggato so mahāmuni;"
    },
    {
      "id": "tha-ap536:5.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap536:5.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap536:6.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap536:6.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap536:6.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "tha-ap536:6.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap536:7.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap536:7.2",
      "pali": "seṭṭhiputto mahāyaso;"
    },
    {
      "id": "tha-ap536:7.3",
      "pali": "Upetvā lokapajjotaṁ,"
    },
    {
      "id": "tha-ap536:7.4",
      "pali": "assosiṁ dhammadesanaṁ."
    },
    {
      "id": "tha-ap536:8.1",
      "pali": "Senāsanāni bhikkhūnaṁ,"
    },
    {
      "id": "tha-ap536:8.2",
      "pali": "paññāpentaṁ sasāvakaṁ;"
    },
    {
      "id": "tha-ap536:8.3",
      "pali": "Kittayantassa vacanaṁ,"
    },
    {
      "id": "tha-ap536:8.4",
      "pali": "suṇitvā mudito ahaṁ."
    },
    {
      "id": "tha-ap536:9.1",
      "pali": "Adhikāraṁ sasaṅghassa,"
    },
    {
      "id": "tha-ap536:9.2",
      "pali": "katvā tassa mahesino;"
    },
    {
      "id": "tha-ap536:9.3",
      "pali": "Nipacca sirasā pāde,"
    },
    {
      "id": "tha-ap536:9.4",
      "pali": "taṁ ṭhānamabhipatthayiṁ."
    },
    {
      "id": "tha-ap536:10.1",
      "pali": "Tadāha sa mahāvīro,"
    },
    {
      "id": "tha-ap536:10.2",
      "pali": "mama kammaṁ pakittayaṁ;"
    },
    {
      "id": "tha-ap536:10.3",
      "pali": "‘Yo sasaṅghamabhojesi,"
    },
    {
      "id": "tha-ap536:10.4",
      "pali": "sattāhaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap536:11.1",
      "pali": "Soyaṁ kamalapattakkho,"
    },
    {
      "id": "tha-ap536:11.2",
      "pali": "sīhaṁso kanakattaco;"
    },
    {
      "id": "tha-ap536:11.3",
      "pali": "Mama pādamūle nipati,"
    },
    {
      "id": "tha-ap536:11.4",
      "pali": "patthayaṁ ṭhānamuttamaṁ."
    },
    {
      "id": "tha-ap536:12.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap536:12.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap536:12.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap536:12.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap536:13.1",
      "pali": "Sāvako tassa buddhassa,"
    },
    {
      "id": "tha-ap536:13.2",
      "pali": "dabbo nāmena vissuto;"
    },
    {
      "id": "tha-ap536:13.3",
      "pali": "Senāsanapaññāpako,"
    },
    {
      "id": "tha-ap536:13.4",
      "pali": "aggo hessatiyaṁ tadā’."
    },
    {
      "id": "tha-ap536:14.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap536:14.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap536:14.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap536:14.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap536:15.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap536:15.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap536:15.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap536:15.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap536:16.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap536:16.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap536:16.3",
      "pali": "Sabbattha sukhito āsiṁ,"
    },
    {
      "id": "tha-ap536:16.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap536:17.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap536:17.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "tha-ap536:17.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "tha-ap536:17.4",
      "pali": "sabbadhammavipassako."
    },
    {
      "id": "tha-ap536:18.1",
      "pali": "Duṭṭhacitto upavadiṁ,"
    },
    {
      "id": "tha-ap536:18.2",
      "pali": "sāvakaṁ tassa tādino;"
    },
    {
      "id": "tha-ap536:18.3",
      "pali": "Sabbāsavaparikkhīṇaṁ,"
    },
    {
      "id": "tha-ap536:18.4",
      "pali": "suddhoti ca vijāniya."
    },
    {
      "id": "tha-ap536:19.1",
      "pali": "Tasseva naravīrassa,"
    },
    {
      "id": "tha-ap536:19.2",
      "pali": "sāvakānaṁ mahesinaṁ;"
    },
    {
      "id": "tha-ap536:19.3",
      "pali": "Salākañca gahetvāna,"
    },
    {
      "id": "tha-ap536:19.4",
      "pali": "khīrodanamadāsahaṁ."
    },
    {
      "id": "tha-ap536:20.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap536:20.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap536:20.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap536:20.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap536:21.1",
      "pali": "Sāsanaṁ jotayitvāna,"
    },
    {
      "id": "tha-ap536:21.2",
      "pali": "abhibhuyya kutitthiye;"
    },
    {
      "id": "tha-ap536:21.3",
      "pali": "Vineyye vinayitvāva,"
    },
    {
      "id": "tha-ap536:21.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "tha-ap536:22.1",
      "pali": "Sasisse nibbute nāthe,"
    },
    {
      "id": "tha-ap536:22.2",
      "pali": "atthamentamhi sāsane;"
    },
    {
      "id": "tha-ap536:22.3",
      "pali": "Devā kandiṁsu saṁviggā,"
    },
    {
      "id": "tha-ap536:22.4",
      "pali": "muttakesā rudammukhā."
    },
    {
      "id": "tha-ap536:23.1",
      "pali": "‘Nibbāyissati dhammakkho,"
    },
    {
      "id": "tha-ap536:23.2",
      "pali": "na passissāma subbate;"
    },
    {
      "id": "tha-ap536:23.3",
      "pali": "Na suṇissāma saddhammaṁ,"
    },
    {
      "id": "tha-ap536:23.4",
      "pali": "aho no appapuññatā’."
    },
    {
      "id": "tha-ap536:24.1",
      "pali": "Tadāyaṁ pathavī sabbā,"
    },
    {
      "id": "tha-ap536:24.2",
      "pali": "acalā sā calācalā;"
    },
    {
      "id": "tha-ap536:24.3",
      "pali": "Sāgaro ca sasokova,"
    },
    {
      "id": "tha-ap536:24.4",
      "pali": "vinadī karuṇaṁ giraṁ."
    },
    {
      "id": "tha-ap536:25.1",
      "pali": "Catuddisā dundubhiyo,"
    },
    {
      "id": "tha-ap536:25.2",
      "pali": "nādayiṁsu amānusā;"
    },
    {
      "id": "tha-ap536:25.3",
      "pali": "Samantato asaniyo,"
    },
    {
      "id": "tha-ap536:25.4",
      "pali": "phaliṁsu ca bhayāvahā."
    },
    {
      "id": "tha-ap536:26.1",
      "pali": "Ukkā patiṁsu nabhasā,"
    },
    {
      "id": "tha-ap536:26.2",
      "pali": "dhūmaketu ca dissati;"
    },
    {
      "id": "tha-ap536:26.3",
      "pali": "Sadhūmā jālavaṭṭā ca,"
    },
    {
      "id": "tha-ap536:26.4",
      "pali": "raviṁsu karuṇaṁ migā."
    },
    {
      "id": "tha-ap536:27.1",
      "pali": "Uppāde dāruṇe disvā,"
    },
    {
      "id": "tha-ap536:27.2",
      "pali": "sāsanatthaṅgasūcake;"
    },
    {
      "id": "tha-ap536:27.3",
      "pali": "Saṁviggā bhikkhavo satta,"
    },
    {
      "id": "tha-ap536:27.4",
      "pali": "cintayimha mayaṁ tadā."
    },
    {
      "id": "tha-ap536:28.1",
      "pali": "‘Sāsanena vināmhākaṁ,"
    },
    {
      "id": "tha-ap536:28.2",
      "pali": "jīvitena alaṁ mayaṁ;"
    },
    {
      "id": "tha-ap536:28.3",
      "pali": "Pavisitvā mahāraññaṁ,"
    },
    {
      "id": "tha-ap536:28.4",
      "pali": "yuñjāma jinasāsanaṁ’."
    },
    {
      "id": "tha-ap536:29.1",
      "pali": "Addasamha tadāraññe,"
    },
    {
      "id": "tha-ap536:29.2",
      "pali": "ubbiddhaṁ selamuttamaṁ;"
    },
    {
      "id": "tha-ap536:29.3",
      "pali": "Nisseṇiyā tamāruyha,"
    },
    {
      "id": "tha-ap536:29.4",
      "pali": "nisseṇiṁ pātayimhase."
    },
    {
      "id": "tha-ap536:30.1",
      "pali": "Tadā ovadi no thero,"
    },
    {
      "id": "tha-ap536:30.2",
      "pali": "‘buddhuppādo sudullabho;"
    },
    {
      "id": "tha-ap536:30.3",
      "pali": "Saddhātidullabhā laddhā,"
    },
    {
      "id": "tha-ap536:30.4",
      "pali": "thokaṁ sesañca sāsanaṁ."
    },
    {
      "id": "tha-ap536:31.1",
      "pali": "Nipatanti khaṇātītā,"
    },
    {
      "id": "tha-ap536:31.2",
      "pali": "anante dukkhasāgare;"
    },
    {
      "id": "tha-ap536:31.3",
      "pali": "Tasmā payogo kattabbo,"
    },
    {
      "id": "tha-ap536:31.4",
      "pali": "yāva ṭhāti mune mataṁ’."
    },
    {
      "id": "tha-ap536:32.1",
      "pali": "Arahā āsi so thero,"
    },
    {
      "id": "tha-ap536:32.2",
      "pali": "anāgāmī tadānugo;"
    },
    {
      "id": "tha-ap536:32.3",
      "pali": "Susīlā itare yuttā,"
    },
    {
      "id": "tha-ap536:32.4",
      "pali": "devalokaṁ agamhase."
    },
    {
      "id": "tha-ap536:33.1",
      "pali": "Nibbuto tiṇṇasaṁsāro,"
    },
    {
      "id": "tha-ap536:33.2",
      "pali": "suddhāvāse ca ekako;"
    },
    {
      "id": "tha-ap536:33.3",
      "pali": "Ahañca pakkusāti ca,"
    },
    {
      "id": "tha-ap536:33.4",
      "pali": "sabhiyo bāhiyo tathā."
    },
    {
      "id": "tha-ap536:34.1",
      "pali": "Kumārakassapo ceva,"
    },
    {
      "id": "tha-ap536:34.2",
      "pali": "tattha tatthūpagā mayaṁ;"
    },
    {
      "id": "tha-ap536:34.3",
      "pali": "Saṁsārabandhanā muttā,"
    },
    {
      "id": "tha-ap536:34.4",
      "pali": "gotamenānukampitā."
    },
    {
      "id": "tha-ap536:35.1",
      "pali": "Mallesu kusinārāyaṁ,"
    },
    {
      "id": "tha-ap536:35.2",
      "pali": "jāto gabbheva me sato;"
    },
    {
      "id": "tha-ap536:35.3",
      "pali": "Mātā matā citāruḷhā,"
    },
    {
      "id": "tha-ap536:35.4",
      "pali": "tato nippatito ahaṁ."
    },
    {
      "id": "tha-ap536:36.1",
      "pali": "Patito dabbapuñjamhi,"
    },
    {
      "id": "tha-ap536:36.2",
      "pali": "tato dabboti vissuto;"
    },
    {
      "id": "tha-ap536:36.3",
      "pali": "Brahmacārībalenāhaṁ,"
    },
    {
      "id": "tha-ap536:36.4",
      "pali": "vimutto sattavassiko."
    },
    {
      "id": "tha-ap536:37.1",
      "pali": "Khīrodanabalenāhaṁ,"
    },
    {
      "id": "tha-ap536:37.2",
      "pali": "pañcahaṅgehupāgato;"
    },
    {
      "id": "tha-ap536:37.3",
      "pali": "Khīṇāsavopavādena,"
    },
    {
      "id": "tha-ap536:37.4",
      "pali": "pāpehi bahucodito."
    },
    {
      "id": "tha-ap536:38.1",
      "pali": "Ubho puññañca pāpañca,"
    },
    {
      "id": "tha-ap536:38.2",
      "pali": "vītivattomhi dānihaṁ;"
    },
    {
      "id": "tha-ap536:38.3",
      "pali": "Patvāna paramaṁ santiṁ,"
    },
    {
      "id": "tha-ap536:38.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap536:39.1",
      "pali": "Senāsanaṁ paññāpayiṁ,"
    },
    {
      "id": "tha-ap536:39.2",
      "pali": "hāsayitvāna subbate;"
    },
    {
      "id": "tha-ap536:39.3",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "tha-ap536:39.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap536:40.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap536:40.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap536:40.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap536:41.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap536:41.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap536:41.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap536:42.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap536:42.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap536:42.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap536:43.1",
      "pali": "Itthaṁ sudaṁ āyasmā dabbamallaputto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap536:44.1",
      "pali": "Dabbamallaputtattherassāpadānaṁ catutthaṁ."
    }
  ]
}
