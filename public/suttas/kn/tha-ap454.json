{
  "uid": "tha-ap454",
  "title": "Morahatthiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap454:1.1",
      "pali": "“Morahatthaṁ gahetvāna,"
    },
    {
      "id": "tha-ap454:1.2",
      "pali": "upesiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap454:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap454:1.4",
      "pali": "morahatthamadāsahaṁ."
    },
    {
      "id": "tha-ap454:2.1",
      "pali": "Iminā morahatthena,"
    },
    {
      "id": "tha-ap454:2.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap454:2.3",
      "pali": "Nibbāyiṁsu tayo aggī,"
    },
    {
      "id": "tha-ap454:2.4",
      "pali": "labhāmi vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap454:3.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap454:3.2",
      "pali": "aho no satthusampadā;"
    },
    {
      "id": "tha-ap454:3.3",
      "pali": "Datvānahaṁ morahatthaṁ,"
    },
    {
      "id": "tha-ap454:3.4",
      "pali": "labhāmi vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap454:4.1",
      "pali": "Tiyaggī nibbutā mayhaṁ,"
    },
    {
      "id": "tha-ap454:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap454:4.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap454:4.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap454:5.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap454:5.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap454:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap454:5.4",
      "pali": "morahatthassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap454:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap454:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap454:6.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap454:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap454:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap454:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap454:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap454:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap454:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap454:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā morahatthiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap454:10.1",
      "pali": "Morahatthiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
