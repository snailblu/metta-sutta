{
  "uid": "ja253",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja253:1.1",
      "pali": "“Mamannapānaṁ vipulaṁ uḷāraṁ,"
    },
    {
      "id": "ja253:1.2",
      "pali": "Uppajjatīmassa maṇissa hetu;"
    },
    {
      "id": "ja253:1.3",
      "pali": "Taṁ te na dassaṁ atiyācakosi,"
    },
    {
      "id": "ja253:1.4",
      "pali": "Na cāpi te assamamāgamissaṁ."
    },
    {
      "id": "ja253:2.1",
      "pali": "Susū yathā sakkharadhotapāṇī,"
    },
    {
      "id": "ja253:2.2",
      "pali": "Tāsesi maṁ selaṁ yācamāno;"
    },
    {
      "id": "ja253:2.3",
      "pali": "Taṁ te na dassaṁ atiyācakosi,"
    },
    {
      "id": "ja253:2.4",
      "pali": "Na cāpi te assamamāgamissaṁ”."
    },
    {
      "id": "ja253:3.1",
      "pali": "“Na taṁ yāce yassa piyaṁ jigīse,"
    },
    {
      "id": "ja253:3.2",
      "pali": "Desso hoti atiyācanāya;"
    },
    {
      "id": "ja253:3.3",
      "pali": "Nāgo maṇiṁ yācito brāhmaṇena,"
    },
    {
      "id": "ja253:3.4",
      "pali": "Adassanaṁyeva tadajjhagamā”ti."
    },
    {
      "id": "ja253:4.1",
      "pali": "Maṇikaṇṭhajātakaṁ tatiyaṁ."
    }
  ]
}
