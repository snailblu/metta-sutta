{
  "uid": "ja16",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja16:1.1",
      "pali": "“Migaṁ tipallatthamanekamāyaṁ,"
    },
    {
      "id": "ja16:1.2",
      "pali": "Aṭṭhakkhuraṁ aḍḍharattāpapāyiṁ;"
    },
    {
      "id": "ja16:1.3",
      "pali": "Ekena sotena chamāssasanto,"
    },
    {
      "id": "ja16:1.4",
      "pali": "Chahi kalāhitibhoti bhāgineyyo”ti."
    },
    {
      "id": "ja16:2.1",
      "pali": "Tipallatthamigajātakaṁ chaṭṭhaṁ."
    }
  ]
}
