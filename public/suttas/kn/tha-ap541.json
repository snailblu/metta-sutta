{
  "uid": "tha-ap541",
  "title": "Rādhattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap541:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap541:1.2",
      "pali": "sabbalokavidū muni;"
    },
    {
      "id": "tha-ap541:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap541:1.4",
      "pali": "kappe uppajji cakkhumā."
    },
    {
      "id": "tha-ap541:2.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "tha-ap541:2.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap541:2.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "tha-ap541:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap541:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap541:3.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap541:3.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "tha-ap541:3.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "tha-ap541:4.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "tha-ap541:4.2",
      "pali": "suññataṁ titthiyehi ca;"
    },
    {
      "id": "tha-ap541:4.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "tha-ap541:4.4",
      "pali": "vasībhūtehi tādibhi."
    },
    {
      "id": "tha-ap541:5.1",
      "pali": "Ratanānaṭṭhapaññāsaṁ,"
    },
    {
      "id": "tha-ap541:5.2",
      "pali": "uggato so mahāmuni;"
    },
    {
      "id": "tha-ap541:5.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap541:5.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap541:6.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap541:6.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap541:6.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "tha-ap541:6.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap541:7.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap541:7.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap541:7.3",
      "pali": "Upecca taṁ naravaraṁ,"
    },
    {
      "id": "tha-ap541:7.4",
      "pali": "assosiṁ dhammadesanaṁ."
    },
    {
      "id": "tha-ap541:8.1",
      "pali": "Paññāpentaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap541:8.2",
      "pali": "parisāsu visāradaṁ;"
    },
    {
      "id": "tha-ap541:8.3",
      "pali": "Paṭibhāneyyakaṁ bhikkhuṁ,"
    },
    {
      "id": "tha-ap541:8.4",
      "pali": "etadagge vināyakaṁ."
    },
    {
      "id": "tha-ap541:9.1",
      "pali": "Tadāhaṁ kāraṁ katvāna,"
    },
    {
      "id": "tha-ap541:9.2",
      "pali": "sasaṅghe lokanāyake;"
    },
    {
      "id": "tha-ap541:9.3",
      "pali": "Nipacca sirasā pāde,"
    },
    {
      "id": "tha-ap541:9.4",
      "pali": "taṁ ṭhānaṁ abhipatthayiṁ."
    },
    {
      "id": "tha-ap541:10.1",
      "pali": "Tato maṁ bhagavā āha,"
    },
    {
      "id": "tha-ap541:10.2",
      "pali": "siṅgīnikkhasamappabho;"
    },
    {
      "id": "tha-ap541:10.3",
      "pali": "Sarena rajanīyena,"
    },
    {
      "id": "tha-ap541:10.4",
      "pali": "kilesamalahārinā."
    },
    {
      "id": "tha-ap541:11.1",
      "pali": "‘Sukhī bhavassu dīghāyu,"
    },
    {
      "id": "tha-ap541:11.2",
      "pali": "sijjhatu paṇidhī tava;"
    },
    {
      "id": "tha-ap541:11.3",
      "pali": "Sasaṅghe me kataṁ kāraṁ,"
    },
    {
      "id": "tha-ap541:11.4",
      "pali": "atīva vipulaṁ tayā."
    },
    {
      "id": "tha-ap541:12.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap541:12.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap541:12.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap541:12.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap541:13.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap541:13.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap541:13.3",
      "pali": "Rādhoti nāmadheyyena,"
    },
    {
      "id": "tha-ap541:13.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap541:14.1",
      "pali": "Sa te hetuguṇe tuṭṭho,"
    },
    {
      "id": "tha-ap541:14.2",
      "pali": "sakyaputto narāsabho;"
    },
    {
      "id": "tha-ap541:14.3",
      "pali": "Paṭibhāneyyakānaggaṁ,"
    },
    {
      "id": "tha-ap541:14.4",
      "pali": "paññapessati nāyako’."
    },
    {
      "id": "tha-ap541:15.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "tha-ap541:15.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "tha-ap541:15.3",
      "pali": "Mettacitto paricariṁ,"
    },
    {
      "id": "tha-ap541:15.4",
      "pali": "sato paññāsamāhito."
    },
    {
      "id": "tha-ap541:16.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap541:16.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap541:16.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap541:16.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap541:17.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap541:17.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap541:17.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap541:17.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap541:18.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap541:18.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap541:18.3",
      "pali": "Sabbattha sukhito āsiṁ,"
    },
    {
      "id": "tha-ap541:18.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap541:19.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap541:19.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "tha-ap541:19.3",
      "pali": "Jāto vippakule niddhe,"
    },
    {
      "id": "tha-ap541:19.4",
      "pali": "vikalacchādanāsane."
    },
    {
      "id": "tha-ap541:20.1",
      "pali": "Kaṭacchubhikkhaṁ pādāsiṁ,"
    },
    {
      "id": "tha-ap541:20.2",
      "pali": "sāriputtassa tādino;"
    },
    {
      "id": "tha-ap541:20.3",
      "pali": "Yadā jiṇṇo ca vuddho ca,"
    },
    {
      "id": "tha-ap541:20.4",
      "pali": "tadārāmamupāgamiṁ."
    },
    {
      "id": "tha-ap541:21.1",
      "pali": "Pabbajati na maṁ koci,"
    },
    {
      "id": "tha-ap541:21.2",
      "pali": "jiṇṇadubbalathāmakaṁ;"
    },
    {
      "id": "tha-ap541:21.3",
      "pali": "Tena dīno vivaṇṇaṅgo,"
    },
    {
      "id": "tha-ap541:21.4",
      "pali": "soko cāsiṁ tadā ahaṁ."
    },
    {
      "id": "tha-ap541:22.1",
      "pali": "Disvā mahākāruṇiko,"
    },
    {
      "id": "tha-ap541:22.2",
      "pali": "mamamāha mahāmuni;"
    },
    {
      "id": "tha-ap541:22.3",
      "pali": "‘Kimatthaṁ puttasokaṭṭo,"
    },
    {
      "id": "tha-ap541:22.4",
      "pali": "brūhi te cittajaṁ rujaṁ’."
    },
    {
      "id": "tha-ap541:23.1",
      "pali": "‘Pabbajjaṁ na labhe vīra,"
    },
    {
      "id": "tha-ap541:23.2",
      "pali": "svākkhāte tava sāsane;"
    },
    {
      "id": "tha-ap541:23.3",
      "pali": "Tena sokena dīnosmi,"
    },
    {
      "id": "tha-ap541:23.4",
      "pali": "saraṇaṁ hohi nāyaka’."
    },
    {
      "id": "tha-ap541:24.1",
      "pali": "Tadā bhikkhū samānetvā,"
    },
    {
      "id": "tha-ap541:24.2",
      "pali": "apucchi munisattamo;"
    },
    {
      "id": "tha-ap541:24.3",
      "pali": "‘Imassa adhikāraṁ ye,"
    },
    {
      "id": "tha-ap541:24.4",
      "pali": "saranti byāharantu te’."
    },
    {
      "id": "tha-ap541:25.1",
      "pali": "Sāriputto tadāvoca,"
    },
    {
      "id": "tha-ap541:25.2",
      "pali": "‘kāramassa sarāmahaṁ;"
    },
    {
      "id": "tha-ap541:25.3",
      "pali": "Kaṭacchubhikkhaṁ dāpesi,"
    },
    {
      "id": "tha-ap541:25.4",
      "pali": "piṇḍāya carato mama’."
    },
    {
      "id": "tha-ap541:26.1",
      "pali": "‘Sādhu sādhu kataññūsi,"
    },
    {
      "id": "tha-ap541:26.2",
      "pali": "sāriputta imaṁ tuvaṁ;"
    },
    {
      "id": "tha-ap541:26.3",
      "pali": "Pabbājehi dijaṁ vuḍḍhaṁ,"
    },
    {
      "id": "tha-ap541:26.4",
      "pali": "hessatājāniyo ayaṁ’."
    },
    {
      "id": "tha-ap541:27.1",
      "pali": "Tato alatthaṁ pabbajjaṁ,"
    },
    {
      "id": "tha-ap541:27.2",
      "pali": "kammavācopasampadaṁ;"
    },
    {
      "id": "tha-ap541:27.3",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "tha-ap541:27.4",
      "pali": "pāpuṇiṁ āsavakkhayaṁ."
    },
    {
      "id": "tha-ap541:28.1",
      "pali": "Sakkaccaṁ munino vākyaṁ,"
    },
    {
      "id": "tha-ap541:28.2",
      "pali": "suṇāmi mudito yato;"
    },
    {
      "id": "tha-ap541:28.3",
      "pali": "Paṭibhāneyyakānaggaṁ,"
    },
    {
      "id": "tha-ap541:28.4",
      "pali": "tato maṁ ṭhapayī jino."
    },
    {
      "id": "tha-ap541:29.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap541:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap541:29.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap541:30.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap541:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap541:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap541:31.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap541:31.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap541:31.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap541:32.1",
      "pali": "Itthaṁ sudaṁ āyasmā rādho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap541:33.1",
      "pali": "Rādhattherassāpadānaṁ navamaṁ."
    }
  ]
}
