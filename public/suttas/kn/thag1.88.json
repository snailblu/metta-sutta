{
  "uid": "thag1.88",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.88:1.1",
      "pali": "“Asakkhiṁ vata attānaṁ,"
    },
    {
      "id": "thag1.88:1.2",
      "pali": "uddhātuṁ udakā thalaṁ;"
    },
    {
      "id": "thag1.88:1.3",
      "pali": "Vuyhamāno mahogheva,"
    },
    {
      "id": "thag1.88:1.4",
      "pali": "saccāni paṭivijjhahan”ti."
    },
    {
      "id": "thag1.88:1.5",
      "pali": "… Ajjuno thero …."
    }
  ]
}
