{
  "uid": "vv18",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv18:1.1",
      "pali": "“Api sakkova devindo,"
    },
    {
      "id": "vv18:1.2",
      "pali": "ramme cittalatāvane;"
    },
    {
      "id": "vv18:1.3",
      "pali": "Samantā anupariyāsi,"
    },
    {
      "id": "vv18:1.4",
      "pali": "nārīgaṇapurakkhatā;"
    },
    {
      "id": "vv18:1.5",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv18:1.6",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv18:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv18:2.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv18:2.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv18:2.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv18:3.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv18:3.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv18:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv18:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv18:4.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv18:4.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv18:4.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv18:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv18:5.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv18:5.2",
      "pali": "Dāsī ahosiṁ parapessiyā kule."
    },
    {
      "id": "vv18:6.1",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv18:6.2",
      "pali": "gotamassa yasassino;"
    },
    {
      "id": "vv18:6.3",
      "pali": "Tassā me nikkamo āsi,"
    },
    {
      "id": "vv18:6.4",
      "pali": "sāsane tassa tādino."
    },
    {
      "id": "vv18:7.1",
      "pali": "Kāmaṁ bhijjatuyaṁ kāyo,"
    },
    {
      "id": "vv18:7.2",
      "pali": "neva atthettha saṇṭhanaṁ;"
    },
    {
      "id": "vv18:7.3",
      "pali": "Sikkhāpadānaṁ pañcannaṁ,"
    },
    {
      "id": "vv18:7.4",
      "pali": "maggo sovatthiko sivo."
    },
    {
      "id": "vv18:8.1",
      "pali": "Akaṇṭako agahano,"
    },
    {
      "id": "vv18:8.2",
      "pali": "uju sabbhi pavedito;"
    },
    {
      "id": "vv18:8.3",
      "pali": "Nikkamassa phalaṁ passa,"
    },
    {
      "id": "vv18:8.4",
      "pali": "yathidaṁ pāpuṇitthikā."
    },
    {
      "id": "vv18:9.1",
      "pali": "Āmantanikā raññomhi,"
    },
    {
      "id": "vv18:9.2",
      "pali": "sakkassa vasavattino;"
    },
    {
      "id": "vv18:9.3",
      "pali": "Saṭṭhi tūriyasahassāni,"
    },
    {
      "id": "vv18:9.4",
      "pali": "paṭibodhaṁ karonti me."
    },
    {
      "id": "vv18:10.1",
      "pali": "Ālambo gaggaro bhīmo,"
    },
    {
      "id": "vv18:10.2",
      "pali": "sādhuvādī ca saṁsayo;"
    },
    {
      "id": "vv18:10.3",
      "pali": "Pokkharo ca suphasso ca,"
    },
    {
      "id": "vv18:10.4",
      "pali": "viṇāmokkhā ca nāriyo."
    },
    {
      "id": "vv18:11.1",
      "pali": "Nandā ceva sunandā ca,"
    },
    {
      "id": "vv18:11.2",
      "pali": "soṇadinnā sucimhitā;"
    },
    {
      "id": "vv18:11.3",
      "pali": "Alambusā missakesī ca,"
    },
    {
      "id": "vv18:11.4",
      "pali": "puṇḍarīkāti dāruṇī."
    },
    {
      "id": "vv18:12.1",
      "pali": "Eṇīphassā suphassā ca,"
    },
    {
      "id": "vv18:12.2",
      "pali": "subhaddā muduvādinī;"
    },
    {
      "id": "vv18:12.3",
      "pali": "Etā caññā ca seyyāse,"
    },
    {
      "id": "vv18:12.4",
      "pali": "accharānaṁ pabodhikā."
    },
    {
      "id": "vv18:13.1",
      "pali": "Tā maṁ kālenupāgantvā,"
    },
    {
      "id": "vv18:13.2",
      "pali": "abhibhāsanti devatā;"
    },
    {
      "id": "vv18:13.3",
      "pali": "Handa naccāma gāyāma,"
    },
    {
      "id": "vv18:13.4",
      "pali": "handa taṁ ramayāmase."
    },
    {
      "id": "vv18:14.1",
      "pali": "Nayidaṁ akatapuññānaṁ,"
    },
    {
      "id": "vv18:14.2",
      "pali": "katapuññānamevidaṁ;"
    },
    {
      "id": "vv18:14.3",
      "pali": "Asokaṁ nandanaṁ rammaṁ,"
    },
    {
      "id": "vv18:14.4",
      "pali": "tidasānaṁ mahāvanaṁ."
    },
    {
      "id": "vv18:15.1",
      "pali": "Sukhaṁ akatapuññānaṁ,"
    },
    {
      "id": "vv18:15.2",
      "pali": "idha natthi parattha ca;"
    },
    {
      "id": "vv18:15.3",
      "pali": "Sukhañca katapuññānaṁ,"
    },
    {
      "id": "vv18:15.4",
      "pali": "idha ceva parattha ca."
    },
    {
      "id": "vv18:16.1",
      "pali": "Tesaṁ sahabyakāmānaṁ,"
    },
    {
      "id": "vv18:16.2",
      "pali": "kattabbaṁ kusalaṁ bahuṁ;"
    },
    {
      "id": "vv18:16.3",
      "pali": "Katapuññā hi modanti,"
    },
    {
      "id": "vv18:16.4",
      "pali": "sagge bhogasamaṅgino”ti."
    },
    {
      "id": "vv18:17.1",
      "pali": "Dāsivimānaṁ paṭhamaṁ."
    }
  ]
}
