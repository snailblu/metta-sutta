{
  "uid": "ja453",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja453:1.1",
      "pali": "“Kiṁsu naro jappamadhiccakāle,"
    },
    {
      "id": "ja453:1.2",
      "pali": "Kaṁ vā vijjaṁ katamaṁ vā sutānaṁ;"
    },
    {
      "id": "ja453:1.3",
      "pali": "So macco asmiñca paramhi loke,"
    },
    {
      "id": "ja453:1.4",
      "pali": "Kathaṁ karo sotthānena gutto”."
    },
    {
      "id": "ja453:2.1",
      "pali": "“Yassa devā pitaro ca sabbe,"
    },
    {
      "id": "ja453:2.2",
      "pali": "Sarīsapā sabbabhūtāni cāpi;"
    },
    {
      "id": "ja453:2.3",
      "pali": "Mettāya niccaṁ apacitāni honti,"
    },
    {
      "id": "ja453:2.4",
      "pali": "Bhūtesu ve sotthānaṁ tadāhu”."
    },
    {
      "id": "ja453:3.1",
      "pali": "“Yo sabbalokassa nivātavutti,"
    },
    {
      "id": "ja453:3.2",
      "pali": "Itthīpumānaṁ sahadārakānaṁ;"
    },
    {
      "id": "ja453:3.3",
      "pali": "Khantā duruttānamappaṭikūlavādī,"
    },
    {
      "id": "ja453:3.4",
      "pali": "Adhivāsanaṁ sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:4.1",
      "pali": "Yo nāvajānāti sahāyamitte,"
    },
    {
      "id": "ja453:4.2",
      "pali": "Sippena kulyāhi dhanena jaccā;"
    },
    {
      "id": "ja453:4.3",
      "pali": "Rucipañño atthakāle matīmā,"
    },
    {
      "id": "ja453:4.4",
      "pali": "Sahāyesu ve sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:5.1",
      "pali": "Mittāni ve yassa bhavanti santo,"
    },
    {
      "id": "ja453:5.2",
      "pali": "Saṁvissatthā avisaṁvādakassa;"
    },
    {
      "id": "ja453:5.3",
      "pali": "Na mittadubbhī saṁvibhāgī dhanena,"
    },
    {
      "id": "ja453:5.4",
      "pali": "Mittesu ve sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:6.1",
      "pali": "Yassa bhariyā tulyavayā samaggā,"
    },
    {
      "id": "ja453:6.2",
      "pali": "Anubbatā dhammakāmā pajātā;"
    },
    {
      "id": "ja453:6.3",
      "pali": "Koliniyā sīlavatī patibbatā,"
    },
    {
      "id": "ja453:6.4",
      "pali": "Dāresu ve sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:7.1",
      "pali": "Yassa rājā bhūtapati yasassī,"
    },
    {
      "id": "ja453:7.2",
      "pali": "Jānāti soceyyaṁ parakkamañca;"
    },
    {
      "id": "ja453:7.3",
      "pali": "Advejjhatā suhadayaṁ mamanti,"
    },
    {
      "id": "ja453:7.4",
      "pali": "Rājūsu ve sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:8.1",
      "pali": "Annañca pānañca dadāti saddho,"
    },
    {
      "id": "ja453:8.2",
      "pali": "Mālañca gandhañca vilepanañca;"
    },
    {
      "id": "ja453:8.3",
      "pali": "Pasannacitto anumodamāno,"
    },
    {
      "id": "ja453:8.4",
      "pali": "Saggesu ve sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:9.1",
      "pali": "Yamariyadhammena punanti vuddhā,"
    },
    {
      "id": "ja453:9.2",
      "pali": "Ārādhitā samacariyāya santo;"
    },
    {
      "id": "ja453:9.3",
      "pali": "Bahussutā isayo sīlavanto,"
    },
    {
      "id": "ja453:9.4",
      "pali": "Arahantamajjhe sotthānaṁ tadāhu."
    },
    {
      "id": "ja453:10.1",
      "pali": "Etāni kho sotthānāni loke,"
    },
    {
      "id": "ja453:10.2",
      "pali": "Viññuppasatthāni sukhudrayāni;"
    },
    {
      "id": "ja453:10.3",
      "pali": "Tānīdha sevetha naro sapañño,"
    },
    {
      "id": "ja453:10.4",
      "pali": "Na hi maṅgale kiñcanamatthi saccan”ti."
    },
    {
      "id": "ja453:11.1",
      "pali": "Mahāmaṅgalajātakaṁ pannarasamaṁ."
    }
  ]
}
