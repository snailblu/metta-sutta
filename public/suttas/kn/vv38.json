{
  "uid": "vv38",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv38:1.1",
      "pali": "“Pāricchattake koviḷāre,"
    },
    {
      "id": "vv38:1.2",
      "pali": "ramaṇīye manorame;"
    },
    {
      "id": "vv38:1.3",
      "pali": "Dibbamālaṁ ganthamānā,"
    },
    {
      "id": "vv38:1.4",
      "pali": "gāyantī sampamodasi."
    },
    {
      "id": "vv38:2.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv38:2.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv38:2.3",
      "pali": "Dibbā saddā niccharanti,"
    },
    {
      "id": "vv38:2.4",
      "pali": "savanīyā manoramā."
    },
    {
      "id": "vv38:3.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv38:3.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv38:3.3",
      "pali": "Dibbā gandhā pavāyanti,"
    },
    {
      "id": "vv38:3.4",
      "pali": "sucigandhā manoramā."
    },
    {
      "id": "vv38:4.1",
      "pali": "Vivattamānā kāyena,"
    },
    {
      "id": "vv38:4.2",
      "pali": "yā veṇīsu piḷandhanā;"
    },
    {
      "id": "vv38:4.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv38:4.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv38:5.1",
      "pali": "Vaṭaṁsakā vātadhutā,"
    },
    {
      "id": "vv38:5.2",
      "pali": "vātena sampakampitā;"
    },
    {
      "id": "vv38:5.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv38:5.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv38:6.1",
      "pali": "Yāpi te sirasmiṁ mālā,"
    },
    {
      "id": "vv38:6.2",
      "pali": "sucigandhā manoramā;"
    },
    {
      "id": "vv38:6.3",
      "pali": "Vāti gandho disā sabbā,"
    },
    {
      "id": "vv38:6.4",
      "pali": "rukkho mañjūsako yathā."
    },
    {
      "id": "vv38:7.1",
      "pali": "Ghāyase taṁ sucigandhaṁ,"
    },
    {
      "id": "vv38:7.2",
      "pali": "rūpaṁ passasi amānusaṁ;"
    },
    {
      "id": "vv38:7.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv38:7.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv38:8.1",
      "pali": "“Pabhassaraṁ accimantaṁ,"
    },
    {
      "id": "vv38:8.2",
      "pali": "vaṇṇagandhena saṁyutaṁ;"
    },
    {
      "id": "vv38:8.3",
      "pali": "Asokapupphamālāhaṁ,"
    },
    {
      "id": "vv38:8.4",
      "pali": "buddhassa upanāmayiṁ."
    },
    {
      "id": "vv38:9.1",
      "pali": "Tāhaṁ kammaṁ karitvāna,"
    },
    {
      "id": "vv38:9.2",
      "pali": "kusalaṁ buddhavaṇṇitaṁ;"
    },
    {
      "id": "vv38:9.3",
      "pali": "Apetasokā sukhitā,"
    },
    {
      "id": "vv38:9.4",
      "pali": "sampamodāmanāmayā”ti."
    },
    {
      "id": "vv38:10.1",
      "pali": "Pāricchattakavimānaṁ dasamaṁ."
    },
    {
      "id": "vv38:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv38:12.1",
      "pali": "Uḷāro ucchu pallaṅko,"
    },
    {
      "id": "vv38:12.2",
      "pali": "latā ca guttilena ca;"
    },
    {
      "id": "vv38:12.3",
      "pali": "Daddallapesamallikā,"
    },
    {
      "id": "vv38:12.4",
      "pali": "visālakkhi pāricchattako;"
    },
    {
      "id": "vv38:12.5",
      "pali": "Vaggo tena pavuccatīti."
    },
    {
      "id": "vv38:13.1",
      "pali": "Pāricchattakavaggo tatiyo."
    }
  ]
}
