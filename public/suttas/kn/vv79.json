{
  "uid": "vv79",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv79:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv79:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv79:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv79:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv79:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv79:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv79:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv79:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv79:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv79:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv79:3.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv79:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv79:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv79:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv79:5.1",
      "pali": "“Gimhānaṁ pacchime māse,"
    },
    {
      "id": "vv79:5.2",
      "pali": "patapante divaṅkare;"
    },
    {
      "id": "vv79:5.3",
      "pali": "Paresaṁ bhatako poso,"
    },
    {
      "id": "vv79:5.4",
      "pali": "ambārāmamasiñcati."
    },
    {
      "id": "vv79:6.1",
      "pali": "Atha tenāgamā bhikkhu,"
    },
    {
      "id": "vv79:6.2",
      "pali": "sāriputtoti vissuto;"
    },
    {
      "id": "vv79:6.3",
      "pali": "Kilantarūpo kāyena,"
    },
    {
      "id": "vv79:6.4",
      "pali": "akilantova cetasā."
    },
    {
      "id": "vv79:7.1",
      "pali": "Tañca disvāna āyantaṁ,"
    },
    {
      "id": "vv79:7.2",
      "pali": "Avocaṁ ambasiñcako;"
    },
    {
      "id": "vv79:7.3",
      "pali": "Sādhu taṁ bhante nhāpeyyaṁ,"
    },
    {
      "id": "vv79:7.4",
      "pali": "Yaṁ mamassa sukhāvahaṁ."
    },
    {
      "id": "vv79:8.1",
      "pali": "Tassa me anukampāya,"
    },
    {
      "id": "vv79:8.2",
      "pali": "nikkhipi pattacīvaraṁ;"
    },
    {
      "id": "vv79:8.3",
      "pali": "Nisīdi rukkhamūlasmiṁ,"
    },
    {
      "id": "vv79:8.4",
      "pali": "chāyāya ekacīvaro."
    },
    {
      "id": "vv79:9.1",
      "pali": "Tañca acchena vārinā,"
    },
    {
      "id": "vv79:9.2",
      "pali": "pasannamānaso naro;"
    },
    {
      "id": "vv79:9.3",
      "pali": "Nhāpayī rukkhamūlasmiṁ,"
    },
    {
      "id": "vv79:9.4",
      "pali": "chāyāya ekacīvaraṁ."
    },
    {
      "id": "vv79:10.1",
      "pali": "Ambo ca sitto samaṇo ca nhāpito,"
    },
    {
      "id": "vv79:10.2",
      "pali": "Mayā ca puññaṁ pasutaṁ anappakaṁ;"
    },
    {
      "id": "vv79:10.3",
      "pali": "Iti so pītiyā kāyaṁ,"
    },
    {
      "id": "vv79:10.4",
      "pali": "Sabbaṁ pharati attano."
    },
    {
      "id": "vv79:11.1",
      "pali": "Tadeva ettakaṁ kammaṁ,"
    },
    {
      "id": "vv79:11.2",
      "pali": "akāsiṁ tāya jātiyā;"
    },
    {
      "id": "vv79:11.3",
      "pali": "Pahāya mānusaṁ dehaṁ,"
    },
    {
      "id": "vv79:11.4",
      "pali": "upapannomhi nandanaṁ."
    },
    {
      "id": "vv79:12.1",
      "pali": "Nandane ca vane ramme,"
    },
    {
      "id": "vv79:12.2",
      "pali": "nānādijagaṇāyute;"
    },
    {
      "id": "vv79:12.3",
      "pali": "Ramāmi naccagītehi,"
    },
    {
      "id": "vv79:12.4",
      "pali": "accharāhi purakkhato”ti."
    },
    {
      "id": "vv79:13.1",
      "pali": "Ambavimānaṁ pañcamaṁ."
    }
  ]
}
