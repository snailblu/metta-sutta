{
  "uid": "ja392",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja392:1.1",
      "pali": "“Yametaṁ vārijaṁ pupphaṁ,"
    },
    {
      "id": "ja392:1.2",
      "pali": "Adinnaṁ upasiṅghasi;"
    },
    {
      "id": "ja392:1.3",
      "pali": "Ekaṅgametaṁ theyyānaṁ,"
    },
    {
      "id": "ja392:1.4",
      "pali": "Gandhathenosi mārisa”."
    },
    {
      "id": "ja392:2.1",
      "pali": "“Na harāmi na bhañjāmi,"
    },
    {
      "id": "ja392:2.2",
      "pali": "ārā siṅghāmi vārijaṁ;"
    },
    {
      "id": "ja392:2.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja392:2.4",
      "pali": "gandhathenoti vuccati."
    },
    {
      "id": "ja392:3.1",
      "pali": "Yoyaṁ bhisāni khaṇati,"
    },
    {
      "id": "ja392:3.2",
      "pali": "puṇḍarīkāni bhañjati;"
    },
    {
      "id": "ja392:3.3",
      "pali": "Evaṁ ākiṇṇakammanto,"
    },
    {
      "id": "ja392:3.4",
      "pali": "kasmā eso na vuccati”."
    },
    {
      "id": "ja392:4.1",
      "pali": "“Ākiṇṇaluddo puriso,"
    },
    {
      "id": "ja392:4.2",
      "pali": "dhāticelaṁva makkhito;"
    },
    {
      "id": "ja392:4.3",
      "pali": "Tasmiṁ me vacanaṁ natthi,"
    },
    {
      "id": "ja392:4.4",
      "pali": "tañcārahāmi vattave."
    },
    {
      "id": "ja392:5.1",
      "pali": "Anaṅgaṇassa posassa,"
    },
    {
      "id": "ja392:5.2",
      "pali": "niccaṁ sucigavesino;"
    },
    {
      "id": "ja392:5.3",
      "pali": "Vālaggamattaṁ pāpassa,"
    },
    {
      "id": "ja392:5.4",
      "pali": "abbhāmattaṁva khāyati”."
    },
    {
      "id": "ja392:6.1",
      "pali": "“Addhā maṁ yakkha jānāsi,"
    },
    {
      "id": "ja392:6.2",
      "pali": "atho maṁ anukampasi;"
    },
    {
      "id": "ja392:6.3",
      "pali": "Punapi yakkha vajjāsi,"
    },
    {
      "id": "ja392:6.4",
      "pali": "yadā passasi edisaṁ”."
    },
    {
      "id": "ja392:7.1",
      "pali": "“Neva taṁ upajīvāmi,"
    },
    {
      "id": "ja392:7.2",
      "pali": "napi te bhatakāmhase;"
    },
    {
      "id": "ja392:7.3",
      "pali": "Tvameva bhikkhu jāneyya,"
    },
    {
      "id": "ja392:7.4",
      "pali": "yena gaccheyya suggatin”ti."
    },
    {
      "id": "ja392:8.1",
      "pali": "Siṅghapupphajātakaṁ sattamaṁ."
    }
  ]
}
