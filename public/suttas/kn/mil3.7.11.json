{
  "uid": "mil3.7.11",
  "title": "11. Assāsapassāsanirodhapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.7.11:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.7.11:1.2",
      "pali": "“bhante nāgasena, tumhe evaṁ bhaṇatha—"
    },
    {
      "id": "mil3.7.11:1.3",
      "pali": "‘sakkā assāsapassāse nirodhetun’”ti?"
    },
    {
      "id": "mil3.7.11:1.4",
      "pali": "“Āma, mahārāja, sakkā assāsapassāse nirodhetun”ti."
    },
    {
      "id": "mil3.7.11:1.5",
      "pali": "“Kathaṁ, bhante nāgasena, sakkā assāsapassāse nirodhetun”ti."
    },
    {
      "id": "mil3.7.11:1.6",
      "pali": "“Taṁ kiṁ maññasi, mahārāja, sutapubbo te koci kākacchamāno”ti."
    },
    {
      "id": "mil3.7.11:1.7",
      "pali": "“Āma, bhante, sutapubbo”ti."
    },
    {
      "id": "mil3.7.11:1.8",
      "pali": "“Kiṁ nu kho, mahārāja, so saddo kāye namite virameyyā”ti."
    },
    {
      "id": "mil3.7.11:1.9",
      "pali": "“Āma, bhante, virameyyā”ti."
    },
    {
      "id": "mil3.7.11:1.10",
      "pali": "“So hi nāma, mahārāja, saddo abhāvitakāyassa abhāvitasīlassa abhāvitacittassa abhāvitapaññassa kāye namite viramissati, kiṁ pana bhāvitakāyassa bhāvitasīlassa bhāvitacittassa bhāvitapaññassa catutthajjhānaṁ samāpannassa assāsapassāsā na nirujjhissantī”ti."
    },
    {
      "id": "mil3.7.11:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.7.11:3.1",
      "pali": "Assāsapassāsanirodhapañho ekādasamo."
    }
  ]
}
