{
  "uid": "iti45",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti45:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti45:2.1",
      "pali": "“Paṭisallānārāmā, bhikkhave, viharatha paṭisallānaratā, ajjhattaṁ cetosamathamanuyuttā, anirākatajjhānā, vipassanāya samannāgatā, brūhetāro suññāgārānaṁ."
    },
    {
      "id": "iti45:2.2",
      "pali": "Paṭisallānārāmānaṁ, bhikkhave, viharataṁ paṭisallānaratānaṁ ajjhattaṁ cetosamathamanuyuttānaṁ anirākatajjhānānaṁ vipassanāya samannāgatānaṁ brūhetānaṁ suññāgārānaṁ dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "iti45:2.3",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "iti45:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti45:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti45:3.1",
      "pali": "“Ye santacittā nipakā,"
    },
    {
      "id": "iti45:3.2",
      "pali": "satimanto ca jhāyino;"
    },
    {
      "id": "iti45:3.3",
      "pali": "Sammā dhammaṁ vipassanti,"
    },
    {
      "id": "iti45:3.4",
      "pali": "kāmesu anapekkhino."
    },
    {
      "id": "iti45:4.1",
      "pali": "Appamādaratā santā,"
    },
    {
      "id": "iti45:4.2",
      "pali": "pamāde bhayadassino;"
    },
    {
      "id": "iti45:4.3",
      "pali": "Abhabbā parihānāya,"
    },
    {
      "id": "iti45:4.4",
      "pali": "nibbānasseva santike”ti."
    },
    {
      "id": "iti45:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti45:5.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
