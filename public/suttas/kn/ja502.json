{
  "uid": "ja502",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja502:1.1",
      "pali": "“Ete haṁsā pakkamanti,"
    },
    {
      "id": "ja502:1.2",
      "pali": "vakkaṅgā bhayameritā;"
    },
    {
      "id": "ja502:1.3",
      "pali": "Harittaca hemavaṇṇa,"
    },
    {
      "id": "ja502:1.4",
      "pali": "kāmaṁ sumukha pakkama."
    },
    {
      "id": "ja502:2.1",
      "pali": "Ohāya maṁ ñātigaṇā,"
    },
    {
      "id": "ja502:2.2",
      "pali": "ekaṁ pāsavasaṁ gataṁ;"
    },
    {
      "id": "ja502:2.3",
      "pali": "Anapekkhamānā gacchanti,"
    },
    {
      "id": "ja502:2.4",
      "pali": "kiṁ eko avahiyyasi."
    },
    {
      "id": "ja502:3.1",
      "pali": "Pateva patataṁ seṭṭha,"
    },
    {
      "id": "ja502:3.2",
      "pali": "natthi baddhe sahāyatā;"
    },
    {
      "id": "ja502:3.3",
      "pali": "Mā anīghāya hāpesi,"
    },
    {
      "id": "ja502:3.4",
      "pali": "kāmaṁ sumukha pakkama”."
    },
    {
      "id": "ja502:4.1",
      "pali": "“Nāhaṁ ‘dukkhapareto’ti,"
    },
    {
      "id": "ja502:4.2",
      "pali": "dhataraṭṭha tuvaṁ jahe;"
    },
    {
      "id": "ja502:4.3",
      "pali": "Jīvitaṁ maraṇaṁ vā me,"
    },
    {
      "id": "ja502:4.4",
      "pali": "tayā saddhiṁ bhavissati”."
    },
    {
      "id": "ja502:5.1",
      "pali": "“Etadariyassa kalyāṇaṁ,"
    },
    {
      "id": "ja502:5.2",
      "pali": "yaṁ tvaṁ sumukha bhāsasi;"
    },
    {
      "id": "ja502:5.3",
      "pali": "Tañca vīmaṁsamānohaṁ,"
    },
    {
      "id": "ja502:5.4",
      "pali": "‘patatetaṁ’ avassajiṁ”."
    },
    {
      "id": "ja502:6.1",
      "pali": "“Apadena padaṁ yāti,"
    },
    {
      "id": "ja502:6.2",
      "pali": "antalikkhacaro dijo;"
    },
    {
      "id": "ja502:6.3",
      "pali": "Ārā pāsaṁ na bujjhi tvaṁ,"
    },
    {
      "id": "ja502:6.4",
      "pali": "haṁsānaṁ pavaruttama”."
    },
    {
      "id": "ja502:7.1",
      "pali": "“Yadā parābhavo hoti,"
    },
    {
      "id": "ja502:7.2",
      "pali": "poso jīvitasaṅkhaye;"
    },
    {
      "id": "ja502:7.3",
      "pali": "Atha jālañca pāsañca,"
    },
    {
      "id": "ja502:7.4",
      "pali": "āsajjāpi na bujjhati”."
    },
    {
      "id": "ja502:8.1",
      "pali": "“Ete haṁsā pakkamanti,"
    },
    {
      "id": "ja502:8.2",
      "pali": "vakkaṅgā bhayameritā;"
    },
    {
      "id": "ja502:8.3",
      "pali": "Harittaca hemavaṇṇa,"
    },
    {
      "id": "ja502:8.4",
      "pali": "tvaññeva avahiyyasi."
    },
    {
      "id": "ja502:9.1",
      "pali": "Ete bhutvā ca pitvā ca,"
    },
    {
      "id": "ja502:9.2",
      "pali": "pakkamanti vihaṅgamā;"
    },
    {
      "id": "ja502:9.3",
      "pali": "Anapekkhamānā vakkaṅgā,"
    },
    {
      "id": "ja502:9.4",
      "pali": "tvaññeveko upāsasi."
    },
    {
      "id": "ja502:10.1",
      "pali": "Kiṁ nu tyāyaṁ dijo hoti,"
    },
    {
      "id": "ja502:10.2",
      "pali": "mutto baddhaṁ upāsasi;"
    },
    {
      "id": "ja502:10.3",
      "pali": "Ohāya sakuṇā yanti,"
    },
    {
      "id": "ja502:10.4",
      "pali": "kiṁ eko avahiyyasi”."
    },
    {
      "id": "ja502:11.1",
      "pali": "“Rājā me so dijo mitto,"
    },
    {
      "id": "ja502:11.2",
      "pali": "sakhā pāṇasamo ca me;"
    },
    {
      "id": "ja502:11.3",
      "pali": "Neva naṁ vijahissāmi,"
    },
    {
      "id": "ja502:11.4",
      "pali": "yāva kālassa pariyāyaṁ”."
    },
    {
      "id": "ja502:12.1",
      "pali": "“Yo ca tvaṁ sakhino hetu,"
    },
    {
      "id": "ja502:12.2",
      "pali": "pāṇaṁ cajitumicchasi;"
    },
    {
      "id": "ja502:12.3",
      "pali": "So te sahāyaṁ muñcāmi,"
    },
    {
      "id": "ja502:12.4",
      "pali": "hotu rājā tavānugo”."
    },
    {
      "id": "ja502:13.1",
      "pali": "“Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja502:13.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja502:13.3",
      "pali": "Yathāhamajja nandāmi,"
    },
    {
      "id": "ja502:13.4",
      "pali": "muttaṁ disvā dijādhipaṁ”."
    },
    {
      "id": "ja502:14.1",
      "pali": "“Kaccinnu bhoto kusalaṁ,"
    },
    {
      "id": "ja502:14.2",
      "pali": "kacci bhoto anāmayaṁ;"
    },
    {
      "id": "ja502:14.3",
      "pali": "Kacci raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja502:14.4",
      "pali": "dhammena manusāsasi”."
    },
    {
      "id": "ja502:15.1",
      "pali": "“Kusalañceva me haṁsa,"
    },
    {
      "id": "ja502:15.2",
      "pali": "atho haṁsa anāmayaṁ;"
    },
    {
      "id": "ja502:15.3",
      "pali": "Atho raṭṭhamidaṁ phītaṁ,"
    },
    {
      "id": "ja502:15.4",
      "pali": "dhammena manusāsahaṁ”."
    },
    {
      "id": "ja502:16.1",
      "pali": "“Kacci bhoto amaccesu,"
    },
    {
      "id": "ja502:16.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja502:16.3",
      "pali": "Kacci ārā amittā te,"
    },
    {
      "id": "ja502:16.4",
      "pali": "chāyā dakkhiṇatoriva”."
    },
    {
      "id": "ja502:17.1",
      "pali": "“Athopi me amaccesu,"
    },
    {
      "id": "ja502:17.2",
      "pali": "doso koci na vijjati;"
    },
    {
      "id": "ja502:17.3",
      "pali": "Atho ārā amittā me,"
    },
    {
      "id": "ja502:17.4",
      "pali": "chāyā dakkhiṇatoriva”."
    },
    {
      "id": "ja502:18.1",
      "pali": "“Kacci te sādisī bhariyā,"
    },
    {
      "id": "ja502:18.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja502:18.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja502:18.4",
      "pali": "tava chandavasānugā”."
    },
    {
      "id": "ja502:19.1",
      "pali": "“Atho me sādisī bhariyā,"
    },
    {
      "id": "ja502:19.2",
      "pali": "assavā piyabhāṇinī;"
    },
    {
      "id": "ja502:19.3",
      "pali": "Puttarūpayasūpetā,"
    },
    {
      "id": "ja502:19.4",
      "pali": "mama chandavasānugā”."
    },
    {
      "id": "ja502:20.1",
      "pali": "“Kacci te bahavo puttā,"
    },
    {
      "id": "ja502:20.2",
      "pali": "sujātā raṭṭhavaḍḍhana;"
    },
    {
      "id": "ja502:20.3",
      "pali": "Paññājavena sampannā,"
    },
    {
      "id": "ja502:20.4",
      "pali": "sammodanti tato tato”."
    },
    {
      "id": "ja502:21.1",
      "pali": "“Satameko ca me puttā,"
    },
    {
      "id": "ja502:21.2",
      "pali": "dhataraṭṭha mayā sutā;"
    },
    {
      "id": "ja502:21.3",
      "pali": "Tesaṁ tvaṁ kiccamakkhāhi,"
    },
    {
      "id": "ja502:21.4",
      "pali": "nāvarujjhanti te vaco”."
    },
    {
      "id": "ja502:22.1",
      "pali": "“Upapannopi ce hoti,"
    },
    {
      "id": "ja502:22.2",
      "pali": "jātiyā vinayena vā;"
    },
    {
      "id": "ja502:22.3",
      "pali": "Atha pacchā kurute yogaṁ,"
    },
    {
      "id": "ja502:22.4",
      "pali": "kicche āpāsu sīdati."
    },
    {
      "id": "ja502:23.1",
      "pali": "Tassa saṁhīrapaññassa,"
    },
    {
      "id": "ja502:23.2",
      "pali": "vivaro jāyate mahā;"
    },
    {
      "id": "ja502:23.3",
      "pali": "Rattimandhova rūpāni,"
    },
    {
      "id": "ja502:23.4",
      "pali": "thūlāni manupassati."
    },
    {
      "id": "ja502:24.1",
      "pali": "Asāre sārayogaññū,"
    },
    {
      "id": "ja502:24.2",
      "pali": "matiṁ na tveva vindati;"
    },
    {
      "id": "ja502:24.3",
      "pali": "Sarabhova giriduggasmiṁ,"
    },
    {
      "id": "ja502:24.4",
      "pali": "antarāyeva sīdati."
    },
    {
      "id": "ja502:25.1",
      "pali": "Hīnajaccopi ce hoti,"
    },
    {
      "id": "ja502:25.2",
      "pali": "uṭṭhātā dhitimā naro;"
    },
    {
      "id": "ja502:25.3",
      "pali": "Ācārasīlasampanno,"
    },
    {
      "id": "ja502:25.4",
      "pali": "nise aggīva bhāsati."
    },
    {
      "id": "ja502:26.1",
      "pali": "Etaṁ me upamaṁ katvā,"
    },
    {
      "id": "ja502:26.2",
      "pali": "putte vijjāsu vācaya;"
    },
    {
      "id": "ja502:26.3",
      "pali": "Saṁvirūḷhetha medhāvī,"
    },
    {
      "id": "ja502:26.4",
      "pali": "khette bījaṁva vuṭṭhiyā”ti."
    },
    {
      "id": "ja502:27.1",
      "pali": "Cūḷahaṁsajātakaṁ chaṭṭhaṁ."
    }
  ]
}
