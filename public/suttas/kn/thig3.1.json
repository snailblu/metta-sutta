{
  "uid": "thig3.1",
  "title": "Aparāsāmātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.1:1.1",
      "pali": "“Paṇṇavīsativassāni,"
    },
    {
      "id": "thig3.1:1.2",
      "pali": "yato pabbajitāya me;"
    },
    {
      "id": "thig3.1:1.3",
      "pali": "Nābhijānāmi cittassa,"
    },
    {
      "id": "thig3.1:1.4",
      "pali": "samaṁ laddhaṁ kudācanaṁ."
    },
    {
      "id": "thig3.1:2.1",
      "pali": "Aladdhā cetaso santiṁ,"
    },
    {
      "id": "thig3.1:2.2",
      "pali": "citte avasavattinī;"
    },
    {
      "id": "thig3.1:2.3",
      "pali": "Tato saṁvegamāpādiṁ,"
    },
    {
      "id": "thig3.1:2.4",
      "pali": "saritvā jinasāsanaṁ."
    },
    {
      "id": "thig3.1:3.1",
      "pali": "Bahūhi dukkhadhammehi,"
    },
    {
      "id": "thig3.1:3.2",
      "pali": "appamādaratāya me;"
    },
    {
      "id": "thig3.1:3.3",
      "pali": "Taṇhakkhayo anuppatto,"
    },
    {
      "id": "thig3.1:3.4",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thig3.1:3.5",
      "pali": "Ajja me sattamī ratti,"
    },
    {
      "id": "thig3.1:3.6",
      "pali": "yato taṇhā visositā”ti."
    },
    {
      "id": "thig3.1:4.1",
      "pali": "… Aparā sāmā therī …."
    }
  ]
}
