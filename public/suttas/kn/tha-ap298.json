{
  "uid": "tha-ap298",
  "title": "6 Pādapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap298:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap298:1.2",
      "pali": "ahosiṁ kinnaro tadā;"
    },
    {
      "id": "tha-ap298:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap298:1.4",
      "pali": "pītaraṁsiṁva bhāṇumaṁ."
    },
    {
      "id": "tha-ap298:2.1",
      "pali": "Upetaṁ tamahaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap298:2.2",
      "pali": "vipassiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap298:2.3",
      "pali": "Candanaṁ tagarañcāpi,"
    },
    {
      "id": "tha-ap298:2.4",
      "pali": "pāde osiñcahaṁ tadā."
    },
    {
      "id": "tha-ap298:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap298:3.2",
      "pali": "yaṁ pādaṁ abhipūjayiṁ;"
    },
    {
      "id": "tha-ap298:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap298:3.4",
      "pali": "pādapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap298:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap298:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap298:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap298:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā pādapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap298:6.1",
      "pali": "Pādapūjakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
