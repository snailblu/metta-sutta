{
  "uid": "tha-ap99",
  "title": "Madhupiṇḍikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap99:1.1",
      "pali": "“Vipine kānane disvā,"
    },
    {
      "id": "tha-ap99:1.2",
      "pali": "appasadde nirākule;"
    },
    {
      "id": "tha-ap99:1.3",
      "pali": "Siddhatthaṁ isinaṁ seṭṭhaṁ,"
    },
    {
      "id": "tha-ap99:1.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap99:2.1",
      "pali": "Nibbutattaṁ mahānāgaṁ,"
    },
    {
      "id": "tha-ap99:2.2",
      "pali": "nisabhājāniyaṁ yathā;"
    },
    {
      "id": "tha-ap99:2.3",
      "pali": "Osadhiṁva virocantaṁ,"
    },
    {
      "id": "tha-ap99:2.4",
      "pali": "devasaṅghanamassitaṁ."
    },
    {
      "id": "tha-ap99:3.1",
      "pali": "Vitti mamāhu tāvade,"
    },
    {
      "id": "tha-ap99:3.2",
      "pali": "ñāṇaṁ uppajji tāvade;"
    },
    {
      "id": "tha-ap99:3.3",
      "pali": "Vuṭṭhitassa samādhimhā,"
    },
    {
      "id": "tha-ap99:3.4",
      "pali": "madhuṁ datvāna satthuno."
    },
    {
      "id": "tha-ap99:4.1",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap99:4.2",
      "pali": "pakkāmiṁ pācināmukho;"
    },
    {
      "id": "tha-ap99:4.3",
      "pali": "Catuttiṁsamhi kappamhi,"
    },
    {
      "id": "tha-ap99:4.4",
      "pali": "rājā āsiṁ sudassano."
    },
    {
      "id": "tha-ap99:5.1",
      "pali": "Madhu bhisehi savati,"
    },
    {
      "id": "tha-ap99:5.2",
      "pali": "bhojanamhi ca tāvade;"
    },
    {
      "id": "tha-ap99:5.3",
      "pali": "Madhuvassaṁ pavassittha,"
    },
    {
      "id": "tha-ap99:5.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap99:6.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap99:6.2",
      "pali": "yaṁ madhuṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap99:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap99:6.4",
      "pali": "madhudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap99:7.1",
      "pali": "Catuttiṁse ito kappe,"
    },
    {
      "id": "tha-ap99:7.2",
      "pali": "cattāro te sudassanā;"
    },
    {
      "id": "tha-ap99:7.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap99:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap99:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap99:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap99:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap99:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā madhupiṇḍiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap99:10.1",
      "pali": "Madhupiṇḍikattherassāpadānaṁ sattamaṁ."
    }
  ]
}
