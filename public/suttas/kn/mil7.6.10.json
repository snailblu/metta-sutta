{
  "uid": "mil7.6.10",
  "title": "Sīhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.6.10:1.1",
      "pali": "“Bhante nāgasena, ‘ajagarassa ekaṁ aṅgaṁ gahetabban’ti yaṁ vadesi, katamaṁ taṁ ekaṁ aṅgaṁ gahetabban”ti?"
    },
    {
      "id": "mil7.6.10:1.2",
      "pali": "“Yathā, mahārāja, ajagaro mahatimahākāyo bahūpi divase ūnūdaro dīnataro kucchipūraṁ āhāraṁ na labhati, aparipuṇṇo yeva yāvadeva sarīrayāpanamattakena yāpeti;"
    },
    {
      "id": "mil7.6.10:1.3",
      "pali": "evameva kho, mahārāja, yogino yogāvacarassa bhikkhācariyappasutassa parapiṇḍamupagatassa paradinnappāṭikaṅkhissa sayaṅgāhappaṭiviratassa dullabhaṁ udaraparipūraṁ āhāraṁ, api ca atthavasikena kulaputtena cattāro pañca ālope abhuñjitvā avasesaṁ udakena paripūretabbaṁ."
    },
    {
      "id": "mil7.6.10:1.4",
      "pali": "Idaṁ, mahārāja, ajagarassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.6.10:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, therena sāriputtena dhammasenāpatinā—"
    },
    {
      "id": "mil7.6.10:2.1",
      "pali": "‘Allaṁ sukkhaṁ vā bhuñjanto,"
    },
    {
      "id": "mil7.6.10:2.2",
      "pali": "Na bāḷhaṁ suhito siyā;"
    },
    {
      "id": "mil7.6.10:2.3",
      "pali": "Ūnūdaro mitāhāro,"
    },
    {
      "id": "mil7.6.10:2.4",
      "pali": "Sato bhikkhu paribbaje."
    },
    {
      "id": "mil7.6.10:3.1",
      "pali": "Cattāro pañca ālope,"
    },
    {
      "id": "mil7.6.10:3.2",
      "pali": "abhutvā udakaṁ pive;"
    },
    {
      "id": "mil7.6.10:3.3",
      "pali": "Alaṁ phāsu vihārāya,"
    },
    {
      "id": "mil7.6.10:3.4",
      "pali": "pahitattassa bhikkhuno’”ti."
    },
    {
      "id": "mil7.6.10:4.1",
      "pali": "Ajagaraṅgapañho dasamo."
    },
    {
      "id": "mil7.6.10:5.1",
      "pali": "Sīhavaggo pañcamo."
    },
    {
      "id": "mil7.6.10:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "mil7.6.10:7.1",
      "pali": "Kesarī cakkavāko ca,"
    },
    {
      "id": "mil7.6.10:7.2",
      "pali": "peṇāhi gharakapotako;"
    },
    {
      "id": "mil7.6.10:7.3",
      "pali": "Ulūko satapatto ca,"
    },
    {
      "id": "mil7.6.10:7.4",
      "pali": "vagguli ca jalūpikā;"
    },
    {
      "id": "mil7.6.10:7.5",
      "pali": "Sappo ajagaro ceva,"
    },
    {
      "id": "mil7.6.10:7.6",
      "pali": "vaggo tena pavuccatīti."
    }
  ]
}
