{
  "uid": "tha-ap74",
  "title": "Padasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap74:1.1",
      "pali": "“Akkantañca padaṁ disvā,"
    },
    {
      "id": "tha-ap74:1.2",
      "pali": "tissassādiccabandhuno;"
    },
    {
      "id": "tha-ap74:1.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap74:1.4",
      "pali": "pade cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap74:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap74:2.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap74:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap74:2.4",
      "pali": "padasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap74:3.1",
      "pali": "Ito sattamake kappe,"
    },
    {
      "id": "tha-ap74:3.2",
      "pali": "sumedho nāma khattiyo;"
    },
    {
      "id": "tha-ap74:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap74:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap74:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap74:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap74:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap74:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā padasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap74:6.1",
      "pali": "Padasaññakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
