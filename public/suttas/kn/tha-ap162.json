{
  "uid": "tha-ap162",
  "title": "Kumudadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap162:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap162:1.2",
      "pali": "mahājātassaro ahu;"
    },
    {
      "id": "tha-ap162:1.3",
      "pali": "Padumuppalasañchanno,"
    },
    {
      "id": "tha-ap162:1.4",
      "pali": "puṇḍarīkasamotthaṭo."
    },
    {
      "id": "tha-ap162:2.1",
      "pali": "Kukuttho nāma nāmena,"
    },
    {
      "id": "tha-ap162:2.2",
      "pali": "tatthāsiṁ sakuṇo tadā;"
    },
    {
      "id": "tha-ap162:2.3",
      "pali": "Sīlavā buddhisampanno,"
    },
    {
      "id": "tha-ap162:2.4",
      "pali": "puññāpuññesu kovido."
    },
    {
      "id": "tha-ap162:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap162:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap162:3.3",
      "pali": "Jātassarassāvidūre,"
    },
    {
      "id": "tha-ap162:3.4",
      "pali": "sañcarittha mahāmuni."
    },
    {
      "id": "tha-ap162:4.1",
      "pali": "Jalajaṁ kumudaṁ chetvā,"
    },
    {
      "id": "tha-ap162:4.2",
      "pali": "upanesiṁ mahesino;"
    },
    {
      "id": "tha-ap162:4.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap162:4.4",
      "pali": "paṭiggahi mahāmuni."
    },
    {
      "id": "tha-ap162:5.1",
      "pali": "Tañca dānaṁ daditvāna,"
    },
    {
      "id": "tha-ap162:5.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap162:5.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap162:5.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap162:6.1",
      "pali": "Soḷaseto kappasate,"
    },
    {
      "id": "tha-ap162:6.2",
      "pali": "āsuṁ varuṇanāmakā;"
    },
    {
      "id": "tha-ap162:6.3",
      "pali": "Aṭṭha ete janādhipā,"
    },
    {
      "id": "tha-ap162:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap162:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap162:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap162:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap162:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā kumudadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap162:9.1",
      "pali": "Kumudadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap162:10.1",
      "pali": "Bandhujīvakavaggo soḷasamo."
    },
    {
      "id": "tha-ap162:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap162:12.1",
      "pali": "Bandhujīvo tambapupphī,"
    },
    {
      "id": "tha-ap162:12.2",
      "pali": "vīthikakkārupupphiyo;"
    },
    {
      "id": "tha-ap162:12.3",
      "pali": "Mandāravo kadambī ca,"
    },
    {
      "id": "tha-ap162:12.4",
      "pali": "sūlako nāgapupphiyo;"
    },
    {
      "id": "tha-ap162:12.5",
      "pali": "Punnāgo komudī gāthā,"
    },
    {
      "id": "tha-ap162:12.6",
      "pali": "chappaññāsa pakittitāti."
    }
  ]
}
