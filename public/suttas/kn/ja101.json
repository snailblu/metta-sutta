{
  "uid": "ja101",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja101:1.1",
      "pali": "“Parosatañcepi samāgatānaṁ,"
    },
    {
      "id": "ja101:1.2",
      "pali": "Jhāyeyyuṁ te vassasataṁ apaññā;"
    },
    {
      "id": "ja101:1.3",
      "pali": "Ekova seyyo puriso sapañño,"
    },
    {
      "id": "ja101:1.4",
      "pali": "Yo bhāsitassa vijānāti atthan”ti."
    },
    {
      "id": "ja101:2.1",
      "pali": "Parosatajātakaṁ paṭhamaṁ."
    }
  ]
}
