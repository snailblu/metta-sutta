{
  "uid": "tha-ap256",
  "title": "4 Ticampakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap256:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap256:1.2",
      "pali": "vikato nāma pabbato;"
    },
    {
      "id": "tha-ap256:1.3",
      "pali": "Tassa vemajjhe vasati,"
    },
    {
      "id": "tha-ap256:1.4",
      "pali": "samaṇo bhāvitindriyo."
    },
    {
      "id": "tha-ap256:2.1",
      "pali": "Disvāna tassopasamaṁ,"
    },
    {
      "id": "tha-ap256:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap256:2.3",
      "pali": "Tīṇi campakapupphāni,"
    },
    {
      "id": "tha-ap256:2.4",
      "pali": "gahetvāna samokiriṁ."
    },
    {
      "id": "tha-ap256:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap256:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap256:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap256:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap256:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap256:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap256:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap256:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ticampakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap256:6.1",
      "pali": "Ticampakapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
