{
  "uid": "tha-ap22",
  "title": "Sumaṅgalattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap22:1.1",
      "pali": "“Āhutiṁ yiṭṭhukāmohaṁ,"
    },
    {
      "id": "tha-ap22:1.2",
      "pali": "paṭiyādetvāna bhojanaṁ;"
    },
    {
      "id": "tha-ap22:1.3",
      "pali": "Brāhmaṇe paṭimānento,"
    },
    {
      "id": "tha-ap22:1.4",
      "pali": "visāle māḷake ṭhito."
    },
    {
      "id": "tha-ap22:2.1",
      "pali": "Athaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap22:2.2",
      "pali": "piyadassiṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap22:2.3",
      "pali": "Sabbalokavinetāraṁ,"
    },
    {
      "id": "tha-ap22:2.4",
      "pali": "sayambhuṁ aggapuggalaṁ."
    },
    {
      "id": "tha-ap22:3.1",
      "pali": "Bhagavantaṁ jutimantaṁ,"
    },
    {
      "id": "tha-ap22:3.2",
      "pali": "sāvakehi purakkhataṁ;"
    },
    {
      "id": "tha-ap22:3.3",
      "pali": "Ādiccamiva rocantaṁ,"
    },
    {
      "id": "tha-ap22:3.4",
      "pali": "rathiyaṁ paṭipannakaṁ."
    },
    {
      "id": "tha-ap22:4.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap22:4.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap22:4.3",
      "pali": "Manasāva nimantesiṁ,"
    },
    {
      "id": "tha-ap22:4.4",
      "pali": "‘āgacchatu mahāmuni’."
    },
    {
      "id": "tha-ap22:5.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap22:5.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap22:5.3",
      "pali": "Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap22:5.4",
      "pali": "mama dvāraṁ upāgami."
    },
    {
      "id": "tha-ap22:6.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap22:6.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap22:6.3",
      "pali": "Pāsādaṁ abhirūhitvā,"
    },
    {
      "id": "tha-ap22:6.4",
      "pali": "sīhāsane nisīdataṁ."
    },
    {
      "id": "tha-ap22:7.1",
      "pali": "Danto dantaparivāro,"
    },
    {
      "id": "tha-ap22:7.2",
      "pali": "tiṇṇo tārayataṁ varo;"
    },
    {
      "id": "tha-ap22:7.3",
      "pali": "Pāsādaṁ abhirūhitvā,"
    },
    {
      "id": "tha-ap22:7.4",
      "pali": "nisīdi pavarāsane."
    },
    {
      "id": "tha-ap22:8.1",
      "pali": "Yaṁ me atthi sake gehe,"
    },
    {
      "id": "tha-ap22:8.2",
      "pali": "āmisaṁ paccupaṭṭhitaṁ;"
    },
    {
      "id": "tha-ap22:8.3",
      "pali": "Tāhaṁ buddhassa pādāsiṁ,"
    },
    {
      "id": "tha-ap22:8.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap22:9.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap22:9.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap22:9.3",
      "pali": "Buddhaseṭṭhaṁ namassāmi,"
    },
    {
      "id": "tha-ap22:9.4",
      "pali": "aho buddhassuḷāratā."
    },
    {
      "id": "tha-ap22:10.1",
      "pali": "Aṭṭhannaṁ payirūpāsataṁ,"
    },
    {
      "id": "tha-ap22:10.2",
      "pali": "bhuñjaṁ khīṇāsavā bahū;"
    },
    {
      "id": "tha-ap22:10.3",
      "pali": "Tuyheveso ānubhāvo,"
    },
    {
      "id": "tha-ap22:10.4",
      "pali": "saraṇaṁ taṁ upemahaṁ."
    },
    {
      "id": "tha-ap22:11.1",
      "pali": "Piyadassī ca bhagavā,"
    },
    {
      "id": "tha-ap22:11.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap22:11.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap22:11.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap22:12.1",
      "pali": "‘Yo so saṅghaṁ abhojesi,"
    },
    {
      "id": "tha-ap22:12.2",
      "pali": "ujubhūtaṁ samāhitaṁ;"
    },
    {
      "id": "tha-ap22:12.3",
      "pali": "Tathāgatañca sambuddhaṁ,"
    },
    {
      "id": "tha-ap22:12.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap22:13.1",
      "pali": "Sattavīsatikkhattuṁ so,"
    },
    {
      "id": "tha-ap22:13.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap22:13.3",
      "pali": "Sakakammābhiraddho so,"
    },
    {
      "id": "tha-ap22:13.4",
      "pali": "devaloke ramissati."
    },
    {
      "id": "tha-ap22:14.1",
      "pali": "Dasa aṭṭha cakkhattuṁ so,"
    },
    {
      "id": "tha-ap22:14.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap22:14.3",
      "pali": "Pathabyā rajjaṁ pañcasataṁ,"
    },
    {
      "id": "tha-ap22:14.4",
      "pali": "vasudhaṁ āvasissati’."
    },
    {
      "id": "tha-ap22:15.1",
      "pali": "Araññavanamoggayha,"
    },
    {
      "id": "tha-ap22:15.2",
      "pali": "kānanaṁ byagghasevitaṁ;"
    },
    {
      "id": "tha-ap22:15.3",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "tha-ap22:15.4",
      "pali": "kilesā jhāpitā mayā."
    },
    {
      "id": "tha-ap22:16.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap22:16.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap22:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap22:16.4",
      "pali": "bhattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap22:17.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap22:17.2",
      "pali": "Vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap22:17.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap22:17.4",
      "pali": "Kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap22:18.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumaṅgalo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap22:19.1",
      "pali": "Sumaṅgalattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap22:20.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap22:21.1",
      "pali": "Sīhāsanī ekathambhī,"
    },
    {
      "id": "tha-ap22:21.2",
      "pali": "nando ca cūḷapanthako;"
    },
    {
      "id": "tha-ap22:21.3",
      "pali": "Pilindarāhulo ceva,"
    },
    {
      "id": "tha-ap22:21.4",
      "pali": "vaṅganto raṭṭhapālako."
    },
    {
      "id": "tha-ap22:22.1",
      "pali": "Sopāko maṅgalo ceva,"
    },
    {
      "id": "tha-ap22:22.2",
      "pali": "daseva dutiye vagge;"
    },
    {
      "id": "tha-ap22:22.3",
      "pali": "Satañca aṭṭhatiṁsa ca,"
    },
    {
      "id": "tha-ap22:22.4",
      "pali": "gāthā cettha pakāsitā."
    },
    {
      "id": "tha-ap22:23.1",
      "pali": "Sīhāsaniyavaggo dutiyo."
    }
  ]
}
