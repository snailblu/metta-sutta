{
  "uid": "tha-ap19",
  "title": "7 Upasenavaṅgantaputtattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap19:1.1",
      "pali": "“Padumuttaraṁ bhagavantaṁ,"
    },
    {
      "id": "tha-ap19:1.2",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap19:1.3",
      "pali": "Pabbhāramhi nisīdantaṁ,"
    },
    {
      "id": "tha-ap19:1.4",
      "pali": "upagacchiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap19:2.1",
      "pali": "Kaṇikārapupphaṁ disvā,"
    },
    {
      "id": "tha-ap19:2.2",
      "pali": "vaṇṭe chetvānahaṁ tadā;"
    },
    {
      "id": "tha-ap19:2.3",
      "pali": "Alaṅkaritvā chattamhi,"
    },
    {
      "id": "tha-ap19:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap19:3.1",
      "pali": "Piṇḍapātañca pādāsiṁ,"
    },
    {
      "id": "tha-ap19:3.2",
      "pali": "paramannaṁ subhojanaṁ;"
    },
    {
      "id": "tha-ap19:3.3",
      "pali": "Buddhena navame tattha,"
    },
    {
      "id": "tha-ap19:3.4",
      "pali": "samaṇe aṭṭha bhojayiṁ."
    },
    {
      "id": "tha-ap19:4.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap19:4.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap19:4.3",
      "pali": "Iminā chattadānena,"
    },
    {
      "id": "tha-ap19:4.4",
      "pali": "paramannapavecchanā."
    },
    {
      "id": "tha-ap19:5.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap19:5.2",
      "pali": "sampattimanubhossasi;"
    },
    {
      "id": "tha-ap19:5.3",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap19:5.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap19:6.1",
      "pali": "Ekavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap19:6.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap19:6.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap19:6.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap19:7.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap19:7.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap19:7.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap19:7.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap19:8.1",
      "pali": "Sāsane dibbamānamhi,"
    },
    {
      "id": "tha-ap19:8.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap19:8.3",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap19:8.4",
      "pali": "oraso dhammanimmito."
    },
    {
      "id": "tha-ap19:9.1",
      "pali": "Upasenoti nāmena,"
    },
    {
      "id": "tha-ap19:9.2",
      "pali": "hessati satthu sāvako;"
    },
    {
      "id": "tha-ap19:9.3",
      "pali": "Samantapāsādikattā,"
    },
    {
      "id": "tha-ap19:9.4",
      "pali": "aggaṭṭhāne ṭhapessati."
    },
    {
      "id": "tha-ap19:10.1",
      "pali": "Carimaṁ vattate mayhaṁ,"
    },
    {
      "id": "tha-ap19:10.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap19:10.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap19:10.4",
      "pali": "jetvā māraṁ savāhiniṁ."
    },
    {
      "id": "tha-ap19:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap19:11.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap19:11.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap19:11.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap19:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā upaseno vaṅgantaputto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap19:13.1",
      "pali": "Upasenavaṅgantaputtattherassāpadānaṁ sattamaṁ."
    },
    {
      "id": "tha-ap19:13.2",
      "pali": "Tatiyabhāṇavāraṁ."
    }
  ]
}
