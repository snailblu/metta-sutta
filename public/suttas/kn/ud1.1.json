{
  "uid": "ud1.1",
  "title": "Paṭhamabodhisutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud1.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud1.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre bodhirukkhamūle paṭhamābhisambuddho."
    },
    {
      "id": "ud1.1:1.3",
      "pali": "Tena kho pana samayena bhagavā sattāhaṁ ekapallaṅkena nisinno hoti vimuttisukhapaṭisaṁvedī."
    },
    {
      "id": "ud1.1:1.4",
      "pali": "Atha kho bhagavā tassa sattāhassa accayena tamhā samādhimhā vuṭṭhahitvā rattiyā paṭhamaṁ yāmaṁ paṭiccasamuppādaṁ anulomaṁ sādhukaṁ manasākāsi:"
    },
    {
      "id": "ud1.1:2.1",
      "pali": "“Iti imasmiṁ sati idaṁ hoti, imassuppādā idaṁ uppajjati, yadidaṁ—"
    },
    {
      "id": "ud1.1:2.2",
      "pali": "avijjāpaccayā saṅkhārā,"
    },
    {
      "id": "ud1.1:2.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ,"
    },
    {
      "id": "ud1.1:2.4",
      "pali": "viññāṇapaccayā nāmarūpaṁ,"
    },
    {
      "id": "ud1.1:2.5",
      "pali": "nāmarūpapaccayā saḷāyatanaṁ,"
    },
    {
      "id": "ud1.1:2.6",
      "pali": "saḷāyatanapaccayā phasso,"
    },
    {
      "id": "ud1.1:2.7",
      "pali": "phassapaccayā vedanā,"
    },
    {
      "id": "ud1.1:2.8",
      "pali": "vedanāpaccayā taṇhā,"
    },
    {
      "id": "ud1.1:2.9",
      "pali": "taṇhāpaccayā upādānaṁ,"
    },
    {
      "id": "ud1.1:2.10",
      "pali": "upādānapaccayā bhavo,"
    },
    {
      "id": "ud1.1:2.11",
      "pali": "bhavapaccayā jāti,"
    },
    {
      "id": "ud1.1:2.12",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "ud1.1:2.13",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hotī”ti."
    },
    {
      "id": "ud1.1:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud1.1:4.1",
      "pali": "“Yadā have pātubhavanti dhammā,"
    },
    {
      "id": "ud1.1:4.2",
      "pali": "Ātāpino jhāyato brāhmaṇassa;"
    },
    {
      "id": "ud1.1:4.3",
      "pali": "Athassa kaṅkhā vapayanti sabbā,"
    },
    {
      "id": "ud1.1:4.4",
      "pali": "Yato pajānāti sahetudhamman”ti."
    },
    {
      "id": "ud1.1:4.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
