{
  "uid": "ud1.2",
  "title": "Dutiyabodhisutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud1.2:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud1.2:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre bodhirukkhamūle paṭhamābhisambuddho."
    },
    {
      "id": "ud1.2:1.3",
      "pali": "Tena kho pana samayena bhagavā sattāhaṁ ekapallaṅkena nisinno hoti vimuttisukhapaṭisaṁvedī."
    },
    {
      "id": "ud1.2:1.4",
      "pali": "Atha kho bhagavā tassa sattāhassa accayena tamhā samādhimhā vuṭṭhahitvā rattiyā majjhimaṁ yāmaṁ paṭiccasamuppādaṁ paṭilomaṁ sādhukaṁ manasākāsi:"
    },
    {
      "id": "ud1.2:2.1",
      "pali": "“Iti imasmiṁ asati idaṁ na hoti, imassa nirodhā idaṁ nirujjhati, yadidaṁ—"
    },
    {
      "id": "ud1.2:2.2",
      "pali": "avijjānirodhā saṅkhāranirodho,"
    },
    {
      "id": "ud1.2:2.3",
      "pali": "saṅkhāranirodhā viññāṇanirodho,"
    },
    {
      "id": "ud1.2:2.4",
      "pali": "viññāṇanirodhā nāmarūpanirodho,"
    },
    {
      "id": "ud1.2:2.5",
      "pali": "nāmarūpanirodhā saḷāyatananirodho,"
    },
    {
      "id": "ud1.2:2.6",
      "pali": "saḷāyatananirodhā phassanirodho,"
    },
    {
      "id": "ud1.2:2.7",
      "pali": "phassanirodhā vedanānirodho,"
    },
    {
      "id": "ud1.2:2.8",
      "pali": "vedanānirodhā taṇhānirodho,"
    },
    {
      "id": "ud1.2:2.9",
      "pali": "taṇhānirodhā upādānanirodho,"
    },
    {
      "id": "ud1.2:2.10",
      "pali": "upādānanirodhā bhavanirodho,"
    },
    {
      "id": "ud1.2:2.11",
      "pali": "bhavanirodhā jātinirodho,"
    },
    {
      "id": "ud1.2:2.12",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "ud1.2:2.13",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "ud1.2:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud1.2:4.1",
      "pali": "“Yadā have pātubhavanti dhammā,"
    },
    {
      "id": "ud1.2:4.2",
      "pali": "Ātāpino jhāyato brāhmaṇassa;"
    },
    {
      "id": "ud1.2:4.3",
      "pali": "Athassa kaṅkhā vapayanti sabbā,"
    },
    {
      "id": "ud1.2:4.4",
      "pali": "Yato khayaṁ paccayānaṁ avedī”ti."
    },
    {
      "id": "ud1.2:4.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
