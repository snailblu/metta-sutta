{
  "uid": "thag6.14",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.14:1.1",
      "pali": "“Dvipādakoyaṁ asuci,"
    },
    {
      "id": "thag6.14:1.2",
      "pali": "duggandho parihīrati;"
    },
    {
      "id": "thag6.14:1.3",
      "pali": "Nānākuṇapaparipūro,"
    },
    {
      "id": "thag6.14:1.4",
      "pali": "vissavanto tato tato."
    },
    {
      "id": "thag6.14:2.1",
      "pali": "Migaṁ nilīnaṁ kūṭena,"
    },
    {
      "id": "thag6.14:2.2",
      "pali": "baḷiseneva ambujaṁ;"
    },
    {
      "id": "thag6.14:2.3",
      "pali": "Vānaraṁ viya lepena,"
    },
    {
      "id": "thag6.14:2.4",
      "pali": "bādhayanti puthujjanaṁ."
    },
    {
      "id": "thag6.14:3.1",
      "pali": "Rūpā saddā rasā gandhā,"
    },
    {
      "id": "thag6.14:3.2",
      "pali": "phoṭṭhabbā ca manoramā;"
    },
    {
      "id": "thag6.14:3.3",
      "pali": "Pañca kāmaguṇā ete,"
    },
    {
      "id": "thag6.14:3.4",
      "pali": "itthirūpasmi dissare."
    },
    {
      "id": "thag6.14:4.1",
      "pali": "Ye etā upasevanti,"
    },
    {
      "id": "thag6.14:4.2",
      "pali": "rattacittā puthujjanā;"
    },
    {
      "id": "thag6.14:4.3",
      "pali": "Vaḍḍhenti kaṭasiṁ ghoraṁ,"
    },
    {
      "id": "thag6.14:4.4",
      "pali": "ācinanti punabbhavaṁ."
    },
    {
      "id": "thag6.14:5.1",
      "pali": "Yo cetā parivajjeti,"
    },
    {
      "id": "thag6.14:5.2",
      "pali": "sappasseva padā siro;"
    },
    {
      "id": "thag6.14:5.3",
      "pali": "Somaṁ visattikaṁ loke,"
    },
    {
      "id": "thag6.14:5.4",
      "pali": "sato samativattati."
    },
    {
      "id": "thag6.14:6.1",
      "pali": "Kāmesvādīnavaṁ disvā,"
    },
    {
      "id": "thag6.14:6.2",
      "pali": "nekkhammaṁ daṭṭhu khemato;"
    },
    {
      "id": "thag6.14:6.3",
      "pali": "Nissaṭo sabbakāmehi,"
    },
    {
      "id": "thag6.14:6.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag6.14:6.5",
      "pali": "… Sabbakāmitthero …."
    },
    {
      "id": "thag6.14:6.6",
      "pali": "Chakkanipāto niṭṭhito."
    },
    {
      "id": "thag6.14:7.1",
      "pali": "Uruveḷakassapo ca,"
    },
    {
      "id": "thag6.14:7.2",
      "pali": "thero tekicchakāri ca;"
    },
    {
      "id": "thag6.14:7.3",
      "pali": "Mahānāgo ca kullo ca,"
    },
    {
      "id": "thag6.14:7.4",
      "pali": "mālukyo sappadāsako;"
    },
    {
      "id": "thag6.14:7.5",
      "pali": "Kātiyāno migajālo,"
    },
    {
      "id": "thag6.14:7.6",
      "pali": "jento sumanasavhayo;"
    },
    {
      "id": "thag6.14:7.7",
      "pali": "Nhātamuni brahmadatto,"
    },
    {
      "id": "thag6.14:7.8",
      "pali": "sirimaṇḍo sabbakāmī ca;"
    },
    {
      "id": "thag6.14:7.9",
      "pali": "Gāthāyo caturāsīti,"
    },
    {
      "id": "thag6.14:7.10",
      "pali": "therā cettha catuddasāti."
    }
  ]
}
