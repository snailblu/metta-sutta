{
  "uid": "tha-ap510",
  "title": "8 Amodaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap510:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap510:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap510:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap510:1.4",
      "pali": "Āmodamadadiṁ phalaṁ."
    },
    {
      "id": "tha-ap510:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap510:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap510:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap510:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap510:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap510:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap510:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap510:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap510:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap510:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap510:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap510:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap510:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap510:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā amodaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap510:7.1",
      "pali": "Amodaphaliyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
