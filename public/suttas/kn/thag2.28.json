{
  "uid": "thag2.28",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.28:1.1",
      "pali": "“Ehi nandaka gacchāma,"
    },
    {
      "id": "thag2.28:1.2",
      "pali": "upajjhāyassa santikaṁ;"
    },
    {
      "id": "thag2.28:1.3",
      "pali": "Sīhanādaṁ nadissāma,"
    },
    {
      "id": "thag2.28:1.4",
      "pali": "buddhaseṭṭhassa sammukhā."
    },
    {
      "id": "thag2.28:2.1",
      "pali": "Yāya no anukampāya,"
    },
    {
      "id": "thag2.28:2.2",
      "pali": "amhe pabbājayī muni;"
    },
    {
      "id": "thag2.28:2.3",
      "pali": "So no attho anuppatto,"
    },
    {
      "id": "thag2.28:2.4",
      "pali": "sabbasaṁyojanakkhayo”ti."
    },
    {
      "id": "thag2.28:2.5",
      "pali": "… Bharato thero …."
    }
  ]
}
