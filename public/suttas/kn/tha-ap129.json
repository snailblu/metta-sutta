{
  "uid": "tha-ap129",
  "title": "Phaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap129:1.1",
      "pali": "“Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap129:1.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap129:1.3",
      "pali": "Himavantassāvidūre,"
    },
    {
      "id": "tha-ap129:1.4",
      "pali": "vasāmi assame ahaṁ."
    },
    {
      "id": "tha-ap129:2.1",
      "pali": "Aggihuttañca me atthi,"
    },
    {
      "id": "tha-ap129:2.2",
      "pali": "puṇḍarīkaphalāni ca;"
    },
    {
      "id": "tha-ap129:2.3",
      "pali": "Puṭake nikkhipitvāna,"
    },
    {
      "id": "tha-ap129:2.4",
      "pali": "dumagge laggitaṁ mayā."
    },
    {
      "id": "tha-ap129:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap129:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap129:3.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap129:3.4",
      "pali": "bhikkhanto mamupāgami."
    },
    {
      "id": "tha-ap129:4.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap129:4.2",
      "pali": "phalaṁ buddhassadāsahaṁ;"
    },
    {
      "id": "tha-ap129:4.3",
      "pali": "Vittisañjanano mayhaṁ,"
    },
    {
      "id": "tha-ap129:4.4",
      "pali": "diṭṭhadhammasukhāvaho."
    },
    {
      "id": "tha-ap129:5.1",
      "pali": "Suvaṇṇavaṇṇo sambuddho,"
    },
    {
      "id": "tha-ap129:5.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap129:5.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap129:5.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap129:6.1",
      "pali": "‘Iminā phaladānena,"
    },
    {
      "id": "tha-ap129:6.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap129:6.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap129:6.4",
      "pali": "duggatiṁ nupapajjati’."
    },
    {
      "id": "tha-ap129:7.1",
      "pali": "Teneva sukkamūlena,"
    },
    {
      "id": "tha-ap129:7.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap129:7.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap129:7.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap129:8.1",
      "pali": "Ito sattasate kappe,"
    },
    {
      "id": "tha-ap129:8.2",
      "pali": "rājā āsiṁ sumaṅgalo;"
    },
    {
      "id": "tha-ap129:8.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap129:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap129:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap129:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap129:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap129:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap129:11.1",
      "pali": "Phaladāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
