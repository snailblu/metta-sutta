{
  "uid": "tha-ap218",
  "title": "6 Sandhitattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap218:1.1",
      "pali": "“Assatthe haritobhāse,"
    },
    {
      "id": "tha-ap218:1.2",
      "pali": "saṁvirūḷhamhi pādape;"
    },
    {
      "id": "tha-ap218:1.3",
      "pali": "Ekaṁ buddhagataṁ saññaṁ,"
    },
    {
      "id": "tha-ap218:1.4",
      "pali": "alabhiṁhaṁ patissato."
    },
    {
      "id": "tha-ap218:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap218:2.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap218:2.3",
      "pali": "Tassā saññāya vāhasā,"
    },
    {
      "id": "tha-ap218:2.4",
      "pali": "patto me āsavakkhayo."
    },
    {
      "id": "tha-ap218:3.1",
      "pali": "Ito terasakappamhi,"
    },
    {
      "id": "tha-ap218:3.2",
      "pali": "dhaniṭṭho nāma khattiyo;"
    },
    {
      "id": "tha-ap218:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap218:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap218:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap218:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap218:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap218:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā sandhito thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap218:6.1",
      "pali": "Sandhitattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
