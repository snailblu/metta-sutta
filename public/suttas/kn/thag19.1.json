{
  "uid": "thag19.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag19.1:1.1",
      "pali": "“Kadā nuhaṁ pabbatakandarāsu,"
    },
    {
      "id": "thag19.1:1.2",
      "pali": "Ekākiyo addutiyo vihassaṁ;"
    },
    {
      "id": "thag19.1:1.3",
      "pali": "Aniccato sabbabhavaṁ vipassaṁ,"
    },
    {
      "id": "thag19.1:1.4",
      "pali": "Taṁ me idaṁ taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:2.1",
      "pali": "Kadā nuhaṁ bhinnapaṭandharo muni,"
    },
    {
      "id": "thag19.1:2.2",
      "pali": "Kāsāvavattho amamo nirāso;"
    },
    {
      "id": "thag19.1:2.3",
      "pali": "Rāgañca dosañca tatheva mohaṁ,"
    },
    {
      "id": "thag19.1:2.4",
      "pali": "Hantvā sukhī pavanagato vihassaṁ."
    },
    {
      "id": "thag19.1:3.1",
      "pali": "Kadā aniccaṁ vadharoganīḷaṁ,"
    },
    {
      "id": "thag19.1:3.2",
      "pali": "Kāyaṁ imaṁ maccujarāyupaddutaṁ;"
    },
    {
      "id": "thag19.1:3.3",
      "pali": "Vipassamāno vītabhayo vihassaṁ,"
    },
    {
      "id": "thag19.1:3.4",
      "pali": "Eko vane taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:4.1",
      "pali": "Kadā nuhaṁ bhayajananiṁ dukhāvahaṁ,"
    },
    {
      "id": "thag19.1:4.2",
      "pali": "Taṇhālataṁ bahuvidhānuvattaniṁ;"
    },
    {
      "id": "thag19.1:4.3",
      "pali": "Paññāmayaṁ tikhiṇamasiṁ gahetvā,"
    },
    {
      "id": "thag19.1:4.4",
      "pali": "Chetvā vase tampi kadā bhavissati."
    },
    {
      "id": "thag19.1:5.1",
      "pali": "Kadā nu paññāmayamuggatejaṁ,"
    },
    {
      "id": "thag19.1:5.2",
      "pali": "Satthaṁ isīnaṁ sahasādiyitvā;"
    },
    {
      "id": "thag19.1:5.3",
      "pali": "Māraṁ sasenaṁ sahasā bhañjissaṁ,"
    },
    {
      "id": "thag19.1:5.4",
      "pali": "Sīhāsane taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:6.1",
      "pali": "Kadā nuhaṁ sabbhi samāgamesu,"
    },
    {
      "id": "thag19.1:6.2",
      "pali": "Diṭṭho bhave dhammagarūhi tādibhi;"
    },
    {
      "id": "thag19.1:6.3",
      "pali": "Yāthāvadassīhi jitindriyehi,"
    },
    {
      "id": "thag19.1:6.4",
      "pali": "Padhāniyo taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:7.1",
      "pali": "Kadā nu maṁ tandi khudā pipāsā,"
    },
    {
      "id": "thag19.1:7.2",
      "pali": "Vātātapā kīṭasarīsapā vā;"
    },
    {
      "id": "thag19.1:7.3",
      "pali": "Na bādhayissanti na taṁ giribbaje,"
    },
    {
      "id": "thag19.1:7.4",
      "pali": "Atthatthiyaṁ taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:8.1",
      "pali": "Kadā nu kho yaṁ viditaṁ mahesinā,"
    },
    {
      "id": "thag19.1:8.2",
      "pali": "Cattāri saccāni sududdasāni;"
    },
    {
      "id": "thag19.1:8.3",
      "pali": "Samāhitatto satimā agacchaṁ,"
    },
    {
      "id": "thag19.1:8.4",
      "pali": "Paññāya taṁ taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:9.1",
      "pali": "Kadā nu rūpe amite ca sadde,"
    },
    {
      "id": "thag19.1:9.2",
      "pali": "Gandhe rase phusitabbe ca dhamme;"
    },
    {
      "id": "thag19.1:9.3",
      "pali": "Ādittatohaṁ samathehi yutto,"
    },
    {
      "id": "thag19.1:9.4",
      "pali": "Paññāya dacchaṁ tadidaṁ kadā me."
    },
    {
      "id": "thag19.1:10.1",
      "pali": "Kadā nuhaṁ dubbacanena vutto,"
    },
    {
      "id": "thag19.1:10.2",
      "pali": "Tato nimittaṁ vimano na hessaṁ;"
    },
    {
      "id": "thag19.1:10.3",
      "pali": "Atho pasatthopi tato nimittaṁ,"
    },
    {
      "id": "thag19.1:10.4",
      "pali": "Tuṭṭho na hessaṁ tadidaṁ kadā me."
    },
    {
      "id": "thag19.1:11.1",
      "pali": "Kadā nu kaṭṭhe ca tiṇe latā ca,"
    },
    {
      "id": "thag19.1:11.2",
      "pali": "Khandhe imehaṁ amite ca dhamme;"
    },
    {
      "id": "thag19.1:11.3",
      "pali": "Ajjhattikāneva ca bāhirāni ca,"
    },
    {
      "id": "thag19.1:11.4",
      "pali": "Samaṁ tuleyyaṁ tadidaṁ kadā me."
    },
    {
      "id": "thag19.1:12.1",
      "pali": "Kadā nu maṁ pāvusakālamegho,"
    },
    {
      "id": "thag19.1:12.2",
      "pali": "Navena toyena sacīvaraṁ vane;"
    },
    {
      "id": "thag19.1:12.3",
      "pali": "Isippayātamhi pathe vajantaṁ,"
    },
    {
      "id": "thag19.1:12.4",
      "pali": "Ovassate taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:13.1",
      "pali": "Kadā mayūrassa sikhaṇḍino vane,"
    },
    {
      "id": "thag19.1:13.2",
      "pali": "Dijassa sutvā girigabbhare rutaṁ;"
    },
    {
      "id": "thag19.1:13.3",
      "pali": "Paccuṭṭhahitvā amatassa pattiyā,"
    },
    {
      "id": "thag19.1:13.4",
      "pali": "Sañcintaye taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:14.1",
      "pali": "Kadā nu gaṅgaṁ yamunaṁ sarassatiṁ,"
    },
    {
      "id": "thag19.1:14.2",
      "pali": "Pātālakhittaṁ vaḷavāmukhañca;"
    },
    {
      "id": "thag19.1:14.3",
      "pali": "Asajjamāno patareyyamiddhiyā,"
    },
    {
      "id": "thag19.1:14.4",
      "pali": "Vibhiṁsanaṁ taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:15.1",
      "pali": "Kadā nu nāgova asaṅgacārī,"
    },
    {
      "id": "thag19.1:15.2",
      "pali": "Padālaye kāmaguṇesu chandaṁ;"
    },
    {
      "id": "thag19.1:15.3",
      "pali": "Nibbajjayaṁ sabbasubhaṁ nimittaṁ,"
    },
    {
      "id": "thag19.1:15.4",
      "pali": "Jhāne yuto taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:16.1",
      "pali": "Kadā iṇaṭṭova daliddako nidhiṁ,"
    },
    {
      "id": "thag19.1:16.2",
      "pali": "Ārādhayitvā dhanikehi pīḷito;"
    },
    {
      "id": "thag19.1:16.3",
      "pali": "Tuṭṭho bhavissaṁ adhigamma sāsanaṁ,"
    },
    {
      "id": "thag19.1:16.4",
      "pali": "Mahesino taṁ nu kadā bhavissati."
    },
    {
      "id": "thag19.1:17.1",
      "pali": "Bahūni vassāni tayāmhi yācito,"
    },
    {
      "id": "thag19.1:17.2",
      "pali": "‘Agāravāsena alaṁ nu te idaṁ’;"
    },
    {
      "id": "thag19.1:17.3",
      "pali": "Taṁ dāni maṁ pabbajitaṁ samānaṁ,"
    },
    {
      "id": "thag19.1:17.4",
      "pali": "Kiṅkāraṇā citta tuvaṁ na yuñjasi."
    },
    {
      "id": "thag19.1:18.1",
      "pali": "Nanu ahaṁ citta tayāmhi yācito,"
    },
    {
      "id": "thag19.1:18.2",
      "pali": "‘Giribbaje citrachadā vihaṅgamā’;"
    },
    {
      "id": "thag19.1:18.3",
      "pali": "Mahindaghosatthanitābhigajjino,"
    },
    {
      "id": "thag19.1:18.4",
      "pali": "Te taṁ ramessanti vanamhi jhāyinaṁ."
    },
    {
      "id": "thag19.1:19.1",
      "pali": "Kulamhi mitte ca piye ca ñātake,"
    },
    {
      "id": "thag19.1:19.2",
      "pali": "Khiḍḍāratiṁ kāmaguṇañca loke;"
    },
    {
      "id": "thag19.1:19.3",
      "pali": "Sabbaṁ pahāya imamajjhupāgato,"
    },
    {
      "id": "thag19.1:19.4",
      "pali": "Athopi tvaṁ citta na mayha tussasi."
    },
    {
      "id": "thag19.1:20.1",
      "pali": "Mameva etaṁ na hi tvaṁ paresaṁ,"
    },
    {
      "id": "thag19.1:20.2",
      "pali": "Sannāhakāle paridevitena kiṁ;"
    },
    {
      "id": "thag19.1:20.3",
      "pali": "Sabbaṁ idaṁ calamiti pekkhamāno,"
    },
    {
      "id": "thag19.1:20.4",
      "pali": "Abhinikkhamiṁ amatapadaṁ jigīsaṁ."
    },
    {
      "id": "thag19.1:21.1",
      "pali": "Suyuttavādī dvipadānamuttamo,"
    },
    {
      "id": "thag19.1:21.2",
      "pali": "Mahābhisakko naradammasārathi;"
    },
    {
      "id": "thag19.1:21.3",
      "pali": "‘Cittaṁ calaṁ makkaṭasannibhaṁ iti,"
    },
    {
      "id": "thag19.1:21.4",
      "pali": "Avītarāgena sudunnivārayaṁ’."
    },
    {
      "id": "thag19.1:22.1",
      "pali": "Kāmā hi citrā madhurā manoramā,"
    },
    {
      "id": "thag19.1:22.2",
      "pali": "Aviddasū yattha sitā puthujjanā;"
    },
    {
      "id": "thag19.1:22.3",
      "pali": "Te dukkhamicchanti punabbhavesino,"
    },
    {
      "id": "thag19.1:22.4",
      "pali": "Cittena nītā niraye nirākatā."
    },
    {
      "id": "thag19.1:23.1",
      "pali": "‘Mayūrakoñcābhirutamhi kānane,"
    },
    {
      "id": "thag19.1:23.2",
      "pali": "Dīpīhi byagghehi purakkhato vasaṁ;"
    },
    {
      "id": "thag19.1:23.3",
      "pali": "Kāye apekkhaṁ jaha mā virādhaya’,"
    },
    {
      "id": "thag19.1:23.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:24.1",
      "pali": "‘Bhāvehi jhānāni ca indriyāni ca,"
    },
    {
      "id": "thag19.1:24.2",
      "pali": "Balāni bojjhaṅgasamādhibhāvanā;"
    },
    {
      "id": "thag19.1:24.3",
      "pali": "Tisso ca vijjā phusa buddhasāsane’,"
    },
    {
      "id": "thag19.1:24.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:25.1",
      "pali": "‘Bhāvehi maggaṁ amatassa pattiyā,"
    },
    {
      "id": "thag19.1:25.2",
      "pali": "Niyyānikaṁ sabbadukhakkhayogadhaṁ;"
    },
    {
      "id": "thag19.1:25.3",
      "pali": "Aṭṭhaṅgikaṁ sabbakilesasodhanaṁ’,"
    },
    {
      "id": "thag19.1:25.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:26.1",
      "pali": "‘Dukkhanti khandhe paṭipassa yoniso,"
    },
    {
      "id": "thag19.1:26.2",
      "pali": "Yato ca dukkhaṁ samudeti taṁ jaha;"
    },
    {
      "id": "thag19.1:26.3",
      "pali": "Idheva dukkhassa karohi antaṁ’,"
    },
    {
      "id": "thag19.1:26.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:27.1",
      "pali": "‘Aniccaṁ dukkhanti vipassa yoniso,"
    },
    {
      "id": "thag19.1:27.2",
      "pali": "Suññaṁ anattāti aghaṁ vadhanti ca;"
    },
    {
      "id": "thag19.1:27.3",
      "pali": "Manovicāre uparundha cetaso’,"
    },
    {
      "id": "thag19.1:27.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:28.1",
      "pali": "‘Muṇḍo virūpo abhisāpamāgato,"
    },
    {
      "id": "thag19.1:28.2",
      "pali": "Kapālahatthova kulesu bhikkhasu;"
    },
    {
      "id": "thag19.1:28.3",
      "pali": "Yuñjassu satthuvacane mahesino’,"
    },
    {
      "id": "thag19.1:28.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:29.1",
      "pali": "‘Susaṁvutatto visikhantare caraṁ,"
    },
    {
      "id": "thag19.1:29.2",
      "pali": "Kulesu kāmesu asaṅgamānaso;"
    },
    {
      "id": "thag19.1:29.3",
      "pali": "Cando yathā dosinapuṇṇamāsiyā’,"
    },
    {
      "id": "thag19.1:29.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:30.1",
      "pali": "‘Āraññiko hohi ca piṇḍapātiko,"
    },
    {
      "id": "thag19.1:30.2",
      "pali": "Sosāniko hohi ca paṁsukūliko;"
    },
    {
      "id": "thag19.1:30.3",
      "pali": "Nesajjiko hohi sadā dhute rato’,"
    },
    {
      "id": "thag19.1:30.4",
      "pali": "Itissu maṁ citta pure niyuñjasi."
    },
    {
      "id": "thag19.1:31.1",
      "pali": "Ropetva rukkhāni yathā phalesī,"
    },
    {
      "id": "thag19.1:31.2",
      "pali": "Mūle taruṁ chettu tameva icchasi;"
    },
    {
      "id": "thag19.1:31.3",
      "pali": "Tathūpamaṁ cittamidaṁ karosi,"
    },
    {
      "id": "thag19.1:31.4",
      "pali": "Yaṁ maṁ aniccamhi cale niyuñjasi."
    },
    {
      "id": "thag19.1:32.1",
      "pali": "Arūpa dūraṅgama ekacāri,"
    },
    {
      "id": "thag19.1:32.2",
      "pali": "Na te karissaṁ vacanaṁ idānihaṁ;"
    },
    {
      "id": "thag19.1:32.3",
      "pali": "Dukkhā hi kāmā kaṭukā mahabbhayā,"
    },
    {
      "id": "thag19.1:32.4",
      "pali": "Nibbānamevābhimano carissaṁ."
    },
    {
      "id": "thag19.1:33.1",
      "pali": "Nāhaṁ alakkhyā ahirikkatāya vā,"
    },
    {
      "id": "thag19.1:33.2",
      "pali": "Na cittahetū na ca dūrakantanā;"
    },
    {
      "id": "thag19.1:33.3",
      "pali": "Ājīvahetū ca ahaṁ na nikkhamiṁ,"
    },
    {
      "id": "thag19.1:33.4",
      "pali": "Kato ca te citta paṭissavo mayā."
    },
    {
      "id": "thag19.1:34.1",
      "pali": "‘Appicchatā sappurisehi vaṇṇitā,"
    },
    {
      "id": "thag19.1:34.2",
      "pali": "Makkhappahānaṁ vupasamo dukhassa’;"
    },
    {
      "id": "thag19.1:34.3",
      "pali": "Itissu maṁ citta tadā niyuñjasi,"
    },
    {
      "id": "thag19.1:34.4",
      "pali": "Idāni tvaṁ gacchasi pubbaciṇṇaṁ."
    },
    {
      "id": "thag19.1:35.1",
      "pali": "Taṇhā avijjā ca piyāpiyañca,"
    },
    {
      "id": "thag19.1:35.2",
      "pali": "Subhāni rūpāni sukhā ca vedanā;"
    },
    {
      "id": "thag19.1:35.3",
      "pali": "Manāpiyā kāmaguṇā ca vantā,"
    },
    {
      "id": "thag19.1:35.4",
      "pali": "Vante ahaṁ āvamituṁ na ussahe."
    },
    {
      "id": "thag19.1:36.1",
      "pali": "Sabbattha te citta vaco kataṁ mayā,"
    },
    {
      "id": "thag19.1:36.2",
      "pali": "Bahūsu jātīsu na mesi kopito;"
    },
    {
      "id": "thag19.1:36.3",
      "pali": "Ajjhattasambhavo kataññutāya te,"
    },
    {
      "id": "thag19.1:36.4",
      "pali": "Dukkhe ciraṁ saṁsaritaṁ tayā kate."
    },
    {
      "id": "thag19.1:37.1",
      "pali": "Tvaññeva no citta karosi brāhmaṇo,"
    },
    {
      "id": "thag19.1:37.2",
      "pali": "Tvaṁ khattiyo rājadasī karosi;"
    },
    {
      "id": "thag19.1:37.3",
      "pali": "Vessā ca suddā ca bhavāma ekadā,"
    },
    {
      "id": "thag19.1:37.4",
      "pali": "Devattanaṁ vāpi taveva vāhasā."
    },
    {
      "id": "thag19.1:38.1",
      "pali": "Taveva hetū asurā bhavāmase,"
    },
    {
      "id": "thag19.1:38.2",
      "pali": "Tvaṁmūlakaṁ nerayikā bhavāmase;"
    },
    {
      "id": "thag19.1:38.3",
      "pali": "Atho tiracchānagatāpi ekadā,"
    },
    {
      "id": "thag19.1:38.4",
      "pali": "Petattanaṁ vāpi taveva vāhasā."
    },
    {
      "id": "thag19.1:39.1",
      "pali": "Nanu dubbhissasi maṁ punappunaṁ,"
    },
    {
      "id": "thag19.1:39.2",
      "pali": "Muhuṁ muhuṁ cāraṇikaṁva dassayaṁ;"
    },
    {
      "id": "thag19.1:39.3",
      "pali": "Ummattakeneva mayā palobhasi,"
    },
    {
      "id": "thag19.1:39.4",
      "pali": "Kiñcāpi te citta virādhitaṁ mayā."
    },
    {
      "id": "thag19.1:40.1",
      "pali": "Idaṁ pure cittamacāri cārikaṁ,"
    },
    {
      "id": "thag19.1:40.2",
      "pali": "Yenicchakaṁ yatthakāmaṁ yathāsukhaṁ;"
    },
    {
      "id": "thag19.1:40.3",
      "pali": "Tadajjahaṁ niggahessāmi yoniso,"
    },
    {
      "id": "thag19.1:40.4",
      "pali": "Hatthippabhinnaṁ viya aṅkusaggaho."
    },
    {
      "id": "thag19.1:41.1",
      "pali": "Satthā ca me lokamimaṁ adhiṭṭhahi,"
    },
    {
      "id": "thag19.1:41.2",
      "pali": "Aniccato addhuvato asārato;"
    },
    {
      "id": "thag19.1:41.3",
      "pali": "Pakkhanda maṁ citta jinassa sāsane,"
    },
    {
      "id": "thag19.1:41.4",
      "pali": "Tārehi oghā mahatā suduttarā."
    },
    {
      "id": "thag19.1:42.1",
      "pali": "Na te idaṁ citta yathā purāṇakaṁ,"
    },
    {
      "id": "thag19.1:42.2",
      "pali": "Nāhaṁ alaṁ tuyha vase nivattituṁ;"
    },
    {
      "id": "thag19.1:42.3",
      "pali": "Mahesino pabbajitomhi sāsane,"
    },
    {
      "id": "thag19.1:42.4",
      "pali": "Na mādisā honti vināsadhārino."
    },
    {
      "id": "thag19.1:43.1",
      "pali": "Nagā samuddā saritā vasundharā,"
    },
    {
      "id": "thag19.1:43.2",
      "pali": "Disā catasso vidisā adho divā;"
    },
    {
      "id": "thag19.1:43.3",
      "pali": "Sabbe aniccā tibhavā upaddutā,"
    },
    {
      "id": "thag19.1:43.4",
      "pali": "Kuhiṁ gato citta sukhaṁ ramissasi."
    },
    {
      "id": "thag19.1:44.1",
      "pali": "Dhitipparaṁ kiṁ mama citta kāhisi,"
    },
    {
      "id": "thag19.1:44.2",
      "pali": "Na te alaṁ citta vasānuvattako;"
    },
    {
      "id": "thag19.1:44.3",
      "pali": "Na jātu bhastaṁ ubhatomukhaṁ chupe,"
    },
    {
      "id": "thag19.1:44.4",
      "pali": "Dhiratthu pūraṁ nava sotasandaniṁ."
    },
    {
      "id": "thag19.1:45.1",
      "pali": "Varāhaeṇeyyavigāḷhasevite,"
    },
    {
      "id": "thag19.1:45.2",
      "pali": "Pabbhārakuṭṭe pakateva sundare;"
    },
    {
      "id": "thag19.1:45.3",
      "pali": "Navambunā pāvusasitthakānane,"
    },
    {
      "id": "thag19.1:45.4",
      "pali": "Tahiṁ guhāgehagato ramissasi."
    },
    {
      "id": "thag19.1:46.1",
      "pali": "Sunīlagīvā susikhā supekhunā,"
    },
    {
      "id": "thag19.1:46.2",
      "pali": "Sucittapattacchadanā vihaṅgamā;"
    },
    {
      "id": "thag19.1:46.3",
      "pali": "Sumañjughosatthanitābhigajjino,"
    },
    {
      "id": "thag19.1:46.4",
      "pali": "Te taṁ ramessanti vanamhi jhāyinaṁ."
    },
    {
      "id": "thag19.1:47.1",
      "pali": "Vuṭṭhamhi deve caturaṅgule tiṇe,"
    },
    {
      "id": "thag19.1:47.2",
      "pali": "Sampupphite meghanibhamhi kānane;"
    },
    {
      "id": "thag19.1:47.3",
      "pali": "Nagantare viṭapisamo sayissaṁ,"
    },
    {
      "id": "thag19.1:47.4",
      "pali": "Taṁ me mudū hehiti tūlasannibhaṁ."
    },
    {
      "id": "thag19.1:48.1",
      "pali": "Tathā tu kassāmi yathāpi issaro,"
    },
    {
      "id": "thag19.1:48.2",
      "pali": "Yaṁ labbhati tenapi hotu me alaṁ;"
    },
    {
      "id": "thag19.1:48.3",
      "pali": "Na tāhaṁ kassāmi yathā atandito,"
    },
    {
      "id": "thag19.1:48.4",
      "pali": "Biḷārabhastaṁva yathā sumadditaṁ."
    },
    {
      "id": "thag19.1:49.1",
      "pali": "Tathā tu kassāmi yathāpi issaro,"
    },
    {
      "id": "thag19.1:49.2",
      "pali": "Yaṁ labbhati tenapi hotu me alaṁ;"
    },
    {
      "id": "thag19.1:49.3",
      "pali": "Viriyena taṁ mayha vasānayissaṁ,"
    },
    {
      "id": "thag19.1:49.4",
      "pali": "Gajaṁva mattaṁ kusalaṅkusaggaho."
    },
    {
      "id": "thag19.1:50.1",
      "pali": "Tayā sudantena avaṭṭhitena hi,"
    },
    {
      "id": "thag19.1:50.2",
      "pali": "Hayena yoggācariyova ujjunā;"
    },
    {
      "id": "thag19.1:50.3",
      "pali": "Pahomi maggaṁ paṭipajjituṁ sivaṁ,"
    },
    {
      "id": "thag19.1:50.4",
      "pali": "Cittānurakkhīhi sadā nisevitaṁ."
    },
    {
      "id": "thag19.1:51.1",
      "pali": "Ārammaṇe taṁ balasā nibandhisaṁ,"
    },
    {
      "id": "thag19.1:51.2",
      "pali": "Nāgaṁva thambhamhi daḷhāya rajjuyā;"
    },
    {
      "id": "thag19.1:51.3",
      "pali": "Taṁ me suguttaṁ satiyā subhāvitaṁ,"
    },
    {
      "id": "thag19.1:51.4",
      "pali": "Anissitaṁ sabbabhavesu hehisi."
    },
    {
      "id": "thag19.1:52.1",
      "pali": "Paññāya chetvā vipathānusārinaṁ,"
    },
    {
      "id": "thag19.1:52.2",
      "pali": "Yogena niggayha pathe nivesiya;"
    },
    {
      "id": "thag19.1:52.3",
      "pali": "Disvā samudayaṁ vibhavañca sambhavaṁ,"
    },
    {
      "id": "thag19.1:52.4",
      "pali": "Dāyādako hehisi aggavādino."
    },
    {
      "id": "thag19.1:53.1",
      "pali": "Catubbipallāsavasaṁ adhiṭṭhitaṁ,"
    },
    {
      "id": "thag19.1:53.2",
      "pali": "Gāmaṇḍalaṁva parinesi citta maṁ;"
    },
    {
      "id": "thag19.1:53.3",
      "pali": "Nanu saṁyojanabandhanacchidaṁ,"
    },
    {
      "id": "thag19.1:53.4",
      "pali": "Saṁsevase kāruṇikaṁ mahāmuniṁ."
    },
    {
      "id": "thag19.1:54.1",
      "pali": "Migo yathā seri sucittakānane,"
    },
    {
      "id": "thag19.1:54.2",
      "pali": "Rammaṁ giriṁ pāvusaabbhamāliniṁ;"
    },
    {
      "id": "thag19.1:54.3",
      "pali": "Anākule tattha nage ramissaṁ,"
    },
    {
      "id": "thag19.1:54.4",
      "pali": "Asaṁsayaṁ citta parā bhavissasi."
    },
    {
      "id": "thag19.1:55.1",
      "pali": "Ye tuyha chandena vasena vattino,"
    },
    {
      "id": "thag19.1:55.2",
      "pali": "Narā ca nārī ca anubhonti yaṁ sukhaṁ;"
    },
    {
      "id": "thag19.1:55.3",
      "pali": "Aviddasū māravasānuvattino,"
    },
    {
      "id": "thag19.1:55.4",
      "pali": "Bhavābhinandī tava citta sāvakā”ti."
    },
    {
      "id": "thag19.1:55.5",
      "pali": "… Tālapuṭo thero …"
    },
    {
      "id": "thag19.1:55.6",
      "pali": "Paññāsanipāto niṭṭhito."
    },
    {
      "id": "thag19.1:56.1",
      "pali": "Paññāsamhi nipātamhi,"
    },
    {
      "id": "thag19.1:56.2",
      "pali": "eko tālapuṭo suci;"
    },
    {
      "id": "thag19.1:56.3",
      "pali": "Gāthāyo tattha paññāsa,"
    },
    {
      "id": "thag19.1:56.4",
      "pali": "puna pañca ca uttarīti."
    }
  ]
}
