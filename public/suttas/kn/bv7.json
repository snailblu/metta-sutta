{
  "uid": "bv7",
  "title": "7. Revatabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv7:1.1",
      "pali": "Sumanassa aparena,"
    },
    {
      "id": "bv7:1.2",
      "pali": "revato nāma nāyako;"
    },
    {
      "id": "bv7:1.3",
      "pali": "Anūpamo asadiso,"
    },
    {
      "id": "bv7:1.4",
      "pali": "atulo uttamo jino."
    },
    {
      "id": "bv7:2.1",
      "pali": "Sopi dhammaṁ pakāsesi,"
    },
    {
      "id": "bv7:2.2",
      "pali": "brahmunā abhiyācito;"
    },
    {
      "id": "bv7:2.3",
      "pali": "Khandhadhātuvavatthānaṁ,"
    },
    {
      "id": "bv7:2.4",
      "pali": "appavattaṁ bhavābhave."
    },
    {
      "id": "bv7:3.1",
      "pali": "Tassābhisamayā tīṇi,"
    },
    {
      "id": "bv7:3.2",
      "pali": "ahesuṁ dhammadesane;"
    },
    {
      "id": "bv7:3.3",
      "pali": "Gaṇanāya na vattabbo,"
    },
    {
      "id": "bv7:3.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv7:4.1",
      "pali": "Yadā arindamaṁ rājaṁ,"
    },
    {
      "id": "bv7:4.2",
      "pali": "vinesi revato muni;"
    },
    {
      "id": "bv7:4.3",
      "pali": "Tadā koṭisahassānaṁ,"
    },
    {
      "id": "bv7:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv7:5.1",
      "pali": "Sattāhaṁ paṭisallānā,"
    },
    {
      "id": "bv7:5.2",
      "pali": "vuṭṭhahitvā narāsabho;"
    },
    {
      "id": "bv7:5.3",
      "pali": "Koṭisataṁ naramarūnaṁ,"
    },
    {
      "id": "bv7:5.4",
      "pali": "vinesi uttame phale."
    },
    {
      "id": "bv7:6.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv7:6.2",
      "pali": "revatassa mahesino;"
    },
    {
      "id": "bv7:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv7:6.4",
      "pali": "suvimuttāna tādinaṁ."
    },
    {
      "id": "bv7:7.1",
      "pali": "Atikkantā gaṇanapathaṁ,"
    },
    {
      "id": "bv7:7.2",
      "pali": "paṭhamaṁ ye samāgatā;"
    },
    {
      "id": "bv7:7.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv7:7.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv7:8.1",
      "pali": "Yopi paññāya asamo,"
    },
    {
      "id": "bv7:8.2",
      "pali": "tassa cakkānuvattako;"
    },
    {
      "id": "bv7:8.3",
      "pali": "So tadā byādhito āsi,"
    },
    {
      "id": "bv7:8.4",
      "pali": "patto jīvitasaṁsayaṁ."
    },
    {
      "id": "bv7:9.1",
      "pali": "Tassa gilānapucchāya,"
    },
    {
      "id": "bv7:9.2",
      "pali": "ye tadā upagatā munī;"
    },
    {
      "id": "bv7:9.3",
      "pali": "Koṭisahassā arahanto,"
    },
    {
      "id": "bv7:9.4",
      "pali": "tatiyo āsi samāgamo."
    },
    {
      "id": "bv7:10.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv7:10.2",
      "pali": "atidevo nāma brāhmaṇo;"
    },
    {
      "id": "bv7:10.3",
      "pali": "Upagantvā revataṁ buddhaṁ,"
    },
    {
      "id": "bv7:10.4",
      "pali": "saraṇaṁ tassa gañchahaṁ."
    },
    {
      "id": "bv7:11.1",
      "pali": "Tassa sīlaṁ samādhiñca,"
    },
    {
      "id": "bv7:11.2",
      "pali": "paññāguṇamanuttamaṁ;"
    },
    {
      "id": "bv7:11.3",
      "pali": "Thomayitvā yathāthāmaṁ,"
    },
    {
      "id": "bv7:11.4",
      "pali": "uttarīyamadāsahaṁ."
    },
    {
      "id": "bv7:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv7:12.2",
      "pali": "revato lokanāyako;"
    },
    {
      "id": "bv7:12.3",
      "pali": "“Aparimeyyito kappe,"
    },
    {
      "id": "bv7:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv7:13.1",
      "pali": "‘Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv7:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv7:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv7:14.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv7:14.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv7:14.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv7:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv7:15.1",
      "pali": "Tadāpi taṁ buddhadhammaṁ,"
    },
    {
      "id": "bv7:15.2",
      "pali": "saritvā anubrūhayiṁ;"
    },
    {
      "id": "bv7:15.3",
      "pali": "Āharissāmi taṁ dhammaṁ,"
    },
    {
      "id": "bv7:15.4",
      "pali": "yaṁ mayhaṁ abhipatthitaṁ."
    },
    {
      "id": "bv7:16.1",
      "pali": "Nagaraṁ sudhaññavatī nāma,"
    },
    {
      "id": "bv7:16.2",
      "pali": "Vipulo nāma khattiyo;"
    },
    {
      "id": "bv7:16.3",
      "pali": "Vipulā nāma janikā,"
    },
    {
      "id": "bv7:16.4",
      "pali": "Revatassa mahesino."
    },
    {
      "id": "bv7:17.1",
      "pali": "Cha ca vassasahassāni,"
    },
    {
      "id": "bv7:17.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv7:17.3",
      "pali": "Sudassano ratanagghi,"
    },
    {
      "id": "bv7:17.4",
      "pali": "āveḷo ca vibhūsito;"
    },
    {
      "id": "bv7:17.5",
      "pali": "Puññakammābhinibbattā,"
    },
    {
      "id": "bv7:17.6",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv7:18.1",
      "pali": "Tettiṁsa ca sahassāni,"
    },
    {
      "id": "bv7:18.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv7:18.3",
      "pali": "Sudassanā nāma nārī,"
    },
    {
      "id": "bv7:18.4",
      "pali": "varuṇo nāma atrajo."
    },
    {
      "id": "bv7:19.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv7:19.2",
      "pali": "rathayānena nikkhami;"
    },
    {
      "id": "bv7:19.3",
      "pali": "Anūnasattamāsāni,"
    },
    {
      "id": "bv7:19.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv7:20.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv7:20.2",
      "pali": "revato lokanāyako;"
    },
    {
      "id": "bv7:20.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv7:20.4",
      "pali": "varuṇārāme sirīghare."
    },
    {
      "id": "bv7:21.1",
      "pali": "Varuṇo brahmadevo ca,"
    },
    {
      "id": "bv7:21.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv7:21.3",
      "pali": "Sambhavo nāmupaṭṭhāko,"
    },
    {
      "id": "bv7:21.4",
      "pali": "revatassa mahesino."
    },
    {
      "id": "bv7:22.1",
      "pali": "Bhaddā ceva subhaddā ca,"
    },
    {
      "id": "bv7:22.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv7:22.3",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv7:22.4",
      "pali": "nāgamūle abujjhatha."
    },
    {
      "id": "bv7:23.1",
      "pali": "Padumo kuñjaro ceva,"
    },
    {
      "id": "bv7:23.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv7:23.3",
      "pali": "Sirīmā ceva yasavatī,"
    },
    {
      "id": "bv7:23.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv7:24.1",
      "pali": "Uccattanena so buddho,"
    },
    {
      "id": "bv7:24.2",
      "pali": "asītihatthamuggato;"
    },
    {
      "id": "bv7:24.3",
      "pali": "Obhāseti disā sabbā,"
    },
    {
      "id": "bv7:24.4",
      "pali": "indaketuva uggato."
    },
    {
      "id": "bv7:25.1",
      "pali": "Tassa sarīre nibbattā,"
    },
    {
      "id": "bv7:25.2",
      "pali": "pabhāmālā anuttarā;"
    },
    {
      "id": "bv7:25.3",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "bv7:25.4",
      "pali": "samantā pharati yojanaṁ."
    },
    {
      "id": "bv7:26.1",
      "pali": "Saṭṭhivassasahassāni,"
    },
    {
      "id": "bv7:26.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv7:26.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv7:26.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv7:27.1",
      "pali": "Dassayitvā buddhabalaṁ,"
    },
    {
      "id": "bv7:27.2",
      "pali": "amataṁ loke pakāsayaṁ;"
    },
    {
      "id": "bv7:27.3",
      "pali": "Nibbāyi anupādāno,"
    },
    {
      "id": "bv7:27.4",
      "pali": "yathaggupādānasaṅkhayā."
    },
    {
      "id": "bv7:28.1",
      "pali": "So ca kāyo ratananibho,"
    },
    {
      "id": "bv7:28.2",
      "pali": "so ca dhammo asādiso;"
    },
    {
      "id": "bv7:28.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv7:28.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv7:29.1",
      "pali": "Revato yasadharo buddho,"
    },
    {
      "id": "bv7:29.2",
      "pali": "Nibbuto so mahāpure;"
    },
    {
      "id": "bv7:29.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv7:29.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv7:30.1",
      "pali": "Revatassa bhagavato vaṁso pañcamo."
    }
  ]
}
