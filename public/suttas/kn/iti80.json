{
  "uid": "iti80",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti80:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti80:2.1",
      "pali": "“Tayome, bhikkhave, akusalavitakkā."
    },
    {
      "id": "iti80:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti80:2.3",
      "pali": "Anavaññattipaṭisaṁyutto vitakko, lābhasakkārasilokapaṭisaṁyutto vitakko, parānuddayatāpaṭisaṁyutto vitakko."
    },
    {
      "id": "iti80:2.4",
      "pali": "Ime kho, bhikkhave, tayo akusalavitakkā”ti."
    },
    {
      "id": "iti80:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti80:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti80:3.1",
      "pali": "“Anavaññattisaṁyutto,"
    },
    {
      "id": "iti80:3.2",
      "pali": "lābhasakkāragāravo;"
    },
    {
      "id": "iti80:3.3",
      "pali": "Sahanandī amaccehi,"
    },
    {
      "id": "iti80:3.4",
      "pali": "ārā saṁyojanakkhayā."
    },
    {
      "id": "iti80:4.1",
      "pali": "Yo ca puttapasuṁ hitvā,"
    },
    {
      "id": "iti80:4.2",
      "pali": "Vivāhe saṁharāni ca;"
    },
    {
      "id": "iti80:4.3",
      "pali": "Bhabbo so tādiso bhikkhu,"
    },
    {
      "id": "iti80:4.4",
      "pali": "Phuṭṭhuṁ sambodhimuttaman”ti."
    },
    {
      "id": "iti80:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti80:5.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
