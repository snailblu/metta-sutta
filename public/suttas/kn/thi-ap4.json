{
  "uid": "thi-ap4",
  "title": "4 Saṅkamanatthātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap4:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "thi-ap4:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "thi-ap4:1.3",
      "pali": "Rathiyaṁ paṭipannassa,"
    },
    {
      "id": "thi-ap4:1.4",
      "pali": "tārayantassa pāṇino."
    },
    {
      "id": "thi-ap4:2.1",
      "pali": "Gharato nikkhamitvāna,"
    },
    {
      "id": "thi-ap4:2.2",
      "pali": "avakujjā nipajjahaṁ;"
    },
    {
      "id": "thi-ap4:2.3",
      "pali": "Anukampako lokanātho,"
    },
    {
      "id": "thi-ap4:2.4",
      "pali": "sirasi akkamī mama."
    },
    {
      "id": "thi-ap4:3.1",
      "pali": "Akkamitvāna sirasi,"
    },
    {
      "id": "thi-ap4:3.2",
      "pali": "agamā lokanāyako;"
    },
    {
      "id": "thi-ap4:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "thi-ap4:3.4",
      "pali": "tusitaṁ agamāsahaṁ."
    },
    {
      "id": "thi-ap4:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap4:4.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap4:4.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap4:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap4:5.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap4:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap4:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap4:6.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap4:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap4:7.1",
      "pali": "Itthaṁ sudaṁ saṅkamanatthā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap4:8.1",
      "pali": "Saṅkamanatthātheriyāpadānaṁ catutthaṁ."
    }
  ]
}
