{
  "uid": "ud7.7",
  "title": "Papañcakhayasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud7.7:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud7.7:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud7.7:1.3",
      "pali": "Tena kho pana samayena bhagavā attano papañcasaññāsaṅkhāpahānaṁ paccavekkhamāno nisinno hoti."
    },
    {
      "id": "ud7.7:2.1",
      "pali": "Atha kho bhagavā attano papañcasaññāsaṅkhāpahānaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud7.7:3.1",
      "pali": "“Yassa papañcā ṭhiti ca natthi,"
    },
    {
      "id": "ud7.7:3.2",
      "pali": "Sandānaṁ palighañca vītivatto;"
    },
    {
      "id": "ud7.7:3.3",
      "pali": "Taṁ nittaṇhaṁ muniṁ carantaṁ,"
    },
    {
      "id": "ud7.7:3.4",
      "pali": "Nāvajānāti sadevakopi loko”ti."
    },
    {
      "id": "ud7.7:3.5",
      "pali": "Sattamaṁ."
    }
  ]
}
