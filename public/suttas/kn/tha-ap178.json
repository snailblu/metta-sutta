{
  "uid": "tha-ap178",
  "title": "Maggadattikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap178:1.1",
      "pali": "“Anomadassī bhagavā,"
    },
    {
      "id": "tha-ap178:1.2",
      "pali": "dvipadindo narāsabho;"
    },
    {
      "id": "tha-ap178:1.3",
      "pali": "Diṭṭhadhammasukhatthāya,"
    },
    {
      "id": "tha-ap178:1.4",
      "pali": "abbhokāsamhi caṅkami."
    },
    {
      "id": "tha-ap178:2.1",
      "pali": "Uddhate pāde pupphāni,"
    },
    {
      "id": "tha-ap178:2.2",
      "pali": "sobhaṁ muddhani tiṭṭhare;"
    },
    {
      "id": "tha-ap178:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap178:2.4",
      "pali": "vanditvā pupphamokiriṁ."
    },
    {
      "id": "tha-ap178:3.1",
      "pali": "Vīsakappasahassamhi,"
    },
    {
      "id": "tha-ap178:3.2",
      "pali": "ito pañca janā ahuṁ;"
    },
    {
      "id": "tha-ap178:3.3",
      "pali": "Pupphacchadaniyā nāma,"
    },
    {
      "id": "tha-ap178:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap178:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap178:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap178:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap178:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā maggadattiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap178:6.1",
      "pali": "Maggadattikattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
