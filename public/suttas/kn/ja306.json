{
  "uid": "ja306",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja306:1.1",
      "pali": "“Kimaṇḍakā ime deva,"
    },
    {
      "id": "ja306:1.2",
      "pali": "nikkhittā kaṁsamallake;"
    },
    {
      "id": "ja306:1.3",
      "pali": "Upalohitakā vaggū,"
    },
    {
      "id": "ja306:1.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja306:2.1",
      "pali": "“Yāni pure tuvaṁ devi,"
    },
    {
      "id": "ja306:2.2",
      "pali": "bhaṇḍu nantakavāsinī;"
    },
    {
      "id": "ja306:2.3",
      "pali": "Ucchaṅgahatthā pacināsi,"
    },
    {
      "id": "ja306:2.4",
      "pali": "tassā te koliyaṁ phalaṁ."
    },
    {
      "id": "ja306:3.1",
      "pali": "Uḍḍayhate na ramati,"
    },
    {
      "id": "ja306:3.2",
      "pali": "bhogā vippajahanti taṁ;"
    },
    {
      "id": "ja306:3.3",
      "pali": "Tatthevimaṁ paṭinetha,"
    },
    {
      "id": "ja306:3.4",
      "pali": "yattha kolaṁ pacissati”."
    },
    {
      "id": "ja306:4.1",
      "pali": "“Honti hete mahārāja,"
    },
    {
      "id": "ja306:4.2",
      "pali": "iddhippattāya nāriyā;"
    },
    {
      "id": "ja306:4.3",
      "pali": "Khama deva sujātāya,"
    },
    {
      "id": "ja306:4.4",
      "pali": "māssā kujjha rathesabhā”ti."
    },
    {
      "id": "ja306:5.1",
      "pali": "Sujātājātakaṁ chaṭṭhaṁ."
    }
  ]
}
