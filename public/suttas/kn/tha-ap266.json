{
  "uid": "tha-ap266",
  "title": "4 Padīpadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap266:1.1",
      "pali": "“Devabhūto ahaṁ santo,"
    },
    {
      "id": "tha-ap266:1.2",
      "pali": "oruyha pathaviṁ tadā;"
    },
    {
      "id": "tha-ap266:1.3",
      "pali": "Padīpe pañca pādāsiṁ,"
    },
    {
      "id": "tha-ap266:1.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap266:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap266:2.2",
      "pali": "yaṁ padīpamadaṁ tadā;"
    },
    {
      "id": "tha-ap266:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap266:2.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap266:3.1",
      "pali": "Pañcapaññāsake kappe,"
    },
    {
      "id": "tha-ap266:3.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap266:3.3",
      "pali": "Samantacakkhunāmena,"
    },
    {
      "id": "tha-ap266:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap266:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap266:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap266:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap266:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā padīpadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap266:6.1",
      "pali": "Padīpadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
