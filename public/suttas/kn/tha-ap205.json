{
  "uid": "tha-ap205",
  "title": "3 Kiṅkaṇipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap205:1.1",
      "pali": "“Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap205:1.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap205:1.3",
      "pali": "Odakaṁ dahamoggayha,"
    },
    {
      "id": "tha-ap205:1.4",
      "pali": "sināyi lokanāyako."
    },
    {
      "id": "tha-ap205:2.1",
      "pali": "Paggayha kiṅkaṇiṁ pupphaṁ,"
    },
    {
      "id": "tha-ap205:2.2",
      "pali": "Vipassissābhiropayiṁ;"
    },
    {
      "id": "tha-ap205:2.3",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap205:2.4",
      "pali": "Dvipadindassa tādino."
    },
    {
      "id": "tha-ap205:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap205:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap205:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap205:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap205:4.1",
      "pali": "Sattavīsatikappamhi,"
    },
    {
      "id": "tha-ap205:4.2",
      "pali": "rājā bhīmaratho ahu;"
    },
    {
      "id": "tha-ap205:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap205:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap205:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap205:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap205:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap205:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kiṅkaṇipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap205:7.1",
      "pali": "Kiṅkaṇipupphiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
