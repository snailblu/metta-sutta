{
  "uid": "tha-ap209",
  "title": "7 Salalamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap209:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap209:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap209:1.3",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap209:1.4",
      "pali": "siddhatthaṁ narasārathiṁ."
    },
    {
      "id": "tha-ap209:2.1",
      "pali": "Dhanuṁ advejjhaṁ katvāna,"
    },
    {
      "id": "tha-ap209:2.2",
      "pali": "usuṁ sannayhahaṁ tadā;"
    },
    {
      "id": "tha-ap209:2.3",
      "pali": "Pupphaṁ savaṇṭaṁ chetvāna,"
    },
    {
      "id": "tha-ap209:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap209:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap209:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap209:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap209:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap209:4.1",
      "pali": "Ekapaññāsito kappe,"
    },
    {
      "id": "tha-ap209:4.2",
      "pali": "eko āsiṁ jutindharo;"
    },
    {
      "id": "tha-ap209:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap209:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap209:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap209:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap209:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap209:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā salalamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap209:7.1",
      "pali": "Salalamāliyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
