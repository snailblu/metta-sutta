{
  "uid": "tha-ap185",
  "title": "3 Koṭumbariyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap185:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap185:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap185:1.3",
      "pali": "Appameyyaṁva udadhiṁ,"
    },
    {
      "id": "tha-ap185:1.4",
      "pali": "vitthataṁ dharaṇiṁ yathā."
    },
    {
      "id": "tha-ap185:2.1",
      "pali": "Pūjitaṁ devasaṅghena,"
    },
    {
      "id": "tha-ap185:2.2",
      "pali": "nisabhājāniyaṁ yathā;"
    },
    {
      "id": "tha-ap185:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap185:2.4",
      "pali": "upāgacchiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap185:3.1",
      "pali": "Sattapupphāni paggayha,"
    },
    {
      "id": "tha-ap185:3.2",
      "pali": "koṭumbarasamākulaṁ;"
    },
    {
      "id": "tha-ap185:3.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap185:3.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap185:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap185:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap185:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap185:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap185:5.1",
      "pali": "Ito vīsatikappamhi,"
    },
    {
      "id": "tha-ap185:5.2",
      "pali": "mahānelasanāmako;"
    },
    {
      "id": "tha-ap185:5.3",
      "pali": "Eko āsi mahātejo,"
    },
    {
      "id": "tha-ap185:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap185:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap185:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap185:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap185:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā koṭumbariyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap185:8.1",
      "pali": "Koṭumbariyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
