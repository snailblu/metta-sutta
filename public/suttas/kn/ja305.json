{
  "uid": "ja305",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja305:1.1",
      "pali": "“Natthi loke raho nāma,"
    },
    {
      "id": "ja305:1.2",
      "pali": "pāpakammaṁ pakubbato;"
    },
    {
      "id": "ja305:1.3",
      "pali": "Passanti vanabhūtāni,"
    },
    {
      "id": "ja305:1.4",
      "pali": "taṁ bālo maññatī raho."
    },
    {
      "id": "ja305:2.1",
      "pali": "Ahaṁ raho na passāmi,"
    },
    {
      "id": "ja305:2.2",
      "pali": "suññaṁ vāpi na vijjati;"
    },
    {
      "id": "ja305:2.3",
      "pali": "Yattha aññaṁ na passāmi,"
    },
    {
      "id": "ja305:2.4",
      "pali": "asuññaṁ hoti taṁ mayā”."
    },
    {
      "id": "ja305:3.1",
      "pali": "“Dujjacco ca sujacco ca,"
    },
    {
      "id": "ja305:3.2",
      "pali": "nando ca sukhavaḍḍhito;"
    },
    {
      "id": "ja305:3.3",
      "pali": "Vejjo ca addhuvasīlo ca,"
    },
    {
      "id": "ja305:3.4",
      "pali": "te dhammaṁ jahu matthikā."
    },
    {
      "id": "ja305:4.1",
      "pali": "Brāhmaṇo ca kathaṁ jahe,"
    },
    {
      "id": "ja305:4.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "ja305:4.3",
      "pali": "Yo dhammamanupāleti,"
    },
    {
      "id": "ja305:4.4",
      "pali": "dhitimā saccanikkamo”ti."
    },
    {
      "id": "ja305:5.1",
      "pali": "Sīlavīmaṁsanajātakaṁ pañcamaṁ."
    }
  ]
}
