{
  "uid": "tha-ap289",
  "title": "Apadāniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap289:1.1",
      "pali": "“Apadānaṁ sugatānaṁ,"
    },
    {
      "id": "tha-ap289:1.2",
      "pali": "kittayiṁhaṁ mahesinaṁ;"
    },
    {
      "id": "tha-ap289:1.3",
      "pali": "Pāde ca sirasā vandiṁ,"
    },
    {
      "id": "tha-ap289:1.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap289:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap289:2.2",
      "pali": "apadānaṁ pakittayiṁ;"
    },
    {
      "id": "tha-ap289:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap289:2.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap289:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap289:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap289:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap289:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā apadāniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap289:5.1",
      "pali": "Apadāniyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
