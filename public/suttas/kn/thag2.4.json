{
  "uid": "thag2.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.4:1.1",
      "pali": "“Tiṇṇaṁ me tālapattānaṁ,"
    },
    {
      "id": "thag2.4:1.2",
      "pali": "gaṅgātīre kuṭī katā;"
    },
    {
      "id": "thag2.4:1.3",
      "pali": "Chavasittova me patto,"
    },
    {
      "id": "thag2.4:1.4",
      "pali": "paṁsukūlañca cīvaraṁ."
    },
    {
      "id": "thag2.4:2.1",
      "pali": "Dvinnaṁ antaravassānaṁ,"
    },
    {
      "id": "thag2.4:2.2",
      "pali": "ekā vācā me bhāsitā;"
    },
    {
      "id": "thag2.4:2.3",
      "pali": "Tatiye antaravassamhi,"
    },
    {
      "id": "thag2.4:2.4",
      "pali": "tamokhandho padālito”ti."
    },
    {
      "id": "thag2.4:2.5",
      "pali": "… Gaṅgātīriyo thero …."
    }
  ]
}
