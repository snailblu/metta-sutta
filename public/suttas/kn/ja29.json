{
  "uid": "ja29",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja29:1.1",
      "pali": "“Yato yato garu dhuraṁ,"
    },
    {
      "id": "ja29:1.2",
      "pali": "yato gambhīravattanī;"
    },
    {
      "id": "ja29:1.3",
      "pali": "Tadāssu kaṇhaṁ yuñjanti,"
    },
    {
      "id": "ja29:1.4",
      "pali": "svāssu taṁ vahate dhuran”ti."
    },
    {
      "id": "ja29:2.1",
      "pali": "Kaṇhajātakaṁ navamaṁ."
    }
  ]
}
