{
  "uid": "cp33",
  "title": "Mettāpāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp33:1.1",
      "pali": "“Sāmo yadā vane āsiṁ,"
    },
    {
      "id": "cp33:1.2",
      "pali": "sakkena abhinimmito;"
    },
    {
      "id": "cp33:1.3",
      "pali": "Pavane sīhabyagghe ca,"
    },
    {
      "id": "cp33:1.4",
      "pali": "mettāya mupanāmayiṁ."
    },
    {
      "id": "cp33:2.1",
      "pali": "Sīhabyagghehi dīpīhi,"
    },
    {
      "id": "cp33:2.2",
      "pali": "acchehi mahisehi ca;"
    },
    {
      "id": "cp33:2.3",
      "pali": "Pasadamigavarāhehi,"
    },
    {
      "id": "cp33:2.4",
      "pali": "parivāretvā vane vasiṁ."
    },
    {
      "id": "cp33:3.1",
      "pali": "Na maṁ koci uttasati,"
    },
    {
      "id": "cp33:3.2",
      "pali": "napi bhāyāmi kassaci;"
    },
    {
      "id": "cp33:3.3",
      "pali": "Mettābalenupatthaddho,"
    },
    {
      "id": "cp33:3.4",
      "pali": "ramāmi pavane tadā”ti."
    },
    {
      "id": "cp33:4.1",
      "pali": "Suvaṇṇasāmacariyaṁ terasamaṁ."
    }
  ]
}
