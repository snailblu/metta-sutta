{
  "uid": "iti15",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti15:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti15:2.1",
      "pali": "“Nāhaṁ, bhikkhave, aññaṁ ekasaṁyojanampi samanupassāmi yena saṁyojanena saṁyuttā sattā dīgharattaṁ sandhāvanti saṁsaranti yathayidaṁ, bhikkhave, taṇhāsaṁyojanaṁ."
    },
    {
      "id": "iti15:2.2",
      "pali": "Taṇhāsaṁyojanena hi, bhikkhave, saṁyuttā sattā dīgharattaṁ sandhāvanti saṁsarantī”ti."
    },
    {
      "id": "iti15:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti15:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti15:3.1",
      "pali": "“Taṇhādutiyo puriso,"
    },
    {
      "id": "iti15:3.2",
      "pali": "dīghamaddhāna saṁsaraṁ;"
    },
    {
      "id": "iti15:3.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "iti15:3.4",
      "pali": "saṁsāraṁ nātivattati."
    },
    {
      "id": "iti15:4.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "iti15:4.2",
      "pali": "Taṇhaṁ dukkhassa sambhavaṁ;"
    },
    {
      "id": "iti15:4.3",
      "pali": "Vītataṇho anādāno,"
    },
    {
      "id": "iti15:4.4",
      "pali": "Sato bhikkhu paribbaje”ti."
    },
    {
      "id": "iti15:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti15:5.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
