{
  "uid": "tha-ap417",
  "title": "5 Nāgapallavattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap417:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap417:1.2",
      "pali": "rājuyyāne vasāmahaṁ;"
    },
    {
      "id": "tha-ap417:1.3",
      "pali": "Mama assamasāmantā,"
    },
    {
      "id": "tha-ap417:1.4",
      "pali": "nisīdi lokanāyako."
    },
    {
      "id": "tha-ap417:2.1",
      "pali": "Nāgapallavamādāya,"
    },
    {
      "id": "tha-ap417:2.2",
      "pali": "buddhassa abhiropayiṁ;"
    },
    {
      "id": "tha-ap417:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap417:2.4",
      "pali": "sugataṁ abhivādayiṁ."
    },
    {
      "id": "tha-ap417:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap417:3.2",
      "pali": "yaṁ pallavamapūjayiṁ;"
    },
    {
      "id": "tha-ap417:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap417:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap417:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap417:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap417:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap417:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap417:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap417:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap417:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap417:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap417:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap417:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāgapallavo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap417:8.1",
      "pali": "Nāgapallavattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
