{
  "uid": "pv15",
  "title": "3. Mattāpetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv15:1.1",
      "pali": "“Naggā dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv15:1.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv15:1.3",
      "pali": "Upphāsulike kisike,"
    },
    {
      "id": "pv15:1.4",
      "pali": "kā nu tvaṁ idha tiṭṭhasī”ti."
    },
    {
      "id": "pv15:2.1",
      "pali": "“Ahaṁ mattā tuvaṁ tissā,"
    },
    {
      "id": "pv15:2.2",
      "pali": "sapattī te pure ahuṁ;"
    },
    {
      "id": "pv15:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv15:2.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv15:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv15:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv15:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv15:3.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv15:4.1",
      "pali": "“Caṇḍī ca pharusā cāsiṁ,"
    },
    {
      "id": "pv15:4.2",
      "pali": "issukī maccharī saṭhā;"
    },
    {
      "id": "pv15:4.3",
      "pali": "Tāhaṁ duruttaṁ vatvāna,"
    },
    {
      "id": "pv15:4.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv15:5.1",
      "pali": "“Sabbaṁ ahampi jānāmi,"
    },
    {
      "id": "pv15:5.2",
      "pali": "yathā tvaṁ caṇḍikā ahu;"
    },
    {
      "id": "pv15:5.3",
      "pali": "Aññañca kho taṁ pucchāmi,"
    },
    {
      "id": "pv15:5.4",
      "pali": "kenāsi paṁsukunthitā”ti."
    },
    {
      "id": "pv15:6.1",
      "pali": "“Sīsaṁnhātā tuvaṁ āsi,"
    },
    {
      "id": "pv15:6.2",
      "pali": "sucivatthā alaṅkatā;"
    },
    {
      "id": "pv15:6.3",
      "pali": "Ahañca kho adhimattaṁ,"
    },
    {
      "id": "pv15:6.4",
      "pali": "samalaṅkatatarā tayā."
    },
    {
      "id": "pv15:7.1",
      "pali": "Tassā me pekkhamānāya,"
    },
    {
      "id": "pv15:7.2",
      "pali": "sāmikena samantayi;"
    },
    {
      "id": "pv15:7.3",
      "pali": "Tato me issā vipulā,"
    },
    {
      "id": "pv15:7.4",
      "pali": "kodho me samajāyatha."
    },
    {
      "id": "pv15:8.1",
      "pali": "Tato paṁsuṁ gahetvāna,"
    },
    {
      "id": "pv15:8.2",
      "pali": "paṁsunā taṁ hi okiriṁ;"
    },
    {
      "id": "pv15:8.3",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv15:8.4",
      "pali": "tenamhi paṁsukunthitā”ti."
    },
    {
      "id": "pv15:9.1",
      "pali": "“Sabbaṁ ahampi jānāmi,"
    },
    {
      "id": "pv15:9.2",
      "pali": "paṁsunā maṁ tvamokiri;"
    },
    {
      "id": "pv15:9.3",
      "pali": "Aññañca kho taṁ pucchāmi,"
    },
    {
      "id": "pv15:9.4",
      "pali": "kena khajjasi kacchuyā”ti."
    },
    {
      "id": "pv15:10.1",
      "pali": "“Bhesajjahārī ubhayo,"
    },
    {
      "id": "pv15:10.2",
      "pali": "vanantaṁ agamimhase;"
    },
    {
      "id": "pv15:10.3",
      "pali": "Tvañca bhesajjamāhari,"
    },
    {
      "id": "pv15:10.4",
      "pali": "ahañca kapikacchuno."
    },
    {
      "id": "pv15:11.1",
      "pali": "Tassā tyājānamānāya,"
    },
    {
      "id": "pv15:11.2",
      "pali": "seyyaṁ tyāhaṁ samokiriṁ;"
    },
    {
      "id": "pv15:11.3",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv15:11.4",
      "pali": "tena khajjāmi kacchuyā”ti."
    },
    {
      "id": "pv15:12.1",
      "pali": "“Sabbaṁ ahampi jānāmi,"
    },
    {
      "id": "pv15:12.2",
      "pali": "seyyaṁ me tvaṁ samokiri;"
    },
    {
      "id": "pv15:12.3",
      "pali": "Aññañca kho taṁ pucchāmi,"
    },
    {
      "id": "pv15:12.4",
      "pali": "kenāsi naggiyā tuvan”ti."
    },
    {
      "id": "pv15:13.1",
      "pali": "“Sahāyānaṁ samayo āsi,"
    },
    {
      "id": "pv15:13.2",
      "pali": "ñātīnaṁ samitī ahu;"
    },
    {
      "id": "pv15:13.3",
      "pali": "Tvañca āmantitā āsi,"
    },
    {
      "id": "pv15:13.4",
      "pali": "sasāminī no ca kho ahaṁ."
    },
    {
      "id": "pv15:14.1",
      "pali": "Tassā tyājānamānāya,"
    },
    {
      "id": "pv15:14.2",
      "pali": "dussaṁ tyāhaṁ apānudiṁ;"
    },
    {
      "id": "pv15:14.3",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv15:14.4",
      "pali": "tenamhi naggiyā ahan”ti."
    },
    {
      "id": "pv15:15.1",
      "pali": "“Sabbaṁ ahampi jānāmi,"
    },
    {
      "id": "pv15:15.2",
      "pali": "dussaṁ me tvaṁ apānudi;"
    },
    {
      "id": "pv15:15.3",
      "pali": "Aññañca kho taṁ pucchāmi,"
    },
    {
      "id": "pv15:15.4",
      "pali": "kenāsi gūthagandhinī”ti."
    },
    {
      "id": "pv15:16.1",
      "pali": "“Tava gandhañca mālañca,"
    },
    {
      "id": "pv15:16.2",
      "pali": "paccagghañca vilepanaṁ;"
    },
    {
      "id": "pv15:16.3",
      "pali": "Gūthakūpe atāresiṁ,"
    },
    {
      "id": "pv15:16.4",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "pv15:16.5",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv15:16.6",
      "pali": "tenamhi gūthagandhinī”ti."
    },
    {
      "id": "pv15:17.1",
      "pali": "“Sabbaṁ ahampi jānāmi,"
    },
    {
      "id": "pv15:17.2",
      "pali": "taṁ pāpaṁ pakataṁ tayā;"
    },
    {
      "id": "pv15:17.3",
      "pali": "Aññañca kho taṁ pucchāmi,"
    },
    {
      "id": "pv15:17.4",
      "pali": "kenāsi duggatā tuvan”ti."
    },
    {
      "id": "pv15:18.1",
      "pali": "“Ubhinnaṁ samakaṁ āsi,"
    },
    {
      "id": "pv15:18.2",
      "pali": "yaṁ gehe vijjate dhanaṁ;"
    },
    {
      "id": "pv15:18.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv15:18.4",
      "pali": "dīpaṁ nākāsimattano;"
    },
    {
      "id": "pv15:18.5",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv15:18.6",
      "pali": "tenamhi duggatā ahaṁ."
    },
    {
      "id": "pv15:19.1",
      "pali": "Tadeva maṁ tvaṁ avaca,"
    },
    {
      "id": "pv15:19.2",
      "pali": "‘pāpakammaṁ nisevasi;"
    },
    {
      "id": "pv15:19.3",
      "pali": "Na hi pāpehi kammehi,"
    },
    {
      "id": "pv15:19.4",
      "pali": "sulabhā hoti suggatī’”ti."
    },
    {
      "id": "pv15:20.1",
      "pali": "“Vāmato maṁ tvaṁ paccesi,"
    },
    {
      "id": "pv15:20.2",
      "pali": "athopi maṁ usūyasi;"
    },
    {
      "id": "pv15:20.3",
      "pali": "Passa pāpānaṁ kammānaṁ,"
    },
    {
      "id": "pv15:20.4",
      "pali": "vipāko hoti yādiso."
    },
    {
      "id": "pv15:21.1",
      "pali": "Te gharā tā ca dāsiyo,"
    },
    {
      "id": "pv15:21.2",
      "pali": "tānevābharaṇānime;"
    },
    {
      "id": "pv15:21.3",
      "pali": "Te aññe paricārenti,"
    },
    {
      "id": "pv15:21.4",
      "pali": "na bhogā honti sassatā."
    },
    {
      "id": "pv15:22.1",
      "pali": "Idāni bhūtassa pitā,"
    },
    {
      "id": "pv15:22.2",
      "pali": "āpaṇā gehamehiti;"
    },
    {
      "id": "pv15:22.3",
      "pali": "Appeva te dade kiñci,"
    },
    {
      "id": "pv15:22.4",
      "pali": "mā su tāva ito agā”ti."
    },
    {
      "id": "pv15:23.1",
      "pali": "“Naggā dubbaṇṇarūpāmhi,"
    },
    {
      "id": "pv15:23.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv15:23.3",
      "pali": "Kopīnametaṁ itthīnaṁ,"
    },
    {
      "id": "pv15:23.4",
      "pali": "mā maṁ bhūtapitāddasā”ti."
    },
    {
      "id": "pv15:24.1",
      "pali": "“Handa kiṁ vā tyāhaṁ dammi,"
    },
    {
      "id": "pv15:24.2",
      "pali": "Kiṁ vā tedha karomahaṁ;"
    },
    {
      "id": "pv15:24.3",
      "pali": "Yena tvaṁ sukhitā assa,"
    },
    {
      "id": "pv15:24.4",
      "pali": "Sabbakāmasamiddhinī”ti."
    },
    {
      "id": "pv15:25.1",
      "pali": "“Cattāro bhikkhū saṅghato,"
    },
    {
      "id": "pv15:25.2",
      "pali": "cattāro pana puggale;"
    },
    {
      "id": "pv15:25.3",
      "pali": "Aṭṭha bhikkhū bhojayitvā,"
    },
    {
      "id": "pv15:25.4",
      "pali": "mama dakkhiṇamādisa;"
    },
    {
      "id": "pv15:25.5",
      "pali": "Tadāhaṁ sukhitā hessaṁ,"
    },
    {
      "id": "pv15:25.6",
      "pali": "sabbakāmasamiddhinī”ti."
    },
    {
      "id": "pv15:26.1",
      "pali": "Sādhūti sā paṭissutvā,"
    },
    {
      "id": "pv15:26.2",
      "pali": "bhojayitvāṭṭha bhikkhavo;"
    },
    {
      "id": "pv15:26.3",
      "pali": "Vatthehacchādayitvāna,"
    },
    {
      "id": "pv15:26.4",
      "pali": "tassā dakkhiṇamādisī."
    },
    {
      "id": "pv15:27.1",
      "pali": "Samanantarānuddiṭṭhe,"
    },
    {
      "id": "pv15:27.2",
      "pali": "vipāko udapajjatha;"
    },
    {
      "id": "pv15:27.3",
      "pali": "Bhojanacchādanapānīyaṁ,"
    },
    {
      "id": "pv15:27.4",
      "pali": "dakkhiṇāya idaṁ phalaṁ."
    },
    {
      "id": "pv15:28.1",
      "pali": "Tato suddhā sucivasanā,"
    },
    {
      "id": "pv15:28.2",
      "pali": "kāsikuttamadhārinī;"
    },
    {
      "id": "pv15:28.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "pv15:28.4",
      "pali": "sapattiṁ upasaṅkami."
    },
    {
      "id": "pv15:29.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "pv15:29.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "pv15:29.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "pv15:29.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "pv15:30.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "pv15:30.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "pv15:30.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "pv15:30.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "pv15:31.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "pv15:31.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "pv15:31.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "pv15:31.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "pv15:32.1",
      "pali": "“Ahaṁ mattā tuvaṁ tissā,"
    },
    {
      "id": "pv15:32.2",
      "pali": "sapattī te pure ahuṁ;"
    },
    {
      "id": "pv15:32.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv15:32.4",
      "pali": "petalokaṁ ito gatā."
    },
    {
      "id": "pv15:33.1",
      "pali": "Tava dinnena dānena,"
    },
    {
      "id": "pv15:33.2",
      "pali": "modāmi akutobhayā;"
    },
    {
      "id": "pv15:33.3",
      "pali": "Ciraṁ jīvāhi bhagini,"
    },
    {
      "id": "pv15:33.4",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "pv15:33.5",
      "pali": "Asokaṁ virajaṁ ṭhānaṁ,"
    },
    {
      "id": "pv15:33.6",
      "pali": "āvāsaṁ vasavattinaṁ."
    },
    {
      "id": "pv15:34.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "pv15:34.2",
      "pali": "Dānaṁ datvāna sobhane;"
    },
    {
      "id": "pv15:34.3",
      "pali": "Vineyya maccheramalaṁ samūlaṁ,"
    },
    {
      "id": "pv15:34.4",
      "pali": "Aninditā saggamupehi ṭhānan”ti."
    },
    {
      "id": "pv15:35.1",
      "pali": "Mattāpetivatthu tatiyaṁ."
    }
  ]
}
