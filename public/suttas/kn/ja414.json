{
  "uid": "ja414",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja414:1.1",
      "pali": "“Kodha jāgarataṁ sutto,"
    },
    {
      "id": "ja414:1.2",
      "pali": "kodha suttesu jāgaro;"
    },
    {
      "id": "ja414:1.3",
      "pali": "Ko mametaṁ vijānāti,"
    },
    {
      "id": "ja414:1.4",
      "pali": "ko taṁ paṭibhaṇāti me”."
    },
    {
      "id": "ja414:2.1",
      "pali": "“Ahaṁ jāgarataṁ sutto,"
    },
    {
      "id": "ja414:2.2",
      "pali": "ahaṁ suttesu jāgaro;"
    },
    {
      "id": "ja414:2.3",
      "pali": "Ahametaṁ vijānāmi,"
    },
    {
      "id": "ja414:2.4",
      "pali": "ahaṁ paṭibhaṇāmi te”."
    },
    {
      "id": "ja414:3.1",
      "pali": "“Kathaṁ jāgarataṁ sutto,"
    },
    {
      "id": "ja414:3.2",
      "pali": "kathaṁ suttesu jāgaro;"
    },
    {
      "id": "ja414:3.3",
      "pali": "Kathaṁ etaṁ vijānāsi,"
    },
    {
      "id": "ja414:3.4",
      "pali": "kathaṁ paṭibhaṇāsi me”."
    },
    {
      "id": "ja414:4.1",
      "pali": "“Ye dhammaṁ nappajānanti,"
    },
    {
      "id": "ja414:4.2",
      "pali": "saṁyamoti damoti ca;"
    },
    {
      "id": "ja414:4.3",
      "pali": "Tesu suppamānesu,"
    },
    {
      "id": "ja414:4.4",
      "pali": "ahaṁ jaggāmi devate."
    },
    {
      "id": "ja414:5.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "ja414:5.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "ja414:5.3",
      "pali": "Tesu jāgaramānesu,"
    },
    {
      "id": "ja414:5.4",
      "pali": "ahaṁ suttosmi devate."
    },
    {
      "id": "ja414:6.1",
      "pali": "Evaṁ jāgarataṁ sutto,"
    },
    {
      "id": "ja414:6.2",
      "pali": "evaṁ suttesu jāgaro;"
    },
    {
      "id": "ja414:6.3",
      "pali": "Evametaṁ vijānāmi,"
    },
    {
      "id": "ja414:6.4",
      "pali": "evaṁ paṭibhaṇāmi te”."
    },
    {
      "id": "ja414:7.1",
      "pali": "“Sādhu jāgarataṁ sutto,"
    },
    {
      "id": "ja414:7.2",
      "pali": "sādhu suttesu jāgaro;"
    },
    {
      "id": "ja414:7.3",
      "pali": "Sādhumetaṁ vijānāsi,"
    },
    {
      "id": "ja414:7.4",
      "pali": "sādhu paṭibhaṇāsi me”ti."
    },
    {
      "id": "ja414:8.1",
      "pali": "Jāgarajātakaṁ navamaṁ."
    }
  ]
}
