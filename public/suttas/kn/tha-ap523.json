{
  "uid": "tha-ap523",
  "title": "Tiṇamuṭṭhidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap523:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap523:1.2",
      "pali": "lambako nāma pabbato;"
    },
    {
      "id": "tha-ap523:1.3",
      "pali": "Tattheva tisso sambuddho,"
    },
    {
      "id": "tha-ap523:1.4",
      "pali": "abbhokāsamhi caṅkami."
    },
    {
      "id": "tha-ap523:2.1",
      "pali": "Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap523:2.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap523:2.3",
      "pali": "Disvāna taṁ devadevaṁ,"
    },
    {
      "id": "tha-ap523:2.4",
      "pali": "tiṇamuṭṭhimadāsahaṁ."
    },
    {
      "id": "tha-ap523:3.1",
      "pali": "Nisīdanatthaṁ buddhassa,"
    },
    {
      "id": "tha-ap523:3.2",
      "pali": "datvā cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap523:3.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap523:3.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap523:4.1",
      "pali": "Aciraṁ gatamattassa,"
    },
    {
      "id": "tha-ap523:4.2",
      "pali": "migarājā apothayi;"
    },
    {
      "id": "tha-ap523:4.3",
      "pali": "Sīhena pothito santo,"
    },
    {
      "id": "tha-ap523:4.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap523:5.1",
      "pali": "Āsanne me kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap523:5.2",
      "pali": "buddhaseṭṭhe anāsave;"
    },
    {
      "id": "tha-ap523:5.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap523:5.4",
      "pali": "devalokamagañchahaṁ."
    },
    {
      "id": "tha-ap523:6.1",
      "pali": "Yūpo tattha subho āsi,"
    },
    {
      "id": "tha-ap523:6.2",
      "pali": "puññakammābhinimmito;"
    },
    {
      "id": "tha-ap523:6.3",
      "pali": "Sahassakaṇḍo satabheṇḍu,"
    },
    {
      "id": "tha-ap523:6.4",
      "pali": "dhajālu haritāmayo."
    },
    {
      "id": "tha-ap523:7.1",
      "pali": "Pabhā niddhāvate tassa,"
    },
    {
      "id": "tha-ap523:7.2",
      "pali": "sataraṁsīva uggato;"
    },
    {
      "id": "tha-ap523:7.3",
      "pali": "Ākiṇṇo devakaññāhi,"
    },
    {
      "id": "tha-ap523:7.4",
      "pali": "āmodiṁ kāmakāmihaṁ."
    },
    {
      "id": "tha-ap523:8.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap523:8.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap523:8.3",
      "pali": "Āgantvāna manussattaṁ,"
    },
    {
      "id": "tha-ap523:8.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap523:9.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap523:9.2",
      "pali": "nisīdanamadāsahaṁ;"
    },
    {
      "id": "tha-ap523:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap523:9.4",
      "pali": "tiṇamuṭṭhe idaṁ phalaṁ."
    },
    {
      "id": "tha-ap523:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap523:10.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap523:10.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap523:10.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap523:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap523:11.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap523:11.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap523:11.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap523:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap523:12.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap523:12.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap523:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap523:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇamuṭṭhidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap523:14.1",
      "pali": "Tiṇamuṭṭhidāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
