{
  "uid": "thag1.52",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.52:1.1",
      "pali": "“Vassati devo yathā sugītaṁ,"
    },
    {
      "id": "thag1.52:1.2",
      "pali": "Channā me kuṭikā sukhā nivātā;"
    },
    {
      "id": "thag1.52:1.3",
      "pali": "Cittaṁ susamāhitañca kāye,"
    },
    {
      "id": "thag1.52:1.4",
      "pali": "Atha ce patthayasi pavassa devā”ti."
    },
    {
      "id": "thag1.52:1.5",
      "pali": "… Subāhutthero …."
    }
  ]
}
