{
  "uid": "thig1.11",
  "title": "Muttātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.11:1.1",
      "pali": "“Sumuttā sādhumuttāmhi,"
    },
    {
      "id": "thig1.11:1.2",
      "pali": "tīhi khujjehi muttiyā;"
    },
    {
      "id": "thig1.11:1.3",
      "pali": "Udukkhalena musalena,"
    },
    {
      "id": "thig1.11:1.4",
      "pali": "patinā khujjakena ca;"
    },
    {
      "id": "thig1.11:1.5",
      "pali": "Muttāmhi jātimaraṇā,"
    },
    {
      "id": "thig1.11:1.6",
      "pali": "bhavanetti samūhatā”ti."
    },
    {
      "id": "thig1.11:2.1",
      "pali": "… Muttā therī …."
    }
  ]
}
