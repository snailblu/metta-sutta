{
  "uid": "mil3.6.8",
  "title": "8. Paññāpatiṭṭhānapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.6.8:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.6.8:1.2",
      "pali": "“bhante nāgasena, paññā kuhiṁ paṭivasatī”ti?"
    },
    {
      "id": "mil3.6.8:1.3",
      "pali": "“Na katthaci, mahārājā”ti."
    },
    {
      "id": "mil3.6.8:1.4",
      "pali": "“Tena hi, bhante nāgasena, natthi paññā”ti."
    },
    {
      "id": "mil3.6.8:1.5",
      "pali": "“Vāto, mahārāja, kuhiṁ paṭivasatī”ti?"
    },
    {
      "id": "mil3.6.8:1.6",
      "pali": "“Na katthaci, bhante”ti."
    },
    {
      "id": "mil3.6.8:1.7",
      "pali": "“Tena hi, mahārāja, natthi vāto”ti."
    },
    {
      "id": "mil3.6.8:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.6.8:3.1",
      "pali": "Paññāpatiṭṭhānapañho aṭṭhamo."
    }
  ]
}
