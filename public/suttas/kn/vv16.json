{
  "uid": "vv16",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv16:1.1",
      "pali": "“Yuttā ca te paramaalaṅkatā hayā,"
    },
    {
      "id": "vv16:1.2",
      "pali": "Adhomukhā aghasigamā balī javā;"
    },
    {
      "id": "vv16:1.3",
      "pali": "Abhinimmitā pañcarathāsatā ca te,"
    },
    {
      "id": "vv16:1.4",
      "pali": "Anventi taṁ sārathicoditā hayā."
    },
    {
      "id": "vv16:2.1",
      "pali": "Sā tiṭṭhasi rathavare alaṅkatā,"
    },
    {
      "id": "vv16:2.2",
      "pali": "Obhāsayaṁ jalamiva joti pāvako;"
    },
    {
      "id": "vv16:2.3",
      "pali": "Pucchāmi taṁ varatanu anomadassane,"
    },
    {
      "id": "vv16:2.4",
      "pali": "Kasmā nu kāyā anadhivaraṁ upāgami”."
    },
    {
      "id": "vv16:3.1",
      "pali": "“Kāmaggapattānaṁ yamāhunuttaraṁ,"
    },
    {
      "id": "vv16:3.2",
      "pali": "Nimmāya nimmāya ramanti devatā;"
    },
    {
      "id": "vv16:3.3",
      "pali": "Tasmā kāyā accharā kāmavaṇṇinī,"
    },
    {
      "id": "vv16:3.4",
      "pali": "Idhāgatā anadhivaraṁ namassituṁ”."
    },
    {
      "id": "vv16:4.1",
      "pali": "“Kiṁ tvaṁ pure sucaritamācarīdha,"
    },
    {
      "id": "vv16:4.2",
      "pali": "Kenacchasi tvaṁ amitayasā sukhedhitā;"
    },
    {
      "id": "vv16:4.3",
      "pali": "Iddhī ca te anadhivarā vihaṅgamā,"
    },
    {
      "id": "vv16:4.4",
      "pali": "Vaṇṇo ca te dasa disā virocati."
    },
    {
      "id": "vv16:5.1",
      "pali": "Devehi tvaṁ parivutā sakkatā casi,"
    },
    {
      "id": "vv16:5.2",
      "pali": "Kuto cutā sugatigatāsi devate;"
    },
    {
      "id": "vv16:5.3",
      "pali": "Kassa vā tvaṁ vacanakarānusāsaniṁ,"
    },
    {
      "id": "vv16:5.4",
      "pali": "Ācikkha me tvaṁ yadi buddhasāvikā”ti."
    },
    {
      "id": "vv16:6.1",
      "pali": "“Nagantare nagaravare sumāpite,"
    },
    {
      "id": "vv16:6.2",
      "pali": "Paricārikā rājavarassa sirimato;"
    },
    {
      "id": "vv16:6.3",
      "pali": "Nacce gīte paramasusikkhitā ahuṁ,"
    },
    {
      "id": "vv16:6.4",
      "pali": "Sirimāti maṁ rājagahe avediṁsu."
    },
    {
      "id": "vv16:7.1",
      "pali": "Buddho ca me isinisabho vināyako,"
    },
    {
      "id": "vv16:7.2",
      "pali": "Adesayī samudayadukkhaniccataṁ;"
    },
    {
      "id": "vv16:7.3",
      "pali": "Asaṅkhataṁ dukkhanirodhasassataṁ,"
    },
    {
      "id": "vv16:7.4",
      "pali": "Maggañcimaṁ akuṭilamañjasaṁ sivaṁ."
    },
    {
      "id": "vv16:8.1",
      "pali": "Sutvānahaṁ amatapadaṁ asaṅkhataṁ,"
    },
    {
      "id": "vv16:8.2",
      "pali": "Tathāgatassanadhivarassa sāsanaṁ;"
    },
    {
      "id": "vv16:8.3",
      "pali": "Sīlesvahaṁ paramasusaṁvutā ahuṁ,"
    },
    {
      "id": "vv16:8.4",
      "pali": "Dhamme ṭhitā naravarabuddhadesite."
    },
    {
      "id": "vv16:9.1",
      "pali": "Ñatvānahaṁ virajapadaṁ asaṅkhataṁ,"
    },
    {
      "id": "vv16:9.2",
      "pali": "Tathāgatenanadhivarena desitaṁ;"
    },
    {
      "id": "vv16:9.3",
      "pali": "Tatthevahaṁ samathasamādhimāphusiṁ,"
    },
    {
      "id": "vv16:9.4",
      "pali": "Sāyeva me paramaniyāmatā ahu."
    },
    {
      "id": "vv16:10.1",
      "pali": "Laddhānahaṁ amatavaraṁ visesanaṁ,"
    },
    {
      "id": "vv16:10.2",
      "pali": "Ekaṁsikā abhisamaye visesiya;"
    },
    {
      "id": "vv16:10.3",
      "pali": "Asaṁsayā bahujanapūjitā ahaṁ,"
    },
    {
      "id": "vv16:10.4",
      "pali": "Khiḍḍāratiṁ paccanubhomanappakaṁ."
    },
    {
      "id": "vv16:11.1",
      "pali": "Evaṁ ahaṁ amatadasamhi devatā,"
    },
    {
      "id": "vv16:11.2",
      "pali": "Tathāgatassanadhivarassa sāvikā;"
    },
    {
      "id": "vv16:11.3",
      "pali": "Dhammaddasā paṭhamaphale patiṭṭhitā,"
    },
    {
      "id": "vv16:11.4",
      "pali": "Sotāpannā na ca pana matthi duggati."
    },
    {
      "id": "vv16:12.1",
      "pali": "Sā vandituṁ anadhivaraṁ upāgamiṁ,"
    },
    {
      "id": "vv16:12.2",
      "pali": "Pāsādike kusalarate ca bhikkhavo;"
    },
    {
      "id": "vv16:12.3",
      "pali": "Namassituṁ samaṇasamāgamaṁ sivaṁ,"
    },
    {
      "id": "vv16:12.4",
      "pali": "Sagāravā sirimato dhammarājino."
    },
    {
      "id": "vv16:13.1",
      "pali": "Disvā muniṁ muditamanamhi pīṇitā,"
    },
    {
      "id": "vv16:13.2",
      "pali": "Tathāgataṁ naravaradammasārathiṁ;"
    },
    {
      "id": "vv16:13.3",
      "pali": "Taṇhacchidaṁ kusalarataṁ vināyakaṁ,"
    },
    {
      "id": "vv16:13.4",
      "pali": "Vandāmahaṁ paramahitānukampakan”ti."
    },
    {
      "id": "vv16:14.1",
      "pali": "Sirimāvimānaṁ soḷasamaṁ."
    }
  ]
}
