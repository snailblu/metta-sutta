{
  "uid": "pv32",
  "title": "7. Migaluddakapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv32:1.1",
      "pali": "“Naranāripurakkhato yuvā,"
    },
    {
      "id": "pv32:1.2",
      "pali": "Rajanīyehi kāmaguṇehi sobhasi;"
    },
    {
      "id": "pv32:1.3",
      "pali": "Divasaṁ anubhosi kāraṇaṁ,"
    },
    {
      "id": "pv32:1.4",
      "pali": "Kimakāsi purimāya jātiyā”ti."
    },
    {
      "id": "pv32:2.1",
      "pali": "“Ahaṁ rājagahe ramme,"
    },
    {
      "id": "pv32:2.2",
      "pali": "ramaṇīye giribbaje;"
    },
    {
      "id": "pv32:2.3",
      "pali": "Migaluddo pure āsiṁ,"
    },
    {
      "id": "pv32:2.4",
      "pali": "lohitapāṇi dāruṇo."
    },
    {
      "id": "pv32:3.1",
      "pali": "Avirodhakaresu pāṇisu,"
    },
    {
      "id": "pv32:3.2",
      "pali": "Puthusattesu paduṭṭhamānaso;"
    },
    {
      "id": "pv32:3.3",
      "pali": "Vicariṁ atidāruṇo sadā,"
    },
    {
      "id": "pv32:3.4",
      "pali": "Parahiṁsāya rato asaññato."
    },
    {
      "id": "pv32:4.1",
      "pali": "Tassa me sahāyo suhadayo,"
    },
    {
      "id": "pv32:4.2",
      "pali": "Saddho āsi upāsako;"
    },
    {
      "id": "pv32:4.3",
      "pali": "Sopi maṁ anukampanto,"
    },
    {
      "id": "pv32:4.4",
      "pali": "Nivāresi punappunaṁ."
    },
    {
      "id": "pv32:5.1",
      "pali": "‘Mākāsi pāpakaṁ kammaṁ,"
    },
    {
      "id": "pv32:5.2",
      "pali": "Mā tāta duggatiṁ agā;"
    },
    {
      "id": "pv32:5.3",
      "pali": "Sace icchasi pecca sukhaṁ,"
    },
    {
      "id": "pv32:5.4",
      "pali": "Virama pāṇavadhā asaṁyamā’."
    },
    {
      "id": "pv32:6.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "pv32:6.2",
      "pali": "Sukhakāmassa hitānukampino;"
    },
    {
      "id": "pv32:6.3",
      "pali": "Nākāsiṁ sakalānusāsaniṁ,"
    },
    {
      "id": "pv32:6.4",
      "pali": "Cirapāpābhirato abuddhimā."
    },
    {
      "id": "pv32:7.1",
      "pali": "So maṁ puna bhūrisumedhaso,"
    },
    {
      "id": "pv32:7.2",
      "pali": "Anukampāya saṁyame nivesayi;"
    },
    {
      "id": "pv32:7.3",
      "pali": "‘Sace divā hanasi pāṇino,"
    },
    {
      "id": "pv32:7.4",
      "pali": "Atha te rattiṁ bhavatu saṁyamo’."
    },
    {
      "id": "pv32:8.1",
      "pali": "Svāhaṁ divā hanitvā pāṇino,"
    },
    {
      "id": "pv32:8.2",
      "pali": "Virato rattimahosi saññato;"
    },
    {
      "id": "pv32:8.3",
      "pali": "Rattāhaṁ paricāremi,"
    },
    {
      "id": "pv32:8.4",
      "pali": "Divā khajjāmi duggato."
    },
    {
      "id": "pv32:9.1",
      "pali": "Tassa kammassa kusalassa,"
    },
    {
      "id": "pv32:9.2",
      "pali": "Anubhomi rattiṁ amānusiṁ;"
    },
    {
      "id": "pv32:9.3",
      "pali": "Divā paṭihatāva kukkurā,"
    },
    {
      "id": "pv32:9.4",
      "pali": "Upadhāvanti samantā khādituṁ."
    },
    {
      "id": "pv32:10.1",
      "pali": "Ye ca te satatānuyogino,"
    },
    {
      "id": "pv32:10.2",
      "pali": "Dhuvaṁ payuttā sugatassa sāsane;"
    },
    {
      "id": "pv32:10.3",
      "pali": "Maññāmi te amatameva kevalaṁ,"
    },
    {
      "id": "pv32:10.4",
      "pali": "Adhigacchanti padaṁ asaṅkhatan”ti."
    },
    {
      "id": "pv32:11.1",
      "pali": "Migaluddakapetavatthu sattamaṁ."
    }
  ]
}
