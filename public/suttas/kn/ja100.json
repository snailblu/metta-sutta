{
  "uid": "ja100",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja100:1.1",
      "pali": "“Asātaṁ sātarūpena,"
    },
    {
      "id": "ja100:1.2",
      "pali": "piyarūpena appiyaṁ;"
    },
    {
      "id": "ja100:1.3",
      "pali": "Dukkhaṁ sukhassa rūpena,"
    },
    {
      "id": "ja100:1.4",
      "pali": "pamattamativattatī”ti."
    },
    {
      "id": "ja100:2.1",
      "pali": "Asātarūpajātakaṁ dasamaṁ."
    },
    {
      "id": "ja100:2.2",
      "pali": "Littavaggo dasamo."
    },
    {
      "id": "ja100:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja100:4.1",
      "pali": "Gilamakkhakutūhala mātukassā,"
    },
    {
      "id": "ja100:4.2",
      "pali": "Muninā ca aniccata pattavaraṁ;"
    },
    {
      "id": "ja100:4.3",
      "pali": "Dhanapālivaro atipaṇḍitako,"
    },
    {
      "id": "ja100:4.4",
      "pali": "Saparosahassaasātadasāti."
    },
    {
      "id": "ja100:5.1",
      "pali": "Majjhimo paṇṇāsako."
    }
  ]
}
