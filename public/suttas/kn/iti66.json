{
  "uid": "iti66",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti66:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti66:2.1",
      "pali": "“Tīṇimāni, bhikkhave, soceyyāni."
    },
    {
      "id": "iti66:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti66:2.3",
      "pali": "Kāyasoceyyaṁ, vacīsoceyyaṁ, manosoceyyaṁ—"
    },
    {
      "id": "iti66:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi soceyyānī”ti."
    },
    {
      "id": "iti66:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti66:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti66:3.1",
      "pali": "“Kāyasuciṁ vacīsuciṁ,"
    },
    {
      "id": "iti66:3.2",
      "pali": "cetosucimanāsavaṁ;"
    },
    {
      "id": "iti66:3.3",
      "pali": "Suciṁ soceyyasampannaṁ,"
    },
    {
      "id": "iti66:3.4",
      "pali": "āhu sabbappahāyinan”ti."
    },
    {
      "id": "iti66:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti66:4.2",
      "pali": "Sattamaṁ."
    }
  ]
}
