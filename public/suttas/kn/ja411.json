{
  "uid": "ja411",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja411:1.1",
      "pali": "“Kāḷāni kesāni pure ahesuṁ,"
    },
    {
      "id": "ja411:1.2",
      "pali": "Jātāni sīsamhi yathāpadese;"
    },
    {
      "id": "ja411:1.3",
      "pali": "Tānajja setāni susīma disvā,"
    },
    {
      "id": "ja411:1.4",
      "pali": "Dhammaṁ cara brahmacariyassa kālo”."
    },
    {
      "id": "ja411:2.1",
      "pali": "“Mameva deva palitaṁ na tuyhaṁ,"
    },
    {
      "id": "ja411:2.2",
      "pali": "Mameva sīsaṁ mama uttamaṅgaṁ;"
    },
    {
      "id": "ja411:2.3",
      "pali": "‘Atthaṁ karissan’ti musā abhāṇiṁ,"
    },
    {
      "id": "ja411:2.4",
      "pali": "Ekāparādhaṁ khama rājaseṭṭha."
    },
    {
      "id": "ja411:3.1",
      "pali": "Daharo tuvaṁ dassaniyosi rāja,"
    },
    {
      "id": "ja411:3.2",
      "pali": "Paṭhamuggato hosi yathā kaḷīro;"
    },
    {
      "id": "ja411:3.3",
      "pali": "Rajjañca kārehi mamañca passa,"
    },
    {
      "id": "ja411:3.4",
      "pali": "Mā kālikaṁ anudhāvī janinda”."
    },
    {
      "id": "ja411:4.1",
      "pali": "“Passāmi vohaṁ dahariṁ kumāriṁ,"
    },
    {
      "id": "ja411:4.2",
      "pali": "Sāmaṭṭhapassaṁ sutanuṁ sumajjhaṁ;"
    },
    {
      "id": "ja411:4.3",
      "pali": "Kāḷappavāḷāva pavellamānā,"
    },
    {
      "id": "ja411:4.4",
      "pali": "Palobhayantīva naresu gacchati."
    },
    {
      "id": "ja411:5.1",
      "pali": "Tamena passāmiparena nāriṁ,"
    },
    {
      "id": "ja411:5.2",
      "pali": "Āsītikaṁ nāvutikaṁ va jaccā;"
    },
    {
      "id": "ja411:5.3",
      "pali": "Daṇḍaṁ gahetvāna pavedhamānaṁ,"
    },
    {
      "id": "ja411:5.4",
      "pali": "Gopānasībhoggasamaṁ carantiṁ."
    },
    {
      "id": "ja411:6.1",
      "pali": "Sohaṁ tamevānuvicintayanto,"
    },
    {
      "id": "ja411:6.2",
      "pali": "Eko sayāmi sayanassa majjhe;"
    },
    {
      "id": "ja411:6.3",
      "pali": "‘Ahampi evaṁ’ iti pekkhamāno,"
    },
    {
      "id": "ja411:6.4",
      "pali": "Na gahe rame brahmacariyassa kālo."
    },
    {
      "id": "ja411:7.1",
      "pali": "Rajjuvālambanī cesā,"
    },
    {
      "id": "ja411:7.2",
      "pali": "Yā gehe vasato rati;"
    },
    {
      "id": "ja411:7.3",
      "pali": "Evampi chetvāna vajanti dhīrā,"
    },
    {
      "id": "ja411:7.4",
      "pali": "Anapekkhino kāmasukhaṁ pahāyā”ti."
    },
    {
      "id": "ja411:8.1",
      "pali": "Susīmajātakaṁ chaṭṭhaṁ."
    }
  ]
}
