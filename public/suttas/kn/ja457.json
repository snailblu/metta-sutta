{
  "uid": "ja457",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja457:1.1",
      "pali": "“Yasokaro puññakarohamasmi,"
    },
    {
      "id": "ja457:1.2",
      "pali": "Sadātthuto samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "ja457:1.3",
      "pali": "Maggāraho devamanussapūjito,"
    },
    {
      "id": "ja457:1.4",
      "pali": "Dhammo ahaṁ dehi adhamma maggaṁ”."
    },
    {
      "id": "ja457:2.1",
      "pali": "“Adhammayānaṁ daḷhamāruhitvā,"
    },
    {
      "id": "ja457:2.2",
      "pali": "Asantasanto balavāhamasmi;"
    },
    {
      "id": "ja457:2.3",
      "pali": "Sa kissa hetumhi tavajja dajjaṁ,"
    },
    {
      "id": "ja457:2.4",
      "pali": "Maggaṁ ahaṁ dhamma adinnapubbaṁ”."
    },
    {
      "id": "ja457:3.1",
      "pali": "“Dhammo have pāturahosi pubbe,"
    },
    {
      "id": "ja457:3.2",
      "pali": "Pacchā adhammo udapādi loke;"
    },
    {
      "id": "ja457:3.3",
      "pali": "Jeṭṭho ca seṭṭho ca sanantano ca,"
    },
    {
      "id": "ja457:3.4",
      "pali": "Uyyāhi jeṭṭhassa kaniṭṭha maggā”."
    },
    {
      "id": "ja457:4.1",
      "pali": "“Na yācanāya napi pātirūpā,"
    },
    {
      "id": "ja457:4.2",
      "pali": "Na arahatā tehaṁ dadeyyaṁ maggaṁ;"
    },
    {
      "id": "ja457:4.3",
      "pali": "Yuddhañca no hotu ubhinnamajja,"
    },
    {
      "id": "ja457:4.4",
      "pali": "Yuddhamhi yo jessati tassa maggo”."
    },
    {
      "id": "ja457:5.1",
      "pali": "“Sabbā disā anuvisaṭohamasmi,"
    },
    {
      "id": "ja457:5.2",
      "pali": "Mahabbalo amitayaso atulyo;"
    },
    {
      "id": "ja457:5.3",
      "pali": "Guṇehi sabbehi upetarūpo,"
    },
    {
      "id": "ja457:5.4",
      "pali": "Dhammo adhamma tvaṁ kathaṁ vijessasi."
    },
    {
      "id": "ja457:6.1",
      "pali": "Lohena ve haññati jātarūpaṁ,"
    },
    {
      "id": "ja457:6.2",
      "pali": "Na jātarūpena hananti lohaṁ;"
    },
    {
      "id": "ja457:6.3",
      "pali": "Sace adhammo hañchati dhammamajja,"
    },
    {
      "id": "ja457:6.4",
      "pali": "Ayo suvaṇṇaṁ viya dassaneyyaṁ."
    },
    {
      "id": "ja457:7.1",
      "pali": "Sace tuvaṁ yuddhabalo adhamma,"
    },
    {
      "id": "ja457:7.2",
      "pali": "Na tuyha vuḍḍhā ca garū ca atthi;"
    },
    {
      "id": "ja457:7.3",
      "pali": "Maggañca te dammi piyāppiyena,"
    },
    {
      "id": "ja457:7.4",
      "pali": "Vācāduruttānipi te khamāmi”."
    },
    {
      "id": "ja457:8.1",
      "pali": "“Idañca sutvā vacanaṁ adhammo,"
    },
    {
      "id": "ja457:8.2",
      "pali": "Avaṁsiro patito uddhapādo;"
    },
    {
      "id": "ja457:8.3",
      "pali": "‘Yuddhatthiko ce na labhāmi yuddhaṁ’,"
    },
    {
      "id": "ja457:8.4",
      "pali": "Ettāvatā hoti hato adhammo."
    },
    {
      "id": "ja457:9.1",
      "pali": "Khantībalo yuddhabalaṁ vijetvā,"
    },
    {
      "id": "ja457:9.2",
      "pali": "Hantvā adhammaṁ nihanitva bhūmyā;"
    },
    {
      "id": "ja457:9.3",
      "pali": "Pāyāsi vitto abhiruyha sandanaṁ,"
    },
    {
      "id": "ja457:9.4",
      "pali": "Maggeneva atibalo saccanikkamo."
    },
    {
      "id": "ja457:10.1",
      "pali": "Mātā pitā samaṇabrāhmaṇā ca,"
    },
    {
      "id": "ja457:10.2",
      "pali": "Asammānitā yassa sake agāre;"
    },
    {
      "id": "ja457:10.3",
      "pali": "Idheva nikkhippa sarīradehaṁ,"
    },
    {
      "id": "ja457:10.4",
      "pali": "Kāyassa bhedā nirayaṁ vajanti te;"
    },
    {
      "id": "ja457:10.5",
      "pali": "Yathā adhammo patito avaṁsiro."
    },
    {
      "id": "ja457:11.1",
      "pali": "Mātā pitā samaṇabrāhmaṇā ca,"
    },
    {
      "id": "ja457:11.2",
      "pali": "Susammānitā yassa sake agāre;"
    },
    {
      "id": "ja457:11.3",
      "pali": "Idheva nikkhippa sarīradehaṁ,"
    },
    {
      "id": "ja457:11.4",
      "pali": "Kāyassa bhedā sugatiṁ vajanti te;"
    },
    {
      "id": "ja457:11.5",
      "pali": "Yathāpi dhammo abhiruyha sandanan”ti."
    },
    {
      "id": "ja457:12.1",
      "pali": "Dhammadevaputtajātakaṁ tatiyaṁ."
    }
  ]
}
