{
  "uid": "tha-ap97",
  "title": "Gandhamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap97:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap97:1.2",
      "pali": "gandhathūpaṁ akāsahaṁ;"
    },
    {
      "id": "tha-ap97:1.3",
      "pali": "Sumanehi paṭicchannaṁ,"
    },
    {
      "id": "tha-ap97:1.4",
      "pali": "buddhānucchavikaṁ kataṁ."
    },
    {
      "id": "tha-ap97:2.1",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap97:2.2",
      "pali": "buddhaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap97:2.3",
      "pali": "Indīvaraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap97:2.4",
      "pali": "ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap97:3.1",
      "pali": "Byagghūsabhaṁva pavaraṁ,"
    },
    {
      "id": "tha-ap97:3.2",
      "pali": "abhijātaṁva kesariṁ;"
    },
    {
      "id": "tha-ap97:3.3",
      "pali": "Nisinnaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap97:3.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap97:4.1",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap97:4.2",
      "pali": "pakkāmiṁ uttarāmukho;"
    },
    {
      "id": "tha-ap97:4.3",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap97:4.4",
      "pali": "gandhamālaṁ yato adaṁ."
    },
    {
      "id": "tha-ap97:5.1",
      "pali": "Buddhe katassa kārassa,"
    },
    {
      "id": "tha-ap97:5.2",
      "pali": "phalenāhaṁ visesato;"
    },
    {
      "id": "tha-ap97:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap97:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap97:6.1",
      "pali": "Cattārīsamhi ekūne,"
    },
    {
      "id": "tha-ap97:6.2",
      "pali": "kappe āsiṁsu soḷasa;"
    },
    {
      "id": "tha-ap97:6.3",
      "pali": "Devagandhasanāmā te,"
    },
    {
      "id": "tha-ap97:6.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap97:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap97:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap97:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap97:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap97:9.1",
      "pali": "Gandhamāliyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
