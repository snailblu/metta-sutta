{
  "uid": "tha-ap327",
  "title": "Nimittasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap327:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap327:1.2",
      "pali": "vasāmi assame ahaṁ;"
    },
    {
      "id": "tha-ap327:1.3",
      "pali": "Suvaṇṇamigamaddakkhiṁ,"
    },
    {
      "id": "tha-ap327:1.4",
      "pali": "carantaṁ vipine ahaṁ."
    },
    {
      "id": "tha-ap327:2.1",
      "pali": "Mige cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap327:2.2",
      "pali": "lokajeṭṭhaṁ anussariṁ;"
    },
    {
      "id": "tha-ap327:2.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap327:2.4",
      "pali": "aññe buddhe anussariṁ."
    },
    {
      "id": "tha-ap327:3.1",
      "pali": "Abbhatītā ca ye buddhā,"
    },
    {
      "id": "tha-ap327:3.2",
      "pali": "vattamānā anāgatā;"
    },
    {
      "id": "tha-ap327:3.3",
      "pali": "Evamevaṁ virocanti,"
    },
    {
      "id": "tha-ap327:3.4",
      "pali": "migarājāva te tayo."
    },
    {
      "id": "tha-ap327:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap327:4.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap327:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap327:4.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap327:5.1",
      "pali": "Sattavīse ito kappe,"
    },
    {
      "id": "tha-ap327:5.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap327:5.3",
      "pali": "Araññasattho nāmena,"
    },
    {
      "id": "tha-ap327:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap327:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap327:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap327:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap327:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā nimittasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap327:8.1",
      "pali": "Nimittasaññakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
