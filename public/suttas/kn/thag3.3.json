{
  "uid": "thag3.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.3:1.1",
      "pali": "“Yo pubbe karaṇīyāni,"
    },
    {
      "id": "thag3.3:1.2",
      "pali": "pacchā so kātumicchati;"
    },
    {
      "id": "thag3.3:1.3",
      "pali": "Sukhā so dhaṁsate ṭhānā,"
    },
    {
      "id": "thag3.3:1.4",
      "pali": "pacchā ca manutappati."
    },
    {
      "id": "thag3.3:2.1",
      "pali": "Yañhi kayirā tañhi vade,"
    },
    {
      "id": "thag3.3:2.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "thag3.3:2.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "thag3.3:2.4",
      "pali": "parijānanti paṇḍitā."
    },
    {
      "id": "thag3.3:3.1",
      "pali": "Susukhaṁ vata nibbānaṁ,"
    },
    {
      "id": "thag3.3:3.2",
      "pali": "sammāsambuddhadesitaṁ;"
    },
    {
      "id": "thag3.3:3.3",
      "pali": "Asokaṁ virajaṁ khemaṁ,"
    },
    {
      "id": "thag3.3:3.4",
      "pali": "yattha dukkhaṁ nirujjhatī”ti."
    },
    {
      "id": "thag3.3:3.5",
      "pali": "… Bākulo thero …."
    }
  ]
}
