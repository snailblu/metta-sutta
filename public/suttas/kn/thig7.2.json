{
  "uid": "thig7.2",
  "title": "Cālātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig7.2:1.1",
      "pali": "“Satiṁ upaṭṭhapetvāna,"
    },
    {
      "id": "thig7.2:1.2",
      "pali": "bhikkhunī bhāvitindriyā;"
    },
    {
      "id": "thig7.2:1.3",
      "pali": "Paṭivijjhi padaṁ santaṁ,"
    },
    {
      "id": "thig7.2:1.4",
      "pali": "saṅkhārūpasamaṁ sukhaṁ”."
    },
    {
      "id": "thig7.2:2.1",
      "pali": "“Kaṁ nu uddissa muṇḍāsi,"
    },
    {
      "id": "thig7.2:2.2",
      "pali": "samaṇī viya dissasi;"
    },
    {
      "id": "thig7.2:2.3",
      "pali": "Na ca rocesi pāsaṇḍe,"
    },
    {
      "id": "thig7.2:2.4",
      "pali": "kimidaṁ carasi momuhā”."
    },
    {
      "id": "thig7.2:3.1",
      "pali": "“Ito bahiddhā pāsaṇḍā,"
    },
    {
      "id": "thig7.2:3.2",
      "pali": "diṭṭhiyo upanissitā;"
    },
    {
      "id": "thig7.2:3.3",
      "pali": "Na te dhammaṁ vijānanti,"
    },
    {
      "id": "thig7.2:3.4",
      "pali": "na te dhammassa kovidā."
    },
    {
      "id": "thig7.2:4.1",
      "pali": "Atthi sakyakule jāto,"
    },
    {
      "id": "thig7.2:4.2",
      "pali": "buddho appaṭipuggalo;"
    },
    {
      "id": "thig7.2:4.3",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thig7.2:4.4",
      "pali": "diṭṭhīnaṁ samatikkamaṁ."
    },
    {
      "id": "thig7.2:5.1",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "thig7.2:5.2",
      "pali": "Dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "thig7.2:5.3",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thig7.2:5.4",
      "pali": "Dukkhūpasamagāminaṁ."
    },
    {
      "id": "thig7.2:6.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig7.2:6.2",
      "pali": "vihariṁ sāsane ratā;"
    },
    {
      "id": "thig7.2:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig7.2:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig7.2:7.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig7.2:7.2",
      "pali": "tamokhandho padālito;"
    },
    {
      "id": "thig7.2:7.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig7.2:7.4",
      "pali": "nihato tvamasi antaka”."
    },
    {
      "id": "thig7.2:8.1",
      "pali": "… Cālā therī …."
    }
  ]
}
