{
  "uid": "thag2.21",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.21:1.1",
      "pali": "“Khandhā mayā pariññātā,"
    },
    {
      "id": "thag2.21:1.2",
      "pali": "taṇhā me susamūhatā;"
    },
    {
      "id": "thag2.21:1.3",
      "pali": "Bhāvitā mama bojjhaṅgā,"
    },
    {
      "id": "thag2.21:1.4",
      "pali": "patto me āsavakkhayo."
    },
    {
      "id": "thag2.21:2.1",
      "pali": "Sohaṁ khandhe pariññāya,"
    },
    {
      "id": "thag2.21:2.2",
      "pali": "abbahitvāna jāliniṁ;"
    },
    {
      "id": "thag2.21:2.3",
      "pali": "Bhāvayitvāna bojjhaṅge,"
    },
    {
      "id": "thag2.21:2.4",
      "pali": "nibbāyissaṁ anāsavo”ti."
    },
    {
      "id": "thag2.21:2.5",
      "pali": "… Uttaro thero …."
    }
  ]
}
