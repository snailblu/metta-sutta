{
  "uid": "tha-ap300",
  "title": "Saraṇagamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap300:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap300:1.2",
      "pali": "ahosiṁ luddako tadā;"
    },
    {
      "id": "tha-ap300:1.3",
      "pali": "Vipassiṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap300:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap300:2.1",
      "pali": "Upāsitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap300:2.2",
      "pali": "veyyāvaccamakāsahaṁ;"
    },
    {
      "id": "tha-ap300:2.3",
      "pali": "Saraṇañca upāgacchiṁ,"
    },
    {
      "id": "tha-ap300:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap300:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap300:3.2",
      "pali": "saraṇaṁ upagacchahaṁ;"
    },
    {
      "id": "tha-ap300:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap300:3.4",
      "pali": "saraṇāgamanapphalaṁ."
    },
    {
      "id": "tha-ap300:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap300:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap300:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap300:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā saraṇagamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap300:6.1",
      "pali": "Saraṇagamaniyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
