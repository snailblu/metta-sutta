{
  "uid": "thag1.105",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.105:1.1",
      "pali": "“Ukkaṇṭhitopi na vase,"
    },
    {
      "id": "thag1.105:1.2",
      "pali": "ramamānopi pakkame;"
    },
    {
      "id": "thag1.105:1.3",
      "pali": "Na tvevānatthasaṁhitaṁ,"
    },
    {
      "id": "thag1.105:1.4",
      "pali": "vase vāsaṁ vicakkhaṇo”ti."
    },
    {
      "id": "thag1.105:1.5",
      "pali": "… Malitavambho thero …."
    }
  ]
}
