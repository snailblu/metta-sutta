{
  "uid": "pv4",
  "title": "4. Piṭṭhadhītalikapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv4:1.1",
      "pali": "“Yaṁ kiñcārammaṇaṁ katvā,"
    },
    {
      "id": "pv4:1.2",
      "pali": "dajjā dānaṁ amaccharī;"
    },
    {
      "id": "pv4:1.3",
      "pali": "Pubbapete ca ārabbha,"
    },
    {
      "id": "pv4:1.4",
      "pali": "atha vā vatthudevatā."
    },
    {
      "id": "pv4:2.1",
      "pali": "Cattāro ca mahārāje,"
    },
    {
      "id": "pv4:2.2",
      "pali": "lokapāle yasassine;"
    },
    {
      "id": "pv4:2.3",
      "pali": "Kuveraṁ dhataraṭṭhañca,"
    },
    {
      "id": "pv4:2.4",
      "pali": "virūpakkhaṁ virūḷhakaṁ;"
    },
    {
      "id": "pv4:2.5",
      "pali": "Te ceva pūjitā honti,"
    },
    {
      "id": "pv4:2.6",
      "pali": "dāyakā ca anipphalā."
    },
    {
      "id": "pv4:3.1",
      "pali": "Na hi ruṇṇaṁ vā soko vā,"
    },
    {
      "id": "pv4:3.2",
      "pali": "yā caññā paridevanā;"
    },
    {
      "id": "pv4:3.3",
      "pali": "Na taṁ petassa atthāya,"
    },
    {
      "id": "pv4:3.4",
      "pali": "evaṁ tiṭṭhanti ñātayo."
    },
    {
      "id": "pv4:4.1",
      "pali": "Ayañca kho dakkhiṇā dinnā,"
    },
    {
      "id": "pv4:4.2",
      "pali": "saṅghamhi suppatiṭṭhitā;"
    },
    {
      "id": "pv4:4.3",
      "pali": "Dīgharattaṁ hitāyassa,"
    },
    {
      "id": "pv4:4.4",
      "pali": "ṭhānaso upakappatī”ti."
    },
    {
      "id": "pv4:5.1",
      "pali": "Piṭṭhadhītalikapetavatthu catutthaṁ."
    }
  ]
}
