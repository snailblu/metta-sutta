{
  "uid": "thag1.110",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.110:1.1",
      "pali": "“Nagā nagaggesu susaṁvirūḷhā,"
    },
    {
      "id": "thag1.110:1.2",
      "pali": "Udaggameghena navena sittā;"
    },
    {
      "id": "thag1.110:1.3",
      "pali": "Vivekakāmassa araññasaññino,"
    },
    {
      "id": "thag1.110:1.4",
      "pali": "Janeti bhiyyo usabhassa kalyatan”ti."
    },
    {
      "id": "thag1.110:1.5",
      "pali": "… Usabho thero …"
    },
    {
      "id": "thag1.110:1.6",
      "pali": "vaggo ekādasamo."
    },
    {
      "id": "thag1.110:2.1",
      "pali": "Belaṭṭhāniko setuccho,"
    },
    {
      "id": "thag1.110:2.2",
      "pali": "Bandhuro khitako isi;"
    },
    {
      "id": "thag1.110:2.3",
      "pali": "Malitavambho suhemanto,"
    },
    {
      "id": "thag1.110:2.4",
      "pali": "Dhammasavo dhammasavapitā;"
    },
    {
      "id": "thag1.110:2.5",
      "pali": "Saṅgharakkhitatthero ca,"
    },
    {
      "id": "thag1.110:2.6",
      "pali": "Usabho ca mahāmunīti."
    }
  ]
}
