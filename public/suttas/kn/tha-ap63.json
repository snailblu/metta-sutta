{
  "uid": "tha-ap63",
  "title": "1 Sakacintaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap63:1.1",
      "pali": "“Pavanaṁ kānanaṁ disvā,"
    },
    {
      "id": "tha-ap63:1.2",
      "pali": "appasaddamanāvilaṁ;"
    },
    {
      "id": "tha-ap63:1.3",
      "pali": "Isīnaṁ anuciṇṇaṁva,"
    },
    {
      "id": "tha-ap63:1.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap63:2.1",
      "pali": "Thūpaṁ katvāna pulinaṁ,"
    },
    {
      "id": "tha-ap63:2.2",
      "pali": "nānāpupphaṁ samokiriṁ;"
    },
    {
      "id": "tha-ap63:2.3",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap63:2.4",
      "pali": "nimmitaṁ abhivandahaṁ."
    },
    {
      "id": "tha-ap63:3.1",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap63:3.2",
      "pali": "rājā raṭṭhamhi issaro;"
    },
    {
      "id": "tha-ap63:3.3",
      "pali": "Sakakammābhiraddhohaṁ,"
    },
    {
      "id": "tha-ap63:3.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap63:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap63:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap63:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap63:4.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap63:5.1",
      "pali": "Asītikappenantayaso,"
    },
    {
      "id": "tha-ap63:5.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap63:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap63:5.4",
      "pali": "catudīpamhi issaro."
    },
    {
      "id": "tha-ap63:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap63:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap63:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap63:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap63:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sakacintaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap63:8.1",
      "pali": "Sakacintaniyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
