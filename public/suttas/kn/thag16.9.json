{
  "uid": "thag16.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.9:1.1",
      "pali": "“Pahāya mātāpitaro,"
    },
    {
      "id": "thag16.9:1.2",
      "pali": "bhaginī ñātibhātaro;"
    },
    {
      "id": "thag16.9:1.3",
      "pali": "Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "thag16.9:1.4",
      "pali": "anuruddhova jhāyati."
    },
    {
      "id": "thag16.9:2.1",
      "pali": "Sameto naccagītehi,"
    },
    {
      "id": "thag16.9:2.2",
      "pali": "sammatāḷappabodhano;"
    },
    {
      "id": "thag16.9:2.3",
      "pali": "Na tena suddhimajjhagaṁ,"
    },
    {
      "id": "thag16.9:2.4",
      "pali": "mārassa visaye rato."
    },
    {
      "id": "thag16.9:3.1",
      "pali": "Etañca samatikkamma,"
    },
    {
      "id": "thag16.9:3.2",
      "pali": "rato buddhassa sāsane;"
    },
    {
      "id": "thag16.9:3.3",
      "pali": "Sabboghaṁ samatikkamma,"
    },
    {
      "id": "thag16.9:3.4",
      "pali": "anuruddhova jhāyati."
    },
    {
      "id": "thag16.9:4.1",
      "pali": "Rūpā saddā rasā gandhā,"
    },
    {
      "id": "thag16.9:4.2",
      "pali": "phoṭṭhabbā ca manoramā;"
    },
    {
      "id": "thag16.9:4.3",
      "pali": "Ete ca samatikkamma,"
    },
    {
      "id": "thag16.9:4.4",
      "pali": "anuruddhova jhāyati."
    },
    {
      "id": "thag16.9:5.1",
      "pali": "Piṇḍapātamatikkanto,"
    },
    {
      "id": "thag16.9:5.2",
      "pali": "eko adutiyo muni;"
    },
    {
      "id": "thag16.9:5.3",
      "pali": "Esati paṁsukūlāni,"
    },
    {
      "id": "thag16.9:5.4",
      "pali": "anuruddho anāsavo."
    },
    {
      "id": "thag16.9:6.1",
      "pali": "Vicinī aggahī dhovi,"
    },
    {
      "id": "thag16.9:6.2",
      "pali": "rajayī dhārayī muni;"
    },
    {
      "id": "thag16.9:6.3",
      "pali": "Paṁsukūlāni matimā,"
    },
    {
      "id": "thag16.9:6.4",
      "pali": "anuruddho anāsavo."
    },
    {
      "id": "thag16.9:7.1",
      "pali": "Mahiccho ca asantuṭṭho,"
    },
    {
      "id": "thag16.9:7.2",
      "pali": "saṁsaṭṭho yo ca uddhato;"
    },
    {
      "id": "thag16.9:7.3",
      "pali": "Tassa dhammā ime honti,"
    },
    {
      "id": "thag16.9:7.4",
      "pali": "pāpakā saṅkilesikā."
    },
    {
      "id": "thag16.9:8.1",
      "pali": "Sato ca hoti appiccho,"
    },
    {
      "id": "thag16.9:8.2",
      "pali": "santuṭṭho avighātavā;"
    },
    {
      "id": "thag16.9:8.3",
      "pali": "Pavivekarato vitto,"
    },
    {
      "id": "thag16.9:8.4",
      "pali": "niccamāraddhavīriyo."
    },
    {
      "id": "thag16.9:9.1",
      "pali": "Tassa dhammā ime honti,"
    },
    {
      "id": "thag16.9:9.2",
      "pali": "kusalā bodhipakkhikā;"
    },
    {
      "id": "thag16.9:9.3",
      "pali": "Anāsavo ca so hoti,"
    },
    {
      "id": "thag16.9:9.4",
      "pali": "iti vuttaṁ mahesinā."
    },
    {
      "id": "thag16.9:10.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "thag16.9:10.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "thag16.9:10.3",
      "pali": "Manomayena kāyena,"
    },
    {
      "id": "thag16.9:10.4",
      "pali": "iddhiyā upasaṅkami."
    },
    {
      "id": "thag16.9:11.1",
      "pali": "Yadā me ahu saṅkappo,"
    },
    {
      "id": "thag16.9:11.2",
      "pali": "tato uttari desayi;"
    },
    {
      "id": "thag16.9:11.3",
      "pali": "Nippapañcarato buddho,"
    },
    {
      "id": "thag16.9:11.4",
      "pali": "nippapañcamadesayi."
    },
    {
      "id": "thag16.9:12.1",
      "pali": "Tassāhaṁ dhammamaññāya,"
    },
    {
      "id": "thag16.9:12.2",
      "pali": "vihāsiṁ sāsane rato;"
    },
    {
      "id": "thag16.9:12.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag16.9:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag16.9:13.1",
      "pali": "Pañcapaññāsavassāni,"
    },
    {
      "id": "thag16.9:13.2",
      "pali": "yato nesajjiko ahaṁ;"
    },
    {
      "id": "thag16.9:13.3",
      "pali": "Pañcavīsativassāni,"
    },
    {
      "id": "thag16.9:13.4",
      "pali": "yato middhaṁ samūhataṁ."
    },
    {
      "id": "thag16.9:14.1",
      "pali": "Nāhu assāsapassāsā,"
    },
    {
      "id": "thag16.9:14.2",
      "pali": "ṭhitacittassa tādino;"
    },
    {
      "id": "thag16.9:14.3",
      "pali": "Anejo santimārabbha,"
    },
    {
      "id": "thag16.9:14.4",
      "pali": "cakkhumā parinibbuto."
    },
    {
      "id": "thag16.9:15.1",
      "pali": "Asallīnena cittena,"
    },
    {
      "id": "thag16.9:15.2",
      "pali": "vedanaṁ ajjhavāsayi;"
    },
    {
      "id": "thag16.9:15.3",
      "pali": "Pajjotasseva nibbānaṁ,"
    },
    {
      "id": "thag16.9:15.4",
      "pali": "vimokkho cetaso ahu."
    },
    {
      "id": "thag16.9:16.1",
      "pali": "Ete pacchimakā dāni,"
    },
    {
      "id": "thag16.9:16.2",
      "pali": "munino phassapañcamā;"
    },
    {
      "id": "thag16.9:16.3",
      "pali": "Nāññe dhammā bhavissanti,"
    },
    {
      "id": "thag16.9:16.4",
      "pali": "sambuddhe parinibbute."
    },
    {
      "id": "thag16.9:17.1",
      "pali": "Natthi dāni punāvāso,"
    },
    {
      "id": "thag16.9:17.2",
      "pali": "devakāyasmi jālini;"
    },
    {
      "id": "thag16.9:17.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag16.9:17.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thag16.9:18.1",
      "pali": "Yassa muhuttena sahassadhā,"
    },
    {
      "id": "thag16.9:18.2",
      "pali": "Loko saṁvidito sabrahmakappo;"
    },
    {
      "id": "thag16.9:18.3",
      "pali": "Vasī iddhiguṇe cutūpapāte,"
    },
    {
      "id": "thag16.9:18.4",
      "pali": "Kāle passati devatā sa bhikkhu."
    },
    {
      "id": "thag16.9:19.1",
      "pali": "Annabhāro pure āsiṁ,"
    },
    {
      "id": "thag16.9:19.2",
      "pali": "daliddo ghāsahārako;"
    },
    {
      "id": "thag16.9:19.3",
      "pali": "Samaṇaṁ paṭipādesiṁ,"
    },
    {
      "id": "thag16.9:19.4",
      "pali": "upariṭṭhaṁ yasassinaṁ."
    },
    {
      "id": "thag16.9:20.1",
      "pali": "Somhi sakyakule jāto,"
    },
    {
      "id": "thag16.9:20.2",
      "pali": "anuruddhoti maṁ vidū;"
    },
    {
      "id": "thag16.9:20.3",
      "pali": "Upeto naccagītehi,"
    },
    {
      "id": "thag16.9:20.4",
      "pali": "sammatāḷappabodhano."
    },
    {
      "id": "thag16.9:21.1",
      "pali": "Athaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "thag16.9:21.2",
      "pali": "satthāraṁ akutobhayaṁ;"
    },
    {
      "id": "thag16.9:21.3",
      "pali": "Tasmiṁ cittaṁ pasādetvā,"
    },
    {
      "id": "thag16.9:21.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thag16.9:22.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thag16.9:22.2",
      "pali": "yattha me vusitaṁ pure;"
    },
    {
      "id": "thag16.9:22.3",
      "pali": "Tāvatiṁsesu devesu,"
    },
    {
      "id": "thag16.9:22.4",
      "pali": "aṭṭhāsiṁ sakkajātiyā."
    },
    {
      "id": "thag16.9:23.1",
      "pali": "Sattakkhattuṁ manussindo,"
    },
    {
      "id": "thag16.9:23.2",
      "pali": "ahaṁ rajjamakārayiṁ;"
    },
    {
      "id": "thag16.9:23.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "thag16.9:23.4",
      "pali": "jambusaṇḍassa issaro;"
    },
    {
      "id": "thag16.9:23.5",
      "pali": "Adaṇḍena asatthena,"
    },
    {
      "id": "thag16.9:23.6",
      "pali": "dhammena anusāsayiṁ."
    },
    {
      "id": "thag16.9:24.1",
      "pali": "Ito satta tato satta,"
    },
    {
      "id": "thag16.9:24.2",
      "pali": "saṁsārāni catuddasa;"
    },
    {
      "id": "thag16.9:24.3",
      "pali": "Nivāsamabhijānissaṁ,"
    },
    {
      "id": "thag16.9:24.4",
      "pali": "devaloke ṭhito tadā."
    },
    {
      "id": "thag16.9:25.1",
      "pali": "Pañcaṅgike samādhimhi,"
    },
    {
      "id": "thag16.9:25.2",
      "pali": "sante ekodibhāvite;"
    },
    {
      "id": "thag16.9:25.3",
      "pali": "Paṭippassaddhiladdhamhi,"
    },
    {
      "id": "thag16.9:25.4",
      "pali": "dibbacakkhu visujjhi me."
    },
    {
      "id": "thag16.9:26.1",
      "pali": "Cutūpapātaṁ jānāmi,"
    },
    {
      "id": "thag16.9:26.2",
      "pali": "sattānaṁ āgatiṁ gatiṁ;"
    },
    {
      "id": "thag16.9:26.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "thag16.9:26.4",
      "pali": "jhāne pañcaṅgike ṭhito."
    },
    {
      "id": "thag16.9:27.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag16.9:27.2",
      "pali": "… pe"
    },
    {
      "id": "thag16.9:27.3",
      "pali": "…"
    },
    {
      "id": "thag16.9:27.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag16.9:28.1",
      "pali": "Vajjīnaṁ veḷuvagāme,"
    },
    {
      "id": "thag16.9:28.2",
      "pali": "ahaṁ jīvitasaṅkhayā;"
    },
    {
      "id": "thag16.9:28.3",
      "pali": "Heṭṭhato veḷugumbasmiṁ,"
    },
    {
      "id": "thag16.9:28.4",
      "pali": "nibbāyissaṁ anāsavo”ti."
    },
    {
      "id": "thag16.9:28.5",
      "pali": "… Anuruddho thero …."
    }
  ]
}
