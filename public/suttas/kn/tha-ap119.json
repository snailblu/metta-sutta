{
  "uid": "tha-ap119",
  "title": "Buddhasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap119:1.1",
      "pali": "“Yadā vipassī lokaggo,"
    },
    {
      "id": "tha-ap119:1.2",
      "pali": "āyusaṅkhāramossaji;"
    },
    {
      "id": "tha-ap119:1.3",
      "pali": "Pathavī sampakampittha,"
    },
    {
      "id": "tha-ap119:1.4",
      "pali": "medanī jalamekhalā."
    },
    {
      "id": "tha-ap119:2.1",
      "pali": "Otataṁ vitthataṁ mayhaṁ,"
    },
    {
      "id": "tha-ap119:2.2",
      "pali": "suvicittavaṭaṁsakaṁ;"
    },
    {
      "id": "tha-ap119:2.3",
      "pali": "Bhavanampi pakampittha,"
    },
    {
      "id": "tha-ap119:2.4",
      "pali": "buddhassa āyusaṅkhaye."
    },
    {
      "id": "tha-ap119:3.1",
      "pali": "Tāso mayhaṁ samuppanno,"
    },
    {
      "id": "tha-ap119:3.2",
      "pali": "bhavane sampakampite;"
    },
    {
      "id": "tha-ap119:3.3",
      "pali": "Uppādo nu kimatthāya,"
    },
    {
      "id": "tha-ap119:3.4",
      "pali": "āloko vipulo ahu."
    },
    {
      "id": "tha-ap119:4.1",
      "pali": "Vessavaṇo idhāgamma,"
    },
    {
      "id": "tha-ap119:4.2",
      "pali": "nibbāpesi mahājanaṁ;"
    },
    {
      "id": "tha-ap119:4.3",
      "pali": "Pāṇabhūte bhayaṁ natthi,"
    },
    {
      "id": "tha-ap119:4.4",
      "pali": "ekaggā hotha saṁvutā."
    },
    {
      "id": "tha-ap119:5.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap119:5.2",
      "pali": "aho no satthu sampadā;"
    },
    {
      "id": "tha-ap119:5.3",
      "pali": "Yasmiṁ uppajjamānamhi,"
    },
    {
      "id": "tha-ap119:5.4",
      "pali": "pathavī sampakampati."
    },
    {
      "id": "tha-ap119:6.1",
      "pali": "Buddhānubhāvaṁ kittetvā,"
    },
    {
      "id": "tha-ap119:6.2",
      "pali": "kappaṁ saggamhi modahaṁ;"
    },
    {
      "id": "tha-ap119:6.3",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap119:6.4",
      "pali": "kusalaṁ caritaṁ mayā."
    },
    {
      "id": "tha-ap119:7.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap119:7.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap119:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap119:7.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap119:8.1",
      "pali": "Ito cuddasakappamhi,"
    },
    {
      "id": "tha-ap119:8.2",
      "pali": "rājā āsiṁ patāpavā;"
    },
    {
      "id": "tha-ap119:8.3",
      "pali": "Samito nāma nāmena,"
    },
    {
      "id": "tha-ap119:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap119:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap119:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap119:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap119:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap119:11.1",
      "pali": "Buddhasaññakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
