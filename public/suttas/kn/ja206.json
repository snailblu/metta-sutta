{
  "uid": "ja206",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja206:1.1",
      "pali": "“Iṅgha vaṭṭamayaṁ pāsaṁ,"
    },
    {
      "id": "ja206:1.2",
      "pali": "chinda dantehi kacchapa;"
    },
    {
      "id": "ja206:1.3",
      "pali": "Ahaṁ tathā karissāmi,"
    },
    {
      "id": "ja206:1.4",
      "pali": "yathā nehiti luddako”."
    },
    {
      "id": "ja206:2.1",
      "pali": "“Kacchapo pāvisī vāriṁ,"
    },
    {
      "id": "ja206:2.2",
      "pali": "kuruṅgo pāvisī vanaṁ;"
    },
    {
      "id": "ja206:2.3",
      "pali": "Satapatto dumaggamhā,"
    },
    {
      "id": "ja206:2.4",
      "pali": "dūre putte apānayī”ti."
    },
    {
      "id": "ja206:3.1",
      "pali": "Kuruṅgamigajātakaṁ chaṭṭhaṁ."
    }
  ]
}
