{
  "uid": "tha-ap547",
  "title": "Nandakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap547:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap547:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "tha-ap547:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap547:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "tha-ap547:2.1",
      "pali": "Hitāya sabbasattānaṁ,"
    },
    {
      "id": "tha-ap547:2.2",
      "pali": "sukhāya vadataṁ varo;"
    },
    {
      "id": "tha-ap547:2.3",
      "pali": "Atthāya purisājañño,"
    },
    {
      "id": "tha-ap547:2.4",
      "pali": "paṭipanno sadevake."
    },
    {
      "id": "tha-ap547:3.1",
      "pali": "Yasaggapatto sirimā,"
    },
    {
      "id": "tha-ap547:3.2",
      "pali": "kittivaṇṇabhato jino;"
    },
    {
      "id": "tha-ap547:3.3",
      "pali": "Pūjito sabbalokassa,"
    },
    {
      "id": "tha-ap547:3.4",
      "pali": "disā sabbāsu vissuto."
    },
    {
      "id": "tha-ap547:4.1",
      "pali": "Uttiṇṇavicikiccho so,"
    },
    {
      "id": "tha-ap547:4.2",
      "pali": "vītivattakathaṅkatho;"
    },
    {
      "id": "tha-ap547:4.3",
      "pali": "Paripuṇṇamanasaṅkappo,"
    },
    {
      "id": "tha-ap547:4.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "tha-ap547:5.1",
      "pali": "Anuppannassa maggassa,"
    },
    {
      "id": "tha-ap547:5.2",
      "pali": "uppādetā naruttamo;"
    },
    {
      "id": "tha-ap547:5.3",
      "pali": "Anakkhātañca akkhāsi,"
    },
    {
      "id": "tha-ap547:5.4",
      "pali": "asañjātañca sañjanī."
    },
    {
      "id": "tha-ap547:6.1",
      "pali": "Maggaññū maggavidū ca,"
    },
    {
      "id": "tha-ap547:6.2",
      "pali": "maggakkhāyī narāsabho;"
    },
    {
      "id": "tha-ap547:6.3",
      "pali": "Maggassa kusalo satthā,"
    },
    {
      "id": "tha-ap547:6.4",
      "pali": "sārathīnaṁ varuttamo."
    },
    {
      "id": "tha-ap547:7.1",
      "pali": "Tadā mahākāruṇiko,"
    },
    {
      "id": "tha-ap547:7.2",
      "pali": "dhammaṁ desesi nāyako;"
    },
    {
      "id": "tha-ap547:7.3",
      "pali": "Nimugge kāmapaṅkamhi,"
    },
    {
      "id": "tha-ap547:7.4",
      "pali": "samuddharati pāṇine."
    },
    {
      "id": "tha-ap547:8.1",
      "pali": "Bhikkhunīnaṁ ovadane,"
    },
    {
      "id": "tha-ap547:8.2",
      "pali": "sāvakaṁ seṭṭhasammataṁ;"
    },
    {
      "id": "tha-ap547:8.3",
      "pali": "Vaṇṇayaṁ etadaggamhi,"
    },
    {
      "id": "tha-ap547:8.4",
      "pali": "paññapesi mahāmuni."
    },
    {
      "id": "tha-ap547:9.1",
      "pali": "Taṁ sutvāhaṁ pamudito,"
    },
    {
      "id": "tha-ap547:9.2",
      "pali": "nimantetvā tathāgataṁ;"
    },
    {
      "id": "tha-ap547:9.3",
      "pali": "Bhojayitvā sasaṅghaṁ taṁ,"
    },
    {
      "id": "tha-ap547:9.4",
      "pali": "patthayiṁ ṭhānamuttamaṁ."
    },
    {
      "id": "tha-ap547:10.1",
      "pali": "Tadā pamudito nātho,"
    },
    {
      "id": "tha-ap547:10.2",
      "pali": "maṁ avoca mahāisi;"
    },
    {
      "id": "tha-ap547:10.3",
      "pali": "‘Sukhī bhavassu dīghāvu,"
    },
    {
      "id": "tha-ap547:10.4",
      "pali": "lacchase taṁ manorathaṁ."
    },
    {
      "id": "tha-ap547:11.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap547:11.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap547:11.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap547:11.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap547:12.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap547:12.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap547:12.3",
      "pali": "Nandako nāma nāmena,"
    },
    {
      "id": "tha-ap547:12.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap547:13.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap547:13.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap547:13.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap547:13.4",
      "pali": "tāvatiṁsūpago ahaṁ."
    },
    {
      "id": "tha-ap547:14.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap547:14.2",
      "pali": "jāto seṭṭhikule ahaṁ;"
    },
    {
      "id": "tha-ap547:14.3",
      "pali": "Sāvatthiyaṁ pure vare,"
    },
    {
      "id": "tha-ap547:14.4",
      "pali": "iddhe phīte mahaddhane."
    },
    {
      "id": "tha-ap547:15.1",
      "pali": "Purappavese sugataṁ,"
    },
    {
      "id": "tha-ap547:15.2",
      "pali": "disvā vimhitamānaso;"
    },
    {
      "id": "tha-ap547:15.3",
      "pali": "Jetārāmapaṭiggāhe,"
    },
    {
      "id": "tha-ap547:15.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap547:16.1",
      "pali": "Nacireneva kālena,"
    },
    {
      "id": "tha-ap547:16.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap547:16.3",
      "pali": "Tatohaṁ tiṇṇasaṁsāro,"
    },
    {
      "id": "tha-ap547:16.4",
      "pali": "sāsito sabbadassinā."
    },
    {
      "id": "tha-ap547:17.1",
      "pali": "Bhikkhunīnaṁ dhammakathaṁ,"
    },
    {
      "id": "tha-ap547:17.2",
      "pali": "paṭipucchākariṁ ahaṁ;"
    },
    {
      "id": "tha-ap547:17.3",
      "pali": "Sāsitā tā mayā sabbā,"
    },
    {
      "id": "tha-ap547:17.4",
      "pali": "abhaviṁsu anāsavā."
    },
    {
      "id": "tha-ap547:18.1",
      "pali": "Satāni pañcanūnāni,"
    },
    {
      "id": "tha-ap547:18.2",
      "pali": "tadā tuṭṭho mahāhito;"
    },
    {
      "id": "tha-ap547:18.3",
      "pali": "Bhikkhunīnaṁ ovadataṁ,"
    },
    {
      "id": "tha-ap547:18.4",
      "pali": "aggaṭṭhāne ṭhapesi maṁ."
    },
    {
      "id": "tha-ap547:19.1",
      "pali": "Satasahasse kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap547:19.2",
      "pali": "phalaṁ dassesi me idha;"
    },
    {
      "id": "tha-ap547:19.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap547:19.4",
      "pali": "kilese jhāpayiṁ mama."
    },
    {
      "id": "tha-ap547:20.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap547:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap547:20.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap547:21.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap547:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap547:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap547:22.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap547:22.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap547:22.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap547:23.1",
      "pali": "Itthaṁ sudaṁ āyasmā nandako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap547:24.1",
      "pali": "Nandakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
