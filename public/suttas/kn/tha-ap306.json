{
  "uid": "tha-ap306",
  "title": "Dhammasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap306:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap306:1.2",
      "pali": "Mahābodhimaho ahu;"
    },
    {
      "id": "tha-ap306:1.3",
      "pali": "Rukkhaṭṭhasseva sambuddho,"
    },
    {
      "id": "tha-ap306:1.4",
      "pali": "Lokajeṭṭho narāsabho."
    },
    {
      "id": "tha-ap306:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap306:2.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap306:2.3",
      "pali": "Catusaccaṁ pakāseti,"
    },
    {
      "id": "tha-ap306:2.4",
      "pali": "vācāsabhimudīrayaṁ."
    },
    {
      "id": "tha-ap306:3.1",
      "pali": "Saṅkhittena ca desento,"
    },
    {
      "id": "tha-ap306:3.2",
      "pali": "vitthārena ca desayaṁ;"
    },
    {
      "id": "tha-ap306:3.3",
      "pali": "Vivaṭṭacchado sambuddho,"
    },
    {
      "id": "tha-ap306:3.4",
      "pali": "nibbāpesi mahājanaṁ."
    },
    {
      "id": "tha-ap306:4.1",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "tha-ap306:4.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap306:4.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap306:4.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap306:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap306:5.2",
      "pali": "yaṁ dhammamasuṇiṁ tadā;"
    },
    {
      "id": "tha-ap306:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap306:5.4",
      "pali": "dhammasavassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap306:6.1",
      "pali": "Tettiṁsamhi ito kappe,"
    },
    {
      "id": "tha-ap306:6.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap306:6.3",
      "pali": "Sutavā nāma nāmena,"
    },
    {
      "id": "tha-ap306:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap306:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap306:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap306:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap306:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhammasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap306:9.1",
      "pali": "Dhammasaññakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
