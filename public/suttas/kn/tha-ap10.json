{
  "uid": "tha-ap10",
  "title": "Piṇḍolabhāradvājattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap10:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap10:1.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap10:1.3",
      "pali": "Purato himavantassa,"
    },
    {
      "id": "tha-ap10:1.4",
      "pali": "cittakūṭe vasī tadā."
    },
    {
      "id": "tha-ap10:2.1",
      "pali": "Abhītarūpo tatthāsiṁ,"
    },
    {
      "id": "tha-ap10:2.2",
      "pali": "migarājā catukkamo;"
    },
    {
      "id": "tha-ap10:2.3",
      "pali": "Tassa saddaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap10:2.4",
      "pali": "vikkhambhanti bahujjanā."
    },
    {
      "id": "tha-ap10:3.1",
      "pali": "Suphullaṁ padumaṁ gayha,"
    },
    {
      "id": "tha-ap10:3.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap10:3.3",
      "pali": "Vuṭṭhitassa samādhimhā,"
    },
    {
      "id": "tha-ap10:3.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap10:4.1",
      "pali": "Catuddisaṁ namassitvā,"
    },
    {
      "id": "tha-ap10:4.2",
      "pali": "buddhaseṭṭhaṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap10:4.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap10:4.4",
      "pali": "sīhanādaṁ nadiṁ ahaṁ."
    },
    {
      "id": "tha-ap10:5.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap10:5.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap10:5.3",
      "pali": "Sakāsane nisīditvā,"
    },
    {
      "id": "tha-ap10:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap10:6.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap10:6.2",
      "pali": "Sabbe devā samāgatā;"
    },
    {
      "id": "tha-ap10:6.3",
      "pali": "‘Āgato vadataṁ seṭṭho,"
    },
    {
      "id": "tha-ap10:6.4",
      "pali": "Dhammaṁ sossāma taṁ mayaṁ’."
    },
    {
      "id": "tha-ap10:7.1",
      "pali": "Tesaṁ hāsaparetānaṁ,"
    },
    {
      "id": "tha-ap10:7.2",
      "pali": "purato lokanāyako;"
    },
    {
      "id": "tha-ap10:7.3",
      "pali": "Mama saddaṁ pakittesi,"
    },
    {
      "id": "tha-ap10:7.4",
      "pali": "dīghadassī mahāmuni."
    },
    {
      "id": "tha-ap10:8.1",
      "pali": "Yenidaṁ padumaṁ dinnaṁ,"
    },
    {
      "id": "tha-ap10:8.2",
      "pali": "sīhanādo ca nādito;"
    },
    {
      "id": "tha-ap10:8.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap10:8.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap10:9.1",
      "pali": "Ito aṭṭhamake kappe,"
    },
    {
      "id": "tha-ap10:9.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap10:9.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap10:9.4",
      "pali": "catudīpamhi issaro."
    },
    {
      "id": "tha-ap10:10.1",
      "pali": "Kārayissati issariyaṁ,"
    },
    {
      "id": "tha-ap10:10.2",
      "pali": "mahiyā catusaṭṭhiyā;"
    },
    {
      "id": "tha-ap10:10.3",
      "pali": "Padumo nāma nāmena,"
    },
    {
      "id": "tha-ap10:10.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap10:11.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap10:11.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap10:11.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap10:11.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap10:12.1",
      "pali": "Pakāsite pāvacane,"
    },
    {
      "id": "tha-ap10:12.2",
      "pali": "brahmabandhu bhavissati;"
    },
    {
      "id": "tha-ap10:12.3",
      "pali": "Brahmaññā abhinikkhamma,"
    },
    {
      "id": "tha-ap10:12.4",
      "pali": "pabbajissati tāvade."
    },
    {
      "id": "tha-ap10:13.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap10:13.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap10:13.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap10:13.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap10:14.1",
      "pali": "Vijane pantaseyyamhi,"
    },
    {
      "id": "tha-ap10:14.2",
      "pali": "vāḷamigasamākule;"
    },
    {
      "id": "tha-ap10:14.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap10:14.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap10:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap10:15.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap10:15.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap10:15.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap10:16.1",
      "pali": "Itthaṁ sudaṁ āyasmā piṇḍolabhāradvājo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap10:17.1",
      "pali": "Piṇḍolabhāradvājattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
