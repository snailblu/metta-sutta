{
  "uid": "tha-ap475",
  "title": "Ukkāsatikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap475:1.1",
      "pali": "“Kosiyo nāma bhagavā,"
    },
    {
      "id": "tha-ap475:1.2",
      "pali": "cittakūṭe vasī tadā;"
    },
    {
      "id": "tha-ap475:1.3",
      "pali": "Jhāyī jhānarato buddho,"
    },
    {
      "id": "tha-ap475:1.4",
      "pali": "vivekābhirato muni."
    },
    {
      "id": "tha-ap475:2.1",
      "pali": "Ajjhogāhetvā himavantaṁ,"
    },
    {
      "id": "tha-ap475:2.2",
      "pali": "Nārīgaṇapurakkhato;"
    },
    {
      "id": "tha-ap475:2.3",
      "pali": "Addasaṁ kosiyaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap475:2.4",
      "pali": "Puṇṇamāyeva candimaṁ."
    },
    {
      "id": "tha-ap475:3.1",
      "pali": "Ukkāsate gahetvāna,"
    },
    {
      "id": "tha-ap475:3.2",
      "pali": "parivāresahaṁ tadā;"
    },
    {
      "id": "tha-ap475:3.3",
      "pali": "Sattarattindivaṁ ṭhatvā,"
    },
    {
      "id": "tha-ap475:3.4",
      "pali": "aṭṭhamena agacchahaṁ."
    },
    {
      "id": "tha-ap475:4.1",
      "pali": "Vuṭṭhitaṁ kosiyaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap475:4.2",
      "pali": "sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap475:4.3",
      "pali": "Pasannacitto vanditvā,"
    },
    {
      "id": "tha-ap475:4.4",
      "pali": "ekaṁ bhikkhaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap475:5.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap475:5.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap475:5.3",
      "pali": "Uppajjiṁ tusite kāye,"
    },
    {
      "id": "tha-ap475:5.4",
      "pali": "ekabhikkhāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap475:6.1",
      "pali": "Divasañceva rattiñca,"
    },
    {
      "id": "tha-ap475:6.2",
      "pali": "āloko hoti me sadā;"
    },
    {
      "id": "tha-ap475:6.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap475:6.4",
      "pali": "obhāsena pharāmahaṁ."
    },
    {
      "id": "tha-ap475:7.1",
      "pali": "Pañcapaññāsakappamhi,"
    },
    {
      "id": "tha-ap475:7.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap475:7.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap475:7.4",
      "pali": "jambumaṇḍassa issaro."
    },
    {
      "id": "tha-ap475:8.1",
      "pali": "Tadā me nagaraṁ āsi,"
    },
    {
      "id": "tha-ap475:8.2",
      "pali": "iddhaṁ phītaṁ sunimmitaṁ;"
    },
    {
      "id": "tha-ap475:8.3",
      "pali": "Tiṁsayojanamāyāmaṁ,"
    },
    {
      "id": "tha-ap475:8.4",
      "pali": "vitthārena ca vīsati."
    },
    {
      "id": "tha-ap475:9.1",
      "pali": "Sobhanaṁ nāma nagaraṁ,"
    },
    {
      "id": "tha-ap475:9.2",
      "pali": "vissakammena māpitaṁ;"
    },
    {
      "id": "tha-ap475:9.3",
      "pali": "Dasasaddāvivittaṁ taṁ,"
    },
    {
      "id": "tha-ap475:9.4",
      "pali": "sammatāḷasamāhitaṁ."
    },
    {
      "id": "tha-ap475:10.1",
      "pali": "Na tamhi nagare atthi,"
    },
    {
      "id": "tha-ap475:10.2",
      "pali": "vallikaṭṭhañca mattikā;"
    },
    {
      "id": "tha-ap475:10.3",
      "pali": "Sabbasoṇṇamayaṁyeva,"
    },
    {
      "id": "tha-ap475:10.4",
      "pali": "jotate niccakālikaṁ."
    },
    {
      "id": "tha-ap475:11.1",
      "pali": "Catupākāraparikkhittaṁ,"
    },
    {
      "id": "tha-ap475:11.2",
      "pali": "tayo āsuṁ maṇimayā;"
    },
    {
      "id": "tha-ap475:11.3",
      "pali": "Vemajjhe tālapantī ca,"
    },
    {
      "id": "tha-ap475:11.4",
      "pali": "vissakammena māpitā."
    },
    {
      "id": "tha-ap475:12.1",
      "pali": "Dasasahassapokkharañño,"
    },
    {
      "id": "tha-ap475:12.2",
      "pali": "padumuppalachāditā;"
    },
    {
      "id": "tha-ap475:12.3",
      "pali": "Puṇḍarīkehi sañchannā,"
    },
    {
      "id": "tha-ap475:12.4",
      "pali": "nānāgandhasamīritā."
    },
    {
      "id": "tha-ap475:13.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap475:13.2",
      "pali": "yaṁ ukkaṁ dhārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap475:13.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap475:13.4",
      "pali": "ukkādhārassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap475:14.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap475:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap475:14.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap475:15.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap475:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap475:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap475:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap475:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap475:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap475:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā ukkāsatiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap475:18.1",
      "pali": "Ukkāsatikattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
