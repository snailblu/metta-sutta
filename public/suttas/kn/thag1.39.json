{
  "uid": "thag1.39",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.39:1.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "thag1.39:1.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "thag1.39:1.3",
      "pali": "Kāmarāgappahānāya,"
    },
    {
      "id": "thag1.39:1.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "thag1.39:1.5",
      "pali": "… Tisso thero …."
    }
  ]
}
