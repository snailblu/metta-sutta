{
  "uid": "ja274",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja274:1.1",
      "pali": "“Kāyaṁ balākā sikhinī,"
    },
    {
      "id": "ja274:1.2",
      "pali": "corī laṅghipitāmahā;"
    },
    {
      "id": "ja274:1.3",
      "pali": "Oraṁ balāke āgaccha,"
    },
    {
      "id": "ja274:1.4",
      "pali": "caṇḍo me vāyaso sakhā”."
    },
    {
      "id": "ja274:2.1",
      "pali": "“Nāhaṁ balākā sikhinī,"
    },
    {
      "id": "ja274:2.2",
      "pali": "ahaṁ lolosmi vāyaso;"
    },
    {
      "id": "ja274:2.3",
      "pali": "Akatvā vacanaṁ tuyhaṁ,"
    },
    {
      "id": "ja274:2.4",
      "pali": "passa lūnosmi āgato”."
    },
    {
      "id": "ja274:3.1",
      "pali": "“Punapāpajjasī samma,"
    },
    {
      "id": "ja274:3.2",
      "pali": "sīlañhi tava tādisaṁ;"
    },
    {
      "id": "ja274:3.3",
      "pali": "Na hi mānusakā bhogā,"
    },
    {
      "id": "ja274:3.4",
      "pali": "subhuñjā honti pakkhinā”ti."
    },
    {
      "id": "ja274:4.1",
      "pali": "Lolajātakaṁ catutthaṁ."
    }
  ]
}
