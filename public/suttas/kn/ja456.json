{
  "uid": "ja456",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja456:1.1",
      "pali": "“Suṇohi mayhaṁ vacanaṁ janinda,"
    },
    {
      "id": "ja456:1.2",
      "pali": "Atthena juṇhamhi idhānupatto;"
    },
    {
      "id": "ja456:1.3",
      "pali": "Na brāhmaṇe addhike tiṭṭhamāne,"
    },
    {
      "id": "ja456:1.4",
      "pali": "Gantabbamāhu dvipadindaseṭṭha”."
    },
    {
      "id": "ja456:2.1",
      "pali": "“Suṇomi tiṭṭhāmi vadehi brahme,"
    },
    {
      "id": "ja456:2.2",
      "pali": "Yenāsi atthena idhānupatto;"
    },
    {
      "id": "ja456:2.3",
      "pali": "Kaṁ vā tvamatthaṁ mayi patthayāno,"
    },
    {
      "id": "ja456:2.4",
      "pali": "Idhāgamā brahme tadiṅgha brūhi”."
    },
    {
      "id": "ja456:3.1",
      "pali": "“Dadāhi me gāmavarāni pañca,"
    },
    {
      "id": "ja456:3.2",
      "pali": "Dāsīsataṁ satta gavaṁsatāni;"
    },
    {
      "id": "ja456:3.3",
      "pali": "Parosahassañca suvaṇṇanikkhe,"
    },
    {
      "id": "ja456:3.4",
      "pali": "Bhariyā ca me sādisī dve dadāhi."
    },
    {
      "id": "ja456:4.1",
      "pali": "Tapo nu te brāhmaṇa bhiṁsarūpo,"
    },
    {
      "id": "ja456:4.2",
      "pali": "Mantā nu te brāhmaṇa cittarūpā;"
    },
    {
      "id": "ja456:4.3",
      "pali": "Yakkhā nu te assavā santi keci,"
    },
    {
      "id": "ja456:4.4",
      "pali": "Atthaṁ vā me abhijānāsi kattaṁ."
    },
    {
      "id": "ja456:5.1",
      "pali": "Na me tapo atthi na cāpi mantā,"
    },
    {
      "id": "ja456:5.2",
      "pali": "Yakkhāpi me assavā natthi keci;"
    },
    {
      "id": "ja456:5.3",
      "pali": "Atthampi te nābhijānāmi kattaṁ,"
    },
    {
      "id": "ja456:5.4",
      "pali": "Pubbe ca kho saṅgatimattamāsi."
    },
    {
      "id": "ja456:6.1",
      "pali": "Paṭhamaṁ idaṁ dassanaṁ jānato me,"
    },
    {
      "id": "ja456:6.2",
      "pali": "Na tābhijānāmi ito puratthā;"
    },
    {
      "id": "ja456:6.3",
      "pali": "Akkhāhi me pucchito etamatthaṁ,"
    },
    {
      "id": "ja456:6.4",
      "pali": "Kadā kuhiṁ vā ahu saṅgamo no."
    },
    {
      "id": "ja456:7.1",
      "pali": "Gandhārarājassa puramhi ramme,"
    },
    {
      "id": "ja456:7.2",
      "pali": "Avasimhase takkasīlāyaṁ deva;"
    },
    {
      "id": "ja456:7.3",
      "pali": "Tatthandhakāramhi timīsikāyaṁ,"
    },
    {
      "id": "ja456:7.4",
      "pali": "Aṁsena aṁsaṁ samaghaṭṭayimha."
    },
    {
      "id": "ja456:8.1",
      "pali": "Te tattha ṭhatvāna ubho janinda,"
    },
    {
      "id": "ja456:8.2",
      "pali": "Sārāṇiyaṁ vītisārayimha tattha;"
    },
    {
      "id": "ja456:8.3",
      "pali": "Sāyeva no saṅgatimattamāsi,"
    },
    {
      "id": "ja456:8.4",
      "pali": "Tato na pacchā na pure ahosi."
    },
    {
      "id": "ja456:9.1",
      "pali": "Yadā kadāci manujesu brahme,"
    },
    {
      "id": "ja456:9.2",
      "pali": "Samāgamo sappurisena hoti;"
    },
    {
      "id": "ja456:9.3",
      "pali": "Na paṇḍitā saṅgatisanthavāni,"
    },
    {
      "id": "ja456:9.4",
      "pali": "Pubbe kataṁ vāpi vināsayanti."
    },
    {
      "id": "ja456:10.1",
      "pali": "Bālāva kho saṅgatisanthavāni,"
    },
    {
      "id": "ja456:10.2",
      "pali": "Pubbe kataṁ vāpi vināsayanti;"
    },
    {
      "id": "ja456:10.3",
      "pali": "Bahumpi bālesu kataṁ vinassati,"
    },
    {
      "id": "ja456:10.4",
      "pali": "Tathā hi bālā akataññurūpā."
    },
    {
      "id": "ja456:11.1",
      "pali": "Dhīrā ca kho saṅgatisanthavāni,"
    },
    {
      "id": "ja456:11.2",
      "pali": "Pubbe kataṁ vāpi na nāsayanti;"
    },
    {
      "id": "ja456:11.3",
      "pali": "Appampi dhīresu kataṁ na nassati,"
    },
    {
      "id": "ja456:11.4",
      "pali": "Tathā hi dhīrā sukataññurūpā."
    },
    {
      "id": "ja456:12.1",
      "pali": "Dadāmi te gāmavarāni pañca,"
    },
    {
      "id": "ja456:12.2",
      "pali": "Dāsīsataṁ satta gavaṁsatāni;"
    },
    {
      "id": "ja456:12.3",
      "pali": "Parosahassañca suvaṇṇanikkhe,"
    },
    {
      "id": "ja456:12.4",
      "pali": "Bhariyā ca te sādisī dve dadāmi."
    },
    {
      "id": "ja456:13.1",
      "pali": "Evaṁ sataṁ hoti samecca rāja,"
    },
    {
      "id": "ja456:13.2",
      "pali": "Nakkhattarājāriva tārakānaṁ;"
    },
    {
      "id": "ja456:13.3",
      "pali": "Āpūratī kāsipatī tathāhaṁ,"
    },
    {
      "id": "ja456:13.4",
      "pali": "Tayāpi me saṅgamo ajja laddho”ti."
    },
    {
      "id": "ja456:14.1",
      "pali": "Juṇhajātakaṁ dutiyaṁ."
    }
  ]
}
