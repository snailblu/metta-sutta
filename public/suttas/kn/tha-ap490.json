{
  "uid": "tha-ap490",
  "title": "Taraṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap490:1.1",
      "pali": "“Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap490:1.2",
      "pali": "sayambhū lokanāyako;"
    },
    {
      "id": "tha-ap490:1.3",
      "pali": "Vinatā nadiyā tīraṁ,"
    },
    {
      "id": "tha-ap490:1.4",
      "pali": "upāgacchi tathāgato."
    },
    {
      "id": "tha-ap490:2.1",
      "pali": "Udakā abhinikkhamma,"
    },
    {
      "id": "tha-ap490:2.2",
      "pali": "kacchapo vārigocaro;"
    },
    {
      "id": "tha-ap490:2.3",
      "pali": "Buddhaṁ tāretukāmohaṁ,"
    },
    {
      "id": "tha-ap490:2.4",
      "pali": "upesiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap490:3.1",
      "pali": "‘Abhirūhatu maṁ buddho,"
    },
    {
      "id": "tha-ap490:3.2",
      "pali": "atthadassī mahāmuni;"
    },
    {
      "id": "tha-ap490:3.3",
      "pali": "Ahaṁ taṁ tārayissāmi,"
    },
    {
      "id": "tha-ap490:3.4",
      "pali": "dukkhassantakaro tuvaṁ’."
    },
    {
      "id": "tha-ap490:4.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap490:4.2",
      "pali": "atthadassī mahāyaso;"
    },
    {
      "id": "tha-ap490:4.3",
      "pali": "Abhirūhitvā me piṭṭhiṁ,"
    },
    {
      "id": "tha-ap490:4.4",
      "pali": "aṭṭhāsi lokanāyako."
    },
    {
      "id": "tha-ap490:5.1",
      "pali": "Yato sarāmi attānaṁ,"
    },
    {
      "id": "tha-ap490:5.2",
      "pali": "yato pattosmi viññutaṁ;"
    },
    {
      "id": "tha-ap490:5.3",
      "pali": "Sukhaṁ me tādisaṁ natthi,"
    },
    {
      "id": "tha-ap490:5.4",
      "pali": "phuṭṭhe pādatale yathā."
    },
    {
      "id": "tha-ap490:6.1",
      "pali": "Uttaritvāna sambuddho,"
    },
    {
      "id": "tha-ap490:6.2",
      "pali": "atthadassī mahāyaso;"
    },
    {
      "id": "tha-ap490:6.3",
      "pali": "Naditīramhi ṭhatvāna,"
    },
    {
      "id": "tha-ap490:6.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap490:7.1",
      "pali": "‘Yāvatā vattate cittaṁ,"
    },
    {
      "id": "tha-ap490:7.2",
      "pali": "gaṅgāsotaṁ tarāmahaṁ;"
    },
    {
      "id": "tha-ap490:7.3",
      "pali": "Ayañca kacchapo rājā,"
    },
    {
      "id": "tha-ap490:7.4",
      "pali": "tāresi mama paññavā."
    },
    {
      "id": "tha-ap490:8.1",
      "pali": "Iminā buddhataraṇena,"
    },
    {
      "id": "tha-ap490:8.2",
      "pali": "mettacittavatāya ca;"
    },
    {
      "id": "tha-ap490:8.3",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap490:8.4",
      "pali": "devaloke ramissati."
    },
    {
      "id": "tha-ap490:9.1",
      "pali": "Devalokā idhāgantvā,"
    },
    {
      "id": "tha-ap490:9.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap490:9.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap490:9.4",
      "pali": "kaṅkhāsotaṁ tarissati."
    },
    {
      "id": "tha-ap490:10.1",
      "pali": "Yathāpi bhaddake khette,"
    },
    {
      "id": "tha-ap490:10.2",
      "pali": "bījaṁ appampi ropitaṁ;"
    },
    {
      "id": "tha-ap490:10.3",
      "pali": "Sammādhāre pavecchante,"
    },
    {
      "id": "tha-ap490:10.4",
      "pali": "phalaṁ toseti kassakaṁ’."
    },
    {
      "id": "tha-ap490:11.1",
      "pali": "Tathevidaṁ buddhakhettaṁ,"
    },
    {
      "id": "tha-ap490:11.2",
      "pali": "sammāsambuddhadesitaṁ;"
    },
    {
      "id": "tha-ap490:11.3",
      "pali": "Sammādhāre pavecchante,"
    },
    {
      "id": "tha-ap490:11.4",
      "pali": "phalaṁ maṁ tosayissati."
    },
    {
      "id": "tha-ap490:12.1",
      "pali": "Padhānapahitattomhi,"
    },
    {
      "id": "tha-ap490:12.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap490:12.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap490:12.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap490:13.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap490:13.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap490:13.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap490:13.4",
      "pali": "taraṇāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap490:14.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap490:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap490:14.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap490:15.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap490:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap490:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap490:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap490:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap490:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap490:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā taraṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap490:18.1",
      "pali": "Taraṇiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
