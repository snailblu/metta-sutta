{
  "uid": "ja242",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja242:1.1",
      "pali": "“Bālo vatāyaṁ sunakho,"
    },
    {
      "id": "ja242:1.2",
      "pali": "yo varattaṁ na khādati;"
    },
    {
      "id": "ja242:1.3",
      "pali": "Bandhanā ca pamuñceyya,"
    },
    {
      "id": "ja242:1.4",
      "pali": "asito ca gharaṁ vaje”."
    },
    {
      "id": "ja242:2.1",
      "pali": "“Aṭṭhitaṁ me manasmiṁ me,"
    },
    {
      "id": "ja242:2.2",
      "pali": "atho me hadaye kataṁ;"
    },
    {
      "id": "ja242:2.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "ja242:2.4",
      "pali": "yāva passupatū jano”ti."
    },
    {
      "id": "ja242:3.1",
      "pali": "Sunakhajātakaṁ dutiyaṁ."
    }
  ]
}
