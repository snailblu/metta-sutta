{
  "uid": "thag2.43",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.43:1.1",
      "pali": "“Kassindriyāni samathaṅgatāni,"
    },
    {
      "id": "thag2.43:1.2",
      "pali": "Assā yathā sārathinā sudantā;"
    },
    {
      "id": "thag2.43:1.3",
      "pali": "Pahīnamānassa anāsavassa,"
    },
    {
      "id": "thag2.43:1.4",
      "pali": "Devāpi kassa pihayanti tādinoti."
    },
    {
      "id": "thag2.43:2.1",
      "pali": "Mayhindriyāni samathaṅgatāni,"
    },
    {
      "id": "thag2.43:2.2",
      "pali": "Assā yathā sārathinā sudantā;"
    },
    {
      "id": "thag2.43:2.3",
      "pali": "Pahīnamānassa anāsavassa,"
    },
    {
      "id": "thag2.43:2.4",
      "pali": "Devāpi mayhaṁ pihayanti tādino”ti."
    },
    {
      "id": "thag2.43:2.5",
      "pali": "… Brahmāli thero …."
    }
  ]
}
