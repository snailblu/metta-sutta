{
  "uid": "thig4.1",
  "title": "Bhaddākāpilānītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig4.1:1.1",
      "pali": "“Putto buddhassa dāyādo,"
    },
    {
      "id": "thig4.1:1.2",
      "pali": "kassapo susamāhito;"
    },
    {
      "id": "thig4.1:1.3",
      "pali": "Pubbenivāsaṁ yovedi,"
    },
    {
      "id": "thig4.1:1.4",
      "pali": "saggāpāyañca passati."
    },
    {
      "id": "thig4.1:2.1",
      "pali": "Atho jātikkhayaṁ patto,"
    },
    {
      "id": "thig4.1:2.2",
      "pali": "abhiññāvosito muni;"
    },
    {
      "id": "thig4.1:2.3",
      "pali": "Etāhi tīhi vijjāhi,"
    },
    {
      "id": "thig4.1:2.4",
      "pali": "tevijjo hoti brāhmaṇo."
    },
    {
      "id": "thig4.1:3.1",
      "pali": "Tatheva bhaddā kāpilānī,"
    },
    {
      "id": "thig4.1:3.2",
      "pali": "tevijjā maccuhāyinī;"
    },
    {
      "id": "thig4.1:3.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "thig4.1:3.4",
      "pali": "jetvā māraṁ savāhiniṁ."
    },
    {
      "id": "thig4.1:4.1",
      "pali": "Disvā ādīnavaṁ loke,"
    },
    {
      "id": "thig4.1:4.2",
      "pali": "ubho pabbajitā mayaṁ;"
    },
    {
      "id": "thig4.1:4.3",
      "pali": "Tyamha khīṇāsavā dantā,"
    },
    {
      "id": "thig4.1:4.4",
      "pali": "sītibhūtamha nibbutā”ti."
    },
    {
      "id": "thig4.1:5.1",
      "pali": "… Bhaddā kāpilānī therī …."
    },
    {
      "id": "thig4.1:6.1",
      "pali": "Catukkanipāto niṭṭhito."
    }
  ]
}
