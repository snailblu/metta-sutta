{
  "uid": "vv54",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv54:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv54:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv54:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv54:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv54:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv54:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv54:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv54:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv54:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv54:3.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv54:3.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv54:3.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv54:4.1",
      "pali": "Pucchāmi taṁ deva mahānubhāva,"
    },
    {
      "id": "vv54:4.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv54:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv54:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv54:5.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv54:5.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv54:5.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv54:5.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv54:6.1",
      "pali": "“Satisamuppādakaro,"
    },
    {
      "id": "vv54:6.2",
      "pali": "dvāre kakkaṭako ṭhito;"
    },
    {
      "id": "vv54:6.3",
      "pali": "Niṭṭhito jātarūpassa,"
    },
    {
      "id": "vv54:6.4",
      "pali": "sobhati dasapādako."
    },
    {
      "id": "vv54:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv54:7.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv54:7.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv54:7.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv54:8.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv54:8.2",
      "pali": "Manussabhūto yamakāsi puññaṁ;"
    },
    {
      "id": "vv54:8.3",
      "pali": "Tenamhi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv54:8.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv54:9.1",
      "pali": "Kakkaṭakarasadāyakavimānaṁ catutthaṁ."
    },
    {
      "id": "vv54:10.1",
      "pali": "(Anantaraṁ pañcavimānaṁ yathā kakkaṭakarasadāyakavimānaṁ tathā vitthāretabbaṁ.)"
    }
  ]
}
