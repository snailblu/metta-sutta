{
  "uid": "tha-ap175",
  "title": "3 Rattipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap175:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap175:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap175:1.3",
      "pali": "Vipassiṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap175:1.4",
      "pali": "devadevaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap175:2.1",
      "pali": "Rattikaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap175:2.2",
      "pali": "kuṭajaṁ dharaṇīruhaṁ;"
    },
    {
      "id": "tha-ap175:2.3",
      "pali": "Samūlaṁ paggahetvāna,"
    },
    {
      "id": "tha-ap175:2.4",
      "pali": "upanesiṁ mahesino."
    },
    {
      "id": "tha-ap175:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap175:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap175:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap175:3.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap175:4.1",
      "pali": "Ito ca aṭṭhame kappe,"
    },
    {
      "id": "tha-ap175:4.2",
      "pali": "suppasannasanāmako;"
    },
    {
      "id": "tha-ap175:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap175:4.4",
      "pali": "rājāhosiṁ mahabbalo."
    },
    {
      "id": "tha-ap175:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap175:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap175:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap175:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā rattipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap175:7.1",
      "pali": "Rattipupphiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
