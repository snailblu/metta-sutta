{
  "uid": "tha-ap346",
  "title": "4 Tikiṅkaṇipūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap346:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap346:1.2",
      "pali": "bhūtagaṇo nāma pabbato;"
    },
    {
      "id": "tha-ap346:1.3",
      "pali": "Tatthaddasaṁ paṁsukūlaṁ,"
    },
    {
      "id": "tha-ap346:1.4",
      "pali": "dumaggamhi vilaggitaṁ."
    },
    {
      "id": "tha-ap346:2.1",
      "pali": "Tīṇi kiṅkaṇipupphāni,"
    },
    {
      "id": "tha-ap346:2.2",
      "pali": "ocinitvānahaṁ tadā;"
    },
    {
      "id": "tha-ap346:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap346:2.4",
      "pali": "paṁsukūlaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap346:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap346:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap346:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap346:3.4",
      "pali": "tiṇṇaṁ pupphānidaṁ phalaṁ."
    },
    {
      "id": "tha-ap346:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap346:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap346:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap346:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā tikiṅkaṇipūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap346:6.1",
      "pali": "Tikiṅkaṇipūjakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
