{
  "uid": "vv36",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv36:1.1",
      "pali": "“Pītavatthe pītadhaje,"
    },
    {
      "id": "vv36:1.2",
      "pali": "pītālaṅkārabhūsite;"
    },
    {
      "id": "vv36:1.3",
      "pali": "Pītantarāhi vaggūhi,"
    },
    {
      "id": "vv36:1.4",
      "pali": "apiḷandhāva sobhasi."
    },
    {
      "id": "vv36:2.1",
      "pali": "Kā kambukāyūradhare,"
    },
    {
      "id": "vv36:2.2",
      "pali": "kañcanāveḷabhūsite;"
    },
    {
      "id": "vv36:2.3",
      "pali": "Hemajālakasañchanne,"
    },
    {
      "id": "vv36:2.4",
      "pali": "nānāratanamālinī."
    },
    {
      "id": "vv36:3.1",
      "pali": "Sovaṇṇamayā lohitaṅgamayā ca,"
    },
    {
      "id": "vv36:3.2",
      "pali": "Muttāmayā veḷuriyamayā ca;"
    },
    {
      "id": "vv36:3.3",
      "pali": "Masāragallā sahalohitaṅgā,"
    },
    {
      "id": "vv36:3.4",
      "pali": "Pārevatakkhīhi maṇīhi cittatā."
    },
    {
      "id": "vv36:4.1",
      "pali": "Koci koci ettha mayūrasussaro,"
    },
    {
      "id": "vv36:4.2",
      "pali": "Haṁsassa rañño karavīkasussaro;"
    },
    {
      "id": "vv36:4.3",
      "pali": "Tesaṁ saro suyyati vaggurūpo,"
    },
    {
      "id": "vv36:4.4",
      "pali": "Pañcaṅgikaṁ tūriyamivappavāditaṁ."
    },
    {
      "id": "vv36:5.1",
      "pali": "Ratho ca te subho vaggu,"
    },
    {
      "id": "vv36:5.2",
      "pali": "nānāratanacittito;"
    },
    {
      "id": "vv36:5.3",
      "pali": "Nānāvaṇṇāhi dhātūhi,"
    },
    {
      "id": "vv36:5.4",
      "pali": "suvibhattova sobhati."
    },
    {
      "id": "vv36:6.1",
      "pali": "Tasmiṁ rathe kañcanabimbavaṇṇe,"
    },
    {
      "id": "vv36:6.2",
      "pali": "Yā tvaṁ ṭhitā bhāsasimaṁ padesaṁ;"
    },
    {
      "id": "vv36:6.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv36:6.4",
      "pali": "Kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv36:7.1",
      "pali": "“Sovaṇṇajālaṁ maṇisoṇṇacittitaṁ,"
    },
    {
      "id": "vv36:7.2",
      "pali": "Muttācitaṁ hemajālena channaṁ;"
    },
    {
      "id": "vv36:7.3",
      "pali": "Parinibbute gotame appameyye,"
    },
    {
      "id": "vv36:7.4",
      "pali": "Pasannacittā ahamābhiropayiṁ."
    },
    {
      "id": "vv36:8.1",
      "pali": "Tāhaṁ kammaṁ karitvāna,"
    },
    {
      "id": "vv36:8.2",
      "pali": "kusalaṁ buddhavaṇṇitaṁ;"
    },
    {
      "id": "vv36:8.3",
      "pali": "Apetasokā sukhitā,"
    },
    {
      "id": "vv36:8.4",
      "pali": "sampamodāmanāmayā”ti."
    },
    {
      "id": "vv36:9.1",
      "pali": "Mallikāvimānaṁ aṭṭhamaṁ."
    }
  ]
}
