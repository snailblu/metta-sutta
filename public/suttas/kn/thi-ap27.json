{
  "uid": "thi-ap27",
  "title": "Bhaddākāpilānītherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap27:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap27:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap27:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap27:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap27:2.1",
      "pali": "Tadāhu haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap27:2.2",
      "pali": "videho nāma nāmato;"
    },
    {
      "id": "thi-ap27:2.3",
      "pali": "Seṭṭhī pahūtaratano,"
    },
    {
      "id": "thi-ap27:2.4",
      "pali": "tassa jāyā ahosahaṁ."
    },
    {
      "id": "thi-ap27:3.1",
      "pali": "Kadāci so narādiccaṁ,"
    },
    {
      "id": "thi-ap27:3.2",
      "pali": "Upecca saparijjano;"
    },
    {
      "id": "thi-ap27:3.3",
      "pali": "Dhammamassosi buddhassa,"
    },
    {
      "id": "thi-ap27:3.4",
      "pali": "Sabbadukkhabhayappahaṁ."
    },
    {
      "id": "thi-ap27:4.1",
      "pali": "Sāvakaṁ dhutavādānaṁ,"
    },
    {
      "id": "thi-ap27:4.2",
      "pali": "aggaṁ kittesi nāyako;"
    },
    {
      "id": "thi-ap27:4.3",
      "pali": "Sutvā sattāhikaṁ dānaṁ,"
    },
    {
      "id": "thi-ap27:4.4",
      "pali": "datvā buddhassa tādino."
    },
    {
      "id": "thi-ap27:5.1",
      "pali": "Nipacca sirasā pāde,"
    },
    {
      "id": "thi-ap27:5.2",
      "pali": "taṁ ṭhānamabhipatthayiṁ;"
    },
    {
      "id": "thi-ap27:5.3",
      "pali": "Sa hāsayanto parisaṁ,"
    },
    {
      "id": "thi-ap27:5.4",
      "pali": "tadā hi narapuṅgavo."
    },
    {
      "id": "thi-ap27:6.1",
      "pali": "Seṭṭhino anukampāya,"
    },
    {
      "id": "thi-ap27:6.2",
      "pali": "imā gāthā abhāsatha;"
    },
    {
      "id": "thi-ap27:6.3",
      "pali": "‘Lacchase patthitaṁ ṭhānaṁ,"
    },
    {
      "id": "thi-ap27:6.4",
      "pali": "nibbuto hohi puttaka."
    },
    {
      "id": "thi-ap27:7.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap27:7.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap27:7.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap27:7.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap27:8.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "thi-ap27:8.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "thi-ap27:8.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap27:8.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "thi-ap27:9.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "thi-ap27:9.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "thi-ap27:9.3",
      "pali": "Mettacitto paricari,"
    },
    {
      "id": "thi-ap27:9.4",
      "pali": "paccayehi vināyakaṁ."
    },
    {
      "id": "thi-ap27:10.1",
      "pali": "Sāsanaṁ jotayitvāna,"
    },
    {
      "id": "thi-ap27:10.2",
      "pali": "so madditvā kutitthiye;"
    },
    {
      "id": "thi-ap27:10.3",
      "pali": "Veneyyaṁ vinayitvā ca,"
    },
    {
      "id": "thi-ap27:10.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "thi-ap27:11.1",
      "pali": "Nibbute tamhi lokagge,"
    },
    {
      "id": "thi-ap27:11.2",
      "pali": "pūjanatthāya satthuno;"
    },
    {
      "id": "thi-ap27:11.3",
      "pali": "Ñātimitte samānetvā,"
    },
    {
      "id": "thi-ap27:11.4",
      "pali": "saha tehi akārayi."
    },
    {
      "id": "thi-ap27:12.1",
      "pali": "Sattayojanikaṁ thūpaṁ,"
    },
    {
      "id": "thi-ap27:12.2",
      "pali": "ubbiddhaṁ ratanāmayaṁ;"
    },
    {
      "id": "thi-ap27:12.3",
      "pali": "Jalantaṁ sataraṁsiṁva,"
    },
    {
      "id": "thi-ap27:12.4",
      "pali": "sālarājaṁva phullitaṁ."
    },
    {
      "id": "thi-ap27:13.1",
      "pali": "Sattasatasahassāni,"
    },
    {
      "id": "thi-ap27:13.2",
      "pali": "pātiyo tattha kārayi;"
    },
    {
      "id": "thi-ap27:13.3",
      "pali": "Naḷaggī viya jotantī,"
    },
    {
      "id": "thi-ap27:13.4",
      "pali": "rataneheva sattahi."
    },
    {
      "id": "thi-ap27:14.1",
      "pali": "Gandhatelena pūretvā,"
    },
    {
      "id": "thi-ap27:14.2",
      "pali": "dīpānujjalayī tahiṁ;"
    },
    {
      "id": "thi-ap27:14.3",
      "pali": "Pūjanatthāya mahesissa,"
    },
    {
      "id": "thi-ap27:14.4",
      "pali": "sabbabhūtānukampino."
    },
    {
      "id": "thi-ap27:15.1",
      "pali": "Sattasatasahassāni,"
    },
    {
      "id": "thi-ap27:15.2",
      "pali": "puṇṇakumbhāni kārayi;"
    },
    {
      "id": "thi-ap27:15.3",
      "pali": "Rataneheva puṇṇāni,"
    },
    {
      "id": "thi-ap27:15.4",
      "pali": "pūjanatthāya mahesino."
    },
    {
      "id": "thi-ap27:16.1",
      "pali": "Majjhe aṭṭhaṭṭhakumbhīnaṁ,"
    },
    {
      "id": "thi-ap27:16.2",
      "pali": "ussitā kañcanagghiyo;"
    },
    {
      "id": "thi-ap27:16.3",
      "pali": "Atirocanti vaṇṇena,"
    },
    {
      "id": "thi-ap27:16.4",
      "pali": "saradeva divākaro."
    },
    {
      "id": "thi-ap27:17.1",
      "pali": "Catudvāresu sobhanti,"
    },
    {
      "id": "thi-ap27:17.2",
      "pali": "toraṇā ratanāmayā;"
    },
    {
      "id": "thi-ap27:17.3",
      "pali": "Ussitā phalakā rammā,"
    },
    {
      "id": "thi-ap27:17.4",
      "pali": "sobhanti ratanāmayā."
    },
    {
      "id": "thi-ap27:18.1",
      "pali": "Virocanti parikkhittā,"
    },
    {
      "id": "thi-ap27:18.2",
      "pali": "avaṭaṁsā sunimmitā;"
    },
    {
      "id": "thi-ap27:18.3",
      "pali": "Ussitāni paṭākāni,"
    },
    {
      "id": "thi-ap27:18.4",
      "pali": "ratanāni virocare."
    },
    {
      "id": "thi-ap27:19.1",
      "pali": "Surattaṁ sukataṁ cittaṁ,"
    },
    {
      "id": "thi-ap27:19.2",
      "pali": "cetiyaṁ ratanāmayaṁ;"
    },
    {
      "id": "thi-ap27:19.3",
      "pali": "Atirocati vaṇṇena,"
    },
    {
      "id": "thi-ap27:19.4",
      "pali": "sasañjhova divākaro."
    },
    {
      "id": "thi-ap27:20.1",
      "pali": "Thūpassa vediyo tisso,"
    },
    {
      "id": "thi-ap27:20.2",
      "pali": "haritālena pūrayi;"
    },
    {
      "id": "thi-ap27:20.3",
      "pali": "Ekaṁ manosilāyekaṁ,"
    },
    {
      "id": "thi-ap27:20.4",
      "pali": "añjanena ca ekikaṁ."
    },
    {
      "id": "thi-ap27:21.1",
      "pali": "Pūjaṁ etādisaṁ rammaṁ,"
    },
    {
      "id": "thi-ap27:21.2",
      "pali": "kāretvā varavādino;"
    },
    {
      "id": "thi-ap27:21.3",
      "pali": "Adāsi dānaṁ saṅghassa,"
    },
    {
      "id": "thi-ap27:21.4",
      "pali": "yāvajīvaṁ yathābalaṁ."
    },
    {
      "id": "thi-ap27:22.1",
      "pali": "Sahāva seṭṭhinā tena,"
    },
    {
      "id": "thi-ap27:22.2",
      "pali": "tāni puññāni sabbaso;"
    },
    {
      "id": "thi-ap27:22.3",
      "pali": "Yāvajīvaṁ karitvāna,"
    },
    {
      "id": "thi-ap27:22.4",
      "pali": "sahāva sugatiṁ gatā."
    },
    {
      "id": "thi-ap27:23.1",
      "pali": "Sampattiyonubhotvāna,"
    },
    {
      "id": "thi-ap27:23.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "thi-ap27:23.3",
      "pali": "Chāyā viya sarīrena,"
    },
    {
      "id": "thi-ap27:23.4",
      "pali": "saha teneva saṁsariṁ."
    },
    {
      "id": "thi-ap27:24.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap27:24.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "thi-ap27:24.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "thi-ap27:24.4",
      "pali": "sabbadhammavipassako."
    },
    {
      "id": "thi-ap27:25.1",
      "pali": "Tadāyaṁ bandhumatiyaṁ,"
    },
    {
      "id": "thi-ap27:25.2",
      "pali": "brāhmaṇo sādhusammato;"
    },
    {
      "id": "thi-ap27:25.3",
      "pali": "Aḍḍho santo guṇenāpi,"
    },
    {
      "id": "thi-ap27:25.4",
      "pali": "dhanena ca suduggato."
    },
    {
      "id": "thi-ap27:26.1",
      "pali": "Tadāpi tassāhaṁ āsiṁ,"
    },
    {
      "id": "thi-ap27:26.2",
      "pali": "brāhmaṇī samacetasā;"
    },
    {
      "id": "thi-ap27:26.3",
      "pali": "Kadāci so dijavaro,"
    },
    {
      "id": "thi-ap27:26.4",
      "pali": "saṅgamesi mahāmuniṁ."
    },
    {
      "id": "thi-ap27:27.1",
      "pali": "Nisinnaṁ janakāyamhi,"
    },
    {
      "id": "thi-ap27:27.2",
      "pali": "desentaṁ amataṁ padaṁ;"
    },
    {
      "id": "thi-ap27:27.3",
      "pali": "Sutvā dhammaṁ pamudito,"
    },
    {
      "id": "thi-ap27:27.4",
      "pali": "adāsi ekasāṭakaṁ."
    },
    {
      "id": "thi-ap27:28.1",
      "pali": "Gharamekena vatthena,"
    },
    {
      "id": "thi-ap27:28.2",
      "pali": "Gantvānetaṁ sa mabravi;"
    },
    {
      "id": "thi-ap27:28.3",
      "pali": "‘Anumoda mahāpuññaṁ,"
    },
    {
      "id": "thi-ap27:28.4",
      "pali": "Dinnaṁ buddhassa sāṭakaṁ’."
    },
    {
      "id": "thi-ap27:29.1",
      "pali": "Tadāhaṁ añjaliṁ katvā,"
    },
    {
      "id": "thi-ap27:29.2",
      "pali": "anumodiṁ supīṇitā;"
    },
    {
      "id": "thi-ap27:29.3",
      "pali": "‘Sudinno sāṭako sāmi,"
    },
    {
      "id": "thi-ap27:29.4",
      "pali": "buddhaseṭṭhassa tādino’."
    },
    {
      "id": "thi-ap27:30.1",
      "pali": "Sukhito sajjito hutvā,"
    },
    {
      "id": "thi-ap27:30.2",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "thi-ap27:30.3",
      "pali": "Bārāṇasipure ramme,"
    },
    {
      "id": "thi-ap27:30.4",
      "pali": "rājā āsi mahīpati."
    },
    {
      "id": "thi-ap27:31.1",
      "pali": "Tadā tassa mahesīhaṁ,"
    },
    {
      "id": "thi-ap27:31.2",
      "pali": "itthigumbassa uttamā;"
    },
    {
      "id": "thi-ap27:31.3",
      "pali": "Tassāti dayitā āsiṁ,"
    },
    {
      "id": "thi-ap27:31.4",
      "pali": "pubbasnehena bhattuno."
    },
    {
      "id": "thi-ap27:32.1",
      "pali": "Piṇḍāya vicarante te,"
    },
    {
      "id": "thi-ap27:32.2",
      "pali": "aṭṭha paccekanāyake;"
    },
    {
      "id": "thi-ap27:32.3",
      "pali": "Disvā pamudito hutvā,"
    },
    {
      "id": "thi-ap27:32.4",
      "pali": "datvā piṇḍaṁ mahārahaṁ."
    },
    {
      "id": "thi-ap27:33.1",
      "pali": "Puno nimantayitvāna,"
    },
    {
      "id": "thi-ap27:33.2",
      "pali": "katvā ratanamaṇḍapaṁ;"
    },
    {
      "id": "thi-ap27:33.3",
      "pali": "Kammārehi kataṁ pattaṁ,"
    },
    {
      "id": "thi-ap27:33.4",
      "pali": "sovaṇṇaṁ vata tattakaṁ."
    },
    {
      "id": "thi-ap27:34.1",
      "pali": "Samānetvāna te sabbe,"
    },
    {
      "id": "thi-ap27:34.2",
      "pali": "tesaṁ dānamadāsi so;"
    },
    {
      "id": "thi-ap27:34.3",
      "pali": "Soṇṇāsane paviṭṭhānaṁ,"
    },
    {
      "id": "thi-ap27:34.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "thi-ap27:35.1",
      "pali": "Tampi dānaṁ sahādāsiṁ,"
    },
    {
      "id": "thi-ap27:35.2",
      "pali": "kāsirājenahaṁ tadā;"
    },
    {
      "id": "thi-ap27:35.3",
      "pali": "Punāhaṁ bārāṇasiyaṁ,"
    },
    {
      "id": "thi-ap27:35.4",
      "pali": "jātā kāsikagāmake."
    },
    {
      "id": "thi-ap27:36.1",
      "pali": "Kuṭumbikakule phīte,"
    },
    {
      "id": "thi-ap27:36.2",
      "pali": "sukhito so sabhātuko;"
    },
    {
      "id": "thi-ap27:36.3",
      "pali": "Jeṭṭhassa bhātuno jāyā,"
    },
    {
      "id": "thi-ap27:36.4",
      "pali": "ahosiṁ supatibbatā."
    },
    {
      "id": "thi-ap27:37.1",
      "pali": "Paccekabuddhaṁ disvāna,"
    },
    {
      "id": "thi-ap27:37.2",
      "pali": "kaniyassa mama bhattuno;"
    },
    {
      "id": "thi-ap27:37.3",
      "pali": "Bhāgannaṁ tassa datvāna,"
    },
    {
      "id": "thi-ap27:37.4",
      "pali": "āgate tamhi pāvadiṁ."
    },
    {
      "id": "thi-ap27:38.1",
      "pali": "Nābhinandittha so dānaṁ,"
    },
    {
      "id": "thi-ap27:38.2",
      "pali": "tato tassa adāsahaṁ;"
    },
    {
      "id": "thi-ap27:38.3",
      "pali": "Ukhā āniya taṁ annaṁ,"
    },
    {
      "id": "thi-ap27:38.4",
      "pali": "puno tasseva so adā."
    },
    {
      "id": "thi-ap27:39.1",
      "pali": "Tadannaṁ chaḍḍayitvāna,"
    },
    {
      "id": "thi-ap27:39.2",
      "pali": "duṭṭhā buddhassahaṁ tadā;"
    },
    {
      "id": "thi-ap27:39.3",
      "pali": "Pattaṁ kalalapuṇṇaṁ taṁ,"
    },
    {
      "id": "thi-ap27:39.4",
      "pali": "adāsiṁ tassa tādino."
    },
    {
      "id": "thi-ap27:40.1",
      "pali": "Dāne ca gahaṇe ceva,"
    },
    {
      "id": "thi-ap27:40.2",
      "pali": "apace padusepi ca;"
    },
    {
      "id": "thi-ap27:40.3",
      "pali": "Samacittamukhaṁ disvā,"
    },
    {
      "id": "thi-ap27:40.4",
      "pali": "tadāhaṁ saṁvijiṁ bhusaṁ."
    },
    {
      "id": "thi-ap27:41.1",
      "pali": "Puno pattaṁ gahetvāna,"
    },
    {
      "id": "thi-ap27:41.2",
      "pali": "sodhayitvā sugandhinā;"
    },
    {
      "id": "thi-ap27:41.3",
      "pali": "Pasannacittā pūretvā,"
    },
    {
      "id": "thi-ap27:41.4",
      "pali": "saghataṁ sakkaraṁ adaṁ."
    },
    {
      "id": "thi-ap27:42.1",
      "pali": "Yattha yatthūpapajjāmi,"
    },
    {
      "id": "thi-ap27:42.2",
      "pali": "surūpā homi dānato;"
    },
    {
      "id": "thi-ap27:42.3",
      "pali": "Buddhassa apakārena,"
    },
    {
      "id": "thi-ap27:42.4",
      "pali": "duggandhā vadanena ca."
    },
    {
      "id": "thi-ap27:43.1",
      "pali": "Puna kassapavīrassa,"
    },
    {
      "id": "thi-ap27:43.2",
      "pali": "nidhāyantamhi cetiye;"
    },
    {
      "id": "thi-ap27:43.3",
      "pali": "Sovaṇṇaṁ iṭṭhakaṁ varaṁ,"
    },
    {
      "id": "thi-ap27:43.4",
      "pali": "adāsiṁ muditā ahaṁ."
    },
    {
      "id": "thi-ap27:44.1",
      "pali": "Catujjātena gandhena,"
    },
    {
      "id": "thi-ap27:44.2",
      "pali": "nicayitvā tamiṭṭhakaṁ;"
    },
    {
      "id": "thi-ap27:44.3",
      "pali": "Muttā duggandhadosamhā,"
    },
    {
      "id": "thi-ap27:44.4",
      "pali": "sabbaṅgasusamāgatā."
    },
    {
      "id": "thi-ap27:45.1",
      "pali": "Sattapātisahassāni,"
    },
    {
      "id": "thi-ap27:45.2",
      "pali": "rataneheva sattahi;"
    },
    {
      "id": "thi-ap27:45.3",
      "pali": "Kāretvā ghatapūrāni,"
    },
    {
      "id": "thi-ap27:45.4",
      "pali": "vaṭṭīni ca sahassaso."
    },
    {
      "id": "thi-ap27:46.1",
      "pali": "Pakkhipitvā padīpetvā,"
    },
    {
      "id": "thi-ap27:46.2",
      "pali": "ṭhapayiṁ sattapantiyo;"
    },
    {
      "id": "thi-ap27:46.3",
      "pali": "Pūjanatthaṁ lokanāthassa,"
    },
    {
      "id": "thi-ap27:46.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "thi-ap27:47.1",
      "pali": "Tadāpi tamhi puññamhi,"
    },
    {
      "id": "thi-ap27:47.2",
      "pali": "bhāginīhaṁ visesato;"
    },
    {
      "id": "thi-ap27:47.3",
      "pali": "Puna kāsīsu sañjāto,"
    },
    {
      "id": "thi-ap27:47.4",
      "pali": "sumitto iti vissuto."
    },
    {
      "id": "thi-ap27:48.1",
      "pali": "Tassāhaṁ bhariyā āsiṁ,"
    },
    {
      "id": "thi-ap27:48.2",
      "pali": "sukhitā sajjitā piyā;"
    },
    {
      "id": "thi-ap27:48.3",
      "pali": "Tadā paccekamunino,"
    },
    {
      "id": "thi-ap27:48.4",
      "pali": "adāsiṁ ghanaveṭhanaṁ."
    },
    {
      "id": "thi-ap27:49.1",
      "pali": "Tassāpi bhāginī āsiṁ,"
    },
    {
      "id": "thi-ap27:49.2",
      "pali": "moditvā dānamuttamaṁ;"
    },
    {
      "id": "thi-ap27:49.3",
      "pali": "Punāpi kāsiraṭṭhamhi,"
    },
    {
      "id": "thi-ap27:49.4",
      "pali": "jāto koliyajātiyā."
    },
    {
      "id": "thi-ap27:50.1",
      "pali": "Tadā koliyaputtānaṁ,"
    },
    {
      "id": "thi-ap27:50.2",
      "pali": "satehi saha pañcahi;"
    },
    {
      "id": "thi-ap27:50.3",
      "pali": "Pañcapaccekabuddhānaṁ,"
    },
    {
      "id": "thi-ap27:50.4",
      "pali": "satāni samupaṭṭhahi."
    },
    {
      "id": "thi-ap27:51.1",
      "pali": "Temāsaṁ tappayitvāna,"
    },
    {
      "id": "thi-ap27:51.2",
      "pali": "adāsi ca ticīvaraṁ;"
    },
    {
      "id": "thi-ap27:51.3",
      "pali": "Jāyā tassa tadā āsiṁ,"
    },
    {
      "id": "thi-ap27:51.4",
      "pali": "puññakammapathānugā."
    },
    {
      "id": "thi-ap27:52.1",
      "pali": "Tato cuto ahu rājā,"
    },
    {
      "id": "thi-ap27:52.2",
      "pali": "nando nāma mahāyaso;"
    },
    {
      "id": "thi-ap27:52.3",
      "pali": "Tassāpi mahesī āsiṁ,"
    },
    {
      "id": "thi-ap27:52.4",
      "pali": "sabbakāmasamiddhinī."
    },
    {
      "id": "thi-ap27:53.1",
      "pali": "Tadā rājā bhavitvāna,"
    },
    {
      "id": "thi-ap27:53.2",
      "pali": "brahmadatto mahīpati;"
    },
    {
      "id": "thi-ap27:53.3",
      "pali": "Padumavatīputtānaṁ,"
    },
    {
      "id": "thi-ap27:53.4",
      "pali": "paccekamuninaṁ tadā."
    },
    {
      "id": "thi-ap27:54.1",
      "pali": "Satāni pañcanūnāni,"
    },
    {
      "id": "thi-ap27:54.2",
      "pali": "yāvajīvaṁ upaṭṭhahiṁ;"
    },
    {
      "id": "thi-ap27:54.3",
      "pali": "Rājuyyāne nivāsetvā,"
    },
    {
      "id": "thi-ap27:54.4",
      "pali": "nibbutāni ca pūjayiṁ."
    },
    {
      "id": "thi-ap27:55.1",
      "pali": "Cetiyāni ca kāretvā,"
    },
    {
      "id": "thi-ap27:55.2",
      "pali": "pabbajitvā ubho mayaṁ;"
    },
    {
      "id": "thi-ap27:55.3",
      "pali": "Bhāvetvā appamaññāyo,"
    },
    {
      "id": "thi-ap27:55.4",
      "pali": "brahmalokaṁ agamhase."
    },
    {
      "id": "thi-ap27:56.1",
      "pali": "Tato cuto mahātitthe,"
    },
    {
      "id": "thi-ap27:56.2",
      "pali": "sujāto pipphalāyano;"
    },
    {
      "id": "thi-ap27:56.3",
      "pali": "Mātā sumanadevīti,"
    },
    {
      "id": "thi-ap27:56.4",
      "pali": "kosigotto dijo pitā."
    },
    {
      "id": "thi-ap27:57.1",
      "pali": "Ahaṁ madde janapade,"
    },
    {
      "id": "thi-ap27:57.2",
      "pali": "sākalāya puruttame;"
    },
    {
      "id": "thi-ap27:57.3",
      "pali": "Kappilassa dijassāsiṁ,"
    },
    {
      "id": "thi-ap27:57.4",
      "pali": "dhītā mātā sucīmati."
    },
    {
      "id": "thi-ap27:58.1",
      "pali": "Ghanakañcanabimbena,"
    },
    {
      "id": "thi-ap27:58.2",
      "pali": "nimminitvāna maṁ pitā;"
    },
    {
      "id": "thi-ap27:58.3",
      "pali": "Adā kassapadhīrassa,"
    },
    {
      "id": "thi-ap27:58.4",
      "pali": "kāmehi vajjitassamaṁ."
    },
    {
      "id": "thi-ap27:59.1",
      "pali": "Kadāci so kāruṇiko,"
    },
    {
      "id": "thi-ap27:59.2",
      "pali": "gantvā kammantapekkhako;"
    },
    {
      "id": "thi-ap27:59.3",
      "pali": "Kākādikehi khajjante,"
    },
    {
      "id": "thi-ap27:59.4",
      "pali": "pāṇe disvāna saṁviji."
    },
    {
      "id": "thi-ap27:60.1",
      "pali": "Gharevāhaṁ tile jāte,"
    },
    {
      "id": "thi-ap27:60.2",
      "pali": "disvānātapatāpane;"
    },
    {
      "id": "thi-ap27:60.3",
      "pali": "Kimī kākehi khajjante,"
    },
    {
      "id": "thi-ap27:60.4",
      "pali": "saṁvegamalabhiṁ tadā."
    },
    {
      "id": "thi-ap27:61.1",
      "pali": "Tadā so pabbajī dhīro,"
    },
    {
      "id": "thi-ap27:61.2",
      "pali": "ahaṁ tamanupabbajiṁ;"
    },
    {
      "id": "thi-ap27:61.3",
      "pali": "Pañcavassāni nivasiṁ,"
    },
    {
      "id": "thi-ap27:61.4",
      "pali": "paribbājavate ahaṁ."
    },
    {
      "id": "thi-ap27:62.1",
      "pali": "Yadā pabbajitā āsi,"
    },
    {
      "id": "thi-ap27:62.2",
      "pali": "gotamī jinaposikā;"
    },
    {
      "id": "thi-ap27:62.3",
      "pali": "Tadāhaṁ tamupagantvā,"
    },
    {
      "id": "thi-ap27:62.4",
      "pali": "buddhena anusāsitā."
    },
    {
      "id": "thi-ap27:63.1",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "thi-ap27:63.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "thi-ap27:63.3",
      "pali": "Aho kalyāṇamittattaṁ,"
    },
    {
      "id": "thi-ap27:63.4",
      "pali": "kassapassa sirīmato."
    },
    {
      "id": "thi-ap27:64.1",
      "pali": "Suto buddhassa dāyādo,"
    },
    {
      "id": "thi-ap27:64.2",
      "pali": "kassapo susamāhito;"
    },
    {
      "id": "thi-ap27:64.3",
      "pali": "Pubbenivāsaṁ yo vedi,"
    },
    {
      "id": "thi-ap27:64.4",
      "pali": "saggāpāyañca passati."
    },
    {
      "id": "thi-ap27:65.1",
      "pali": "Atho jātikkhayaṁ patto,"
    },
    {
      "id": "thi-ap27:65.2",
      "pali": "abhiññāvosito muni;"
    },
    {
      "id": "thi-ap27:65.3",
      "pali": "Etāhi tīhi vijjāhi,"
    },
    {
      "id": "thi-ap27:65.4",
      "pali": "tevijjo hoti brāhmaṇo."
    },
    {
      "id": "thi-ap27:66.1",
      "pali": "Tatheva bhaddākāpilānī,"
    },
    {
      "id": "thi-ap27:66.2",
      "pali": "tevijjā maccuhāyinī;"
    },
    {
      "id": "thi-ap27:66.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "thi-ap27:66.4",
      "pali": "jitvā māraṁ savāhanaṁ."
    },
    {
      "id": "thi-ap27:67.1",
      "pali": "Disvā ādīnavaṁ loke,"
    },
    {
      "id": "thi-ap27:67.2",
      "pali": "ubho pabbajitā mayaṁ;"
    },
    {
      "id": "thi-ap27:67.3",
      "pali": "Tyamha khīṇāsavā dantā,"
    },
    {
      "id": "thi-ap27:67.4",
      "pali": "sītibhūtāmha nibbutā."
    },
    {
      "id": "thi-ap27:68.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap27:68.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap27:68.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap27:69.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap27:69.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap27:69.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap27:70.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap27:70.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap27:70.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap27:71.1",
      "pali": "Itthaṁ sudaṁ bhaddākāpilānī bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap27:72.1",
      "pali": "Bhaddākāpilānītheriyāpadānaṁ sattamaṁ."
    }
  ]
}
