{
  "uid": "iti11",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti11:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti11:2.1",
      "pali": "“Mohaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti11:2.2",
      "pali": "Mohañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti11:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti11:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti11:3.1",
      "pali": "“Yena mohena mūḷhāse,"
    },
    {
      "id": "iti11:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti11:3.3",
      "pali": "Taṁ mohaṁ sammadaññāya,"
    },
    {
      "id": "iti11:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti11:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti11:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti11:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti11:4.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
