{
  "uid": "ja219",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja219:1.1",
      "pali": "“Hiraññaṁ me suvaṇṇaṁ me,"
    },
    {
      "id": "ja219:1.2",
      "pali": "esā rattiṁ divā kathā;"
    },
    {
      "id": "ja219:1.3",
      "pali": "Dummedhānaṁ manussānaṁ,"
    },
    {
      "id": "ja219:1.4",
      "pali": "ariyadhammaṁ apassataṁ."
    },
    {
      "id": "ja219:2.1",
      "pali": "Dve dve gahapatayo gehe,"
    },
    {
      "id": "ja219:2.2",
      "pali": "eko tattha amassuko;"
    },
    {
      "id": "ja219:2.3",
      "pali": "Lambatthano veṇikato,"
    },
    {
      "id": "ja219:2.4",
      "pali": "atho aṅkitakaṇṇako;"
    },
    {
      "id": "ja219:2.5",
      "pali": "Kīto dhanena bahunā,"
    },
    {
      "id": "ja219:2.6",
      "pali": "so taṁ vitudate janan”ti."
    },
    {
      "id": "ja219:3.1",
      "pali": "Garahitajātakaṁ navamaṁ."
    }
  ]
}
