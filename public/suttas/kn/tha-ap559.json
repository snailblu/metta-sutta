{
  "uid": "tha-ap559",
  "title": "Aparauttarattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap559:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap559:1.2",
      "pali": "siddhatthe lokanāyake;"
    },
    {
      "id": "tha-ap559:1.3",
      "pali": "Mama ñātī samānetvā,"
    },
    {
      "id": "tha-ap559:1.4",
      "pali": "dhātupūjaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap559:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap559:2.2",
      "pali": "yaṁ dhātumabhipūjayiṁ;"
    },
    {
      "id": "tha-ap559:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap559:2.4",
      "pali": "dhātupūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap559:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap559:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap559:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap559:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap559:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap559:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap559:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap559:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap559:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap559:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā aparauttaratthero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap559:7.1",
      "pali": "Aparassa uttarattherassāpadānaṁ sattamaṁ."
    }
  ]
}
