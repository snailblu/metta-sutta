{
  "uid": "tha-ap31",
  "title": "Ekañjalikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap31:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap31:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap31:1.3",
      "pali": "Vipassiṁ satthavāhaggaṁ,"
    },
    {
      "id": "tha-ap31:1.4",
      "pali": "Naravaraṁ vināyakaṁ."
    },
    {
      "id": "tha-ap31:2.1",
      "pali": "Adantadamanaṁ tādiṁ,"
    },
    {
      "id": "tha-ap31:2.2",
      "pali": "mahāvādiṁ mahāmatiṁ;"
    },
    {
      "id": "tha-ap31:2.3",
      "pali": "Disvā pasanno sumano,"
    },
    {
      "id": "tha-ap31:2.4",
      "pali": "ekañjalimakāsahaṁ."
    },
    {
      "id": "tha-ap31:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap31:3.2",
      "pali": "yamañjaliṁ kariṁ tadā;"
    },
    {
      "id": "tha-ap31:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap31:3.4",
      "pali": "añjalissa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap31:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap31:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap31:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap31:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap31:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekañjaliko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap31:6.1",
      "pali": "Ekañjalikattherassāpadānaṁ navamaṁ."
    }
  ]
}
