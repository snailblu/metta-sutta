{
  "uid": "vv39",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv39:1.1",
      "pali": "“Mañjiṭṭhake vimānasmiṁ,"
    },
    {
      "id": "vv39:1.2",
      "pali": "soṇṇavālukasanthate;"
    },
    {
      "id": "vv39:1.3",
      "pali": "Pañcaṅgikena tūriyena,"
    },
    {
      "id": "vv39:1.4",
      "pali": "ramasi suppavādite."
    },
    {
      "id": "vv39:2.1",
      "pali": "Tamhā vimānā oruyha,"
    },
    {
      "id": "vv39:2.2",
      "pali": "nimmitā ratanāmayā;"
    },
    {
      "id": "vv39:2.3",
      "pali": "Ogāhasi sālavanaṁ,"
    },
    {
      "id": "vv39:2.4",
      "pali": "pupphitaṁ sabbakālikaṁ."
    },
    {
      "id": "vv39:3.1",
      "pali": "Yassa yasseva sālassa,"
    },
    {
      "id": "vv39:3.2",
      "pali": "mūle tiṭṭhasi devate;"
    },
    {
      "id": "vv39:3.3",
      "pali": "So so muñcati pupphāni,"
    },
    {
      "id": "vv39:3.4",
      "pali": "onamitvā dumuttamo."
    },
    {
      "id": "vv39:4.1",
      "pali": "Vāteritaṁ sālavanaṁ,"
    },
    {
      "id": "vv39:4.2",
      "pali": "ādhutaṁ dijasevitaṁ;"
    },
    {
      "id": "vv39:4.3",
      "pali": "Vāti gandho disā sabbā,"
    },
    {
      "id": "vv39:4.4",
      "pali": "rukkho mañjūsako yathā."
    },
    {
      "id": "vv39:5.1",
      "pali": "Ghāyase taṁ sucigandhaṁ,"
    },
    {
      "id": "vv39:5.2",
      "pali": "rūpaṁ passasi amānusaṁ;"
    },
    {
      "id": "vv39:5.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv39:5.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv39:6.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv39:6.2",
      "pali": "Dāsī ayirakule ahuṁ;"
    },
    {
      "id": "vv39:6.3",
      "pali": "Buddhaṁ nisinnaṁ disvāna,"
    },
    {
      "id": "vv39:6.4",
      "pali": "Sālapupphehi okiriṁ."
    },
    {
      "id": "vv39:7.1",
      "pali": "Vaṭaṁsakañca sukataṁ,"
    },
    {
      "id": "vv39:7.2",
      "pali": "sālapupphamayaṁ ahaṁ;"
    },
    {
      "id": "vv39:7.3",
      "pali": "Buddhassa upanāmesiṁ,"
    },
    {
      "id": "vv39:7.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv39:8.1",
      "pali": "Tāhaṁ kammaṁ karitvāna,"
    },
    {
      "id": "vv39:8.2",
      "pali": "kusalaṁ buddhavaṇṇitaṁ;"
    },
    {
      "id": "vv39:8.3",
      "pali": "Apetasokā sukhitā,"
    },
    {
      "id": "vv39:8.4",
      "pali": "sampamodāmanāmayā”ti."
    },
    {
      "id": "vv39:9.1",
      "pali": "Mañjiṭṭhakavimānaṁ paṭhamaṁ."
    }
  ]
}
