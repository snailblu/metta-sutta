{
  "uid": "ja127",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja127:1.1",
      "pali": "“Te desā tāni vatthūni,"
    },
    {
      "id": "ja127:1.2",
      "pali": "ahañca vanagocaro;"
    },
    {
      "id": "ja127:1.3",
      "pali": "Anuvicca kho taṁ gaṇheyyuṁ,"
    },
    {
      "id": "ja127:1.4",
      "pali": "piva khīraṁ kalaṇḍukā”ti."
    },
    {
      "id": "ja127:2.1",
      "pali": "Kalaṇḍukajātakaṁ sattamaṁ."
    }
  ]
}
