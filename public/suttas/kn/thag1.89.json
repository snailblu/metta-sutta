{
  "uid": "thag1.89",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.89:1.1",
      "pali": "“Uttiṇṇā paṅkapalipā,"
    },
    {
      "id": "thag1.89:1.2",
      "pali": "pātālā parivajjitā;"
    },
    {
      "id": "thag1.89:1.3",
      "pali": "Mutto oghā ca ganthā ca,"
    },
    {
      "id": "thag1.89:1.4",
      "pali": "sabbe mānā visaṁhatā”ti."
    },
    {
      "id": "thag1.89:1.5",
      "pali": "… Devasabho thero …."
    }
  ]
}
