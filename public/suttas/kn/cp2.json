{
  "uid": "cp2",
  "title": "Dānapāramī 2",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp2:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp2:1.2",
      "pali": "Brāhmaṇo saṅkhasavhayo;"
    },
    {
      "id": "cp2:1.3",
      "pali": "Mahāsamuddaṁ taritukāmo,"
    },
    {
      "id": "cp2:1.4",
      "pali": "Upagacchāmi paṭṭanaṁ."
    },
    {
      "id": "cp2:2.1",
      "pali": "Tatthaddasaṁ paṭipathe,"
    },
    {
      "id": "cp2:2.2",
      "pali": "Sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "cp2:2.3",
      "pali": "Kantāraddhānaṁ paṭipannaṁ,"
    },
    {
      "id": "cp2:2.4",
      "pali": "Tattāya kaṭhinabhūmiyā."
    },
    {
      "id": "cp2:3.1",
      "pali": "Tamahaṁ paṭipathe disvā,"
    },
    {
      "id": "cp2:3.2",
      "pali": "imamatthaṁ vicintayiṁ;"
    },
    {
      "id": "cp2:3.3",
      "pali": "‘Idaṁ khettaṁ anuppattaṁ,"
    },
    {
      "id": "cp2:3.4",
      "pali": "puññakāmassa jantuno."
    },
    {
      "id": "cp2:4.1",
      "pali": "Yathā kassako puriso,"
    },
    {
      "id": "cp2:4.2",
      "pali": "khettaṁ disvā mahāgamaṁ;"
    },
    {
      "id": "cp2:4.3",
      "pali": "Tattha bījaṁ na ropeti,"
    },
    {
      "id": "cp2:4.4",
      "pali": "na so dhaññena atthiko."
    },
    {
      "id": "cp2:5.1",
      "pali": "Evamevāhaṁ puññakāmo,"
    },
    {
      "id": "cp2:5.2",
      "pali": "Disvā khettavaruttamaṁ;"
    },
    {
      "id": "cp2:5.3",
      "pali": "Yadi tattha kāraṁ na karomi,"
    },
    {
      "id": "cp2:5.4",
      "pali": "Nāhaṁ puññena atthiko."
    },
    {
      "id": "cp2:6.1",
      "pali": "Yathā amacco muddikāmo,"
    },
    {
      "id": "cp2:6.2",
      "pali": "rañño antepure jane;"
    },
    {
      "id": "cp2:6.3",
      "pali": "Na deti tesaṁ dhanadhaññaṁ,"
    },
    {
      "id": "cp2:6.4",
      "pali": "muddito parihāyati."
    },
    {
      "id": "cp2:7.1",
      "pali": "Evamevāhaṁ puññakāmo,"
    },
    {
      "id": "cp2:7.2",
      "pali": "Vipulaṁ disvāna dakkhiṇaṁ;"
    },
    {
      "id": "cp2:7.3",
      "pali": "Yadi tassa dānaṁ na dadāmi,"
    },
    {
      "id": "cp2:7.4",
      "pali": "Parihāyissāmi puññato’."
    },
    {
      "id": "cp2:8.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "cp2:8.2",
      "pali": "orohitvā upāhanā;"
    },
    {
      "id": "cp2:8.3",
      "pali": "Tassa pādāni vanditvā,"
    },
    {
      "id": "cp2:8.4",
      "pali": "adāsiṁ chattupāhanaṁ."
    },
    {
      "id": "cp2:9.1",
      "pali": "Tenevāhaṁ sataguṇato,"
    },
    {
      "id": "cp2:9.2",
      "pali": "Sukhumālo sukhedhito;"
    },
    {
      "id": "cp2:9.3",
      "pali": "Api ca dānaṁ paripūrento,"
    },
    {
      "id": "cp2:9.4",
      "pali": "Evaṁ tassa adāsahan”ti."
    },
    {
      "id": "cp2:10.1",
      "pali": "Saṅkhacariyaṁ dutiyaṁ."
    }
  ]
}
