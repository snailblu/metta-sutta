{
  "uid": "tha-ap381",
  "title": "Sumanadāmiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap381:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap381:1.2",
      "pali": "nhātakassa tapassino;"
    },
    {
      "id": "tha-ap381:1.3",
      "pali": "Katvāna sumanadāmaṁ,"
    },
    {
      "id": "tha-ap381:1.4",
      "pali": "dhārayiṁ purato ṭhito."
    },
    {
      "id": "tha-ap381:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap381:2.2",
      "pali": "yaṁ dāmaṁ dhārayiṁ tadā;"
    },
    {
      "id": "tha-ap381:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap381:2.4",
      "pali": "sumanadhāraṇe phalaṁ."
    },
    {
      "id": "tha-ap381:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap381:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap381:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap381:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap381:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap381:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap381:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap381:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap381:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap381:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumanadāmiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap381:7.1",
      "pali": "Sumanadāmiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
