{
  "uid": "pv45",
  "title": "10. Gaṇapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv45:1.1",
      "pali": "“Naggā dubbaṇṇarūpāttha,"
    },
    {
      "id": "pv45:1.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv45:1.3",
      "pali": "Upphāsulikā kisikā,"
    },
    {
      "id": "pv45:1.4",
      "pali": "ke nu tumhettha mārisā”ti."
    },
    {
      "id": "pv45:2.1",
      "pali": "“Mayaṁ bhadante petāmhā,"
    },
    {
      "id": "pv45:2.2",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv45:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv45:2.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv45:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv45:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv45:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv45:3.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv45:4.1",
      "pali": "“Anāvaṭesu titthesu,"
    },
    {
      "id": "pv45:4.2",
      "pali": "vicinimhaddhamāsakaṁ;"
    },
    {
      "id": "pv45:4.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv45:4.4",
      "pali": "dīpaṁ nākamha attano."
    },
    {
      "id": "pv45:5.1",
      "pali": "Nadiṁ upema tasitā,"
    },
    {
      "id": "pv45:5.2",
      "pali": "rittakā parivattati;"
    },
    {
      "id": "pv45:5.3",
      "pali": "Chāyaṁ upema uṇhesu,"
    },
    {
      "id": "pv45:5.4",
      "pali": "ātapo parivattati."
    },
    {
      "id": "pv45:6.1",
      "pali": "Aggivaṇṇo ca no vāto,"
    },
    {
      "id": "pv45:6.2",
      "pali": "ḍahanto upavāyati;"
    },
    {
      "id": "pv45:6.3",
      "pali": "Etañca bhante arahāma,"
    },
    {
      "id": "pv45:6.4",
      "pali": "aññañca pāpakaṁ tato."
    },
    {
      "id": "pv45:7.1",
      "pali": "Api yojanāni gacchāma,"
    },
    {
      "id": "pv45:7.2",
      "pali": "chātā āhāragedhino;"
    },
    {
      "id": "pv45:7.3",
      "pali": "Aladdhāva nivattāma,"
    },
    {
      "id": "pv45:7.4",
      "pali": "aho no appapuññatā."
    },
    {
      "id": "pv45:8.1",
      "pali": "Chātā pamucchitā bhantā,"
    },
    {
      "id": "pv45:8.2",
      "pali": "bhūmiyaṁ paṭisumbhitā;"
    },
    {
      "id": "pv45:8.3",
      "pali": "Uttānā paṭikirāma,"
    },
    {
      "id": "pv45:8.4",
      "pali": "avakujjā patāmase."
    },
    {
      "id": "pv45:9.1",
      "pali": "Te ca tattheva patitā,"
    },
    {
      "id": "pv45:9.2",
      "pali": "bhūmiyaṁ paṭisumbhitā;"
    },
    {
      "id": "pv45:9.3",
      "pali": "Uraṁ sīsañca ghaṭṭema,"
    },
    {
      "id": "pv45:9.4",
      "pali": "aho no appapuññatā."
    },
    {
      "id": "pv45:10.1",
      "pali": "Etañca bhante arahāma,"
    },
    {
      "id": "pv45:10.2",
      "pali": "aññañca pāpakaṁ tato;"
    },
    {
      "id": "pv45:10.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv45:10.4",
      "pali": "dīpaṁ nākamha attano."
    },
    {
      "id": "pv45:11.1",
      "pali": "Te hi nūna ito gantvā,"
    },
    {
      "id": "pv45:11.2",
      "pali": "yoniṁ laddhāna mānusiṁ;"
    },
    {
      "id": "pv45:11.3",
      "pali": "Vadaññū sīlasampannā,"
    },
    {
      "id": "pv45:11.4",
      "pali": "kāhāma kusalaṁ bahun”ti."
    },
    {
      "id": "pv45:12.1",
      "pali": "Gaṇapetavatthu dasamaṁ."
    }
  ]
}
