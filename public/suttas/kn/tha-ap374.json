{
  "uid": "tha-ap374",
  "title": "Pāṭalipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap374:1.1",
      "pali": "“Vipassī nāma bhagavā,"
    },
    {
      "id": "tha-ap374:1.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap374:1.3",
      "pali": "Purakkhato sasissehi,"
    },
    {
      "id": "tha-ap374:1.4",
      "pali": "pāvisi bandhumaṁ jino."
    },
    {
      "id": "tha-ap374:2.1",
      "pali": "Tīṇi pāṭalipupphāni,"
    },
    {
      "id": "tha-ap374:2.2",
      "pali": "ucchaṅge ṭhapitāni me;"
    },
    {
      "id": "tha-ap374:2.3",
      "pali": "Sīsaṁ nhāyitukāmova,"
    },
    {
      "id": "tha-ap374:2.4",
      "pali": "nadītitthaṁ agacchahaṁ."
    },
    {
      "id": "tha-ap374:3.1",
      "pali": "Nikkhamma bandhumatiyā,"
    },
    {
      "id": "tha-ap374:3.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap374:3.3",
      "pali": "Indīvaraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap374:3.4",
      "pali": "ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap374:4.1",
      "pali": "Byagghūsabhaṁva pavaraṁ,"
    },
    {
      "id": "tha-ap374:4.2",
      "pali": "abhijātaṁva kesariṁ;"
    },
    {
      "id": "tha-ap374:4.3",
      "pali": "Gacchantaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap374:4.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap374:5.1",
      "pali": "Tasmiṁ pasanno sugate,"
    },
    {
      "id": "tha-ap374:5.2",
      "pali": "kilesamaladhovane;"
    },
    {
      "id": "tha-ap374:5.3",
      "pali": "Gahetvā tīṇi pupphāni,"
    },
    {
      "id": "tha-ap374:5.4",
      "pali": "buddhaseṭṭhaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap374:6.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap374:6.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap374:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap374:6.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap374:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap374:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap374:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap374:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāṭalipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap374:9.1",
      "pali": "Pāṭalipupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
