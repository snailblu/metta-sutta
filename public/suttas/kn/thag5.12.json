{
  "uid": "thag5.12",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.12:1.1",
      "pali": "“Yo ve garūnaṁ vacanaññu dhīro,"
    },
    {
      "id": "thag5.12:1.2",
      "pali": "Vase ca tamhi janayetha pemaṁ;"
    },
    {
      "id": "thag5.12:1.3",
      "pali": "So bhattimā nāma ca hoti paṇḍito,"
    },
    {
      "id": "thag5.12:1.4",
      "pali": "Ñatvā ca dhammesu visesi assa."
    },
    {
      "id": "thag5.12:2.1",
      "pali": "Yaṁ āpadā uppatitā uḷārā,"
    },
    {
      "id": "thag5.12:2.2",
      "pali": "Nakkhambhayante paṭisaṅkhayantaṁ;"
    },
    {
      "id": "thag5.12:2.3",
      "pali": "So thāmavā nāma ca hoti paṇḍito,"
    },
    {
      "id": "thag5.12:2.4",
      "pali": "Ñatvā ca dhammesu visesi assa."
    },
    {
      "id": "thag5.12:3.1",
      "pali": "Yo ve samuddova ṭhito anejo,"
    },
    {
      "id": "thag5.12:3.2",
      "pali": "Gambhīrapañño nipuṇatthadassī;"
    },
    {
      "id": "thag5.12:3.3",
      "pali": "Asaṁhāriyo nāma ca hoti paṇḍito,"
    },
    {
      "id": "thag5.12:3.4",
      "pali": "Ñatvā ca dhammesu visesi assa."
    },
    {
      "id": "thag5.12:4.1",
      "pali": "Bahussuto dhammadharo ca hoti,"
    },
    {
      "id": "thag5.12:4.2",
      "pali": "Dhammassa hoti anudhammacārī;"
    },
    {
      "id": "thag5.12:4.3",
      "pali": "So tādiso nāma ca hoti paṇḍito,"
    },
    {
      "id": "thag5.12:4.4",
      "pali": "Ñatvā ca dhammesu visesi assa."
    },
    {
      "id": "thag5.12:5.1",
      "pali": "Atthañca yo jānāti bhāsitassa,"
    },
    {
      "id": "thag5.12:5.2",
      "pali": "Atthañca ñatvāna tathā karoti;"
    },
    {
      "id": "thag5.12:5.3",
      "pali": "Atthantaro nāma sa hoti paṇḍito,"
    },
    {
      "id": "thag5.12:5.4",
      "pali": "Ñatvā ca dhammesu visesi assā”ti."
    },
    {
      "id": "thag5.12:5.5",
      "pali": "… Kosiyo thero …."
    },
    {
      "id": "thag5.12:5.6",
      "pali": "Pañcakanipāto niṭṭhito."
    },
    {
      "id": "thag5.12:6.1",
      "pali": "Rājadatto subhūto ca,"
    },
    {
      "id": "thag5.12:6.2",
      "pali": "girimānandasumanā;"
    },
    {
      "id": "thag5.12:6.3",
      "pali": "Vaḍḍho ca kassapo thero,"
    },
    {
      "id": "thag5.12:6.4",
      "pali": "gayākassapavakkalī."
    },
    {
      "id": "thag5.12:7.1",
      "pali": "Vijito yasadatto ca,"
    },
    {
      "id": "thag5.12:7.2",
      "pali": "soṇo kosiyasavhayo;"
    },
    {
      "id": "thag5.12:7.3",
      "pali": "Saṭṭhi ca pañca gāthāyo,"
    },
    {
      "id": "thag5.12:7.4",
      "pali": "therā ca ettha dvādasāti."
    }
  ]
}
