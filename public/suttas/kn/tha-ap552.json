{
  "uid": "tha-ap552",
  "title": "Cūḷasugandhattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap552:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap552:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap552:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap552:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap552:2.1",
      "pali": "Anubyañjanasampanno,"
    },
    {
      "id": "tha-ap552:2.2",
      "pali": "bāttiṁsavaralakkhaṇo;"
    },
    {
      "id": "tha-ap552:2.3",
      "pali": "Byāmappabhāparivuto,"
    },
    {
      "id": "tha-ap552:2.4",
      "pali": "raṁsijālasamotthaṭo."
    },
    {
      "id": "tha-ap552:3.1",
      "pali": "Assāsetā yathā cando,"
    },
    {
      "id": "tha-ap552:3.2",
      "pali": "sūriyova pabhaṅkaro;"
    },
    {
      "id": "tha-ap552:3.3",
      "pali": "Nibbāpetā yathā megho,"
    },
    {
      "id": "tha-ap552:3.4",
      "pali": "sāgarova guṇākaro."
    },
    {
      "id": "tha-ap552:4.1",
      "pali": "Dharaṇīriva sīlena,"
    },
    {
      "id": "tha-ap552:4.2",
      "pali": "himavāva samādhinā;"
    },
    {
      "id": "tha-ap552:4.3",
      "pali": "Ākāso viya paññāya,"
    },
    {
      "id": "tha-ap552:4.4",
      "pali": "asaṅgo anilo yathā."
    },
    {
      "id": "tha-ap552:5.1",
      "pali": "Tadāhaṁ bārāṇasiyaṁ,"
    },
    {
      "id": "tha-ap552:5.2",
      "pali": "upapanno mahākule;"
    },
    {
      "id": "tha-ap552:5.3",
      "pali": "Pahūtadhanadhaññasmiṁ,"
    },
    {
      "id": "tha-ap552:5.4",
      "pali": "nānāratanasañcaye."
    },
    {
      "id": "tha-ap552:6.1",
      "pali": "Mahatā parivārena,"
    },
    {
      "id": "tha-ap552:6.2",
      "pali": "nisinnaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap552:6.3",
      "pali": "Upecca dhammamassosiṁ,"
    },
    {
      "id": "tha-ap552:6.4",
      "pali": "amataṁva manoharaṁ."
    },
    {
      "id": "tha-ap552:7.1",
      "pali": "Dvattiṁsalakkhaṇadharo,"
    },
    {
      "id": "tha-ap552:7.2",
      "pali": "sanakkhattova candimā;"
    },
    {
      "id": "tha-ap552:7.3",
      "pali": "Anubyañjanasampanno,"
    },
    {
      "id": "tha-ap552:7.4",
      "pali": "sālarājāva phullito."
    },
    {
      "id": "tha-ap552:8.1",
      "pali": "Raṁsijālaparikkhitto,"
    },
    {
      "id": "tha-ap552:8.2",
      "pali": "dittova kanakācalo;"
    },
    {
      "id": "tha-ap552:8.3",
      "pali": "Byāmappabhāparivuto,"
    },
    {
      "id": "tha-ap552:8.4",
      "pali": "sataraṁsī divākaro."
    },
    {
      "id": "tha-ap552:9.1",
      "pali": "Soṇṇānano jinavaro,"
    },
    {
      "id": "tha-ap552:9.2",
      "pali": "samaṇīva siluccayo;"
    },
    {
      "id": "tha-ap552:9.3",
      "pali": "Karuṇā puṇṇahadayo,"
    },
    {
      "id": "tha-ap552:9.4",
      "pali": "guṇena viya sāgaro."
    },
    {
      "id": "tha-ap552:10.1",
      "pali": "Lokavissutakitti ca,"
    },
    {
      "id": "tha-ap552:10.2",
      "pali": "sinerūva naguttamo;"
    },
    {
      "id": "tha-ap552:10.3",
      "pali": "Yasasā vitthato vīro,"
    },
    {
      "id": "tha-ap552:10.4",
      "pali": "ākāsasadiso muni."
    },
    {
      "id": "tha-ap552:11.1",
      "pali": "Asaṅgacitto sabbattha,"
    },
    {
      "id": "tha-ap552:11.2",
      "pali": "anilo viya nāyako;"
    },
    {
      "id": "tha-ap552:11.3",
      "pali": "Patiṭṭhā sabbabhūtānaṁ,"
    },
    {
      "id": "tha-ap552:11.4",
      "pali": "mahīva munisattamo."
    },
    {
      "id": "tha-ap552:12.1",
      "pali": "Anupalitto lokena,"
    },
    {
      "id": "tha-ap552:12.2",
      "pali": "toyena padumaṁ yathā;"
    },
    {
      "id": "tha-ap552:12.3",
      "pali": "Kuvādagacchadahano,"
    },
    {
      "id": "tha-ap552:12.4",
      "pali": "aggikhandhova sobhasi."
    },
    {
      "id": "tha-ap552:13.1",
      "pali": "Agadho viya sabbattha,"
    },
    {
      "id": "tha-ap552:13.2",
      "pali": "kilesavisanāsako;"
    },
    {
      "id": "tha-ap552:13.3",
      "pali": "Gandhamādanaselova,"
    },
    {
      "id": "tha-ap552:13.4",
      "pali": "guṇagandhavibhūsito."
    },
    {
      "id": "tha-ap552:14.1",
      "pali": "Guṇānaṁ ākaro vīro,"
    },
    {
      "id": "tha-ap552:14.2",
      "pali": "ratanānaṁva sāgaro;"
    },
    {
      "id": "tha-ap552:14.3",
      "pali": "Sindhūva vanarājīnaṁ,"
    },
    {
      "id": "tha-ap552:14.4",
      "pali": "kilesamalahārako."
    },
    {
      "id": "tha-ap552:15.1",
      "pali": "Vijayīva mahāyodho,"
    },
    {
      "id": "tha-ap552:15.2",
      "pali": "mārasenāvamaddano;"
    },
    {
      "id": "tha-ap552:15.3",
      "pali": "Cakkavattīva so rājā,"
    },
    {
      "id": "tha-ap552:15.4",
      "pali": "bojjhaṅgaratanissaro."
    },
    {
      "id": "tha-ap552:16.1",
      "pali": "Mahābhisakkasaṅkāso,"
    },
    {
      "id": "tha-ap552:16.2",
      "pali": "dosabyādhitikicchako;"
    },
    {
      "id": "tha-ap552:16.3",
      "pali": "Sallakatto yathā vejjo,"
    },
    {
      "id": "tha-ap552:16.4",
      "pali": "diṭṭhigaṇḍaviphālako."
    },
    {
      "id": "tha-ap552:17.1",
      "pali": "So tadā lokapajjoto,"
    },
    {
      "id": "tha-ap552:17.2",
      "pali": "sanarāmarasakkato;"
    },
    {
      "id": "tha-ap552:17.3",
      "pali": "Parisāsu narādicco,"
    },
    {
      "id": "tha-ap552:17.4",
      "pali": "dhammaṁ desayate jino."
    },
    {
      "id": "tha-ap552:18.1",
      "pali": "‘Dānaṁ datvā mahābhogo,"
    },
    {
      "id": "tha-ap552:18.2",
      "pali": "sīlena sugatūpago;"
    },
    {
      "id": "tha-ap552:18.3",
      "pali": "Bhāvanāya ca nibbāti’,"
    },
    {
      "id": "tha-ap552:18.4",
      "pali": "iccevamanusāsatha."
    },
    {
      "id": "tha-ap552:19.1",
      "pali": "Desanaṁ taṁ mahassādaṁ,"
    },
    {
      "id": "tha-ap552:19.2",
      "pali": "ādimajjhantasobhanaṁ;"
    },
    {
      "id": "tha-ap552:19.3",
      "pali": "Suṇanti parisā sabbā,"
    },
    {
      "id": "tha-ap552:19.4",
      "pali": "amataṁva mahārasaṁ."
    },
    {
      "id": "tha-ap552:20.1",
      "pali": "Sutvā sumadhuraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap552:20.2",
      "pali": "pasanno jinasāsane;"
    },
    {
      "id": "tha-ap552:20.3",
      "pali": "Sugataṁ saraṇaṁ gantvā,"
    },
    {
      "id": "tha-ap552:20.4",
      "pali": "yāvajīvaṁ namassahaṁ."
    },
    {
      "id": "tha-ap552:21.1",
      "pali": "Munino gandhakuṭiyā,"
    },
    {
      "id": "tha-ap552:21.2",
      "pali": "opuñjesiṁ tadā mahiṁ;"
    },
    {
      "id": "tha-ap552:21.3",
      "pali": "Catujjātena gandhena,"
    },
    {
      "id": "tha-ap552:21.4",
      "pali": "māse aṭṭha dinesvahaṁ."
    },
    {
      "id": "tha-ap552:22.1",
      "pali": "Paṇidhāya sugandhattaṁ,"
    },
    {
      "id": "tha-ap552:22.2",
      "pali": "sarīravissagandhino;"
    },
    {
      "id": "tha-ap552:22.3",
      "pali": "Tadā jino viyākāsi,"
    },
    {
      "id": "tha-ap552:22.4",
      "pali": "sugandhatanulābhitaṁ."
    },
    {
      "id": "tha-ap552:23.1",
      "pali": "‘Yo yaṁ gandhakuṭibhūmiṁ,"
    },
    {
      "id": "tha-ap552:23.2",
      "pali": "gandhenopuñjate sakiṁ;"
    },
    {
      "id": "tha-ap552:23.3",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "tha-ap552:23.4",
      "pali": "upapanno tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap552:24.1",
      "pali": "Sugandhadeho sabbattha,"
    },
    {
      "id": "tha-ap552:24.2",
      "pali": "bhavissati ayaṁ naro;"
    },
    {
      "id": "tha-ap552:24.3",
      "pali": "Guṇagandhayutto hutvā,"
    },
    {
      "id": "tha-ap552:24.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap552:25.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap552:25.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap552:25.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap552:25.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap552:26.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap552:26.2",
      "pali": "jāto vippakule ahaṁ;"
    },
    {
      "id": "tha-ap552:26.3",
      "pali": "Gabbhaṁ me vasato mātā,"
    },
    {
      "id": "tha-ap552:26.4",
      "pali": "dehenāsi sugandhitā."
    },
    {
      "id": "tha-ap552:27.1",
      "pali": "Yadā ca mātukucchimhā,"
    },
    {
      "id": "tha-ap552:27.2",
      "pali": "nikkhamāmi tadā purī;"
    },
    {
      "id": "tha-ap552:27.3",
      "pali": "Sāvatthisabbagandhehi,"
    },
    {
      "id": "tha-ap552:27.4",
      "pali": "vāsitā viya vāyatha."
    },
    {
      "id": "tha-ap552:28.1",
      "pali": "Pupphavassañca surabhi,"
    },
    {
      "id": "tha-ap552:28.2",
      "pali": "dibbagandhaṁ manoramaṁ;"
    },
    {
      "id": "tha-ap552:28.3",
      "pali": "Dhūpāni ca mahagghāni,"
    },
    {
      "id": "tha-ap552:28.4",
      "pali": "upavāyiṁsu tāvade."
    },
    {
      "id": "tha-ap552:29.1",
      "pali": "Devā ca sabbagandhehi,"
    },
    {
      "id": "tha-ap552:29.2",
      "pali": "dhūpapupphehi taṁ gharaṁ;"
    },
    {
      "id": "tha-ap552:29.3",
      "pali": "Vāsayiṁsu sugandhena,"
    },
    {
      "id": "tha-ap552:29.4",
      "pali": "yasmiṁ jāto ahaṁ ghare."
    },
    {
      "id": "tha-ap552:30.1",
      "pali": "Yadā ca taruṇo bhaddo,"
    },
    {
      "id": "tha-ap552:30.2",
      "pali": "paṭhame yobbane ṭhito;"
    },
    {
      "id": "tha-ap552:30.3",
      "pali": "Tadā selaṁ saparisaṁ,"
    },
    {
      "id": "tha-ap552:30.4",
      "pali": "vinetvā narasārathi."
    },
    {
      "id": "tha-ap552:31.1",
      "pali": "Tehi sabbehi parivuto,"
    },
    {
      "id": "tha-ap552:31.2",
      "pali": "sāvatthipuramāgato;"
    },
    {
      "id": "tha-ap552:31.3",
      "pali": "Tadā buddhānubhāvaṁ taṁ,"
    },
    {
      "id": "tha-ap552:31.4",
      "pali": "disvā pabbajito ahaṁ."
    },
    {
      "id": "tha-ap552:32.1",
      "pali": "Sīlaṁ samādhipaññañca,"
    },
    {
      "id": "tha-ap552:32.2",
      "pali": "vimuttiñca anuttaraṁ;"
    },
    {
      "id": "tha-ap552:32.3",
      "pali": "Bhāvetvā caturo dhamme,"
    },
    {
      "id": "tha-ap552:32.4",
      "pali": "pāpuṇiṁ āsavakkhayaṁ."
    },
    {
      "id": "tha-ap552:33.1",
      "pali": "Yadā pabbajito cāhaṁ,"
    },
    {
      "id": "tha-ap552:33.2",
      "pali": "yadā ca arahā ahuṁ;"
    },
    {
      "id": "tha-ap552:33.3",
      "pali": "Nibbāyissaṁ yadā cāhaṁ,"
    },
    {
      "id": "tha-ap552:33.4",
      "pali": "gandhavasso tadā ahu."
    },
    {
      "id": "tha-ap552:34.1",
      "pali": "Sarīragandho ca sadātiseti me,"
    },
    {
      "id": "tha-ap552:34.2",
      "pali": "Mahārahaṁ candanacampakuppalaṁ;"
    },
    {
      "id": "tha-ap552:34.3",
      "pali": "Tatheva gandhe itare ca sabbaso,"
    },
    {
      "id": "tha-ap552:34.4",
      "pali": "Pasayha vāyāmi tato tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap552:35.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap552:35.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap552:35.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap552:36.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap552:36.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap552:36.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap552:37.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap552:37.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap552:37.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap552:38.1",
      "pali": "Itthaṁ sudaṁ āyasmā cūḷasugandho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap552:39.1",
      "pali": "Cūḷasugandhattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap552:40.1",
      "pali": "Bhaddiyavaggo pañcapaññāsamo."
    },
    {
      "id": "tha-ap552:41.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap552:42.1",
      "pali": "Bhaddiyo revato thero,"
    },
    {
      "id": "tha-ap552:42.2",
      "pali": "mahālābhī ca sīvali;"
    },
    {
      "id": "tha-ap552:42.3",
      "pali": "Vaṅgīso nandako ceva,"
    },
    {
      "id": "tha-ap552:42.4",
      "pali": "kāḷudāyī tathābhayo."
    },
    {
      "id": "tha-ap552:43.1",
      "pali": "Lomaso vanavaccho ca,"
    },
    {
      "id": "tha-ap552:43.2",
      "pali": "sugandho ceva dasamo;"
    },
    {
      "id": "tha-ap552:43.3",
      "pali": "Tīṇi gāthāsatā tattha,"
    },
    {
      "id": "tha-ap552:43.4",
      "pali": "soḷasā ca taduttari."
    },
    {
      "id": "tha-ap552:44.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap552:45.1",
      "pali": "Kaṇikāravhayo vaggo,"
    },
    {
      "id": "tha-ap552:45.2",
      "pali": "phalado tiṇadāyako;"
    },
    {
      "id": "tha-ap552:45.3",
      "pali": "Kaccāno bhaddiyo vaggo,"
    },
    {
      "id": "tha-ap552:45.4",
      "pali": "gāthāyo gaṇitā cimā."
    },
    {
      "id": "tha-ap552:46.1",
      "pali": "Navagāthāsatānīha,"
    },
    {
      "id": "tha-ap552:46.2",
      "pali": "caturāsītiyeva ca;"
    },
    {
      "id": "tha-ap552:46.3",
      "pali": "Sapaññāsaṁ pañcasataṁ,"
    },
    {
      "id": "tha-ap552:46.4",
      "pali": "apadānā pakāsitā."
    },
    {
      "id": "tha-ap552:47.1",
      "pali": "Saha udānagāthāhi,"
    },
    {
      "id": "tha-ap552:47.2",
      "pali": "chasahassāni hontimā;"
    },
    {
      "id": "tha-ap552:47.3",
      "pali": "Dvesatāni ca gāthānaṁ,"
    },
    {
      "id": "tha-ap552:47.4",
      "pali": "aṭṭhārasa taduttari."
    }
  ]
}
