{
  "uid": "ja72",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja72:1.1",
      "pali": "“Akataññussa posassa,"
    },
    {
      "id": "ja72:1.2",
      "pali": "niccaṁ vivaradassino;"
    },
    {
      "id": "ja72:1.3",
      "pali": "Sabbañce pathaviṁ dajjā,"
    },
    {
      "id": "ja72:1.4",
      "pali": "neva naṁ abhirādhaye”ti."
    },
    {
      "id": "ja72:2.1",
      "pali": "Sīlavahatthijātakaṁ dutiyaṁ."
    }
  ]
}
