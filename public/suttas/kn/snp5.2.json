{
  "uid": "snp5.2",
  "title": "Ajitamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.2:1.1",
      "pali": "“Kenassu nivuto loko,"
    },
    {
      "id": "snp5.2:1.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "snp5.2:1.3",
      "pali": "Kenassu nappakāsati;"
    },
    {
      "id": "snp5.2:1.4",
      "pali": "Kissābhilepanaṁ brūsi,"
    },
    {
      "id": "snp5.2:1.5",
      "pali": "Kiṁsu tassa mahabbhayaṁ”."
    },
    {
      "id": "snp5.2:2.1",
      "pali": "“Avijjāya nivuto loko,"
    },
    {
      "id": "snp5.2:2.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "snp5.2:2.3",
      "pali": "Vevicchā pamādā nappakāsati;"
    },
    {
      "id": "snp5.2:2.4",
      "pali": "Jappābhilepanaṁ brūmi,"
    },
    {
      "id": "snp5.2:2.5",
      "pali": "Dukkhamassa mahabbhayaṁ”."
    },
    {
      "id": "snp5.2:3.1",
      "pali": "“Savanti sabbadhi sotā,"
    },
    {
      "id": "snp5.2:3.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "snp5.2:3.3",
      "pali": "Sotānaṁ kiṁ nivāraṇaṁ;"
    },
    {
      "id": "snp5.2:3.4",
      "pali": "Sotānaṁ saṁvaraṁ brūhi,"
    },
    {
      "id": "snp5.2:3.5",
      "pali": "Kena sotā pidhiyyare”."
    },
    {
      "id": "snp5.2:4.1",
      "pali": "“Yāni sotāni lokasmiṁ,"
    },
    {
      "id": "snp5.2:4.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "snp5.2:4.3",
      "pali": "Sati tesaṁ nivāraṇaṁ;"
    },
    {
      "id": "snp5.2:4.4",
      "pali": "Sotānaṁ saṁvaraṁ brūmi,"
    },
    {
      "id": "snp5.2:4.5",
      "pali": "Paññāyete pidhiyyare”."
    },
    {
      "id": "snp5.2:5.1",
      "pali": "“Paññā ceva sati yañca,"
    },
    {
      "id": "snp5.2:5.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "snp5.2:5.3",
      "pali": "Nāmarūpañca mārisa;"
    },
    {
      "id": "snp5.2:5.4",
      "pali": "Etaṁ me puṭṭho pabrūhi,"
    },
    {
      "id": "snp5.2:5.5",
      "pali": "Katthetaṁ uparujjhati”."
    },
    {
      "id": "snp5.2:6.1",
      "pali": "“Yametaṁ pañhaṁ apucchi,"
    },
    {
      "id": "snp5.2:6.2",
      "pali": "ajita taṁ vadāmi te;"
    },
    {
      "id": "snp5.2:6.3",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "snp5.2:6.4",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "snp5.2:6.5",
      "pali": "Viññāṇassa nirodhena,"
    },
    {
      "id": "snp5.2:6.6",
      "pali": "etthetaṁ uparujjhati”."
    },
    {
      "id": "snp5.2:7.1",
      "pali": "“Ye ca saṅkhātadhammāse,"
    },
    {
      "id": "snp5.2:7.2",
      "pali": "ye ca sekhā puthū idha;"
    },
    {
      "id": "snp5.2:7.3",
      "pali": "Tesaṁ me nipako iriyaṁ,"
    },
    {
      "id": "snp5.2:7.4",
      "pali": "puṭṭho pabrūhi mārisa”."
    },
    {
      "id": "snp5.2:8.1",
      "pali": "“Kāmesu nābhigijjheyya,"
    },
    {
      "id": "snp5.2:8.2",
      "pali": "Manasānāvilo siyā;"
    },
    {
      "id": "snp5.2:8.3",
      "pali": "Kusalo sabbadhammānaṁ,"
    },
    {
      "id": "snp5.2:8.4",
      "pali": "Sato bhikkhu paribbaje”ti."
    },
    {
      "id": "snp5.2:8.5",
      "pali": "Ajitamāṇavapucchā paṭhamā."
    }
  ]
}
