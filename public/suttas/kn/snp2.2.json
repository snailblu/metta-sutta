{
  "uid": "snp2.2",
  "title": "Āmagandhasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.2:1.1",
      "pali": "“Sāmākaciṅgūlakacīnakāni ca,"
    },
    {
      "id": "snp2.2:1.2",
      "pali": "Pattapphalaṁ mūlaphalaṁ gavipphalaṁ;"
    },
    {
      "id": "snp2.2:1.3",
      "pali": "Dhammena laddhaṁ satamasnamānā,"
    },
    {
      "id": "snp2.2:1.4",
      "pali": "Na kāmakāmā alikaṁ bhaṇanti."
    },
    {
      "id": "snp2.2:2.1",
      "pali": "Yadasnamāno sukataṁ suniṭṭhitaṁ,"
    },
    {
      "id": "snp2.2:2.2",
      "pali": "Parehi dinnaṁ payataṁ paṇītaṁ;"
    },
    {
      "id": "snp2.2:2.3",
      "pali": "Sālīnamannaṁ paribhuñjamāno,"
    },
    {
      "id": "snp2.2:2.4",
      "pali": "So bhuñjasī kassapa āmagandhaṁ."
    },
    {
      "id": "snp2.2:3.1",
      "pali": "Na āmagandho mama kappatīti,"
    },
    {
      "id": "snp2.2:3.2",
      "pali": "Icceva tvaṁ bhāsasi brahmabandhu;"
    },
    {
      "id": "snp2.2:3.3",
      "pali": "Sālīnamannaṁ paribhuñjamāno,"
    },
    {
      "id": "snp2.2:3.4",
      "pali": "Sakuntamaṁsehi susaṅkhatehi;"
    },
    {
      "id": "snp2.2:3.5",
      "pali": "Pucchāmi taṁ kassapa etamatthaṁ,"
    },
    {
      "id": "snp2.2:3.6",
      "pali": "Kathaṁpakāro tava āmagandho”."
    },
    {
      "id": "snp2.2:4.1",
      "pali": "“Pāṇātipāto vadhachedabandhanaṁ,"
    },
    {
      "id": "snp2.2:4.2",
      "pali": "Theyyaṁ musāvādo nikativañcanāni ca;"
    },
    {
      "id": "snp2.2:4.3",
      "pali": "Ajjhenakuttaṁ paradārasevanā,"
    },
    {
      "id": "snp2.2:4.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:5.1",
      "pali": "Ye idha kāmesu asaññatā janā,"
    },
    {
      "id": "snp2.2:5.2",
      "pali": "Rasesu giddhā asucibhāvamassitā;"
    },
    {
      "id": "snp2.2:5.3",
      "pali": "Natthikadiṭṭhī visamā durannayā,"
    },
    {
      "id": "snp2.2:5.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:6.1",
      "pali": "Ye lūkhasā dāruṇā piṭṭhimaṁsikā,"
    },
    {
      "id": "snp2.2:6.2",
      "pali": "Mittadduno nikkaruṇātimānino;"
    },
    {
      "id": "snp2.2:6.3",
      "pali": "Adānasīlā na ca denti kassaci,"
    },
    {
      "id": "snp2.2:6.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:7.1",
      "pali": "Kodho mado thambho paccupaṭṭhāpanā,"
    },
    {
      "id": "snp2.2:7.2",
      "pali": "Māyā usūyā bhassasamussayo ca;"
    },
    {
      "id": "snp2.2:7.3",
      "pali": "Mānātimāno ca asabbhi santhavo,"
    },
    {
      "id": "snp2.2:7.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:8.1",
      "pali": "Ye pāpasīlā iṇaghātasūcakā,"
    },
    {
      "id": "snp2.2:8.2",
      "pali": "Vohārakūṭā idha pāṭirūpikā;"
    },
    {
      "id": "snp2.2:8.3",
      "pali": "Narādhamā yedha karonti kibbisaṁ,"
    },
    {
      "id": "snp2.2:8.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:9.1",
      "pali": "Ye idha pāṇesu asaññatā janā,"
    },
    {
      "id": "snp2.2:9.2",
      "pali": "Paresamādāya vihesamuyyutā;"
    },
    {
      "id": "snp2.2:9.3",
      "pali": "Dussīlaluddā pharusā anādarā,"
    },
    {
      "id": "snp2.2:9.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:10.1",
      "pali": "Etesu giddhā viruddhātipātino,"
    },
    {
      "id": "snp2.2:10.2",
      "pali": "Niccuyyutā pecca tamaṁ vajanti ye;"
    },
    {
      "id": "snp2.2:10.3",
      "pali": "Patanti sattā nirayaṁ avaṁsirā,"
    },
    {
      "id": "snp2.2:10.4",
      "pali": "Esāmagandho na hi maṁsabhojanaṁ."
    },
    {
      "id": "snp2.2:11.1",
      "pali": "Na macchamaṁsānamanāsakattaṁ,"
    },
    {
      "id": "snp2.2:11.2",
      "pali": "Na naggiyaṁ na muṇḍiyaṁ jaṭājallaṁ;"
    },
    {
      "id": "snp2.2:11.3",
      "pali": "Kharājināni nāggihuttassupasevanā,"
    },
    {
      "id": "snp2.2:11.4",
      "pali": "Ye vāpi loke amarā bahū tapā;"
    },
    {
      "id": "snp2.2:11.5",
      "pali": "Mantāhutī yaññamutūpasevanā,"
    },
    {
      "id": "snp2.2:11.6",
      "pali": "Sodhenti maccaṁ avitiṇṇakaṅkhaṁ."
    },
    {
      "id": "snp2.2:12.1",
      "pali": "Sotesu gutto viditindriyo care,"
    },
    {
      "id": "snp2.2:12.2",
      "pali": "Dhamme ṭhito ajjavamaddave rato;"
    },
    {
      "id": "snp2.2:12.3",
      "pali": "Saṅgātigo sabbadukkhappahīno,"
    },
    {
      "id": "snp2.2:12.4",
      "pali": "Na lippati diṭṭhasutesu dhīro”."
    },
    {
      "id": "snp2.2:13.1",
      "pali": "Iccetamatthaṁ bhagavā punappunaṁ,"
    },
    {
      "id": "snp2.2:13.2",
      "pali": "Akkhāsi naṁ vedayi mantapāragū;"
    },
    {
      "id": "snp2.2:13.3",
      "pali": "Citrāhi gāthāhi munī pakāsayi,"
    },
    {
      "id": "snp2.2:13.4",
      "pali": "Nirāmagandho asito durannayo."
    },
    {
      "id": "snp2.2:14.1",
      "pali": "Sutvāna buddhassa subhāsitaṁ padaṁ,"
    },
    {
      "id": "snp2.2:14.2",
      "pali": "Nirāmagandhaṁ sabbadukkhappanūdanaṁ;"
    },
    {
      "id": "snp2.2:14.3",
      "pali": "Nīcamano vandi tathāgatassa,"
    },
    {
      "id": "snp2.2:14.4",
      "pali": "Tattheva pabbajjamarocayitthāti."
    },
    {
      "id": "snp2.2:14.5",
      "pali": "Āmagandhasuttaṁ dutiyaṁ."
    }
  ]
}
