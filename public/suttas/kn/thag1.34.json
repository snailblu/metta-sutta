{
  "uid": "thag1.34",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.34:1.1",
      "pali": "“Anāsannavarā etā,"
    },
    {
      "id": "thag1.34:1.2",
      "pali": "niccameva vijānatā;"
    },
    {
      "id": "thag1.34:1.3",
      "pali": "Gāmā araññamāgamma,"
    },
    {
      "id": "thag1.34:1.4",
      "pali": "tato gehaṁ upāvisi;"
    },
    {
      "id": "thag1.34:1.5",
      "pali": "Tato uṭṭhāya pakkāmi,"
    },
    {
      "id": "thag1.34:1.6",
      "pali": "anāmantetvā posiyo”ti."
    },
    {
      "id": "thag1.34:1.7",
      "pali": "… Posiyo thero …."
    }
  ]
}
