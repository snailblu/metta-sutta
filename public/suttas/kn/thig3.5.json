{
  "uid": "thig3.5",
  "title": "Ubbiritherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.5:1.1",
      "pali": "“Amma jīvāti vanamhi kandasi,"
    },
    {
      "id": "thig3.5:1.2",
      "pali": "Attānaṁ adhigaccha ubbiri;"
    },
    {
      "id": "thig3.5:1.3",
      "pali": "Cullāsītisahassāni,"
    },
    {
      "id": "thig3.5:1.4",
      "pali": "Sabbā jīvasanāmikā;"
    },
    {
      "id": "thig3.5:1.5",
      "pali": "Etamhāḷāhane daḍḍhā,"
    },
    {
      "id": "thig3.5:1.6",
      "pali": "Tāsaṁ kamanusocasi”."
    },
    {
      "id": "thig3.5:2.1",
      "pali": "“Abbahī vata me sallaṁ,"
    },
    {
      "id": "thig3.5:2.2",
      "pali": "duddasaṁ hadayassitaṁ;"
    },
    {
      "id": "thig3.5:2.3",
      "pali": "Yaṁ me sokaparetāya,"
    },
    {
      "id": "thig3.5:2.4",
      "pali": "dhītusokaṁ byapānudi."
    },
    {
      "id": "thig3.5:3.1",
      "pali": "Sājja abbūḷhasallāhaṁ,"
    },
    {
      "id": "thig3.5:3.2",
      "pali": "Nicchātā parinibbutā;"
    },
    {
      "id": "thig3.5:3.3",
      "pali": "Buddhaṁ dhammañca saṅghañca,"
    },
    {
      "id": "thig3.5:3.4",
      "pali": "Upemi saraṇaṁ munin”ti."
    },
    {
      "id": "thig3.5:4.1",
      "pali": "… Ubbirī therī …."
    }
  ]
}
