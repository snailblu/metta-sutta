{
  "uid": "ja294",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja294:1.1",
      "pali": "“Koyaṁ bindussaro vaggu,"
    },
    {
      "id": "ja294:1.2",
      "pali": "saravantānamuttamo;"
    },
    {
      "id": "ja294:1.3",
      "pali": "Accuto jambusākhāya,"
    },
    {
      "id": "ja294:1.4",
      "pali": "moracchāpova kūjati”."
    },
    {
      "id": "ja294:2.1",
      "pali": "“Kulaputtova jānāti,"
    },
    {
      "id": "ja294:2.2",
      "pali": "kulaputtaṁ pasaṁsituṁ;"
    },
    {
      "id": "ja294:2.3",
      "pali": "Byagghacchāpasarīvaṇṇa,"
    },
    {
      "id": "ja294:2.4",
      "pali": "bhuñja samma dadāmi te”."
    },
    {
      "id": "ja294:3.1",
      "pali": "“Cirassaṁ vata passāmi,"
    },
    {
      "id": "ja294:3.2",
      "pali": "musāvādī samāgate;"
    },
    {
      "id": "ja294:3.3",
      "pali": "Vantādaṁ kuṇapādañca,"
    },
    {
      "id": "ja294:3.4",
      "pali": "aññamaññaṁ pasaṁsake”ti."
    },
    {
      "id": "ja294:4.1",
      "pali": "Jambukhādakajātakaṁ catutthaṁ."
    }
  ]
}
