{
  "uid": "ja367",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja367:1.1",
      "pali": "“Yvāyaṁ sāḷiyachāpoti,"
    },
    {
      "id": "ja367:1.2",
      "pali": "kaṇhasappaṁ agāhayi;"
    },
    {
      "id": "ja367:1.3",
      "pali": "Tena sappenayaṁ daṭṭho,"
    },
    {
      "id": "ja367:1.4",
      "pali": "hato pāpānusāsako."
    },
    {
      "id": "ja367:2.1",
      "pali": "Ahantāra mahantāraṁ,"
    },
    {
      "id": "ja367:2.2",
      "pali": "yo naro hantumicchati;"
    },
    {
      "id": "ja367:2.3",
      "pali": "Evaṁ so nihato seti,"
    },
    {
      "id": "ja367:2.4",
      "pali": "yathāyaṁ puriso hato."
    },
    {
      "id": "ja367:3.1",
      "pali": "Ahantāra maghātentaṁ,"
    },
    {
      "id": "ja367:3.2",
      "pali": "yo naro hantumicchati;"
    },
    {
      "id": "ja367:3.3",
      "pali": "Evaṁ so nihato seti,"
    },
    {
      "id": "ja367:3.4",
      "pali": "yathāyaṁ puriso hato."
    },
    {
      "id": "ja367:4.1",
      "pali": "Yathā paṁsumuṭṭhiṁ puriso,"
    },
    {
      "id": "ja367:4.2",
      "pali": "paṭivātaṁ paṭikkhipe;"
    },
    {
      "id": "ja367:4.3",
      "pali": "Tameva so rajo hanti,"
    },
    {
      "id": "ja367:4.4",
      "pali": "tathāyaṁ puriso hato."
    },
    {
      "id": "ja367:5.1",
      "pali": "Yo appaduṭṭhassa narassa dussati,"
    },
    {
      "id": "ja367:5.2",
      "pali": "Suddhassa posassa anaṅgaṇassa;"
    },
    {
      "id": "ja367:5.3",
      "pali": "Tameva bālaṁ pacceti pāpaṁ,"
    },
    {
      "id": "ja367:5.4",
      "pali": "Sukhumo rajo paṭivātaṁva khitto”ti."
    },
    {
      "id": "ja367:6.1",
      "pali": "Sāḷiyajātakaṁ sattamaṁ."
    }
  ]
}
