{
  "uid": "vv28",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv28:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv28:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv28:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv28:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv28:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv28:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv28:2.3",
      "pali": "vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv28:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv28:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv28:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv28:4.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv28:4.2",
      "pali": "Purimāya jātiyā manussaloke."
    },
    {
      "id": "vv28:5.1",
      "pali": "Addasaṁ virajaṁ bhikkhuṁ,"
    },
    {
      "id": "vv28:5.2",
      "pali": "vippasannamanāvilaṁ;"
    },
    {
      "id": "vv28:5.3",
      "pali": "Tassa adāsahaṁ bhikkhaṁ,"
    },
    {
      "id": "vv28:5.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv28:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv28:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv28:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv28:7.1",
      "pali": "Dutiyabhikkhādāyikāvimānaṁ ekādasamaṁ."
    },
    {
      "id": "vv28:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv28:9.1",
      "pali": "Dāsī ceva lakhumā ca,"
    },
    {
      "id": "vv28:9.2",
      "pali": "atha ācāmadāyikā;"
    },
    {
      "id": "vv28:9.3",
      "pali": "Caṇḍālī bhadditthī ceva,"
    },
    {
      "id": "vv28:9.4",
      "pali": "soṇadinnā uposathā;"
    },
    {
      "id": "vv28:9.5",
      "pali": "Niddā ceva suniddā ca,"
    },
    {
      "id": "vv28:9.6",
      "pali": "dve ca bhikkhāya dāyikā;"
    },
    {
      "id": "vv28:9.7",
      "pali": "Vaggo tena pavuccatīti."
    },
    {
      "id": "vv28:10.1",
      "pali": "Itthivimāne dutiyo vaggo."
    },
    {
      "id": "vv28:11.1",
      "pali": "Bhāṇavāraṁ paṭhamaṁ."
    }
  ]
}
