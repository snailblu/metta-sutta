{
  "uid": "ja158",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja158:1.1",
      "pali": "“Nayidaṁ visamasīlena,"
    },
    {
      "id": "ja158:1.2",
      "pali": "soṇena suhanū saha;"
    },
    {
      "id": "ja158:1.3",
      "pali": "Suhanūpi tādisoyeva,"
    },
    {
      "id": "ja158:1.4",
      "pali": "yo soṇassa sagocaro."
    },
    {
      "id": "ja158:2.1",
      "pali": "Pakkhandinā pagabbhena,"
    },
    {
      "id": "ja158:2.2",
      "pali": "niccaṁ sandānakhādinā;"
    },
    {
      "id": "ja158:2.3",
      "pali": "Sameti pāpaṁ pāpena,"
    },
    {
      "id": "ja158:2.4",
      "pali": "sameti asatā asan”ti."
    },
    {
      "id": "ja158:3.1",
      "pali": "Suhanujātakaṁ aṭṭhamaṁ."
    }
  ]
}
