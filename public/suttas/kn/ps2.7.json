      "id": "ps2.7:31.7",
      "pali": "Dhamme patiṭṭhito pavattetīti—dhammacakkaṁ …pe…"
    },
    {
      "id": "ps2.7:31.8",
      "pali": "amatogadhaṁ nibbānaṁ pariyosānaṭṭhena dhammo."
    },
    {
      "id": "ps2.7:31.9",
      "pali": "Taṁ dhammaṁ pavattetīti—dhammacakkanti."
    },
    {
      "id": "ps2.7:31.10",
      "pali": "Dhammacakkakathā niṭṭhitā."
    }
  ]
}
