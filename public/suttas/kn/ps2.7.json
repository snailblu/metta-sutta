{
  "uid": "ps2.7",
  "title": "2.7. Dhammacakkakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps2.7:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā bārāṇasiyaṁ viharati …pe…"
    },
    {
      "id": "ps2.7:1.2",
      "pali": "iti hidaṁ āyasmato koṇḍaññassa “aññāsikoṇḍañño” tveva nāmaṁ ahosi."
    },
    {
      "id": "ps2.7:2.1",
      "pali": "“Idaṁ dukkhaṁ ariyasaccan”ti pubbe ananussutesu dhammesu cakkhuṁ udapādi, ñāṇaṁ udapādi, paññā udapādi, vijjā udapādi, āloko udapādi."
    },
    {
      "id": "ps2.7:3.1",
      "pali": "Cakkhuṁ udapādīti—"
    },
    {
      "id": "ps2.7:3.2",
      "pali": "kenaṭṭhena?"
    },
    {
      "id": "ps2.7:3.3",
      "pali": "Ñāṇaṁ udapādīti—"
    },
    {
      "id": "ps2.7:3.4",
      "pali": "kenaṭṭhena?"
    },
    {
      "id": "ps2.7:3.5",
      "pali": "Paññā udapādīti—"
    },
    {
      "id": "ps2.7:3.6",
      "pali": "kenaṭṭhena?"
    },
    {
      "id": "ps2.7:3.7",
      "pali": "Vijjā udapādīti—"
    },
    {
      "id": "ps2.7:3.8",
      "pali": "kenaṭṭhena?"
    },
    {
      "id": "ps2.7:3.9",
      "pali": "Āloko udapādīti—"
    },
    {
      "id": "ps2.7:3.10",
      "pali": "kenaṭṭhena?"
    },
    {
      "id": "ps2.7:3.11",
      "pali": "<b>Cakkhuṁ udapādī</b>ti—"
    },
    {
      "id": "ps2.7:3.12",
      "pali": "dassanaṭṭhena."
    },
    {
      "id": "ps2.7:3.13",
      "pali": "<b>Ñāṇaṁ udapādī</b>ti—"
    },
    {
      "id": "ps2.7:3.14",
      "pali": "ñātaṭṭhena."
    },
    {
      "id": "ps2.7:3.15",
      "pali": "<b>Paññā udapādī</b>ti—"
    },
    {
      "id": "ps2.7:3.16",
      "pali": "pajānanaṭṭhena."
    },
    {
      "id": "ps2.7:3.17",
      "pali": "<b>Vijjā udapādī</b>ti—"
    },
    {
      "id": "ps2.7:3.18",
      "pali": "paṭivedhaṭṭhena."
    },
    {
      "id": "ps2.7:3.19",
      "pali": "<b>Āloko udapādī</b>ti—"
    },
    {
      "id": "ps2.7:3.20",
      "pali": "obhāsaṭṭhena."
    },
    {
      "id": "ps2.7:4.1",
      "pali": "Cakkhuṁ dhammo, dassanaṭṭho attho."
    },
    {
      "id": "ps2.7:4.2",
      "pali": "Ñāṇaṁ dhammo, ñātaṭṭho attho."
    },
    {
      "id": "ps2.7:4.3",
      "pali": "Paññā dhammo, pajānanaṭṭho attho."
    },
    {
      "id": "ps2.7:4.4",
      "pali": "Vijjā dhammo, paṭivedhaṭṭho attho."
    },
    {
      "id": "ps2.7:4.5",
      "pali": "Āloko dhammo, obhāsaṭṭho attho."
    },
    {
      "id": "ps2.7:4.6",
      "pali": "Ime pañca dhammā pañca atthā dukkhavatthukā saccavatthukā saccārammaṇā saccagocarā saccasaṅgahitā saccapariyāpannā sacce samudāgatā sacce ṭhitā sacce patiṭṭhitā."
    },
    {
      "id": "ps2.7:5.1",
      "pali": "<b>Dhammacakkan</b>ti kenaṭṭhena dhammacakkaṁ?"
    },
    {
      "id": "ps2.7:5.2",
      "pali": "Dhammañca pavatteti cakkañcāti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.3",
      "pali": "Cakkañca pavatteti dhammañcāti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.4",
      "pali": "Dhammena pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.5",
      "pali": "Dhammacariyāya pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.6",
      "pali": "Dhamme ṭhito pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.7",
      "pali": "Dhamme patiṭṭhito pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.8",
      "pali": "Dhamme patiṭṭhāpento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.9",
      "pali": "Dhamme vasippatto pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.10",
      "pali": "Dhamme vasiṁ pāpento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.11",
      "pali": "Dhamme pāramippatto pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.12",
      "pali": "Dhamme pāramiṁ pāpento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.13",
      "pali": "Dhamme vesārajjappatto pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.14",
      "pali": "Dhamme vesārajjaṁ pāpento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.15",
      "pali": "Dhammaṁ sakkaronto pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.16",
      "pali": "Dhammaṁ garuṁ karonto pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.17",
      "pali": "Dhammaṁ mānento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.18",
      "pali": "Dhammaṁ pūjento pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.19",
      "pali": "Dhammaṁ apacāyamāno pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.20",
      "pali": "Dhammaddhajo pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.21",
      "pali": "Dhammaketu pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.22",
      "pali": "Dhammādhipateyyo pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:5.23",
      "pali": "Taṁ kho pana dhammacakkaṁ appaṭivattiyaṁ samaṇena vā brāhmaṇena vā devena vā mārena vā brahmunā vā kenaci vā lokasminti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.1",
      "pali": "Saddhindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.2",
      "pali": "Vīriyindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.3",
      "pali": "Satindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.4",
      "pali": "Samādhindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.5",
      "pali": "Paññindriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.6",
      "pali": "Saddhābalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.7",
      "pali": "Vīriyabalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.8",
      "pali": "Satibalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.9",
      "pali": "Samādhibalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.10",
      "pali": "Paññābalaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.11",
      "pali": "Satisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.12",
      "pali": "Dhammavicayasambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.13",
      "pali": "Vīriyasambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.14",
      "pali": "Pītisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.15",
      "pali": "Passaddhisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.16",
      "pali": "Samādhisambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.17",
      "pali": "Upekkhāsambojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.18",
      "pali": "Sammādiṭṭhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.19",
      "pali": "Sammāsaṅkappo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.20",
      "pali": "Sammāvācā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.21",
      "pali": "Sammākammanto dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.22",
      "pali": "Sammāājīvo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.23",
      "pali": "Sammāvāyāmo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.24",
      "pali": "Sammāsati dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:6.25",
      "pali": "Sammāsamādhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.1",
      "pali": "Ādhipateyyaṭṭhena indriyaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.2",
      "pali": "Akampiyaṭṭhena balaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.3",
      "pali": "Niyyānikaṭṭhena bojjhaṅgo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.4",
      "pali": "Hetuṭṭhena maggo dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.5",
      "pali": "Upaṭṭhānaṭṭhena satipaṭṭhānā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.6",
      "pali": "Padahanaṭṭhena sammappadhānā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.7",
      "pali": "Ijjhanaṭṭhena iddhipādā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.8",
      "pali": "Tathaṭṭhena saccā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.9",
      "pali": "Avikkhepaṭṭhena samatho dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.10",
      "pali": "Anupassanaṭṭhena vipassanā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.11",
      "pali": "Ekarasaṭṭhena samathavipassanā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.12",
      "pali": "Anativattanaṭṭhena yuganaddhaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.13",
      "pali": "Saṁvaraṭṭhena sīlavisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.14",
      "pali": "Avikkhepaṭṭhena cittavisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.15",
      "pali": "Dassanaṭṭhena diṭṭhivisuddhi dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.16",
      "pali": "Muttaṭṭhena vimokkho dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.17",
      "pali": "Paṭivedhaṭṭhena vijjā dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.18",
      "pali": "Pariccāgaṭṭhena vimutti dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.19",
      "pali": "Samucchedaṭṭhena khaye ñāṇaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.20",
      "pali": "Paṭippassaddhaṭṭhena anuppāde ñāṇaṁ dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.21",
      "pali": "Chando mūlaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.22",
      "pali": "Manasikāro samuṭṭhānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.23",
      "pali": "Phasso samodhānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.24",
      "pali": "Vedanā samosaraṇaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.25",
      "pali": "Samādhi pamukhaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.26",
      "pali": "Sati ādhipateyyaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.27",
      "pali": "Paññā taduttaraṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.28",
      "pali": "Vimutti sāraṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:7.29",
      "pali": "Amatogadhaṁ nibbānaṁ pariyosānaṭṭhena dhammo taṁ dhammaṁ pavattetīti—dhammacakkaṁ."
    },
    {
      "id": "ps2.7:8.1",
      "pali": "“Taṁ kho panidaṁ dukkhaṁ ariyasaccaṁ pariññeyyan”ti …pe…"
    },
