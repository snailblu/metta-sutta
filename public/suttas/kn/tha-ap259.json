{
  "uid": "tha-ap259",
  "title": "Mañjaripūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap259:1.1",
      "pali": "“Mañjarikaṁ karitvāna,"
    },
    {
      "id": "tha-ap259:1.2",
      "pali": "rathiyaṁ paṭipajjahaṁ;"
    },
    {
      "id": "tha-ap259:1.3",
      "pali": "Addasaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap259:1.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap259:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap259:2.2",
      "pali": "paramāya ca pītiyā;"
    },
    {
      "id": "tha-ap259:2.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap259:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap259:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap259:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap259:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap259:3.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap259:4.1",
      "pali": "Ito tesattatikappe,"
    },
    {
      "id": "tha-ap259:4.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap259:4.3",
      "pali": "Jotiyo nāma nāmena,"
    },
    {
      "id": "tha-ap259:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap259:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap259:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap259:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap259:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā mañjaripūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap259:7.1",
      "pali": "Mañjaripūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
