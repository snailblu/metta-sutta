{
  "uid": "ja260",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja260:1.1",
      "pali": "“Yassatthā dūramāyanti,"
    },
    {
      "id": "ja260:1.2",
      "pali": "amittamapi yācituṁ;"
    },
    {
      "id": "ja260:1.3",
      "pali": "Tassūdarassahaṁ dūto,"
    },
    {
      "id": "ja260:1.4",
      "pali": "mā me kujjha rathesabha”."
    },
    {
      "id": "ja260:2.1",
      "pali": "“Yassa divā ca ratto ca,"
    },
    {
      "id": "ja260:2.2",
      "pali": "vasamāyanti māṇavā;"
    },
    {
      "id": "ja260:2.3",
      "pali": "Tassūdarassahaṁ dūto,"
    },
    {
      "id": "ja260:2.4",
      "pali": "mā me kujjha rathesabha."
    },
    {
      "id": "ja260:3.1",
      "pali": "Dadāmi te brāhmaṇa rohiṇīnaṁ,"
    },
    {
      "id": "ja260:3.2",
      "pali": "Gavaṁ sahassaṁ saha puṅgavena;"
    },
    {
      "id": "ja260:3.3",
      "pali": "Dūto hi dūtassa kathaṁ na dajjaṁ,"
    },
    {
      "id": "ja260:3.4",
      "pali": "Mayampi tasseva bhavāma dūtā”ti."
    },
    {
      "id": "ja260:4.1",
      "pali": "Dūtajātakaṁ dasamaṁ."
    },
    {
      "id": "ja260:4.2",
      "pali": "Saṅkappavaggo paṭhamo."
    },
    {
      "id": "ja260:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja260:6.1",
      "pali": "Usukāravaro tilamuṭṭhi maṇi,"
    },
    {
      "id": "ja260:6.2",
      "pali": "Hayarāja vihaṅgama āsiviso;"
    },
    {
      "id": "ja260:6.3",
      "pali": "Janasandha kahāpaṇavassa puna,"
    },
    {
      "id": "ja260:6.4",
      "pali": "Tiriṭaṁ puna dūtavarena dasāti."
    }
  ]
}
