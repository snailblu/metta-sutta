{
  "uid": "ja314",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja314:1.1",
      "pali": "“Dujjīvitamajīvimha,"
    },
    {
      "id": "ja314:1.2",
      "pali": "ye sante na dadamhase;"
    },
    {
      "id": "ja314:1.3",
      "pali": "Vijjamānesu bhogesu,"
    },
    {
      "id": "ja314:1.4",
      "pali": "dīpaṁ nākamha attano”."
    },
    {
      "id": "ja314:2.1",
      "pali": "“Saṭṭhi vassasahassāni,"
    },
    {
      "id": "ja314:2.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "ja314:2.3",
      "pali": "Niraye paccamānānaṁ,"
    },
    {
      "id": "ja314:2.4",
      "pali": "kadā anto bhavissati”."
    },
    {
      "id": "ja314:3.1",
      "pali": "“Natthi anto kuto anto,"
    },
    {
      "id": "ja314:3.2",
      "pali": "na anto paṭidissati;"
    },
    {
      "id": "ja314:3.3",
      "pali": "Tadā hi pakataṁ pāpaṁ,"
    },
    {
      "id": "ja314:3.4",
      "pali": "mama tuyhañca mārisā”."
    },
    {
      "id": "ja314:4.1",
      "pali": "“Sohaṁ nūna ito gantvā,"
    },
    {
      "id": "ja314:4.2",
      "pali": "yoniṁ laddhāna mānusiṁ;"
    },
    {
      "id": "ja314:4.3",
      "pali": "Vadaññū sīlasampanno,"
    },
    {
      "id": "ja314:4.4",
      "pali": "kāhāmi kusalaṁ bahun”ti."
    },
    {
      "id": "ja314:5.1",
      "pali": "Lohakumbhijātakaṁ catutthaṁ."
    }
  ]
}
