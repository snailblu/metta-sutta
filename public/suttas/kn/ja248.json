{
  "uid": "ja248",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja248:1.1",
      "pali": "“Sabbehi kiṁsuko diṭṭho,"
    },
    {
      "id": "ja248:1.2",
      "pali": "kinnvettha vicikicchatha;"
    },
    {
      "id": "ja248:1.3",
      "pali": "Na hi sabbesu ṭhānesu,"
    },
    {
      "id": "ja248:1.4",
      "pali": "sārathī paripucchito”."
    },
    {
      "id": "ja248:2.1",
      "pali": "“Evaṁ sabbehi ñāṇehi,"
    },
    {
      "id": "ja248:2.2",
      "pali": "yesaṁ dhammā ajānitā;"
    },
    {
      "id": "ja248:2.3",
      "pali": "Te ve dhammesu kaṅkhanti,"
    },
    {
      "id": "ja248:2.4",
      "pali": "kiṁsukasmiṁva bhātaro”ti."
    },
    {
      "id": "ja248:3.1",
      "pali": "Kiṁsukopamajātakaṁ aṭṭhamaṁ."
    }
  ]
}
