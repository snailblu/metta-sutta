{
  "uid": "ud5.10",
  "title": "Cūḷapanthakasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud5.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud5.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud5.10:1.3",
      "pali": "Tena kho pana samayena āyasmā cūḷapanthako bhagavato avidūre nisinno hoti pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā."
    },
    {
      "id": "ud5.10:2.1",
      "pali": "Addasā kho bhagavā āyasmantaṁ cūḷapanthakaṁ avidūre nisinnaṁ pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā."
    },
    {
      "id": "ud5.10:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud5.10:4.1",
      "pali": "“Ṭhitena kāyena ṭhitena cetasā,"
    },
    {
      "id": "ud5.10:4.2",
      "pali": "Tiṭṭhaṁ nisinno uda vā sayāno;"
    },
    {
      "id": "ud5.10:4.3",
      "pali": "Etaṁ satiṁ bhikkhu adhiṭṭhahāno,"
    },
    {
      "id": "ud5.10:4.4",
      "pali": "Labhetha pubbāpariyaṁ visesaṁ;"
    },
    {
      "id": "ud5.10:4.5",
      "pali": "Laddhāna pubbāpariyaṁ visesaṁ,"
    },
    {
      "id": "ud5.10:4.6",
      "pali": "Adassanaṁ maccurājassa gacche”ti."
    },
    {
      "id": "ud5.10:4.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "ud5.10:4.8",
      "pali": "Soṇavaggo pañcamo."
    },
    {
      "id": "ud5.10:5.1",
      "pali": "Piyo appāyukā kuṭṭhī,"
    },
    {
      "id": "ud5.10:5.2",
      "pali": "kumārakā uposatho;"
    },
    {
      "id": "ud5.10:5.3",
      "pali": "Soṇo ca revato bhedo,"
    },
    {
      "id": "ud5.10:5.4",
      "pali": "sadhāya panthakena cāti."
    }
  ]
}
