{
  "uid": "tha-ap34",
  "title": "Sāgatattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap34:1.1",
      "pali": "“Sobhito nāma nāmena,"
    },
    {
      "id": "tha-ap34:1.2",
      "pali": "ahosiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap34:1.3",
      "pali": "Purakkhato sasissehi,"
    },
    {
      "id": "tha-ap34:1.4",
      "pali": "ārāmaṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap34:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap34:2.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap34:2.3",
      "pali": "Ārāmadvārā nikkhamma,"
    },
    {
      "id": "tha-ap34:2.4",
      "pali": "aṭṭhāsi purisuttamo."
    },
    {
      "id": "tha-ap34:3.1",
      "pali": "Tamaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap34:3.2",
      "pali": "dantaṁ dantapurakkhataṁ;"
    },
    {
      "id": "tha-ap34:3.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap34:3.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap34:4.1",
      "pali": "Ye keci pādapā sabbe,"
    },
    {
      "id": "tha-ap34:4.2",
      "pali": "mahiyā te virūhare;"
    },
    {
      "id": "tha-ap34:4.3",
      "pali": "Buddhimanto tathā sattā,"
    },
    {
      "id": "tha-ap34:4.4",
      "pali": "ruhanti jinasāsane."
    },
    {
      "id": "tha-ap34:5.1",
      "pali": "Satthavāhosi sappañño,"
    },
    {
      "id": "tha-ap34:5.2",
      "pali": "mahesi bahuke jane;"
    },
    {
      "id": "tha-ap34:5.3",
      "pali": "Vipathā uddharitvāna,"
    },
    {
      "id": "tha-ap34:5.4",
      "pali": "pathaṁ ācikkhase tuvaṁ."
    },
    {
      "id": "tha-ap34:6.1",
      "pali": "Danto dantaparikiṇṇo,"
    },
    {
      "id": "tha-ap34:6.2",
      "pali": "jhāyī jhānaratehi ca;"
    },
    {
      "id": "tha-ap34:6.3",
      "pali": "Ātāpī pahitattehi,"
    },
    {
      "id": "tha-ap34:6.4",
      "pali": "upasantehi tādibhi."
    },
    {
      "id": "tha-ap34:7.1",
      "pali": "Alaṅkato parisāhi,"
    },
    {
      "id": "tha-ap34:7.2",
      "pali": "puññañāṇehi sobhati;"
    },
    {
      "id": "tha-ap34:7.3",
      "pali": "Pabhā niddhāvate tuyhaṁ,"
    },
    {
      "id": "tha-ap34:7.4",
      "pali": "sūriyodayane yathā."
    },
    {
      "id": "tha-ap34:8.1",
      "pali": "Pasannacittaṁ disvāna,"
    },
    {
      "id": "tha-ap34:8.2",
      "pali": "mahesī padumuttaro;"
    },
    {
      "id": "tha-ap34:8.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap34:8.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap34:9.1",
      "pali": "‘Yo so hāsaṁ janetvāna,"
    },
    {
      "id": "tha-ap34:9.2",
      "pali": "mamaṁ kittesi brāhmaṇo;"
    },
    {
      "id": "tha-ap34:9.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap34:9.4",
      "pali": "devaloke ramissati."
    },
    {
      "id": "tha-ap34:10.1",
      "pali": "Tusitā hi cavitvāna,"
    },
    {
      "id": "tha-ap34:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap34:10.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap34:10.4",
      "pali": "sāsane pabbajissati."
    },
    {
      "id": "tha-ap34:11.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap34:11.2",
      "pali": "arahattaṁ labhissati;"
    },
    {
      "id": "tha-ap34:11.3",
      "pali": "Sāgato nāma nāmena,"
    },
    {
      "id": "tha-ap34:11.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap34:12.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "tha-ap34:12.2",
      "pali": "pāpakammaṁ vivajjayiṁ;"
    },
    {
      "id": "tha-ap34:12.3",
      "pali": "Vacīduccaritaṁ hitvā,"
    },
    {
      "id": "tha-ap34:12.4",
      "pali": "ājīvaṁ parisodhayiṁ."
    },
    {
      "id": "tha-ap34:13.1",
      "pali": "Evaṁ viharamānohaṁ,"
    },
    {
      "id": "tha-ap34:13.2",
      "pali": "tejodhātūsu kovido;"
    },
    {
      "id": "tha-ap34:13.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap34:13.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap34:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap34:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap34:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap34:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā sāgato thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap34:16.1",
      "pali": "Sāgatattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
