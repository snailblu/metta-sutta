{
  "uid": "bv6",
  "title": "6. Sumanabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv6:1.1",
      "pali": "“Maṅgalassa aparena,"
    },
    {
      "id": "bv6:1.2",
      "pali": "sumano nāma nāyako;"
    },
    {
      "id": "bv6:1.3",
      "pali": "Sabbadhammehi asamo,"
    },
    {
      "id": "bv6:1.4",
      "pali": "sabbasattānamuttamo."
    },
    {
      "id": "bv6:2.1",
      "pali": "Tadā amatabheriṁ so,"
    },
    {
      "id": "bv6:2.2",
      "pali": "āhanī mekhale pure;"
    },
    {
      "id": "bv6:2.3",
      "pali": "Dhammasaṅkhasamāyuttaṁ,"
    },
    {
      "id": "bv6:2.4",
      "pali": "navaṅgaṁ jinasāsanaṁ."
    },
    {
      "id": "bv6:3.1",
      "pali": "Nijjinitvā kilese so,"
    },
    {
      "id": "bv6:3.2",
      "pali": "patvā sambodhimuttamaṁ;"
    },
    {
      "id": "bv6:3.3",
      "pali": "Māpesi nagaraṁ satthā,"
    },
    {
      "id": "bv6:3.4",
      "pali": "saddhammapuravaruttamaṁ."
    },
    {
      "id": "bv6:4.1",
      "pali": "Nirantaraṁ akuṭilaṁ,"
    },
    {
      "id": "bv6:4.2",
      "pali": "ujuṁ vipulavitthataṁ;"
    },
    {
      "id": "bv6:4.3",
      "pali": "Māpesi so mahāvīthiṁ,"
    },
    {
      "id": "bv6:4.4",
      "pali": "satipaṭṭhānavaruttamaṁ."
    },
    {
      "id": "bv6:5.1",
      "pali": "Phale cattāri sāmaññe,"
    },
    {
      "id": "bv6:5.2",
      "pali": "catasso paṭisambhidā;"
    },
    {
      "id": "bv6:5.3",
      "pali": "Chaḷabhiññāṭṭhasamāpattī,"
    },
    {
      "id": "bv6:5.4",
      "pali": "pasāresi tattha vīthiyaṁ."
    },
    {
      "id": "bv6:6.1",
      "pali": "Ye appamattā akhilā,"
    },
    {
      "id": "bv6:6.2",
      "pali": "hirivīriyehupāgatā;"
    },
    {
      "id": "bv6:6.3",
      "pali": "Te te ime guṇavare,"
    },
    {
      "id": "bv6:6.4",
      "pali": "ādiyanti yathā sukhaṁ."
    },
    {
      "id": "bv6:7.1",
      "pali": "Evametena yogena,"
    },
    {
      "id": "bv6:7.2",
      "pali": "uddharanto mahājanaṁ;"
    },
    {
      "id": "bv6:7.3",
      "pali": "Bodhesi paṭhamaṁ satthā,"
    },
    {
      "id": "bv6:7.4",
      "pali": "koṭisatasahassiyo."
    },
    {
      "id": "bv6:8.1",
      "pali": "Yamhi kāle mahāvīro,"
    },
    {
      "id": "bv6:8.2",
      "pali": "ovadī titthiye gaṇe;"
    },
    {
      "id": "bv6:8.3",
      "pali": "Koṭisahassābhisamiṁsu,"
    },
    {
      "id": "bv6:8.4",
      "pali": "dutiye dhammadesane."
    },
    {
      "id": "bv6:9.1",
      "pali": "Yadā devā manussā ca,"
    },
    {
      "id": "bv6:9.2",
      "pali": "samaggā ekamānasā;"
    },
    {
      "id": "bv6:9.3",
      "pali": "Nirodhapañhaṁ pucchiṁsu,"
    },
    {
      "id": "bv6:9.4",
      "pali": "saṁsayañcāpi mānasaṁ."
    },
    {
      "id": "bv6:10.1",
      "pali": "Tadāpi dhammadesane,"
    },
    {
      "id": "bv6:10.2",
      "pali": "nirodhaparidīpane;"
    },
    {
      "id": "bv6:10.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv6:10.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv6:11.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv6:11.2",
      "pali": "sumanassa mahesino;"
    },
    {
      "id": "bv6:11.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv6:11.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv6:12.1",
      "pali": "Vassaṁvutthassa bhagavato,"
    },
    {
      "id": "bv6:12.2",
      "pali": "abhighuṭṭhe pavāraṇe;"
    },
    {
      "id": "bv6:12.3",
      "pali": "Koṭisatasahassehi,"
    },
    {
      "id": "bv6:12.4",
      "pali": "pavāresi tathāgato."
    },
    {
      "id": "bv6:13.1",
      "pali": "Tatoparaṁ sannipāte,"
    },
    {
      "id": "bv6:13.2",
      "pali": "vimale kañcanapabbate;"
    },
    {
      "id": "bv6:13.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv6:13.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv6:14.1",
      "pali": "Yadā sakko devarājā,"
    },
    {
      "id": "bv6:14.2",
      "pali": "buddhadassanupāgami;"
    },
    {
      "id": "bv6:14.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv6:14.4",
      "pali": "tatiyo āsi samāgamo."
    },
    {
      "id": "bv6:15.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv6:15.2",
      "pali": "nāgarājā mahiddhiko;"
    },
    {
      "id": "bv6:15.3",
      "pali": "Atulo nāma nāmena,"
    },
    {
      "id": "bv6:15.4",
      "pali": "ussannakusalasañcayo."
    },
    {
      "id": "bv6:16.1",
      "pali": "Tadāhaṁ nāgabhavanā,"
    },
    {
      "id": "bv6:16.2",
      "pali": "nikkhamitvā sañātibhi;"
    },
    {
      "id": "bv6:16.3",
      "pali": "Nāgānaṁ dibbaturiyehi,"
    },
    {
      "id": "bv6:16.4",
      "pali": "sasaṅghaṁ jinamupaṭṭhahiṁ."
    },
    {
      "id": "bv6:17.1",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv6:17.2",
      "pali": "annapānena tappayiṁ;"
    },
    {
      "id": "bv6:17.3",
      "pali": "Paccekadussayugaṁ datvā,"
    },
    {
      "id": "bv6:17.4",
      "pali": "saraṇaṁ tamupāgamiṁ."
    },
    {
      "id": "bv6:18.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv6:18.2",
      "pali": "sumano lokanāyako;"
    },
    {
      "id": "bv6:18.3",
      "pali": "‘Aparimeyyito kappe,"
    },
    {
      "id": "bv6:18.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv6:19.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv6:19.2",
      "pali": "…pe…"
    },
    {
      "id": "bv6:19.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv6:20.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv6:20.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv6:20.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv6:20.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv6:21.1",
      "pali": "Nagaraṁ mekhalaṁ nāma,"
    },
    {
      "id": "bv6:21.2",
      "pali": "sudatto nāma khattiyo;"
    },
    {
      "id": "bv6:21.3",
      "pali": "Sirimā nāma janikā,"
    },
    {
      "id": "bv6:21.4",
      "pali": "sumanassa mahesino."
    },
    {
      "id": "bv6:22.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv6:22.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv6:22.3",
      "pali": "Cando sucando vaṭaṁso ca,"
    },
    {
      "id": "bv6:22.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv6:23.1",
      "pali": "Tesaṭṭhisatasahassāni,"
    },
    {
      "id": "bv6:23.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv6:23.3",
      "pali": "Vaṭaṁsikā nāma nārī,"
    },
    {
      "id": "bv6:23.4",
      "pali": "anūpamo nāma atrajo."
    },
    {
      "id": "bv6:24.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv6:24.2",
      "pali": "hatthiyānena nikkhami;"
    },
    {
      "id": "bv6:24.3",
      "pali": "Anūnadasamāsāni,"
    },
    {
      "id": "bv6:24.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv6:25.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv6:25.2",
      "pali": "sumano lokanāyako;"
    },
    {
      "id": "bv6:25.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv6:25.4",
      "pali": "mekhale puramuttame."
    },
    {
      "id": "bv6:26.1",
      "pali": "Saraṇo bhāvitatto ca,"
    },
    {
      "id": "bv6:26.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv6:26.3",
      "pali": "Udeno nāmupaṭṭhāko,"
    },
    {
      "id": "bv6:26.4",
      "pali": "sumanassa mahesino."
    },
    {
      "id": "bv6:27.1",
      "pali": "Soṇā ca upasoṇā ca,"
    },
    {
      "id": "bv6:27.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv6:27.3",
      "pali": "Sopi buddho amitayaso,"
    },
    {
      "id": "bv6:27.4",
      "pali": "nāgamūle abujjhatha."
    },
    {
      "id": "bv6:28.1",
      "pali": "Varuṇo ceva saraṇo ca,"
    },
    {
      "id": "bv6:28.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv6:28.3",
      "pali": "Cālā ca upacālā ca,"
    },
    {
      "id": "bv6:28.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv6:29.1",
      "pali": "Uccattanena so buddho,"
    },
    {
      "id": "bv6:29.2",
      "pali": "navutihatthamuggato;"
    },
    {
      "id": "bv6:29.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "bv6:29.4",
      "pali": "dasasahassī virocati."
    },
    {
      "id": "bv6:30.1",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv6:30.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv6:30.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv6:30.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv6:31.1",
      "pali": "Tāraṇīye tārayitvā,"
    },
    {
      "id": "bv6:31.2",
      "pali": "bodhanīye ca bodhayi;"
    },
    {
      "id": "bv6:31.3",
      "pali": "Parinibbāyi sambuddho,"
    },
    {
      "id": "bv6:31.4",
      "pali": "uḷurājāva atthami."
    },
    {
      "id": "bv6:32.1",
      "pali": "Te ca khīṇāsavā bhikkhū,"
    },
    {
      "id": "bv6:32.2",
      "pali": "so ca buddho asādiso;"
    },
    {
      "id": "bv6:32.3",
      "pali": "Atulappabhaṁ dassayitvā,"
    },
    {
      "id": "bv6:32.4",
      "pali": "nibbutā ye mahāyasā."
    },
    {
      "id": "bv6:33.1",
      "pali": "Tañca ñāṇaṁ atuliyaṁ,"
    },
    {
      "id": "bv6:33.2",
      "pali": "Tāni ca atulāni ratanāni;"
    },
    {
      "id": "bv6:33.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv6:33.4",
      "pali": "Nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv6:34.1",
      "pali": "Sumano yasadharo buddho,"
    },
    {
      "id": "bv6:34.2",
      "pali": "Aṅgārāmamhi nibbuto;"
    },
    {
      "id": "bv6:34.3",
      "pali": "Tattheva tassa jinathūpo,"
    },
    {
      "id": "bv6:34.4",
      "pali": "Catuyojanamuggato”ti."
    },
    {
      "id": "bv6:35.1",
      "pali": "Sumanassa bhagavato vaṁso catuttho."
    }
  ]
}
