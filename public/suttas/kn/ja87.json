{
  "uid": "ja87",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja87:1.1",
      "pali": "“Yassa maṅgalā samūhatāse,"
    },
    {
      "id": "ja87:1.2",
      "pali": "Uppātā supinā ca lakkhaṇā ca;"
    },
    {
      "id": "ja87:1.3",
      "pali": "So maṅgaladosavītivatto,"
    },
    {
      "id": "ja87:1.4",
      "pali": "Yugayogādhigato na jātumetī”ti."
    },
    {
      "id": "ja87:2.1",
      "pali": "Maṅgalajātakaṁ sattamaṁ."
    }
  ]
}
