{
  "uid": "ja497",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja497:1.1",
      "pali": "“Kuto nu āgacchasi dummavāsī,"
    },
    {
      "id": "ja497:1.2",
      "pali": "Otallako paṁsupisācakova;"
    },
    {
      "id": "ja497:1.3",
      "pali": "Saṅkāracoḷaṁ paṭimuñca kaṇṭhe,"
    },
    {
      "id": "ja497:1.4",
      "pali": "Ko re tuvaṁ hosi adakkhiṇeyyo”."
    },
    {
      "id": "ja497:2.1",
      "pali": "“Annaṁ tavedaṁ pakataṁ yasassi,"
    },
    {
      "id": "ja497:2.2",
      "pali": "Taṁ khajjare bhuñjare piyyare ca;"
    },
    {
      "id": "ja497:2.3",
      "pali": "Jānāsi maṁ tvaṁ paradattūpajīviṁ,"
    },
    {
      "id": "ja497:2.4",
      "pali": "Uttiṭṭhapiṇḍaṁ labhataṁ sapāko”."
    },
    {
      "id": "ja497:3.1",
      "pali": "“Annaṁ mamedaṁ pakataṁ brāhmaṇānaṁ,"
    },
    {
      "id": "ja497:3.2",
      "pali": "Attatthāya saddahato mamedaṁ;"
    },
    {
      "id": "ja497:3.3",
      "pali": "Apehi etto kimidhaṭṭhitosi,"
    },
    {
      "id": "ja497:3.4",
      "pali": "Na mādisā tuyhaṁ dadanti jamma”."
    },
    {
      "id": "ja497:4.1",
      "pali": "“Thale ca ninne ca vapanti bījaṁ,"
    },
    {
      "id": "ja497:4.2",
      "pali": "Anūpakhette phalamāsamānā;"
    },
    {
      "id": "ja497:4.3",
      "pali": "Etāya saddhāya dadāhi dānaṁ,"
    },
    {
      "id": "ja497:4.4",
      "pali": "Appeva ārādhaye dakkhiṇeyye”."
    },
    {
      "id": "ja497:5.1",
      "pali": "“Khettāni mayhaṁ viditāni loke,"
    },
    {
      "id": "ja497:5.2",
      "pali": "Yesāhaṁ bījāni patiṭṭhapemi;"
    },
    {
      "id": "ja497:5.3",
      "pali": "Ye brāhmaṇā jātimantūpapannā,"
    },
    {
      "id": "ja497:5.4",
      "pali": "Tānīdha khettāni supesalāni”."
    },
    {
      "id": "ja497:6.1",
      "pali": "“Jātimado ca atimānitā ca,"
    },
    {
      "id": "ja497:6.2",
      "pali": "Lobho ca doso ca mado ca moho;"
    },
    {
      "id": "ja497:6.3",
      "pali": "Ete aguṇā yesu ca santi sabbe,"
    },
    {
      "id": "ja497:6.4",
      "pali": "Tānīdha khettāni apesalāni."
    },
    {
      "id": "ja497:7.1",
      "pali": "Jātimado ca atimānitā ca,"
    },
    {
      "id": "ja497:7.2",
      "pali": "Lobho ca doso ca mado ca moho;"
    },
    {
      "id": "ja497:7.3",
      "pali": "Ete aguṇā yesu na santi sabbe,"
    },
    {
      "id": "ja497:7.4",
      "pali": "Tānīdha khettāni supesalāni”."
    },
    {
      "id": "ja497:8.1",
      "pali": "“Kvettha gatā upajotiyo ca,"
    },
    {
      "id": "ja497:8.2",
      "pali": "Upajjhāyo ca atha vā gaṇḍakucchi;"
    },
    {
      "id": "ja497:8.3",
      "pali": "Imassa daṇḍañca vadhañca datvā,"
    },
    {
      "id": "ja497:8.4",
      "pali": "Gale gahetvā khalayātha jammaṁ”."
    },
    {
      "id": "ja497:9.1",
      "pali": "“Giriṁ nakhena khaṇasi,"
    },
    {
      "id": "ja497:9.2",
      "pali": "ayo dantehi khādasi;"
    },
    {
      "id": "ja497:9.3",
      "pali": "Jātavedaṁ padahasi,"
    },
    {
      "id": "ja497:9.4",
      "pali": "yo isiṁ paribhāsasi”."
    },
    {
      "id": "ja497:10.1",
      "pali": "“Idaṁ vatvāna mātaṅgo,"
    },
    {
      "id": "ja497:10.2",
      "pali": "isi saccaparakkamo;"
    },
    {
      "id": "ja497:10.3",
      "pali": "Antalikkhasmiṁ pakkāmi,"
    },
    {
      "id": "ja497:10.4",
      "pali": "brāhmaṇānaṁ udikkhataṁ”."
    },
    {
      "id": "ja497:11.1",
      "pali": "“Āvellitaṁ piṭṭhito uttamaṅgaṁ,"
    },
    {
      "id": "ja497:11.2",
      "pali": "Bāhuṁ pasāreti akammaneyyaṁ;"
    },
    {
      "id": "ja497:11.3",
      "pali": "Setāni akkhīni yathā matassa,"
    },
    {
      "id": "ja497:11.4",
      "pali": "Ko me imaṁ puttamakāsi evaṁ”."
    },
    {
      "id": "ja497:12.1",
      "pali": "“Idhāgamā samaṇo dummavāsī,"
    },
    {
      "id": "ja497:12.2",
      "pali": "Otallako paṁsupisācakova;"
    },
    {
      "id": "ja497:12.3",
      "pali": "Saṅkāracoḷaṁ paṭimuñca kaṇṭhe,"
    },
    {
      "id": "ja497:12.4",
      "pali": "So te imaṁ puttamakāsi evaṁ”."
    },
    {
      "id": "ja497:13.1",
      "pali": "“Katamaṁ disaṁ agamā bhūripañño,"
    },
    {
      "id": "ja497:13.2",
      "pali": "Akkhātha me māṇavā etamatthaṁ;"
    },
    {
      "id": "ja497:13.3",
      "pali": "Gantvāna taṁ paṭikaremu accayaṁ,"
    },
    {
      "id": "ja497:13.4",
      "pali": "Appeva naṁ putta labhemu jīvitaṁ”."
    },
    {
      "id": "ja497:14.1",
      "pali": "“Vehāyasaṁ agamā bhūripañño,"
    },
    {
      "id": "ja497:14.2",
      "pali": "Pathaddhuno pannaraseva cando;"
    },
    {
      "id": "ja497:14.3",
      "pali": "Api cāpi so purimadisaṁ agacchi,"
    },
    {
      "id": "ja497:14.4",
      "pali": "Saccappaṭiñño isi sādhurūpo”."
    },
    {
      "id": "ja497:15.1",
      "pali": "“Āvellitaṁ piṭṭhito uttamaṅgaṁ,"
    },
    {
      "id": "ja497:15.2",
      "pali": "Bāhuṁ pasāreti akammaneyyaṁ;"
    },
    {
      "id": "ja497:15.3",
      "pali": "Setāni akkhīni yathā matassa,"
    },
    {
      "id": "ja497:15.4",
      "pali": "Ko me imaṁ puttamakāsi evaṁ”."
    },
    {
      "id": "ja497:16.1",
      "pali": "“Yakkhā have santi mahānubhāvā,"
    },
    {
      "id": "ja497:16.2",
      "pali": "Anvāgatā isayo sādhurūpā;"
    },
    {
      "id": "ja497:16.3",
      "pali": "Te duṭṭhacittaṁ kupitaṁ viditvā,"
    },
    {
      "id": "ja497:16.4",
      "pali": "Yakkhā hi te puttamakaṁsu evaṁ”."
    },
    {
      "id": "ja497:17.1",
      "pali": "“Yakkhā ca me puttamakaṁsu evaṁ,"
    },
    {
      "id": "ja497:17.2",
      "pali": "Tvaññeva me mā kuddho brahmacāri;"
    },
    {
      "id": "ja497:17.3",
      "pali": "Tumheva pāde saraṇaṁ gatāsmi,"
    },
    {
      "id": "ja497:17.4",
      "pali": "Anvāgatā puttasokena bhikkhu”."
    },
    {
      "id": "ja497:18.1",
      "pali": "“Tadeva hi etarahi ca mayhaṁ,"
    },
    {
      "id": "ja497:18.2",
      "pali": "Manopadoso na mamatthi koci;"
    },
    {
      "id": "ja497:18.3",
      "pali": "Putto ca te vedamadena matto,"
    },
    {
      "id": "ja497:18.4",
      "pali": "Atthaṁ na jānāti adhicca vede”."
    },
    {
      "id": "ja497:19.1",
      "pali": "“Addhā have bhikkhu muhuttakena,"
    },
    {
      "id": "ja497:19.2",
      "pali": "Sammuyhateva purisassa saññā;"
    },
    {
      "id": "ja497:19.3",
      "pali": "Ekāparādhaṁ khama bhūripañña,"
    },
    {
      "id": "ja497:19.4",
      "pali": "Na paṇḍitā kodhabalā bhavanti”."
    },
    {
      "id": "ja497:20.1",
      "pali": "“Idañca mayhaṁ uttiṭṭhapiṇḍaṁ,"
    },
    {
      "id": "ja497:20.2",
      "pali": "Tava maṇḍabyo bhuñjatu appapañño;"
    },
    {
      "id": "ja497:20.3",
      "pali": "Yakkhā ca te naṁ na viheṭhayeyyuṁ,"
    },
    {
      "id": "ja497:20.4",
      "pali": "Putto ca te hessati so arogo”."
    },
    {
      "id": "ja497:21.1",
      "pali": "“Maṇḍabya bālosi parittapañño,"
    },
    {
      "id": "ja497:21.2",
      "pali": "Yo puññakhettānamakovidosi;"
    },
    {
      "id": "ja497:21.3",
      "pali": "Mahakkasāvesu dadāsi dānaṁ,"
    },
    {
      "id": "ja497:21.4",
      "pali": "Kiliṭṭhakammesu asaññatesu."
    },
    {
      "id": "ja497:22.1",
      "pali": "Jaṭā ca kesā ajinā nivatthā,"
    },
    {
      "id": "ja497:22.2",
      "pali": "Jarūdapānaṁva mukhaṁ parūḷhaṁ;"
    },
    {
      "id": "ja497:22.3",
      "pali": "Pajaṁ imaṁ passatha dummarūpaṁ,"
    },
    {
      "id": "ja497:22.4",
      "pali": "Na jaṭājinaṁ tāyati appapaññaṁ."
    },
    {
      "id": "ja497:23.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "ja497:23.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "ja497:23.3",
      "pali": "Khīṇāsavā arahanto,"
    },
    {
      "id": "ja497:23.4",
      "pali": "tesu dinnaṁ mahapphalan”ti."
    },
    {
      "id": "ja497:24.1",
      "pali": "Mātaṅgajātakaṁ paṭhamaṁ."
    }
  ]
}
