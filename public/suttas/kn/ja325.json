{
  "uid": "ja325",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja325:1.1",
      "pali": "“Samaṇaṁ taṁ maññamāno,"
    },
    {
      "id": "ja325:1.2",
      "pali": "upagacchimasaññataṁ;"
    },
    {
      "id": "ja325:1.3",
      "pali": "So maṁ daṇḍena pāhāsi,"
    },
    {
      "id": "ja325:1.4",
      "pali": "yathā assamaṇo tathā”."
    },
    {
      "id": "ja325:2.1",
      "pali": "“Kiṁ te jaṭāhi dummedha,"
    },
    {
      "id": "ja325:2.2",
      "pali": "kiṁ te ajinasāṭiyā;"
    },
    {
      "id": "ja325:2.3",
      "pali": "Abbhantaraṁ te gahanaṁ,"
    },
    {
      "id": "ja325:2.4",
      "pali": "bāhiraṁ parimajjasi”."
    },
    {
      "id": "ja325:3.1",
      "pali": "“Ehi godha nivattassu,"
    },
    {
      "id": "ja325:3.2",
      "pali": "bhuñja sālīnamodanaṁ;"
    },
    {
      "id": "ja325:3.3",
      "pali": "Telaṁ loṇañca me atthi,"
    },
    {
      "id": "ja325:3.4",
      "pali": "pahūtaṁ mayha pipphali."
    },
    {
      "id": "ja325:4.1",
      "pali": "Esa bhiyyo pavekkhāmi,"
    },
    {
      "id": "ja325:4.2",
      "pali": "vammikaṁ sataporisaṁ;"
    },
    {
      "id": "ja325:4.3",
      "pali": "Telaṁ loṇañca kittesi,"
    },
    {
      "id": "ja325:4.4",
      "pali": "ahitaṁ mayha pipphalī”ti."
    },
    {
      "id": "ja325:5.1",
      "pali": "Godharājajātakaṁ pañcamaṁ."
    }
  ]
}
