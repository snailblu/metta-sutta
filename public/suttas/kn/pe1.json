{
  "uid": "pe1",
  "title": "1. Ariyasaccappakāsanapaṭhamabhūmi",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pe1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "pe1:2.1",
      "pali": "Namo sammāsambuddhānaṁ paramatthadassīnaṁ sīlādiguṇapāramippattānaṁ."
    },
    {
      "id": "pe1:3.1",
      "pali": "Duve hetū duve paccayā sāvakassa sammādiṭṭhiyā uppādāya—"
    },
    {
      "id": "pe1:3.2",
      "pali": "parato ca ghoso saccānusandhi, ajjhattañca yoniso manasikāro."
    },
    {
      "id": "pe1:3.3",
      "pali": "Tattha katamo parato ghoso?"
    },
    {
      "id": "pe1:3.4",
      "pali": "Yā parato desanā ovādo anusāsanī saccakathā saccānulomo."
    },
    {
      "id": "pe1:3.5",
      "pali": "Cattāri saccāni—"
    },
    {
      "id": "pe1:3.6",
      "pali": "dukkhaṁ samudayo nirodho maggo."
    },
    {
      "id": "pe1:3.7",
      "pali": "Imesaṁ catunnaṁ saccānaṁ yā desanā sandassanā vivaraṇā vibhajanā uttānīkiriyā pakāsanā—"
    },
    {
      "id": "pe1:3.8",
      "pali": "ayaṁ vuccati saccānulomo ghosoti."
    },
    {
      "id": "pe1:4.1",
      "pali": "Tattha katamo ajjhattaṁ yoniso manasikāro?"
    },
    {
      "id": "pe1:5.1",
      "pali": "Ajjhattaṁ yoniso manasikāro nāma yo yathādesite dhamme bahiddhā ārammaṇaṁ anabhinīharitvā yoniso manasikāro—"
    },
    {
      "id": "pe1:5.2",
      "pali": "ayaṁ vuccati yoniso manasikāro."
    },
    {
      "id": "pe1:6.1",
      "pali": "Taṁākāro yoniso dvāro vidhi upāyo."
    },
    {
      "id": "pe1:6.2",
      "pali": "Yathā puriso sukkhe kaṭṭhe vigatasnehe sukkhāya uttarāraṇiyā thale abhimanthamānaṁ bhabbo jotissa adhigamāya."
    },
    {
      "id": "pe1:6.3",
      "pali": "Taṁ kissa hetu."
    },
    {
      "id": "pe1:6.4",
      "pali": "Yoniso aggissa adhigamāya."
    },
    {
      "id": "pe1:6.5",
      "pali": "Evamevassa yamidaṁ dukkhasamudayanirodhamaggānaṁ aviparītadhammadesanaṁ manasikaroti—"
    },
    {
      "id": "pe1:6.6",
      "pali": "ayaṁ vuccati yoniso manasikāro."
    },
    {
      "id": "pe1:7.1",
      "pali": "Yathā tisso upamā pubbe assutā ca assutapubbā ca paṭibhanti."
    },
    {
      "id": "pe1:7.2",
      "pali": "Yo hi koci kāmesu avītarāgoti …pe…"
    },
    {
      "id": "pe1:7.3",
      "pali": "duve upamā ayoniso kātabbā pacchimesu vuttaṁ."
    },
    {
      "id": "pe1:7.4",
      "pali": "Tattha yo ca parato ghoso yo ca ajjhattaṁ yoniso manasikāro—"
    },
    {
      "id": "pe1:7.5",
      "pali": "ime dve paccayā."
    },
    {
      "id": "pe1:7.6",
      "pali": "Parato ghosena yā uppajjati paññā—"
    },
    {
      "id": "pe1:7.7",
      "pali": "ayaṁ vuccati sutamayī paññā."
    },
    {
      "id": "pe1:7.8",
      "pali": "Yā ajjhattaṁ yoniso manasikārena uppajjati paññā—"
    },
    {
      "id": "pe1:7.9",
      "pali": "ayaṁ vuccati cintāmayī paññāti."
    },
    {
      "id": "pe1:7.10",
      "pali": "Imā dve paññā veditabbā."
    },
    {
      "id": "pe1:7.11",
      "pali": "Purimakā ca dve paccayā."
    },
    {
      "id": "pe1:7.12",
      "pali": "Ime dve hetū dve paccayā sāvakassa sammādiṭṭhiyā uppādāya."
    },
    {
      "id": "pe1:8.1",
      "pali": "Tattha parato ghosassa saccānusandhissa desitassa atthaṁ avijānanto atthappaṭisaṁvedī bhavissatīti netaṁ ṭhānaṁ vijjati."
    },
    {
      "id": "pe1:8.2",
      "pali": "Na ca atthappaṭisaṁvedī yoniso manasikarissatīti netaṁ ṭhānaṁ vijjati."
    },
    {
      "id": "pe1:8.3",
      "pali": "Parato ghosassa saccānusandhissa desitassa atthaṁ vijānanto atthappaṭisaṁvedī bhavissatīti ṭhānametaṁ vijjati."
    },
    {
      "id": "pe1:8.4",
      "pali": "Atthappaṭisaṁvedī ca yoniso manasikarissatīti ṭhānametaṁ vijjati."
    },
    {
      "id": "pe1:8.5",
      "pali": "Esa hetu etaṁ ārammaṇaṁ eso upāyo sāvakassa niyyānassa, natthañño."
    },
    {
      "id": "pe1:8.6",
      "pali": "Soyaṁ na ca suttassa atthavijānanāya saha yutto nāpi ghosānuyogena parato ghosassa atthaṁ avijānantena sakkā uttari manussadhammaṁ alamariyañāṇadassanaṁ adhigantuṁ, tasmā nibbāyitukāmena sutamayena atthā pariyesitabbā."
    },
    {
      "id": "pe1:8.7",
      "pali": "Tattha pariyesanāya ayaṁ anupubbī bhavati soḷasa hārā, pañca nayā, aṭṭhārasa mūlapadāni."
    },
    {
      "id": "pe1:9.1",
      "pali": "Tatthāyaṁ uddānagāthā"
    },
    {
      "id": "pe1:10.1",
      "pali": "Soḷasahārā nettī,"
    },
    {
      "id": "pe1:10.2",
      "pali": "Pañcanayā sāsanassa pariyeṭṭhi;"
    },
    {
      "id": "pe1:10.3",
      "pali": "Aṭṭhārasamūlapadā,"
    },
    {
      "id": "pe1:10.4",
      "pali": "Kaccāyanagottaniddiṭṭhā."
    },
    {
      "id": "pe1:11.1",
      "pali": "Tattha katame <b>soḷasahārā</b>?"
    },
    {
      "id": "pe1:12.1",
      "pali": "Desanā vicayo yutti padaṭṭhānaṁ lakkhaṇaṁ catubyūho āvaṭṭo vibhatti parivattano vevacano paññatti otaraṇo sodhano adhiṭṭhāno parikkhāro samāropano—"
    },
    {
      "id": "pe1:12.2",
      "pali": "ime soḷasa hārā."
    },
    {
      "id": "pe1:13.1",
      "pali": "Tattha uddānagāthā"
    },
    {
      "id": "pe1:14.1",
      "pali": "Desanā vicayo yutti,"
    },
    {
      "id": "pe1:14.2",
      "pali": "padaṭṭhāno ca lakkhaṇo;"
    },
    {
      "id": "pe1:14.3",
      "pali": "Catubyūho ca āvaṭṭo,"
    },
    {
      "id": "pe1:14.4",
      "pali": "vibhatti parivattano."
    },
    {
      "id": "pe1:15.1",
      "pali": "Vevacano ca paññatti,"
    },
    {
      "id": "pe1:15.2",
      "pali": "otaraṇo ca sodhano;"
    },
    {
      "id": "pe1:15.3",
      "pali": "Adhiṭṭhāno parikkhāro,"
    },
    {
      "id": "pe1:15.4",
      "pali": "samāropano soḷaso."
    },
    {
      "id": "pe1:16.1",
      "pali": "Tattha katame <b>pañca nayā</b>?"
    },
    {
      "id": "pe1:17.1",
      "pali": "Nandiyāvaṭṭo tipukkhalo sīhavikkīḷito disālocano aṅkusoti."
    },
    {
      "id": "pe1:18.1",
      "pali": "Tattha uddānagāthā"
    },
    {
      "id": "pe1:19.1",
      "pali": "Paṭhamo nandiyāvaṭṭo,"
    },
    {
      "id": "pe1:19.2",
      "pali": "dutiyo ca tipukkhalo;"
    },
    {
      "id": "pe1:19.3",
      "pali": "Sīhavikkīḷito nāma,"
    },
    {
      "id": "pe1:19.4",
      "pali": "tatiyo hoti so nayo."
    },
    {
      "id": "pe1:20.1",
      "pali": "Disālocanamāhaṁsu,"
    },
    {
      "id": "pe1:20.2",
      "pali": "catuttho nayalañjako;"
    },
    {
      "id": "pe1:20.3",
      "pali": "Pañcamo aṅkuso nāma,"
    },
    {
      "id": "pe1:20.4",
      "pali": "sabbe pañca nayā gatā."
    },
    {
      "id": "pe1:21.1",
      "pali": "Tattha katamāni <b>aṭṭhārasa mūlapadāni</b>?"
    },
    {
      "id": "pe1:22.1",
      "pali": "Avijjā taṇhā lobho doso moho subhasaññā sukhasaññā niccasaññā attasaññā samatho vipassanā alobho adoso amoho asubhasaññā dukkhasaññā aniccasaññā anattasaññā, imāni aṭṭhārasa mūlapadāni."
    },
    {
      "id": "pe1:22.2",
      "pali": "Tattha nava padāni akusalāni yattha sabbaṁ akusalaṁ samosarati."
    },
    {
      "id": "pe1:22.3",
      "pali": "Nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati."
    },
    {
      "id": "pe1:23.1",
      "pali": "Katamāni nava padāni akusalāni yattha sabbaṁ akusalaṁ samosarati?"
    },
    {
      "id": "pe1:24.1",
      "pali": "Avijjā yāva attasaññā, imāni nava padāni akusalāni, yattha sabbaṁ akusalaṁ samosarati."
    },
    {
      "id": "pe1:25.1",
      "pali": "Katamāni nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati?"
    },
    {
      "id": "pe1:26.1",
      "pali": "Samatho yāva anattasaññā, imāni nava padāni kusalāni yattha sabbaṁ kusalaṁ samosarati."
    },
    {
      "id": "pe1:26.2",
      "pali": "Imāni aṭṭhārasa mūlapadāni."
    },
    {
      "id": "pe1:27.1",
      "pali": "Tattha imā uddānagāthā"
    },
    {
      "id": "pe1:28.1",
      "pali": "Taṇhā ca avijjā lobho,"
    },
    {
      "id": "pe1:28.2",
      "pali": "Doso tatheva moho ca;"
    },
    {
      "id": "pe1:28.3",
      "pali": "Cattāro ca vipallāsā,"
    },
    {
      "id": "pe1:28.4",
      "pali": "Kilesabhūmi nava padāni."
    },
    {
      "id": "pe1:29.1",
      "pali": "Ye ca satipaṭṭhānā samatho,"
    },
    {
      "id": "pe1:29.2",
      "pali": "Vipassanā kusalamūlaṁ;"
    },
    {
      "id": "pe1:29.3",
      "pali": "Etaṁ sabbaṁ kusalaṁ,"
    },
    {
      "id": "pe1:29.4",
      "pali": "Indriyabhūmi navapadāni."
    },
    {
      "id": "pe1:30.1",
      "pali": "Sabbaṁ kusalaṁ navahi padehi yujjati,"
    },
    {
      "id": "pe1:30.2",
      "pali": "Navahi ceva akusalaṁ;"
    },
    {
      "id": "pe1:30.3",
      "pali": "Ekake nava mūlapadāni,"
    },
    {
      "id": "pe1:30.4",
      "pali": "Ubhayato aṭṭhārasa mūlapadāni."
    },
    {
      "id": "pe1:31.1",
      "pali": "Imesaṁ aṭṭhārasannaṁ mūlapadānaṁ yāni nava padāni akusalāni, ayaṁ dukkhasamudayo;"
    },
    {
      "id": "pe1:31.2",
      "pali": "yāni nava padāni kusalāni, ayaṁ dukkhanirodhagāminī paṭipadā."
    },
    {
      "id": "pe1:31.3",
      "pali": "Iti samudayassa dukkhaṁ phalaṁ, dukkhanirodhagāminiyā paṭipadāya nirodhaṁ phalaṁ."
    },
    {
      "id": "pe1:31.4",
      "pali": "Imāni cattāri ariyasaccāni bhagavatā bārāṇasiyaṁ desitāni."
    },
    {
      "id": "pe1:32.1",
      "pali": "Tattha dukkhassa ariyasaccassa aparimāṇāni akkharāni padāni byañjanāni ākārāni niruttiyo niddesā desitā etassevatthassa saṅkāsanāya pakāsanāya vivaraṇāya vibhajanāya uttānīkammatāya paññāpanāyāti."
    },
    {
      "id": "pe1:32.2",
      "pali": "Yā evaṁ sabbesaṁ saccānaṁ iti ekamekaṁ saccaṁ aparimāṇehi akkharapadabyañjanaākāraniruttiniddesehi pariyesitabbaṁ, tañca byañjanaṁ atthaputhuttena pana attheva byañjanaputhuttena."
    },
    {
      "id": "pe1:33.1",
      "pali": "Yo hi koci samaṇo vā brāhmaṇo vā evaṁ vadeyya “ahaṁ idaṁ dukkhaṁ paccakkhāya aññaṁ dukkhaṁ paññapessāmī”ti tassa taṁ vācāvatthukamevassa pucchito ca na sampāyissati."
    },
    {
      "id": "pe1:33.2",
      "pali": "Evaṁ saccāni."
    },
    {
      "id": "pe1:33.3",
      "pali": "Yañca rattiṁ bhagavā abhisambuddho, yañca rattiṁ anupādāya parinibbuto, etthantare yaṁ kiñci bhagavatā bhāsitaṁ suttaṁ geyyaṁ veyyākaraṇaṁ gāthā udānaṁ itivuttakaṁ jātakaṁ abbhutadhammaṁ vedallaṁ, sabbaṁ taṁ dhammacakkaṁ pavattitaṁ."
    },
    {
      "id": "pe1:33.4",
      "pali": "Na kiñci buddhānaṁ bhagavantānaṁ dhammadesanāya dhammacakkato bahiddhā, tassa sabbaṁ suttaṁ ariyadhammesu pariyesitabbaṁ."
    },
    {
      "id": "pe1:33.5",
      "pali": "Tattha pariggaṇhanāya ālokasabhāni cattāri ariyasaccāni thāvarāni imāni."
    },
    {
      "id": "pe1:34.1",
      "pali": "Tattha katamaṁ <b>dukkhaṁ</b>?"
    },
    {
      "id": "pe1:34.2",
      "pali": "Jāti jarā byādhi maraṇaṁ saṅkhittena pañcupādānakkhandhā dukkhā."
    },
    {
      "id": "pe1:34.3",
      "pali": "Tatthāyaṁ lakkhaṇaniddeso, pātubhāvalakkhaṇā jāti, paripākalakkhaṇā jarā, dukkhadukkhatālakkhaṇo byādhi, cutilakkhaṇaṁ maraṇaṁ, piyavippayogavipariṇāmaparitāpanalakkhaṇo soko, lālappanalakkhaṇo paridevo, kāyasampīḷanalakkhaṇaṁ dukkhaṁ, cittasampīḷanalakkhaṇaṁ domanassaṁ, kilesaparidahanalakkhaṇo upāyāso, amanāpasamodhānalakkhaṇo appiyasampayogo, manāpavinābhāvalakkhaṇo piyavippayogo, adhippāyavivattanalakkhaṇo alābho, apariññālakkhaṇā pañcupādānakkhandhā, paripākacutilakkhaṇaṁ jarāmaraṇaṁ, pātubhāvacutilakkhaṇaṁ cutopapatti, paṭisandhinibbattanalakkhaṇo samudayo, samudayaparijahanalakkhaṇo nirodho, anusayasamucchedalakkhaṇo maggo."
    },
    {
      "id": "pe1:34.4",
      "pali": "Byādhilakkhaṇaṁ dukkhaṁ, sañjānanalakkhaṇo samudayo, niyyānikalakkhaṇo maggo, santilakkhaṇo nirodho."
    },
    {
      "id": "pe1:34.5",
      "pali": "Appaṭisandhibhāvanirodhalakkhaṇā anupādisesā nibbānadhātu, dukkhañca samudayo ca, dukkhañca nirodho ca, dukkhañca maggo ca, samudayo ca dukkhañca, samudayo ca nirodho ca, samudayo ca maggo ca, nirodho ca samudayo ca, nirodho ca dukkhañca, nirodho ca maggo ca, maggo ca nirodho ca, maggo ca samudayo ca, maggo ca dukkhañca."
    },
    {
      "id": "pe1:35.1",
      "pali": "Tatthimāni suttāni."
    },
    {
      "id": "pe1:36.1",
      "pali": "“Yamekarattiṁ paṭhamaṁ,"
    },
    {
      "id": "pe1:36.2",
      "pali": "gabbhe vasati māṇavo;"
    },
    {
      "id": "pe1:36.3",
      "pali": "Abbhuṭṭhitova so yāti,"
    },
    {
      "id": "pe1:36.4",
      "pali": "sa gacchaṁ na nivattatī”ti."
    },
    {
      "id": "pe1:37.1",
      "pali": "Aṭṭhimā, ānanda, dānūpapattiyo ekuttarike suttaṁ—"
    },
    {
      "id": "pe1:37.2",
      "pali": "ayaṁ jāti."
    },
    {
      "id": "pe1:38.1",
      "pali": "Tattha katamā jarā?"
    },
    {
      "id": "pe1:39.1",
      "pali": "“Acaritvā brahmacariyaṁ,"
    },
    {
      "id": "pe1:39.2",
      "pali": "aladdhā yobbane dhanaṁ;"
    },
    {
      "id": "pe1:39.3",
      "pali": "Jiṇṇakoñcāva jhāyanti,"
    },
    {
      "id": "pe1:39.4",
      "pali": "khīṇamaccheva pallale”."
    },
    {
      "id": "pe1:40.1",
      "pali": "Pañca pubbanimittāni devesu—"
    },
    {
      "id": "pe1:40.2",
      "pali": "ayaṁ jarā."
    },
    {
      "id": "pe1:41.1",
      "pali": "Tattha katamo byādhi?"
    },
    {
      "id": "pe1:42.1",
      "pali": "Sāmaṁ tena kuto rāja,"
    },
    {
      "id": "pe1:42.2",
      "pali": "Tuvampi jarāyanti vedesi;"
    },
    {
      "id": "pe1:42.3",
      "pali": "Khattiya kammassa phalo,"
    },
    {
      "id": "pe1:42.4",
      "pali": "Loko na hi kammaṁ panayati."
    },
    {
      "id": "pe1:43.1",
      "pali": "Tayo gilānā—"
    },
    {
      "id": "pe1:43.2",
      "pali": "ayaṁ byādhi."
    },
    {
      "id": "pe1:44.1",
      "pali": "Tattha katamaṁ maraṇaṁ?"
    },
    {
      "id": "pe1:45.1",
      "pali": "Yathāpi kumbhakārassa,"
    },
    {
      "id": "pe1:45.2",
      "pali": "kataṁ mattikabhājanaṁ;"
    },
    {
      "id": "pe1:45.3",
      "pali": "Khuddakañca mahantañca,"
    },
    {
      "id": "pe1:45.4",
      "pali": "yaṁ pakkaṁ yañca āmakaṁ;"
    },
    {
      "id": "pe1:45.5",
      "pali": "Sabbaṁ bhedanapariyantaṁ,"
    },
    {
      "id": "pe1:45.6",
      "pali": "evaṁ maccāna jīvitaṁ."
    },
    {
      "id": "pe1:46.1",
      "pali": "Mamāyite passatha phandamāne,"
    },
    {
      "id": "pe1:46.2",
      "pali": "Maccheva appodake khīṇasote;"
    },
    {
      "id": "pe1:46.3",
      "pali": "Etampi disvā amamo careyya,"
    },
    {
      "id": "pe1:46.4",
      "pali": "Bhavesu āsattimakubbamāno."
    },
    {
      "id": "pe1:47.1",
      "pali": "Udakappanasuttaṁ—"
    },
    {
      "id": "pe1:47.2",
      "pali": "idaṁ maraṇaṁ."
    },
    {
      "id": "pe1:48.1",
      "pali": "Tattha katamo soko?"
    },
    {
      "id": "pe1:49.1",
      "pali": "Idha socati pecca socati,"
    },
    {
      "id": "pe1:49.2",
      "pali": "Pāpakārī ubhayattha socati;"
    },
    {
      "id": "pe1:49.3",
      "pali": "So socati so vihaññati,"
    },
    {
      "id": "pe1:49.4",
      "pali": "Disvā kammakiliṭṭhamattano."
    },
    {
      "id": "pe1:50.1",
      "pali": "Tīṇi duccaritāni—"
    },
    {
      "id": "pe1:50.2",
      "pali": "ayaṁ soko."
    },
    {
      "id": "pe1:51.1",
      "pali": "Tattha katamo paridevo?"
    },
    {
      "id": "pe1:52.1",
      "pali": "Kāmesu giddhā pasutā pamūḷhā,"
    },
    {
      "id": "pe1:52.2",
      "pali": "Avadāniyā te visame niviṭṭhā;"
    },
    {
      "id": "pe1:52.3",
      "pali": "Dukkhūpanītā paridevayanti,"
    },
    {
      "id": "pe1:52.4",
      "pali": "Kiṁsu bhavissāma ito cutāse."
    },
    {
      "id": "pe1:53.1",
      "pali": "Tisso vipattiyo—"
    },
    {
      "id": "pe1:53.2",
      "pali": "ayaṁ paridevo."
    },
    {
      "id": "pe1:54.1",
      "pali": "Tattha katamaṁ dukkhaṁ?"
    },
    {
      "id": "pe1:55.1",
      "pali": "Sataṁ āsi ayosaṅkū,"
    },
    {
      "id": "pe1:55.2",
      "pali": "sabbe paccattavedanā;"
    },
    {
      "id": "pe1:55.3",
      "pali": "Jalitā jātavedāva,"
    },
    {
      "id": "pe1:55.4",
      "pali": "accisaṅghasamākulā."
    },
    {
      "id": "pe1:56.1",
      "pali": "Mahā vata so pariḷāho saṁyuttake suttaṁ saccasaṁyuttesu—"
    },
    {
      "id": "pe1:56.2",
      "pali": "idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:57.1",
      "pali": "Tattha katamaṁ domanassaṁ?"
    },
    {
      "id": "pe1:58.1",
      "pali": "Saṅkappehi pareto so,"
    },
    {
      "id": "pe1:58.2",
      "pali": "kapaṇo viya jhāyati;"
    },
    {
      "id": "pe1:58.3",
      "pali": "Sutvā paresaṁ nigghosaṁ,"
    },
    {
      "id": "pe1:58.4",
      "pali": "maṅku hoti tathāvidho."
    },
    {
      "id": "pe1:59.1",
      "pali": "Dveme tapanīyā dhammā—"
    },
    {
      "id": "pe1:59.2",
      "pali": "idaṁ domanassaṁ."
    },
    {
      "id": "pe1:60.1",
      "pali": "Tattha katamo upāyāso?"
    },
    {
      "id": "pe1:61.1",
      "pali": "Kammārānaṁ yathā ukkā,"
    },
    {
      "id": "pe1:61.2",
      "pali": "anto ḍayhati no bahi;"
    },
    {
      "id": "pe1:61.3",
      "pali": "Evaṁ ḍayhati me hadayaṁ,"
    },
    {
      "id": "pe1:61.4",
      "pali": "sutvā nibbattamambujaṁ."
    },
    {
      "id": "pe1:62.1",
      "pali": "Tayo aggī—"
    },
    {
      "id": "pe1:62.2",
      "pali": "ayaṁ upāyāso."
    },
    {
      "id": "pe1:63.1",
      "pali": "Tattha katamo appiyasampayogo?"
    },
    {
      "id": "pe1:64.1",
      "pali": "Ayasāva malaṁ samuṭṭhitaṁ,"
    },
    {
      "id": "pe1:64.2",
      "pali": "Tatuṭṭhāya tameva khādati;"
    },
    {
      "id": "pe1:64.3",
      "pali": "Evaṁ atidhonacārinaṁ,"
    },
    {
      "id": "pe1:64.4",
      "pali": "Sāni kammāni nayanti duggatiṁ."
    },
    {
      "id": "pe1:65.1",
      "pali": "Dveme tathāgataṁ abbhācikkhanti, ekuttarike suttaṁ dukesu—"
    },
    {
      "id": "pe1:65.2",
      "pali": "ayaṁ appiyasampayogo."
    },
    {
      "id": "pe1:66.1",
      "pali": "Tattha katamo piyavippayogo?"
    },
    {
      "id": "pe1:67.1",
      "pali": "Supinena yathāpi saṅgataṁ,"
    },
    {
      "id": "pe1:67.2",
      "pali": "Paṭibuddho puriso na passati;"
    },
    {
      "id": "pe1:67.3",
      "pali": "Evampi piyāyitaṁ janaṁ,"
    },
    {
      "id": "pe1:67.4",
      "pali": "Petaṁ kālaṅkataṁ na passati."
    },
    {
      "id": "pe1:68.1",
      "pali": "Te devā cavanadhammaṁ viditvā tīhi vācāhi anusāsanti."
    },
    {
      "id": "pe1:68.2",
      "pali": "Ayaṁ piyavippayogo."
    },
    {
      "id": "pe1:69.1",
      "pali": "Yampicchaṁ na labhati,"
    },
    {
      "id": "pe1:69.2",
      "pali": "tisso māradhītaro;"
    },
    {
      "id": "pe1:69.3",
      "pali": "Tassa ce kāmayānassa,"
    },
    {
      "id": "pe1:69.4",
      "pali": "chandajātassa jantuno;"
    },
    {
      "id": "pe1:69.5",
      "pali": "Te kāmā parihāyanti,"
    },
    {
      "id": "pe1:69.6",
      "pali": "sallaviddhova ruppati."
    },
    {
      "id": "pe1:70.1",
      "pali": "Saṅkhittena pañcupādānakkhandhā dukkhā."
    },
    {
      "id": "pe1:71.1",
      "pali": "Cakkhu sotañca ghānañca,"
    },
    {
      "id": "pe1:71.2",
      "pali": "jivhā kāyo tato manaṁ;"
    },
    {
      "id": "pe1:71.3",
      "pali": "Ete lokāmisā ghorā,"
    },
    {
      "id": "pe1:71.4",
      "pali": "yattha sattā puthujjanā."
    },
    {
      "id": "pe1:72.1",
      "pali": "Pañcime bhikkhave khandhā—"
    },
    {
      "id": "pe1:72.2",
      "pali": "idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:73.1",
      "pali": "Tattha katamā jarā ca maraṇañca?"
    },
    {
      "id": "pe1:74.1",
      "pali": "Appaṁ vata jīvitaṁ idaṁ,"
    },
    {
      "id": "pe1:74.2",
      "pali": "Oraṁ vassasatāpi mīyate;"
    },
    {
      "id": "pe1:74.3",
      "pali": "Atha vāpi akicchaṁ jīvitaṁ,"
    },
    {
      "id": "pe1:74.4",
      "pali": "Atha kho so jarasāpi mīyate."
    },
    {
      "id": "pe1:75.1",
      "pali": "Saṁyuttake pasenadisaṁyuttake suttaṁ ayyikā me kālaṅkatā—"
    },
    {
      "id": "pe1:75.2",
      "pali": "ayaṁ jarā ca maraṇañca."
    },
    {
      "id": "pe1:76.1",
      "pali": "Tattha katamā cuti ca upapatti ca?"
    },
    {
      "id": "pe1:77.1",
      "pali": "“Sabbe sattā marissanti,"
    },
    {
      "id": "pe1:77.2",
      "pali": "Maraṇantaṁ hi jīvitaṁ;"
    },
    {
      "id": "pe1:77.3",
      "pali": "Yathākammaṁ gamissanti,"
    },
    {
      "id": "pe1:77.4",
      "pali": "Attakammaphalūpagā”ti.—"
    },
    {
      "id": "pe1:78.1",
      "pali": "Ayaṁ cuti ca upapatti ca."
    },
    {
      "id": "pe1:79.1",
      "pali": "Imehi suttehi ekasadisehi ca aññehi navavidhaṁ suttaṁ taṁ anupaviṭṭhehi lakkhaṇato dukkhaṁ ñatvā sādhāraṇañca asādhāraṇañca dukkhaṁ ariyasaccaṁ niddisitabbaṁ."
    },
    {
      "id": "pe1:79.2",
      "pali": "Gāthāhi gāthā anuminitabbā, byākaraṇehi vā byākaraṇaṁ—"
    },
    {
      "id": "pe1:79.3",
      "pali": "idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:80.1",
      "pali": "Tattha katamo <b>dukkhasamudayo</b>?"
    },
    {
      "id": "pe1:81.1",
      "pali": "Kāmesu sattā kāmasaṅgasattā,"
    },
    {
      "id": "pe1:81.2",
      "pali": "Saṁyojane vajjamapassamānā;"
    },
    {
      "id": "pe1:81.3",
      "pali": "Na hi jātu saṁyojanasaṅgasattā,"
    },
    {
      "id": "pe1:81.4",
      "pali": "Oghaṁ tareyyuṁ vipulaṁ mahantaṁ."
    },
    {
      "id": "pe1:82.1",
      "pali": "Cattāro āsavā suttaṁ—"
    },
    {
      "id": "pe1:82.2",
      "pali": "ayaṁ dukkhasamudayo."
    },
    {
      "id": "pe1:83.1",
      "pali": "Tattha katamo <b>dukkhanirodho</b>?"
    },
    {
      "id": "pe1:84.1",
      "pali": "Yamhi na māyā vasatī na māno,"
    },
    {
      "id": "pe1:84.2",
      "pali": "Yo vītalobho amamo nirāso;"
    },
    {
      "id": "pe1:84.3",
      "pali": "Panuṇṇakodho abhinibbutatto,"
    },
    {
      "id": "pe1:84.4",
      "pali": "So brāhmaṇo so samaṇo sa bhikkhu."
    },
    {
      "id": "pe1:85.1",
      "pali": "Dvemā vimuttiyo, rāgavirāgā ca cetovimutti;"
    },
    {
      "id": "pe1:85.2",
      "pali": "avijjāvirāgā ca paññāvimutti—"
    },
    {
      "id": "pe1:85.3",
      "pali": "ayaṁ nirodho."
    },
    {
      "id": "pe1:86.1",
      "pali": "Tattha katamo <b>maggo</b>?"
    },
    {
      "id": "pe1:87.1",
      "pali": "Eseva maggo natthañño,"
    },
    {
      "id": "pe1:87.2",
      "pali": "dassanassa visuddhiyā;"
    },
    {
      "id": "pe1:87.3",
      "pali": "Ariyo aṭṭhaṅgiko maggo,"
    },
    {
      "id": "pe1:87.4",
      "pali": "mārassetaṁ pamohanaṁ."
    },
    {
      "id": "pe1:88.1",
      "pali": "Sattime, bhikkhave, bojjhaṅgā—"
    },
    {
      "id": "pe1:88.2",
      "pali": "ayaṁ maggo."
    },
    {
      "id": "pe1:89.1",
      "pali": "Tattha katamāni <b>cattāri ariyasaccāni</b>?"
    },
    {
      "id": "pe1:90.1",
      "pali": "“Ye dhammā hetuppabhavā,"
    },
    {
      "id": "pe1:90.2",
      "pali": "Tesaṁ hetuṁ tathāgato āha;"
    },
    {
      "id": "pe1:90.3",
      "pali": "Tesañca yo nirodho,"
    },
    {
      "id": "pe1:90.4",
      "pali": "Evaṁvādī mahāsamaṇo”ti."
    },
    {
      "id": "pe1:91.1",
      "pali": "Hetuppabhavā dhammā dukkhaṁ, hetusamudayo, yaṁ bhagavato vacanaṁ."
    },
    {
      "id": "pe1:91.2",
      "pali": "Ayaṁ dhammo yo nirodho, ye hi keci saṁyojaniyesu dhammesu assadānupassino viharanti."
    },
    {
      "id": "pe1:91.3",
      "pali": "Kilesā taṇhā pavaḍḍhati, taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "pe1:91.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "pe1:91.5",
      "pali": "Tattha yaṁ saṁyojanaṁ—"
    },
    {
      "id": "pe1:91.6",
      "pali": "ayaṁ samudayo."
    },
    {
      "id": "pe1:91.7",
      "pali": "Ye saṁyojaniyā dhammā ye ca sokaparidevadukkhadomanassupāyāsā sambhavanti—"
    },
    {
      "id": "pe1:91.8",
      "pali": "idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:91.9",
      "pali": "Yā saṁyojaniyesu dhammesu ādīnavānupassanā—"
    },
    {
      "id": "pe1:91.10",
      "pali": "ayaṁ maggo."
    },
    {
      "id": "pe1:91.11",
      "pali": "Parimuccati jātiyā jarāya byādhīhi maraṇehi sokehi paridevehi yāva upāyāsehi—"
    },
    {
      "id": "pe1:91.12",
      "pali": "idaṁ nibbānaṁ."
    },
    {
      "id": "pe1:91.13",
      "pali": "Imāni cattāri saccāni."
    },
    {
      "id": "pe1:92.1",
      "pali": "Tattha katamā <b>anupādisesā nibbānadhātu</b>?"
    },
    {
      "id": "pe1:93.1",
      "pali": "Atthaṅgatassa na pamāṇamatthi,"
    },
    {
      "id": "pe1:93.2",
      "pali": "Taṁ hi vā natthi yena naṁ paññapeyya;"
    },
    {
      "id": "pe1:93.3",
      "pali": "Sabbasaṅgānaṁ samūhatattā vidū,"
    },
    {
      "id": "pe1:93.4",
      "pali": "Sitā vādasatassu sabbe."
    },
    {
      "id": "pe1:94.1",
      "pali": "Saṁyuttake godhikasaṁyuttaṁ."
    },
    {
      "id": "pe1:95.1",
      "pali": "Imāni <b>asādhāraṇāni suttāni</b>."
    },
    {
      "id": "pe1:95.2",
      "pali": "Yahiṁ yahiṁ saccāni niddiṭṭhāni, tahiṁ tahiṁ saccalakkhaṇato otāretvā aparimāṇehi byañjanehi so attho pariyesitabbo."
    },
    {
      "id": "pe1:95.3",
      "pali": "Tattha atthānuparivatti byañjanena puna byañjanānuparivatti atthena tassa ekamekassa aparimāṇāni byañjanāni imehi suttehi yathānikkhittehi cattāri ariyasaccāni niddisitabbāni."
    },
    {
      "id": "pe1:95.4",
      "pali": "Pañcanikāye anupaviṭṭhāhi gāthāhi gāthā anuminitabbā, byākaraṇena byākaraṇaṁ."
    },
    {
      "id": "pe1:95.5",
      "pali": "Imāni asādhāraṇāni suttāni."
    },
    {
      "id": "pe1:96.1",
      "pali": "Tesaṁ imā uddānagāthā"
    },
    {
      "id": "pe1:97.1",
      "pali": "Yamekarattiṁ paṭhamaṁ,"
    },
    {
      "id": "pe1:97.2",
      "pali": "aṭṭha dānūpapattiyo;"
    },
    {
      "id": "pe1:97.3",
      "pali": "Pañca pubbanimittāni,"
    },
    {
      "id": "pe1:97.4",
      "pali": "khīṇamacchaṁva pallalaṁ."
    },
    {
      "id": "pe1:98.1",
      "pali": "Sāmaṁ tena kuto rāja,"
    },
    {
      "id": "pe1:98.2",
      "pali": "tayo devā gilānakā;"
    },
    {
      "id": "pe1:98.3",
      "pali": "Yathāpi kumbhakārassa,"
    },
    {
      "id": "pe1:98.4",
      "pali": "yathā nadidakappanaṁ."
    },
    {
      "id": "pe1:99.1",
      "pali": "Idha socati pecca socati,"
    },
    {
      "id": "pe1:99.2",
      "pali": "Tīṇi duccaritāni ca;"
    },
    {
      "id": "pe1:99.3",
      "pali": "Kāmesu giddhā pasutā,"
    },
    {
      "id": "pe1:99.4",
      "pali": "Yāva tisso vipattiyo."
    },
    {
      "id": "pe1:100.1",
      "pali": "Sataṁ āsi ayosaṅkū,"
    },
    {
      "id": "pe1:100.2",
      "pali": "pariḷāho mahattaro;"
    },
    {
      "id": "pe1:100.3",
      "pali": "Saṅkappehi pareto so,"
    },
    {
      "id": "pe1:100.4",
      "pali": "tattha tapaniyehi ca."
    },
    {
      "id": "pe1:101.1",
      "pali": "Kammārānaṁ yathā ukkā,"
    },
    {
      "id": "pe1:101.2",
      "pali": "tayo aggī pakāsitā;"
    },
    {
      "id": "pe1:101.3",
      "pali": "Ayato malamuppannaṁ,"
    },
    {
      "id": "pe1:101.4",
      "pali": "abbhakkhānaṁ tathāgate."
    },
    {
      "id": "pe1:102.1",
      "pali": "Tividhaṁ devānusāsanti,"
    },
    {
      "id": "pe1:102.2",
      "pali": "supinena saṅgamo yathā;"
    },
    {
      "id": "pe1:102.3",
      "pali": "Tisso ceva māradhītā,"
    },
    {
      "id": "pe1:102.4",
      "pali": "sallaviddhova ruppati."
    },
    {
      "id": "pe1:103.1",
      "pali": "Cakkhu sotañca ghānañca,"
    },
    {
      "id": "pe1:103.2",
      "pali": "pañcakkhandhā pakāsitā;"
    },
    {
      "id": "pe1:103.3",
      "pali": "Appaṁ vata jīvitaṁ idaṁ,"
    },
    {
      "id": "pe1:103.4",
      "pali": "ayyikā me mahallikā."
    },
    {
      "id": "pe1:104.1",
      "pali": "Sabbe sattā marissanti,"
    },
    {
      "id": "pe1:104.2",
      "pali": "upapatti cuticayaṁ;"
    },
    {
      "id": "pe1:104.3",
      "pali": "Kāmesu sattā pasutā,"
    },
    {
      "id": "pe1:104.4",
      "pali": "āsavehi catūhi ca."
    },
    {
      "id": "pe1:105.1",
      "pali": "Yamhi na māyā vasati,"
    },
    {
      "id": "pe1:105.2",
      "pali": "dvemā cetovimuttiyo;"
    },
    {
      "id": "pe1:105.3",
      "pali": "Eseva maggo natthañño,"
    },
    {
      "id": "pe1:105.4",
      "pali": "bojjhaṅgā ca sudesitā."
    },
    {
      "id": "pe1:106.1",
      "pali": "Atthaṅgatassa na pamāṇamatthi,"
    },
    {
      "id": "pe1:106.2",
      "pali": "Godhiko parinibbuto;"
    },
    {
      "id": "pe1:106.3",
      "pali": "Ye dhammā hetuppabhavā,"
    },
    {
      "id": "pe1:106.4",
      "pali": "Saṁyojanānupassino."
    },
    {
      "id": "pe1:107.1",
      "pali": "Imā dasa tesaṁ uddānagāthā."
    },
    {
      "id": "pe1:108.1",
      "pali": "Tatthimāni <b>sādhāraṇāni suttāni</b> yesu suttesu sādhāraṇāni saccāni desitāni anulomampi paṭilomampi vomissakampi."
    },
    {
      "id": "pe1:108.2",
      "pali": "Tattha ayaṁ ādi."
    },
    {
      "id": "pe1:109.1",
      "pali": "Avijjāya nivuto loko,"
    },
    {
      "id": "pe1:109.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "pe1:109.3",
      "pali": "Vivicchā pamādā nappakāsati;"
    },
    {
      "id": "pe1:109.4",
      "pali": "Jappābhilepanaṁ brūmi,"
    },
    {
      "id": "pe1:109.5",
      "pali": "Dukkhamassa mahabbhayaṁ."
    },
    {
      "id": "pe1:110.1",
      "pali": "Tattha yā avijjā ca vivicchā ca, ayaṁ samudayo."
    },
    {
      "id": "pe1:110.2",
      "pali": "Yaṁ mahabbhayaṁ, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:110.3",
      "pali": "Imāni dve saccāni—"
    },
    {
      "id": "pe1:110.4",
      "pali": "dukkhañca samudayo ca."
    },
    {
      "id": "pe1:110.5",
      "pali": "“Saṁyojanaṁ saṁyojaniyā ca dhammā”ti saṁyuttake cittasaṁyuttakesu byākaraṇaṁ."
    },
    {
      "id": "pe1:110.6",
      "pali": "Tattha yaṁ saṁyojanaṁ, ayaṁ samudayo."
    },
    {
      "id": "pe1:110.7",
      "pali": "Ye saṁyojaniyā dhammā, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:110.8",
      "pali": "Imāni dve saccāni—"
    },
    {
      "id": "pe1:110.9",
      "pali": "dukkhañca samudayo ca."
    },
    {
      "id": "pe1:111.1",
      "pali": "Tattha katamaṁ dukkhañca nirodho ca?"
    },
    {
      "id": "pe1:112.1",
      "pali": "Ucchinnabhavataṇhassa,"
    },
    {
      "id": "pe1:112.2",
      "pali": "netticchinnassa bhikkhuno;"
    },
    {
      "id": "pe1:112.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "pe1:112.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "pe1:113.1",
      "pali": "Yaṁ cittaṁ, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:113.2",
      "pali": "Yo bhavataṇhāya upacchedo, ayaṁ dukkhanirodho."
    },
    {
      "id": "pe1:113.3",
      "pali": "Vikkhīṇo jātisaṁsāro, natthi dāni punabbhavoti niddeso."
    },
    {
      "id": "pe1:113.4",
      "pali": "Imāni dve saccāni—"
    },
    {
      "id": "pe1:113.5",
      "pali": "dukkhañca nirodho ca."
    },
    {
      "id": "pe1:113.6",
      "pali": "Dvemā, bhikkhave, vimuttiyo;"
    },
    {
      "id": "pe1:113.7",
      "pali": "rāgavirāgā ca cetovimutti, avijjāvirāgā ca paññāvimutti."
    },
    {
      "id": "pe1:113.8",
      "pali": "Yaṁ cittaṁ, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:113.9",
      "pali": "Yā vimutti, ayaṁ nirodho."
    },
    {
      "id": "pe1:113.10",
      "pali": "Imāni dve saccāni—"
    },
    {
      "id": "pe1:113.11",
      "pali": "dukkhañca nirodho ca."
    },
    {
      "id": "pe1:114.1",
      "pali": "Tattha katamaṁ dukkhañca maggo ca?"
    },
    {
      "id": "pe1:115.1",
      "pali": "Kumbhūpamaṁ kāyamimaṁ viditvā,"
    },
    {
      "id": "pe1:115.2",
      "pali": "Nagarūpamaṁ cittamidaṁ ṭhapetvā;"
    },
    {
      "id": "pe1:115.3",
      "pali": "Yodhetha māraṁ paññāvudhena,"
    },
    {
      "id": "pe1:115.4",
      "pali": "Jitañca rakkhe anivesano siyā."
    },
    {
      "id": "pe1:116.1",
      "pali": "Tattha yañca kumbhūpamo kāyo yañca nagarūpamaṁ cittaṁ, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:116.2",
      "pali": "Yaṁ paññāvudhena māraṁ yodhethāti ayaṁ maggo."
    },
    {
      "id": "pe1:116.3",
      "pali": "Imāni dve saccāni."
    },
    {
      "id": "pe1:116.4",
      "pali": "Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahitabbaṁ."
    },
    {
      "id": "pe1:116.5",
      "pali": "Yā saṁyojanā, ayaṁ maggo."
    },
    {
      "id": "pe1:116.6",
      "pali": "Ye te dhammā anattaniyā pahātabbā, rūpaṁ yāva viññāṇaṁ, idaṁ dukkhañca maggo ca."
    },
    {
      "id": "pe1:117.1",
      "pali": "Tattha katamaṁ dukkhañca samudayo ca nirodho ca?"
    },
    {
      "id": "pe1:118.1",
      "pali": "Ye keci sokā paridevitā vā,"
    },
    {
      "id": "pe1:118.2",
      "pali": "Dukkhā ca lokasmimanekarūpā;"
    },
    {
      "id": "pe1:118.3",
      "pali": "Piyaṁ paṭiccappabhavanti ete,"
    },
    {
      "id": "pe1:118.4",
      "pali": "Piye asante na bhavanti ete."
    },
    {
      "id": "pe1:119.1",
      "pali": "Ye sokaparidevā, yaṁ ca anekarūpaṁ dukkhaṁ, yaṁ pemato bhavati, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:119.2",
      "pali": "Yaṁ pemaṁ, ayaṁ samudayo."
    },
    {
      "id": "pe1:119.3",
      "pali": "Yo tattha chandarāgavinayo piyassa akiriyā, ayaṁ nirodho."
    },
    {
      "id": "pe1:119.4",
      "pali": "Imāni tīṇi saccāni."
    },
    {
      "id": "pe1:119.5",
      "pali": "Timbaruko paribbājako pacceti “sayaṅkataṁ paraṅkatan”ti."
    },
    {
      "id": "pe1:119.6",
      "pali": "Yathesā vīmaṁsā, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:119.7",
      "pali": "Yā ete dve ante anupagamma majjhimā paṭipadā avijjāpaccayā saṅkhārā yāva jātipaccayā jarāmaraṇaṁ, idampi dukkhañca samudayo ca."
    },
    {
      "id": "pe1:119.8",
      "pali": "Viññāṇaṁ nāmarūpaṁ saḷāyatanaṁ phasso vedanā bhavo jāti jarāmaraṇaṁ, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:119.9",
      "pali": "Avijjā saṅkhārā taṇhā upādānaṁ, ayaṁ samudayo."
    },
    {
      "id": "pe1:119.10",
      "pali": "Iti idaṁ sayaṅkataṁ vīmaṁseyyāti yañca paṭiccasamuppāde dukkhaṁ, idaṁ eso samudayo niddiṭṭho."
    },
    {
      "id": "pe1:119.11",
      "pali": "Avijjānirodhā saṅkhāranirodho ca yāva ca jarāmaraṇanirodhoti ayaṁ nirodho."
    },
    {
      "id": "pe1:119.12",
      "pali": "Imāni tīṇi saccāni dukkhañca samudayo ca nirodho ca."
    },
    {
      "id": "pe1:120.1",
      "pali": "Tattha katamaṁ dukkhañca samudayo ca maggo ca?"
    },
    {
      "id": "pe1:121.1",
      "pali": "“Yo dukkhamaddakkhi yatonidānaṁ,"
    },
    {
      "id": "pe1:121.2",
      "pali": "Kāmesu so jantu kathaṁ nameyya;"
    },
    {
      "id": "pe1:121.3",
      "pali": "Kāmā hi loke saṅgāti ñatvā,"
    },
    {
      "id": "pe1:121.4",
      "pali": "Tesaṁ satīmā vinayāya sikkhe”ti."
    },
    {
      "id": "pe1:122.1",
      "pali": "Yo dukkhamaddakkhi, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:122.2",
      "pali": "Yato bhavati, ayaṁ samudayo."
    },
    {
      "id": "pe1:122.3",
      "pali": "Sandiṭṭhaṁ yato bhavati yāva tassa vinayāya sikkhā, ayaṁ maggo."
    },
    {
      "id": "pe1:122.4",
      "pali": "Imāni tīṇi saccāni."
    },
    {
      "id": "pe1:123.1",
      "pali": "Ekādasaṅguttaresu gopālakopamasuttaṁ."
    },
    {
      "id": "pe1:124.1",
      "pali": "Tattha yāva rūpasaññuttā yañca saḷāyatanaṁ yathā vaṇaṁ paṭicchādeti yañca titthaṁ yathā ca labhati dhammūpasañhitaṁ uḷāraṁ pītipāmojjaṁ catubbidhaṁ ca attabhāvato ca vatthu, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:124.2",
      "pali": "Yāva āsāṭikaṁ hāretā hoti, ayaṁ samudayo."
    },
    {
      "id": "pe1:124.3",
      "pali": "Rūpasaññuttā āsāṭakaharaṇaṁ vaṇapaṭicchādanaṁ vīthiññutā gocarakusalañca, ayaṁ maggo."
    },
    {
      "id": "pe1:124.4",
      "pali": "Avasesā dhammā atthi hetū atthi paccayā atthi nissayā sāvasesadohitā anekapūjā ca kalyāṇamittatappaccayā dhammā vīthiññutā ca hetu, imāni tīṇi saccāni."
    },
    {
      "id": "pe1:125.1",
      "pali": "Tattha katamaṁ dukkhañca maggo ca nirodho ca?"
    },
    {
      "id": "pe1:126.1",
      "pali": "Sati kāyagatā upaṭṭhitā,"
    },
    {
      "id": "pe1:126.2",
      "pali": "Chasu phassāyatanesu saṁvuto;"
    },
    {
      "id": "pe1:126.3",
      "pali": "Satataṁ bhikkhu samāhito,"
    },
    {
      "id": "pe1:126.4",
      "pali": "Jaññā nibbānamattano."
    },
    {
      "id": "pe1:127.1",
      "pali": "Tattha yā ca kāyagatā sati yañca saḷāyatanaṁ yattha sabbañcetaṁ dukkhaṁ."
    },
    {
      "id": "pe1:127.2",
      "pali": "Yā ca kāyagatā sati yo ca sīlasaṁvaro yo ca samādhi yattha yā sati, ayaṁ paññākkhandho."
    },
    {
      "id": "pe1:127.3",
      "pali": "Sabbampi sīlakkhandho samādhikkhandho, ayaṁ maggo."
    },
    {
      "id": "pe1:127.4",
      "pali": "Evaṁvihārinā ñātabbaṁ nibbānaṁ."
    },
    {
      "id": "pe1:127.5",
      "pali": "Ayaṁ nirodho, imāni tīṇi saccāni."
    },
    {
      "id": "pe1:127.6",
      "pali": "Sīle patiṭṭhāya dve dhammā bhāvetabbā samatho ca vipassanā ca."
    },
    {
      "id": "pe1:127.7",
      "pali": "Tattha yaṁ cittasahajātā dhammā, idaṁ dukkhaṁ."
    },
    {
      "id": "pe1:127.8",
      "pali": "Yo ca samatho yā ca vipassanā, ayaṁ maggo."
    },
    {
      "id": "pe1:127.9",
      "pali": "Rāgavirāgā ca cetovimutti, avijjāvirāgā ca paññāvimutti, ayaṁ nirodho."
    },
    {
      "id": "pe1:127.10",
      "pali": "Imāni tīṇi saccāni."
    },
    {
      "id": "pe1:128.1",
      "pali": "Tattha katamo samudayo ca nirodho ca?"
    },
    {
      "id": "pe1:129.1",
      "pali": "Āsā ca pīhā abhinandanā ca,"
    },
    {
      "id": "pe1:129.2",
      "pali": "Anekadhātūsu sarā patiṭṭhitā;"
    },
    {
      "id": "pe1:129.3",
      "pali": "Aññāṇamūlappabhavā pajappitā,"
    },
    {
      "id": "pe1:129.4",
      "pali": "Sabbā mayā byantikatā samūlikā."
    },
    {
      "id": "pe1:130.1",
      "pali": "Aññāṇamūlappabhavāti purimakehi samudayo."
    },
    {
      "id": "pe1:130.2",
      "pali": "Sabbā mayā byantikatā samūlikāti nirodho."
    },
    {
      "id": "pe1:130.3",
      "pali": "Imāni dve saccāni."
    },
    {
      "id": "pe1:130.4",
      "pali": "Catunnaṁ dhammānaṁ ananubodhā appaṭivedhā vitthārena kātabbaṁ."
    },
    {
      "id": "pe1:130.5",
      "pali": "Ariyassa sīlassa samādhino paññāya vimuttiyā."
    },
    {
      "id": "pe1:130.6",
      "pali": "Tattha yo imesaṁ catunnaṁ dhammānaṁ ananubodhā appaṭivedhā, ayaṁ samudayo."
    },
    {
      "id": "pe1:130.7",
      "pali": "Paṭivedho bhavanettiyā, ayaṁ nirodho."
    },
    {
      "id": "pe1:130.8",
      "pali": "Ayaṁ samudayo ca nirodho ca."
    },
    {
      "id": "pe1:131.1",
      "pali": "Tattha katamo samudayo ca maggo ca?"
    },
    {
      "id": "pe1:132.1",
      "pali": "Yāni sotāni lokasmiṁ,"
    },
    {
      "id": "pe1:132.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "pe1:132.3",
      "pali": "Sati tesaṁ nivāraṇaṁ;"
    },
    {
      "id": "pe1:132.4",
      "pali": "Sotānaṁ saṁvaraṁ brūmi,"
    },
    {
      "id": "pe1:132.5",
      "pali": "Paññāyete pidhīyare."
    },
    {
      "id": "pe1:133.1",
      "pali": "Yāni sotānīti ayaṁ samudayo."
    },
    {
      "id": "pe1:133.2",
      "pali": "Yā ca paññā yā ca sati nivāraṇaṁ pidhānañca, ayaṁ maggo."
    },
    {
      "id": "pe1:133.3",
      "pali": "Imāni dve saccāni."
    },
    {
      "id": "pe1:133.4",
      "pali": "Sañcetaniyaṁ suttaṁ daḷhanemiyānākāro chahi māsehi niddiṭṭho."
    },
    {
      "id": "pe1:133.5",
      "pali": "Tattha yaṁ kāyaṁ kāyakammaṁ savaṅkaṁ sadosaṁ sakasāvaṁ yā savaṅkatā sadosatā sakasāvatā, ayaṁ samudayo."
    },
    {
      "id": "pe1:133.6",
      "pali": "Evaṁ vacīkammaṁ manokammaṁ avaṅkaṁ adosaṁ akasāvaṁ, yā avaṅkatā adosatā akasāvatā, ayaṁ maggo."
    },
    {
      "id": "pe1:133.7",
      "pali": "Evaṁ vacīkammaṁ manokammaṁ."
    },
    {
      "id": "pe1:133.8",
      "pali": "Imāni dve saccāni samudayo ca maggo ca."
    },
    {
      "id": "pe1:134.1",
      "pali": "Tattha katamo samudayo ca nirodho ca maggo ca?"
    },
    {
      "id": "pe1:135.1",
      "pali": "“Nissitassa calitaṁ, anissitassa calitaṁ natthi, calite asati passaddhi, passaddhiyā sati nati na hoti, natiyā asati āgatigati na hoti, āgatigatiyā asati cutūpapāto na hoti, cutūpapāte asati nevidha na huraṁ na ubhayamantarena."
    },
    {
      "id": "pe1:135.2",
      "pali": "Esevanto dukkhassā”ti."
    },
    {
      "id": "pe1:136.1",
      "pali": "Tattha dve nissayā, ayaṁ samudayo."
    },
    {
      "id": "pe1:136.2",
      "pali": "Yo ca anissayo, yā ca anati, ayaṁ maggo."
    },
    {
      "id": "pe1:136.3",
      "pali": "Yā āgatigati na hoti cutūpapāto ca yo esevanto dukkhassāti, ayaṁ nirodho."
    },
    {
      "id": "pe1:136.4",
      "pali": "Imāni tīṇi saccāni."
    },
    {
      "id": "pe1:136.5",
      "pali": "Anupaṭṭhitakāyagatā sati …pe…"
    },
    {
      "id": "pe1:136.6",
      "pali": "yaṁ vimuttiñāṇadassanaṁ, ayaṁ samudayo."
    },
    {
      "id": "pe1:136.7",
      "pali": "Ekārasaupanissayā vimuttiyo yāva upanissayaupasampadā upaṭṭhitakāyagatāsatissa viharati."
    },
    {
      "id": "pe1:136.8",
      "pali": "Sīlasaṁvaro sosāniyo hoti, yañca vimuttiñāṇadassanaṁ, ayaṁ maggo."
    },
    {
      "id": "pe1:136.9",
      "pali": "Yā ca vimutti, ayaṁ nirodho."
    },
    {
      "id": "pe1:136.10",
      "pali": "Imāni tīṇi saccāni."
    },
    {
      "id": "pe1:136.11",
      "pali": "Samudayo ca nirodho ca maggo ca."
    },
    {
      "id": "pe1:137.1",
      "pali": "Tattha katamo nirodho ca maggo ca?"
    },
    {
      "id": "pe1:138.1",
      "pali": "Sayaṁ katena saccena,"
    },
    {
      "id": "pe1:138.2",
      "pali": "Tena attanā abhinibbānagato vitiṇṇakaṅkho;"
    },
    {
      "id": "pe1:138.3",
      "pali": "Vibhavañca ñatvā lokasmiṁ,"
    },
    {
      "id": "pe1:138.4",
      "pali": "Tāva khīṇapunabbhavo sa bhikkhu."
    },
    {
      "id": "pe1:139.1",
      "pali": "Yaṁ saccena, ayaṁ maggo."
    },
    {
      "id": "pe1:139.2",
      "pali": "Yaṁ khīṇapunabbhavo, ayaṁ nirodho."
    },
    {
      "id": "pe1:139.3",
      "pali": "Imāni dve saccāni."
    },
    {
      "id": "pe1:139.4",
      "pali": "Pañca vimuttāyatanāni satthā vā dhammaṁ desesi aññataro vā viññū sabrahmacārīti vitthārena kātabbā."
    },
    {
      "id": "pe1:139.5",
      "pali": "Tassa atthappaṭisaṁvedissa pāmojjaṁ jāyati, pamuditassa pīti jāyati, yāva nibbindanto virajjati, ayaṁ maggo."
    },
    {
      "id": "pe1:139.6",
      "pali": "Yā vimutti, ayaṁ nirodho."
    },
    {
      "id": "pe1:139.7",
      "pali": "Evaṁ pañca vimuttāyatanāni vitthārena."
    },
    {
      "id": "pe1:139.8",
      "pali": "Imāni dve saccāni nirodho ca maggo ca."
    },
    {
      "id": "pe1:140.1",
      "pali": "Imāni sādhāraṇāni suttāni."
    },
    {
      "id": "pe1:140.2",
      "pali": "Imehi sādhāraṇehi suttehi yathānikkhittehi paṭivedhato ca lakkhaṇato ca otāretvā aññāni suttāni niddisitabbāni aparihāyantena."
    },
    {
      "id": "pe1:140.3",
      "pali": "Gāthāhi gāthā anuminitabbā, byākaraṇehi byākaraṇaṁ."
    },
    {
      "id": "pe1:140.4",
      "pali": "Ime ca sādhāraṇā dasa parivaḍḍhakā eko ca catukko niddeso sādhāraṇo."
    },
    {
      "id": "pe1:140.5",
      "pali": "Ayañca pakiṇṇakaniddeso."
    },
    {
      "id": "pe1:140.6",
      "pali": "Ekaṁ pañca cha ca savekadeso sabbaṁ."
    },
    {
      "id": "pe1:140.7",
      "pali": "Ime dve parivajjanā purimakā ca dasa."
    },
    {
      "id": "pe1:140.8",
      "pali": "Ime dvādasa parivaḍḍhakā saccāni."
    },
    {
      "id": "pe1:140.9",
      "pali": "Ettāvatā sabbaṁ suttaṁ natthi, taṁ byākaraṇaṁ vā gāthā viya."
    },
    {
      "id": "pe1:140.10",
      "pali": "Imehi dvādasahi parivaḍḍhakehi na otarituṁ appamattena pariyesitvā niddisitabbā."
    },
    {
      "id": "pe1:141.1",
      "pali": "Tatthāyaṁ saṅkhepo."
    },
    {
      "id": "pe1:141.2",
      "pali": "Sabbaṁ dukkhaṁ sattahi padehi samosaraṇaṁ gacchati."
    },
    {
      "id": "pe1:141.3",
      "pali": "Katarehi sattahi?"
    },
    {
      "id": "pe1:141.4",
      "pali": "Appiyasampayogo ca piyavippayogo ca, imehi dvīhi padehi sabbaṁ dukkhaṁ niddisitabbaṁ."
    },
    {
      "id": "pe1:141.5",
      "pali": "Tassa dve nissayā—"
    },
    {
      "id": "pe1:141.6",
      "pali": "kāyo ca cittañca."
    },
    {
      "id": "pe1:141.7",
      "pali": "Tena vuccati “kāyikaṁ dukkhaṁ cetasikañce”ti, natthi taṁ dukkhaṁ na kāyikaṁ vā na cetasikaṁ, sabbaṁ dukkhaṁ dvīhi dukkhehi niddisitabbaṁ kāyikena ca cetasikena ca."
    },
    {
      "id": "pe1:141.8",
      "pali": "Tīhi dukkhatāhi saṅgahitaṁ dukkhadukkhatāya saṅkhāradukkhatāya vipariṇāmadukkhatāya."
    },
    {
      "id": "pe1:141.9",
      "pali": "Iti taṁ sabbaṁ dukkhaṁ tīhi dukkhatāhi saṅgahitaṁ."
    },
    {
      "id": "pe1:141.10",
      "pali": "Iti idañca dukkhaṁ tividhaṁ."
    },
    {
      "id": "pe1:141.11",
      "pali": "Duvidhaṁ dukkhaṁ kāyikañca cetasikañca."
    },
    {
      "id": "pe1:141.12",
      "pali": "Duvidhaṁ appiyasampayogo ca piyavippayogo ca."
    },
    {
      "id": "pe1:141.13",
      "pali": "Idaṁ sattavidhaṁ dukkhaṁ."
    },
    {
      "id": "pe1:142.1",
      "pali": "Tattha tividho samudayo acatuttho apañcamo."
    },
    {
      "id": "pe1:142.2",
      "pali": "Katamo tividho?"
    },
    {
      "id": "pe1:142.3",
      "pali": "Taṇhā ca diṭṭhi ca kammaṁ."
    },
    {
      "id": "pe1:142.4",
      "pali": "Tattha taṇhā ca bhavasamudayo kammaṁ."
    },
    {
      "id": "pe1:142.5",
      "pali": "Tathā nibbattassa hīnapaṇītatā, ayaṁ samudayo."
    },
    {
      "id": "pe1:142.6",
      "pali": "Iti yāpi bhavagatīsu hīnatā ca paṇītatā ca, yāpi tīhi dukkhatāhi saṅgahitā, yopi dvīhi mūlehi samudānīto avijjāya nivutassa bhavataṇhāsaṁyuttassa saviññāṇako kāyo, sopi tīhi dukkhatāhi saṅgahito."
    },
    {
      "id": "pe1:143.1",
      "pali": "Tathā vipallāsato diṭṭhi āgantabbā."
    },
    {
      "id": "pe1:143.2",
      "pali": "Sā sattavidhā niddisitabbā."
    },
    {
      "id": "pe1:143.3",
      "pali": "Eko vipallāso tīṇi niddisīyati, cattāri vipallāsavatthūni."
    },
    {
      "id": "pe1:143.4",
      "pali": "Tattha katamo eko vipallāso?"
    },
    {
      "id": "pe1:143.5",
      "pali": "Yo viparītaggāho paṭikkhepena, otaraṇaṁ yathā “anicce niccam”iti viparītaṁ gaṇhāti."
    },
    {
      "id": "pe1:143.6",
      "pali": "Evaṁ cattāro vipallāsā."
    },
    {
      "id": "pe1:143.7",
      "pali": "Ayameko vipallāsīyati saññā cittaṁ diṭṭhi."
    },
    {
      "id": "pe1:143.8",
      "pali": "Katamāni cattāri vipallāsavatthūni?"
    },
    {
      "id": "pe1:143.9",
      "pali": "Kāyo vedanā cittaṁ dhammā."
    },
    {
      "id": "pe1:143.10",
      "pali": "Evaṁ vipallāsagatassa akusalañca pavaḍḍheti."
    },
    {
      "id": "pe1:143.11",
      "pali": "Tattha saññāvipallāso dosaṁ akusalamūlaṁ pavaḍḍheti."
    },
    {
      "id": "pe1:143.12",
      "pali": "Cittavipallāso lobhaṁ akusalamūlaṁ pavaḍḍheti."
    },
    {
      "id": "pe1:143.13",
      "pali": "Diṭṭhivipallāso mohaṁ akusalamūlaṁ pavaḍḍheti."
    },
    {
      "id": "pe1:143.14",
      "pali": "Tattha dosassa akusalamūlassa tīṇi micchattāni phalaṁ—"
    },
    {
      "id": "pe1:143.15",
      "pali": "micchāvācā micchākammanto micchāājīvo;"
    },
    {
      "id": "pe1:143.16",
      "pali": "lobhassa akusalamūlassa tīṇi micchattāni phalaṁ—"
    },
    {
      "id": "pe1:143.17",
      "pali": "micchāsaṅkappo micchāvāyāmo micchāsamādhi;"
    },
    {
      "id": "pe1:143.18",
      "pali": "mohassa akusalamūlassa dve micchattāni phalaṁ—"
    },
    {
      "id": "pe1:143.19",
      "pali": "micchādiṭṭhi ca micchāsati ca."
    },
    {
      "id": "pe1:143.20",
      "pali": "Evaṁ akusalaṁ sahetu sappaccayaṁ vipallāsā ca paccayo, akusalamūlāni sahetū eteyeva paṭipakkhena anūnā anadhikā dvīhi paccayehi niddisitabbā."
    },
    {
      "id": "pe1:143.21",
      "pali": "Nirodhe ca magge ca vipallāsamupādāya parato paṭipakkhena catasso."
    },
    {
      "id": "pe1:144.1",
      "pali": "Tatthimā uddānagāthā"
    },
    {
      "id": "pe1:145.1",
      "pali": "Avijjāya nivuto loko,"
    },
    {
      "id": "pe1:145.2",
      "pali": "cittaṁ saṁyojanampi;"
    },
    {
      "id": "pe1:145.3",
      "pali": "Sā pacchinnabhavataṇhā,"
    },
    {
      "id": "pe1:145.4",
      "pali": "dvemā ceva vimuttiyo."
    },
    {
      "id": "pe1:146.1",
      "pali": "Kumbhūpamaṁ kāyamimaṁ,"
    },
    {
      "id": "pe1:146.2",
      "pali": "Yaṁ na tumhākaṁ taṁ pajaha;"
    },
    {
      "id": "pe1:146.3",
      "pali": "Ye keci sokaparidevā,"
    },
    {
      "id": "pe1:146.4",
      "pali": "Timbaruko ca sayaṅkataṁ."
    },
    {
      "id": "pe1:147.1",
      "pali": "Dukkhaṁ diṭṭhi ca uppannaṁ,"
    },
    {
      "id": "pe1:147.2",
      "pali": "yañca gopālakopamaṁ;"
    },
    {
      "id": "pe1:147.3",
      "pali": "Sati kāyagatā māhu,"
    },
    {
      "id": "pe1:147.4",
      "pali": "samatho ca vipassanā."
    },
    {
      "id": "pe1:148.1",
      "pali": "Āsā pihā ca abhinandanā ca,"
    },
    {
      "id": "pe1:148.2",
      "pali": "Catunnamananubodhanā;"
    },
    {
      "id": "pe1:148.3",
      "pali": "Yāni sotāni lokasmiṁ,"
    },
    {
      "id": "pe1:148.4",
      "pali": "Daḷhaṁ nemiyānākāro."
    },
    {
      "id": "pe1:149.1",
      "pali": "Yaṁ nissitassa calitaṁ,"
    },
    {
      "id": "pe1:149.2",
      "pali": "Anupaṭṭhitakāyagatāsati;"
    },
    {
      "id": "pe1:149.3",
      "pali": "Sayaṁ katena saccena,"
    },
    {
      "id": "pe1:149.4",
      "pali": "Vimuttāyatanehi ca."
    },
    {
      "id": "pe1:150.1",
      "pali": "Peṭakopadese mahākaccāyanena bhāsite paṭhamabhūmi ariyasaccappakāsanā nāma taṁ jīvatā bhagavatā mādisena samuddanena tathāgatenāti."
    }
  ]
}
