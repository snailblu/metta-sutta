{
  "uid": "cnd21",
  "title": "17. Pārāyanatthutigāthāniddesa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cnd21:1.1",
      "pali": "<b>Idamavoca bhagavā magadhesu viharanto pāsāṇake cetiye, paricārakasoḷasānaṁ brāhmaṇānaṁ ajjhiṭṭho puṭṭho puṭṭho pañhaṁ byākāsi.</b>"
    },
    {
      "id": "cnd21:2.1",
      "pali": "<b>Idamavoca bhagavā</b>ti idaṁ pārāyanaṁ avoca."
    },
    {
      "id": "cnd21:2.2",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd21:2.3",
      "pali": "idamavoca bhagavā."
    },
    {
      "id": "cnd21:2.4",
      "pali": "<b>Magadhesu viharanto</b>ti magadhanāmake janapade viharanto iriyanto vattento pālento yapento yāpento."
    },
    {
      "id": "cnd21:2.5",
      "pali": "<b>Pāsāṇake cetiye</b>ti pāsāṇakacetiyaṁ vuccati buddhāsananti—"
    },
    {
      "id": "cnd21:2.6",
      "pali": "magadhesu viharanto pāsāṇake cetiye."
    },
    {
      "id": "cnd21:2.7",
      "pali": "<b>Paricārakasoḷasānaṁ brāhmaṇānan</b>ti piṅgiyo brāhmaṇo bāvarissa brāhmaṇassa paddho paddhacaro paricārako sisso."
    },
    {
      "id": "cnd21:2.8",
      "pali": "Piṅgiyena te soḷasāti—"
    },
    {
      "id": "cnd21:2.9",
      "pali": "evampi paricārakasoḷasānaṁ brāhmaṇānaṁ."
    },
    {
      "id": "cnd21:2.10",
      "pali": "Atha vā te soḷasa brāhmaṇā buddhassa bhagavato paddhā paddhacarā paricārakā sissāti—"
    },
    {
      "id": "cnd21:2.11",
      "pali": "evampi paricārakasoḷasānaṁ brāhmaṇānaṁ."
    },
    {
      "id": "cnd21:3.1",
      "pali": "<b>Ajjhiṭṭho puṭṭho puṭṭho pañhaṁ byākāsī</b>ti."
    },
    {
      "id": "cnd21:3.2",
      "pali": "<b>Ajjhiṭṭho</b>ti ajjhiṭṭho ajjhesito."
    },
    {
      "id": "cnd21:3.3",
      "pali": "<b>Puṭṭho puṭṭho</b>ti puṭṭho puṭṭho pucchito pucchito yācito yācito ajjhesito ajjhesito pasādito pasādito."
    },
    {
      "id": "cnd21:3.4",
      "pali": "<b>Pañhaṁ byākāsī</b>ti pañhaṁ byākāsi ācikkhi desesi paññapesi paṭṭhapesi vivari vibhaji uttānīākāsi pakāsesīti—"
    },
    {
      "id": "cnd21:3.5",
      "pali": "ajjhiṭṭho puṭṭho puṭṭho pañhaṁ byākāsi."
    },
    {
      "id": "cnd21:3.6",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:4.1",
      "pali": "“Idamavoca bhagavā magadhesu viharanto pāsāṇake cetiye, paricārakasoḷasānaṁ brāhmaṇānaṁ ajjhiṭṭho puṭṭho puṭṭho pañhaṁ byākāsī”ti."
    },
    {
      "id": "cnd21:5.1",
      "pali": "<b>Ekamekassa cepi pañhassa atthamaññāya dhammamaññāya dhammānudhammaṁ paṭipajjeyya, gaccheyyeva jarāmaraṇassa pāraṁ.</b>"
    },
    {
      "id": "cnd21:5.2",
      "pali": "<b>Pāraṅgamanīyā ime dhammāti.</b>"
    },
    {
      "id": "cnd21:5.3",
      "pali": "<b>Tasmā imassa dhammapariyāyassa “pārāyanan”teva adhivacanaṁ.</b>"
    },
    {
      "id": "cnd21:6.1",
      "pali": "<b>Ekamekassa cepi pañhassā</b>ti ekamekassa cepi ajitapañhassa, ekamekassa cepi tissametteyyapañhassa, ekamekassa cepi puṇṇakapañhassa, ekamekassa cepi mettagūpañhassa, ekamekassa cepi dhotakapañhassa, ekamekassa cepi upasīvapañhassa, ekamekassa cepi nandakapañhassa, ekamekassa cepi hemakapañhassa, ekamekassa cepi todeyyapañhassa, ekamekassa cepi kappapañhassa, ekamekassa cepi jatukaṇṇipañhassa, ekamekassa cepi bhadrāvudhapañhassa, ekamekassa cepi udayapañhassa, ekamekassa cepi posālapañhassa, ekamekassa cepi mogharājapañhassa, ekamekassa cepi piṅgiyapañhassāti—"
    },
    {
      "id": "cnd21:6.2",
      "pali": "ekamekassa cepi pañhassa."
    },
    {
      "id": "cnd21:7.1",
      "pali": "<b>Atthamaññāya dhammamaññāyā</b>ti sveva pañho dhammo, visajjanaṁ atthoti atthaṁ aññāya jānitvā tulayitvā tīrayitvā vibhāvayitvā vibhūtaṁ katvāti—"
    },
    {
      "id": "cnd21:7.2",
      "pali": "atthamaññāya."
    },
    {
      "id": "cnd21:7.3",
      "pali": "<b>Dhammamaññāyā</b>ti dhammaṁ aññāya jānitvā tulayitvā tīrayitvā vibhāvayitvā vibhūtaṁ katvāti—"
    },
    {
      "id": "cnd21:7.4",
      "pali": "dhammamaññāyāti—"
    },
    {
      "id": "cnd21:7.5",
      "pali": "atthamaññāya dhammamaññāya."
    },
    {
      "id": "cnd21:7.6",
      "pali": "<b>Dhammānudhammaṁ paṭipajjeyyā</b>ti sammāpaṭipadaṁ anulomapaṭipadaṁ apaccanīkapaṭipadaṁ anvatthapaṭipadaṁ dhammānudhammapaṭipadaṁ paṭipajjeyyāti—"
    },
    {
      "id": "cnd21:7.7",
      "pali": "dhammānudhammaṁ paṭipajjeyya."
    },
    {
      "id": "cnd21:7.8",
      "pali": "<b>Gaccheyyeva jarāmaraṇassa pāran</b>ti jarāmaraṇassa pāraṁ vuccati amataṁ nibbānaṁ."
    },
    {
      "id": "cnd21:7.9",
      "pali": "Yo so sabbasaṅkhārasamatho sabbūpadhipaṭinissaggo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "cnd21:7.10",
      "pali": "<b>Gaccheyyeva jarāmaraṇassa pāran</b>ti jarāmaraṇassa pāraṁ gaccheyya, pāraṁ adhigaccheyya, pāraṁ adhiphasseyya, pāraṁ sacchikareyyāti—"
    },
    {
      "id": "cnd21:7.11",
      "pali": "gaccheyyeva jarāmaraṇassa pāraṁ."
    },
    {
      "id": "cnd21:7.12",
      "pali": "<b>Pāraṅgamanīyā ime dhammā</b>ti ime dhammā pāraṅgamanīyā."
    },
    {
      "id": "cnd21:7.13",
      "pali": "Pāraṁ pāpenti pāraṁ sampāpenti pāraṁ samanupāpenti, jarāmaraṇassa taraṇāya saṁvattantīti—"
    },
    {
      "id": "cnd21:7.14",
      "pali": "pāraṅgamanīyā ime dhammāti."
    },
    {
      "id": "cnd21:8.1",
      "pali": "<b>Tasmā imassa dhammapariyāyassā</b>ti."
    },
    {
      "id": "cnd21:8.2",
      "pali": "<b>Tasmā</b>ti tasmā taṅkāraṇā taṁhetu tappaccayā taṁnidānāti—"
    },
    {
      "id": "cnd21:8.3",
      "pali": "tasmā."
    },
    {
      "id": "cnd21:8.4",
      "pali": "<b>Imassa dhammapariyāyassā</b>ti imassa pārāyanassāti—"
    },
    {
      "id": "cnd21:8.5",
      "pali": "tasmā imassa dhammapariyāyassa."
    },
    {
      "id": "cnd21:8.6",
      "pali": "<b>Pārāyananteva adhivacanan</b>ti pāraṁ vuccati amataṁ nibbānaṁ …pe… nirodho nibbānaṁ."
    },
    {
      "id": "cnd21:8.7",
      "pali": "Ayanaṁ vuccati maggo, seyyathidaṁ—"
    },
    {
      "id": "cnd21:8.8",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "cnd21:8.9",
      "pali": "<b>Adhivacanan</b>ti saṅkhā samaññā paññatti vohāro nāmaṁ nāmakammaṁ nāmadheyyaṁ nirutti byañjanaṁ abhilāpoti—"
    },
    {
      "id": "cnd21:8.10",
      "pali": "pārāyananteva adhivacanaṁ."
    },
    {
      "id": "cnd21:8.11",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:9.1",
      "pali": "“Ekamekassa cepi pañhassa atthamaññāya dhammamaññāya dhammānudhammaṁ paṭipajjeyya, gaccheyyeva jarāmaraṇassa pāraṁ."
    },
    {
      "id": "cnd21:9.2",
      "pali": "Pāraṅgamanīyā ime dhammāti."
    },
    {
      "id": "cnd21:9.3",
      "pali": "Tasmā imassa dhammapariyāyassa ‘pārāyanan’teva adhivacanan”ti."
    },
    {
      "id": "cnd21:10.1",
      "pali": "<b>Ajito tissametteyyo,</b>"
    },
    {
      "id": "cnd21:10.2",
      "pali": "<b>puṇṇako atha mettagū;</b>"
    },
    {
      "id": "cnd21:10.3",
      "pali": "<b>Dhotako upasīvo ca,</b>"
    },
    {
      "id": "cnd21:10.4",
      "pali": "<b>nando ca atha hemako. </b>"
    },
    {
      "id": "cnd21:11.1",
      "pali": "<b>Todeyyakappā dubhayo,</b>"
    },
    {
      "id": "cnd21:11.2",
      "pali": "<b>jatukaṇṇī ca paṇḍito;</b>"
    },
    {
      "id": "cnd21:11.3",
      "pali": "<b>Bhadrāvudho udayo ca,</b>"
    },
    {
      "id": "cnd21:11.4",
      "pali": "<b>posālo cāpi brāhmaṇo;</b>"
    },
    {
      "id": "cnd21:11.5",
      "pali": "<b>Mogharājā ca medhāvī,</b>"
    },
    {
      "id": "cnd21:11.6",
      "pali": "<b>piṅgiyo ca mahāisi. </b>"
    },
    {
      "id": "cnd21:12.1",
      "pali": "<b>Ete buddhaṁ upāgacchuṁ,</b>"
    },
    {
      "id": "cnd21:12.2",
      "pali": "<b>Sampannacaraṇaṁ isiṁ;</b>"
    },
    {
      "id": "cnd21:12.3",
      "pali": "<b>Pucchantā nipuṇe pañhe,</b>"
    },
    {
      "id": "cnd21:12.4",
      "pali": "<b>Buddhaseṭṭhaṁ upāgamuṁ. </b>"
    },
    {
      "id": "cnd21:13.1",
      "pali": "<b>Ete buddhaṁ upāgacchun</b>ti."
    },
    {
      "id": "cnd21:13.2",
      "pali": "<b>Ete</b>ti soḷasa pārāyaniyā brāhmaṇā."
    },
    {
      "id": "cnd21:13.3",
      "pali": "<b>Buddho</b>ti yo so bhagavā sayambhū anācariyako pubbe ananussutesu dhammesu sāmaṁ saccāni abhisambujjhi, tattha ca sabbaññutaṁ patto balesu ca vasībhāvaṁ."
    },
    {
      "id": "cnd21:13.4",
      "pali": "<b>Buddho</b>ti kenaṭṭhena buddho?"
    },
    {
      "id": "cnd21:13.5",
      "pali": "Bujjhitā saccānīti buddho, bodhetā pajāyāti buddho, sabbaññutāya buddho, sabbadassāvitāya buddho, abhiññeyyatāya buddho, visavitāya buddho, khīṇāsavasaṅkhātena buddho, nirupalepasaṅkhātena buddho, ekantavītarāgoti buddho, ekantavītadosoti buddho, ekantavītamohoti buddho, ekantanikkilesoti buddho, ekāyanamaggaṁ gatoti buddho, eko anuttaraṁ sammāsambodhiṁ abhisambuddhoti buddho, abuddhivihatattā buddhipaṭilābhāti buddho."
    },
    {
      "id": "cnd21:13.6",
      "pali": "<b>Buddho</b>ti netaṁ nāmaṁ mātarā kataṁ na pitarā kataṁ na bhātarā kataṁ na bhaginiyā kataṁ na mittāmaccehi kataṁ na ñātisālohitehi kataṁ na samaṇabrāhmaṇehi kataṁ na devatāhi kataṁ."
    },
    {
      "id": "cnd21:13.7",
      "pali": "Vimokkhantikametaṁ buddhānaṁ bhagavantānaṁ bodhiyā mūle saha sabbaññutañāṇassa paṭilābhā sacchikā paññatti, yadidaṁ buddhoti."
    },
    {
      "id": "cnd21:13.8",
      "pali": "<b>Ete buddhaṁ upāgacchun</b>ti ete buddhaṁ upāgamiṁsu upasaṅkamiṁsu payirupāsiṁsu paripucchiṁsu paripañhiṁsūti—"
    },
    {
      "id": "cnd21:13.9",
      "pali": "ete buddhaṁ upāgacchuṁ."
    },
    {
      "id": "cnd21:14.1",
      "pali": "<b>Sampannacaraṇaṁ isin</b>ti <b>caraṇaṁ</b> vuccati sīlācāranibbatti."
    },
    {
      "id": "cnd21:14.2",
      "pali": "Sīlasaṁvaropi caraṇaṁ, indriyasaṁvaropi caraṇaṁ, bhojane mattaññutāpi caraṇaṁ, jāgariyānuyogopi caraṇaṁ, sattapi saddhammā caraṇaṁ, cattāripi jhānāni caraṇaṁ."
    },
    {
      "id": "cnd21:14.3",
      "pali": "<b>Sampannacaraṇan</b>ti sampannacaraṇaṁ seṭṭhacaraṇaṁ viseṭṭhacaraṇaṁ pāmokkhacaraṇaṁ uttamacaraṇaṁ pavaracaraṇaṁ."
    },
    {
      "id": "cnd21:14.4",
      "pali": "<b>Isī</b>ti isi bhagavā mahantaṁ sīlakkhandhaṁ esī gavesī pariyesīti isi …pe… mahesakkhehi vā sattehi esito gavesito pariyesito—"
    },
    {
      "id": "cnd21:14.5",
      "pali": "“kahaṁ buddho, kahaṁ bhagavā, kahaṁ devadevo kahaṁ narāsabho”ti—"
    },
    {
      "id": "cnd21:14.6",
      "pali": "isīti—"
    },
    {
      "id": "cnd21:14.7",
      "pali": "sampannacaraṇaṁ isiṁ."
    },
    {
      "id": "cnd21:15.1",
      "pali": "<b>Pucchantā nipuṇe pañhe</b>ti."
    },
    {
      "id": "cnd21:15.2",
      "pali": "<b>Pucchantā</b>ti pucchantā yācantā ajjhesantā pasādentā."
    },
    {
      "id": "cnd21:15.3",
      "pali": "<b>Nipuṇe pañhe</b>ti gambhīre duddase duranubodhe sante paṇīte atakkāvacare nipuṇe paṇḍitavedanīye pañheti—"
    },
    {
      "id": "cnd21:15.4",
      "pali": "pucchantā nipuṇe pañhe."
    },
    {
      "id": "cnd21:16.1",
      "pali": "<b>Buddhaseṭṭhaṁ upāgamun</b>ti."
    },
    {
      "id": "cnd21:16.2",
      "pali": "<b>Buddho</b>ti yo so bhagavā …pe… sacchikā paññatti, yadidaṁ buddhoti."
    },
    {
      "id": "cnd21:16.3",
      "pali": "<b>Seṭṭhan</b>ti aggaṁ seṭṭhaṁ viseṭṭhaṁ pāmokkhaṁ uttamaṁ pavaraṁ buddhaṁ upāgamuṁ upāgamiṁsu upasaṅkamiṁsu payirupāsiṁsu paripucchiṁsu paripañhiṁsūti—"
    },
    {
      "id": "cnd21:16.4",
      "pali": "buddhaseṭṭhaṁ upāgamuṁ."
    },
    {
      "id": "cnd21:16.5",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:17.1",
      "pali": "“Ete buddhaṁ upāgacchuṁ,"
    },
    {
      "id": "cnd21:17.2",
      "pali": "sampannacaraṇaṁ isiṁ;"
    },
    {
      "id": "cnd21:17.3",
      "pali": "Pucchantā nipuṇe pañhe,"
    },
    {
      "id": "cnd21:17.4",
      "pali": "buddhaseṭṭhaṁ upāgamun”ti."
    },
    {
      "id": "cnd21:18.1",
      "pali": "<b>Tesaṁ buddho pabyākāsi,</b>"
    },
    {
      "id": "cnd21:18.2",
      "pali": "<b>Pañhaṁ puṭṭho yathātathaṁ;</b>"
    },
    {
      "id": "cnd21:18.3",
      "pali": "<b>Pañhānaṁ veyyākaraṇena,</b>"
    },
    {
      "id": "cnd21:18.4",
      "pali": "<b>Tosesi brāhmaṇe muni. </b>"
    },
    {
      "id": "cnd21:19.1",
      "pali": "<b>Tesaṁ buddho pabyākāsī</b>ti."
    },
    {
      "id": "cnd21:19.2",
      "pali": "<b>Tesan</b>ti soḷasānaṁ pārāyaniyānaṁ brāhmaṇānaṁ."
    },
    {
      "id": "cnd21:19.3",
      "pali": "<b>Buddho</b>ti yo so bhagavā …pe… sacchikā paññatti, yadidaṁ buddhoti."
    },
    {
      "id": "cnd21:19.4",
      "pali": "<b>Pabyākāsī</b>ti tesaṁ buddho pabyākāsi ācikkhi desesi paññapesi paṭṭhapesi vivari vibhaji uttānīakāsi pakāsesīti—"
    },
    {
      "id": "cnd21:19.5",
      "pali": "tesaṁ buddho pabyākāsi."
    },
    {
      "id": "cnd21:20.1",
      "pali": "<b>Pañhaṁ puṭṭho yathātathan</b>ti."
    },
    {
      "id": "cnd21:20.2",
      "pali": "<b>Pañhaṁ puṭṭho</b>ti pañhaṁ puṭṭho pucchito yācito ajjhesito pasādito."
    },
    {
      "id": "cnd21:20.3",
      "pali": "<b>Yathātathan</b>ti yathā ācikkhitabbaṁ tathā ācikkhi, yathā desitabbaṁ tathā desesi, yathā paññapetabbaṁ tathā paññapesi, yathā paṭṭhapetabbaṁ tathā paṭṭhapesi, yathā vivaritabbaṁ tathā vivari, yathā vibhajitabbaṁ tathā vibhaji, yathā uttānīkātabbaṁ tathā uttānīakāsi, yathā pakāsitabbaṁ tathā pakāsesīti—"
    },
    {
      "id": "cnd21:20.4",
      "pali": "pañhaṁ puṭṭho yathātathaṁ."
    },
    {
      "id": "cnd21:21.1",
      "pali": "<b>Pañhānaṁ veyyākaraṇenā</b>ti pañhānaṁ veyyākaraṇena ācikkhanena desanena paññapanena paṭṭhapanena vivaraṇena vibhajanena uttānīkammena pakāsanenāti—"
    },
    {
      "id": "cnd21:21.2",
      "pali": "pañhānaṁ veyyākaraṇena."
    },
    {
      "id": "cnd21:22.1",
      "pali": "<b>Tosesi brāhmaṇe munī</b>ti."
    },
    {
      "id": "cnd21:22.2",
      "pali": "<b>Tosesī</b>ti tosesi vitosesi pasādesi ārādhesi attamane akāsi."
    },
    {
      "id": "cnd21:22.3",
      "pali": "<b>Brāhmaṇe</b>ti soḷasa pārāyaniye brāhmaṇe."
    },
    {
      "id": "cnd21:22.4",
      "pali": "<b>Munī</b>ti monaṁ vuccati ñāṇaṁ …pe… saṅgajālamaticca so munīti—"
    },
    {
      "id": "cnd21:22.5",
      "pali": "tosesi brāhmaṇe muni."
    },
    {
      "id": "cnd21:22.6",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:23.1",
      "pali": "“Tesaṁ buddho pabyākāsi,"
    },
    {
      "id": "cnd21:23.2",
      "pali": "pañhaṁ puṭṭho yathātathaṁ;"
    },
    {
      "id": "cnd21:23.3",
      "pali": "Pañhānaṁ veyyākaraṇena,"
    },
    {
      "id": "cnd21:23.4",
      "pali": "tosesi brāhmaṇe munī”ti."
    },
    {
      "id": "cnd21:24.1",
      "pali": "<b>Te tositā cakkhumatā,</b>"
    },
    {
      "id": "cnd21:24.2",
      "pali": "<b>buddhenādiccabandhunā;</b>"
    },
    {
      "id": "cnd21:24.3",
      "pali": "<b>Brahmacariyamacariṁsu,</b>"
    },
    {
      "id": "cnd21:24.4",
      "pali": "<b>varapaññassa santike. </b>"
    },
    {
      "id": "cnd21:25.1",
      "pali": "<b>Te tositā cakkhumatā</b>ti."
    },
    {
      "id": "cnd21:25.2",
      "pali": "<b>Te</b>ti soḷasa pārāyaniyā brāhmaṇā."
    },
    {
      "id": "cnd21:25.3",
      "pali": "<b>Tositā</b>ti tositā vitositā pasāditā ārādhitā attamanā katāti—"
    },
    {
      "id": "cnd21:25.4",
      "pali": "te tositā."
    },
    {
      "id": "cnd21:25.5",
      "pali": "<b>Cakkhumatā</b>ti bhagavā pañcahi cakkhūhi cakkhumā—"
    },
    {
      "id": "cnd21:25.6",
      "pali": "maṁsacakkhunāpi cakkhumā, dibbacakkhunāpi cakkhumā, paññācakkhunāpi cakkhumā, buddhacakkhunāpi cakkhumā, samantacakkhunāpi cakkhumā."
    },
    {
      "id": "cnd21:25.7",
      "pali": "Kathaṁ bhagavā maṁsacakkhunāpi cakkhumā …pe…"
    },
    {
      "id": "cnd21:25.8",
      "pali": "evaṁ bhagavā samantacakkhunāpi cakkhumāti—"
    },
    {
      "id": "cnd21:25.9",
      "pali": "te tositā cakkhumatā."
    },
    {
      "id": "cnd21:26.1",
      "pali": "<b>Buddhenādiccabandhunā</b>ti."
    },
    {
      "id": "cnd21:26.2",
      "pali": "<b>Buddho</b>ti yo so bhagavā …pe… sacchikā paññatti, yadidaṁ buddhoti."
    },
    {
      "id": "cnd21:26.3",
      "pali": "<b>Ādiccabandhunā</b>ti <b>ādicco</b> vuccati sūriyo."
    },
    {
      "id": "cnd21:26.4",
      "pali": "So gotamo gottena, bhagavāpi gotamo gottena, bhagavā sūriyassa gottañātako gottabandhu."
    },
    {
      "id": "cnd21:26.5",
      "pali": "Tasmā buddho ādiccabandhūti—"
    },
    {
      "id": "cnd21:26.6",
      "pali": "buddhenādiccabandhunā."
    },
    {
      "id": "cnd21:27.1",
      "pali": "<b>Brahmacariyamacariṁsū</b>ti brahmacariyaṁ vuccati asaddhammasamāpattiyā ārati virati paṭivirati veramaṇī viramaṇaṁ akiriyā akaraṇaṁ anajjhāpatti velāanatikkamo setughāto."
    },
    {
      "id": "cnd21:27.2",
      "pali": "Api ca nippariyāyavasena brahmacariyaṁ vuccati ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "cnd21:27.3",
      "pali": "sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi."
    },
    {
      "id": "cnd21:27.4",
      "pali": "<b>Brahmacariyamacariṁsū</b>ti brahmacariyaṁ cariṁsu acariṁsu samādāya vattiṁsūti—"
    },
    {
      "id": "cnd21:27.5",
      "pali": "brahmacariyamacariṁsu."
    },
    {
      "id": "cnd21:28.1",
      "pali": "<b>Varapaññassa santike</b>ti varapaññassa aggapaññassa seṭṭhapaññassa viseṭṭhapaññassa pāmokkhapaññassa uttamapaññassa pavarapaññassa."
    },
    {
      "id": "cnd21:28.2",
      "pali": "<b>Santike</b>ti santike sāmantā āsanne avidūre upakaṭṭheti—"
    },
    {
      "id": "cnd21:28.3",
      "pali": "varapaññassa santike."
    },
    {
      "id": "cnd21:28.4",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:29.1",
      "pali": "“Te tositā cakkhumatā,"
    },
    {
      "id": "cnd21:29.2",
      "pali": "buddhenādiccabandhunā;"
    },
    {
      "id": "cnd21:29.3",
      "pali": "Brahmacariyamacariṁsu,"
    },
    {
      "id": "cnd21:29.4",
      "pali": "varapaññassa santike”ti."
    },
    {
      "id": "cnd21:30.1",
      "pali": "<b>Ekamekassa pañhassa,</b>"
    },
    {
      "id": "cnd21:30.2",
      "pali": "<b>yathā buddhena desitaṁ;</b>"
    },
    {
      "id": "cnd21:30.3",
      "pali": "<b>Tathā yo paṭipajjeyya,</b>"
    },
    {
      "id": "cnd21:30.4",
      "pali": "<b>gacche pāraṁ apārato. </b>"
    },
    {
      "id": "cnd21:31.1",
      "pali": "<b>Ekamekassa pañhassā</b>ti ekamekassa ajitapañhassa, ekamekassa tissametteyyapañhassa …pe…"
    },
    {
      "id": "cnd21:31.2",
      "pali": "ekamekassa piṅgiyapañhassāti—"
    },
    {
      "id": "cnd21:31.3",
      "pali": "ekamekassa pañhassa."
    },
    {
      "id": "cnd21:32.1",
      "pali": "<b>Yathā buddhena desitan</b>ti."
    },
    {
      "id": "cnd21:32.2",
      "pali": "<b>Buddho</b>ti yo so bhagavā sayambhū …pe…"
    },
    {
      "id": "cnd21:32.3",
      "pali": "sacchikā paññatti, yadidaṁ buddhoti."
    },
    {
      "id": "cnd21:32.4",
      "pali": "<b>Yathā buddhena desitan</b>ti yathā buddhena ācikkhitaṁ desitaṁ paññapitaṁ paṭṭhapitaṁ vivaritaṁ vibhajitaṁ uttānīkataṁ pakāsitanti—"
    },
    {
      "id": "cnd21:32.5",
      "pali": "yathā buddhena desitaṁ."
    },
    {
      "id": "cnd21:33.1",
      "pali": "<b>Tathā yo paṭipajjeyyā</b>ti sammāpaṭipadaṁ anulomapaṭipadaṁ apaccanīkapaṭipadaṁ anvatthapaṭipadaṁ dhammānudhammapaṭipadaṁ paṭipajjeyyāti—"
    },
    {
      "id": "cnd21:33.2",
      "pali": "tathā yo paṭipajjeyya."
    },
    {
      "id": "cnd21:34.1",
      "pali": "<b>Gacche pāraṁ apārato</b>ti pāraṁ vuccati amataṁ nibbānaṁ …pe… nirodho nibbānaṁ;"
    },
    {
      "id": "cnd21:34.2",
      "pali": "apāraṁ vuccanti kilesā ca khandhā ca abhisaṅkhārā ca."
    },
    {
      "id": "cnd21:34.3",
      "pali": "<b>Gacche pāraṁ apārato</b>ti apārato pāraṁ gaccheyya, pāraṁ adhigaccheyya, pāraṁ phasseyya, pāraṁ sacchikareyyāti—"
    },
    {
      "id": "cnd21:34.4",
      "pali": "gacche pāraṁ apārato."
    },
    {
      "id": "cnd21:34.5",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:35.1",
      "pali": "“Ekamekassa pañhassa,"
    },
    {
      "id": "cnd21:35.2",
      "pali": "yathā buddhena desitaṁ;"
    },
    {
      "id": "cnd21:35.3",
      "pali": "Tathā yo paṭipajjeyya,"
    },
    {
      "id": "cnd21:35.4",
      "pali": "gacche pāraṁ apārato”ti."
    },
    {
      "id": "cnd21:36.1",
      "pali": "<b>Apārā pāraṁ gaccheyya,</b>"
    },
    {
      "id": "cnd21:36.2",
      "pali": "<b>bhāvento maggamuttamaṁ;</b>"
    },
    {
      "id": "cnd21:36.3",
      "pali": "<b>Maggo so pāraṁ gamanāya,</b>"
    },
    {
      "id": "cnd21:36.4",
      "pali": "<b>tasmā pārāyanaṁ iti. </b>"
    },
    {
      "id": "cnd21:37.1",
      "pali": "<b>Apārā pāraṁ gaccheyyā</b>ti apāraṁ vuccanti kilesā ca khandhā ca abhisaṅkhārā ca;"
    },
    {
      "id": "cnd21:37.2",
      "pali": "pāraṁ vuccati amataṁ nibbānaṁ …pe…"
    },
    {
      "id": "cnd21:37.3",
      "pali": "taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "cnd21:37.4",
      "pali": "<b>Apārā pāraṁ gaccheyyā</b>ti apārā pāraṁ gaccheyya, pāraṁ adhigaccheyya, pāraṁ phasseyya, pāraṁ sacchikareyyāti—"
    },
    {
      "id": "cnd21:37.5",
      "pali": "apārā pāraṁ gaccheyya."
    },
    {
      "id": "cnd21:38.1",
      "pali": "<b>Bhāvento maggamuttaman</b>ti maggamuttamaṁ vuccati ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "cnd21:38.2",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "cnd21:38.3",
      "pali": "<b>Maggamuttaman</b>ti maggaṁ aggaṁ seṭṭhaṁ viseṭṭhaṁ pāmokkhaṁ uttamaṁ pavaraṁ."
    },
    {
      "id": "cnd21:38.4",
      "pali": "<b>Bhāvento</b>ti bhāvento āsevanto bahulīkarontoti—"
    },
    {
      "id": "cnd21:38.5",
      "pali": "bhāvento maggamuttamaṁ."
    },
    {
      "id": "cnd21:39.1",
      "pali": "<b>Maggo so pāraṁ gamanāyā</b>ti—"
    },
    {
      "id": "cnd21:40.1",
      "pali": "Maggo pantho patho pajjo,"
    },
    {
      "id": "cnd21:40.2",
      "pali": "añjasaṁ vaṭumāyanaṁ;"
    },
    {
      "id": "cnd21:40.3",
      "pali": "Nāvā uttarasetu ca,"
    },
    {
      "id": "cnd21:40.4",
      "pali": "kullo ca bhisi saṅkamo."
    },
    {
      "id": "cnd21:41.1",
      "pali": "<b>Pāraṁ gamanāyā</b>ti pāraṁ gamanāya pāraṁ sampāpanāya pāraṁ samanupāpanāya jarāmaraṇassa taraṇāyāti—"
    },
    {
      "id": "cnd21:41.2",
      "pali": "maggo so pāraṁ gamanāya."
    },
    {
      "id": "cnd21:42.1",
      "pali": "<b>Tasmā pārāyanaṁ itī</b>ti."
    },
    {
      "id": "cnd21:42.2",
      "pali": "<b>Tasmā</b>ti tasmā taṅkāraṇā taṁhetu tappaccayā taṁnidānā."
    },
    {
      "id": "cnd21:42.3",
      "pali": "Pāraṁ vuccati amataṁ nibbānaṁ …pe… nirodho nibbānaṁ."
    },
    {
      "id": "cnd21:42.4",
      "pali": "Ayanaṁ vuccati maggo."
    },
    {
      "id": "cnd21:42.5",
      "pali": "<b>Itī</b>ti padasandhi …pe… padānupubbatāpetaṁ itīti—"
    },
    {
      "id": "cnd21:42.6",
      "pali": "tasmā pārāyanaṁ iti."
    },
    {
      "id": "cnd21:42.7",
      "pali": "Tenetaṁ vuccati—"
    },
    {
      "id": "cnd21:43.1",
      "pali": "“Apārā pāraṁ gaccheyya,"
    },
    {
      "id": "cnd21:43.2",
      "pali": "bhāvento maggamuttamaṁ;"
    },
    {
      "id": "cnd21:43.3",
      "pali": "Maggo so pāraṁ gamanāya,"
    },
    {
      "id": "cnd21:43.4",
      "pali": "tasmā pārāyanaṁ itī”ti."
    },
    {
      "id": "cnd21:43.5",
      "pali": "Pārāyanatthutigāthāniddeso sattarasamo."
    }
  ]
}
