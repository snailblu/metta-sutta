{
  "uid": "ja134",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja134:1.1",
      "pali": "“Ye saññino tepi duggatā,"
    },
    {
      "id": "ja134:1.2",
      "pali": "Yepi asaññino tepi duggatā;"
    },
    {
      "id": "ja134:1.3",
      "pali": "Etaṁ ubhayaṁ vivajjaya,"
    },
    {
      "id": "ja134:1.4",
      "pali": "Taṁ samāpattisukhaṁ anaṅgaṇan”ti."
    },
    {
      "id": "ja134:2.1",
      "pali": "Jhānasodhanajātakaṁ catutthaṁ."
    }
  ]
}
