{
  "uid": "tha-ap88",
  "title": "6 Dutiyaraṁsisaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap88:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap88:1.2",
      "pali": "vākacīradharo ahaṁ;"
    },
    {
      "id": "tha-ap88:1.3",
      "pali": "Caṅkamañca samārūḷho,"
    },
    {
      "id": "tha-ap88:1.4",
      "pali": "nisīdiṁ pācināmukho."
    },
    {
      "id": "tha-ap88:2.1",
      "pali": "Pabbate sugataṁ disvā,"
    },
    {
      "id": "tha-ap88:2.2",
      "pali": "phussaṁ jhānarataṁ tadā;"
    },
    {
      "id": "tha-ap88:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap88:2.4",
      "pali": "raṁsyā cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap88:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap88:3.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap88:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap88:3.4",
      "pali": "raṁsisaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap88:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap88:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap88:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap88:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā raṁsisaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap88:6.1",
      "pali": "Dutiyaraṁsisaññakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
