{
  "uid": "ja160",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja160:1.1",
      "pali": "“Evameva nūna rājānaṁ,"
    },
    {
      "id": "ja160:1.2",
      "pali": "vedehaṁ mithilaggahaṁ;"
    },
    {
      "id": "ja160:1.3",
      "pali": "Assā vahanti ājaññā,"
    },
    {
      "id": "ja160:1.4",
      "pali": "yathā haṁsā vinīlakaṁ”."
    },
    {
      "id": "ja160:2.1",
      "pali": "“Vinīla duggaṁ bhajasi,"
    },
    {
      "id": "ja160:2.2",
      "pali": "abhūmiṁ tāta sevasi;"
    },
    {
      "id": "ja160:2.3",
      "pali": "Gāmantakāni sevassu,"
    },
    {
      "id": "ja160:2.4",
      "pali": "etaṁ mātālayaṁ tavāti."
    },
    {
      "id": "ja160:3.1",
      "pali": "Vinīlajātakaṁ dasamaṁ."
    },
    {
      "id": "ja160:3.2",
      "pali": "Daḷhavaggo paṭhamo."
    },
    {
      "id": "ja160:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja160:5.1",
      "pali": "Varaballika daddara sūkarako,"
    },
    {
      "id": "ja160:5.2",
      "pali": "Uraguttama pañcamabhaggavaro;"
    },
    {
      "id": "ja160:5.3",
      "pali": "Mahatīcamu yāva siṅgālavaro,"
    },
    {
      "id": "ja160:5.4",
      "pali": "Suhanuttama mora vinīlaṁ dasā”ti."
    }
  ]
}
