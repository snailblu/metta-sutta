{
  "uid": "thag3.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.10:1.1",
      "pali": "“Ahu tuyhaṁ pure saddhā,"
    },
    {
      "id": "thag3.10:1.2",
      "pali": "sā te ajja na vijjati;"
    },
    {
      "id": "thag3.10:1.3",
      "pali": "Yaṁ tuyhaṁ tuyhamevetaṁ,"
    },
    {
      "id": "thag3.10:1.4",
      "pali": "natthi duccaritaṁ mama."
    },
    {
      "id": "thag3.10:2.1",
      "pali": "Aniccā hi calā saddhā,"
    },
    {
      "id": "thag3.10:2.2",
      "pali": "evaṁ diṭṭhā hi sā mayā;"
    },
    {
      "id": "thag3.10:2.3",
      "pali": "Rajjantipi virajjanti,"
    },
    {
      "id": "thag3.10:2.4",
      "pali": "tattha kiṁ jiyyate muni."
    },
    {
      "id": "thag3.10:3.1",
      "pali": "Paccati munino bhattaṁ,"
    },
    {
      "id": "thag3.10:3.2",
      "pali": "Thokaṁ thokaṁ kule kule;"
    },
    {
      "id": "thag3.10:3.3",
      "pali": "Piṇḍikāya carissāmi,"
    },
    {
      "id": "thag3.10:3.4",
      "pali": "Atthi jaṅghabalaṁ mamā”ti."
    },
    {
      "id": "thag3.10:3.5",
      "pali": "… Sāṭimattiyo thero …."
    }
  ]
}
