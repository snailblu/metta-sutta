{
  "uid": "ja401",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja401:1.1",
      "pali": "“Paṇṇakaṁ tikhiṇadhāraṁ,"
    },
    {
      "id": "ja401:1.2",
      "pali": "Asiṁ sampannapāyinaṁ;"
    },
    {
      "id": "ja401:1.3",
      "pali": "Parisāyaṁ puriso gilati,"
    },
    {
      "id": "ja401:1.4",
      "pali": "Kiṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:1.5",
      "pali": "Yadaññaṁ dukkaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:1.6",
      "pali": "Taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja401:2.1",
      "pali": "“Gileyya puriso lobhā,"
    },
    {
      "id": "ja401:2.2",
      "pali": "asiṁ sampannapāyinaṁ;"
    },
    {
      "id": "ja401:2.3",
      "pali": "Yo ca vajjā dadāmīti,"
    },
    {
      "id": "ja401:2.4",
      "pali": "taṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:2.5",
      "pali": "Sabbaññaṁ sukaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:2.6",
      "pali": "evaṁ jānāhi maddava”."
    },
    {
      "id": "ja401:3.1",
      "pali": "“Byākāsi āyuro pañhaṁ,"
    },
    {
      "id": "ja401:3.2",
      "pali": "atthaṁ dhammassa kovido;"
    },
    {
      "id": "ja401:3.3",
      "pali": "Pukkusaṁ dāni pucchāmi,"
    },
    {
      "id": "ja401:3.4",
      "pali": "kiṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:3.5",
      "pali": "Yadaññaṁ dukkaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:3.6",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja401:4.1",
      "pali": "“Na vācamupajīvanti,"
    },
    {
      "id": "ja401:4.2",
      "pali": "aphalaṁ giramudīritaṁ;"
    },
    {
      "id": "ja401:4.3",
      "pali": "Yo ca datvā avākayirā,"
    },
    {
      "id": "ja401:4.4",
      "pali": "taṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:4.5",
      "pali": "Sabbaññaṁ sukaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:4.6",
      "pali": "evaṁ jānāhi maddava”."
    },
    {
      "id": "ja401:5.1",
      "pali": "“Byākāsi pukkuso pañhaṁ,"
    },
    {
      "id": "ja401:5.2",
      "pali": "atthaṁ dhammassa kovido;"
    },
    {
      "id": "ja401:5.3",
      "pali": "Senakaṁ dāni pucchāmi,"
    },
    {
      "id": "ja401:5.4",
      "pali": "kiṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:5.5",
      "pali": "Yadaññaṁ dukkaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:5.6",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja401:6.1",
      "pali": "“Dadeyya puriso dānaṁ,"
    },
    {
      "id": "ja401:6.2",
      "pali": "appaṁ vā yadi vā bahuṁ;"
    },
    {
      "id": "ja401:6.3",
      "pali": "Yo ca datvā nānutappe,"
    },
    {
      "id": "ja401:6.4",
      "pali": "taṁ dukkarataraṁ tato;"
    },
    {
      "id": "ja401:6.5",
      "pali": "Sabbaññaṁ sukaraṁ ṭhānaṁ,"
    },
    {
      "id": "ja401:6.6",
      "pali": "evaṁ jānāhi maddava”."
    },
    {
      "id": "ja401:7.1",
      "pali": "“Byākāsi āyuro pañhaṁ,"
    },
    {
      "id": "ja401:7.2",
      "pali": "atho pukkusaporiso;"
    },
    {
      "id": "ja401:7.3",
      "pali": "Sabbe pañhe atibhoti,"
    },
    {
      "id": "ja401:7.4",
      "pali": "yathā bhāsati senako”ti."
    },
    {
      "id": "ja401:8.1",
      "pali": "Paṇṇakajātakaṁ chaṭṭhaṁ."
    }
  ]
}
