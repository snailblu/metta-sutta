{
  "uid": "tha-ap376",
  "title": "4 Paṭṭipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap376:1.1",
      "pali": "“Yadā nibbāyi sambuddho,"
    },
    {
      "id": "tha-ap376:1.2",
      "pali": "mahesī padumuttaro;"
    },
    {
      "id": "tha-ap376:1.3",
      "pali": "Samāgamma janā sabbe,"
    },
    {
      "id": "tha-ap376:1.4",
      "pali": "sarīraṁ nīharanti te."
    },
    {
      "id": "tha-ap376:2.1",
      "pali": "Nīharante sarīramhi,"
    },
    {
      "id": "tha-ap376:2.2",
      "pali": "vajjamānāsu bherisu;"
    },
    {
      "id": "tha-ap376:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap376:2.4",
      "pali": "paṭṭipupphaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap376:3.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap376:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap376:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap376:3.4",
      "pali": "sarīrapūjite phalaṁ."
    },
    {
      "id": "tha-ap376:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap376:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap376:4.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap376:4.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap376:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap376:5.2",
      "pali": "Mama buddhassa santike;"
    },
    {
      "id": "tha-ap376:5.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap376:5.4",
      "pali": "Kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap376:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap376:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap376:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap376:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṭṭipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap376:8.1",
      "pali": "Paṭṭipupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
