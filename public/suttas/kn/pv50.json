{
  "uid": "pv50",
  "title": "15. Seṭṭhiputtapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv50:1.1",
      "pali": "“Saṭṭhivassasahassāni,"
    },
    {
      "id": "pv50:1.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "pv50:1.3",
      "pali": "Niraye paccamānānaṁ,"
    },
    {
      "id": "pv50:1.4",
      "pali": "kadā anto bhavissati."
    },
    {
      "id": "pv50:2.1",
      "pali": "Natthi anto kuto anto,"
    },
    {
      "id": "pv50:2.2",
      "pali": "na anto paṭidissati;"
    },
    {
      "id": "pv50:2.3",
      "pali": "Tathā hi pakataṁ pāpaṁ,"
    },
    {
      "id": "pv50:2.4",
      "pali": "tuyhaṁ mayhañca mārisā."
    },
    {
      "id": "pv50:3.1",
      "pali": "Dujjīvitamajīvamha,"
    },
    {
      "id": "pv50:3.2",
      "pali": "ye sante na dadamhase;"
    },
    {
      "id": "pv50:3.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv50:3.4",
      "pali": "dīpaṁ nākamha attano."
    },
    {
      "id": "pv50:4.1",
      "pali": "Sohaṁ nūna ito gantvā,"
    },
    {
      "id": "pv50:4.2",
      "pali": "yoniṁ laddhāna mānusiṁ;"
    },
    {
      "id": "pv50:4.3",
      "pali": "Vadaññū sīlasampanno,"
    },
    {
      "id": "pv50:4.4",
      "pali": "kāhāmi kusalaṁ bahun”ti."
    },
    {
      "id": "pv50:5.1",
      "pali": "Seṭṭhiputtapetavatthu pannarasamaṁ."
    }
  ]
}
