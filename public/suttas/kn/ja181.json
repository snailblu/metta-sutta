{
  "uid": "ja181",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja181:1.1",
      "pali": "Dhanuggaho asadiso,"
    },
    {
      "id": "ja181:1.2",
      "pali": "rājaputto mahabbalo;"
    },
    {
      "id": "ja181:1.3",
      "pali": "Dūrepātī akkhaṇavedhī,"
    },
    {
      "id": "ja181:1.4",
      "pali": "mahākāyappadālano."
    },
    {
      "id": "ja181:2.1",
      "pali": "Sabbāmitte raṇaṁ katvā,"
    },
    {
      "id": "ja181:2.2",
      "pali": "na ca kañci viheṭhayi;"
    },
    {
      "id": "ja181:2.3",
      "pali": "Bhātaraṁ sotthiṁ katvāna,"
    },
    {
      "id": "ja181:2.4",
      "pali": "saṁyamaṁ ajjhupāgamīti."
    },
    {
      "id": "ja181:3.1",
      "pali": "Asadisajātakaṁ paṭhamaṁ."
    }
  ]
}
