{
  "uid": "thag2.16",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.16:1.1",
      "pali": "“Kāḷī itthī brahatī dhaṅkarūpā,"
    },
    {
      "id": "thag2.16:1.2",
      "pali": "Satthiñca bhetvā aparañca satthiṁ;"
    },
    {
      "id": "thag2.16:1.3",
      "pali": "Bāhañca bhetvā aparañca bāhaṁ,"
    },
    {
      "id": "thag2.16:1.4",
      "pali": "Sīsañca bhetvā dadhithālakaṁva;"
    },
    {
      "id": "thag2.16:1.5",
      "pali": "Esā nisinnā abhisandahitvā."
    },
    {
      "id": "thag2.16:2.1",
      "pali": "Yo ve avidvā upadhiṁ karoti,"
    },
    {
      "id": "thag2.16:2.2",
      "pali": "Punappunaṁ dukkhamupeti mando;"
    },
    {
      "id": "thag2.16:2.3",
      "pali": "Tasmā pajānaṁ upadhiṁ na kayirā,"
    },
    {
      "id": "thag2.16:2.4",
      "pali": "Māhaṁ puna bhinnasiro sayissan”ti."
    },
    {
      "id": "thag2.16:2.5",
      "pali": "… Mahākāḷo thero …."
    }
  ]
}
