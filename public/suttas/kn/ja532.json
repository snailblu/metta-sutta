{
  "uid": "ja532",
  "title": "Kusavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja532:1.1",
      "pali": "“Devatā nusi gandhabbo,"
    },
    {
      "id": "ja532:1.2",
      "pali": "adu sakko purindado;"
    },
    {
      "id": "ja532:1.3",
      "pali": "Manussabhūto iddhimā,"
    },
    {
      "id": "ja532:1.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja532:2.1",
      "pali": "“Nāpi devo na gandhabbo,"
    },
    {
      "id": "ja532:2.2",
      "pali": "nāpi sakko purindado;"
    },
    {
      "id": "ja532:2.3",
      "pali": "Manussabhūto iddhimā,"
    },
    {
      "id": "ja532:2.4",
      "pali": "evaṁ jānāhi bhāradha”."
    },
    {
      "id": "ja532:3.1",
      "pali": "“Katarūpamidaṁ bhoto,"
    },
    {
      "id": "ja532:3.2",
      "pali": "veyyāvaccaṁ anappakaṁ;"
    },
    {
      "id": "ja532:3.3",
      "pali": "Devamhi vassamānamhi,"
    },
    {
      "id": "ja532:3.4",
      "pali": "anovassaṁ bhavaṁ akā."
    },
    {
      "id": "ja532:4.1",
      "pali": "Tato vātātape ghore,"
    },
    {
      "id": "ja532:4.2",
      "pali": "sītacchāyaṁ bhavaṁ akā;"
    },
    {
      "id": "ja532:4.3",
      "pali": "Tato amittamajjhesu,"
    },
    {
      "id": "ja532:4.4",
      "pali": "saratāṇaṁ bhavaṁ akā."
    },
    {
      "id": "ja532:5.1",
      "pali": "Tato phītāni raṭṭhāni,"
    },
    {
      "id": "ja532:5.2",
      "pali": "vasino te bhavaṁ akā;"
    },
    {
      "id": "ja532:5.3",
      "pali": "Tato ekasataṁ khatye,"
    },
    {
      "id": "ja532:5.4",
      "pali": "anuyante bhavaṁ akā."
    },
    {
      "id": "ja532:6.1",
      "pali": "Patītāssu mayaṁ bhoto,"
    },
    {
      "id": "ja532:6.2",
      "pali": "Vada taṁ bhañjamicchasi;"
    },
    {
      "id": "ja532:6.3",
      "pali": "Hatthiyānaṁ assarathaṁ,"
    },
    {
      "id": "ja532:6.4",
      "pali": "Nāriyo ca alaṅkatā;"
    },
    {
      "id": "ja532:6.5",
      "pali": "Nivesanāni rammāni,"
    },
    {
      "id": "ja532:6.6",
      "pali": "Mayaṁ bhoto dadāmase."
    },
    {
      "id": "ja532:7.1",
      "pali": "Atha vaṅge vā magadhe,"
    },
    {
      "id": "ja532:7.2",
      "pali": "mayaṁ bhoto dadāmase;"
    },
    {
      "id": "ja532:7.3",
      "pali": "Atha vā assakāvantī,"
    },
    {
      "id": "ja532:7.4",
      "pali": "sumanā damma te mayaṁ."
    },
    {
      "id": "ja532:8.1",
      "pali": "Upaḍḍhaṁ vāpi rajjassa,"
    },
    {
      "id": "ja532:8.2",
      "pali": "mayaṁ bhoto dadāmase;"
    },
    {
      "id": "ja532:8.3",
      "pali": "Sace te attho rajjena,"
    },
    {
      "id": "ja532:8.4",
      "pali": "anusāsa yadicchasi”."
    },
    {
      "id": "ja532:9.1",
      "pali": "“Na me atthopi rajjena,"
    },
    {
      "id": "ja532:9.2",
      "pali": "nagarena dhanena vā;"
    },
    {
      "id": "ja532:9.3",
      "pali": "Athopi janapadena,"
    },
    {
      "id": "ja532:9.4",
      "pali": "attho mayhaṁ na vijjati."
    },
    {
      "id": "ja532:10.1",
      "pali": "Bhotova raṭṭhe vijite,"
    },
    {
      "id": "ja532:10.2",
      "pali": "araññe atthi assamo;"
    },
    {
      "id": "ja532:10.3",
      "pali": "Pitā mayhaṁ janettī ca,"
    },
    {
      "id": "ja532:10.4",
      "pali": "ubho sammanti assame."
    },
    {
      "id": "ja532:11.1",
      "pali": "Tesāhaṁ pubbācariyesu,"
    },
    {
      "id": "ja532:11.2",
      "pali": "Puññaṁ na labhāmi kātave;"
    },
    {
      "id": "ja532:11.3",
      "pali": "Bhavantaṁ ajjhāvaraṁ katvā,"
    },
    {
      "id": "ja532:11.4",
      "pali": "Soṇaṁ yācemu saṁvaraṁ”."
    },
    {
      "id": "ja532:12.1",
      "pali": "“Karomi te taṁ vacanaṁ,"
    },
    {
      "id": "ja532:12.2",
      "pali": "yaṁ maṁ bhaṇasi brāhmaṇa;"
    },
    {
      "id": "ja532:12.3",
      "pali": "Etañca kho no akkhāhi,"
    },
    {
      "id": "ja532:12.4",
      "pali": "kīvanto hontu yācakā”."
    },
    {
      "id": "ja532:13.1",
      "pali": "“Parosataṁ jānapadā,"
    },
    {
      "id": "ja532:13.2",
      "pali": "mahāsālā ca brāhmaṇā;"
    },
    {
      "id": "ja532:13.3",
      "pali": "Ime ca khattiyā sabbe,"
    },
    {
      "id": "ja532:13.4",
      "pali": "abhijātā yasassino;"
    },
    {
      "id": "ja532:13.5",
      "pali": "Bhavañca rājā manojo,"
    },
    {
      "id": "ja532:13.6",
      "pali": "alaṁ hessanti yācakā”."
    },
    {
      "id": "ja532:14.1",
      "pali": "“Hatthī asse ca yojentu,"
    },
    {
      "id": "ja532:14.2",
      "pali": "rathaṁ sannayha sārathi;"
    },
    {
      "id": "ja532:14.3",
      "pali": "Ābandhanāni gaṇhātha,"
    },
    {
      "id": "ja532:14.4",
      "pali": "pādāsussārayaddhaje;"
    },
    {
      "id": "ja532:14.5",
      "pali": "Assamaṁ taṁ gamissāmi,"
    },
    {
      "id": "ja532:14.6",
      "pali": "yattha sammati kosiyo”."
    },
    {
      "id": "ja532:15.1",
      "pali": "Tato ca rājā pāyāsi,"
    },
    {
      "id": "ja532:15.2",
      "pali": "senāya caturaṅginī;"
    },
    {
      "id": "ja532:15.3",
      "pali": "Agamā assamaṁ rammaṁ,"
    },
    {
      "id": "ja532:15.4",
      "pali": "yattha sammati kosiyo."
    },
    {
      "id": "ja532:16.1",
      "pali": "“Kassa kādambayo kājo,"
    },
    {
      "id": "ja532:16.2",
      "pali": "vehāsaṁ caturaṅgulaṁ;"
    },
    {
      "id": "ja532:16.3",
      "pali": "Aṁsaṁ asamphusaṁ eti,"
    },
    {
      "id": "ja532:16.4",
      "pali": "udahārāya gacchato”."
    },
    {
      "id": "ja532:17.1",
      "pali": "“Ahaṁ soṇo mahārāja,"
    },
    {
      "id": "ja532:17.2",
      "pali": "tāpaso sahitabbato;"
    },
    {
      "id": "ja532:17.3",
      "pali": "Bharāmi mātāpitaro,"
    },
    {
      "id": "ja532:17.4",
      "pali": "rattindivamatandito."
    },
    {
      "id": "ja532:18.1",
      "pali": "Vane phalañca mūlañca,"
    },
    {
      "id": "ja532:18.2",
      "pali": "āharitvā disampati;"
    },
    {
      "id": "ja532:18.3",
      "pali": "Posemi mātāpitaro,"
    },
    {
      "id": "ja532:18.4",
      "pali": "pubbe katamanussaraṁ”."
    },
    {
      "id": "ja532:19.1",
      "pali": "“Icchāma assamaṁ gantuṁ,"
    },
    {
      "id": "ja532:19.2",
      "pali": "yattha sammati kosiyo;"
    },
    {
      "id": "ja532:19.3",
      "pali": "Maggaṁ no soṇa akkhāhi,"
    },
    {
      "id": "ja532:19.4",
      "pali": "yena gacchemu assamaṁ”."
    },
    {
      "id": "ja532:20.1",
      "pali": "“Ayaṁ ekapadī rāja,"
    },
    {
      "id": "ja532:20.2",
      "pali": "yenetaṁ meghasannibhaṁ;"
    },
    {
      "id": "ja532:20.3",
      "pali": "Koviḷārehi sañchannaṁ,"
    },
    {
      "id": "ja532:20.4",
      "pali": "ettha sammati kosiyo”."
    },
    {
      "id": "ja532:21.1",
      "pali": "Idaṁ vatvāna pakkāmi,"
    },
    {
      "id": "ja532:21.2",
      "pali": "taramāno mahāisi;"
    },
    {
      "id": "ja532:21.3",
      "pali": "Vehāse antalikkhasmiṁ,"
    },
    {
      "id": "ja532:21.4",
      "pali": "anusāsitvāna khattiye."
    },
    {
      "id": "ja532:22.1",
      "pali": "Assamaṁ parimajjitvā,"
    },
    {
      "id": "ja532:22.2",
      "pali": "paññāpetvāna āsanaṁ;"
    },
    {
      "id": "ja532:22.3",
      "pali": "Paṇṇasālaṁ pavisitvā,"
    },
    {
      "id": "ja532:22.4",
      "pali": "pitaraṁ paṭibodhayi."
    },
    {
      "id": "ja532:23.1",
      "pali": "“Ime āyanti rājāno,"
    },
    {
      "id": "ja532:23.2",
      "pali": "abhijātā yasassino;"
    },
    {
      "id": "ja532:23.3",
      "pali": "Assamā nikkhamitvāna,"
    },
    {
      "id": "ja532:23.4",
      "pali": "nisīda tvaṁ mahāise”."
    },
    {
      "id": "ja532:24.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja532:24.2",
      "pali": "taramāno mahāisi;"
    },
    {
      "id": "ja532:24.3",
      "pali": "Assamā nikkhamitvāna,"
    },
    {
      "id": "ja532:24.4",
      "pali": "sadvāramhi upāvisi."
    },
    {
      "id": "ja532:25.1",
      "pali": "Tañca disvāna āyantaṁ,"
    },
    {
      "id": "ja532:25.2",
      "pali": "jalantaṁriva tejasā;"
    },
    {
      "id": "ja532:25.3",
      "pali": "Khatyasaṅghaparibyūḷhaṁ,"
    },
    {
      "id": "ja532:25.4",
      "pali": "kosiyo etadabravi."
    },
    {
      "id": "ja532:26.1",
      "pali": "Kassa bherī mudiṅgā ca,"
    },
    {
      "id": "ja532:26.2",
      "pali": "saṅkhā paṇavadindimā;"
    },
    {
      "id": "ja532:26.3",
      "pali": "Purato paṭipannāni,"
    },
    {
      "id": "ja532:26.4",
      "pali": "hāsayantā rathesabhaṁ."
    },
    {
      "id": "ja532:27.1",
      "pali": "Kassa kañcanapaṭṭena,"
    },
    {
      "id": "ja532:27.2",
      "pali": "puthunā vijjuvaṇṇinā;"
    },
    {
      "id": "ja532:27.3",
      "pali": "Yuvā kalāpasannaddho,"
    },
    {
      "id": "ja532:27.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:28.1",
      "pali": "Ukkāmukhapahaṭṭhaṁva,"
    },
    {
      "id": "ja532:28.2",
      "pali": "khadiraṅgārasannibhaṁ;"
    },
    {
      "id": "ja532:28.3",
      "pali": "Mukhañca rucirā bhāti,"
    },
    {
      "id": "ja532:28.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:29.1",
      "pali": "Kassa paggahitaṁ chattaṁ,"
    },
    {
      "id": "ja532:29.2",
      "pali": "sasalākaṁ manoramaṁ;"
    },
    {
      "id": "ja532:29.3",
      "pali": "Ādiccaraṁsāvaraṇaṁ,"
    },
    {
      "id": "ja532:29.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:30.1",
      "pali": "Kassa aṅgaṁ pariggayha,"
    },
    {
      "id": "ja532:30.2",
      "pali": "vāḷabījanimuttamaṁ;"
    },
    {
      "id": "ja532:30.3",
      "pali": "Caranti varapuññassa,"
    },
    {
      "id": "ja532:30.4",
      "pali": "hatthikkhandhena āyato."
    },
    {
      "id": "ja532:31.1",
      "pali": "Kassa setāni chattāni,"
    },
    {
      "id": "ja532:31.2",
      "pali": "ājānīyā ca vammitā;"
    },
    {
      "id": "ja532:31.3",
      "pali": "Samantā parikīrenti,"
    },
    {
      "id": "ja532:31.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:32.1",
      "pali": "Kassa ekasataṁ khatyā,"
    },
    {
      "id": "ja532:32.2",
      "pali": "anuyantā yasassino;"
    },
    {
      "id": "ja532:32.3",
      "pali": "Samantānupariyanti,"
    },
    {
      "id": "ja532:32.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:33.1",
      "pali": "Hatthi assaratha patti,"
    },
    {
      "id": "ja532:33.2",
      "pali": "senā ca caturaṅginī;"
    },
    {
      "id": "ja532:33.3",
      "pali": "Samantānupariyanti,"
    },
    {
      "id": "ja532:33.4",
      "pali": "ko eti siriyā jalaṁ."
    },
    {
      "id": "ja532:34.1",
      "pali": "Kassesā mahatī senā,"
    },
    {
      "id": "ja532:34.2",
      "pali": "piṭṭhito anuvattati;"
    },
    {
      "id": "ja532:34.3",
      "pali": "Akkhobhaṇī apariyantā,"
    },
    {
      "id": "ja532:34.4",
      "pali": "sāgarasseva ūmiyo."
    },
    {
      "id": "ja532:35.1",
      "pali": "Rājābhirājā manojo,"
    },
    {
      "id": "ja532:35.2",
      "pali": "indova jayataṁ pati;"
    },
    {
      "id": "ja532:35.3",
      "pali": "Nandassajjhāvaraṁ eti,"
    },
    {
      "id": "ja532:35.4",
      "pali": "assamaṁ brahmacārinaṁ."
    },
    {
      "id": "ja532:36.1",
      "pali": "Tassesā mahatī senā,"
    },
    {
      "id": "ja532:36.2",
      "pali": "piṭṭhito anuvattati;"
    },
    {
      "id": "ja532:36.3",
      "pali": "Akkhobhaṇī apariyantā,"
    },
    {
      "id": "ja532:36.4",
      "pali": "sāgarasseva ūmiyo."
    },
    {
      "id": "ja532:37.1",
      "pali": "Anulittā candanena,"
    },
    {
      "id": "ja532:37.2",
      "pali": "kāsikuttamadhārino;"
    },
    {
      "id": "ja532:37.3",
      "pali": "Sabbe pañjalikā hutvā,"
    },
    {
      "id": "ja532:37.4",
      "pali": "isīnaṁ ajjhupāgamuṁ."
    },
    {
      "id": "ja532:38.1",
      "pali": "“Kacci nu bhoto kusalaṁ,"
    },
    {
      "id": "ja532:38.2",
      "pali": "kacci bhoto anāmayaṁ;"
    },
    {
      "id": "ja532:38.3",
      "pali": "Kacci uñchena yāpetha,"
    },
    {
      "id": "ja532:38.4",
      "pali": "kacci mūlaphalā bahū."
    },
    {
      "id": "ja532:39.1",
      "pali": "Kacci ḍaṁsā makasā ca,"
    },
    {
      "id": "ja532:39.2",
      "pali": "appameva sarīsapā;"
    },
    {
      "id": "ja532:39.3",
      "pali": "Vane vāḷamigākiṇṇe,"
    },
    {
      "id": "ja532:39.4",
      "pali": "kacci hiṁsā na vijjati”."
    },
    {
      "id": "ja532:40.1",
      "pali": "“Kusalañceva no rāja,"
    },
    {
      "id": "ja532:40.2",
      "pali": "atho rāja anāmayaṁ;"
    },
    {
      "id": "ja532:40.3",
      "pali": "Atho uñchena yāpema,"
    },
    {
      "id": "ja532:40.4",
      "pali": "atho mūlaphalā bahū."
    },
    {
      "id": "ja532:41.1",
      "pali": "Atho ḍaṁsā makasā ca,"
    },
    {
      "id": "ja532:41.2",
      "pali": "appameva sarīsapā;"
    },
    {
      "id": "ja532:41.3",
      "pali": "Vane vāḷamigākiṇṇe,"
    },
    {
      "id": "ja532:41.4",
      "pali": "hiṁsā mayhaṁ na vijjati."
    },
    {
      "id": "ja532:42.1",
      "pali": "Bahūni vassapūgāni,"
    },
    {
      "id": "ja532:42.2",
      "pali": "assame sammataṁ idha;"
    },
    {
      "id": "ja532:42.3",
      "pali": "Nābhijānāmi uppannaṁ,"
    },
    {
      "id": "ja532:42.4",
      "pali": "ābādhaṁ amanoramaṁ."
    },
    {
      "id": "ja532:43.1",
      "pali": "Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja532:43.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja532:43.3",
      "pali": "Issarosi anuppatto,"
    },
    {
      "id": "ja532:43.4",
      "pali": "yaṁ idhatthi pavedaya."
    },
    {
      "id": "ja532:44.1",
      "pali": "Tindukāni piyālāni,"
    },
    {
      "id": "ja532:44.2",
      "pali": "madhuke kāsumāriyo;"
    },
    {
      "id": "ja532:44.3",
      "pali": "Phalāni khuddakappāni,"
    },
    {
      "id": "ja532:44.4",
      "pali": "bhuñja rāja varaṁ varaṁ."
    },
    {
      "id": "ja532:45.1",
      "pali": "Idampi pānīyaṁ sītaṁ,"
    },
    {
      "id": "ja532:45.2",
      "pali": "ābhataṁ girigabbharā;"
    },
    {
      "id": "ja532:45.3",
      "pali": "Tato piva mahārāja,"
    },
    {
      "id": "ja532:45.4",
      "pali": "sace tvaṁ abhikaṅkhasi”."
    },
    {
      "id": "ja532:46.1",
      "pali": "“Paṭiggahitaṁ yaṁ dinnaṁ,"
    },
    {
      "id": "ja532:46.2",
      "pali": "sabbassa agghiyaṁ kataṁ;"
    },
    {
      "id": "ja532:46.3",
      "pali": "Nandassāpi nisāmetha,"
    },
    {
      "id": "ja532:46.4",
      "pali": "vacanaṁ so pavakkhati."
    },
    {
      "id": "ja532:47.1",
      "pali": "Ajjhāvaramhā nandassa,"
    },
    {
      "id": "ja532:47.2",
      "pali": "bhoto santikamāgatā;"
    },
    {
      "id": "ja532:47.3",
      "pali": "Suṇātu bhavaṁ vacanaṁ,"
    },
    {
      "id": "ja532:47.4",
      "pali": "nandassa parisāya ca”."
    },
    {
      "id": "ja532:48.1",
      "pali": "“Parosataṁ jānapadā,"
    },
    {
      "id": "ja532:48.2",
      "pali": "mahāsālā ca brāhmaṇā;"
    },
    {
      "id": "ja532:48.3",
      "pali": "Ime ca khattiyā sabbe,"
    },
    {
      "id": "ja532:48.4",
      "pali": "abhijātā yasassino;"
    },
    {
      "id": "ja532:48.5",
      "pali": "Bhavañca rājā manojo,"
    },
    {
      "id": "ja532:48.6",
      "pali": "anumaññantu me vaco."
    },
    {
      "id": "ja532:49.1",
      "pali": "Ye ca santi samītāro,"
    },
    {
      "id": "ja532:49.2",
      "pali": "yakkhāni idha massame;"
    },
    {
      "id": "ja532:49.3",
      "pali": "Araññe bhūtabhabyāni,"
    },
    {
      "id": "ja532:49.4",
      "pali": "suṇantu vacanaṁ mama."
    },
    {
      "id": "ja532:50.1",
      "pali": "Namo katvāna bhūtānaṁ,"
    },
    {
      "id": "ja532:50.2",
      "pali": "isiṁ vakkhāmi subbataṁ;"
    },
    {
      "id": "ja532:50.3",
      "pali": "So tyāhaṁ dakkhiṇā bāhu,"
    },
    {
      "id": "ja532:50.4",
      "pali": "tava kosiya sammato."
    },
    {
      "id": "ja532:51.1",
      "pali": "Pitaraṁ me janettiñca,"
    },
    {
      "id": "ja532:51.2",
      "pali": "bhattukāmassa me sato;"
    },
    {
      "id": "ja532:51.3",
      "pali": "Vīra puññamidaṁ ṭhānaṁ,"
    },
    {
      "id": "ja532:51.4",
      "pali": "mā maṁ kosiya vāraya."
    },
    {
      "id": "ja532:52.1",
      "pali": "Sabbhi hetaṁ upaññātaṁ,"
    },
    {
      "id": "ja532:52.2",
      "pali": "mametaṁ upanissaja;"
    },
    {
      "id": "ja532:52.3",
      "pali": "Uṭṭhānapāricariyāya,"
    },
    {
      "id": "ja532:52.4",
      "pali": "dīgharattaṁ tayā kataṁ;"
    },
    {
      "id": "ja532:52.5",
      "pali": "Mātāpitūsu puññāni,"
    },
    {
      "id": "ja532:52.6",
      "pali": "mama lokadado bhava."
    },
    {
      "id": "ja532:53.1",
      "pali": "Tatheva santi manujā,"
    },
    {
      "id": "ja532:53.2",
      "pali": "dhamme dhammapadaṁ vidū;"
    },
    {
      "id": "ja532:53.3",
      "pali": "Maggo saggassa lokassa,"
    },
    {
      "id": "ja532:53.4",
      "pali": "yathā jānāsi tvaṁ ise."
    },
    {
      "id": "ja532:54.1",
      "pali": "Uṭṭhānapāricariyāya,"
    },
    {
      "id": "ja532:54.2",
      "pali": "mātāpitusukhāvahaṁ;"
    },
    {
      "id": "ja532:54.3",
      "pali": "Taṁ maṁ puññā nivāreti,"
    },
    {
      "id": "ja532:54.4",
      "pali": "ariyamaggāvaro naro”."
    },
    {
      "id": "ja532:55.1",
      "pali": "“Suṇantu bhonto vacanaṁ,"
    },
    {
      "id": "ja532:55.2",
      "pali": "bhāturajjhāvarā mama;"
    },
    {
      "id": "ja532:55.3",
      "pali": "Kulavaṁsaṁ mahārāja,"
    },
    {
      "id": "ja532:55.4",
      "pali": "porāṇaṁ parihāpayaṁ;"
    },
    {
      "id": "ja532:55.5",
      "pali": "Adhammacārī jeṭṭhesu,"
    },
    {
      "id": "ja532:55.6",
      "pali": "nirayaṁ sopapajjati."
    },
    {
      "id": "ja532:56.1",
      "pali": "Ye ca dhammassa kusalā,"
    },
    {
      "id": "ja532:56.2",
      "pali": "porāṇassa disampati;"
    },
    {
      "id": "ja532:56.3",
      "pali": "Cārittena ca sampannā,"
    },
    {
      "id": "ja532:56.4",
      "pali": "na te gacchanti duggatiṁ."
    },
    {
      "id": "ja532:57.1",
      "pali": "Mātā pitā ca bhātā ca,"
    },
    {
      "id": "ja532:57.2",
      "pali": "bhaginī ñātibandhavā;"
    },
    {
      "id": "ja532:57.3",
      "pali": "Sabbe jeṭṭhassa te bhārā,"
    },
    {
      "id": "ja532:57.4",
      "pali": "evaṁ jānāhi bhāradha."
    },
    {
      "id": "ja532:58.1",
      "pali": "Ādiyitvā garuṁ bhāraṁ,"
    },
    {
      "id": "ja532:58.2",
      "pali": "nāviko viya ussahe;"
    },
    {
      "id": "ja532:58.3",
      "pali": "Dhammañca nappamajjāmi,"
    },
    {
      "id": "ja532:58.4",
      "pali": "jeṭṭho casmi rathesabha”."
    },
    {
      "id": "ja532:59.1",
      "pali": "“Adhigamā tame ñāṇaṁ,"
    },
    {
      "id": "ja532:59.2",
      "pali": "Jālaṁva jātavedato;"
    },
    {
      "id": "ja532:59.3",
      "pali": "Evameva no bhavaṁ dhammaṁ,"
    },
    {
      "id": "ja532:59.4",
      "pali": "Kosiyo pavidaṁsayi."
    },
    {
      "id": "ja532:60.1",
      "pali": "Yathā udayamādicco,"
    },
    {
      "id": "ja532:60.2",
      "pali": "Vāsudevo pabhaṅkaro;"
    },
    {
      "id": "ja532:60.3",
      "pali": "Pāṇīnaṁ pavidaṁseti,"
    },
    {
      "id": "ja532:60.4",
      "pali": "Rūpaṁ kalyāṇapāpakaṁ;"
    },
    {
      "id": "ja532:60.5",
      "pali": "Evameva no bhavaṁ dhammaṁ,"
    },
    {
      "id": "ja532:60.6",
      "pali": "Kosiyo pavidaṁsayi”."
    },
    {
      "id": "ja532:61.1",
      "pali": "“Evaṁ me yācamānassa,"
    },
    {
      "id": "ja532:61.2",
      "pali": "añjaliṁ nāvabujjhatha;"
    },
    {
      "id": "ja532:61.3",
      "pali": "Tava paddhacaro hessaṁ,"
    },
    {
      "id": "ja532:61.4",
      "pali": "vuṭṭhito paricārako”."
    },
    {
      "id": "ja532:62.1",
      "pali": "“Addhā nanda vijānāsi,"
    },
    {
      "id": "ja532:62.2",
      "pali": "Saddhammaṁ sabbhi desitaṁ;"
    },
    {
      "id": "ja532:62.3",
      "pali": "Ariyo ariyasamācāro,"
    },
    {
      "id": "ja532:62.4",
      "pali": "Bāḷhaṁ tvaṁ mama ruccasi."
    },
    {
      "id": "ja532:63.1",
      "pali": "Bhavantaṁ vadāmi bhotiñca,"
    },
    {
      "id": "ja532:63.2",
      "pali": "suṇātha vacanaṁ mama;"
    },
    {
      "id": "ja532:63.3",
      "pali": "Nāyaṁ bhāro bhāramato,"
    },
    {
      "id": "ja532:63.4",
      "pali": "ahu mayhaṁ kudācanaṁ."
    },
    {
      "id": "ja532:64.1",
      "pali": "Taṁ maṁ upaṭṭhitaṁ santaṁ,"
    },
    {
      "id": "ja532:64.2",
      "pali": "mātāpitusukhāvahaṁ;"
    },
    {
      "id": "ja532:64.3",
      "pali": "Nando ajjhāvaraṁ katvā,"
    },
    {
      "id": "ja532:64.4",
      "pali": "upaṭṭhānāya yācati."
    },
    {
      "id": "ja532:65.1",
      "pali": "Yo ve icchati kāmena,"
    },
    {
      "id": "ja532:65.2",
      "pali": "santānaṁ brahmacārinaṁ;"
    },
    {
      "id": "ja532:65.3",
      "pali": "Nandaṁ vo varatha eko,"
    },
    {
      "id": "ja532:65.4",
      "pali": "kaṁ nando upatiṭṭhatu”."
    },
    {
      "id": "ja532:66.1",
      "pali": "“Tayā tāta anuññātā,"
    },
    {
      "id": "ja532:66.2",
      "pali": "soṇa taṁ nissitā mayaṁ;"
    },
    {
      "id": "ja532:66.3",
      "pali": "Upaghātuṁ labhe nandaṁ,"
    },
    {
      "id": "ja532:66.4",
      "pali": "muddhani brahmacārinaṁ."
    },
    {
      "id": "ja532:67.1",
      "pali": "Assatthasseva taruṇaṁ,"
    },
    {
      "id": "ja532:67.2",
      "pali": "pavāḷaṁ māluteritaṁ;"
    },
    {
      "id": "ja532:67.3",
      "pali": "Cirassaṁ nandaṁ disvāna,"
    },
    {
      "id": "ja532:67.4",
      "pali": "hadayaṁ me pavedhati."
    },
    {
      "id": "ja532:68.1",
      "pali": "Yadā suttāpi supine,"
    },
    {
      "id": "ja532:68.2",
      "pali": "nandaṁ passāmi āgataṁ;"
    },
    {
      "id": "ja532:68.3",
      "pali": "Udaggā sumanā homi,"
    },
    {
      "id": "ja532:68.4",
      "pali": "nando no āgato ayaṁ."
    },
    {
      "id": "ja532:69.1",
      "pali": "Yadā ca paṭibujjhitvā,"
    },
    {
      "id": "ja532:69.2",
      "pali": "nandaṁ passāmi nāgataṁ;"
    },
    {
      "id": "ja532:69.3",
      "pali": "Bhiyyo āvisatī soko,"
    },
    {
      "id": "ja532:69.4",
      "pali": "domanassañcanappakaṁ."
    },
    {
      "id": "ja532:70.1",
      "pali": "Sāhaṁ ajja cirassampi,"
    },
    {
      "id": "ja532:70.2",
      "pali": "nandaṁ passāmi āgataṁ;"
    },
    {
      "id": "ja532:70.3",
      "pali": "Bhattucca mayhañca piyo,"
    },
    {
      "id": "ja532:70.4",
      "pali": "nando no pāvisī gharaṁ."
    },
    {
      "id": "ja532:71.1",
      "pali": "Pitupi nando suppiyo,"
    },
    {
      "id": "ja532:71.2",
      "pali": "Yaṁ nando nappavase gharā;"
    },
    {
      "id": "ja532:71.3",
      "pali": "Labhatū tāta nando taṁ,"
    },
    {
      "id": "ja532:71.4",
      "pali": "Maṁ nando upatiṭṭhatu”."
    },
    {
      "id": "ja532:72.1",
      "pali": "“Anukampikā patiṭṭhā ca,"
    },
    {
      "id": "ja532:72.2",
      "pali": "pubbe rasadadī ca no;"
    },
    {
      "id": "ja532:72.3",
      "pali": "Maggo saggassa lokassa,"
    },
    {
      "id": "ja532:72.4",
      "pali": "mātā taṁ varate ise."
    },
    {
      "id": "ja532:73.1",
      "pali": "Pubbe rasadadī gottī,"
    },
    {
      "id": "ja532:73.2",
      "pali": "mātā puññūpasaṁhitā;"
    },
    {
      "id": "ja532:73.3",
      "pali": "Maggo saggassa lokassa,"
    },
    {
      "id": "ja532:73.4",
      "pali": "mātā taṁ varate ise”."
    },
    {
      "id": "ja532:74.1",
      "pali": "“Ākaṅkhamānā puttaphalaṁ,"
    },
    {
      "id": "ja532:74.2",
      "pali": "devatāya namassati;"
    },
    {
      "id": "ja532:74.3",
      "pali": "Nakkhattāni ca pucchati,"
    },
    {
      "id": "ja532:74.4",
      "pali": "utusaṁvaccharāni ca."
    },
    {
      "id": "ja532:75.1",
      "pali": "Tassā utumhi nhātāya,"
    },
    {
      "id": "ja532:75.2",
      "pali": "hoti gabbhassa vokkamo;"
    },
    {
      "id": "ja532:75.3",
      "pali": "Tena dohaḷinī hoti,"
    },
    {
      "id": "ja532:75.4",
      "pali": "suhadā tena vuccati."
    },
    {
      "id": "ja532:76.1",
      "pali": "Saṁvaccharaṁ vā ūnaṁ vā,"
    },
    {
      "id": "ja532:76.2",
      "pali": "pariharitvā vijāyati;"
    },
    {
      "id": "ja532:76.3",
      "pali": "Tena sā janayantīti,"
    },
    {
      "id": "ja532:76.4",
      "pali": "janetti tena vuccati."
    },
    {
      "id": "ja532:77.1",
      "pali": "Thanakhīrena gītena,"
    },
    {
      "id": "ja532:77.2",
      "pali": "aṅgapāvuraṇena ca;"
    },
    {
      "id": "ja532:77.3",
      "pali": "Rodantaṁ puttaṁ toseti,"
    },
    {
      "id": "ja532:77.4",
      "pali": "tosentī tena vuccati."
    },
    {
      "id": "ja532:78.1",
      "pali": "Tato vātātape ghore,"
    },
    {
      "id": "ja532:78.2",
      "pali": "mamaṁ katvā udikkhati;"
    },
    {
      "id": "ja532:78.3",
      "pali": "Dārakaṁ appajānantaṁ,"
    },
    {
      "id": "ja532:78.4",
      "pali": "posentī tena vuccati."
    },
    {
      "id": "ja532:79.1",
      "pali": "Yañca mātudhanaṁ hoti,"
    },
    {
      "id": "ja532:79.2",
      "pali": "yañca hoti pituddhanaṁ;"
    },
    {
      "id": "ja532:79.3",
      "pali": "Ubhayampetassa gopeti,"
    },
    {
      "id": "ja532:79.4",
      "pali": "api puttassa no siyā."
    },
    {
      "id": "ja532:80.1",
      "pali": "Evaṁ putta aduṁ putta,"
    },
    {
      "id": "ja532:80.2",
      "pali": "iti mātā vihaññati;"
    },
    {
      "id": "ja532:80.3",
      "pali": "Pamattaṁ paradāresu,"
    },
    {
      "id": "ja532:80.4",
      "pali": "nisīthe pattayobbane;"
    },
    {
      "id": "ja532:80.5",
      "pali": "Sāyaṁ puttaṁ anāyantaṁ,"
    },
    {
      "id": "ja532:80.6",
      "pali": "iti mātā vihaññati."
    },
    {
      "id": "ja532:81.1",
      "pali": "Evaṁ kicchā bhato poso,"
    },
    {
      "id": "ja532:81.2",
      "pali": "mātu aparicārako;"
    },
    {
      "id": "ja532:81.3",
      "pali": "Mātari micchā caritvāna,"
    },
    {
      "id": "ja532:81.4",
      "pali": "nirayaṁ sopapajjati."
    },
    {
      "id": "ja532:82.1",
      "pali": "Evaṁ kicchā bhato poso,"
    },
    {
      "id": "ja532:82.2",
      "pali": "pitu aparicārako;"
    },
    {
      "id": "ja532:82.3",
      "pali": "Pitari micchā caritvāna,"
    },
    {
      "id": "ja532:82.4",
      "pali": "nirayaṁ sopapajjati."
    },
    {
      "id": "ja532:83.1",
      "pali": "Dhanāpi dhanakāmānaṁ,"
    },
    {
      "id": "ja532:83.2",
      "pali": "Nassati iti me sutaṁ;"
    },
    {
      "id": "ja532:83.3",
      "pali": "Mātaraṁ aparicaritvāna,"
    },
    {
      "id": "ja532:83.4",
      "pali": "Kicchaṁ vā so nigacchati."
    },
    {
      "id": "ja532:84.1",
      "pali": "Dhanāpi dhanakāmānaṁ,"
    },
    {
      "id": "ja532:84.2",
      "pali": "Nassati iti me sutaṁ;"
    },
    {
      "id": "ja532:84.3",
      "pali": "Pitaraṁ aparicaritvāna,"
    },
    {
      "id": "ja532:84.4",
      "pali": "Kicchaṁ vā so nigacchati."
    },
    {
      "id": "ja532:85.1",
      "pali": "Ānando ca pamodo ca,"
    },
    {
      "id": "ja532:85.2",
      "pali": "sadā hasitakīḷitaṁ;"
    },
    {
      "id": "ja532:85.3",
      "pali": "Mātaraṁ paricaritvāna,"
    },
    {
      "id": "ja532:85.4",
      "pali": "labbhametaṁ vijānato."
    },
    {
      "id": "ja532:86.1",
      "pali": "Ānando ca pamodo ca,"
    },
    {
      "id": "ja532:86.2",
      "pali": "sadā hasitakīḷitaṁ;"
    },
    {
      "id": "ja532:86.3",
      "pali": "Pitaraṁ paricaritvāna,"
    },
    {
      "id": "ja532:86.4",
      "pali": "labbhametaṁ vijānato."
    },
    {
      "id": "ja532:87.1",
      "pali": "Dānañca piyavācā ca,"
    },
    {
      "id": "ja532:87.2",
      "pali": "atthacariyā ca yā idha;"
    },
    {
      "id": "ja532:87.3",
      "pali": "Samānattatā ca dhammesu,"
    },
    {
      "id": "ja532:87.4",
      "pali": "tattha tattha yathārahaṁ;"
    },
    {
      "id": "ja532:87.5",
      "pali": "Ete kho saṅgahā loke,"
    },
    {
      "id": "ja532:87.6",
      "pali": "rathassāṇīva yāyato."
    },
    {
      "id": "ja532:88.1",
      "pali": "Ete ca saṅgahā nāssu,"
    },
    {
      "id": "ja532:88.2",
      "pali": "na mātā puttakāraṇā;"
    },
    {
      "id": "ja532:88.3",
      "pali": "Labhetha mānaṁ pūjaṁ vā,"
    },
    {
      "id": "ja532:88.4",
      "pali": "pitā vā puttakāraṇā."
    },
    {
      "id": "ja532:89.1",
      "pali": "Yasmā ca saṅgahā ete,"
    },
    {
      "id": "ja532:89.2",
      "pali": "sammapekkhanti paṇḍitā;"
    },
    {
      "id": "ja532:89.3",
      "pali": "Tasmā mahattaṁ papponti,"
    },
    {
      "id": "ja532:89.4",
      "pali": "pāsaṁsā ca bhavanti te."
    },
    {
      "id": "ja532:90.1",
      "pali": "Brahmāti mātāpitaro,"
    },
    {
      "id": "ja532:90.2",
      "pali": "pubbācariyāti vuccare;"
    },
    {
      "id": "ja532:90.3",
      "pali": "Āhuneyyā ca puttānaṁ,"
    },
    {
      "id": "ja532:90.4",
      "pali": "pajāya anukampakā."
    },
    {
      "id": "ja532:91.1",
      "pali": "Tasmā hi ne namasseyya,"
    },
    {
      "id": "ja532:91.2",
      "pali": "sakkareyya ca paṇḍito;"
    },
    {
      "id": "ja532:91.3",
      "pali": "Annena atho pānena,"
    },
    {
      "id": "ja532:91.4",
      "pali": "vatthena sayanena ca;"
    },
    {
      "id": "ja532:91.5",
      "pali": "Ucchādanena nhāpanena,"
    },
    {
      "id": "ja532:91.6",
      "pali": "pādānaṁ dhovanena ca."
    },
    {
      "id": "ja532:92.1",
      "pali": "Tāya naṁ pāricariyāya,"
    },
    {
      "id": "ja532:92.2",
      "pali": "Mātāpitūsu paṇḍitā;"
    },
    {
      "id": "ja532:92.3",
      "pali": "Idheva naṁ pasaṁsanti,"
    },
    {
      "id": "ja532:92.4",
      "pali": "Pecca sagge pamodatī”ti."
    },
    {
      "id": "ja532:93.1",
      "pali": "Soṇanandajātakaṁ dutiyaṁ."
    },
    {
      "id": "ja532:94.1",
      "pali": "Sattatinipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja532:95.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja532:96.1",
      "pali": "Atha sattatimamhi nipātavare,"
    },
    {
      "id": "ja532:96.2",
      "pali": "Sabhāvantu kusāvatirājavaro;"
    },
    {
      "id": "ja532:96.3",
      "pali": "Atha soṇasunandavaro ca puna,"
    },
    {
      "id": "ja532:96.4",
      "pali": "Abhivāsitasattatimamhi suteti."
    }
  ]
}
