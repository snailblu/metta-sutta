{
  "uid": "pv40",
  "title": "5. Ucchupetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv40:1.1",
      "pali": "“Idaṁ mama ucchuvanaṁ mahantaṁ,"
    },
    {
      "id": "pv40:1.2",
      "pali": "Nibbattati puññaphalaṁ anappakaṁ;"
    },
    {
      "id": "pv40:1.3",
      "pali": "Taṁ dāni me na paribhogameti,"
    },
    {
      "id": "pv40:1.4",
      "pali": "Ācikkha bhante kissa ayaṁ vipāko."
    },
    {
      "id": "pv40:2.1",
      "pali": "Haññāmi khajjāmi ca vāyamāmi,"
    },
    {
      "id": "pv40:2.2",
      "pali": "Parisakkāmi paribhuñjituṁ kiñci;"
    },
    {
      "id": "pv40:2.3",
      "pali": "Svāhaṁ chinnathāmo kapaṇo lālapāmi,"
    },
    {
      "id": "pv40:2.4",
      "pali": "Kissa kammassa ayaṁ vipāko."
    },
    {
      "id": "pv40:3.1",
      "pali": "Vighāto cāhaṁ paripatāmi chamāyaṁ,"
    },
    {
      "id": "pv40:3.2",
      "pali": "Parivattāmi vāricarova ghamme;"
    },
    {
      "id": "pv40:3.3",
      "pali": "Rudato ca me assukā niggalanti,"
    },
    {
      "id": "pv40:3.4",
      "pali": "Ācikkha bhante kissa ayaṁ vipāko."
    },
    {
      "id": "pv40:4.1",
      "pali": "Chāto kilanto ca pipāsito ca,"
    },
    {
      "id": "pv40:4.2",
      "pali": "Santassito sātasukhaṁ na vinde;"
    },
    {
      "id": "pv40:4.3",
      "pali": "Pucchāmi taṁ etamatthaṁ bhadante,"
    },
    {
      "id": "pv40:4.4",
      "pali": "Kathaṁ nu ucchuparibhogaṁ labheyyan”ti."
    },
    {
      "id": "pv40:5.1",
      "pali": "“Pure tuvaṁ kammamakāsi attanā,"
    },
    {
      "id": "pv40:5.2",
      "pali": "Manussabhūto purimāya jātiyā;"
    },
    {
      "id": "pv40:5.3",
      "pali": "Ahañca taṁ etamatthaṁ vadāmi,"
    },
    {
      "id": "pv40:5.4",
      "pali": "Sutvāna tvaṁ etamatthaṁ vijāna."
    },
    {
      "id": "pv40:6.1",
      "pali": "Ucchuṁ tuvaṁ khādamāno payāto,"
    },
    {
      "id": "pv40:6.2",
      "pali": "Puriso ca te piṭṭhito anvagacchi;"
    },
    {
      "id": "pv40:6.3",
      "pali": "So ca taṁ paccāsanto kathesi,"
    },
    {
      "id": "pv40:6.4",
      "pali": "Tassa tuvaṁ na kiñci ālapittha."
    },
    {
      "id": "pv40:7.1",
      "pali": "So ca taṁ abhaṇantaṁ ayāci,"
    },
    {
      "id": "pv40:7.2",
      "pali": "‘Dehayya ucchun’ti ca taṁ avoca;"
    },
    {
      "id": "pv40:7.3",
      "pali": "Tassa tuvaṁ piṭṭhito ucchuṁ adāsi,"
    },
    {
      "id": "pv40:7.4",
      "pali": "Tassetaṁ kammassa ayaṁ vipāko."
    },
    {
      "id": "pv40:8.1",
      "pali": "Iṅgha tvaṁ gantvāna piṭṭhito gaṇheyyāsi,"
    },
    {
      "id": "pv40:8.2",
      "pali": "Gahetvāna taṁ khādassu yāvadatthaṁ;"
    },
    {
      "id": "pv40:8.3",
      "pali": "Teneva tvaṁ attamano bhavissasi,"
    },
    {
      "id": "pv40:8.4",
      "pali": "Haṭṭho cudaggo ca pamodito cā”ti."
    },
    {
      "id": "pv40:9.1",
      "pali": "Gantvāna so piṭṭhito aggahesi,"
    },
    {
      "id": "pv40:9.2",
      "pali": "Gahetvāna taṁ khādi yāvadatthaṁ;"
    },
    {
      "id": "pv40:9.3",
      "pali": "Teneva so attamano ahosi,"
    },
    {
      "id": "pv40:9.4",
      "pali": "Haṭṭho cudaggo ca pamodito cāti."
    },
    {
      "id": "pv40:10.1",
      "pali": "Ucchupetavatthu pañcamaṁ."
    }
  ]
}
