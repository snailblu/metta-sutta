{
  "uid": "ja178",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja178:1.1",
      "pali": "“Janittaṁ me bhavittaṁ me,"
    },
    {
      "id": "ja178:1.2",
      "pali": "iti paṅke avassayiṁ;"
    },
    {
      "id": "ja178:1.3",
      "pali": "Taṁ maṁ paṅko ajjhabhavi,"
    },
    {
      "id": "ja178:1.4",
      "pali": "yathā dubbalakaṁ tathā;"
    },
    {
      "id": "ja178:1.5",
      "pali": "Taṁ taṁ vadāmi bhaggava,"
    },
    {
      "id": "ja178:1.6",
      "pali": "suṇohi vacanaṁ mama”."
    },
    {
      "id": "ja178:2.1",
      "pali": "“Gāme vā yadi vā raññe,"
    },
    {
      "id": "ja178:2.2",
      "pali": "sukhaṁ yatrādhigacchati;"
    },
    {
      "id": "ja178:2.3",
      "pali": "Taṁ janittaṁ bhavittañca,"
    },
    {
      "id": "ja178:2.4",
      "pali": "purisassa pajānato;"
    },
    {
      "id": "ja178:2.5",
      "pali": "Yamhi jīve tamhi gacche,"
    },
    {
      "id": "ja178:2.6",
      "pali": "na niketahato siyā”ti."
    },
    {
      "id": "ja178:3.1",
      "pali": "Kacchapajātakaṁ aṭṭhamaṁ."
    }
  ]
}
