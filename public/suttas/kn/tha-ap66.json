{
  "uid": "tha-ap66",
  "title": "Parappasādakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap66:1.1",
      "pali": "“Usabhaṁ pavaraṁ vīraṁ,"
    },
    {
      "id": "tha-ap66:1.2",
      "pali": "Mahesiṁ vijitāvinaṁ;"
    },
    {
      "id": "tha-ap66:1.3",
      "pali": "Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap66:1.4",
      "pali": "Ko disvā nappasīdati."
    },
    {
      "id": "tha-ap66:2.1",
      "pali": "Himavāvāparimeyyo,"
    },
    {
      "id": "tha-ap66:2.2",
      "pali": "sāgarova duruttaro;"
    },
    {
      "id": "tha-ap66:2.3",
      "pali": "Tatheva jhānaṁ buddhassa,"
    },
    {
      "id": "tha-ap66:2.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap66:3.1",
      "pali": "Vasudhā yathāppameyyā,"
    },
    {
      "id": "tha-ap66:3.2",
      "pali": "cittā vanavaṭaṁsakā;"
    },
    {
      "id": "tha-ap66:3.3",
      "pali": "Tatheva sīlaṁ buddhassa,"
    },
    {
      "id": "tha-ap66:3.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap66:4.1",
      "pali": "Anilañjasāsaṅkhubbho,"
    },
    {
      "id": "tha-ap66:4.2",
      "pali": "yathākāso asaṅkhiyo;"
    },
    {
      "id": "tha-ap66:4.3",
      "pali": "Tatheva ñāṇaṁ buddhassa,"
    },
    {
      "id": "tha-ap66:4.4",
      "pali": "ko disvā nappasīdati."
    },
    {
      "id": "tha-ap66:5.1",
      "pali": "Imāhi catugāthāhi,"
    },
    {
      "id": "tha-ap66:5.2",
      "pali": "brāhmaṇo senasavhayo;"
    },
    {
      "id": "tha-ap66:5.3",
      "pali": "Buddhaseṭṭhaṁ thavitvāna,"
    },
    {
      "id": "tha-ap66:5.4",
      "pali": "siddhatthaṁ aparājitaṁ."
    },
    {
      "id": "tha-ap66:6.1",
      "pali": "Catunnavutikappāni,"
    },
    {
      "id": "tha-ap66:6.2",
      "pali": "duggatiṁ nupapajjatha;"
    },
    {
      "id": "tha-ap66:6.3",
      "pali": "Sugatiṁ sukhasampattiṁ,"
    },
    {
      "id": "tha-ap66:6.4",
      "pali": "anubhosimanappakaṁ."
    },
    {
      "id": "tha-ap66:7.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap66:7.2",
      "pali": "thavitvā lokanāyakaṁ;"
    },
    {
      "id": "tha-ap66:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap66:7.4",
      "pali": "thomanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap66:8.1",
      "pali": "Cātuddasamhi kappamhi,"
    },
    {
      "id": "tha-ap66:8.2",
      "pali": "caturo āsumuggatā;"
    },
    {
      "id": "tha-ap66:8.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap66:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap66:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap66:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap66:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap66:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā parappasādako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap66:11.1",
      "pali": "Parappasādakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
