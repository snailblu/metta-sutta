{
  "uid": "ja93",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja93:1.1",
      "pali": "“Na vissase avissatthe,"
    },
    {
      "id": "ja93:1.2",
      "pali": "vissatthepi na vissase;"
    },
    {
      "id": "ja93:1.3",
      "pali": "Vissāsā bhayamanveti,"
    },
    {
      "id": "ja93:1.4",
      "pali": "sīhaṁva migamātukāti."
    },
    {
      "id": "ja93:2.1",
      "pali": "Visāsabhojanajātakaṁ tatiyaṁ."
    }
  ]
}
