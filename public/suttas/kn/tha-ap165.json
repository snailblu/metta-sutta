{
  "uid": "tha-ap165",
  "title": "Khajjakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap165:1.1",
      "pali": "“Tissassa kho bhagavato,"
    },
    {
      "id": "tha-ap165:1.2",
      "pali": "pubbe phalamadāsahaṁ;"
    },
    {
      "id": "tha-ap165:1.3",
      "pali": "Nāḷikerañca pādāsiṁ,"
    },
    {
      "id": "tha-ap165:1.4",
      "pali": "khajjakaṁ abhisammataṁ."
    },
    {
      "id": "tha-ap165:2.1",
      "pali": "Buddhassa tamahaṁ datvā,"
    },
    {
      "id": "tha-ap165:2.2",
      "pali": "Tissassa tu mahesino;"
    },
    {
      "id": "tha-ap165:2.3",
      "pali": "Modāmahaṁ kāmakāmī,"
    },
    {
      "id": "tha-ap165:2.4",
      "pali": "Upapajjiṁ yamicchakaṁ."
    },
    {
      "id": "tha-ap165:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap165:3.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap165:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap165:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap165:4.1",
      "pali": "Ito terasakappamhi,"
    },
    {
      "id": "tha-ap165:4.2",
      "pali": "rājā indasamo ahu;"
    },
    {
      "id": "tha-ap165:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap165:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap165:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap165:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap165:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap165:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā khajjakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap165:7.1",
      "pali": "Khajjakadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
