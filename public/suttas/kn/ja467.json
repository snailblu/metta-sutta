{
  "uid": "ja467",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja467:1.1",
      "pali": "“Kāmaṁ kāmayamānassa,"
    },
    {
      "id": "ja467:1.2",
      "pali": "tassa ce taṁ samijjhati;"
    },
    {
      "id": "ja467:1.3",
      "pali": "Addhā pītimano hoti,"
    },
    {
      "id": "ja467:1.4",
      "pali": "laddhā macco yadicchati."
    },
    {
      "id": "ja467:2.1",
      "pali": "Kāmaṁ kāmayamānassa,"
    },
    {
      "id": "ja467:2.2",
      "pali": "tassa ce taṁ samijjhati;"
    },
    {
      "id": "ja467:2.3",
      "pali": "Tato naṁ aparaṁ kāme,"
    },
    {
      "id": "ja467:2.4",
      "pali": "ghamme taṇhaṁva vindati."
    },
    {
      "id": "ja467:3.1",
      "pali": "Gavaṁva siṅgino siṅgaṁ,"
    },
    {
      "id": "ja467:3.2",
      "pali": "vaḍḍhamānassa vaḍḍhati;"
    },
    {
      "id": "ja467:3.3",
      "pali": "Evaṁ mandassa posassa,"
    },
    {
      "id": "ja467:3.4",
      "pali": "bālassa avijānato;"
    },
    {
      "id": "ja467:3.5",
      "pali": "Bhiyyo taṇhā pipāsā ca,"
    },
    {
      "id": "ja467:3.6",
      "pali": "vaḍḍhamānassa vaḍḍhati."
    },
    {
      "id": "ja467:4.1",
      "pali": "Pathabyā sāliyavakaṁ,"
    },
    {
      "id": "ja467:4.2",
      "pali": "gavāssaṁ dāsaporisaṁ;"
    },
    {
      "id": "ja467:4.3",
      "pali": "Datvā ca nālamekassa,"
    },
    {
      "id": "ja467:4.4",
      "pali": "iti vidvā samaṁ care."
    },
    {
      "id": "ja467:5.1",
      "pali": "Rājā pasayha pathaviṁ vijitvā,"
    },
    {
      "id": "ja467:5.2",
      "pali": "Sasāgarantaṁ mahimāvasanto;"
    },
    {
      "id": "ja467:5.3",
      "pali": "Oraṁ samuddassa atittarūpo,"
    },
    {
      "id": "ja467:5.4",
      "pali": "Pāraṁ samuddassapi patthayetha."
    },
    {
      "id": "ja467:6.1",
      "pali": "Yāva anussaraṁ kāme,"
    },
    {
      "id": "ja467:6.2",
      "pali": "Manasā titti nājjhagā;"
    },
    {
      "id": "ja467:6.3",
      "pali": "Tato nivattā paṭikkamma disvā,"
    },
    {
      "id": "ja467:6.4",
      "pali": "Te ve sutittā ye paññāya tittā."
    },
    {
      "id": "ja467:7.1",
      "pali": "Paññāya tittinaṁ seṭṭhaṁ,"
    },
    {
      "id": "ja467:7.2",
      "pali": "na so kāmehi tappati;"
    },
    {
      "id": "ja467:7.3",
      "pali": "Paññāya tittaṁ purisaṁ,"
    },
    {
      "id": "ja467:7.4",
      "pali": "taṇhā na kurute vasaṁ."
    },
    {
      "id": "ja467:8.1",
      "pali": "Apacinetheva kāmānaṁ,"
    },
    {
      "id": "ja467:8.2",
      "pali": "appicchassa alolupo;"
    },
    {
      "id": "ja467:8.3",
      "pali": "Samuddamatto puriso,"
    },
    {
      "id": "ja467:8.4",
      "pali": "na so kāmehi tappati."
    },
    {
      "id": "ja467:9.1",
      "pali": "Rathakārova cammassa,"
    },
    {
      "id": "ja467:9.2",
      "pali": "parikantaṁ upāhanaṁ;"
    },
    {
      "id": "ja467:9.3",
      "pali": "Yaṁ yaṁ cajati kāmānaṁ,"
    },
    {
      "id": "ja467:9.4",
      "pali": "taṁ taṁ sampajjate sukhaṁ;"
    },
    {
      "id": "ja467:9.5",
      "pali": "Sabbañce sukhamiccheyya,"
    },
    {
      "id": "ja467:9.6",
      "pali": "sabbe kāme pariccaje”."
    },
    {
      "id": "ja467:10.1",
      "pali": "“Aṭṭha te bhāsitā gāthā,"
    },
    {
      "id": "ja467:10.2",
      "pali": "sabbā honti sahassiyo;"
    },
    {
      "id": "ja467:10.3",
      "pali": "Paṭigaṇha mahābrahme,"
    },
    {
      "id": "ja467:10.4",
      "pali": "sādhetaṁ tava bhāsitaṁ”."
    },
    {
      "id": "ja467:11.1",
      "pali": "“Na me attho sahassehi,"
    },
    {
      "id": "ja467:11.2",
      "pali": "satehi nahutehi vā;"
    },
    {
      "id": "ja467:11.3",
      "pali": "Pacchimaṁ bhāsato gāthaṁ,"
    },
    {
      "id": "ja467:11.4",
      "pali": "kāme me na rato mano”."
    },
    {
      "id": "ja467:12.1",
      "pali": "“Bhadrako vatāyaṁ māṇavako,"
    },
    {
      "id": "ja467:12.2",
      "pali": "Sabbalokavidū muni;"
    },
    {
      "id": "ja467:12.3",
      "pali": "Yo imaṁ taṇhaṁ dukkhajananiṁ,"
    },
    {
      "id": "ja467:12.4",
      "pali": "Parijānāti paṇḍito”ti."
    },
    {
      "id": "ja467:13.1",
      "pali": "Kāmajātakaṁ catutthaṁ."
    }
  ]
}
