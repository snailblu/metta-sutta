{
  "uid": "tha-ap348",
  "title": "Campakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap348:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap348:1.2",
      "pali": "jāpalo nāma pabbato;"
    },
    {
      "id": "tha-ap348:1.3",
      "pali": "Buddho sudassano nāma,"
    },
    {
      "id": "tha-ap348:1.4",
      "pali": "vihāsi pabbatantare."
    },
    {
      "id": "tha-ap348:2.1",
      "pali": "Pupphaṁ hemavantaṁ gayha,"
    },
    {
      "id": "tha-ap348:2.2",
      "pali": "Gacchaṁ vehāyasenahaṁ;"
    },
    {
      "id": "tha-ap348:2.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap348:2.4",
      "pali": "Oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap348:3.1",
      "pali": "Satta campakapupphāni,"
    },
    {
      "id": "tha-ap348:3.2",
      "pali": "sīse katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap348:3.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap348:3.4",
      "pali": "sayambhussa mahesino."
    },
    {
      "id": "tha-ap348:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap348:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap348:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap348:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap348:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap348:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap348:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap348:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā campakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap348:7.1",
      "pali": "Campakapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
