{
  "uid": "tha-ap257",
  "title": "Sattapāṭaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap257:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap257:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap257:1.3",
      "pali": "Satta pāṭalipupphāni,"
    },
    {
      "id": "tha-ap257:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap257:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap257:2.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap257:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap257:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap257:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap257:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap257:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap257:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattapāṭaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap257:5.1",
      "pali": "Sattapāṭaliyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
