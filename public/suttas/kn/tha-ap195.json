{
  "uid": "tha-ap195",
  "title": "Khaṇḍaphulliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap195:1.1",
      "pali": "“Phussassa kho bhagavato,"
    },
    {
      "id": "tha-ap195:1.2",
      "pali": "thūpo āsi mahāvane;"
    },
    {
      "id": "tha-ap195:1.3",
      "pali": "Kuñjarehi tadā bhinno,"
    },
    {
      "id": "tha-ap195:1.4",
      "pali": "parūḷho pādapo tahiṁ."
    },
    {
      "id": "tha-ap195:2.1",
      "pali": "Visamañca samaṁ katvā,"
    },
    {
      "id": "tha-ap195:2.2",
      "pali": "sudhāpiṇḍaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap195:2.3",
      "pali": "Tilokagaruno tassa,"
    },
    {
      "id": "tha-ap195:2.4",
      "pali": "guṇehi paritosito."
    },
    {
      "id": "tha-ap195:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap195:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap195:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap195:3.4",
      "pali": "sudhāpiṇḍassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap195:4.1",
      "pali": "Sattasattatikappamhi,"
    },
    {
      "id": "tha-ap195:4.2",
      "pali": "jitasenāsuṁ soḷasa;"
    },
    {
      "id": "tha-ap195:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap195:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap195:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap195:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap195:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap195:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā khaṇḍaphulliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap195:7.1",
      "pali": "Khaṇḍaphulliyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
