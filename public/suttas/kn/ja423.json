{
  "uid": "ja423",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja423:1.1",
      "pali": "“Yo indriyānaṁ kāmena,"
    },
    {
      "id": "ja423:1.2",
      "pali": "vasaṁ nārada gacchati;"
    },
    {
      "id": "ja423:1.3",
      "pali": "So pariccajjubho loke,"
    },
    {
      "id": "ja423:1.4",
      "pali": "jīvantova visussati."
    },
    {
      "id": "ja423:2.1",
      "pali": "Sukhassānantaraṁ dukkhaṁ,"
    },
    {
      "id": "ja423:2.2",
      "pali": "dukkhassānantaraṁ sukhaṁ;"
    },
    {
      "id": "ja423:2.3",
      "pali": "Sosi patto sukhā dukkhaṁ,"
    },
    {
      "id": "ja423:2.4",
      "pali": "pāṭikaṅkha varaṁ sukhaṁ."
    },
    {
      "id": "ja423:3.1",
      "pali": "Kicchakāle kicchasaho,"
    },
    {
      "id": "ja423:3.2",
      "pali": "yo kicchaṁ nātivattati;"
    },
    {
      "id": "ja423:3.3",
      "pali": "Sa kicchantaṁ sukhaṁ dhīro,"
    },
    {
      "id": "ja423:3.4",
      "pali": "yogaṁ samadhigacchati."
    },
    {
      "id": "ja423:4.1",
      "pali": "Na heva kāmāna kāmā,"
    },
    {
      "id": "ja423:4.2",
      "pali": "nānatthā nātthakāraṇā;"
    },
    {
      "id": "ja423:4.3",
      "pali": "Na katañca niraṅkatvā,"
    },
    {
      "id": "ja423:4.4",
      "pali": "dhammā cavitumarahasi”."
    },
    {
      "id": "ja423:5.1",
      "pali": "“Dakkhaṁ gahapatī sādhu,"
    },
    {
      "id": "ja423:5.2",
      "pali": "saṁvibhajjañca bhojanaṁ;"
    },
    {
      "id": "ja423:5.3",
      "pali": "Ahāso atthalābhesu,"
    },
    {
      "id": "ja423:5.4",
      "pali": "atthabyāpatti abyatho”."
    },
    {
      "id": "ja423:6.1",
      "pali": "“Ettāvatetaṁ paṇḍiccaṁ,"
    },
    {
      "id": "ja423:6.2",
      "pali": "api so devilo bravi;"
    },
    {
      "id": "ja423:6.3",
      "pali": "Na yito kiñci pāpiyo,"
    },
    {
      "id": "ja423:6.4",
      "pali": "yo indriyānaṁ vasaṁ vaje”."
    },
    {
      "id": "ja423:7.1",
      "pali": "“Amittānaṁva hatthatthaṁ,"
    },
    {
      "id": "ja423:7.2",
      "pali": "sivi pappoti māmiva;"
    },
    {
      "id": "ja423:7.3",
      "pali": "Kammaṁ vijjañca dakkheyyaṁ,"
    },
    {
      "id": "ja423:7.4",
      "pali": "vivāhaṁ sīlamaddavaṁ;"
    },
    {
      "id": "ja423:7.5",
      "pali": "Ete ca yase hāpetvā,"
    },
    {
      "id": "ja423:7.6",
      "pali": "nibbatto sehi kammehi."
    },
    {
      "id": "ja423:8.1",
      "pali": "Sohaṁ sahassajīnova,"
    },
    {
      "id": "ja423:8.2",
      "pali": "abandhu aparāyaṇo;"
    },
    {
      "id": "ja423:8.3",
      "pali": "Ariyadhammā apakkanto,"
    },
    {
      "id": "ja423:8.4",
      "pali": "yathā peto tathevahaṁ."
    },
    {
      "id": "ja423:9.1",
      "pali": "Sukhakāme dukkhāpetvā,"
    },
    {
      "id": "ja423:9.2",
      "pali": "āpannosmi padaṁ imaṁ;"
    },
    {
      "id": "ja423:9.3",
      "pali": "So sukhaṁ nādhigacchāmi,"
    },
    {
      "id": "ja423:9.4",
      "pali": "ṭhito bhāṇumatāmivā”ti."
    },
    {
      "id": "ja423:10.1",
      "pali": "Indriyajātakaṁ sattamaṁ."
    }
  ]
}
