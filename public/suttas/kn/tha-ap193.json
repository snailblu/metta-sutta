{
  "uid": "tha-ap193",
  "title": "Tamālapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap193:1.1",
      "pali": "“Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap193:1.2",
      "pali": "thambhā sovaṇṇayā ahū;"
    },
    {
      "id": "tha-ap193:1.3",
      "pali": "Devalaṭṭhipaṭibhāgaṁ,"
    },
    {
      "id": "tha-ap193:1.4",
      "pali": "vimānaṁ me sunimmitaṁ."
    },
    {
      "id": "tha-ap193:2.1",
      "pali": "Tamālapupphaṁ paggayha,"
    },
    {
      "id": "tha-ap193:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap193:2.3",
      "pali": "Buddhassa abhiropayiṁ,"
    },
    {
      "id": "tha-ap193:2.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap193:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap193:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap193:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap193:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap193:4.1",
      "pali": "Ito vīsatime kappe,"
    },
    {
      "id": "tha-ap193:4.2",
      "pali": "candatittoti ekako;"
    },
    {
      "id": "tha-ap193:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap193:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap193:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap193:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap193:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap193:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap193:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā tamālapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap193:7.1",
      "pali": "Tamālapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
