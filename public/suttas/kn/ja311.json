{
  "uid": "ja311",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja311:1.1",
      "pali": "“Uṭṭhehi cora kiṁ sesi,"
    },
    {
      "id": "ja311:1.2",
      "pali": "ko attho supanena te;"
    },
    {
      "id": "ja311:1.3",
      "pali": "Mā taṁ gahesuṁ rājāno,"
    },
    {
      "id": "ja311:1.4",
      "pali": "gāme kibbisakārakaṁ”."
    },
    {
      "id": "ja311:2.1",
      "pali": "“Yannu coraṁ gahessanti,"
    },
    {
      "id": "ja311:2.2",
      "pali": "gāme kibbisakārakaṁ;"
    },
    {
      "id": "ja311:2.3",
      "pali": "Kiṁ tattha pucimandassa,"
    },
    {
      "id": "ja311:2.4",
      "pali": "vane jātassa tiṭṭhato”."
    },
    {
      "id": "ja311:3.1",
      "pali": "“Na tvaṁ assattha jānāsi,"
    },
    {
      "id": "ja311:3.2",
      "pali": "mama corassa cantaraṁ;"
    },
    {
      "id": "ja311:3.3",
      "pali": "Coraṁ gahetvā rājāno,"
    },
    {
      "id": "ja311:3.4",
      "pali": "gāme kibbisakārakaṁ;"
    },
    {
      "id": "ja311:3.5",
      "pali": "Appenti nimbasūlasmiṁ,"
    },
    {
      "id": "ja311:3.6",
      "pali": "tasmiṁ me saṅkate mano”."
    },
    {
      "id": "ja311:4.1",
      "pali": "“Saṅkeyya saṅkitabbāni,"
    },
    {
      "id": "ja311:4.2",
      "pali": "rakkheyyānāgataṁ bhayaṁ;"
    },
    {
      "id": "ja311:4.3",
      "pali": "Anāgatabhayā dhīro,"
    },
    {
      "id": "ja311:4.4",
      "pali": "ubho loke avekkhatī”ti."
    },
    {
      "id": "ja311:5.1",
      "pali": "Pucimandajātakaṁ paṭhamaṁ."
    }
  ]
}
