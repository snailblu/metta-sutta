{
  "uid": "ja316",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja316:1.1",
      "pali": "“Satta me rohitā macchā,"
    },
    {
      "id": "ja316:1.2",
      "pali": "udakā thalamubbhatā;"
    },
    {
      "id": "ja316:1.3",
      "pali": "Idaṁ brāhmaṇa me atthi,"
    },
    {
      "id": "ja316:1.4",
      "pali": "etaṁ bhutvā vane vasa”."
    },
    {
      "id": "ja316:2.1",
      "pali": "“Dussa me khettapālassa,"
    },
    {
      "id": "ja316:2.2",
      "pali": "rattibhattaṁ apābhataṁ;"
    },
    {
      "id": "ja316:2.3",
      "pali": "Maṁsasūlā ca dve godhā,"
    },
    {
      "id": "ja316:2.4",
      "pali": "ekañca dadhivārakaṁ;"
    },
    {
      "id": "ja316:2.5",
      "pali": "Idaṁ brāhmaṇa me atthi,"
    },
    {
      "id": "ja316:2.6",
      "pali": "etaṁ bhutvā vane vasa”."
    },
    {
      "id": "ja316:3.1",
      "pali": "“Ambapakkaṁ dakaṁ sītaṁ,"
    },
    {
      "id": "ja316:3.2",
      "pali": "Sītacchāyā manoramā;"
    },
    {
      "id": "ja316:3.3",
      "pali": "Idaṁ brāhmaṇa me atthi,"
    },
    {
      "id": "ja316:3.4",
      "pali": "Etaṁ bhutvā vane vasa”."
    },
    {
      "id": "ja316:4.1",
      "pali": "“Na sasassa tilā atthi,"
    },
    {
      "id": "ja316:4.2",
      "pali": "Na muggā napi taṇḍulā;"
    },
    {
      "id": "ja316:4.3",
      "pali": "Iminā agginā pakkaṁ,"
    },
    {
      "id": "ja316:4.4",
      "pali": "Mamaṁ bhutvā vane vasā”ti."
    },
    {
      "id": "ja316:5.1",
      "pali": "Sasapaṇḍitajātakaṁ chaṭṭhaṁ."
    }
  ]
}
