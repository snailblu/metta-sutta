{
  "uid": "thag20.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag20.1:1.1",
      "pali": "“Āraññikā piṇḍapātikā,"
    },
    {
      "id": "thag20.1:1.2",
      "pali": "uñchāpattāgate ratā;"
    },
    {
      "id": "thag20.1:1.3",
      "pali": "Dālemu maccuno senaṁ,"
    },
    {
      "id": "thag20.1:1.4",
      "pali": "ajjhattaṁ susamāhitā."
    },
    {
      "id": "thag20.1:2.1",
      "pali": "Āraññikā piṇḍapātikā,"
    },
    {
      "id": "thag20.1:2.2",
      "pali": "uñchāpattāgate ratā;"
    },
    {
      "id": "thag20.1:2.3",
      "pali": "Dhunāma maccuno senaṁ,"
    },
    {
      "id": "thag20.1:2.4",
      "pali": "naḷāgāraṁva kuñjaro."
    },
    {
      "id": "thag20.1:3.1",
      "pali": "Rukkhamūlikā sātatikā,"
    },
    {
      "id": "thag20.1:3.2",
      "pali": "uñchāpattāgate ratā;"
    },
    {
      "id": "thag20.1:3.3",
      "pali": "Dālemu maccuno senaṁ,"
    },
    {
      "id": "thag20.1:3.4",
      "pali": "ajjhattaṁ susamāhitā."
    },
    {
      "id": "thag20.1:4.1",
      "pali": "Rukkhamūlikā sātatikā,"
    },
    {
      "id": "thag20.1:4.2",
      "pali": "uñchāpattāgate ratā;"
    },
    {
      "id": "thag20.1:4.3",
      "pali": "Dhunāma maccuno senaṁ,"
    },
    {
      "id": "thag20.1:4.4",
      "pali": "naḷāgāraṁva kuñjaro”."
    },
    {
      "id": "thag20.1:5.1",
      "pali": "“Aṭṭhikaṅkalakuṭike,"
    },
    {
      "id": "thag20.1:5.2",
      "pali": "maṁsanhārupasibbite;"
    },
    {
      "id": "thag20.1:5.3",
      "pali": "Dhiratthu pure duggandhe,"
    },
    {
      "id": "thag20.1:5.4",
      "pali": "paragatte mamāyase."
    },
    {
      "id": "thag20.1:6.1",
      "pali": "Gūthabhaste taconaddhe,"
    },
    {
      "id": "thag20.1:6.2",
      "pali": "uragaṇḍipisācini;"
    },
    {
      "id": "thag20.1:6.3",
      "pali": "Nava sotāni te kāye,"
    },
    {
      "id": "thag20.1:6.4",
      "pali": "yāni sandanti sabbadā."
    },
    {
      "id": "thag20.1:7.1",
      "pali": "Tava sarīraṁ navasotaṁ,"
    },
    {
      "id": "thag20.1:7.2",
      "pali": "Duggandhakaraṁ paribandhaṁ;"
    },
    {
      "id": "thag20.1:7.3",
      "pali": "Bhikkhu parivajjayate taṁ,"
    },
    {
      "id": "thag20.1:7.4",
      "pali": "Mīḷhaṁ ca yathā sucikāmo."
    },
    {
      "id": "thag20.1:8.1",
      "pali": "Evañce taṁ jano jaññā,"
    },
    {
      "id": "thag20.1:8.2",
      "pali": "yathā jānāmi taṁ ahaṁ;"
    },
    {
      "id": "thag20.1:8.3",
      "pali": "Ārakā parivajjeyya,"
    },
    {
      "id": "thag20.1:8.4",
      "pali": "gūthaṭṭhānaṁva pāvuse”."
    },
    {
      "id": "thag20.1:9.1",
      "pali": "“Evametaṁ mahāvīra,"
    },
    {
      "id": "thag20.1:9.2",
      "pali": "yathā samaṇa bhāsasi;"
    },
    {
      "id": "thag20.1:9.3",
      "pali": "Ettha ceke visīdanti,"
    },
    {
      "id": "thag20.1:9.4",
      "pali": "paṅkamhiva jaraggavo”."
    },
    {
      "id": "thag20.1:10.1",
      "pali": "“Ākāsamhi haliddiyā,"
    },
    {
      "id": "thag20.1:10.2",
      "pali": "yo maññetha rajetave;"
    },
    {
      "id": "thag20.1:10.3",
      "pali": "Aññena vāpi raṅgena,"
    },
    {
      "id": "thag20.1:10.4",
      "pali": "vighātudayameva taṁ."
    },
    {
      "id": "thag20.1:11.1",
      "pali": "Tadākāsasamaṁ cittaṁ,"
    },
    {
      "id": "thag20.1:11.2",
      "pali": "ajjhattaṁ susamāhitaṁ;"
    },
    {
      "id": "thag20.1:11.3",
      "pali": "Mā pāpacitte āsādi,"
    },
    {
      "id": "thag20.1:11.4",
      "pali": "aggikhandhaṁva pakkhimā”."
    },
    {
      "id": "thag20.1:12.1",
      "pali": "“Passa cittakataṁ bimbaṁ,"
    },
    {
      "id": "thag20.1:12.2",
      "pali": "arukāyaṁ samussitaṁ;"
    },
    {
      "id": "thag20.1:12.3",
      "pali": "Āturaṁ bahusaṅkappaṁ,"
    },
    {
      "id": "thag20.1:12.4",
      "pali": "yassa natthi dhuvaṁ ṭhiti."
    },
    {
      "id": "thag20.1:13.1",
      "pali": "Passa cittakataṁ rūpaṁ,"
    },
    {
      "id": "thag20.1:13.2",
      "pali": "maṇinā kuṇḍalena ca;"
    },
    {
      "id": "thag20.1:13.3",
      "pali": "Aṭṭhiṁ tacena onaddhaṁ,"
    },
    {
      "id": "thag20.1:13.4",
      "pali": "saha vatthehi sobhati."
    },
    {
      "id": "thag20.1:14.1",
      "pali": "Alattakakatā pādā,"
    },
    {
      "id": "thag20.1:14.2",
      "pali": "mukhaṁ cuṇṇakamakkhitaṁ;"
    },
    {
      "id": "thag20.1:14.3",
      "pali": "Alaṁ bālassa mohāya,"
    },
    {
      "id": "thag20.1:14.4",
      "pali": "no ca pāragavesino."
    },
    {
      "id": "thag20.1:15.1",
      "pali": "Aṭṭhapadakatā kesā,"
    },
    {
      "id": "thag20.1:15.2",
      "pali": "nettā añjanamakkhitā;"
    },
    {
      "id": "thag20.1:15.3",
      "pali": "Alaṁ bālassa mohāya,"
    },
    {
      "id": "thag20.1:15.4",
      "pali": "no ca pāragavesino."
    },
    {
      "id": "thag20.1:16.1",
      "pali": "Añjanīva navā cittā,"
    },
    {
      "id": "thag20.1:16.2",
      "pali": "pūtikāyo alaṅkato;"
    },
    {
      "id": "thag20.1:16.3",
      "pali": "Alaṁ bālassa mohāya,"
    },
    {
      "id": "thag20.1:16.4",
      "pali": "no ca pāragavesino."
    },
    {
      "id": "thag20.1:17.1",
      "pali": "Odahi migavo pāsaṁ,"
    },
    {
      "id": "thag20.1:17.2",
      "pali": "nāsadā vāguraṁ migo;"
    },
    {
      "id": "thag20.1:17.3",
      "pali": "Bhutvā nivāpaṁ gacchāma,"
    },
    {
      "id": "thag20.1:17.4",
      "pali": "kaddante migabandhake."
    },
    {
      "id": "thag20.1:18.1",
      "pali": "Chinno pāso migavassa,"
    },
    {
      "id": "thag20.1:18.2",
      "pali": "nāsadā vāguraṁ migo;"
    },
    {
      "id": "thag20.1:18.3",
      "pali": "Bhutvā nivāpaṁ gacchāma,"
    },
    {
      "id": "thag20.1:18.4",
      "pali": "socante migaluddake”."
    },
    {
      "id": "thag20.1:19.1",
      "pali": "“Tadāsi yaṁ bhiṁsanakaṁ,"
    },
    {
      "id": "thag20.1:19.2",
      "pali": "tadāsi lomahaṁsanaṁ;"
    },
    {
      "id": "thag20.1:19.3",
      "pali": "Anekākārasampanne,"
    },
    {
      "id": "thag20.1:19.4",
      "pali": "sāriputtamhi nibbute."
    },
    {
      "id": "thag20.1:20.1",
      "pali": "Aniccā vata saṅkhārā,"
    },
    {
      "id": "thag20.1:20.2",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "thag20.1:20.3",
      "pali": "Upajjitvā nirujjhanti,"
    },
    {
      "id": "thag20.1:20.4",
      "pali": "tesaṁ vūpasamo sukho."
    },
    {
      "id": "thag20.1:21.1",
      "pali": "Sukhumaṁ te paṭivijjhanti,"
    },
    {
      "id": "thag20.1:21.2",
      "pali": "vālaggaṁ usunā yathā;"
    },
    {
      "id": "thag20.1:21.3",
      "pali": "Ye pañcakkhandhe passanti,"
    },
    {
      "id": "thag20.1:21.4",
      "pali": "parato no ca attato."
    },
    {
      "id": "thag20.1:22.1",
      "pali": "Ye ca passanti saṅkhāre,"
    },
    {
      "id": "thag20.1:22.2",
      "pali": "parato no ca attato;"
    },
    {
      "id": "thag20.1:22.3",
      "pali": "Paccabyādhiṁsu nipuṇaṁ,"
    },
    {
      "id": "thag20.1:22.4",
      "pali": "vālaggaṁ usunā yathā."
    },
    {
      "id": "thag20.1:23.1",
      "pali": "Sattiyā viya omaṭṭho,"
    },
    {
      "id": "thag20.1:23.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "thag20.1:23.3",
      "pali": "Kāmarāgappahānāya,"
    },
    {
      "id": "thag20.1:23.4",
      "pali": "sato bhikkhu paribbaje."
    },
    {
      "id": "thag20.1:24.1",
      "pali": "Sattiyā viya omaṭṭho,"
    },
    {
      "id": "thag20.1:24.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "thag20.1:24.3",
      "pali": "Bhavarāgappahānāya,"
    },
    {
      "id": "thag20.1:24.4",
      "pali": "sato bhikkhu paribbaje."
    },
    {
      "id": "thag20.1:25.1",
      "pali": "Codito bhāvitattena,"
    },
    {
      "id": "thag20.1:25.2",
      "pali": "sarīrantimadhārinā;"
    },
    {
      "id": "thag20.1:25.3",
      "pali": "Migāramātupāsādaṁ,"
    },
    {
      "id": "thag20.1:25.4",
      "pali": "pādaṅguṭṭhena kampayiṁ."
    },
    {
      "id": "thag20.1:26.1",
      "pali": "Nayidaṁ sithilamārabbha,"
    },
    {
      "id": "thag20.1:26.2",
      "pali": "nayidaṁ appena thāmasā;"
    },
    {
      "id": "thag20.1:26.3",
      "pali": "Nibbānamadhigantabbaṁ,"
    },
    {
      "id": "thag20.1:26.4",
      "pali": "sabbaganthapamocanaṁ."
    },
    {
      "id": "thag20.1:27.1",
      "pali": "Ayañca daharo bhikkhu,"
    },
    {
      "id": "thag20.1:27.2",
      "pali": "ayamuttamaporiso;"
    },
    {
      "id": "thag20.1:27.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "thag20.1:27.4",
      "pali": "jetvā māraṁ savāhiniṁ."
    },
    {
      "id": "thag20.1:28.1",
      "pali": "Vivaramanupabhanti vijjutā,"
    },
    {
      "id": "thag20.1:28.2",
      "pali": "Vebhārassa ca paṇḍavassa ca;"
    },
    {
      "id": "thag20.1:28.3",
      "pali": "Nagavivaragato jhāyati,"
    },
    {
      "id": "thag20.1:28.4",
      "pali": "Putto appaṭimassa tādino."
    },
    {
      "id": "thag20.1:29.1",
      "pali": "Upasanto uparato,"
    },
    {
      "id": "thag20.1:29.2",
      "pali": "pantasenāsano muni;"
    },
    {
      "id": "thag20.1:29.3",
      "pali": "Dāyādo buddhaseṭṭhassa,"
    },
    {
      "id": "thag20.1:29.4",
      "pali": "brahmunā abhivandito”."
    },
    {
      "id": "thag20.1:30.1",
      "pali": "“Upasantaṁ uparataṁ,"
    },
    {
      "id": "thag20.1:30.2",
      "pali": "pantasenāsanaṁ muniṁ;"
    },
    {
      "id": "thag20.1:30.3",
      "pali": "Dāyādaṁ buddhaseṭṭhassa,"
    },
    {
      "id": "thag20.1:30.4",
      "pali": "vanda brāhmaṇa kassapaṁ."
    },
    {
      "id": "thag20.1:31.1",
      "pali": "Yo ca jātisataṁ gacche,"
    },
    {
      "id": "thag20.1:31.2",
      "pali": "sabbā brāhmaṇajātiyo;"
    },
    {
      "id": "thag20.1:31.3",
      "pali": "Sottiyo vedasampanno,"
    },
    {
      "id": "thag20.1:31.4",
      "pali": "manussesu punappunaṁ."
    },
    {
      "id": "thag20.1:32.1",
      "pali": "Ajjhāyakopi ce assa,"
    },
    {
      "id": "thag20.1:32.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "thag20.1:32.3",
      "pali": "Etassa vandanāyetaṁ,"
    },
    {
      "id": "thag20.1:32.4",
      "pali": "kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "thag20.1:33.1",
      "pali": "Yo so aṭṭha vimokkhāni,"
    },
    {
      "id": "thag20.1:33.2",
      "pali": "purebhattaṁ aphassayi;"
    },
    {
      "id": "thag20.1:33.3",
      "pali": "Anulomaṁ paṭilomaṁ,"
    },
    {
      "id": "thag20.1:33.4",
      "pali": "tato piṇḍāya gacchati."
    },
    {
      "id": "thag20.1:34.1",
      "pali": "Tādisaṁ bhikkhuṁ māsādi,"
    },
    {
      "id": "thag20.1:34.2",
      "pali": "māttānaṁ khaṇi brāhmaṇa;"
    },
    {
      "id": "thag20.1:34.3",
      "pali": "Abhippasādehi manaṁ,"
    },
    {
      "id": "thag20.1:34.4",
      "pali": "arahantamhi tādine;"
    },
    {
      "id": "thag20.1:34.5",
      "pali": "Khippaṁ pañjaliko vanda,"
    },
    {
      "id": "thag20.1:34.6",
      "pali": "mā te vijaṭi matthakaṁ”."
    },
    {
      "id": "thag20.1:35.1",
      "pali": "“Neso passati saddhammaṁ,"
    },
    {
      "id": "thag20.1:35.2",
      "pali": "saṁsārena purakkhato;"
    },
    {
      "id": "thag20.1:35.3",
      "pali": "Adhogamaṁ jimhapathaṁ,"
    },
    {
      "id": "thag20.1:35.4",
      "pali": "kummaggamanudhāvati."
    },
    {
      "id": "thag20.1:36.1",
      "pali": "Kimīva mīḷhasallitto,"
    },
    {
      "id": "thag20.1:36.2",
      "pali": "saṅkhāre adhimucchito;"
    },
    {
      "id": "thag20.1:36.3",
      "pali": "Pagāḷho lābhasakkāre,"
    },
    {
      "id": "thag20.1:36.4",
      "pali": "tuccho gacchati poṭṭhilo”."
    },
    {
      "id": "thag20.1:37.1",
      "pali": "“Imañca passa āyantaṁ,"
    },
    {
      "id": "thag20.1:37.2",
      "pali": "sāriputtaṁ sudassanaṁ;"
    },
    {
      "id": "thag20.1:37.3",
      "pali": "Vimuttaṁ ubhatobhāge,"
    },
    {
      "id": "thag20.1:37.4",
      "pali": "ajjhattaṁ susamāhitaṁ."
    },
    {
      "id": "thag20.1:38.1",
      "pali": "Visallaṁ khīṇasaṁyogaṁ,"
    },
    {
      "id": "thag20.1:38.2",
      "pali": "tevijjaṁ maccuhāyinaṁ;"
    },
    {
      "id": "thag20.1:38.3",
      "pali": "Dakkhiṇeyyaṁ manussānaṁ,"
    },
    {
      "id": "thag20.1:38.4",
      "pali": "puññakkhettaṁ anuttaraṁ”."
    },
    {
      "id": "thag20.1:39.1",
      "pali": "“Ete sambahulā devā,"
    },
    {
      "id": "thag20.1:39.2",
      "pali": "iddhimanto yasassino;"
    },
    {
      "id": "thag20.1:39.3",
      "pali": "Dasa devasahassāni,"
    },
    {
      "id": "thag20.1:39.4",
      "pali": "sabbe brahmapurohitā;"
    },
    {
      "id": "thag20.1:39.5",
      "pali": "Moggallānaṁ namassantā,"
    },
    {
      "id": "thag20.1:39.6",
      "pali": "tiṭṭhanti pañjalīkatā."
    },
    {
      "id": "thag20.1:40.1",
      "pali": "‘Namo te purisājañña,"
    },
    {
      "id": "thag20.1:40.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "thag20.1:40.3",
      "pali": "Yassa te āsavā khīṇā,"
    },
    {
      "id": "thag20.1:40.4",
      "pali": "dakkhiṇeyyosi mārisa’."
    },
    {
      "id": "thag20.1:41.1",
      "pali": "Pūjito naradevena,"
    },
    {
      "id": "thag20.1:41.2",
      "pali": "uppanno maraṇābhibhū;"
    },
    {
      "id": "thag20.1:41.3",
      "pali": "Puṇḍarīkaṁva toyena,"
    },
    {
      "id": "thag20.1:41.4",
      "pali": "saṅkhārenupalippati."
    },
    {
      "id": "thag20.1:42.1",
      "pali": "Yassa muhuttena sahassadhā loko,"
    },
    {
      "id": "thag20.1:42.2",
      "pali": "Saṁvidito sabrahmakappo vasi;"
    },
    {
      "id": "thag20.1:42.3",
      "pali": "Iddhiguṇe cutupapāte kāle,"
    },
    {
      "id": "thag20.1:42.4",
      "pali": "Passati devatā sa bhikkhu”."
    },
    {
      "id": "thag20.1:43.1",
      "pali": "“Sāriputtova paññāya,"
    },
    {
      "id": "thag20.1:43.2",
      "pali": "sīlena upasamena ca;"
    },
    {
      "id": "thag20.1:43.3",
      "pali": "Yopi pāraṅgato bhikkhu,"
    },
    {
      "id": "thag20.1:43.4",
      "pali": "etāvaparamo siyā."
    },
    {
      "id": "thag20.1:44.1",
      "pali": "Koṭisatasahassassa,"
    },
    {
      "id": "thag20.1:44.2",
      "pali": "Attabhāvaṁ khaṇena nimmine;"
    },
    {
      "id": "thag20.1:44.3",
      "pali": "Ahaṁ vikubbanāsu kusalo,"
    },
    {
      "id": "thag20.1:44.4",
      "pali": "Vasībhūtomhi iddhiyā."
    },
    {
      "id": "thag20.1:45.1",
      "pali": "Samādhivijjāvasipāramīgato,"
    },
    {
      "id": "thag20.1:45.2",
      "pali": "Moggallānagotto asitassa sāsane;"
    },
    {
      "id": "thag20.1:45.3",
      "pali": "Dhīro samucchindi samāhitindriyo,"
    },
    {
      "id": "thag20.1:45.4",
      "pali": "Nāgo yathā pūtilataṁva bandhanaṁ."
    },
    {
      "id": "thag20.1:46.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag20.1:46.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thag20.1:46.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thag20.1:46.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag20.1:47.1",
      "pali": "Yassa catthāya pabbajito,"
    },
    {
      "id": "thag20.1:47.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag20.1:47.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag20.1:47.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thag20.1:48.1",
      "pali": "Kīdiso nirayo āsi,"
    },
    {
      "id": "thag20.1:48.2",
      "pali": "yattha dussī apaccatha;"
    },
    {
      "id": "thag20.1:48.3",
      "pali": "Vidhuraṁ sāvakamāsajja,"
    },
    {
      "id": "thag20.1:48.4",
      "pali": "kakusandhañca brāhmaṇaṁ."
    },
    {
      "id": "thag20.1:49.1",
      "pali": "Sataṁ āsi ayosaṅkū,"
    },
    {
      "id": "thag20.1:49.2",
      "pali": "sabbe paccattavedanā;"
    },
    {
      "id": "thag20.1:49.3",
      "pali": "Īdiso nirayo āsi,"
    },
    {
      "id": "thag20.1:49.4",
      "pali": "yattha dussī apaccatha;"
    },
    {
      "id": "thag20.1:49.5",
      "pali": "Vidhuraṁ sāvakamāsajja,"
    },
    {
      "id": "thag20.1:49.6",
      "pali": "kakusandhañca brāhmaṇaṁ."
    },
    {
      "id": "thag20.1:50.1",
      "pali": "Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:50.2",
      "pali": "bhikkhu buddhassa sāvako;"
    },
    {
      "id": "thag20.1:50.3",
      "pali": "Tādisaṁ bhikkhumāsajja,"
    },
    {
      "id": "thag20.1:50.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:51.1",
      "pali": "Majjhesarasmiṁ tiṭṭhanti,"
    },
    {
      "id": "thag20.1:51.2",
      "pali": "vimānā kappaṭhāyino;"
    },
    {
      "id": "thag20.1:51.3",
      "pali": "Veḷuriyavaṇṇā rucirā,"
    },
    {
      "id": "thag20.1:51.4",
      "pali": "accimanto pabhassarā;"
    },
    {
      "id": "thag20.1:51.5",
      "pali": "Accharā tattha naccanti,"
    },
    {
      "id": "thag20.1:51.6",
      "pali": "puthu nānattavaṇṇiyo."
    },
    {
      "id": "thag20.1:52.1",
      "pali": "Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:52.2",
      "pali": "… pe"
    },
    {
      "id": "thag20.1:52.3",
      "pali": "…"
    },
    {
      "id": "thag20.1:52.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:53.1",
      "pali": "Yo ve buddhena codito,"
    },
    {
      "id": "thag20.1:53.2",
      "pali": "bhikkhusaṅghassa pekkhato;"
    },
    {
      "id": "thag20.1:53.3",
      "pali": "Migāramātupāsādaṁ,"
    },
    {
      "id": "thag20.1:53.4",
      "pali": "pādaṅguṭṭhena kampayi."
    },
    {
      "id": "thag20.1:54.1",
      "pali": "Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:54.2",
      "pali": "… pe"
    },
    {
      "id": "thag20.1:54.3",
      "pali": "…"
    },
    {
      "id": "thag20.1:54.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:55.1",
      "pali": "Yo vejayantapāsādaṁ,"
    },
    {
      "id": "thag20.1:55.2",
      "pali": "pādaṅguṭṭhena kampayi;"
    },
    {
      "id": "thag20.1:55.3",
      "pali": "Iddhibalenupatthaddho,"
    },
    {
      "id": "thag20.1:55.4",
      "pali": "saṁvejesi ca devatā."
    },
    {
      "id": "thag20.1:56.1",
      "pali": "Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:56.2",
      "pali": "… pe"
    },
    {
      "id": "thag20.1:56.3",
      "pali": "…"
    },
    {
      "id": "thag20.1:56.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:57.1",
      "pali": "Yo vejayantapāsāde,"
    },
    {
      "id": "thag20.1:57.2",
      "pali": "sakkaṁ so paripucchati;"
    },
    {
      "id": "thag20.1:57.3",
      "pali": "Api āvuso jānāsi,"
    },
    {
      "id": "thag20.1:57.4",
      "pali": "taṇhakkhayavimuttiyo;"
    },
    {
      "id": "thag20.1:57.5",
      "pali": "Tassa sakko viyākāsi,"
    },
    {
      "id": "thag20.1:57.6",
      "pali": "pañhaṁ puṭṭho yathātathaṁ”."
    },
    {
      "id": "thag20.1:58.1",
      "pali": "“Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:58.2",
      "pali": "… pe"
    },
    {
      "id": "thag20.1:58.3",
      "pali": "…"
    },
    {
      "id": "thag20.1:58.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:59.1",
      "pali": "Yo brahmānaṁ paripucchati,"
    },
    {
      "id": "thag20.1:59.2",
      "pali": "Sudhammāyaṁ ṭhito sabhaṁ;"
    },
    {
      "id": "thag20.1:59.3",
      "pali": "Ajjāpi tyāvuso sā diṭṭhi,"
    },
    {
      "id": "thag20.1:59.4",
      "pali": "Yā te diṭṭhi pure ahu;"
    },
    {
      "id": "thag20.1:59.5",
      "pali": "Passasi vītivattantaṁ,"
    },
    {
      "id": "thag20.1:59.6",
      "pali": "Brahmaloke pabhassaraṁ."
    },
    {
      "id": "thag20.1:60.1",
      "pali": "Tassa brahmā viyākāsi,"
    },
    {
      "id": "thag20.1:60.2",
      "pali": "pañhaṁ puṭṭho yathātathaṁ;"
    },
    {
      "id": "thag20.1:60.3",
      "pali": "Na me mārisa sā diṭṭhi,"
    },
    {
      "id": "thag20.1:60.4",
      "pali": "yā me diṭṭhi pure ahu."
    },
    {
      "id": "thag20.1:61.1",
      "pali": "Passāmi vītivattantaṁ,"
    },
    {
      "id": "thag20.1:61.2",
      "pali": "brahmaloke pabhassaraṁ;"
    },
    {
      "id": "thag20.1:61.3",
      "pali": "Sohaṁ ajja kathaṁ vajjaṁ,"
    },
    {
      "id": "thag20.1:61.4",
      "pali": "ahaṁ niccomhi sassato”."
    },
    {
      "id": "thag20.1:62.1",
      "pali": "“Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:62.2",
      "pali": "… pe"
    },
    {
      "id": "thag20.1:62.3",
      "pali": "…"
    },
    {
      "id": "thag20.1:62.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:63.1",
      "pali": "Yo mahāneruno kūṭaṁ,"
    },
    {
      "id": "thag20.1:63.2",
      "pali": "vimokkhena aphassayi;"
    },
    {
      "id": "thag20.1:63.3",
      "pali": "Vanaṁ pubbavidehānaṁ,"
    },
    {
      "id": "thag20.1:63.4",
      "pali": "ye ca bhūmisayā narā."
    },
    {
      "id": "thag20.1:64.1",
      "pali": "Yo etamabhijānāti,"
    },
    {
      "id": "thag20.1:64.2",
      "pali": "bhikkhu buddhassa sāvako;"
    },
    {
      "id": "thag20.1:64.3",
      "pali": "Tādisaṁ bhikkhumāsajja,"
    },
    {
      "id": "thag20.1:64.4",
      "pali": "kaṇha dukkhaṁ nigacchasi."
    },
    {
      "id": "thag20.1:65.1",
      "pali": "Na ve aggi cetayati,"
    },
    {
      "id": "thag20.1:65.2",
      "pali": "ahaṁ bālaṁ ḍahāmīti;"
    },
    {
      "id": "thag20.1:65.3",
      "pali": "Bālova jalitaṁ aggiṁ,"
    },
    {
      "id": "thag20.1:65.4",
      "pali": "āsajja naṁ paḍayhati."
    },
    {
      "id": "thag20.1:66.1",
      "pali": "Evamevaṁ tuvaṁ māra,"
    },
    {
      "id": "thag20.1:66.2",
      "pali": "āsajja naṁ tathāgataṁ;"
    },
    {
      "id": "thag20.1:66.3",
      "pali": "Sayaṁ ḍahissasi attānaṁ,"
    },
    {
      "id": "thag20.1:66.4",
      "pali": "bālo aggiṁva samphusaṁ."
    },
    {
      "id": "thag20.1:67.1",
      "pali": "Apuññaṁ pasavī māro,"
    },
    {
      "id": "thag20.1:67.2",
      "pali": "āsajja naṁ tathāgataṁ;"
    },
    {
      "id": "thag20.1:67.3",
      "pali": "Kiṁ nu maññasi pāpima,"
    },
    {
      "id": "thag20.1:67.4",
      "pali": "na me pāpaṁ vipaccati."
    },
    {
      "id": "thag20.1:68.1",
      "pali": "Karato te cīyate pāpaṁ,"
    },
    {
      "id": "thag20.1:68.2",
      "pali": "cirarattāya antaka;"
    },
    {
      "id": "thag20.1:68.3",
      "pali": "Māra nibbinda buddhamhā,"
    },
    {
      "id": "thag20.1:68.4",
      "pali": "āsaṁ mākāsi bhikkhusu”."
    },
    {
      "id": "thag20.1:69.1",
      "pali": "“Iti māraṁ atajjesi,"
    },
    {
      "id": "thag20.1:69.2",
      "pali": "bhikkhu bhesakaḷāvane;"
    },
    {
      "id": "thag20.1:69.3",
      "pali": "Tato so dummano yakkho,"
    },
    {
      "id": "thag20.1:69.4",
      "pali": "tatthevantaradhāyathā”ti."
    },
    {
      "id": "thag20.1:69.5",
      "pali": "Itthaṁ sudaṁ āyasmā mahāmoggallāno thero gāthāyo abhāsitthāti."
    },
    {
      "id": "thag20.1:69.6",
      "pali": "Saṭṭhinipāto niṭṭhito."
    },
    {
      "id": "thag20.1:70.1",
      "pali": "Saṭṭhikamhi nipātamhi,"
    },
    {
      "id": "thag20.1:70.2",
      "pali": "moggallāno mahiddhiko;"
    },
    {
      "id": "thag20.1:70.3",
      "pali": "Ekova theragāthāyo,"
    },
    {
      "id": "thag20.1:70.4",
      "pali": "aṭṭhasaṭṭhi bhavanti tāti."
    }
  ]
}
