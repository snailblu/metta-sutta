{
  "uid": "thig6.2",
  "title": "Vāseṭṭhītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.2:1.1",
      "pali": "“Puttasokenahaṁ aṭṭā,"
    },
    {
      "id": "thig6.2:1.2",
      "pali": "khittacittā visaññinī;"
    },
    {
      "id": "thig6.2:1.3",
      "pali": "Naggā pakiṇṇakesī ca,"
    },
    {
      "id": "thig6.2:1.4",
      "pali": "tena tena vicārihaṁ."
    },
    {
      "id": "thig6.2:2.1",
      "pali": "Vīthi saṅkārakūṭesu,"
    },
    {
      "id": "thig6.2:2.2",
      "pali": "susāne rathiyāsu ca;"
    },
    {
      "id": "thig6.2:2.3",
      "pali": "Acariṁ tīṇi vassāni,"
    },
    {
      "id": "thig6.2:2.4",
      "pali": "khuppipāsāsamappitā."
    },
    {
      "id": "thig6.2:3.1",
      "pali": "Athaddasāsiṁ sugataṁ,"
    },
    {
      "id": "thig6.2:3.2",
      "pali": "nagaraṁ mithilaṁ pati;"
    },
    {
      "id": "thig6.2:3.3",
      "pali": "Adantānaṁ dametāraṁ,"
    },
    {
      "id": "thig6.2:3.4",
      "pali": "sambuddhamakutobhayaṁ."
    },
    {
      "id": "thig6.2:4.1",
      "pali": "Sacittaṁ paṭiladdhāna,"
    },
    {
      "id": "thig6.2:4.2",
      "pali": "vanditvāna upāvisiṁ;"
    },
    {
      "id": "thig6.2:4.3",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thig6.2:4.4",
      "pali": "anukampāya gotamo."
    },
    {
      "id": "thig6.2:5.1",
      "pali": "Tassa dhammaṁ suṇitvāna,"
    },
    {
      "id": "thig6.2:5.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thig6.2:5.3",
      "pali": "Yuñjantī satthuvacane,"
    },
    {
      "id": "thig6.2:5.4",
      "pali": "sacchākāsiṁ padaṁ sivaṁ."
    },
    {
      "id": "thig6.2:6.1",
      "pali": "Sabbe sokā samucchinnā,"
    },
    {
      "id": "thig6.2:6.2",
      "pali": "pahīnā etadantikā;"
    },
    {
      "id": "thig6.2:6.3",
      "pali": "Pariññātā hi me vatthū,"
    },
    {
      "id": "thig6.2:6.4",
      "pali": "yato sokāna sambhavo”ti."
    },
    {
      "id": "thig6.2:7.1",
      "pali": "… Vāseṭṭhī therī …."
    }
  ]
}
