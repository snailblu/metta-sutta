{
  "uid": "tha-ap219",
  "title": "Tālavaṇṭadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap219:1.1",
      "pali": "“Tālavaṇṭaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap219:1.2",
      "pali": "tissassādiccabandhuno;"
    },
    {
      "id": "tha-ap219:1.3",
      "pali": "Gimhanibbāpanatthāya,"
    },
    {
      "id": "tha-ap219:1.4",
      "pali": "pariḷāhopasantiyā."
    },
    {
      "id": "tha-ap219:2.1",
      "pali": "Sannibbāpemi rāgaggiṁ,"
    },
    {
      "id": "tha-ap219:2.2",
      "pali": "dosaggiñca taduttariṁ;"
    },
    {
      "id": "tha-ap219:2.3",
      "pali": "Nibbāpemi ca mohaggiṁ,"
    },
    {
      "id": "tha-ap219:2.4",
      "pali": "tālavaṇṭassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap219:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap219:3.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap219:3.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap219:3.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap219:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap219:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap219:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap219:4.4",
      "pali": "tālavaṇṭassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap219:5.1",
      "pali": "Tesaṭṭhimhi ito kappe,"
    },
    {
      "id": "tha-ap219:5.2",
      "pali": "mahānāmasanāmako;"
    },
    {
      "id": "tha-ap219:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap219:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap219:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap219:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap219:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap219:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tālavaṇṭadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap219:8.1",
      "pali": "Tālavaṇṭadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
