{
  "uid": "vv69",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv69:1.1",
      "pali": "Suriyo yathā vigatavalāhake nabhe,"
    },
    {
      "id": "vv69:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv69:2.1",
      "pali": "(Yathā purimavimānaṁ tathā vitthāretabbaṁ.)"
    },
    {
      "id": "vv69:3.1",
      "pali": "“Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv69:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv69:3.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv69:4.1",
      "pali": "Dutiyaupassayadāyakavimānaṁ pañcamaṁ."
    }
  ]
}
