{
  "uid": "tha-ap508",
  "title": "Mātuluṅgaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap508:1.1",
      "pali": "“Kaṇikāraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap508:1.2",
      "pali": "puṇṇamāyeva candimaṁ;"
    },
    {
      "id": "tha-ap508:1.3",
      "pali": "Jalantaṁ dīparukkhaṁva,"
    },
    {
      "id": "tha-ap508:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap508:2.1",
      "pali": "Mātuluṅgaphalaṁ gayha,"
    },
    {
      "id": "tha-ap508:2.2",
      "pali": "adāsiṁ satthuno ahaṁ;"
    },
    {
      "id": "tha-ap508:2.3",
      "pali": "Dakkhiṇeyyassa vīrassa,"
    },
    {
      "id": "tha-ap508:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap508:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap508:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap508:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap508:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap508:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap508:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap508:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap508:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap508:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap508:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap508:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap508:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap508:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap508:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā mātuluṅgaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap508:8.1",
      "pali": "Mātuluṅgaphaladāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
