{
  "uid": "tha-ap187",
  "title": "Isimuggadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap187:1.1",
      "pali": "“Udentaṁ sataraṁsiṁva,"
    },
    {
      "id": "tha-ap187:1.2",
      "pali": "pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap187:1.3",
      "pali": "Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap187:1.4",
      "pali": "padumuttaranāyakaṁ."
    },
    {
      "id": "tha-ap187:2.1",
      "pali": "Isimuggāni pisitvā,"
    },
    {
      "id": "tha-ap187:2.2",
      "pali": "madhukhudde anīḷake;"
    },
    {
      "id": "tha-ap187:2.3",
      "pali": "Pāsādeva ṭhito santo,"
    },
    {
      "id": "tha-ap187:2.4",
      "pali": "adāsiṁ lokabandhuno."
    },
    {
      "id": "tha-ap187:3.1",
      "pali": "Aṭṭhasatasahassāni,"
    },
    {
      "id": "tha-ap187:3.2",
      "pali": "ahesuṁ buddhasāvakā;"
    },
    {
      "id": "tha-ap187:3.3",
      "pali": "Sabbesaṁ pattapūrentaṁ,"
    },
    {
      "id": "tha-ap187:3.4",
      "pali": "tato cāpi bahuttaraṁ."
    },
    {
      "id": "tha-ap187:4.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap187:4.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap187:4.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap187:4.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap187:5.1",
      "pali": "Cattālīsamhi sahasse,"
    },
    {
      "id": "tha-ap187:5.2",
      "pali": "kappānaṁ aṭṭhatiṁsa te;"
    },
    {
      "id": "tha-ap187:5.3",
      "pali": "Isimuggasanāmā te,"
    },
    {
      "id": "tha-ap187:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap187:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap187:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap187:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap187:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā isimuggadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap187:8.1",
      "pali": "Isimuggadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
