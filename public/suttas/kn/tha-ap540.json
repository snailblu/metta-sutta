{
  "uid": "tha-ap540",
  "title": "8 Uruveḷakassapattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap540:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap540:1.2",
      "pali": "sabbalokavidū muni;"
    },
    {
      "id": "tha-ap540:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap540:1.4",
      "pali": "kappe uppajji cakkhumā."
    },
    {
      "id": "tha-ap540:2.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "tha-ap540:2.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap540:2.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "tha-ap540:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap540:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap540:3.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap540:3.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "tha-ap540:3.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "tha-ap540:4.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "tha-ap540:4.2",
      "pali": "suññataṁ titthiyehi ca;"
    },
    {
      "id": "tha-ap540:4.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "tha-ap540:4.4",
      "pali": "vasībhūtehi tādibhi."
    },
    {
      "id": "tha-ap540:5.1",
      "pali": "Ratanānaṭṭhapaññāsaṁ,"
    },
    {
      "id": "tha-ap540:5.2",
      "pali": "uggato so mahāmuni;"
    },
    {
      "id": "tha-ap540:5.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap540:5.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap540:6.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap540:6.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap540:6.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "tha-ap540:6.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap540:7.1",
      "pali": "Tadāhaṁ haṁsavatiyā,"
    },
    {
      "id": "tha-ap540:7.2",
      "pali": "brāhmaṇo sādhusammato;"
    },
    {
      "id": "tha-ap540:7.3",
      "pali": "Upecca lokapajjotaṁ,"
    },
    {
      "id": "tha-ap540:7.4",
      "pali": "assosiṁ dhammadesanaṁ."
    },
    {
      "id": "tha-ap540:8.1",
      "pali": "Tadā mahāparisatiṁ,"
    },
    {
      "id": "tha-ap540:8.2",
      "pali": "mahāparisasāvakaṁ;"
    },
    {
      "id": "tha-ap540:8.3",
      "pali": "Ṭhapentaṁ etadaggamhi,"
    },
    {
      "id": "tha-ap540:8.4",
      "pali": "sutvāna mudito ahaṁ."
    },
    {
      "id": "tha-ap540:9.1",
      "pali": "Mahatā parivārena,"
    },
    {
      "id": "tha-ap540:9.2",
      "pali": "nimantetvā mahājinaṁ;"
    },
    {
      "id": "tha-ap540:9.3",
      "pali": "Brāhmaṇānaṁ sahassena,"
    },
    {
      "id": "tha-ap540:9.4",
      "pali": "sahadānamadāsahaṁ."
    },
    {
      "id": "tha-ap540:10.1",
      "pali": "Mahādānaṁ daditvāna,"
    },
    {
      "id": "tha-ap540:10.2",
      "pali": "abhivādiya nāyakaṁ;"
    },
    {
      "id": "tha-ap540:10.3",
      "pali": "Ekamantaṁ ṭhito haṭṭho,"
    },
    {
      "id": "tha-ap540:10.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap540:11.1",
      "pali": "‘Tayi saddhāya me vīra,"
    },
    {
      "id": "tha-ap540:11.2",
      "pali": "adhikāraguṇena ca;"
    },
    {
      "id": "tha-ap540:11.3",
      "pali": "Parisā mahatī hotu,"
    },
    {
      "id": "tha-ap540:11.4",
      "pali": "nibbattassa tahiṁ tahiṁ’."
    },
    {
      "id": "tha-ap540:12.1",
      "pali": "Tadā avoca parisaṁ,"
    },
    {
      "id": "tha-ap540:12.2",
      "pali": "gajagajjitasussaro;"
    },
    {
      "id": "tha-ap540:12.3",
      "pali": "Karavīkaruto satthā,"
    },
    {
      "id": "tha-ap540:12.4",
      "pali": "‘etaṁ passatha brāhmaṇaṁ."
    },
    {
      "id": "tha-ap540:13.1",
      "pali": "Hemavaṇṇaṁ mahābāhuṁ,"
    },
    {
      "id": "tha-ap540:13.2",
      "pali": "kamalānanalocanaṁ;"
    },
    {
      "id": "tha-ap540:13.3",
      "pali": "Udaggatanujaṁ haṭṭhaṁ,"
    },
    {
      "id": "tha-ap540:13.4",
      "pali": "saddhavantaṁ guṇe mama."
    },
    {
      "id": "tha-ap540:14.1",
      "pali": "Esa patthayate ṭhānaṁ,"
    },
    {
      "id": "tha-ap540:14.2",
      "pali": "sīhaghosassa bhikkhuno;"
    },
    {
      "id": "tha-ap540:14.3",
      "pali": "Anāgatamhi addhāne,"
    },
    {
      "id": "tha-ap540:14.4",
      "pali": "lacchase taṁ manorathaṁ."
    },
    {
      "id": "tha-ap540:15.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap540:15.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap540:15.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap540:15.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap540:16.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap540:16.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap540:16.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap540:16.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap540:17.1",
      "pali": "Ito dvenavute kappe,"
    },
    {
      "id": "tha-ap540:17.2",
      "pali": "ahu satthā anuttaro;"
    },
    {
      "id": "tha-ap540:17.3",
      "pali": "Anūpamo asadiso,"
    },
    {
      "id": "tha-ap540:17.4",
      "pali": "phusso lokagganāyako."
    },
    {
      "id": "tha-ap540:18.1",
      "pali": "So ca sabbaṁ tamaṁ hantvā,"
    },
    {
      "id": "tha-ap540:18.2",
      "pali": "vijaṭetvā mahājaṭaṁ;"
    },
    {
      "id": "tha-ap540:18.3",
      "pali": "Vassate amataṁ vuṭṭhiṁ,"
    },
    {
      "id": "tha-ap540:18.4",
      "pali": "tappayanto sadevakaṁ."
    },
    {
      "id": "tha-ap540:19.1",
      "pali": "Tadā hi bārāṇasiyaṁ,"
    },
    {
      "id": "tha-ap540:19.2",
      "pali": "rājā paccā ahumhase;"
    },
    {
      "id": "tha-ap540:19.3",
      "pali": "Bhātaromha tayo sabbe,"
    },
    {
      "id": "tha-ap540:19.4",
      "pali": "saṁvisaṭṭhāva rājino."
    },
    {
      "id": "tha-ap540:20.1",
      "pali": "Vīraṅgarūpā balino,"
    },
    {
      "id": "tha-ap540:20.2",
      "pali": "saṅgāme aparājitā;"
    },
    {
      "id": "tha-ap540:20.3",
      "pali": "Tadā kupitapaccanto,"
    },
    {
      "id": "tha-ap540:20.4",
      "pali": "amhe āha mahīpati."
    },
    {
      "id": "tha-ap540:21.1",
      "pali": "‘Etha gantvāna paccantaṁ,"
    },
    {
      "id": "tha-ap540:21.2",
      "pali": "sodhetvā aṭṭavībalaṁ;"
    },
    {
      "id": "tha-ap540:21.3",
      "pali": "Khemaṁ vijiritaṁ katvā,"
    },
    {
      "id": "tha-ap540:21.4",
      "pali": "puna dethāti bhāsatha’."
    },
    {
      "id": "tha-ap540:22.1",
      "pali": "Tato mayaṁ avocumha,"
    },
    {
      "id": "tha-ap540:22.2",
      "pali": "yadi deyyāsi nāyakaṁ;"
    },
    {
      "id": "tha-ap540:22.3",
      "pali": "Upaṭṭhānāya amhākaṁ,"
    },
    {
      "id": "tha-ap540:22.4",
      "pali": "sādhayissāma vo tato."
    },
    {
      "id": "tha-ap540:23.1",
      "pali": "Tato mayaṁ laddhavarā,"
    },
    {
      "id": "tha-ap540:23.2",
      "pali": "bhūmipālena pesitā;"
    },
    {
      "id": "tha-ap540:23.3",
      "pali": "Nikkhittasatthaṁ paccantaṁ,"
    },
    {
      "id": "tha-ap540:23.4",
      "pali": "katvā punarupacca taṁ."
    },
    {
      "id": "tha-ap540:24.1",
      "pali": "Yācitvā satthupaṭṭhānaṁ,"
    },
    {
      "id": "tha-ap540:24.2",
      "pali": "rājānaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap540:24.3",
      "pali": "Munivīraṁ labhitvāna,"
    },
    {
      "id": "tha-ap540:24.4",
      "pali": "yāvajīvaṁ yajimha taṁ."
    },
    {
      "id": "tha-ap540:25.1",
      "pali": "Mahagghāni ca vatthāni,"
    },
    {
      "id": "tha-ap540:25.2",
      "pali": "paṇītāni rasāni ca;"
    },
    {
      "id": "tha-ap540:25.3",
      "pali": "Senāsanāni rammāni,"
    },
    {
      "id": "tha-ap540:25.4",
      "pali": "bhesajjāni hitāni ca."
    },
    {
      "id": "tha-ap540:26.1",
      "pali": "Datvā sasaṅghamunino,"
    },
    {
      "id": "tha-ap540:26.2",
      "pali": "dhammenuppāditāni no;"
    },
    {
      "id": "tha-ap540:26.3",
      "pali": "Sīlavanto kāruṇikā,"
    },
    {
      "id": "tha-ap540:26.4",
      "pali": "bhāvanāyuttamānasā."
    },
    {
      "id": "tha-ap540:27.1",
      "pali": "Saddhā paricaritvāna,"
    },
    {
      "id": "tha-ap540:27.2",
      "pali": "mettacittena nāyakaṁ;"
    },
    {
      "id": "tha-ap540:27.3",
      "pali": "Nibbute tamhi lokagge,"
    },
    {
      "id": "tha-ap540:27.4",
      "pali": "pūjaṁ katvā yathābalaṁ."
    },
    {
      "id": "tha-ap540:28.1",
      "pali": "Tato cutā santusitaṁ,"
    },
    {
      "id": "tha-ap540:28.2",
      "pali": "gatā tattha mahāsukhaṁ;"
    },
    {
      "id": "tha-ap540:28.3",
      "pali": "Anubhūtā mayaṁ sabbe,"
    },
    {
      "id": "tha-ap540:28.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap540:29.1",
      "pali": "Māyākāro yathā raṅge,"
    },
    {
      "id": "tha-ap540:29.2",
      "pali": "dassesi vikatiṁ bahuṁ;"
    },
    {
      "id": "tha-ap540:29.3",
      "pali": "Tathā bhave bhamantohaṁ,"
    },
    {
      "id": "tha-ap540:29.4",
      "pali": "videhādhipatī ahuṁ."
    },
    {
      "id": "tha-ap540:30.1",
      "pali": "Guṇāceḷassa vākyena,"
    },
    {
      "id": "tha-ap540:30.2",
      "pali": "micchādiṭṭhigatāsayo;"
    },
    {
      "id": "tha-ap540:30.3",
      "pali": "Narakaṁ maggamārūḷho,"
    },
    {
      "id": "tha-ap540:30.4",
      "pali": "rucāya mama dhītuyā."
    },
    {
      "id": "tha-ap540:31.1",
      "pali": "Ovādaṁ nādiyitvāna,"
    },
    {
      "id": "tha-ap540:31.2",
      "pali": "brahmunā nāradenahaṁ;"
    },
    {
      "id": "tha-ap540:31.3",
      "pali": "Bahudhā saṁsito santo,"
    },
    {
      "id": "tha-ap540:31.4",
      "pali": "diṭṭhiṁ hitvāna pāpikaṁ."
    },
    {
      "id": "tha-ap540:32.1",
      "pali": "Pūrayitvā visesena,"
    },
    {
      "id": "tha-ap540:32.2",
      "pali": "dasa kammapathānihaṁ;"
    },
    {
      "id": "tha-ap540:32.3",
      "pali": "Hitvāna dehamagamiṁ,"
    },
    {
      "id": "tha-ap540:32.4",
      "pali": "saggaṁ sabhavanaṁ yathā."
    },
    {
      "id": "tha-ap540:33.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap540:33.2",
      "pali": "brahmabandhu ahosahaṁ;"
    },
    {
      "id": "tha-ap540:33.3",
      "pali": "Bārāṇasiyaṁ phītāyaṁ,"
    },
    {
      "id": "tha-ap540:33.4",
      "pali": "jāto vippamahākule."
    },
    {
      "id": "tha-ap540:34.1",
      "pali": "Maccubyādhijarā bhīto,"
    },
    {
      "id": "tha-ap540:34.2",
      "pali": "ogāhetvā mahāvanaṁ;"
    },
    {
      "id": "tha-ap540:34.3",
      "pali": "Nibbānaṁ padamesanto,"
    },
    {
      "id": "tha-ap540:34.4",
      "pali": "jaṭilesu paribbajiṁ."
    },
    {
      "id": "tha-ap540:35.1",
      "pali": "Tadā dve bhātaro mayhaṁ,"
    },
    {
      "id": "tha-ap540:35.2",
      "pali": "pabbajiṁsu mayā saha;"
    },
    {
      "id": "tha-ap540:35.3",
      "pali": "Uruvelāyaṁ māpetvā,"
    },
    {
      "id": "tha-ap540:35.4",
      "pali": "assamaṁ nivasiṁ ahaṁ."
    },
    {
      "id": "tha-ap540:36.1",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap540:36.2",
      "pali": "uruveḷanivāsiko;"
    },
    {
      "id": "tha-ap540:36.3",
      "pali": "Tato me āsi paññatti,"
    },
    {
      "id": "tha-ap540:36.4",
      "pali": "uruveḷakassapo iti."
    },
    {
      "id": "tha-ap540:37.1",
      "pali": "Nadīsakāse bhātā me,"
    },
    {
      "id": "tha-ap540:37.2",
      "pali": "nadīkassapasavhayo;"
    },
    {
      "id": "tha-ap540:37.3",
      "pali": "Āsī sakāsanāmena,"
    },
    {
      "id": "tha-ap540:37.4",
      "pali": "gayāyaṁ gayākassapo."
    },
    {
      "id": "tha-ap540:38.1",
      "pali": "Dve satāni kaniṭṭhassa,"
    },
    {
      "id": "tha-ap540:38.2",
      "pali": "tīṇi majjhassa bhātuno;"
    },
    {
      "id": "tha-ap540:38.3",
      "pali": "Mama pañca satānūnā,"
    },
    {
      "id": "tha-ap540:38.4",
      "pali": "sissā sabbe mamānugā."
    },
    {
      "id": "tha-ap540:39.1",
      "pali": "Tadā upecca maṁ buddho,"
    },
    {
      "id": "tha-ap540:39.2",
      "pali": "katvāna vividhāni me;"
    },
    {
      "id": "tha-ap540:39.3",
      "pali": "Pāṭihīrāni lokaggo,"
    },
    {
      "id": "tha-ap540:39.4",
      "pali": "vinesi narasārathi."
    },
    {
      "id": "tha-ap540:40.1",
      "pali": "Sahassaparivārena,"
    },
    {
      "id": "tha-ap540:40.2",
      "pali": "ahosiṁ ehibhikkhuko;"
    },
    {
      "id": "tha-ap540:40.3",
      "pali": "Teheva saha sabbehi,"
    },
    {
      "id": "tha-ap540:40.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap540:41.1",
      "pali": "Te cevaññe ca bahavo,"
    },
    {
      "id": "tha-ap540:41.2",
      "pali": "sissā maṁ parivārayuṁ;"
    },
    {
      "id": "tha-ap540:41.3",
      "pali": "Sāsituñca samatthohaṁ,"
    },
    {
      "id": "tha-ap540:41.4",
      "pali": "tato maṁ isisattamo."
    },
    {
      "id": "tha-ap540:42.1",
      "pali": "Mahāparisabhāvasmiṁ,"
    },
    {
      "id": "tha-ap540:42.2",
      "pali": "etadagge ṭhapesi maṁ;"
    },
    {
      "id": "tha-ap540:42.3",
      "pali": "Aho buddhe kataṁ kāraṁ,"
    },
    {
      "id": "tha-ap540:42.4",
      "pali": "saphalaṁ me ajāyatha."
    },
    {
      "id": "tha-ap540:43.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap540:43.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap540:43.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap540:44.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap540:44.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap540:44.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap540:45.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap540:45.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap540:45.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap540:46.1",
      "pali": "Itthaṁ sudaṁ āyasmā uruveḷakassapo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap540:47.1",
      "pali": "Uruveḷakassapattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
