{
  "uid": "tha-ap378",
  "title": "Gandhamuṭṭhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap378:1.1",
      "pali": "“Citake karīyamāne,"
    },
    {
      "id": "tha-ap378:1.2",
      "pali": "nānāgandhe samāhate;"
    },
    {
      "id": "tha-ap378:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap378:1.4",
      "pali": "gandhamuṭṭhimapūjayiṁ."
    },
    {
      "id": "tha-ap378:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap378:2.2",
      "pali": "citakaṁ yaṁ apūjayiṁ;"
    },
    {
      "id": "tha-ap378:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap378:2.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap378:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap378:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap378:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap378:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap378:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap378:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap378:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap378:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap378:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap378:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhamuṭṭhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap378:7.1",
      "pali": "Gandhamuṭṭhiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
