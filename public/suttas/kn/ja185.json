{
  "uid": "ja185",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja185:1.1",
      "pali": "“Yathodake āvile appasanne,"
    },
    {
      "id": "ja185:1.2",
      "pali": "Na passati sippikasambukañca;"
    },
    {
      "id": "ja185:1.3",
      "pali": "Sakkharaṁ vālukaṁ macchagumbaṁ,"
    },
    {
      "id": "ja185:1.4",
      "pali": "Evaṁ āvilamhi citte;"
    },
    {
      "id": "ja185:1.5",
      "pali": "Na passati attadatthaṁ paratthaṁ."
    },
    {
      "id": "ja185:2.1",
      "pali": "Yathodake acche vippasanne,"
    },
    {
      "id": "ja185:2.2",
      "pali": "So passati sippikasambukañca;"
    },
    {
      "id": "ja185:2.3",
      "pali": "Sakkharaṁ vālukaṁ macchagumbaṁ,"
    },
    {
      "id": "ja185:2.4",
      "pali": "Evaṁ anāvilamhi citte;"
    },
    {
      "id": "ja185:2.5",
      "pali": "So passati attadatthaṁ paratthan”ti."
    },
    {
      "id": "ja185:3.1",
      "pali": "Anabhiratijātakaṁ pañcamaṁ."
    }
  ]
}
