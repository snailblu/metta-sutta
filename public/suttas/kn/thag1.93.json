{
  "uid": "thag1.93",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.93:1.1",
      "pali": "“Dukkhā kāmā eraka,"
    },
    {
      "id": "thag1.93:1.2",
      "pali": "Na sukhā kāmā eraka;"
    },
    {
      "id": "thag1.93:1.3",
      "pali": "Yo kāme kāmayati,"
    },
    {
      "id": "thag1.93:1.4",
      "pali": "Dukkhaṁ so kāmayati eraka;"
    },
    {
      "id": "thag1.93:1.5",
      "pali": "Yo kāme na kāmayati,"
    },
    {
      "id": "thag1.93:1.6",
      "pali": "Dukkhaṁ so na kāmayati erakā”ti."
    },
    {
      "id": "thag1.93:1.7",
      "pali": "… Erako thero …."
    }
  ]
}
