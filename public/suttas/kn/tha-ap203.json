{
  "uid": "tha-ap203",
  "title": "Kaṇikārapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap203:1.1",
      "pali": "“Kaṇikāraṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap203:1.2",
      "pali": "ocinitvānahaṁ tadā;"
    },
    {
      "id": "tha-ap203:1.3",
      "pali": "Tissassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap203:1.4",
      "pali": "oghatiṇṇassa tādino."
    },
    {
      "id": "tha-ap203:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap203:2.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap203:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap203:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap203:3.1",
      "pali": "Pañcattiṁse ito kappe,"
    },
    {
      "id": "tha-ap203:3.2",
      "pali": "aruṇapāṇīti vissuto;"
    },
    {
      "id": "tha-ap203:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap203:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap203:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap203:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap203:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap203:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap203:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kaṇikārapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap203:6.1",
      "pali": "Kaṇikārapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
