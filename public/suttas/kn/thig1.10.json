{
  "uid": "thig1.10",
  "title": "Upasamātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.10:1.1",
      "pali": "“Upasame tare oghaṁ,"
    },
    {
      "id": "thig1.10:1.2",
      "pali": "maccudheyyaṁ suduttaraṁ;"
    },
    {
      "id": "thig1.10:1.3",
      "pali": "Dhārehi antimaṁ dehaṁ,"
    },
    {
      "id": "thig1.10:1.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "thig1.10:2.1",
      "pali": "… Upasamā therī …."
    }
  ]
}
