{
  "uid": "ja110",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja110:1.1",
      "pali": "“Sabbasaṁhārako natthi,"
    },
    {
      "id": "ja110:1.2",
      "pali": "suddhaṁ kaṅgu pavāyati;"
    },
    {
      "id": "ja110:1.3",
      "pali": "Alikaṁ bhāyatiyaṁ dhuttī,"
    },
    {
      "id": "ja110:1.4",
      "pali": "saccamāha mahallikā”ti."
    },
    {
      "id": "ja110:2.1",
      "pali": "Sabbasaṁhārakapañhajātakaṁ dasamaṁ."
    },
    {
      "id": "ja110:2.2",
      "pali": "Parosatavaggo ekādasamo."
    },
    {
      "id": "ja110:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja110:4.1",
      "pali": "Saparosatatāyitaverī puna,"
    },
    {
      "id": "ja110:4.2",
      "pali": "Bhamacakkatha nāgasirivhayano;"
    },
    {
      "id": "ja110:4.3",
      "pali": "Sukhakañca vata sippaka bāhiyā,"
    },
    {
      "id": "ja110:4.4",
      "pali": "Kuṇḍapūva mahallikakā ca dasāti."
    }
  ]
}
