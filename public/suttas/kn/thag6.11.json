{
  "uid": "thag6.11",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.11:1.1",
      "pali": "“Vātarogābhinīto tvaṁ,"
    },
    {
      "id": "thag6.11:1.2",
      "pali": "viharaṁ kānane vane;"
    },
    {
      "id": "thag6.11:1.3",
      "pali": "Paviddhagocare lūkhe,"
    },
    {
      "id": "thag6.11:1.4",
      "pali": "kathaṁ bhikkhu karissasi”."
    },
    {
      "id": "thag6.11:2.1",
      "pali": "“Pītisukhena vipulena,"
    },
    {
      "id": "thag6.11:2.2",
      "pali": "pharitvāna samussayaṁ;"
    },
    {
      "id": "thag6.11:2.3",
      "pali": "Lūkhampi abhisambhonto,"
    },
    {
      "id": "thag6.11:2.4",
      "pali": "viharissāmi kānane."
    },
    {
      "id": "thag6.11:3.1",
      "pali": "Bhāvento satta bojjhaṅge,"
    },
    {
      "id": "thag6.11:3.2",
      "pali": "indriyāni balāni ca;"
    },
    {
      "id": "thag6.11:3.3",
      "pali": "Jhānasokhummasampanno,"
    },
    {
      "id": "thag6.11:3.4",
      "pali": "viharissaṁ anāsavo."
    },
    {
      "id": "thag6.11:4.1",
      "pali": "Vippamuttaṁ kilesehi,"
    },
    {
      "id": "thag6.11:4.2",
      "pali": "suddhacittaṁ anāvilaṁ;"
    },
    {
      "id": "thag6.11:4.3",
      "pali": "Abhiṇhaṁ paccavekkhanto,"
    },
    {
      "id": "thag6.11:4.4",
      "pali": "viharissaṁ anāsavo."
    },
    {
      "id": "thag6.11:5.1",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "thag6.11:5.2",
      "pali": "ye me vijjiṁsu āsavā;"
    },
    {
      "id": "thag6.11:5.3",
      "pali": "Sabbe asesā ucchinnā,"
    },
    {
      "id": "thag6.11:5.4",
      "pali": "na ca uppajjare puna."
    },
    {
      "id": "thag6.11:6.1",
      "pali": "Pañcakkhandhā pariññātā,"
    },
    {
      "id": "thag6.11:6.2",
      "pali": "tiṭṭhanti chinnamūlakā;"
    },
    {
      "id": "thag6.11:6.3",
      "pali": "Dukkhakkhayo anuppatto,"
    },
    {
      "id": "thag6.11:6.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag6.11:6.5",
      "pali": "… Nhātakamunitthero …."
    }
  ]
}
