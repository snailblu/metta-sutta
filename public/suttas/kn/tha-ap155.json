{
  "uid": "tha-ap155",
  "title": "Vīthisammajjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap155:1.1",
      "pali": "“Udentaṁ sataraṁsiṁva,"
    },
    {
      "id": "tha-ap155:1.2",
      "pali": "pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap155:1.3",
      "pali": "Pannarase yathā candaṁ,"
    },
    {
      "id": "tha-ap155:1.4",
      "pali": "niyyantaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap155:2.1",
      "pali": "Aṭṭhasaṭṭhisahassāni,"
    },
    {
      "id": "tha-ap155:2.2",
      "pali": "sabbe khīṇāsavā ahuṁ;"
    },
    {
      "id": "tha-ap155:2.3",
      "pali": "Parivāriṁsu sambuddhaṁ,"
    },
    {
      "id": "tha-ap155:2.4",
      "pali": "dvipadindaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap155:3.1",
      "pali": "Sammajjitvāna taṁ vīthiṁ,"
    },
    {
      "id": "tha-ap155:3.2",
      "pali": "niyyante lokanāyake;"
    },
    {
      "id": "tha-ap155:3.3",
      "pali": "Ussāpesiṁ dhajaṁ tattha,"
    },
    {
      "id": "tha-ap155:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap155:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap155:4.2",
      "pali": "yaṁ dhajaṁ abhiropayiṁ;"
    },
    {
      "id": "tha-ap155:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap155:4.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap155:5.1",
      "pali": "Ito catutthake kappe,"
    },
    {
      "id": "tha-ap155:5.2",
      "pali": "rājāhosiṁ mahabbalo;"
    },
    {
      "id": "tha-ap155:5.3",
      "pali": "Sabbākārena sampanno,"
    },
    {
      "id": "tha-ap155:5.4",
      "pali": "sudhajo iti vissuto."
    },
    {
      "id": "tha-ap155:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap155:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap155:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap155:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā vīthisammajjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap155:8.1",
      "pali": "Vīthisammajjakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
