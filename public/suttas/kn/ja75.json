{
  "uid": "ja75",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja75:1.1",
      "pali": "“Abhitthanaya pajjunna,"
    },
    {
      "id": "ja75:1.2",
      "pali": "nidhiṁ kākassa nāsaya;"
    },
    {
      "id": "ja75:1.3",
      "pali": "Kākaṁ sokāya randhehi,"
    },
    {
      "id": "ja75:1.4",
      "pali": "mañca sokā pamocayā”ti."
    },
    {
      "id": "ja75:2.1",
      "pali": "Macchajātakaṁ pañcamaṁ."
    }
  ]
}
