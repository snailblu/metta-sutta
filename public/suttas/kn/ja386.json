{
  "uid": "ja386",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja386:1.1",
      "pali": "“Saccaṁ kirevamāhaṁsu,"
    },
    {
      "id": "ja386:1.2",
      "pali": "vastaṁ bāloti paṇḍitā;"
    },
    {
      "id": "ja386:1.3",
      "pali": "Passa bālo rahokammaṁ,"
    },
    {
      "id": "ja386:1.4",
      "pali": "āvikubbaṁ na bujjhati”."
    },
    {
      "id": "ja386:2.1",
      "pali": "“Tvaṁ khopi samma bālosi,"
    },
    {
      "id": "ja386:2.2",
      "pali": "kharaputta vijānahi;"
    },
    {
      "id": "ja386:2.3",
      "pali": "Rajjuyā hi parikkhitto,"
    },
    {
      "id": "ja386:2.4",
      "pali": "vaṅkoṭṭho ohitomukho."
    },
    {
      "id": "ja386:3.1",
      "pali": "Aparampi samma te bālyaṁ,"
    },
    {
      "id": "ja386:3.2",
      "pali": "yo mutto na palāyasi;"
    },
    {
      "id": "ja386:3.3",
      "pali": "So ca bālataro samma,"
    },
    {
      "id": "ja386:3.4",
      "pali": "yaṁ tvaṁ vahasi senakaṁ”."
    },
    {
      "id": "ja386:4.1",
      "pali": "“Yannu samma ahaṁ bālo,"
    },
    {
      "id": "ja386:4.2",
      "pali": "ajarāja vijānahi;"
    },
    {
      "id": "ja386:4.3",
      "pali": "Atha kena senako bālo,"
    },
    {
      "id": "ja386:4.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja386:5.1",
      "pali": "“Uttamatthaṁ labhitvāna,"
    },
    {
      "id": "ja386:5.2",
      "pali": "bhariyāya yo padassati;"
    },
    {
      "id": "ja386:5.3",
      "pali": "Tena jahissatattānaṁ,"
    },
    {
      "id": "ja386:5.4",
      "pali": "sā cevassa na hessati”."
    },
    {
      "id": "ja386:6.1",
      "pali": "“Na ve piyammeti janinda tādiso,"
    },
    {
      "id": "ja386:6.2",
      "pali": "Attaṁ niraṅkatvā piyāni sevati;"
    },
    {
      "id": "ja386:6.3",
      "pali": "Attāva seyyo paramā ca seyyo,"
    },
    {
      "id": "ja386:6.4",
      "pali": "Labbhā piyā ocitatthena pacchā”ti."
    },
    {
      "id": "ja386:7.1",
      "pali": "Kharaputtajātakaṁ paṭhamaṁ."
    }
  ]
}
