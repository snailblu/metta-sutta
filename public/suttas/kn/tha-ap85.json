{
  "uid": "tha-ap85",
  "title": "3 Nipannañjalikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap85:1.1",
      "pali": "“Rukkhamūle nisinnohaṁ,"
    },
    {
      "id": "tha-ap85:1.2",
      "pali": "byādhito paramena ca;"
    },
    {
      "id": "tha-ap85:1.3",
      "pali": "Paramakāruññapattomhi,"
    },
    {
      "id": "tha-ap85:1.4",
      "pali": "araññe kānane ahaṁ."
    },
    {
      "id": "tha-ap85:2.1",
      "pali": "Anukampaṁ upādāya,"
    },
    {
      "id": "tha-ap85:2.2",
      "pali": "tisso satthā upesi maṁ;"
    },
    {
      "id": "tha-ap85:2.3",
      "pali": "Sohaṁ nipannako santo,"
    },
    {
      "id": "tha-ap85:2.4",
      "pali": "sire katvāna añjaliṁ."
    },
    {
      "id": "tha-ap85:3.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap85:3.2",
      "pali": "sabbasattānamuttamaṁ;"
    },
    {
      "id": "tha-ap85:3.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap85:3.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap85:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap85:4.2",
      "pali": "yaṁ vandiṁ purisuttamaṁ;"
    },
    {
      "id": "tha-ap85:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap85:4.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap85:5.1",
      "pali": "Ito pañcamake kappe,"
    },
    {
      "id": "tha-ap85:5.2",
      "pali": "pañcevāsuṁ mahāsikhā;"
    },
    {
      "id": "tha-ap85:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap85:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap85:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap85:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap85:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap85:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā nipannañjaliko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap85:8.1",
      "pali": "Nipannañjalikattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
