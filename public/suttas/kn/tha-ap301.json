{
  "uid": "tha-ap301",
  "title": "Ambapiṇḍiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap301:1.1",
      "pali": "“Romaso nāma nāmena,"
    },
    {
      "id": "tha-ap301:1.2",
      "pali": "dānavo iti vissuto;"
    },
    {
      "id": "tha-ap301:1.3",
      "pali": "Ambapiṇḍī mayā dinnā,"
    },
    {
      "id": "tha-ap301:1.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap301:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap301:2.2",
      "pali": "yamambamadadiṁ tadā;"
    },
    {
      "id": "tha-ap301:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap301:2.4",
      "pali": "ambadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap301:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap301:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap301:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap301:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambapiṇḍiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap301:5.1",
      "pali": "Ambapiṇḍiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
