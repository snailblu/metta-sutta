{
  "uid": "tha-ap15",
  "title": "Nandattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap15:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap15:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap15:1.3",
      "pali": "Vatthaṁ khomaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap15:1.4",
      "pali": "Sayambhussa mahesino."
    },
    {
      "id": "tha-ap15:2.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "tha-ap15:2.2",
      "pali": "jalajuttaranāmako;"
    },
    {
      "id": "tha-ap15:2.3",
      "pali": "‘Iminā vatthadānena,"
    },
    {
      "id": "tha-ap15:2.4",
      "pali": "hemavaṇṇo bhavissasi."
    },
    {
      "id": "tha-ap15:3.1",
      "pali": "Dve sampattī anubhotvā,"
    },
    {
      "id": "tha-ap15:3.2",
      "pali": "kusalamūlehi codito;"
    },
    {
      "id": "tha-ap15:3.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap15:3.4",
      "pali": "kaniṭṭho tvaṁ bhavissasi."
    },
    {
      "id": "tha-ap15:4.1",
      "pali": "Rāgaratto sukhasīlo,"
    },
    {
      "id": "tha-ap15:4.2",
      "pali": "kāmesu gedhamāyuto;"
    },
    {
      "id": "tha-ap15:4.3",
      "pali": "Buddhena codito santo,"
    },
    {
      "id": "tha-ap15:4.4",
      "pali": "tadā tvaṁ pabbajissasi."
    },
    {
      "id": "tha-ap15:5.1",
      "pali": "Pabbajitvāna tvaṁ tattha,"
    },
    {
      "id": "tha-ap15:5.2",
      "pali": "kusalamūlena codito;"
    },
    {
      "id": "tha-ap15:5.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap15:5.4",
      "pali": "nibbāyissasināsavo’."
    },
    {
      "id": "tha-ap15:6.1",
      "pali": "Satta kappasahassamhi,"
    },
    {
      "id": "tha-ap15:6.2",
      "pali": "caturo ceḷanāmakā;"
    },
    {
      "id": "tha-ap15:6.3",
      "pali": "Saṭṭhi kappasahassamhi,"
    },
    {
      "id": "tha-ap15:6.4",
      "pali": "upacelā catujjanā."
    },
    {
      "id": "tha-ap15:7.1",
      "pali": "Pañca kappasahassamhi,"
    },
    {
      "id": "tha-ap15:7.2",
      "pali": "ceḷāva caturo janā;"
    },
    {
      "id": "tha-ap15:7.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap15:7.4",
      "pali": "catudīpamhi issarā."
    },
    {
      "id": "tha-ap15:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap15:8.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap15:8.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap15:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap15:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā nando thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap15:10.1",
      "pali": "Nandattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
