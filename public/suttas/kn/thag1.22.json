{
  "uid": "thag1.22",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.22:1.1",
      "pali": "“Nīlā sugīvā sikhino,"
    },
    {
      "id": "thag1.22:1.2",
      "pali": "Morā kārambhiyaṁ abhinadanti;"
    },
    {
      "id": "thag1.22:1.3",
      "pali": "Te sītavātakīḷitā,"
    },
    {
      "id": "thag1.22:1.4",
      "pali": "Suttaṁ jhāyaṁ nibodhentī”ti."
    },
    {
      "id": "thag1.22:1.5",
      "pali": "… Cittako thero …."
    }
  ]
}
