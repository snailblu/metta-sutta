{
  "uid": "tha-ap275",
  "title": "3 Caṅkoṭakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap275:1.1",
      "pali": "“Mahāsamuddaṁ nissāya,"
    },
    {
      "id": "tha-ap275:1.2",
      "pali": "vasatī pabbatantare;"
    },
    {
      "id": "tha-ap275:1.3",
      "pali": "Paccuggantvāna katvāna,"
    },
    {
      "id": "tha-ap275:1.4",
      "pali": "caṅkoṭaka madāsahaṁ."
    },
    {
      "id": "tha-ap275:2.1",
      "pali": "Siddhatthassa mahesino,"
    },
    {
      "id": "tha-ap275:2.2",
      "pali": "sabbasattānukampino;"
    },
    {
      "id": "tha-ap275:2.3",
      "pali": "Pupphacaṅkoṭakaṁ datvā,"
    },
    {
      "id": "tha-ap275:2.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap275:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap275:3.2",
      "pali": "caṅkoṭakamadaṁ tadā;"
    },
    {
      "id": "tha-ap275:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap275:3.4",
      "pali": "caṅkoṭakassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap275:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap275:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap275:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap275:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā caṅkoṭakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap275:6.1",
      "pali": "Caṅkoṭakiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
