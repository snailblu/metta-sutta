{
  "uid": "ja243",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja243:1.1",
      "pali": "“Sattatantiṁ sumadhuraṁ,"
    },
    {
      "id": "ja243:1.2",
      "pali": "rāmaṇeyyaṁ avācayiṁ;"
    },
    {
      "id": "ja243:1.3",
      "pali": "So maṁ raṅgamhi avheti,"
    },
    {
      "id": "ja243:1.4",
      "pali": "saraṇaṁ me hohi kosiya”."
    },
    {
      "id": "ja243:2.1",
      "pali": "“Ahaṁ taṁ saraṇaṁ samma,"
    },
    {
      "id": "ja243:2.2",
      "pali": "Ahamācariyapūjako;"
    },
    {
      "id": "ja243:2.3",
      "pali": "Na taṁ jayissati sisso,"
    },
    {
      "id": "ja243:2.4",
      "pali": "Sissamācariya jessasī”ti."
    },
    {
      "id": "ja243:3.1",
      "pali": "Guttilajātakaṁ tatiyaṁ."
    }
  ]
}
