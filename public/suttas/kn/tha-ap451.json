{
  "uid": "tha-ap451",
  "title": "9 Vedikārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap451:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap451:1.2",
      "pali": "Bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap451:1.3",
      "pali": "Vedikaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap451:1.4",
      "pali": "Sakaṁ cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap451:2.1",
      "pali": "Atoḷārāni bhaṇḍāni,"
    },
    {
      "id": "tha-ap451:2.2",
      "pali": "katāni akatāni ca;"
    },
    {
      "id": "tha-ap451:2.3",
      "pali": "Antalikkhā pavassanti,"
    },
    {
      "id": "tha-ap451:2.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap451:3.1",
      "pali": "Ubhato byūḷhasaṅgāme,"
    },
    {
      "id": "tha-ap451:3.2",
      "pali": "pakkhandanto bhayānake;"
    },
    {
      "id": "tha-ap451:3.3",
      "pali": "Bhayabheravaṁ na passāmi,"
    },
    {
      "id": "tha-ap451:3.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap451:4.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap451:4.2",
      "pali": "byamhaṁ nibbattate subhaṁ;"
    },
    {
      "id": "tha-ap451:4.3",
      "pali": "Sayanāni mahagghāni,"
    },
    {
      "id": "tha-ap451:4.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap451:5.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap451:5.2",
      "pali": "yaṁ vedikamakārayiṁ;"
    },
    {
      "id": "tha-ap451:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap451:5.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap451:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap451:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap451:6.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap451:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap451:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap451:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap451:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap451:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap451:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap451:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā vedikārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap451:10.1",
      "pali": "Vedikārakattherassāpadānaṁ navamaṁ."
    }
  ]
}
