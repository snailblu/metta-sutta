{
  "uid": "tha-ap52",
  "title": "Cundattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap52:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap52:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap52:1.3",
      "pali": "Agghiyaṁ kārayitvāna,"
    },
    {
      "id": "tha-ap52:1.4",
      "pali": "jātipupphehi chādayiṁ."
    },
    {
      "id": "tha-ap52:2.1",
      "pali": "Niṭṭhāpetvāna taṁ pupphaṁ,"
    },
    {
      "id": "tha-ap52:2.2",
      "pali": "buddhassa upanāmayiṁ;"
    },
    {
      "id": "tha-ap52:2.3",
      "pali": "Pupphāvasesaṁ paggayha,"
    },
    {
      "id": "tha-ap52:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap52:3.1",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap52:3.2",
      "pali": "buddhaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap52:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap52:3.4",
      "pali": "pupphagghiyamupānayiṁ."
    },
    {
      "id": "tha-ap52:4.1",
      "pali": "Vitiṇṇakaṅkho sambuddho,"
    },
    {
      "id": "tha-ap52:4.2",
      "pali": "tiṇṇoghehi purakkhato;"
    },
    {
      "id": "tha-ap52:4.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap52:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap52:5.1",
      "pali": "‘Dibbagandhaṁ pavāyantaṁ,"
    },
    {
      "id": "tha-ap52:5.2",
      "pali": "yo me pupphagghiyaṁ adā;"
    },
    {
      "id": "tha-ap52:5.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap52:5.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap52:6.1",
      "pali": "Ito cuto ayaṁ poso,"
    },
    {
      "id": "tha-ap52:6.2",
      "pali": "devasaṅghapurakkhato;"
    },
    {
      "id": "tha-ap52:6.3",
      "pali": "Jātipupphehi parikiṇṇo,"
    },
    {
      "id": "tha-ap52:6.4",
      "pali": "devalokaṁ gamissati."
    },
    {
      "id": "tha-ap52:7.1",
      "pali": "Ubbiddhaṁ bhavanaṁ tassa,"
    },
    {
      "id": "tha-ap52:7.2",
      "pali": "Sovaṇṇañca maṇīmayaṁ;"
    },
    {
      "id": "tha-ap52:7.3",
      "pali": "Byamhaṁ pātubhavissati,"
    },
    {
      "id": "tha-ap52:7.4",
      "pali": "Puññakammappabhāvitaṁ."
    },
    {
      "id": "tha-ap52:8.1",
      "pali": "Catusattatikkhattuṁ so,"
    },
    {
      "id": "tha-ap52:8.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap52:8.3",
      "pali": "Anubhossati sampattiṁ,"
    },
    {
      "id": "tha-ap52:8.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap52:9.1",
      "pali": "Pathabyā rajjaṁ tisataṁ,"
    },
    {
      "id": "tha-ap52:9.2",
      "pali": "vasudhaṁ āvasissati;"
    },
    {
      "id": "tha-ap52:9.3",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap52:9.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap52:10.1",
      "pali": "Dujjayo nāma nāmena,"
    },
    {
      "id": "tha-ap52:10.2",
      "pali": "hessati manujādhipo;"
    },
    {
      "id": "tha-ap52:10.3",
      "pali": "Anubhotvāna taṁ puññaṁ,"
    },
    {
      "id": "tha-ap52:10.4",
      "pali": "sakakammaṁ apassito."
    },
    {
      "id": "tha-ap52:11.1",
      "pali": "Vinipātaṁ agantvāna,"
    },
    {
      "id": "tha-ap52:11.2",
      "pali": "manussattaṁ gamissati;"
    },
    {
      "id": "tha-ap52:11.3",
      "pali": "Hiraññaṁ tassa nicitaṁ,"
    },
    {
      "id": "tha-ap52:11.4",
      "pali": "koṭisatamanappakaṁ."
    },
    {
      "id": "tha-ap52:12.1",
      "pali": "Nibbattissati yonimhi,"
    },
    {
      "id": "tha-ap52:12.2",
      "pali": "brāhmaṇe so bhavissati;"
    },
    {
      "id": "tha-ap52:12.3",
      "pali": "Vaṅgantassa suto dhīmā,"
    },
    {
      "id": "tha-ap52:12.4",
      "pali": "sāriyā oraso piyo."
    },
    {
      "id": "tha-ap52:13.1",
      "pali": "So ca pacchā pabbajitvā,"
    },
    {
      "id": "tha-ap52:13.2",
      "pali": "aṅgīrasassa sāsane;"
    },
    {
      "id": "tha-ap52:13.3",
      "pali": "Cūḷacundoti nāmena,"
    },
    {
      "id": "tha-ap52:13.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap52:14.1",
      "pali": "Sāmaṇerova so santo,"
    },
    {
      "id": "tha-ap52:14.2",
      "pali": "khīṇāsavo bhavissati;"
    },
    {
      "id": "tha-ap52:14.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap52:14.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap52:15.1",
      "pali": "Upaṭṭhahiṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap52:15.2",
      "pali": "aññe ca pesale bahū;"
    },
    {
      "id": "tha-ap52:15.3",
      "pali": "Bhātaraṁ me cupaṭṭhāsiṁ,"
    },
    {
      "id": "tha-ap52:15.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "tha-ap52:16.1",
      "pali": "Bhātaraṁ me upaṭṭhitvā,"
    },
    {
      "id": "tha-ap52:16.2",
      "pali": "dhātuṁ pattamhi ohiya;"
    },
    {
      "id": "tha-ap52:16.3",
      "pali": "Sambuddhaṁ upanāmesiṁ,"
    },
    {
      "id": "tha-ap52:16.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap52:17.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap52:17.2",
      "pali": "buddho loke sadevake;"
    },
    {
      "id": "tha-ap52:17.3",
      "pali": "Sandassayanto taṁ dhātuṁ,"
    },
    {
      "id": "tha-ap52:17.4",
      "pali": "kittayi aggasāvakaṁ."
    },
    {
      "id": "tha-ap52:18.1",
      "pali": "Cittañca suvimuttaṁ me,"
    },
    {
      "id": "tha-ap52:18.2",
      "pali": "saddhā mayhaṁ patiṭṭhitā;"
    },
    {
      "id": "tha-ap52:18.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap52:18.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap52:19.1",
      "pali": "Paṭisambhidānuppattā,"
    },
    {
      "id": "tha-ap52:19.2",
      "pali": "Vimokkhāpi ca phassitā;"
    },
    {
      "id": "tha-ap52:19.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap52:19.4",
      "pali": "Kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap52:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā cundo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap52:21.1",
      "pali": "Cundattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap52:22.1",
      "pali": "Upālivaggo pañcamo."
    },
    {
      "id": "tha-ap52:23.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap52:24.1",
      "pali": "Upāli soṇo bhaddiyo,"
    },
    {
      "id": "tha-ap52:24.2",
      "pali": "sanniṭṭhāpakahatthiyo;"
    },
    {
      "id": "tha-ap52:24.3",
      "pali": "Chadanaṁ seyyacaṅkamaṁ,"
    },
    {
      "id": "tha-ap52:24.4",
      "pali": "subhaddo cundasavhayo;"
    },
    {
      "id": "tha-ap52:24.5",
      "pali": "Gāthāsataṁ satālīsaṁ,"
    },
    {
      "id": "tha-ap52:24.6",
      "pali": "catasso ca taduttari."
    }
  ]
}
