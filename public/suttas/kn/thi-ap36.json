{
  "uid": "thi-ap36",
  "title": "6 Abhirūpanandātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap36:1.1",
      "pali": "“Ekanavutito kappe,"
    },
    {
      "id": "thi-ap36:1.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "thi-ap36:1.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "thi-ap36:1.4",
      "pali": "sabbadhammesu cakkhumā."
    },
    {
      "id": "thi-ap36:2.1",
      "pali": "Tadāhaṁ bandhumatiyaṁ,"
    },
    {
      "id": "thi-ap36:2.2",
      "pali": "iddhe phīte mahākule;"
    },
    {
      "id": "thi-ap36:2.3",
      "pali": "Jātā surūpā dayitā,"
    },
    {
      "id": "thi-ap36:2.4",
      "pali": "pūjanīyā janassa ca."
    },
    {
      "id": "thi-ap36:3.1",
      "pali": "Upagantvā mahāvīraṁ,"
    },
    {
      "id": "thi-ap36:3.2",
      "pali": "vipassiṁ lokanāyakaṁ;"
    },
    {
      "id": "thi-ap36:3.3",
      "pali": "Dhammaṁ suṇitvā saraṇaṁ,"
    },
    {
      "id": "thi-ap36:3.4",
      "pali": "upesiṁ naranāyakaṁ."
    },
    {
      "id": "thi-ap36:4.1",
      "pali": "Sīlesu saṁvutā hutvā,"
    },
    {
      "id": "thi-ap36:4.2",
      "pali": "nibbute ca naruttame;"
    },
    {
      "id": "thi-ap36:4.3",
      "pali": "Dhātuthūpassa upari,"
    },
    {
      "id": "thi-ap36:4.4",
      "pali": "soṇṇacchattamapūjayiṁ."
    },
    {
      "id": "thi-ap36:5.1",
      "pali": "Muttacāgā sīlavatī,"
    },
    {
      "id": "thi-ap36:5.2",
      "pali": "yāvajīvaṁ tato cutā;"
    },
    {
      "id": "thi-ap36:5.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap36:5.4",
      "pali": "tāvatiṁsūpagā ahaṁ."
    },
    {
      "id": "thi-ap36:6.1",
      "pali": "Tadā dasahi ṭhānehi,"
    },
    {
      "id": "thi-ap36:6.2",
      "pali": "adhibhotvāna sesake;"
    },
    {
      "id": "thi-ap36:6.3",
      "pali": "Rūpasaddehi gandhehi,"
    },
    {
      "id": "thi-ap36:6.4",
      "pali": "rasehi phusanehi ca."
    },
    {
      "id": "thi-ap36:7.1",
      "pali": "Āyunāpi ca vaṇṇena,"
    },
    {
      "id": "thi-ap36:7.2",
      "pali": "sukhena yasasāpi ca;"
    },
    {
      "id": "thi-ap36:7.3",
      "pali": "Tathevādhipateyyena,"
    },
    {
      "id": "thi-ap36:7.4",
      "pali": "adhigayha virocahaṁ."
    },
    {
      "id": "thi-ap36:8.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap36:8.2",
      "pali": "jātāhaṁ kapilavhaye;"
    },
    {
      "id": "thi-ap36:8.3",
      "pali": "Dhītā khemakasakkassa,"
    },
    {
      "id": "thi-ap36:8.4",
      "pali": "nandā nāmāti vissutā."
    },
    {
      "id": "thi-ap36:9.1",
      "pali": "Abhirūpasampadampi,"
    },
    {
      "id": "thi-ap36:9.2",
      "pali": "ahu me kantisūcakaṁ;"
    },
    {
      "id": "thi-ap36:9.3",
      "pali": "Yadāhaṁ yobbanappattā,"
    },
    {
      "id": "thi-ap36:9.4",
      "pali": "rūpalāvaññabhūsitā."
    },
    {
      "id": "thi-ap36:10.1",
      "pali": "Tadā mamatthe sakyānaṁ,"
    },
    {
      "id": "thi-ap36:10.2",
      "pali": "vivādo sumahā ahu;"
    },
    {
      "id": "thi-ap36:10.3",
      "pali": "Pabbājesi tato tāto,"
    },
    {
      "id": "thi-ap36:10.4",
      "pali": "‘mā sakyā vinassiṁsu’ti."
    },
    {
      "id": "thi-ap36:11.1",
      "pali": "Pabbajitvā tathāgataṁ,"
    },
    {
      "id": "thi-ap36:11.2",
      "pali": "rūpadessiṁ naruttamaṁ;"
    },
    {
      "id": "thi-ap36:11.3",
      "pali": "Sutvāna nopagacchāmi,"
    },
    {
      "id": "thi-ap36:11.4",
      "pali": "mama rūpena gabbitā."
    },
    {
      "id": "thi-ap36:12.1",
      "pali": "Ovādampi na gacchāmi,"
    },
    {
      "id": "thi-ap36:12.2",
      "pali": "buddhadassanabhīrutā;"
    },
    {
      "id": "thi-ap36:12.3",
      "pali": "Tadā jino upāyena,"
    },
    {
      "id": "thi-ap36:12.4",
      "pali": "upanetvā sasantikaṁ."
    },
    {
      "id": "thi-ap36:13.1",
      "pali": "Tissitthiyo nidassesi,"
    },
    {
      "id": "thi-ap36:13.2",
      "pali": "iddhiyā maggakovido;"
    },
    {
      "id": "thi-ap36:13.3",
      "pali": "Accharārūpasadisaṁ,"
    },
    {
      "id": "thi-ap36:13.4",
      "pali": "taruṇiṁ jaritaṁ mataṁ."
    },
    {
      "id": "thi-ap36:14.1",
      "pali": "Tāyo disvā susaṁviggā,"
    },
    {
      "id": "thi-ap36:14.2",
      "pali": "virattāse kaḷevare;"
    },
    {
      "id": "thi-ap36:14.3",
      "pali": "Aṭṭhāsiṁ bhavanibbindā,"
    },
    {
      "id": "thi-ap36:14.4",
      "pali": "tadā maṁ āha nāyako."
    },
    {
      "id": "thi-ap36:15.1",
      "pali": "‘Āturaṁ asuciṁ pūtiṁ,"
    },
    {
      "id": "thi-ap36:15.2",
      "pali": "passa nande samussayaṁ;"
    },
    {
      "id": "thi-ap36:15.3",
      "pali": "Uggharantaṁ paggharantaṁ,"
    },
    {
      "id": "thi-ap36:15.4",
      "pali": "bālānaṁ abhinanditaṁ."
    },
    {
      "id": "thi-ap36:16.1",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "thi-ap36:16.2",
      "pali": "ekaggaṁ susamāhitaṁ;"
    },
    {
      "id": "thi-ap36:16.3",
      "pali": "Yathā idaṁ tathā etaṁ,"
    },
    {
      "id": "thi-ap36:16.4",
      "pali": "yathā etaṁ tathā idaṁ."
    },
    {
      "id": "thi-ap36:17.1",
      "pali": "Evametaṁ avekkhantī,"
    },
    {
      "id": "thi-ap36:17.2",
      "pali": "rattindivamatanditā;"
    },
    {
      "id": "thi-ap36:17.3",
      "pali": "Tato sakāya paññāya,"
    },
    {
      "id": "thi-ap36:17.4",
      "pali": "abhinibbijjha vacchasi’."
    },
    {
      "id": "thi-ap36:18.1",
      "pali": "Tassā me appamattāya,"
    },
    {
      "id": "thi-ap36:18.2",
      "pali": "vicarantiyā yoniso;"
    },
    {
      "id": "thi-ap36:18.3",
      "pali": "Yathābhūtaṁ ayaṁ kāyo,"
    },
    {
      "id": "thi-ap36:18.4",
      "pali": "diṭṭho santarabāhiro."
    },
    {
      "id": "thi-ap36:19.1",
      "pali": "Atha nibbindahaṁ kāye,"
    },
    {
      "id": "thi-ap36:19.2",
      "pali": "ajjhattañca virajjahaṁ;"
    },
    {
      "id": "thi-ap36:19.3",
      "pali": "Appamattā visaṁyuttā,"
    },
    {
      "id": "thi-ap36:19.4",
      "pali": "upasantāmhi nibbutā."
    },
    {
      "id": "thi-ap36:20.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap36:20.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap36:20.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap36:20.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap36:21.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap36:21.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap36:21.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap36:21.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap36:22.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap36:22.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap36:22.3",
      "pali": "Ñāṇaṁ mama mahāvīra,"
    },
    {
      "id": "thi-ap36:22.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap36:23.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap36:23.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap36:23.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap36:24.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap36:24.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap36:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap36:25.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap36:25.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap36:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap36:26.1",
      "pali": "Itthaṁ sudaṁ abhirūpanandā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap36:27.1",
      "pali": "Abhirūpanandātheriyāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
