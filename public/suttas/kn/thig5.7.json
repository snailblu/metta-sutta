{
  "uid": "thig5.7",
  "title": "Sakulātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.7:1.1",
      "pali": "“Agārasmiṁ vasantīhaṁ,"
    },
    {
      "id": "thig5.7:1.2",
      "pali": "dhammaṁ sutvāna bhikkhuno;"
    },
    {
      "id": "thig5.7:1.3",
      "pali": "Addasaṁ virajaṁ dhammaṁ,"
    },
    {
      "id": "thig5.7:1.4",
      "pali": "nibbānaṁ padamaccutaṁ."
    },
    {
      "id": "thig5.7:2.1",
      "pali": "Sāhaṁ puttaṁ dhītarañca,"
    },
    {
      "id": "thig5.7:2.2",
      "pali": "dhanadhaññañca chaḍḍiya;"
    },
    {
      "id": "thig5.7:2.3",
      "pali": "Kese chedāpayitvāna,"
    },
    {
      "id": "thig5.7:2.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thig5.7:3.1",
      "pali": "Sikkhamānā ahaṁ santī,"
    },
    {
      "id": "thig5.7:3.2",
      "pali": "bhāventī maggamañjasaṁ;"
    },
    {
      "id": "thig5.7:3.3",
      "pali": "Pahāsiṁ rāgadosañca,"
    },
    {
      "id": "thig5.7:3.4",
      "pali": "tadekaṭṭhe ca āsave."
    },
    {
      "id": "thig5.7:4.1",
      "pali": "Bhikkhunī upasampajja,"
    },
    {
      "id": "thig5.7:4.2",
      "pali": "pubbajātimanussariṁ;"
    },
    {
      "id": "thig5.7:4.3",
      "pali": "Dibbacakkhu visodhitaṁ,"
    },
    {
      "id": "thig5.7:4.4",
      "pali": "vimalaṁ sādhubhāvitaṁ."
    },
    {
      "id": "thig5.7:5.1",
      "pali": "Saṅkhāre parato disvā,"
    },
    {
      "id": "thig5.7:5.2",
      "pali": "hetujāte palokite;"
    },
    {
      "id": "thig5.7:5.3",
      "pali": "Pahāsiṁ āsave sabbe,"
    },
    {
      "id": "thig5.7:5.4",
      "pali": "sītibhūtāmhi nibbutā”ti."
    },
    {
      "id": "thig5.7:6.1",
      "pali": "… Sakulā therī …."
    }
  ]
}
