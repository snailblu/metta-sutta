{
  "uid": "kp5",
  "title": "Maṅgalasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "kp5:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "kp5:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "kp5:1.3",
      "pali": "Atha kho aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "kp5:1.4",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ gāthāya ajjhabhāsi—"
    },
    {
      "id": "kp5:2.1",
      "pali": "“Bahū devā manussā ca,"
    },
    {
      "id": "kp5:2.2",
      "pali": "maṅgalāni acintayuṁ;"
    },
    {
      "id": "kp5:2.3",
      "pali": "Ākaṅkhamānā sotthānaṁ,"
    },
    {
      "id": "kp5:2.4",
      "pali": "brūhi maṅgalamuttamaṁ”."
    },
    {
      "id": "kp5:3.1",
      "pali": "“Asevanā ca bālānaṁ,"
    },
    {
      "id": "kp5:3.2",
      "pali": "paṇḍitānañca sevanā;"
    },
    {
      "id": "kp5:3.3",
      "pali": "Pūjā ca pūjaneyyānaṁ,"
    },
    {
      "id": "kp5:3.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:4.1",
      "pali": "Patirūpadesavāso ca,"
    },
    {
      "id": "kp5:4.2",
      "pali": "pubbe ca katapuññatā;"
    },
    {
      "id": "kp5:4.3",
      "pali": "Attasammāpaṇidhi ca,"
    },
    {
      "id": "kp5:4.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:5.1",
      "pali": "Bāhusaccañca sippañca,"
    },
    {
      "id": "kp5:5.2",
      "pali": "vinayo ca susikkhito;"
    },
    {
      "id": "kp5:5.3",
      "pali": "Subhāsitā ca yā vācā,"
    },
    {
      "id": "kp5:5.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:6.1",
      "pali": "Mātāpituupaṭṭhānaṁ,"
    },
    {
      "id": "kp5:6.2",
      "pali": "puttadārassa saṅgaho;"
    },
    {
      "id": "kp5:6.3",
      "pali": "Anākulā ca kammantā,"
    },
    {
      "id": "kp5:6.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:7.1",
      "pali": "Dānañca dhammacariyā ca,"
    },
    {
      "id": "kp5:7.2",
      "pali": "ñātakānañca saṅgaho;"
    },
    {
      "id": "kp5:7.3",
      "pali": "Anavajjāni kammāni,"
    },
    {
      "id": "kp5:7.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:8.1",
      "pali": "Āratī viratī pāpā,"
    },
    {
      "id": "kp5:8.2",
      "pali": "majjapānā ca saṁyamo;"
    },
    {
      "id": "kp5:8.3",
      "pali": "Appamādo ca dhammesu,"
    },
    {
      "id": "kp5:8.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:9.1",
      "pali": "Gāravo ca nivāto ca,"
    },
    {
      "id": "kp5:9.2",
      "pali": "santuṭṭhi ca kataññutā;"
    },
    {
      "id": "kp5:9.3",
      "pali": "Kālena dhammassavanaṁ,"
    },
    {
      "id": "kp5:9.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:10.1",
      "pali": "Khantī ca sovacassatā,"
    },
    {
      "id": "kp5:10.2",
      "pali": "samaṇānañca dassanaṁ;"
    },
    {
      "id": "kp5:10.3",
      "pali": "Kālena dhammasākacchā,"
    },
    {
      "id": "kp5:10.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:11.1",
      "pali": "Tapo ca brahmacariyañca,"
    },
    {
      "id": "kp5:11.2",
      "pali": "ariyasaccāna dassanaṁ;"
    },
    {
      "id": "kp5:11.3",
      "pali": "Nibbānasacchikiriyā ca,"
    },
    {
      "id": "kp5:11.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:12.1",
      "pali": "Phuṭṭhassa lokadhammehi,"
    },
    {
      "id": "kp5:12.2",
      "pali": "cittaṁ yassa na kampati;"
    },
    {
      "id": "kp5:12.3",
      "pali": "Asokaṁ virajaṁ khemaṁ,"
    },
    {
      "id": "kp5:12.4",
      "pali": "etaṁ maṅgalamuttamaṁ."
    },
    {
      "id": "kp5:13.1",
      "pali": "Etādisāni katvāna,"
    },
    {
      "id": "kp5:13.2",
      "pali": "Sabbattha maparājitā;"
    },
    {
      "id": "kp5:13.3",
      "pali": "Sabbattha sotthiṁ gacchanti,"
    },
    {
      "id": "kp5:13.4",
      "pali": "Taṁ tesaṁ maṅgalamuttaman”ti."
    },
    {
      "id": "kp5:14.1",
      "pali": "Maṅgalasuttaṁ."
    }
  ]
}
