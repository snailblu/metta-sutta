{
  "uid": "tha-ap324",
  "title": "2 Pulinapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap324:1.1",
      "pali": "“Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap324:1.2",
      "pali": "nisabhājāniyaṁ yathā;"
    },
    {
      "id": "tha-ap324:1.3",
      "pali": "Osadhiṁva virocantaṁ,"
    },
    {
      "id": "tha-ap324:1.4",
      "pali": "obhāsantaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap324:2.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap324:2.2",
      "pali": "avandiṁ satthuno ahaṁ;"
    },
    {
      "id": "tha-ap324:2.3",
      "pali": "Satthāraṁ parivaṇṇesiṁ,"
    },
    {
      "id": "tha-ap324:2.4",
      "pali": "sakakammena tosayiṁ."
    },
    {
      "id": "tha-ap324:3.1",
      "pali": "Susuddhaṁ pulinaṁ gayha,"
    },
    {
      "id": "tha-ap324:3.2",
      "pali": "gatamagge samokiriṁ;"
    },
    {
      "id": "tha-ap324:3.3",
      "pali": "Ucchaṅgena gahetvāna,"
    },
    {
      "id": "tha-ap324:3.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap324:4.1",
      "pali": "Tato upaḍḍhapulinaṁ,"
    },
    {
      "id": "tha-ap324:4.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap324:4.3",
      "pali": "Divāvihāre osiñciṁ,"
    },
    {
      "id": "tha-ap324:4.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap324:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap324:5.2",
      "pali": "pulinaṁ yamasiñcahaṁ;"
    },
    {
      "id": "tha-ap324:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap324:5.4",
      "pali": "pulinassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap324:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap324:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap324:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap324:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pulinapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap324:8.1",
      "pali": "Pulinapūjakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
