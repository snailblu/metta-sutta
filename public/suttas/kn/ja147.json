{
  "uid": "ja147",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja147:1.1",
      "pali": "“Nayidaṁ dukkhaṁ aduṁ dukkhaṁ,"
    },
    {
      "id": "ja147:1.2",
      "pali": "Yaṁ maṁ tudati vāyaso;"
    },
    {
      "id": "ja147:1.3",
      "pali": "Yaṁ sāmā puppharattena,"
    },
    {
      "id": "ja147:1.4",
      "pali": "Kattikaṁ nānubhossatī”ti."
    },
    {
      "id": "ja147:2.1",
      "pali": "Puppharattajātakaṁ sattamaṁ."
    }
  ]
}
