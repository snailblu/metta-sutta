{
  "uid": "thag1.108",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.108:1.1",
      "pali": "“Sa vīsavassasatiko,"
    },
    {
      "id": "thag1.108:1.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thag1.108:1.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag1.108:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.108:1.5",
      "pali": "… Dhammasavapitu thero …."
    }
  ]
}
