{
  "uid": "tha-ap429",
  "title": "7 Ekadhammassavaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap429:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap429:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap429:1.3",
      "pali": "Catusaccaṁ pakāsento,"
    },
    {
      "id": "tha-ap429:1.4",
      "pali": "santāresi bahuṁ janaṁ."
    },
    {
      "id": "tha-ap429:2.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "tha-ap429:2.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "tha-ap429:2.3",
      "pali": "Dhunanto vākacīrāni,"
    },
    {
      "id": "tha-ap429:2.4",
      "pali": "gacchāmi ambare tadā."
    },
    {
      "id": "tha-ap429:3.1",
      "pali": "Buddhaseṭṭhassa upari,"
    },
    {
      "id": "tha-ap429:3.2",
      "pali": "gantuṁ na visahāmahaṁ;"
    },
    {
      "id": "tha-ap429:3.3",
      "pali": "Pakkhīva selamāsajja,"
    },
    {
      "id": "tha-ap429:3.4",
      "pali": "gamanaṁ na labhāmahaṁ."
    },
    {
      "id": "tha-ap429:4.1",
      "pali": "Udake vokkamitvāna,"
    },
    {
      "id": "tha-ap429:4.2",
      "pali": "evaṁ gacchāmi ambare;"
    },
    {
      "id": "tha-ap429:4.3",
      "pali": "Na me idaṁ bhūtapubbaṁ,"
    },
    {
      "id": "tha-ap429:4.4",
      "pali": "iriyāpathavikopanaṁ."
    },
    {
      "id": "tha-ap429:5.1",
      "pali": "Handa metaṁ gavesissaṁ,"
    },
    {
      "id": "tha-ap429:5.2",
      "pali": "appevatthaṁ labheyyahaṁ;"
    },
    {
      "id": "tha-ap429:5.3",
      "pali": "Orohanto antalikkhā,"
    },
    {
      "id": "tha-ap429:5.4",
      "pali": "saddamassosi satthuno."
    },
    {
      "id": "tha-ap429:6.1",
      "pali": "Sarena rajanīyena,"
    },
    {
      "id": "tha-ap429:6.2",
      "pali": "savanīyena vaggunā;"
    },
    {
      "id": "tha-ap429:6.3",
      "pali": "Aniccataṁ kathentassa,"
    },
    {
      "id": "tha-ap429:6.4",
      "pali": "taññeva uggahiṁ tadā;"
    },
    {
      "id": "tha-ap429:6.5",
      "pali": "Aniccasaññamuggayha,"
    },
    {
      "id": "tha-ap429:6.6",
      "pali": "agamāsiṁ mamassamaṁ."
    },
    {
      "id": "tha-ap429:7.1",
      "pali": "Yāvatāyuṁ vasitvāna,"
    },
    {
      "id": "tha-ap429:7.2",
      "pali": "tattha kālaṅkato ahaṁ;"
    },
    {
      "id": "tha-ap429:7.3",
      "pali": "Carime vattamānamhi,"
    },
    {
      "id": "tha-ap429:7.4",
      "pali": "saddhammassavanaṁ sariṁ."
    },
    {
      "id": "tha-ap429:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap429:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap429:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap429:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap429:9.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap429:9.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap429:9.3",
      "pali": "Ekapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap429:9.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap429:10.1",
      "pali": "Ekavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap429:10.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap429:10.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap429:10.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap429:11.1",
      "pali": "Anubhomi sakaṁ puññaṁ,"
    },
    {
      "id": "tha-ap429:11.2",
      "pali": "sukhitohaṁ bhavābhave;"
    },
    {
      "id": "tha-ap429:11.3",
      "pali": "Anussarāmi taṁ saññaṁ,"
    },
    {
      "id": "tha-ap429:11.4",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "tha-ap429:11.5",
      "pali": "Na koṭiṁ paṭivijjhāmi,"
    },
    {
      "id": "tha-ap429:11.6",
      "pali": "nibbānaṁ accutaṁ padaṁ."
    },
    {
      "id": "tha-ap429:12.1",
      "pali": "Pitugehe nisīditvā,"
    },
    {
      "id": "tha-ap429:12.2",
      "pali": "samaṇo bhāvitindriyo;"
    },
    {
      "id": "tha-ap429:12.3",
      "pali": "Kathaṁsa paridīpento,"
    },
    {
      "id": "tha-ap429:12.4",
      "pali": "aniccatamudāhari."
    },
    {
      "id": "tha-ap429:13.1",
      "pali": "‘Aniccā vata saṅkhārā,"
    },
    {
      "id": "tha-ap429:13.2",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "tha-ap429:13.3",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "tha-ap429:13.4",
      "pali": "tesaṁ vūpasamo sukho’."
    },
    {
      "id": "tha-ap429:14.1",
      "pali": "Saha gāthaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap429:14.2",
      "pali": "pubbasaññamanussariṁ;"
    },
    {
      "id": "tha-ap429:14.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap429:14.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap429:15.1",
      "pali": "<b>Jātiyā sattavassena</b>,"
    },
    {
      "id": "tha-ap429:15.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap429:15.3",
      "pali": "Upasampādayī buddho,"
    },
    {
      "id": "tha-ap429:15.4",
      "pali": "dhammassavanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap429:16.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap429:16.2",
      "pali": "yaṁ dhammamasuṇiṁ tadā;"
    },
    {
      "id": "tha-ap429:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap429:16.4",
      "pali": "dhammassavanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap429:17.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap429:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap429:17.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap429:18.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap429:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap429:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap429:19.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap429:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap429:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap429:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekadhammassavaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap429:21.1",
      "pali": "Ekadhammassavaniyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
