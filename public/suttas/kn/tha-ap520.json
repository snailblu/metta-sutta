{
  "uid": "tha-ap520",
  "title": "Ghosasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap520:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap520:1.2",
      "pali": "araññe vipine ahaṁ;"
    },
    {
      "id": "tha-ap520:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap520:1.4",
      "pali": "devasaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap520:2.1",
      "pali": "Catusaccaṁ pakāsentaṁ,"
    },
    {
      "id": "tha-ap520:2.2",
      "pali": "desentaṁ amataṁ padaṁ;"
    },
    {
      "id": "tha-ap520:2.3",
      "pali": "Assosiṁ madhuraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap520:2.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap520:3.1",
      "pali": "Ghose cittaṁ pasādesiṁ,"
    },
    {
      "id": "tha-ap520:3.2",
      "pali": "asamappaṭipuggale;"
    },
    {
      "id": "tha-ap520:3.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap520:3.4",
      "pali": "uttariṁ duttaraṁ bhavaṁ."
    },
    {
      "id": "tha-ap520:4.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap520:4.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap520:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap520:4.4",
      "pali": "ghosasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap520:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap520:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap520:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap520:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap520:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap520:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap520:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap520:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap520:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap520:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā ghosasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap520:9.1",
      "pali": "Ghosasaññakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
