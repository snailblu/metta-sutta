{
  "uid": "thig5.1",
  "title": "Aññataratherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.1:1.1",
      "pali": "“Paṇṇavīsativassāni,"
    },
    {
      "id": "thig5.1:1.2",
      "pali": "yato pabbajitā ahaṁ;"
    },
    {
      "id": "thig5.1:1.3",
      "pali": "Nāccharāsaṅghātamattampi,"
    },
    {
      "id": "thig5.1:1.4",
      "pali": "cittassūpasamajjhagaṁ."
    },
    {
      "id": "thig5.1:2.1",
      "pali": "Aladdhā cetaso santiṁ,"
    },
    {
      "id": "thig5.1:2.2",
      "pali": "kāmarāgenavassutā;"
    },
    {
      "id": "thig5.1:2.3",
      "pali": "Bāhā paggayha kandantī,"
    },
    {
      "id": "thig5.1:2.4",
      "pali": "vihāraṁ pāvisiṁ ahaṁ."
    },
    {
      "id": "thig5.1:3.1",
      "pali": "Sā bhikkhuniṁ upāgacchiṁ,"
    },
    {
      "id": "thig5.1:3.2",
      "pali": "yā me saddhāyikā ahu;"
    },
    {
      "id": "thig5.1:3.3",
      "pali": "Sā me dhammamadesesi,"
    },
    {
      "id": "thig5.1:3.4",
      "pali": "khandhāyatanadhātuyo."
    },
    {
      "id": "thig5.1:4.1",
      "pali": "Tassā dhammaṁ suṇitvāna,"
    },
    {
      "id": "thig5.1:4.2",
      "pali": "ekamante upāvisiṁ;"
    },
    {
      "id": "thig5.1:4.3",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thig5.1:4.4",
      "pali": "dibbacakkhu visodhitaṁ."
    },
    {
      "id": "thig5.1:5.1",
      "pali": "Cetopariccañāṇañca,"
    },
    {
      "id": "thig5.1:5.2",
      "pali": "sotadhātu visodhitā;"
    },
    {
      "id": "thig5.1:5.3",
      "pali": "Iddhīpi me sacchikatā,"
    },
    {
      "id": "thig5.1:5.4",
      "pali": "patto me āsavakkhayo;"
    },
    {
      "id": "thig5.1:5.5",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thig5.1:5.6",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig5.1:6.1",
      "pali": "… Aññatarā therī …."
    }
  ]
}
