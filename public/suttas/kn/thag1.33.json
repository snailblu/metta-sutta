{
  "uid": "thag1.33",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.33:1.1",
      "pali": "“Yathāpi ekaputtasmiṁ,"
    },
    {
      "id": "thag1.33:1.2",
      "pali": "piyasmiṁ kusalī siyā;"
    },
    {
      "id": "thag1.33:1.3",
      "pali": "Evaṁ sabbesu pāṇesu,"
    },
    {
      "id": "thag1.33:1.4",
      "pali": "sabbattha kusalo siyā”ti."
    },
    {
      "id": "thag1.33:1.5",
      "pali": "… Sopāko thero …."
    }
  ]
}
