{
  "uid": "tha-ap354",
  "title": "Yavakalāpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap354:1.1",
      "pali": "“Nagare aruṇavatiyā,"
    },
    {
      "id": "tha-ap354:1.2",
      "pali": "āsiṁ yavasiko tadā;"
    },
    {
      "id": "tha-ap354:1.3",
      "pali": "Panthe disvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap354:1.4",
      "pali": "yavakalāpaṁ santhariṁ."
    },
    {
      "id": "tha-ap354:2.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap354:2.2",
      "pali": "sikhī lokagganāyako;"
    },
    {
      "id": "tha-ap354:2.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap354:2.4",
      "pali": "nisīdi yavasanthare."
    },
    {
      "id": "tha-ap354:3.1",
      "pali": "Disvā nisinnaṁ vimalaṁ,"
    },
    {
      "id": "tha-ap354:3.2",
      "pali": "mahājhāyiṁ vināyakaṁ;"
    },
    {
      "id": "tha-ap354:3.3",
      "pali": "Pāmojjaṁ janayitvāna,"
    },
    {
      "id": "tha-ap354:3.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap354:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap354:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap354:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap354:4.4",
      "pali": "yavatthare idaṁ phalaṁ."
    },
    {
      "id": "tha-ap354:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap354:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap354:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap354:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā yavakalāpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap354:7.1",
      "pali": "Yavakalāpiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
