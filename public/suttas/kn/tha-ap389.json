{
  "uid": "tha-ap389",
  "title": "Kadaliphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap389:1.1",
      "pali": "“Kaṇikāraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap389:1.2",
      "pali": "puṇṇamāyeva candimaṁ;"
    },
    {
      "id": "tha-ap389:1.3",
      "pali": "Jalantaṁ dīparukkhaṁva,"
    },
    {
      "id": "tha-ap389:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap389:2.1",
      "pali": "Kadaliphalaṁ paggayha,"
    },
    {
      "id": "tha-ap389:2.2",
      "pali": "adāsiṁ satthuno ahaṁ;"
    },
    {
      "id": "tha-ap389:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap389:2.4",
      "pali": "vanditvāna apakkamiṁ."
    },
    {
      "id": "tha-ap389:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap389:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap389:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap389:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap389:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap389:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap389:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap389:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap389:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap389:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap389:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap389:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap389:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap389:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kadaliphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap389:8.1",
      "pali": "Kadaliphaladāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
