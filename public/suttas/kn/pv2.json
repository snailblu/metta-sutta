{
  "uid": "pv2",
  "title": "2. Sūkaramukhapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv2:1.1",
      "pali": "“Kāyo te sabbasovaṇṇo,"
    },
    {
      "id": "pv2:1.2",
      "pali": "sabbā obhāsate disā;"
    },
    {
      "id": "pv2:1.3",
      "pali": "Mukhaṁ te sūkarasseva,"
    },
    {
      "id": "pv2:1.4",
      "pali": "kiṁ kammamakarī pure”."
    },
    {
      "id": "pv2:2.1",
      "pali": "“Kāyena saññato āsiṁ,"
    },
    {
      "id": "pv2:2.2",
      "pali": "vācāyāsimasaññato;"
    },
    {
      "id": "pv2:2.3",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "pv2:2.4",
      "pali": "yathā passasi nārada."
    },
    {
      "id": "pv2:3.1",
      "pali": "Taṁ tyāhaṁ nārada brūmi,"
    },
    {
      "id": "pv2:3.2",
      "pali": "Sāmaṁ diṭṭhamidaṁ tayā;"
    },
    {
      "id": "pv2:3.3",
      "pali": "Mākāsi mukhasā pāpaṁ,"
    },
    {
      "id": "pv2:3.4",
      "pali": "Mā kho sūkaramukho ahū”ti."
    },
    {
      "id": "pv2:4.1",
      "pali": "Sūkaramukhapetavatthu dutiyaṁ."
    }
  ]
}
