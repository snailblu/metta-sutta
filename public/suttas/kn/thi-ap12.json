{
  "uid": "thi-ap12",
  "title": "2 Saḷalapupphikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap12:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "thi-ap12:1.2",
      "pali": "ahosiṁ kinnarī tadā;"
    },
    {
      "id": "thi-ap12:1.3",
      "pali": "Addasāhaṁ devadevaṁ,"
    },
    {
      "id": "thi-ap12:1.4",
      "pali": "caṅkamantaṁ narāsabhaṁ."
    },
    {
      "id": "thi-ap12:2.1",
      "pali": "Ocinitvāna saḷalaṁ,"
    },
    {
      "id": "thi-ap12:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "thi-ap12:2.3",
      "pali": "Upasiṅghi mahāvīro,"
    },
    {
      "id": "thi-ap12:2.4",
      "pali": "saḷalaṁ devagandhikaṁ."
    },
    {
      "id": "thi-ap12:3.1",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "thi-ap12:3.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "thi-ap12:3.3",
      "pali": "Upasiṅghi mahāvīro,"
    },
    {
      "id": "thi-ap12:3.4",
      "pali": "pekkhamānāya me tadā."
    },
    {
      "id": "thi-ap12:4.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "thi-ap12:4.2",
      "pali": "vanditvā dvipaduttamaṁ;"
    },
    {
      "id": "thi-ap12:4.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "thi-ap12:4.4",
      "pali": "tato pabbatamāruhiṁ."
    },
    {
      "id": "thi-ap12:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap12:5.2",
      "pali": "yaṁ pupphamadadiṁ tadā;"
    },
    {
      "id": "thi-ap12:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap12:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap12:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap12:6.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap12:6.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap12:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap12:7.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap12:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap12:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap12:8.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap12:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap12:9.1",
      "pali": "Itthaṁ sudaṁ saḷalapupphikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap12:10.1",
      "pali": "Saḷalapupphikātheriyāpadānaṁ dutiyaṁ."
    }
  ]
}
