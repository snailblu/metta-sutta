{
  "uid": "tha-ap93",
  "title": "Sudhāpiṇḍiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap93:1.1",
      "pali": "“Pūjārahe pūjayato,"
    },
    {
      "id": "tha-ap93:1.2",
      "pali": "buddhe yadi va sāvake;"
    },
    {
      "id": "tha-ap93:1.3",
      "pali": "Papañcasamatikkante,"
    },
    {
      "id": "tha-ap93:1.4",
      "pali": "tiṇṇasokapariddave."
    },
    {
      "id": "tha-ap93:2.1",
      "pali": "Te tādise pūjayato,"
    },
    {
      "id": "tha-ap93:2.2",
      "pali": "nibbute akutobhaye;"
    },
    {
      "id": "tha-ap93:2.3",
      "pali": "Na sakkā puññaṁ saṅkhātuṁ,"
    },
    {
      "id": "tha-ap93:2.4",
      "pali": "imettamapi kenaci."
    },
    {
      "id": "tha-ap93:3.1",
      "pali": "Catunnamapi dīpānaṁ,"
    },
    {
      "id": "tha-ap93:3.2",
      "pali": "issaraṁ yodha kāraye;"
    },
    {
      "id": "tha-ap93:3.3",
      "pali": "Ekissā pūjanāyetaṁ,"
    },
    {
      "id": "tha-ap93:3.4",
      "pali": "kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "tha-ap93:4.1",
      "pali": "Siddhatthassa naraggassa,"
    },
    {
      "id": "tha-ap93:4.2",
      "pali": "cetiye phalitantare;"
    },
    {
      "id": "tha-ap93:4.3",
      "pali": "Sudhāpiṇḍo mayā dinno,"
    },
    {
      "id": "tha-ap93:4.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap93:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap93:5.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap93:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap93:5.4",
      "pali": "paṭisaṅkhārassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap93:6.1",
      "pali": "Ito tiṁsatikappamhi,"
    },
    {
      "id": "tha-ap93:6.2",
      "pali": "paṭisaṅkhārasavhayā;"
    },
    {
      "id": "tha-ap93:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap93:6.4",
      "pali": "terasa cakkavattino."
    },
    {
      "id": "tha-ap93:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap93:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap93:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap93:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap93:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā sudhāpiṇḍiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap93:9.1",
      "pali": "Sudhāpiṇḍiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
