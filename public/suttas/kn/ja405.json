{
  "uid": "ja405",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja405:1.1",
      "pali": "“Dvāsattati gotama puññakammā,"
    },
    {
      "id": "ja405:1.2",
      "pali": "Vasavattino jātijaraṁ atītā;"
    },
    {
      "id": "ja405:1.3",
      "pali": "Ayamantimā vedagū brahmapatti,"
    },
    {
      "id": "ja405:1.4",
      "pali": "Asmābhijappanti janā anekā”."
    },
    {
      "id": "ja405:2.1",
      "pali": "“Appañhi etaṁ na hi dīghamāyu,"
    },
    {
      "id": "ja405:2.2",
      "pali": "Yaṁ tvaṁ baka maññasi dīghamāyuṁ;"
    },
    {
      "id": "ja405:2.3",
      "pali": "Sataṁ sahassāni nirabbudānaṁ,"
    },
    {
      "id": "ja405:2.4",
      "pali": "Āyuṁ pajānāmi tavāha brahme”."
    },
    {
      "id": "ja405:3.1",
      "pali": "“Anantadassī bhagavāhamasmi,"
    },
    {
      "id": "ja405:3.2",
      "pali": "Jātijjaraṁ sokamupātivatto;"
    },
    {
      "id": "ja405:3.3",
      "pali": "Kiṁ me purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "ja405:3.4",
      "pali": "Ācikkha me taṁ yamahaṁ vijaññaṁ”."
    },
    {
      "id": "ja405:4.1",
      "pali": "“Yaṁ tvaṁ apāyesi bahū manusse,"
    },
    {
      "id": "ja405:4.2",
      "pali": "Pipāsite ghammani samparete;"
    },
    {
      "id": "ja405:4.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "ja405:4.4",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "ja405:5.1",
      "pali": "Yaṁ eṇikūlasmi janaṁ gahītaṁ,"
    },
    {
      "id": "ja405:5.2",
      "pali": "Amocayī gayhaka niyyamānaṁ;"
    },
    {
      "id": "ja405:5.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "ja405:5.4",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "ja405:6.1",
      "pali": "Gaṅgāya sotasmiṁ gahītanāvaṁ,"
    },
    {
      "id": "ja405:6.2",
      "pali": "Luddena nāgena manussakappā;"
    },
    {
      "id": "ja405:6.3",
      "pali": "Amocayi tvaṁ balasā pasayha,"
    },
    {
      "id": "ja405:6.4",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ;"
    },
    {
      "id": "ja405:6.5",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "ja405:7.1",
      "pali": "Kappo ca te baddhacaro ahosiṁ,"
    },
    {
      "id": "ja405:7.2",
      "pali": "Sambuddhimantaṁ vatinaṁ amaññaṁ;"
    },
    {
      "id": "ja405:7.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "ja405:7.4",
      "pali": "Suttappabuddhova anussarāmi”."
    },
    {
      "id": "ja405:8.1",
      "pali": "“Addhā pajānāsi mametamāyuṁ,"
    },
    {
      "id": "ja405:8.2",
      "pali": "Aññampi jānāsi tathā hi buddho;"
    },
    {
      "id": "ja405:8.3",
      "pali": "Tathā hi tāyaṁ jalitānubhāvo,"
    },
    {
      "id": "ja405:8.4",
      "pali": "Obhāsayaṁ tiṭṭhati brahmalokan”ti."
    },
    {
      "id": "ja405:9.1",
      "pali": "Bakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja405:9.2",
      "pali": "Kukkuvaggo paṭhamo."
    },
    {
      "id": "ja405:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja405:11.1",
      "pali": "Varakaṇṇika cāpavaro sutano,"
    },
    {
      "id": "ja405:11.2",
      "pali": "Atha gijjha sarohitamacchavaro;"
    },
    {
      "id": "ja405:11.3",
      "pali": "Puna paṇṇaka senaka yācanako,"
    },
    {
      "id": "ja405:11.4",
      "pali": "Atha veri sabrahmabakena dasāti."
    }
  ]
}
