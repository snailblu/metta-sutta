{
  "uid": "tha-ap14",
  "title": "Ekatthambhikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap14:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap14:1.2",
      "pali": "mahāpūgagaṇo ahu;"
    },
    {
      "id": "tha-ap14:1.3",
      "pali": "Saraṇaṁ gatā ca te buddhaṁ,"
    },
    {
      "id": "tha-ap14:1.4",
      "pali": "saddahanti tathāgataṁ."
    },
    {
      "id": "tha-ap14:2.1",
      "pali": "Sabbe saṅgamma mantetvā,"
    },
    {
      "id": "tha-ap14:2.2",
      "pali": "māḷaṁ kubbanti satthuno;"
    },
    {
      "id": "tha-ap14:2.3",
      "pali": "Ekatthambhaṁ alabhantā,"
    },
    {
      "id": "tha-ap14:2.4",
      "pali": "vicinanti brahāvane."
    },
    {
      "id": "tha-ap14:3.1",
      "pali": "Tehaṁ araññe disvāna,"
    },
    {
      "id": "tha-ap14:3.2",
      "pali": "upagamma gaṇaṁ tadā;"
    },
    {
      "id": "tha-ap14:3.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap14:3.4",
      "pali": "paripucchiṁ gaṇaṁ ahaṁ."
    },
    {
      "id": "tha-ap14:4.1",
      "pali": "Te me puṭṭhā viyākaṁsu,"
    },
    {
      "id": "tha-ap14:4.2",
      "pali": "sīlavanto upāsakā;"
    },
    {
      "id": "tha-ap14:4.3",
      "pali": "Māḷaṁ mayaṁ kattukāmā,"
    },
    {
      "id": "tha-ap14:4.4",
      "pali": "ekatthambho na labbhati."
    },
    {
      "id": "tha-ap14:5.1",
      "pali": "Ekatthambhaṁ mamaṁ detha,"
    },
    {
      "id": "tha-ap14:5.2",
      "pali": "ahaṁ dassāmi satthuno;"
    },
    {
      "id": "tha-ap14:5.3",
      "pali": "Āharissāmahaṁ thambhaṁ,"
    },
    {
      "id": "tha-ap14:5.4",
      "pali": "appossukkā bhavantu te."
    },
    {
      "id": "tha-ap14:6.1",
      "pali": "Te me thambhaṁ pavecchiṁsu,"
    },
    {
      "id": "tha-ap14:6.2",
      "pali": "pasannā tuṭṭhamānasā;"
    },
    {
      "id": "tha-ap14:6.3",
      "pali": "Tato paṭinivattitvā,"
    },
    {
      "id": "tha-ap14:6.4",
      "pali": "agamaṁsu sakaṁ gharaṁ."
    },
    {
      "id": "tha-ap14:7.1",
      "pali": "Aciraṁ gate pūgagaṇe,"
    },
    {
      "id": "tha-ap14:7.2",
      "pali": "thambhaṁ ahāsahaṁ tadā;"
    },
    {
      "id": "tha-ap14:7.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap14:7.4",
      "pali": "paṭhamaṁ ussapesahaṁ."
    },
    {
      "id": "tha-ap14:8.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap14:8.2",
      "pali": "Vimānaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap14:8.3",
      "pali": "Ubbiddhaṁ bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap14:8.4",
      "pali": "Sattabhūmaṁ samuggataṁ."
    },
    {
      "id": "tha-ap14:9.1",
      "pali": "Vajjamānāsu bherīsu,"
    },
    {
      "id": "tha-ap14:9.2",
      "pali": "paricāremahaṁ sadā;"
    },
    {
      "id": "tha-ap14:9.3",
      "pali": "Pañcapaññāsakappamhi,"
    },
    {
      "id": "tha-ap14:9.4",
      "pali": "rājā āsiṁ yasodharo."
    },
    {
      "id": "tha-ap14:10.1",
      "pali": "Tatthāpi bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap14:10.2",
      "pali": "sattabhūmaṁ samuggataṁ;"
    },
    {
      "id": "tha-ap14:10.3",
      "pali": "Kūṭāgāravarūpetaṁ,"
    },
    {
      "id": "tha-ap14:10.4",
      "pali": "ekatthambhaṁ manoramaṁ."
    },
    {
      "id": "tha-ap14:11.1",
      "pali": "Ekavīsatikappamhi,"
    },
    {
      "id": "tha-ap14:11.2",
      "pali": "udeno nāma khattiyo;"
    },
    {
      "id": "tha-ap14:11.3",
      "pali": "Tatrāpi bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap14:11.4",
      "pali": "sattabhūmaṁ samuggataṁ."
    },
    {
      "id": "tha-ap14:12.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap14:12.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap14:12.3",
      "pali": "Anubhomi sukhaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap14:12.4",
      "pali": "ekatthambhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap14:13.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap14:13.2",
      "pali": "yaṁ thambhamadadaṁ tadā;"
    },
    {
      "id": "tha-ap14:13.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap14:13.4",
      "pali": "ekatthambhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap14:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap14:14.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap14:14.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap14:14.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap14:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekatthambhiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap14:16.1",
      "pali": "Ekatthambhikattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
