{
  "uid": "ja468",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja468:1.1",
      "pali": "“Dasa khalu imāni ṭhānāni,"
    },
    {
      "id": "ja468:1.2",
      "pali": "Yāni pubbe akaritvā;"
    },
    {
      "id": "ja468:1.3",
      "pali": "Sa pacchā manutappati,"
    },
    {
      "id": "ja468:1.4",
      "pali": "Iccevāha janasandho."
    },
    {
      "id": "ja468:2.1",
      "pali": "Aladdhā vittaṁ tappati,"
    },
    {
      "id": "ja468:2.2",
      "pali": "pubbe asamudānitaṁ;"
    },
    {
      "id": "ja468:2.3",
      "pali": "Na pubbe dhanamesissaṁ,"
    },
    {
      "id": "ja468:2.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:3.1",
      "pali": "Sakyarūpaṁ pure santaṁ,"
    },
    {
      "id": "ja468:3.2",
      "pali": "mayā sippaṁ na sikkhitaṁ;"
    },
    {
      "id": "ja468:3.3",
      "pali": "Kicchā vutti asippassa,"
    },
    {
      "id": "ja468:3.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:4.1",
      "pali": "Kūṭavedī pure āsiṁ,"
    },
    {
      "id": "ja468:4.2",
      "pali": "pisuṇo piṭṭhimaṁsiko;"
    },
    {
      "id": "ja468:4.3",
      "pali": "Caṇḍo ca pharuso cāpi,"
    },
    {
      "id": "ja468:4.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:5.1",
      "pali": "Pāṇātipātī pure āsiṁ,"
    },
    {
      "id": "ja468:5.2",
      "pali": "luddo cāpi anāriyo;"
    },
    {
      "id": "ja468:5.3",
      "pali": "Bhūtānaṁ nāpacāyissaṁ,"
    },
    {
      "id": "ja468:5.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:6.1",
      "pali": "Bahūsu vata santīsu,"
    },
    {
      "id": "ja468:6.2",
      "pali": "anāpādāsu itthisu;"
    },
    {
      "id": "ja468:6.3",
      "pali": "Paradāraṁ asevissaṁ,"
    },
    {
      "id": "ja468:6.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:7.1",
      "pali": "Bahumhi vata santamhi,"
    },
    {
      "id": "ja468:7.2",
      "pali": "annapāne upaṭṭhite;"
    },
    {
      "id": "ja468:7.3",
      "pali": "Na pubbe adadaṁ dānaṁ,"
    },
    {
      "id": "ja468:7.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:8.1",
      "pali": "Mātaraṁ pitarañcāpi,"
    },
    {
      "id": "ja468:8.2",
      "pali": "jiṇṇakaṁ gatayobbanaṁ;"
    },
    {
      "id": "ja468:8.3",
      "pali": "Pahu santo na posissaṁ,"
    },
    {
      "id": "ja468:8.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:9.1",
      "pali": "Ācariyamanusatthāraṁ,"
    },
    {
      "id": "ja468:9.2",
      "pali": "sabbakāmarasāharaṁ;"
    },
    {
      "id": "ja468:9.3",
      "pali": "Pitaraṁ atimaññissaṁ,"
    },
    {
      "id": "ja468:9.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:10.1",
      "pali": "Samaṇe brāhmaṇe cāpi,"
    },
    {
      "id": "ja468:10.2",
      "pali": "sīlavante bahussute;"
    },
    {
      "id": "ja468:10.3",
      "pali": "Na pubbe payirupāsissaṁ,"
    },
    {
      "id": "ja468:10.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:11.1",
      "pali": "Sādhu hoti tapo ciṇṇo,"
    },
    {
      "id": "ja468:11.2",
      "pali": "santo ca payirupāsito;"
    },
    {
      "id": "ja468:11.3",
      "pali": "Na ca pubbe tapo ciṇṇo,"
    },
    {
      "id": "ja468:11.4",
      "pali": "iti pacchānutappati."
    },
    {
      "id": "ja468:12.1",
      "pali": "Yo ca etāni ṭhānāni,"
    },
    {
      "id": "ja468:12.2",
      "pali": "yoniso paṭipajjati;"
    },
    {
      "id": "ja468:12.3",
      "pali": "Karaṁ purisakiccāni,"
    },
    {
      "id": "ja468:12.4",
      "pali": "sa pacchā nānutappatī”ti."
    },
    {
      "id": "ja468:13.1",
      "pali": "Janasandhajātakaṁ pañcamaṁ."
    }
  ]
}
