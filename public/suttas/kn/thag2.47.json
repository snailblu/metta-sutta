{
  "uid": "thag2.47",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.47:1.1",
      "pali": "“Nandamānāgataṁ cittaṁ,"
    },
    {
      "id": "thag2.47:1.2",
      "pali": "sūlamāropamānakaṁ;"
    },
    {
      "id": "thag2.47:1.3",
      "pali": "Tena teneva vajasi,"
    },
    {
      "id": "thag2.47:1.4",
      "pali": "yena sūlaṁ kaliṅgaraṁ."
    },
    {
      "id": "thag2.47:2.1",
      "pali": "Tāhaṁ cittakaliṁ brūmi,"
    },
    {
      "id": "thag2.47:2.2",
      "pali": "taṁ brūmi cittadubbhakaṁ;"
    },
    {
      "id": "thag2.47:2.3",
      "pali": "Satthā te dullabho laddho,"
    },
    {
      "id": "thag2.47:2.4",
      "pali": "mānatthe maṁ niyojayī”ti."
    },
    {
      "id": "thag2.47:2.5",
      "pali": "… Anūpamo thero …."
    }
  ]
}
