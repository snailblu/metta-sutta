{
  "uid": "ne28",
  "title": "Sampāta 9",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne28:1.1",
      "pali": "Tattha katamo parivattano hārasampāto?"
    },
    {
      "id": "ne28:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne28:2.2",
      "pali": "Samathavipassanāya bhāvitāya nirodho phalaṁ, pariññātaṁ dukkhaṁ, samudayo pahīno, maggo bhāvito paṭipakkhena."
    },
    {
      "id": "ne28:2.3",
      "pali": "Niyutto parivattano hārasampāto."
    }
  ]
}
