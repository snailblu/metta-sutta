{
  "uid": "thag3.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.2:1.1",
      "pali": "“Pañcāhāhaṁ pabbajito,"
    },
    {
      "id": "thag3.2:1.2",
      "pali": "sekho appattamānaso;"
    },
    {
      "id": "thag3.2:1.3",
      "pali": "Vihāraṁ me paviṭṭhassa,"
    },
    {
      "id": "thag3.2:1.4",
      "pali": "cetaso paṇidhī ahu."
    },
    {
      "id": "thag3.2:2.1",
      "pali": "Nāsissaṁ na pivissāmi,"
    },
    {
      "id": "thag3.2:2.2",
      "pali": "vihārato na nikkhame;"
    },
    {
      "id": "thag3.2:2.3",
      "pali": "Napi passaṁ nipātessaṁ,"
    },
    {
      "id": "thag3.2:2.4",
      "pali": "taṇhāsalle anūhate."
    },
    {
      "id": "thag3.2:3.1",
      "pali": "Tassa mevaṁ viharato,"
    },
    {
      "id": "thag3.2:3.2",
      "pali": "passa vīriyaparakkamaṁ;"
    },
    {
      "id": "thag3.2:3.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag3.2:3.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag3.2:3.5",
      "pali": "… Paccayo thero …."
    }
  ]
}
