{
  "uid": "tha-ap297",
  "title": "Gosīsanikkhepakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap297:1.1",
      "pali": "“Ārāmadvārā nikkhamma,"
    },
    {
      "id": "tha-ap297:1.2",
      "pali": "gosīsaṁ santhataṁ mayā;"
    },
    {
      "id": "tha-ap297:1.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap297:1.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap297:2.1",
      "pali": "Ājāniyā vātajavā,"
    },
    {
      "id": "tha-ap297:2.2",
      "pali": "sindhavā sīghavāhanā;"
    },
    {
      "id": "tha-ap297:2.3",
      "pali": "Anubhomi sabbametaṁ,"
    },
    {
      "id": "tha-ap297:2.4",
      "pali": "gosīsassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap297:3.1",
      "pali": "Aho kāraṁ paramakāraṁ,"
    },
    {
      "id": "tha-ap297:3.2",
      "pali": "sukhette sukataṁ mayā;"
    },
    {
      "id": "tha-ap297:3.3",
      "pali": "Saṅghe katassa kārassa,"
    },
    {
      "id": "tha-ap297:3.4",
      "pali": "na aññaṁ kalamagghati."
    },
    {
      "id": "tha-ap297:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap297:4.2",
      "pali": "yaṁ sīsaṁ santhariṁ ahaṁ;"
    },
    {
      "id": "tha-ap297:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap297:4.4",
      "pali": "santharassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap297:5.1",
      "pali": "Pañcasattatikappamhi,"
    },
    {
      "id": "tha-ap297:5.2",
      "pali": "suppatiṭṭhitanāmako;"
    },
    {
      "id": "tha-ap297:5.3",
      "pali": "Eko āsiṁ mahātejo,"
    },
    {
      "id": "tha-ap297:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap297:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap297:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap297:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap297:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā gosīsanikkhepako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap297:8.1",
      "pali": "Gosīsanikkhepakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
