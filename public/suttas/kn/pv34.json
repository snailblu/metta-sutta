{
  "uid": "pv34",
  "title": "9. Kūṭavinicchayikapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv34:1.1",
      "pali": "“Mālī kiriṭī kāyūrī,"
    },
    {
      "id": "pv34:1.2",
      "pali": "gattā te candanussadā;"
    },
    {
      "id": "pv34:1.3",
      "pali": "Pasannamukhavaṇṇosi,"
    },
    {
      "id": "pv34:1.4",
      "pali": "sūriyavaṇṇova sobhasi."
    },
    {
      "id": "pv34:2.1",
      "pali": "Amānusā pārisajjā,"
    },
    {
      "id": "pv34:2.2",
      "pali": "ye teme paricārakā;"
    },
    {
      "id": "pv34:2.3",
      "pali": "Dasa kaññāsahassāni,"
    },
    {
      "id": "pv34:2.4",
      "pali": "yā temā paricārikā;"
    },
    {
      "id": "pv34:2.5",
      "pali": "Tā kambukāyūradharā,"
    },
    {
      "id": "pv34:2.6",
      "pali": "kañcanāveḷabhūsitā."
    },
    {
      "id": "pv34:3.1",
      "pali": "Mahānubhāvosi tuvaṁ,"
    },
    {
      "id": "pv34:3.2",
      "pali": "lomahaṁsanarūpavā;"
    },
    {
      "id": "pv34:3.3",
      "pali": "Piṭṭhimaṁsāni attano,"
    },
    {
      "id": "pv34:3.4",
      "pali": "sāmaṁ ukkacca khādasi."
    },
    {
      "id": "pv34:4.1",
      "pali": "Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv34:4.2",
      "pali": "manasā dukkuṭaṁ kataṁ;"
    },
    {
      "id": "pv34:4.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv34:4.4",
      "pali": "piṭṭhimaṁsāni attano;"
    },
    {
      "id": "pv34:4.5",
      "pali": "Sāmaṁ ukkacca khādasī”ti."
    },
    {
      "id": "pv34:5.1",
      "pali": "“Attanohaṁ anatthāya,"
    },
    {
      "id": "pv34:5.2",
      "pali": "jīvaloke acārisaṁ;"
    },
    {
      "id": "pv34:5.3",
      "pali": "Pesuññamusāvādena,"
    },
    {
      "id": "pv34:5.4",
      "pali": "nikativañcanāya ca."
    },
    {
      "id": "pv34:6.1",
      "pali": "Tatthāhaṁ parisaṁ gantvā,"
    },
    {
      "id": "pv34:6.2",
      "pali": "Saccakāle upaṭṭhite;"
    },
    {
      "id": "pv34:6.3",
      "pali": "Atthaṁ dhammaṁ nirākatvā,"
    },
    {
      "id": "pv34:6.4",
      "pali": "Adhammamanuvattisaṁ."
    },
    {
      "id": "pv34:7.1",
      "pali": "Evaṁ so khādatattānaṁ,"
    },
    {
      "id": "pv34:7.2",
      "pali": "yo hoti piṭṭhimaṁsiko;"
    },
    {
      "id": "pv34:7.3",
      "pali": "Yathāhaṁ ajja khādāmi,"
    },
    {
      "id": "pv34:7.4",
      "pali": "piṭṭhimaṁsāni attano."
    },
    {
      "id": "pv34:8.1",
      "pali": "Tayidaṁ tayā nārada sāmaṁ diṭṭhaṁ,"
    },
    {
      "id": "pv34:8.2",
      "pali": "Anukampakā ye kusalā vadeyyuṁ;"
    },
    {
      "id": "pv34:8.3",
      "pali": "Mā pesuṇaṁ mā ca musā abhāṇi,"
    },
    {
      "id": "pv34:8.4",
      "pali": "Mā khosi piṭṭhimaṁsiko tuvan”ti."
    },
    {
      "id": "pv34:9.1",
      "pali": "Kūṭavinicchayikapetavatthu navamaṁ."
    }
  ]
}
