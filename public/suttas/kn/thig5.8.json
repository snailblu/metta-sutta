{
  "uid": "thig5.8",
  "title": "Soṇātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.8:1.1",
      "pali": "“Dasa putte vijāyitvā,"
    },
    {
      "id": "thig5.8:1.2",
      "pali": "asmiṁ rūpasamussaye;"
    },
    {
      "id": "thig5.8:1.3",
      "pali": "Tatohaṁ dubbalā jiṇṇā,"
    },
    {
      "id": "thig5.8:1.4",
      "pali": "bhikkhuniṁ upasaṅkamiṁ."
    },
    {
      "id": "thig5.8:2.1",
      "pali": "Sā me dhammamadesesi,"
    },
    {
      "id": "thig5.8:2.2",
      "pali": "khandhāyatanadhātuyo;"
    },
    {
      "id": "thig5.8:2.3",
      "pali": "Tassā dhammaṁ suṇitvāna,"
    },
    {
      "id": "thig5.8:2.4",
      "pali": "kese chetvāna pabbajiṁ."
    },
    {
      "id": "thig5.8:3.1",
      "pali": "Tassā me sikkhamānāya,"
    },
    {
      "id": "thig5.8:3.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thig5.8:3.3",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thig5.8:3.4",
      "pali": "yattha me vusitaṁ pure."
    },
    {
      "id": "thig5.8:4.1",
      "pali": "Animittañca bhāvemi,"
    },
    {
      "id": "thig5.8:4.2",
      "pali": "ekaggā susamāhitā;"
    },
    {
      "id": "thig5.8:4.3",
      "pali": "Anantarāvimokkhāsiṁ,"
    },
    {
      "id": "thig5.8:4.4",
      "pali": "anupādāya nibbutā."
    },
    {
      "id": "thig5.8:5.1",
      "pali": "Pañcakkhandhā pariññātā,"
    },
    {
      "id": "thig5.8:5.2",
      "pali": "tiṭṭhanti chinnamūlakā;"
    },
    {
      "id": "thig5.8:5.3",
      "pali": "Dhi tavatthu jare jamme,"
    },
    {
      "id": "thig5.8:5.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thig5.8:6.1",
      "pali": "… Soṇā therī …."
    }
  ]
}
