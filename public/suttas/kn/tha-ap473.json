{
  "uid": "tha-ap473",
  "title": "Naḷamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap473:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap473:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap473:1.3",
      "pali": "Vipinaggena gacchantaṁ,"
    },
    {
      "id": "tha-ap473:1.4",
      "pali": "Addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap473:2.1",
      "pali": "Naḷamālaṁ gahetvāna,"
    },
    {
      "id": "tha-ap473:2.2",
      "pali": "nikkhamanto ca tāvade;"
    },
    {
      "id": "tha-ap473:2.3",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap473:2.4",
      "pali": "oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap473:3.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap473:3.2",
      "pali": "naḷamālamapūjayiṁ;"
    },
    {
      "id": "tha-ap473:3.3",
      "pali": "Dakkhiṇeyyaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap473:3.4",
      "pali": "sabbalokānukampakaṁ."
    },
    {
      "id": "tha-ap473:4.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap473:4.2",
      "pali": "yaṁ mālamabhiropayiṁ;"
    },
    {
      "id": "tha-ap473:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap473:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap473:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap473:5.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap473:5.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap473:5.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap473:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap473:6.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap473:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap473:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap473:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap473:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap473:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap473:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap473:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā naḷamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap473:9.1",
      "pali": "Naḷamāliyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
