{
  "uid": "tha-ap282",
  "title": "10 Taraṇīyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap282:1.1",
      "pali": "“Mahāpathamhi visame,"
    },
    {
      "id": "tha-ap282:1.2",
      "pali": "setu kārāpito mayā;"
    },
    {
      "id": "tha-ap282:1.3",
      "pali": "Taraṇatthāya lokassa,"
    },
    {
      "id": "tha-ap282:1.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap282:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap282:2.2",
      "pali": "yo setu kārito mayā;"
    },
    {
      "id": "tha-ap282:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap282:2.4",
      "pali": "setudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap282:3.1",
      "pali": "Pañcapaññāsito kappe,"
    },
    {
      "id": "tha-ap282:3.2",
      "pali": "eko āsiṁ samogadho;"
    },
    {
      "id": "tha-ap282:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap282:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap282:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap282:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap282:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap282:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā taraṇīyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap282:6.1",
      "pali": "Taraṇīyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap282:6.2",
      "pali": "Suvaṇṇabibbohanavaggo aṭṭhavīsatimo."
    },
    {
      "id": "tha-ap282:7.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap282:8.1",
      "pali": "Suvaṇṇaṁ tilamuṭṭhi ca,"
    },
    {
      "id": "tha-ap282:8.2",
      "pali": "caṅkoṭabbhañjanañjalī;"
    },
    {
      "id": "tha-ap282:8.3",
      "pali": "Potthako citamāluvā,"
    },
    {
      "id": "tha-ap282:8.4",
      "pali": "ekapuṇḍarī setunā;"
    },
    {
      "id": "tha-ap282:8.5",
      "pali": "Dvecattālīsa gāthāyo,"
    },
    {
      "id": "tha-ap282:8.6",
      "pali": "gaṇitāyo vibhāvibhīti."
    },
    {
      "id": "tha-ap282:9.1",
      "pali": "Ekādasamaṁ bhāṇavāraṁ."
    }
  ]
}
