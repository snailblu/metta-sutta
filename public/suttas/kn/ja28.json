{
  "uid": "ja28",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja28:1.1",
      "pali": "“Manuññameva bhāseyya,"
    },
    {
      "id": "ja28:1.2",
      "pali": "nāmanuññaṁ kudācanaṁ;"
    },
    {
      "id": "ja28:1.3",
      "pali": "Manuññaṁ bhāsamānassa,"
    },
    {
      "id": "ja28:1.4",
      "pali": "garuṁ bhāraṁ udaddhari;"
    },
    {
      "id": "ja28:1.5",
      "pali": "Dhanañca naṁ alābhesi,"
    },
    {
      "id": "ja28:1.6",
      "pali": "tena cattamano ahū”ti."
    },
    {
      "id": "ja28:2.1",
      "pali": "Nandivisālajātakaṁ aṭṭhamaṁ."
    }
  ]
}
