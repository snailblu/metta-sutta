{
  "uid": "thag4.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.8:1.1",
      "pali": "“Ubhayeneva sampanno,"
    },
    {
      "id": "thag4.8:1.2",
      "pali": "rāhulabhaddoti maṁ vidū;"
    },
    {
      "id": "thag4.8:1.3",
      "pali": "Yañcamhi putto buddhassa,"
    },
    {
      "id": "thag4.8:1.4",
      "pali": "yañca dhammesu cakkhumā."
    },
    {
      "id": "thag4.8:2.1",
      "pali": "Yañca me āsavā khīṇā,"
    },
    {
      "id": "thag4.8:2.2",
      "pali": "yañca natthi punabbhavo;"
    },
    {
      "id": "thag4.8:2.3",
      "pali": "Arahā dakkhiṇeyyomhi,"
    },
    {
      "id": "thag4.8:2.4",
      "pali": "tevijjo amataddaso."
    },
    {
      "id": "thag4.8:3.1",
      "pali": "Kāmandhā jālapacchannā,"
    },
    {
      "id": "thag4.8:3.2",
      "pali": "taṇhāchādanachāditā;"
    },
    {
      "id": "thag4.8:3.3",
      "pali": "Pamattabandhunā baddhā,"
    },
    {
      "id": "thag4.8:3.4",
      "pali": "macchāva kumināmukhe."
    },
    {
      "id": "thag4.8:4.1",
      "pali": "Taṁ kāmaṁ ahamujjhitvā,"
    },
    {
      "id": "thag4.8:4.2",
      "pali": "chetvā mārassa bandhanaṁ;"
    },
    {
      "id": "thag4.8:4.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "thag4.8:4.4",
      "pali": "sītibhūtosmi nibbuto”ti."
    },
    {
      "id": "thag4.8:4.5",
      "pali": "… Rāhulo thero …."
    }
  ]
}
