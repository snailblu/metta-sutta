{
  "uid": "thag4.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.5:1.1",
      "pali": "“Pañcapaññāsavassāni,"
    },
    {
      "id": "thag4.5:1.2",
      "pali": "rajojallamadhārayiṁ;"
    },
    {
      "id": "thag4.5:1.3",
      "pali": "Bhuñjanto māsikaṁ bhattaṁ,"
    },
    {
      "id": "thag4.5:1.4",
      "pali": "kesamassuṁ alocayiṁ."
    },
    {
      "id": "thag4.5:2.1",
      "pali": "Ekapādena aṭṭhāsiṁ,"
    },
    {
      "id": "thag4.5:2.2",
      "pali": "āsanaṁ parivajjayiṁ;"
    },
    {
      "id": "thag4.5:2.3",
      "pali": "Sukkhagūthāni ca khādiṁ,"
    },
    {
      "id": "thag4.5:2.4",
      "pali": "uddesañca na sādiyiṁ."
    },
    {
      "id": "thag4.5:3.1",
      "pali": "Etādisaṁ karitvāna,"
    },
    {
      "id": "thag4.5:3.2",
      "pali": "bahuṁ duggatigāminaṁ;"
    },
    {
      "id": "thag4.5:3.3",
      "pali": "Vuyhamāno mahoghena,"
    },
    {
      "id": "thag4.5:3.4",
      "pali": "buddhaṁ saraṇamāgamaṁ."
    },
    {
      "id": "thag4.5:4.1",
      "pali": "Saraṇagamanaṁ passa,"
    },
    {
      "id": "thag4.5:4.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag4.5:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag4.5:4.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag4.5:4.5",
      "pali": "… Jambuko thero …."
    }
  ]
}
