{
  "uid": "thag5.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.5:1.1",
      "pali": "“Sādhū hi kira me mātā,"
    },
    {
      "id": "thag5.5:1.2",
      "pali": "Patodaṁ upadaṁsayi;"
    },
    {
      "id": "thag5.5:1.3",
      "pali": "Yassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thag5.5:1.4",
      "pali": "Anusiṭṭho janettiyā;"
    },
    {
      "id": "thag5.5:1.5",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "thag5.5:1.6",
      "pali": "Patto sambodhimuttamaṁ."
    },
    {
      "id": "thag5.5:2.1",
      "pali": "Arahā dakkhiṇeyyomhi,"
    },
    {
      "id": "thag5.5:2.2",
      "pali": "tevijjo amataddaso;"
    },
    {
      "id": "thag5.5:2.3",
      "pali": "Jetvā namucino senaṁ,"
    },
    {
      "id": "thag5.5:2.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "thag5.5:3.1",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "thag5.5:3.2",
      "pali": "ye me vijjiṁsu āsavā;"
    },
    {
      "id": "thag5.5:3.3",
      "pali": "Sabbe asesā ucchinnā,"
    },
    {
      "id": "thag5.5:3.4",
      "pali": "na ca uppajjare puna."
    },
    {
      "id": "thag5.5:4.1",
      "pali": "Visāradā kho bhaginī,"
    },
    {
      "id": "thag5.5:4.2",
      "pali": "etamatthaṁ abhāsayi;"
    },
    {
      "id": "thag5.5:4.3",
      "pali": "‘Apihā nūna mayipi,"
    },
    {
      "id": "thag5.5:4.4",
      "pali": "vanatho te na vijjati’."
    },
    {
      "id": "thag5.5:5.1",
      "pali": "Pariyantakataṁ dukkhaṁ,"
    },
    {
      "id": "thag5.5:5.2",
      "pali": "antimoyaṁ samussayo;"
    },
    {
      "id": "thag5.5:5.3",
      "pali": "Jātimaraṇasaṁsāro,"
    },
    {
      "id": "thag5.5:5.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag5.5:5.5",
      "pali": "… Vaḍḍho thero …."
    }
  ]
}
