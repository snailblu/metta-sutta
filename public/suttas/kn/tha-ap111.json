{
  "uid": "tha-ap111",
  "title": "Biḷālidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap111:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap111:1.2",
      "pali": "vasāmi paṇṇasanthare;"
    },
    {
      "id": "tha-ap111:1.3",
      "pali": "Ghāsesu gedhamāpanno,"
    },
    {
      "id": "tha-ap111:1.4",
      "pali": "seyyasīlo cahaṁ tadā."
    },
    {
      "id": "tha-ap111:2.1",
      "pali": "Khaṇantālu kalambāni,"
    },
    {
      "id": "tha-ap111:2.2",
      "pali": "biḷālitakkalāni ca;"
    },
    {
      "id": "tha-ap111:2.3",
      "pali": "Kolaṁ bhallātakaṁ billaṁ,"
    },
    {
      "id": "tha-ap111:2.4",
      "pali": "āhatvā paṭiyāditaṁ."
    },
    {
      "id": "tha-ap111:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap111:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap111:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap111:3.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap111:4.1",
      "pali": "Upāgataṁ mahānāgaṁ,"
    },
    {
      "id": "tha-ap111:4.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap111:4.3",
      "pali": "Biḷāliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap111:4.4",
      "pali": "pattamhi okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap111:5.1",
      "pali": "Paribhuñji mahāvīro,"
    },
    {
      "id": "tha-ap111:5.2",
      "pali": "tosayanto mamaṁ tadā;"
    },
    {
      "id": "tha-ap111:5.3",
      "pali": "Paribhuñjitvāna sabbaññū,"
    },
    {
      "id": "tha-ap111:5.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap111:6.1",
      "pali": "‘Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap111:6.2",
      "pali": "biḷāliṁ me adā tuvaṁ;"
    },
    {
      "id": "tha-ap111:6.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap111:6.4",
      "pali": "duggatiṁ nupapajjasi’."
    },
    {
      "id": "tha-ap111:7.1",
      "pali": "Carimaṁ vattate mayhaṁ,"
    },
    {
      "id": "tha-ap111:7.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap111:7.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap111:7.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap111:8.1",
      "pali": "Catupaññāsito kappe,"
    },
    {
      "id": "tha-ap111:8.2",
      "pali": "sumekhaliyasavhayo;"
    },
    {
      "id": "tha-ap111:8.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap111:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap111:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap111:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap111:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap111:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā biḷālidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap111:11.1",
      "pali": "Biḷālidāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
