{
  "uid": "vv75",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv75:1.1",
      "pali": "“Yathā vanaṁ cittalataṁ pabhāsati,"
    },
    {
      "id": "vv75:1.2",
      "pali": "Uyyānaseṭṭhaṁ tidasānamuttamaṁ;"
    },
    {
      "id": "vv75:1.3",
      "pali": "Tathūpamaṁ tuyhamidaṁ vimānaṁ,"
    },
    {
      "id": "vv75:1.4",
      "pali": "Obhāsayaṁ tiṭṭhati antalikkhe."
    },
    {
      "id": "vv75:2.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv75:2.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv75:2.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv75:2.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv75:3.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv75:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv75:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv75:4.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv75:4.2",
      "pali": "Daliddo atāṇo kapaṇo kammakaro ahosiṁ;"
    },
    {
      "id": "vv75:4.3",
      "pali": "Jiṇṇe ca mātāpitaro abhāriṁ,"
    },
    {
      "id": "vv75:4.4",
      "pali": "Piyā ca me sīlavanto ahesuṁ;"
    },
    {
      "id": "vv75:4.5",
      "pali": "Annañca pānañca pasannacitto,"
    },
    {
      "id": "vv75:4.6",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv75:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv75:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv75:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv75:6.1",
      "pali": "Cittalatāvimānaṁ paṭhamaṁ."
    }
  ]
}
