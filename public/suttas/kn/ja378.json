{
  "uid": "ja378",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja378:1.1",
      "pali": "“Paṅko ca kāmā palipo ca kāmā,"
    },
    {
      "id": "ja378:1.2",
      "pali": "Bhayañca metaṁ timūlaṁ pavuttaṁ;"
    },
    {
      "id": "ja378:1.3",
      "pali": "Rajo ca dhūmo ca mayā pakāsitā,"
    },
    {
      "id": "ja378:1.4",
      "pali": "Hitvā tuvaṁ pabbaja brahmadatta”."
    },
    {
      "id": "ja378:2.1",
      "pali": "“Gadhito ca ratto ca adhimucchito ca,"
    },
    {
      "id": "ja378:2.2",
      "pali": "Kāmesvahaṁ brāhmaṇa bhiṁsarūpaṁ;"
    },
    {
      "id": "ja378:2.3",
      "pali": "Taṁ nussahe jīvikattho pahātuṁ,"
    },
    {
      "id": "ja378:2.4",
      "pali": "Kāhāmi puññāni anappakāni”."
    },
    {
      "id": "ja378:3.1",
      "pali": "“Yo atthakāmassa hitānukampino,"
    },
    {
      "id": "ja378:3.2",
      "pali": "Ovajjamāno na karoti sāsanaṁ;"
    },
    {
      "id": "ja378:3.3",
      "pali": "Idameva seyyo iti maññamāno,"
    },
    {
      "id": "ja378:3.4",
      "pali": "Punappunaṁ gabbhamupeti mando."
    },
    {
      "id": "ja378:4.1",
      "pali": "So ghorarūpaṁ nirayaṁ upeti,"
    },
    {
      "id": "ja378:4.2",
      "pali": "Subhāsubhaṁ muttakarīsapūraṁ;"
    },
    {
      "id": "ja378:4.3",
      "pali": "Sattā sakāye na jahanti giddhā,"
    },
    {
      "id": "ja378:4.4",
      "pali": "Ye honti kāmesu avītarāgā”."
    },
    {
      "id": "ja378:5.1",
      "pali": "“Mīḷhena littā ruhirena makkhitā,"
    },
    {
      "id": "ja378:5.2",
      "pali": "Semhena littā upanikkhamanti;"
    },
    {
      "id": "ja378:5.3",
      "pali": "Yaṁ yañhi kāyena phusanti tāvade,"
    },
    {
      "id": "ja378:5.4",
      "pali": "Sabbaṁ asātaṁ dukhameva kevalaṁ."
    },
    {
      "id": "ja378:6.1",
      "pali": "Disvā vadāmi na hi aññato savaṁ,"
    },
    {
      "id": "ja378:6.2",
      "pali": "Pubbenivāsaṁ bahukaṁ sarāmi;"
    },
    {
      "id": "ja378:6.3",
      "pali": "Citrāhi gāthāhi subhāsitāhi,"
    },
    {
      "id": "ja378:6.4",
      "pali": "Darīmukho nijjhāpayi sumedhan”ti."
    },
    {
      "id": "ja378:7.1",
      "pali": "Darīmukhajātakaṁ tatiyaṁ."
    }
  ]
}
