{
  "uid": "thag1.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.10:1.1",
      "pali": "“Vihari apekkhaṁ idha vā huraṁ vā,"
    },
    {
      "id": "thag1.10:1.2",
      "pali": "Yo vedagū samito yatatto;"
    },
    {
      "id": "thag1.10:1.3",
      "pali": "Sabbesu dhammesu anūpalitto,"
    },
    {
      "id": "thag1.10:1.4",
      "pali": "Lokassa jaññā udayabbayañcā”ti."
    },
    {
      "id": "thag1.10:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā puṇṇamāso thero gāthaṁ abhāsitthāti."
    },
    {
      "id": "thag1.10:1.6",
      "pali": "vaggo paṭhamo."
    },
    {
      "id": "thag1.10:2.1",
      "pali": "Subhūti koṭṭhiko thero,"
    },
    {
      "id": "thag1.10:2.2",
      "pali": "kaṅkhārevatasammato;"
    },
    {
      "id": "thag1.10:2.3",
      "pali": "Mantāṇiputto dabbo ca,"
    },
    {
      "id": "thag1.10:2.4",
      "pali": "sītavaniyo ca bhalliyo;"
    },
    {
      "id": "thag1.10:2.5",
      "pali": "Vīro pilindavaccho ca,"
    },
    {
      "id": "thag1.10:2.6",
      "pali": "puṇṇamāso tamonudoti."
    }
  ]
}
