{
  "uid": "tha-ap232",
  "title": "10 Ekavandaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap232:1.1",
      "pali": "“Usabhaṁ pavaraṁ vīraṁ,"
    },
    {
      "id": "tha-ap232:1.2",
      "pali": "vessabhuṁ vijitāvinaṁ;"
    },
    {
      "id": "tha-ap232:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap232:1.4",
      "pali": "buddhaseṭṭhamavandahaṁ."
    },
    {
      "id": "tha-ap232:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap232:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap232:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap232:2.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap232:3.1",
      "pali": "Catuvīsatikappamhi,"
    },
    {
      "id": "tha-ap232:3.2",
      "pali": "vikatānandanāmako;"
    },
    {
      "id": "tha-ap232:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap232:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap232:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap232:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap232:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap232:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekavandaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap232:6.1",
      "pali": "Ekavandaniyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap232:7.1",
      "pali": "Ālambaṇadāyakavaggo tevīsatimo."
    },
    {
      "id": "tha-ap232:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap232:9.1",
      "pali": "Ālambaṇañca ajinaṁ,"
    },
    {
      "id": "tha-ap232:9.2",
      "pali": "maṁsadārakkhadāyako;"
    },
    {
      "id": "tha-ap232:9.3",
      "pali": "Abyādhi aṅkolaṁ soṇṇaṁ,"
    },
    {
      "id": "tha-ap232:9.4",
      "pali": "miñjaāveḷavandanaṁ;"
    },
    {
      "id": "tha-ap232:9.5",
      "pali": "Pañcapaññāsa gāthāyo,"
    },
    {
      "id": "tha-ap232:9.6",
      "pali": "gaṇitā atthadassibhi."
    }
  ]
}
