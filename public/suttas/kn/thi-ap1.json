{
  "uid": "thi-ap1",
  "title": "Sumedhātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "thi-ap1:2.1",
      "pali": "Atha therikāpadānāni suṇātha—"
    },
    {
      "id": "thi-ap1:3.1",
      "pali": "“Bhagavati koṇāgamane,"
    },
    {
      "id": "thi-ap1:3.2",
      "pali": "Saṅghārāmamhi navanivesanamhi;"
    },
    {
      "id": "thi-ap1:3.3",
      "pali": "Sakhiyo tisso janiyo,"
    },
    {
      "id": "thi-ap1:3.4",
      "pali": "Vihāradānaṁ adāsimha."
    },
    {
      "id": "thi-ap1:4.1",
      "pali": "Dasakkhattuṁ satakkhattuṁ,"
    },
    {
      "id": "thi-ap1:4.2",
      "pali": "Dasasatakkhattuṁ satānañca satakkhattuṁ;"
    },
    {
      "id": "thi-ap1:4.3",
      "pali": "Devesu upapajjimha,"
    },
    {
      "id": "thi-ap1:4.4",
      "pali": "Ko vādo mānuse bhave."
    },
    {
      "id": "thi-ap1:5.1",
      "pali": "Deve mahiddhikā ahumha,"
    },
    {
      "id": "thi-ap1:5.2",
      "pali": "mānusakamhi ko vādo;"
    },
    {
      "id": "thi-ap1:5.3",
      "pali": "Sattaratanamahesī,"
    },
    {
      "id": "thi-ap1:5.4",
      "pali": "itthiratanaṁ ahaṁ bhaviṁ."
    },
    {
      "id": "thi-ap1:6.1",
      "pali": "Idha sañcitakusalā,"
    },
    {
      "id": "thi-ap1:6.2",
      "pali": "susamiddhakulappajā;"
    },
    {
      "id": "thi-ap1:6.3",
      "pali": "Dhanañjānī ca khemā ca,"
    },
    {
      "id": "thi-ap1:6.4",
      "pali": "ahampi ca tayo janā."
    },
    {
      "id": "thi-ap1:7.1",
      "pali": "Ārāmaṁ sukataṁ katvā,"
    },
    {
      "id": "thi-ap1:7.2",
      "pali": "sabbāvayavamaṇḍitaṁ;"
    },
    {
      "id": "thi-ap1:7.3",
      "pali": "Buddhappamukhasaṅghassa,"
    },
    {
      "id": "thi-ap1:7.4",
      "pali": "niyyādetvā samoditā."
    },
    {
      "id": "thi-ap1:8.1",
      "pali": "Yattha yatthūpapajjāmi,"
    },
    {
      "id": "thi-ap1:8.2",
      "pali": "tassa kammassa vāhasā;"
    },
    {
      "id": "thi-ap1:8.3",
      "pali": "Devesu aggataṁ pattā,"
    },
    {
      "id": "thi-ap1:8.4",
      "pali": "manussesu tatheva ca."
    },
    {
      "id": "thi-ap1:9.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "thi-ap1:9.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap1:9.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap1:9.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap1:10.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap1:10.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap1:10.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap1:10.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap1:11.1",
      "pali": "Tassāsuṁ satta dhītaro,"
    },
    {
      "id": "thi-ap1:11.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap1:11.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap1:11.4",
      "pali": "brahmacariyaṁ cariṁsu tā."
    },
    {
      "id": "thi-ap1:12.1",
      "pali": "Tāsaṁ sahāyikā hutvā,"
    },
    {
      "id": "thi-ap1:12.2",
      "pali": "sīlesu susamāhitā;"
    },
    {
      "id": "thi-ap1:12.3",
      "pali": "Datvā dānāni sakkaccaṁ,"
    },
    {
      "id": "thi-ap1:12.4",
      "pali": "agāreva vataṁ cariṁ."
    },
    {
      "id": "thi-ap1:13.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap1:13.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap1:13.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap1:13.4",
      "pali": "tāvatiṁsūpagā ahaṁ."
    },
    {
      "id": "thi-ap1:14.1",
      "pali": "Tato cutā yāmamagaṁ,"
    },
    {
      "id": "thi-ap1:14.2",
      "pali": "tatohaṁ tusitaṁ gatā;"
    },
    {
      "id": "thi-ap1:14.3",
      "pali": "Tato ca nimmānaratiṁ,"
    },
    {
      "id": "thi-ap1:14.4",
      "pali": "vasavattipuraṁ tato."
    },
    {
      "id": "thi-ap1:15.1",
      "pali": "Yattha yatthūpapajjāmi,"
    },
    {
      "id": "thi-ap1:15.2",
      "pali": "puññakammasamohitā;"
    },
    {
      "id": "thi-ap1:15.3",
      "pali": "Tattha tattheva rājūnaṁ,"
    },
    {
      "id": "thi-ap1:15.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap1:16.1",
      "pali": "Tato cutā manussatte,"
    },
    {
      "id": "thi-ap1:16.2",
      "pali": "rājūnaṁ cakkavattinaṁ;"
    },
    {
      "id": "thi-ap1:16.3",
      "pali": "Maṇḍalīnañca rājūnaṁ,"
    },
    {
      "id": "thi-ap1:16.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap1:17.1",
      "pali": "Sampattimanubhotvāna,"
    },
    {
      "id": "thi-ap1:17.2",
      "pali": "devesu mānusesu ca;"
    },
    {
      "id": "thi-ap1:17.3",
      "pali": "Sabbattha sukhitā hutvā,"
    },
    {
      "id": "thi-ap1:17.4",
      "pali": "nekajātīsu saṁsariṁ."
    },
    {
      "id": "thi-ap1:18.1",
      "pali": "So hetu ca so pabhavo,"
    },
    {
      "id": "thi-ap1:18.2",
      "pali": "Tammūlaṁ sāsane khamaṁ;"
    },
    {
      "id": "thi-ap1:18.3",
      "pali": "Paṭhamaṁ taṁ samodhānaṁ,"
    },
    {
      "id": "thi-ap1:18.4",
      "pali": "Taṁ dhammaratāya nibbānaṁ."
    },
    {
      "id": "thi-ap1:19.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap1:19.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap1:19.3",
      "pali": "Nāgīva bandhanaṁ chetvā,"
    },
    {
      "id": "thi-ap1:19.4",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap1:20.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap1:20.2",
      "pali": "buddhaseṭṭhassa santike;"
    },
    {
      "id": "thi-ap1:20.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thi-ap1:20.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap1:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap1:21.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "thi-ap1:21.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thi-ap1:21.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap1:22.1",
      "pali": "Itthaṁ sudaṁ sumedhā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap1:23.1",
      "pali": "Sumedhātheriyāpadānaṁ paṭhamaṁ."
    }
  ]
}
