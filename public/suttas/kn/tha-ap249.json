{
  "uid": "tha-ap249",
  "title": "Dhātupūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap249:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap249:1.2",
      "pali": "siddhatthamhi naruttame;"
    },
    {
      "id": "tha-ap249:1.3",
      "pali": "Ekā dhātu mayā laddhā,"
    },
    {
      "id": "tha-ap249:1.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap249:2.1",
      "pali": "Tāhaṁ dhātuṁ gahetvāna,"
    },
    {
      "id": "tha-ap249:2.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "tha-ap249:2.3",
      "pali": "Pañcavasse paricariṁ,"
    },
    {
      "id": "tha-ap249:2.4",
      "pali": "tiṭṭhantaṁva naruttamaṁ."
    },
    {
      "id": "tha-ap249:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap249:3.2",
      "pali": "yaṁ dhātuṁ pūjayiṁ tadā;"
    },
    {
      "id": "tha-ap249:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap249:3.4",
      "pali": "dhātupaṭṭhahane phalaṁ."
    },
    {
      "id": "tha-ap249:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap249:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap249:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap249:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhātupūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap249:6.1",
      "pali": "Dhātupūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
