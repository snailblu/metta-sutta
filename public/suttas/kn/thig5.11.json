{
  "uid": "thig5.11",
  "title": "Tiṁsamattātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.11:1.1",
      "pali": "“Musalāni gahetvāna,"
    },
    {
      "id": "thig5.11:1.2",
      "pali": "dhaññaṁ koṭṭenti māṇavā;"
    },
    {
      "id": "thig5.11:1.3",
      "pali": "Puttadārāni posentā,"
    },
    {
      "id": "thig5.11:1.4",
      "pali": "dhanaṁ vindanti māṇavā."
    },
    {
      "id": "thig5.11:2.1",
      "pali": "Karotha buddhasāsanaṁ,"
    },
    {
      "id": "thig5.11:2.2",
      "pali": "yaṁ katvā nānutappati;"
    },
    {
      "id": "thig5.11:2.3",
      "pali": "Khippaṁ pādāni dhovitvā,"
    },
    {
      "id": "thig5.11:2.4",
      "pali": "ekamante nisīdatha;"
    },
    {
      "id": "thig5.11:2.5",
      "pali": "Cetosamathamanuyuttā,"
    },
    {
      "id": "thig5.11:2.6",
      "pali": "karotha buddhasāsanaṁ”."
    },
    {
      "id": "thig5.11:3.1",
      "pali": "Tassā tā vacanaṁ sutvā,"
    },
    {
      "id": "thig5.11:3.2",
      "pali": "paṭācārāya sāsanaṁ;"
    },
    {
      "id": "thig5.11:3.3",
      "pali": "Pāde pakkhālayitvāna,"
    },
    {
      "id": "thig5.11:3.4",
      "pali": "ekamantaṁ upāvisuṁ;"
    },
    {
      "id": "thig5.11:3.5",
      "pali": "Cetosamathamanuyuttā,"
    },
    {
      "id": "thig5.11:3.6",
      "pali": "akaṁsu buddhasāsanaṁ."
    },
    {
      "id": "thig5.11:4.1",
      "pali": "Rattiyā purime yāme,"
    },
    {
      "id": "thig5.11:4.2",
      "pali": "pubbajātimanussaruṁ;"
    },
    {
      "id": "thig5.11:4.3",
      "pali": "Rattiyā majjhime yāme,"
    },
    {
      "id": "thig5.11:4.4",
      "pali": "dibbacakkhuṁ visodhayuṁ;"
    },
    {
      "id": "thig5.11:4.5",
      "pali": "Rattiyā pacchime yāme,"
    },
    {
      "id": "thig5.11:4.6",
      "pali": "tamokhandhaṁ padālayuṁ."
    },
    {
      "id": "thig5.11:5.1",
      "pali": "Uṭṭhāya pāde vandiṁsu,"
    },
    {
      "id": "thig5.11:5.2",
      "pali": "“katā te anusāsanī;"
    },
    {
      "id": "thig5.11:5.3",
      "pali": "Indaṁva devā tidasā,"
    },
    {
      "id": "thig5.11:5.4",
      "pali": "saṅgāme aparājitaṁ;"
    },
    {
      "id": "thig5.11:5.5",
      "pali": "Purakkhatvā vihassāma,"
    },
    {
      "id": "thig5.11:5.6",
      "pali": "tevijjāmha anāsavā”ti."
    },
    {
      "id": "thig5.11:6.1",
      "pali": "Itthaṁ sudaṁ tiṁsamattā therī bhikkhuniyo paṭācārāya santike aññaṁ byākariṁsūti."
    }
  ]
}
