{
  "uid": "bv5",
  "title": "5. Maṅgalabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv5:1.1",
      "pali": "“Koṇḍaññassa aparena,"
    },
    {
      "id": "bv5:1.2",
      "pali": "maṅgalo nāma nāyako;"
    },
    {
      "id": "bv5:1.3",
      "pali": "Tamaṁ loke nihantvāna,"
    },
    {
      "id": "bv5:1.4",
      "pali": "dhammokkamabhidhārayi."
    },
    {
      "id": "bv5:2.1",
      "pali": "Atulāsi pabhā tassa,"
    },
    {
      "id": "bv5:2.2",
      "pali": "jinehaññehi uttariṁ;"
    },
    {
      "id": "bv5:2.3",
      "pali": "Candasūriyapabhaṁ hantvā,"
    },
    {
      "id": "bv5:2.4",
      "pali": "dasasahassī virocati."
    },
    {
      "id": "bv5:3.1",
      "pali": "Sopi buddho pakāsesi,"
    },
    {
      "id": "bv5:3.2",
      "pali": "caturo saccavaruttame;"
    },
    {
      "id": "bv5:3.3",
      "pali": "Te te saccarasaṁ pītvā,"
    },
    {
      "id": "bv5:3.4",
      "pali": "vinodenti mahātamaṁ."
    },
    {
      "id": "bv5:4.1",
      "pali": "Patvāna bodhimatulaṁ,"
    },
    {
      "id": "bv5:4.2",
      "pali": "paṭhame dhammadesane;"
    },
    {
      "id": "bv5:4.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv5:4.4",
      "pali": "dhammābhisamayo ahu."
    },
    {
      "id": "bv5:5.1",
      "pali": "Surindadevabhavane,"
    },
    {
      "id": "bv5:5.2",
      "pali": "buddho dhammamadesayi;"
    },
    {
      "id": "bv5:5.3",
      "pali": "Tadā koṭisahassānaṁ,"
    },
    {
      "id": "bv5:5.4",
      "pali": "dutiyo samayo ahu."
    },
    {
      "id": "bv5:6.1",
      "pali": "Yadā sunando cakkavattī,"
    },
    {
      "id": "bv5:6.2",
      "pali": "sambuddhaṁ upasaṅkami;"
    },
    {
      "id": "bv5:6.3",
      "pali": "Tadā āhani sambuddho,"
    },
    {
      "id": "bv5:6.4",
      "pali": "dhammabheriṁ varuttamaṁ."
    },
    {
      "id": "bv5:7.1",
      "pali": "Sunandassānucarā janatā,"
    },
    {
      "id": "bv5:7.2",
      "pali": "Tadāsuṁ navutikoṭiyo;"
    },
    {
      "id": "bv5:7.3",
      "pali": "Sabbepi te niravasesā,"
    },
    {
      "id": "bv5:7.4",
      "pali": "Ahesuṁ ehi bhikkhukā."
    },
    {
      "id": "bv5:8.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv5:8.2",
      "pali": "maṅgalassa mahesino;"
    },
    {
      "id": "bv5:8.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv5:8.4",
      "pali": "paṭhamo āsi samāgamo."
    },
    {
      "id": "bv5:9.1",
      "pali": "Dutiyo koṭisatasahassānaṁ,"
    },
    {
      "id": "bv5:9.2",
      "pali": "Tatiyo navutikoṭinaṁ;"
    },
    {
      "id": "bv5:9.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv5:9.4",
      "pali": "Tadā āsi samāgamo."
    },
    {
      "id": "bv5:10.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv5:10.2",
      "pali": "surucī nāma brāhmaṇo;"
    },
    {
      "id": "bv5:10.3",
      "pali": "Ajjhāyako mantadharo,"
    },
    {
      "id": "bv5:10.4",
      "pali": "tiṇṇaṁ vedāna pāragū."
    },
    {
      "id": "bv5:11.1",
      "pali": "Tamahaṁ upasaṅkamma,"
    },
    {
      "id": "bv5:11.2",
      "pali": "Saraṇaṁ gantvāna satthuno;"
    },
    {
      "id": "bv5:11.3",
      "pali": "Sambuddhappamukhaṁ saṅghaṁ,"
    },
    {
      "id": "bv5:11.4",
      "pali": "Gandhamālena pūjayiṁ;"
    },
    {
      "id": "bv5:11.5",
      "pali": "Pūjetvā gandhamālena,"
    },
    {
      "id": "bv5:11.6",
      "pali": "Gavapānena tappayiṁ."
    },
    {
      "id": "bv5:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv5:12.2",
      "pali": "maṅgalo dvipaduttamo;"
    },
    {
      "id": "bv5:12.3",
      "pali": "‘Aparimeyyito kappe,"
    },
    {
      "id": "bv5:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv5:13.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv5:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv5:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv5:14.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv5:14.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv5:14.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv5:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv5:15.1",
      "pali": "Tadā pītimanubrūhanto,"
    },
    {
      "id": "bv5:15.2",
      "pali": "sambodhivarapattiyā;"
    },
    {
      "id": "bv5:15.3",
      "pali": "Buddhe datvāna maṁ gehaṁ,"
    },
    {
      "id": "bv5:15.4",
      "pali": "pabbajiṁ tassa santike."
    },
    {
      "id": "bv5:16.1",
      "pali": "Suttantaṁ vinayañcāpi,"
    },
    {
      "id": "bv5:16.2",
      "pali": "navaṅgaṁ satthusāsanaṁ;"
    },
    {
      "id": "bv5:16.3",
      "pali": "Sabbaṁ pariyāpuṇitvā,"
    },
    {
      "id": "bv5:16.4",
      "pali": "sobhayiṁ jinasāsanaṁ."
    },
    {
      "id": "bv5:17.1",
      "pali": "Tatthappamatto viharanto,"
    },
    {
      "id": "bv5:17.2",
      "pali": "brahmaṁ bhāvetva bhāvanaṁ;"
    },
    {
      "id": "bv5:17.3",
      "pali": "Abhiññāpāramiṁ gantvā,"
    },
    {
      "id": "bv5:17.4",
      "pali": "brahmalokamagacchahaṁ."
    },
    {
      "id": "bv5:18.1",
      "pali": "Uttaraṁ nāma nagaraṁ,"
    },
    {
      "id": "bv5:18.2",
      "pali": "uttaro nāma khattiyo;"
    },
    {
      "id": "bv5:18.3",
      "pali": "Uttarā nāma janikā,"
    },
    {
      "id": "bv5:18.4",
      "pali": "maṅgalassa mahesino."
    },
    {
      "id": "bv5:19.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv5:19.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv5:19.3",
      "pali": "Yasavā sucimā sirīmā,"
    },
    {
      "id": "bv5:19.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv5:20.1",
      "pali": "Samatiṁsasahassāni,"
    },
    {
      "id": "bv5:20.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv5:20.3",
      "pali": "Yasavatī nāma nārī,"
    },
    {
      "id": "bv5:20.4",
      "pali": "sīvalo nāma atrajo."
    },
    {
      "id": "bv5:21.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv5:21.2",
      "pali": "assayānena nikkhami;"
    },
    {
      "id": "bv5:21.3",
      "pali": "Anūnaaṭṭhamāsāni,"
    },
    {
      "id": "bv5:21.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv5:22.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv5:22.2",
      "pali": "maṅgalo nāma nāyako;"
    },
    {
      "id": "bv5:22.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv5:22.4",
      "pali": "vane sirīvaruttame."
    },
    {
      "id": "bv5:23.1",
      "pali": "Sudevo dhammaseno ca,"
    },
    {
      "id": "bv5:23.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv5:23.3",
      "pali": "Pālito nāmupaṭṭhāko,"
    },
    {
      "id": "bv5:23.4",
      "pali": "maṅgalassa mahesino."
    },
    {
      "id": "bv5:24.1",
      "pali": "Sīvalā ca asokā ca,"
    },
    {
      "id": "bv5:24.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv5:24.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv5:24.4",
      "pali": "nāgarukkhoti vuccati."
    },
    {
      "id": "bv5:25.1",
      "pali": "Nando ceva visākho ca,"
    },
    {
      "id": "bv5:25.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv5:25.3",
      "pali": "Anulā ceva sutanā ca,"
    },
    {
      "id": "bv5:25.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv5:26.1",
      "pali": "Aṭṭhāsīti ratanāni,"
    },
    {
      "id": "bv5:26.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv5:26.3",
      "pali": "Tato niddhāvatī raṁsī,"
    },
    {
      "id": "bv5:26.4",
      "pali": "anekasatasahassiyo."
    },
    {
      "id": "bv5:27.1",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv5:27.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv5:27.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv5:27.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv5:28.1",
      "pali": "Yathāpi sāgare ūmī,"
    },
    {
      "id": "bv5:28.2",
      "pali": "na sakkā tā gaṇetuye;"
    },
    {
      "id": "bv5:28.3",
      "pali": "Tatheva sāvakā tassa,"
    },
    {
      "id": "bv5:28.4",
      "pali": "na sakkā te gaṇetuye."
    },
    {
      "id": "bv5:29.1",
      "pali": "Yāva aṭṭhāsi sambuddho,"
    },
    {
      "id": "bv5:29.2",
      "pali": "maṅgalo lokanāyako;"
    },
    {
      "id": "bv5:29.3",
      "pali": "Na tassa sāsane atthi,"
    },
    {
      "id": "bv5:29.4",
      "pali": "sakilesamaraṇaṁ tadā."
    },
    {
      "id": "bv5:30.1",
      "pali": "Dhammokkaṁ dhārayitvāna,"
    },
    {
      "id": "bv5:30.2",
      "pali": "santāretvā mahājanaṁ;"
    },
    {
      "id": "bv5:30.3",
      "pali": "Jalitvā dhūmaketūva,"
    },
    {
      "id": "bv5:30.4",
      "pali": "nibbuto so mahāyaso."
    },
    {
      "id": "bv5:31.1",
      "pali": "Saṅkhārānaṁ sabhāvatthaṁ,"
    },
    {
      "id": "bv5:31.2",
      "pali": "dassayitvā sadevake;"
    },
    {
      "id": "bv5:31.3",
      "pali": "Jalitvā aggikkhandhova,"
    },
    {
      "id": "bv5:31.4",
      "pali": "sūriyo atthaṅgato yathā."
    },
    {
      "id": "bv5:32.1",
      "pali": "Uyyāne vassare nāma,"
    },
    {
      "id": "bv5:32.2",
      "pali": "Buddho nibbāyi maṅgalo;"
    },
    {
      "id": "bv5:32.3",
      "pali": "Tatthevassa jinathūpo,"
    },
    {
      "id": "bv5:32.4",
      "pali": "Tiṁsayojanamuggato”ti."
    },
    {
      "id": "bv5:33.1",
      "pali": "Maṅgalassa bhagavato vaṁso tatiyo."
    }
  ]
}
