{
  "uid": "tha-ap332",
  "title": "Saparivārachattadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap332:1.1",
      "pali": "“Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap332:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap332:1.3",
      "pali": "Ākāse jalavuṭṭhīva,"
    },
    {
      "id": "tha-ap332:1.4",
      "pali": "vassate dhammavuṭṭhiyā."
    },
    {
      "id": "tha-ap332:2.1",
      "pali": "Tamaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap332:2.2",
      "pali": "desentaṁ amataṁ padaṁ;"
    },
    {
      "id": "tha-ap332:2.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap332:2.4",
      "pali": "agamāsiṁ sakaṁ gharaṁ."
    },
    {
      "id": "tha-ap332:3.1",
      "pali": "Chattaṁ alaṅkataṁ gayha,"
    },
    {
      "id": "tha-ap332:3.2",
      "pali": "upagacchiṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap332:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap332:3.4",
      "pali": "ākāse ukkhipiṁ ahaṁ."
    },
    {
      "id": "tha-ap332:4.1",
      "pali": "Susaṅgahitayānaṁva,"
    },
    {
      "id": "tha-ap332:4.2",
      "pali": "dantova sāvakuttamo;"
    },
    {
      "id": "tha-ap332:4.3",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap332:4.4",
      "pali": "matthake sampatiṭṭhahi."
    },
    {
      "id": "tha-ap332:5.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap332:5.2",
      "pali": "buddho lokagganāyako;"
    },
    {
      "id": "tha-ap332:5.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap332:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap332:6.1",
      "pali": "‘Yena chattamidaṁ dinnaṁ,"
    },
    {
      "id": "tha-ap332:6.2",
      "pali": "alaṅkataṁ manoramaṁ;"
    },
    {
      "id": "tha-ap332:6.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap332:6.4",
      "pali": "duggatiṁ so na gacchati."
    },
    {
      "id": "tha-ap332:7.1",
      "pali": "Sattakkhattuñca devesu,"
    },
    {
      "id": "tha-ap332:7.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap332:7.3",
      "pali": "Bāttiṁsakkhattuñca rājā,"
    },
    {
      "id": "tha-ap332:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap332:8.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap332:8.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap332:8.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap332:8.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap332:9.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap332:9.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap332:9.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap332:9.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap332:10.1",
      "pali": "Buddhassa giramaññāya,"
    },
    {
      "id": "tha-ap332:10.2",
      "pali": "vācāsabhimudīritaṁ;"
    },
    {
      "id": "tha-ap332:10.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap332:10.4",
      "pali": "bhiyyo hāsaṁ janesahaṁ."
    },
    {
      "id": "tha-ap332:11.1",
      "pali": "Jahitvā mānusaṁ yoniṁ,"
    },
    {
      "id": "tha-ap332:11.2",
      "pali": "Dibbaṁ yoniṁ samajjhagaṁ;"
    },
    {
      "id": "tha-ap332:11.3",
      "pali": "Vimānamuttamaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap332:11.4",
      "pali": "Abbhuggataṁ manoramaṁ."
    },
    {
      "id": "tha-ap332:12.1",
      "pali": "Vimānā nikkhamantassa,"
    },
    {
      "id": "tha-ap332:12.2",
      "pali": "setacchattaṁ dharīyati;"
    },
    {
      "id": "tha-ap332:12.3",
      "pali": "Tadā saññaṁ paṭilabhiṁ,"
    },
    {
      "id": "tha-ap332:12.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap332:13.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap332:13.2",
      "pali": "manussattañca āgamiṁ;"
    },
    {
      "id": "tha-ap332:13.3",
      "pali": "Chattiṁsakkhattuṁ cakkavattī,"
    },
    {
      "id": "tha-ap332:13.4",
      "pali": "sattakappasatamhito."
    },
    {
      "id": "tha-ap332:14.1",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap332:14.2",
      "pali": "āgacchiṁ tidasaṁ puraṁ;"
    },
    {
      "id": "tha-ap332:14.3",
      "pali": "Saṁsaritvānupubbena,"
    },
    {
      "id": "tha-ap332:14.4",
      "pali": "mānusaṁ punarāgamiṁ."
    },
    {
      "id": "tha-ap332:15.1",
      "pali": "Okkantaṁ mātukucchiṁ maṁ,"
    },
    {
      "id": "tha-ap332:15.2",
      "pali": "setacchattaṁ adhārayuṁ;"
    },
    {
      "id": "tha-ap332:15.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap332:15.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap332:16.1",
      "pali": "Sunando nāma nāmena,"
    },
    {
      "id": "tha-ap332:16.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap332:16.3",
      "pali": "Phalikaṁ chattamādāya,"
    },
    {
      "id": "tha-ap332:16.4",
      "pali": "sāvakaggassa so tadā."
    },
    {
      "id": "tha-ap332:17.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap332:17.2",
      "pali": "sāriputto mahākathī;"
    },
    {
      "id": "tha-ap332:17.3",
      "pali": "Sutvānumodanaṁ tassa,"
    },
    {
      "id": "tha-ap332:17.4",
      "pali": "pubbakammamanussariṁ."
    },
    {
      "id": "tha-ap332:18.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap332:18.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap332:18.3",
      "pali": "Saritvā purimaṁ kammaṁ,"
    },
    {
      "id": "tha-ap332:18.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap332:19.1",
      "pali": "Uṭṭhāya āsanā tamhā,"
    },
    {
      "id": "tha-ap332:19.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap332:19.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap332:19.4",
      "pali": "imaṁ vācaṁ udīrayiṁ."
    },
    {
      "id": "tha-ap332:20.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap332:20.2",
      "pali": "buddho loke anuttaro;"
    },
    {
      "id": "tha-ap332:20.3",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap332:20.4",
      "pali": "āhutīnaṁ paṭiggaho."
    },
    {
      "id": "tha-ap332:21.1",
      "pali": "Tassa chattaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap332:21.2",
      "pali": "vicittaṁ samalaṅkataṁ;"
    },
    {
      "id": "tha-ap332:21.3",
      "pali": "Ubho hatthehi paggaṇhi,"
    },
    {
      "id": "tha-ap332:21.4",
      "pali": "sayambhū aggapuggalo."
    },
    {
      "id": "tha-ap332:22.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap332:22.2",
      "pali": "aho no satthusampadā;"
    },
    {
      "id": "tha-ap332:22.3",
      "pali": "Ekacchattassa dānena,"
    },
    {
      "id": "tha-ap332:22.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap332:23.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap332:23.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap332:23.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap332:23.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap332:24.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap332:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap332:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap332:25.1",
      "pali": "Itthaṁ sudaṁ āyasmā saparivārachattadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap332:26.1",
      "pali": "Saparivārachattadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap332:27.1",
      "pali": "Umāpupphiyavaggo tettiṁsatimo."
    },
    {
      "id": "tha-ap332:28.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap332:29.1",
      "pali": "Umāpupphañca pulinaṁ,"
    },
    {
      "id": "tha-ap332:29.2",
      "pali": "hāso yañño nimittako;"
    },
    {
      "id": "tha-ap332:29.3",
      "pali": "Saṁsāvako nigguṇḍī ca,"
    },
    {
      "id": "tha-ap332:29.4",
      "pali": "sumanaṁ pupphachattako;"
    },
    {
      "id": "tha-ap332:29.5",
      "pali": "Saparivārachatto ca,"
    },
    {
      "id": "tha-ap332:29.6",
      "pali": "gāthā sattasatuttarāti."
    }
  ]
}
