{
  "uid": "tha-ap370",
  "title": "Ekacampakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap370:1.1",
      "pali": "“Upasanto ca sambuddho,"
    },
    {
      "id": "tha-ap370:1.2",
      "pali": "vasatī pabbatantare;"
    },
    {
      "id": "tha-ap370:1.3",
      "pali": "Ekacampakamādāya,"
    },
    {
      "id": "tha-ap370:1.4",
      "pali": "upagacchiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap370:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap370:2.2",
      "pali": "paccekamunimuttamaṁ;"
    },
    {
      "id": "tha-ap370:2.3",
      "pali": "Ubhohatthehi paggayha,"
    },
    {
      "id": "tha-ap370:2.4",
      "pali": "pūjayiṁ aparājitaṁ."
    },
    {
      "id": "tha-ap370:3.1",
      "pali": "Pañcasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap370:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap370:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap370:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap370:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap370:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap370:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap370:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekacampakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap370:6.1",
      "pali": "Ekacampakapupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
