{
  "uid": "ja91",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja91:1.1",
      "pali": "“Littaṁ paramena tejasā,"
    },
    {
      "id": "ja91:1.2",
      "pali": "Gilamakkhaṁ puriso na bujjhati;"
    },
    {
      "id": "ja91:1.3",
      "pali": "Gila re gila pāpadhuttaka,"
    },
    {
      "id": "ja91:1.4",
      "pali": "Pacchā te kaṭukaṁ bhavissatī”ti."
    },
    {
      "id": "ja91:2.1",
      "pali": "Littajātakaṁ paṭhamaṁ."
    }
  ]
}
