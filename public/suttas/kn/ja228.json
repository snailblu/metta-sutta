{
  "uid": "ja228",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja228:1.1",
      "pali": "“Tayo giriṁ antaraṁ kāmayāmi,"
    },
    {
      "id": "ja228:1.2",
      "pali": "Pañcālā kuruyo kekake ca;"
    },
    {
      "id": "ja228:1.3",
      "pali": "Tatuttariṁ brāhmaṇa kāmayāmi,"
    },
    {
      "id": "ja228:1.4",
      "pali": "Tikiccha maṁ brāhmaṇa kāmanītaṁ”."
    },
    {
      "id": "ja228:2.1",
      "pali": "“Kaṇhāhidaṭṭhassa karonti heke,"
    },
    {
      "id": "ja228:2.2",
      "pali": "Amanussapaviṭṭhassa karonti paṇḍitā;"
    },
    {
      "id": "ja228:2.3",
      "pali": "Na kāmanītassa karoti koci,"
    },
    {
      "id": "ja228:2.4",
      "pali": "Okkantasukkassa hi kā tikicchā”ti."
    },
    {
      "id": "ja228:3.1",
      "pali": "Kāmanītajātakaṁ aṭṭhamaṁ."
    }
  ]
}
