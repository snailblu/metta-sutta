{
  "uid": "thig2.7",
  "title": "Mittātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.7:1.1",
      "pali": "“Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "thig2.7:1.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "thig2.7:1.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "thig2.7:1.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "thig2.7:2.1",
      "pali": "Uposathaṁ upāgacchiṁ,"
    },
    {
      "id": "thig2.7:2.2",
      "pali": "devakāyābhinandinī;"
    },
    {
      "id": "thig2.7:2.3",
      "pali": "Sājja ekena bhattena,"
    },
    {
      "id": "thig2.7:2.4",
      "pali": "muṇḍā saṅghāṭipārutā;"
    },
    {
      "id": "thig2.7:2.5",
      "pali": "Devakāyaṁ na patthehaṁ,"
    },
    {
      "id": "thig2.7:2.6",
      "pali": "vineyya hadaye daran”ti."
    },
    {
      "id": "thig2.7:3.1",
      "pali": "… Mittā therī …."
    }
  ]
}
