{
  "uid": "tha-ap390",
  "title": "Panasaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap390:1.1",
      "pali": "“Ajjuno nāma sambuddho,"
    },
    {
      "id": "tha-ap390:1.2",
      "pali": "himavante vasī tadā;"
    },
    {
      "id": "tha-ap390:1.3",
      "pali": "Caraṇena ca sampanno,"
    },
    {
      "id": "tha-ap390:1.4",
      "pali": "samādhikusalo muni."
    },
    {
      "id": "tha-ap390:2.1",
      "pali": "Kumbhamattaṁ gahetvāna,"
    },
    {
      "id": "tha-ap390:2.2",
      "pali": "panasaṁ jīvajīvakaṁ;"
    },
    {
      "id": "tha-ap390:2.3",
      "pali": "Chattapaṇṇe ṭhapetvāna,"
    },
    {
      "id": "tha-ap390:2.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap390:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap390:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap390:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap390:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap390:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap390:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap390:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap390:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap390:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap390:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap390:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap390:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap390:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap390:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā panasaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap390:8.1",
      "pali": "Panasaphaladāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
