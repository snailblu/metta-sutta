{
  "uid": "tha-ap437",
  "title": "Ucchukhaṇḍikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap437:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap437:1.2",
      "pali": "dvārapālo ahosahaṁ;"
    },
    {
      "id": "tha-ap437:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap437:1.4",
      "pali": "sabbadhammāna pāraguṁ."
    },
    {
      "id": "tha-ap437:2.1",
      "pali": "Ucchukhaṇḍikamādāya,"
    },
    {
      "id": "tha-ap437:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap437:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap437:2.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap437:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap437:3.2",
      "pali": "yaṁ ucchumadadiṁ tadā;"
    },
    {
      "id": "tha-ap437:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap437:3.4",
      "pali": "ucchukhaṇḍassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap437:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap437:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap437:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap437:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap437:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap437:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap437:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap437:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap437:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap437:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ucchukhaṇḍiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap437:8.1",
      "pali": "Ucchukhaṇḍikattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
