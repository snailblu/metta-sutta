{
  "uid": "tha-ap215",
  "title": "Saccasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap215:1.1",
      "pali": "“Vessabhū tamhi samaye,"
    },
    {
      "id": "tha-ap215:1.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap215:1.3",
      "pali": "Deseti ariyasaccāni,"
    },
    {
      "id": "tha-ap215:1.4",
      "pali": "nibbāpento mahājanaṁ."
    },
    {
      "id": "tha-ap215:2.1",
      "pali": "Paramakāruññapattomhi,"
    },
    {
      "id": "tha-ap215:2.2",
      "pali": "samitiṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap215:2.3",
      "pali": "Sohaṁ nisinnako santo,"
    },
    {
      "id": "tha-ap215:2.4",
      "pali": "dhammamassosi satthuno."
    },
    {
      "id": "tha-ap215:3.1",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "tha-ap215:3.2",
      "pali": "devalokaṁ agacchahaṁ;"
    },
    {
      "id": "tha-ap215:3.3",
      "pali": "Tiṁsakappāni devesu,"
    },
    {
      "id": "tha-ap215:3.4",
      "pali": "avasiṁ tatthahaṁ pure."
    },
    {
      "id": "tha-ap215:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap215:4.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap215:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap215:4.4",
      "pali": "saccasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap215:5.1",
      "pali": "Chabbīsamhi ito kappe,"
    },
    {
      "id": "tha-ap215:5.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap215:5.3",
      "pali": "Ekaphusitanāmena,"
    },
    {
      "id": "tha-ap215:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap215:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap215:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap215:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap215:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā saccasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap215:8.1",
      "pali": "Saccasaññakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
