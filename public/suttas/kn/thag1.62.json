{
  "uid": "thag1.62",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.62:1.1",
      "pali": "“Ekakā mayaṁ araññe viharāma,"
    },
    {
      "id": "thag1.62:1.2",
      "pali": "Apaviddhaṁva vanasmiṁ dārukaṁ;"
    },
    {
      "id": "thag1.62:1.3",
      "pali": "Tassa me bahukā pihayanti,"
    },
    {
      "id": "thag1.62:1.4",
      "pali": "Nerayikā viya saggagāminan”ti."
    },
    {
      "id": "thag1.62:1.5",
      "pali": "… Vajjiputto thero …."
    }
  ]
}
