{
  "uid": "ja309",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja309:1.1",
      "pali": "“Sabbamidaṁ carimaṁ kataṁ,"
    },
    {
      "id": "ja309:1.2",
      "pali": "Ubho dhammaṁ na passare;"
    },
    {
      "id": "ja309:1.3",
      "pali": "Ubho pakatiyā cutā,"
    },
    {
      "id": "ja309:1.4",
      "pali": "Yo cāyaṁ mantejjhāpeti;"
    },
    {
      "id": "ja309:1.5",
      "pali": "Yo ca mantaṁ adhīyati”."
    },
    {
      "id": "ja309:2.1",
      "pali": "“Sālīnaṁ odanaṁ bhuñje,"
    },
    {
      "id": "ja309:2.2",
      "pali": "suciṁ maṁsūpasecanaṁ;"
    },
    {
      "id": "ja309:2.3",
      "pali": "Tasmā etaṁ na sevāmi,"
    },
    {
      "id": "ja309:2.4",
      "pali": "dhammaṁ isīhi sevitaṁ”."
    },
    {
      "id": "ja309:3.1",
      "pali": "“Paribbaja mahā loko,"
    },
    {
      "id": "ja309:3.2",
      "pali": "pacantaññepi pāṇino;"
    },
    {
      "id": "ja309:3.3",
      "pali": "Mā taṁ adhammo ācarito,"
    },
    {
      "id": "ja309:3.4",
      "pali": "asmā kumbhamivābhidā."
    },
    {
      "id": "ja309:4.1",
      "pali": "Dhiratthu taṁ yasalābhaṁ,"
    },
    {
      "id": "ja309:4.2",
      "pali": "dhanalābhañca brāhmaṇa;"
    },
    {
      "id": "ja309:4.3",
      "pali": "Yā vutti vinipātena,"
    },
    {
      "id": "ja309:4.4",
      "pali": "adhammacaraṇena vā”ti."
    },
    {
      "id": "ja309:5.1",
      "pali": "Chavakajātakaṁ navamaṁ."
    }
  ]
}
