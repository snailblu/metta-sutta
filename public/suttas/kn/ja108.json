{
  "uid": "ja108",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja108:1.1",
      "pali": "“Sikkheyya sikkhitabbāni,"
    },
    {
      "id": "ja108:1.2",
      "pali": "santi sacchandino janā;"
    },
    {
      "id": "ja108:1.3",
      "pali": "Bāhiyā hi suhannena,"
    },
    {
      "id": "ja108:1.4",
      "pali": "rājānamabhirādhayī”ti."
    },
    {
      "id": "ja108:2.1",
      "pali": "Bāhiyajātakaṁ aṭṭhamaṁ."
    }
  ]
}
