{
  "uid": "cp7",
  "title": "Dānapāramī 7",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp7:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp7:1.2",
      "pali": "ekarājassa atrajo;"
    },
    {
      "id": "cp7:1.3",
      "pali": "Nagare pupphavatiyā,"
    },
    {
      "id": "cp7:1.4",
      "pali": "kumāro candasavhayo."
    },
    {
      "id": "cp7:2.1",
      "pali": "Tadāhaṁ yajanā mutto,"
    },
    {
      "id": "cp7:2.2",
      "pali": "nikkhanto yaññavāṭato;"
    },
    {
      "id": "cp7:2.3",
      "pali": "Saṁvegaṁ janayitvāna,"
    },
    {
      "id": "cp7:2.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "cp7:3.1",
      "pali": "Nāhaṁ pivāmi khādāmi,"
    },
    {
      "id": "cp7:3.2",
      "pali": "napi bhuñjāmi bhojanaṁ;"
    },
    {
      "id": "cp7:3.3",
      "pali": "Dakkhiṇeyye adatvāna,"
    },
    {
      "id": "cp7:3.4",
      "pali": "api chappañcarattiyo."
    },
    {
      "id": "cp7:4.1",
      "pali": "Yathāpi vāṇijo nāma,"
    },
    {
      "id": "cp7:4.2",
      "pali": "Katvāna bhaṇḍasañcayaṁ;"
    },
    {
      "id": "cp7:4.3",
      "pali": "Yattha lābho mahā hoti,"
    },
    {
      "id": "cp7:4.4",
      "pali": "Tattha taṁ harati bhaṇḍakaṁ."
    },
    {
      "id": "cp7:5.1",
      "pali": "Tatheva sakabhuttāpi,"
    },
    {
      "id": "cp7:5.2",
      "pali": "pare dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "cp7:5.3",
      "pali": "Tasmā parassa dātabbaṁ,"
    },
    {
      "id": "cp7:5.4",
      "pali": "satabhāgo bhavissati."
    },
    {
      "id": "cp7:6.1",
      "pali": "Etamatthavasaṁ ñatvā,"
    },
    {
      "id": "cp7:6.2",
      "pali": "demi dānaṁ bhavābhave;"
    },
    {
      "id": "cp7:6.3",
      "pali": "Na paṭikkamāmi dānato,"
    },
    {
      "id": "cp7:6.4",
      "pali": "sambodhimanupattiyā”ti."
    },
    {
      "id": "cp7:7.1",
      "pali": "Candakumāracariyaṁ sattamaṁ."
    }
  ]
}
