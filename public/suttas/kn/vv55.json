{
  "uid": "vv55",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv55:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv55:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv55:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv55:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv55:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv55:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv55:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv55:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv55:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv55:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv55:3.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv55:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv55:4.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv55:4.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv55:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv55:5.1",
      "pali": "“Dibbaṁ mamaṁ vassasahassamāyu,"
    },
    {
      "id": "vv55:5.2",
      "pali": "Vācābhigītaṁ manasā pavattitaṁ;"
    },
    {
      "id": "vv55:5.3",
      "pali": "Ettāvatā ṭhassati puññakammo,"
    },
    {
      "id": "vv55:5.4",
      "pali": "Dibbehi kāmehi samaṅgibhūto."
    },
    {
      "id": "vv55:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv55:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv55:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv55:7.1",
      "pali": "Dvārapālavimānaṁ pañcamaṁ."
    }
  ]
}
