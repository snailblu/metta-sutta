{
  "uid": "tha-ap28",
  "title": "Dhūpadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap28:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap28:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap28:1.3",
      "pali": "Kuṭidhūpaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap28:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap28:2.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap28:2.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap28:2.3",
      "pali": "Sabbesampi piyo homi,"
    },
    {
      "id": "tha-ap28:2.4",
      "pali": "dhūpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap28:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap28:3.2",
      "pali": "yaṁ dhūpamadadiṁ tadā;"
    },
    {
      "id": "tha-ap28:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap28:3.4",
      "pali": "dhūpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap28:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap28:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap28:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap28:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap28:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhūpadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap28:6.1",
      "pali": "Dhūpadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
