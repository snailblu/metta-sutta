{
  "uid": "tha-ap73",
  "title": "Nāgasamālattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap73:1.1",
      "pali": "“Āpāṭaliṁ ahaṁ pupphaṁ,"
    },
    {
      "id": "tha-ap73:1.2",
      "pali": "ujjhitaṁ sumahāpathe;"
    },
    {
      "id": "tha-ap73:1.3",
      "pali": "Thūpamhi abhiropesiṁ,"
    },
    {
      "id": "tha-ap73:1.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap73:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap73:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap73:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap73:2.4",
      "pali": "thūpapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap73:3.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap73:3.2",
      "pali": "bhūmiyo nāma khattiyo;"
    },
    {
      "id": "tha-ap73:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap73:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap73:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap73:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap73:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap73:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap73:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāgasamālo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap73:6.1",
      "pali": "Nāgasamālattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
