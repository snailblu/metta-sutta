{
  "uid": "ja380",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja380:1.1",
      "pali": "“Āsāvatī nāma latā,"
    },
    {
      "id": "ja380:1.2",
      "pali": "jātā cittalatāvane;"
    },
    {
      "id": "ja380:1.3",
      "pali": "Tassā vassasahassena,"
    },
    {
      "id": "ja380:1.4",
      "pali": "ekaṁ nibbattate phalaṁ."
    },
    {
      "id": "ja380:2.1",
      "pali": "Taṁ devā payirupāsanti,"
    },
    {
      "id": "ja380:2.2",
      "pali": "tāva dūraphalaṁ satiṁ;"
    },
    {
      "id": "ja380:2.3",
      "pali": "Āsīseva tuvaṁ rāja,"
    },
    {
      "id": "ja380:2.4",
      "pali": "āsā phalavatī sukhā."
    },
    {
      "id": "ja380:3.1",
      "pali": "Āsīsateva so pakkhī,"
    },
    {
      "id": "ja380:3.2",
      "pali": "āsīsateva so dijo;"
    },
    {
      "id": "ja380:3.3",
      "pali": "Tassa cāsā samijjhati,"
    },
    {
      "id": "ja380:3.4",
      "pali": "tāva dūragatā satī;"
    },
    {
      "id": "ja380:3.5",
      "pali": "Āsīseva tuvaṁ rāja,"
    },
    {
      "id": "ja380:3.6",
      "pali": "āsā phalavatī sukhā”."
    },
    {
      "id": "ja380:4.1",
      "pali": "“Sampesi kho maṁ vācāya,"
    },
    {
      "id": "ja380:4.2",
      "pali": "na ca sampesi kammunā;"
    },
    {
      "id": "ja380:4.3",
      "pali": "Mālā sereyyakasseva,"
    },
    {
      "id": "ja380:4.4",
      "pali": "vaṇṇavantā agandhikā."
    },
    {
      "id": "ja380:5.1",
      "pali": "Aphalaṁ madhuraṁ vācaṁ,"
    },
    {
      "id": "ja380:5.2",
      "pali": "yo mittesu pakubbati;"
    },
    {
      "id": "ja380:5.3",
      "pali": "Adadaṁ avissajaṁ bhogaṁ,"
    },
    {
      "id": "ja380:5.4",
      "pali": "sandhi tenassa jīrati."
    },
    {
      "id": "ja380:6.1",
      "pali": "Yañhi kayirā tañhi vade,"
    },
    {
      "id": "ja380:6.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "ja380:6.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "ja380:6.4",
      "pali": "parijānanti paṇḍitā."
    },
    {
      "id": "ja380:7.1",
      "pali": "Balañca vata me khīṇaṁ,"
    },
    {
      "id": "ja380:7.2",
      "pali": "pātheyyañca na vijjati;"
    },
    {
      "id": "ja380:7.3",
      "pali": "Saṅke pāṇūparodhāya,"
    },
    {
      "id": "ja380:7.4",
      "pali": "handa dāni vajāmahaṁ”."
    },
    {
      "id": "ja380:8.1",
      "pali": "“Etadeva hi me nāmaṁ,"
    },
    {
      "id": "ja380:8.2",
      "pali": "Yaṁ nāmasmi rathesabha;"
    },
    {
      "id": "ja380:8.3",
      "pali": "Āgamehi mahārāja,"
    },
    {
      "id": "ja380:8.4",
      "pali": "Pitaraṁ āmantayāmahan”ti."
    },
    {
      "id": "ja380:9.1",
      "pali": "Āsaṅkajātakaṁ pañcamaṁ."
    }
  ]
}
