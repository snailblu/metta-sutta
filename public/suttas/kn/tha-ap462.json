{
  "uid": "tha-ap462",
  "title": "Gandhapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap462:1.1",
      "pali": "“Citāsu kurumānāsu,"
    },
    {
      "id": "tha-ap462:1.2",
      "pali": "nānāgandhe samāhaṭe;"
    },
    {
      "id": "tha-ap462:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap462:1.4",
      "pali": "gandhamuṭṭhimapūjayiṁ."
    },
    {
      "id": "tha-ap462:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap462:2.2",
      "pali": "citakaṁ yamapūjayiṁ;"
    },
    {
      "id": "tha-ap462:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap462:2.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap462:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap462:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap462:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap462:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap462:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap462:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap462:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap462:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap462:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap462:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap462:7.1",
      "pali": "Gandhapūjakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap462:8.1",
      "pali": "Jagatidāyakavaggo chacattālīsamo."
    },
    {
      "id": "tha-ap462:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap462:10.1",
      "pali": "Jagatī morahatthī ca,"
    },
    {
      "id": "tha-ap462:10.2",
      "pali": "āsanī ukkadhārako;"
    },
    {
      "id": "tha-ap462:10.3",
      "pali": "Akkami vanakoraṇḍi,"
    },
    {
      "id": "tha-ap462:10.4",
      "pali": "chattado jātipūjako."
    },
    {
      "id": "tha-ap462:11.1",
      "pali": "Paṭṭipupphī ca yo thero,"
    },
    {
      "id": "tha-ap462:11.2",
      "pali": "dasamo gandhapūjako;"
    },
    {
      "id": "tha-ap462:11.3",
      "pali": "Sattasaṭṭhi ca gāthāyo,"
    },
    {
      "id": "tha-ap462:11.4",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
