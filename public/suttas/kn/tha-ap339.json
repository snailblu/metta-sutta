{
  "uid": "tha-ap339",
  "title": "Tiṇakuṭidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap339:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap339:1.2",
      "pali": "ahosiṁ parakammiko;"
    },
    {
      "id": "tha-ap339:1.3",
      "pali": "Parakammāyane yutto,"
    },
    {
      "id": "tha-ap339:1.4",
      "pali": "parabhattaṁ apassito."
    },
    {
      "id": "tha-ap339:2.1",
      "pali": "Rahogato nisīditvā,"
    },
    {
      "id": "tha-ap339:2.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "tha-ap339:2.3",
      "pali": "Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap339:2.4",
      "pali": "adhikāro ca natthi me."
    },
    {
      "id": "tha-ap339:3.1",
      "pali": "Kālo me gatiṁ sodhetuṁ,"
    },
    {
      "id": "tha-ap339:3.2",
      "pali": "khaṇo me paṭipādito;"
    },
    {
      "id": "tha-ap339:3.3",
      "pali": "Dukkho nirayasamphasso,"
    },
    {
      "id": "tha-ap339:3.4",
      "pali": "apuññānañhi pāṇinaṁ."
    },
    {
      "id": "tha-ap339:4.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "tha-ap339:4.2",
      "pali": "kammasāmiṁ upāgamiṁ;"
    },
    {
      "id": "tha-ap339:4.3",
      "pali": "Ekāhaṁ kammaṁ yācitvā,"
    },
    {
      "id": "tha-ap339:4.4",
      "pali": "vipinaṁ pāvisiṁ ahaṁ."
    },
    {
      "id": "tha-ap339:5.1",
      "pali": "Tiṇakaṭṭhañca valliñca,"
    },
    {
      "id": "tha-ap339:5.2",
      "pali": "āharitvānahaṁ tadā;"
    },
    {
      "id": "tha-ap339:5.3",
      "pali": "Tidaṇḍake ṭhapetvāna,"
    },
    {
      "id": "tha-ap339:5.4",
      "pali": "akaṁ tiṇakuṭiṁ ahaṁ."
    },
    {
      "id": "tha-ap339:6.1",
      "pali": "Saṅghassatthāya kuṭikaṁ,"
    },
    {
      "id": "tha-ap339:6.2",
      "pali": "niyyādetvāna taṁ ahaṁ;"
    },
    {
      "id": "tha-ap339:6.3",
      "pali": "Tadaheyeva āgantvā,"
    },
    {
      "id": "tha-ap339:6.4",
      "pali": "kammasāmiṁ upāgamiṁ."
    },
    {
      "id": "tha-ap339:7.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap339:7.2",
      "pali": "tāvatiṁsamagacchahaṁ;"
    },
    {
      "id": "tha-ap339:7.3",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap339:7.4",
      "pali": "kuṭikāya sunimmitaṁ."
    },
    {
      "id": "tha-ap339:8.1",
      "pali": "Sahassakaṇḍaṁ satabheṇḍu,"
    },
    {
      "id": "tha-ap339:8.2",
      "pali": "dhajālu haritāmayaṁ;"
    },
    {
      "id": "tha-ap339:8.3",
      "pali": "Satasahassaniyyūhā,"
    },
    {
      "id": "tha-ap339:8.4",
      "pali": "byamhe pātubhaviṁsu me."
    },
    {
      "id": "tha-ap339:9.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap339:9.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap339:9.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap339:9.4",
      "pali": "pāsādo upatiṭṭhati."
    },
    {
      "id": "tha-ap339:10.1",
      "pali": "Bhayaṁ vā chambhitattaṁ vā,"
    },
    {
      "id": "tha-ap339:10.2",
      "pali": "lomahaṁso na vijjati;"
    },
    {
      "id": "tha-ap339:10.3",
      "pali": "Tāsaṁ mama na jānāmi,"
    },
    {
      "id": "tha-ap339:10.4",
      "pali": "tiṇakuṭikāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap339:11.1",
      "pali": "Sīhabyagghā ca dīpī ca,"
    },
    {
      "id": "tha-ap339:11.2",
      "pali": "acchakokataracchakā;"
    },
    {
      "id": "tha-ap339:11.3",
      "pali": "Sabbe maṁ parivajjenti,"
    },
    {
      "id": "tha-ap339:11.4",
      "pali": "tiṇakuṭikāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap339:12.1",
      "pali": "Sarīsapā ca bhūtā ca,"
    },
    {
      "id": "tha-ap339:12.2",
      "pali": "ahī kumbhaṇḍarakkhasā;"
    },
    {
      "id": "tha-ap339:12.3",
      "pali": "Tepi maṁ parivajjenti,"
    },
    {
      "id": "tha-ap339:12.4",
      "pali": "tiṇakuṭikāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap339:13.1",
      "pali": "Na pāpasupinassāpi,"
    },
    {
      "id": "tha-ap339:13.2",
      "pali": "sarāmi dassanaṁ mama;"
    },
    {
      "id": "tha-ap339:13.3",
      "pali": "Upaṭṭhitā sati mayhaṁ,"
    },
    {
      "id": "tha-ap339:13.4",
      "pali": "tiṇakuṭikāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap339:14.1",
      "pali": "Tāyeva tiṇakuṭikāya,"
    },
    {
      "id": "tha-ap339:14.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap339:14.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap339:14.4",
      "pali": "dhammaṁ sacchikariṁ ahaṁ."
    },
    {
      "id": "tha-ap339:15.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap339:15.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap339:15.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap339:15.4",
      "pali": "tiṇakuṭikāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap339:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap339:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap339:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap339:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇakuṭidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap339:18.1",
      "pali": "Tiṇakuṭidāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
