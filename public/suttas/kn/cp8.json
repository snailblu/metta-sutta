{
  "uid": "cp8",
  "title": "Dānapāramī 8",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp8:1.1",
      "pali": "“Ariṭṭhasavhaye nagare,"
    },
    {
      "id": "cp8:1.2",
      "pali": "sivināmāsi khattiyo;"
    },
    {
      "id": "cp8:1.3",
      "pali": "Nisajja pāsādavare,"
    },
    {
      "id": "cp8:1.4",
      "pali": "evaṁ cintesahaṁ tadā."
    },
    {
      "id": "cp8:2.1",
      "pali": "‘Yaṁ kiñci mānusaṁ dānaṁ,"
    },
    {
      "id": "cp8:2.2",
      "pali": "adinnaṁ me na vijjati;"
    },
    {
      "id": "cp8:2.3",
      "pali": "Yopi yāceyya maṁ cakkhuṁ,"
    },
    {
      "id": "cp8:2.4",
      "pali": "dadeyyaṁ avikampito’."
    },
    {
      "id": "cp8:3.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "cp8:3.2",
      "pali": "sakko devānamissaro;"
    },
    {
      "id": "cp8:3.3",
      "pali": "Nisinno devaparisāya,"
    },
    {
      "id": "cp8:3.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "cp8:4.1",
      "pali": "‘Nisajja pāsādavare,"
    },
    {
      "id": "cp8:4.2",
      "pali": "sivirājā mahiddhiko;"
    },
    {
      "id": "cp8:4.3",
      "pali": "Cintento vividhaṁ dānaṁ,"
    },
    {
      "id": "cp8:4.4",
      "pali": "adeyyaṁ so na passati."
    },
    {
      "id": "cp8:5.1",
      "pali": "Tathaṁ nu vitathaṁ netaṁ,"
    },
    {
      "id": "cp8:5.2",
      "pali": "handa vīmaṁsayāmi taṁ;"
    },
    {
      "id": "cp8:5.3",
      "pali": "Muhuttaṁ āgameyyātha,"
    },
    {
      "id": "cp8:5.4",
      "pali": "yāva jānāmi taṁ manaṁ’."
    },
    {
      "id": "cp8:6.1",
      "pali": "Pavedhamāno palitasiro,"
    },
    {
      "id": "cp8:6.2",
      "pali": "Valigatto jarāturo;"
    },
    {
      "id": "cp8:6.3",
      "pali": "Andhavaṇṇova hutvāna,"
    },
    {
      "id": "cp8:6.4",
      "pali": "Rājānaṁ upasaṅkami."
    },
    {
      "id": "cp8:7.1",
      "pali": "So tadā paggahetvāna,"
    },
    {
      "id": "cp8:7.2",
      "pali": "vāmaṁ dakkhiṇabāhu ca;"
    },
    {
      "id": "cp8:7.3",
      "pali": "Sirasmiṁ añjaliṁ katvā,"
    },
    {
      "id": "cp8:7.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "cp8:8.1",
      "pali": "‘Yācāmi taṁ mahārāja,"
    },
    {
      "id": "cp8:8.2",
      "pali": "dhammika raṭṭhavaḍḍhana;"
    },
    {
      "id": "cp8:8.3",
      "pali": "Tava dānaratā kitti,"
    },
    {
      "id": "cp8:8.4",
      "pali": "uggatā devamānuse."
    },
    {
      "id": "cp8:9.1",
      "pali": "Ubhopi nettā nayanā,"
    },
    {
      "id": "cp8:9.2",
      "pali": "andhā upahatā mama;"
    },
    {
      "id": "cp8:9.3",
      "pali": "Ekaṁ me nayanaṁ dehi,"
    },
    {
      "id": "cp8:9.4",
      "pali": "tvampi ekena yāpaya’."
    },
    {
      "id": "cp8:10.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp8:10.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "cp8:10.3",
      "pali": "Katañjalī vedajāto,"
    },
    {
      "id": "cp8:10.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "cp8:11.1",
      "pali": "‘Idānāhaṁ cintayitvāna,"
    },
    {
      "id": "cp8:11.2",
      "pali": "pāsādato idhāgato;"
    },
    {
      "id": "cp8:11.3",
      "pali": "Tvaṁ mama cittamaññāya,"
    },
    {
      "id": "cp8:11.4",
      "pali": "nettaṁ yācitumāgato."
    },
    {
      "id": "cp8:12.1",
      "pali": "Aho me mānasaṁ siddhaṁ,"
    },
    {
      "id": "cp8:12.2",
      "pali": "saṅkappo paripūrito;"
    },
    {
      "id": "cp8:12.3",
      "pali": "Adinnapubbaṁ dānavaraṁ,"
    },
    {
      "id": "cp8:12.4",
      "pali": "ajja dassāmi yācake."
    },
    {
      "id": "cp8:13.1",
      "pali": "Ehi sivaka uṭṭhehi,"
    },
    {
      "id": "cp8:13.2",
      "pali": "mā dandhayi mā pavedhayi;"
    },
    {
      "id": "cp8:13.3",
      "pali": "Ubhopi nayanaṁ dehi,"
    },
    {
      "id": "cp8:13.4",
      "pali": "uppāṭetvā vaṇibbake’."
    },
    {
      "id": "cp8:14.1",
      "pali": "Tato so codito mayhaṁ,"
    },
    {
      "id": "cp8:14.2",
      "pali": "sivako vacanaṁ karo;"
    },
    {
      "id": "cp8:14.3",
      "pali": "Uddharitvāna pādāsi,"
    },
    {
      "id": "cp8:14.4",
      "pali": "tālamiñjaṁva yācake."
    },
    {
      "id": "cp8:15.1",
      "pali": "Dadamānassa dentassa,"
    },
    {
      "id": "cp8:15.2",
      "pali": "dinnadānassa me sato;"
    },
    {
      "id": "cp8:15.3",
      "pali": "Cittassa aññathā natthi,"
    },
    {
      "id": "cp8:15.4",
      "pali": "bodhiyāyeva kāraṇā."
    },
    {
      "id": "cp8:16.1",
      "pali": "Na me dessā ubho cakkhū,"
    },
    {
      "id": "cp8:16.2",
      "pali": "attā na me na dessiyo;"
    },
    {
      "id": "cp8:16.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp8:16.4",
      "pali": "tasmā cakkhuṁ adāsahan”ti."
    },
    {
      "id": "cp8:17.1",
      "pali": "Sivirājacariyaṁ aṭṭhamaṁ."
    }
  ]
}
