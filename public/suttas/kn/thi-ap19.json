{
  "uid": "thi-ap19",
  "title": "Uppalavaṇṇātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap19:1.1",
      "pali": "“Bhikkhunī uppalavaṇṇā,"
    },
    {
      "id": "thi-ap19:1.2",
      "pali": "iddhiyā pāramiṁ gatā;"
    },
    {
      "id": "thi-ap19:1.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "thi-ap19:1.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "thi-ap19:2.1",
      "pali": "‘Nitthiṇṇā jātisaṁsāraṁ,"
    },
    {
      "id": "thi-ap19:2.2",
      "pali": "pattāhaṁ acalaṁ padaṁ;"
    },
    {
      "id": "thi-ap19:2.3",
      "pali": "Sabbadukkhaṁ mayā khīṇaṁ,"
    },
    {
      "id": "thi-ap19:2.4",
      "pali": "ārocemi mahāmuni."
    },
    {
      "id": "thi-ap19:3.1",
      "pali": "Yāvatā parisā atthi,"
    },
    {
      "id": "thi-ap19:3.2",
      "pali": "pasannā jinasāsane;"
    },
    {
      "id": "thi-ap19:3.3",
      "pali": "Yassā ca meparādhotthi,"
    },
    {
      "id": "thi-ap19:3.4",
      "pali": "khamantu jinasammukhā."
    },
    {
      "id": "thi-ap19:4.1",
      "pali": "Saṁsāre saṁsarantiyā,"
    },
    {
      "id": "thi-ap19:4.2",
      "pali": "khalitaṁ me sace bhave;"
    },
    {
      "id": "thi-ap19:4.3",
      "pali": "Ārocemi mahāvīra,"
    },
    {
      "id": "thi-ap19:4.4",
      "pali": "aparādhaṁ khamassu taṁ’."
    },
    {
      "id": "thi-ap19:5.1",
      "pali": "‘Iddhiñcāpi nidassehi,"
    },
    {
      "id": "thi-ap19:5.2",
      "pali": "mama sāsanakārike;"
    },
    {
      "id": "thi-ap19:5.3",
      "pali": "Catasso parisā ajja,"
    },
    {
      "id": "thi-ap19:5.4",
      "pali": "kaṅkhaṁ chindāhi yāvatā’."
    },
    {
      "id": "thi-ap19:6.1",
      "pali": "‘Dhītā tuyhaṁ mahāvīra,"
    },
    {
      "id": "thi-ap19:6.2",
      "pali": "paññavanta jutindhara;"
    },
    {
      "id": "thi-ap19:6.3",
      "pali": "Bahuñca dukkaraṁ kammaṁ,"
    },
    {
      "id": "thi-ap19:6.4",
      "pali": "kataṁ me atidukkaraṁ."
    },
    {
      "id": "thi-ap19:7.1",
      "pali": "Uppalasseva me vaṇṇo,"
    },
    {
      "id": "thi-ap19:7.2",
      "pali": "nāmenuppalanāmikā;"
    },
    {
      "id": "thi-ap19:7.3",
      "pali": "Sāvikā te mahāvīra,"
    },
    {
      "id": "thi-ap19:7.4",
      "pali": "pāde vandāmi cakkhuma."
    },
    {
      "id": "thi-ap19:8.1",
      "pali": "Rāhulo ca ahañceva,"
    },
    {
      "id": "thi-ap19:8.2",
      "pali": "nekajātisate bahū;"
    },
    {
      "id": "thi-ap19:8.3",
      "pali": "Ekasmiṁ sambhave jātā,"
    },
    {
      "id": "thi-ap19:8.4",
      "pali": "samānachandamānasā."
    },
    {
      "id": "thi-ap19:9.1",
      "pali": "Nibbatti ekato hoti,"
    },
    {
      "id": "thi-ap19:9.2",
      "pali": "jātiyāpi ca ekato;"
    },
    {
      "id": "thi-ap19:9.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap19:9.4",
      "pali": "ubhopi nānāsambhavā."
    },
    {
      "id": "thi-ap19:10.1",
      "pali": "Putto ca rāhulo nāma,"
    },
    {
      "id": "thi-ap19:10.2",
      "pali": "dhītā uppalasavhayā;"
    },
    {
      "id": "thi-ap19:10.3",
      "pali": "Passa vīra mamaṁ iddhiṁ,"
    },
    {
      "id": "thi-ap19:10.4",
      "pali": "balaṁ dassemi satthuno’."
    },
    {
      "id": "thi-ap19:11.1",
      "pali": "Mahāsamudde caturo,"
    },
    {
      "id": "thi-ap19:11.2",
      "pali": "pakkhipi hatthapātiyaṁ;"
    },
    {
      "id": "thi-ap19:11.3",
      "pali": "Telaṁ hatthagatañceva,"
    },
    {
      "id": "thi-ap19:11.4",
      "pali": "khiḍḍo komārako yathā."
    },
    {
      "id": "thi-ap19:12.1",
      "pali": "Ubbattayitvā pathaviṁ,"
    },
    {
      "id": "thi-ap19:12.2",
      "pali": "pakkhipi hatthapātiyaṁ;"
    },
    {
      "id": "thi-ap19:12.3",
      "pali": "Cittaṁ muñjaṁ yathā nāma,"
    },
    {
      "id": "thi-ap19:12.4",
      "pali": "luñci komārako yuvā."
    },
    {
      "id": "thi-ap19:13.1",
      "pali": "Cakkavāḷasamaṁ pāṇiṁ,"
    },
    {
      "id": "thi-ap19:13.2",
      "pali": "chādayitvāna matthake;"
    },
    {
      "id": "thi-ap19:13.3",
      "pali": "Vassāpetvāna phusitaṁ,"
    },
    {
      "id": "thi-ap19:13.4",
      "pali": "nānāvaṇṇaṁ punappunaṁ."
    },
    {
      "id": "thi-ap19:14.1",
      "pali": "Bhūmiṁ udukkhalaṁ katvā,"
    },
    {
      "id": "thi-ap19:14.2",
      "pali": "dhaññaṁ katvāna sakkharaṁ;"
    },
    {
      "id": "thi-ap19:14.3",
      "pali": "Sineruṁ musalaṁ katvā,"
    },
    {
      "id": "thi-ap19:14.4",
      "pali": "maddi komārikā yathā."
    },
    {
      "id": "thi-ap19:15.1",
      "pali": "‘Dhītāhaṁ buddhaseṭṭhassa,"
    },
    {
      "id": "thi-ap19:15.2",
      "pali": "nāmenuppalasavhayā;"
    },
    {
      "id": "thi-ap19:15.3",
      "pali": "Abhiññāsu vasībhūtā,"
    },
    {
      "id": "thi-ap19:15.4",
      "pali": "tava sāsanakārikā."
    },
    {
      "id": "thi-ap19:16.1",
      "pali": "Nānāvikubbanaṁ katvā,"
    },
    {
      "id": "thi-ap19:16.2",
      "pali": "dassetvā lokanāyakaṁ;"
    },
    {
      "id": "thi-ap19:16.3",
      "pali": "Nāmagottañca sāvetvā,"
    },
    {
      "id": "thi-ap19:16.4",
      "pali": "pāde vandāmi cakkhuma."
    },
    {
      "id": "thi-ap19:17.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap19:17.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap19:17.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap19:17.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap19:18.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap19:18.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap19:18.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap19:18.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap19:19.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap19:19.2",
      "pali": "Paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap19:19.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap19:19.4",
      "pali": "Sabhāvena mahesino."
    },
    {
      "id": "thi-ap19:20.1",
      "pali": "Purimānaṁ jinaggānaṁ,"
    },
    {
      "id": "thi-ap19:20.2",
      "pali": "saṅgamaṁ te nidassitaṁ;"
    },
    {
      "id": "thi-ap19:20.3",
      "pali": "Adhikāraṁ bahuṁ mayhaṁ,"
    },
    {
      "id": "thi-ap19:20.4",
      "pali": "tuyhatthāya mahāmuni."
    },
    {
      "id": "thi-ap19:21.1",
      "pali": "Yaṁ mayā pūritaṁ kammaṁ,"
    },
    {
      "id": "thi-ap19:21.2",
      "pali": "Kusalaṁ sara me muni;"
    },
    {
      "id": "thi-ap19:21.3",
      "pali": "Tavatthāya mahāvīra,"
    },
    {
      "id": "thi-ap19:21.4",
      "pali": "Puññaṁ upacitaṁ mayā."
    },
    {
      "id": "thi-ap19:22.1",
      "pali": "Abhabbaṭṭhāne vajjetvā,"
    },
    {
      "id": "thi-ap19:22.2",
      "pali": "vārayantī anācaraṁ;"
    },
    {
      "id": "thi-ap19:22.3",
      "pali": "Tavatthāya mahāvīra,"
    },
    {
      "id": "thi-ap19:22.4",
      "pali": "cattaṁ me jīvituttamaṁ."
    },
    {
      "id": "thi-ap19:23.1",
      "pali": "Dasakoṭisahassāni,"
    },
    {
      "id": "thi-ap19:23.2",
      "pali": "adāsiṁ mama jīvitaṁ;"
    },
    {
      "id": "thi-ap19:23.3",
      "pali": "Pariccattā ca me homi,"
    },
    {
      "id": "thi-ap19:23.4",
      "pali": "tavatthāya mahāmuni’."
    },
    {
      "id": "thi-ap19:24.1",
      "pali": "Tadātivimhitā sabbā,"
    },
    {
      "id": "thi-ap19:24.2",
      "pali": "sirasāva katañjalī;"
    },
    {
      "id": "thi-ap19:24.3",
      "pali": "‘Avocayye kathaṁ āsi,"
    },
    {
      "id": "thi-ap19:24.4",
      "pali": "atuliddhiparakkamā’."
    },
    {
      "id": "thi-ap19:25.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap19:25.2",
      "pali": "nāgakaññā ahaṁ tadā;"
    },
    {
      "id": "thi-ap19:25.3",
      "pali": "Vimalā nāma nāmena,"
    },
    {
      "id": "thi-ap19:25.4",
      "pali": "kaññānaṁ sādhusammatā."
    },
    {
      "id": "thi-ap19:26.1",
      "pali": "Mahorago mahānāgo,"
    },
    {
      "id": "thi-ap19:26.2",
      "pali": "pasanno jinasāsane;"
    },
    {
      "id": "thi-ap19:26.3",
      "pali": "Padumuttaraṁ mahātejaṁ,"
    },
    {
      "id": "thi-ap19:26.4",
      "pali": "nimantesi sasāvakaṁ."
    },
    {
      "id": "thi-ap19:27.1",
      "pali": "Ratanamayaṁ maṇḍapaṁ,"
    },
    {
      "id": "thi-ap19:27.2",
      "pali": "pallaṅkaṁ ratanāmayaṁ;"
    },
    {
      "id": "thi-ap19:27.3",
      "pali": "Ratanaṁ vālukākiṇṇaṁ,"
    },
    {
      "id": "thi-ap19:27.4",
      "pali": "upabhogaṁ ratanāmayaṁ."
    },
    {
      "id": "thi-ap19:28.1",
      "pali": "Maggañca paṭiyādesi,"
    },
    {
      "id": "thi-ap19:28.2",
      "pali": "ratanaddhajabhūsitaṁ;"
    },
    {
      "id": "thi-ap19:28.3",
      "pali": "Paccuggantvāna sambuddhaṁ,"
    },
    {
      "id": "thi-ap19:28.4",
      "pali": "vajjanto tūriyehi so."
    },
    {
      "id": "thi-ap19:29.1",
      "pali": "Parisāhi ca catūhi,"
    },
    {
      "id": "thi-ap19:29.2",
      "pali": "parivuto lokanāyako;"
    },
    {
      "id": "thi-ap19:29.3",
      "pali": "Mahoragassa bhavane,"
    },
    {
      "id": "thi-ap19:29.4",
      "pali": "nisīdi paramāsane."
    },
    {
      "id": "thi-ap19:30.1",
      "pali": "Annaṁ pānaṁ khādanīyaṁ,"
    },
    {
      "id": "thi-ap19:30.2",
      "pali": "bhojanañca mahārahaṁ;"
    },
    {
      "id": "thi-ap19:30.3",
      "pali": "Varaṁ varañca pādāsi,"
    },
    {
      "id": "thi-ap19:30.4",
      "pali": "nāgarājā mahāyasaṁ."
    },
    {
      "id": "thi-ap19:31.1",
      "pali": "Bhuñjitvāna sambuddho,"
    },
    {
      "id": "thi-ap19:31.2",
      "pali": "pattaṁ dhovitvā yoniso;"
    },
    {
      "id": "thi-ap19:31.3",
      "pali": "Anumodanīyaṅkāsi,"
    },
    {
      "id": "thi-ap19:31.4",
      "pali": "nāgakaññā mahiddhikā."
    },
    {
      "id": "thi-ap19:32.1",
      "pali": "Sabbaññuṁ phullitaṁ disvā,"
    },
    {
      "id": "thi-ap19:32.2",
      "pali": "nāgakaññā mahāyasaṁ;"
    },
    {
      "id": "thi-ap19:32.3",
      "pali": "Pasannaṁ satthuno cittaṁ,"
    },
    {
      "id": "thi-ap19:32.4",
      "pali": "sunibandhañca mānasaṁ."
    },
    {
      "id": "thi-ap19:33.1",
      "pali": "Mamañca cittamaññāya,"
    },
    {
      "id": "thi-ap19:33.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "thi-ap19:33.3",
      "pali": "Tasmiṁ khaṇe mahāvīro,"
    },
    {
      "id": "thi-ap19:33.4",
      "pali": "bhikkhuniṁ dassayiddhiyā."
    },
    {
      "id": "thi-ap19:34.1",
      "pali": "Iddhī anekā dassesi,"
    },
    {
      "id": "thi-ap19:34.2",
      "pali": "bhikkhunī sā visāradā;"
    },
    {
      "id": "thi-ap19:34.3",
      "pali": "Pamoditā vedajātā,"
    },
    {
      "id": "thi-ap19:34.4",
      "pali": "satthāraṁ idamabravi."
    },
    {
      "id": "thi-ap19:35.1",
      "pali": "‘Addasāhaṁ imaṁ iddhiṁ,"
    },
    {
      "id": "thi-ap19:35.2",
      "pali": "sumanaṁ itarāyapi;"
    },
    {
      "id": "thi-ap19:35.3",
      "pali": "Kathaṁ ahosi sā vīra,"
    },
    {
      "id": "thi-ap19:35.4",
      "pali": "iddhiyā suvisāradā’."
    },
    {
      "id": "thi-ap19:36.1",
      "pali": "‘Orasā mukhato jātā,"
    },
    {
      "id": "thi-ap19:36.2",
      "pali": "dhītā mama mahiddhikā;"
    },
    {
      "id": "thi-ap19:36.3",
      "pali": "Mamānusāsanikarā,"
    },
    {
      "id": "thi-ap19:36.4",
      "pali": "iddhiyā suvisāradā’."
    },
    {
      "id": "thi-ap19:37.1",
      "pali": "Buddhassa vacanaṁ sutvā,"
    },
    {
      "id": "thi-ap19:37.2",
      "pali": "evaṁ patthesahaṁ tadā;"
    },
    {
      "id": "thi-ap19:37.3",
      "pali": "‘Ahampi tādisā homi,"
    },
    {
      "id": "thi-ap19:37.4",
      "pali": "iddhiyā suvisāradā."
    },
    {
      "id": "thi-ap19:38.1",
      "pali": "Pamoditāhaṁ sumanā,"
    },
    {
      "id": "thi-ap19:38.2",
      "pali": "patthe uttamamānasā;"
    },
    {
      "id": "thi-ap19:38.3",
      "pali": "Anāgatamhi addhāne,"
    },
    {
      "id": "thi-ap19:38.4",
      "pali": "īdisā homi nāyaka’."
    },
    {
      "id": "thi-ap19:39.1",
      "pali": "Maṇimayamhi pallaṅke,"
    },
    {
      "id": "thi-ap19:39.2",
      "pali": "maṇḍapamhi pabhassare;"
    },
    {
      "id": "thi-ap19:39.3",
      "pali": "Annapānena tappetvā,"
    },
    {
      "id": "thi-ap19:39.4",
      "pali": "sasaṅghaṁ lokanāyakaṁ."
    },
    {
      "id": "thi-ap19:40.1",
      "pali": "Nāgānaṁ pavaraṁ pupphaṁ,"
    },
    {
      "id": "thi-ap19:40.2",
      "pali": "aruṇaṁ nāma uppalaṁ;"
    },
    {
      "id": "thi-ap19:40.3",
      "pali": "‘Vaṇṇaṁ me īdisaṁ hotu’,"
    },
    {
      "id": "thi-ap19:40.4",
      "pali": "pūjesiṁ lokanāyakaṁ."
    },
    {
      "id": "thi-ap19:41.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap19:41.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap19:41.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap19:41.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap19:42.1",
      "pali": "Tato cutāhaṁ manuje,"
    },
    {
      "id": "thi-ap19:42.2",
      "pali": "upapannā sayambhuno;"
    },
    {
      "id": "thi-ap19:42.3",
      "pali": "Uppalehi paṭicchannaṁ,"
    },
    {
      "id": "thi-ap19:42.4",
      "pali": "piṇḍapātamadāsahaṁ."
    },
    {
      "id": "thi-ap19:43.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap19:43.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "thi-ap19:43.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "thi-ap19:43.4",
      "pali": "sabbadhammesu cakkhumā."
    },
    {
      "id": "thi-ap19:44.1",
      "pali": "Seṭṭhidhītā tadā hutvā,"
    },
    {
      "id": "thi-ap19:44.2",
      "pali": "bārāṇasipuruttame;"
    },
    {
      "id": "thi-ap19:44.3",
      "pali": "Nimantetvāna sambuddhaṁ,"
    },
    {
      "id": "thi-ap19:44.4",
      "pali": "sasaṅghaṁ lokanāyakaṁ."
    },
    {
      "id": "thi-ap19:45.1",
      "pali": "Mahādānaṁ daditvāna,"
    },
    {
      "id": "thi-ap19:45.2",
      "pali": "uppalehi vināyakaṁ;"
    },
    {
      "id": "thi-ap19:45.3",
      "pali": "Pūjayitvā cetasāva,"
    },
    {
      "id": "thi-ap19:45.4",
      "pali": "vaṇṇasobhaṁ apatthayiṁ."
    },
    {
      "id": "thi-ap19:46.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap19:46.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap19:46.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap19:46.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap19:47.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap19:47.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap19:47.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap19:47.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap19:48.1",
      "pali": "Tassāsiṁ dutiyā dhītā,"
    },
    {
      "id": "thi-ap19:48.2",
      "pali": "samaṇaguttasavhayā;"
    },
    {
      "id": "thi-ap19:48.3",
      "pali": "Dhammaṁ sutvā jinaggassa,"
    },
    {
      "id": "thi-ap19:48.4",
      "pali": "pabbajjaṁ samarocayiṁ."
    },
    {
      "id": "thi-ap19:49.1",
      "pali": "Anujāni na no tāto,"
    },
    {
      "id": "thi-ap19:49.2",
      "pali": "agāreva tadā mayaṁ;"
    },
    {
      "id": "thi-ap19:49.3",
      "pali": "Vīsavassasahassāni,"
    },
    {
      "id": "thi-ap19:49.4",
      "pali": "vicarimha atanditā."
    },
    {
      "id": "thi-ap19:50.1",
      "pali": "Komāribrahmacariyaṁ,"
    },
    {
      "id": "thi-ap19:50.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap19:50.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap19:50.4",
      "pali": "muditā sattadhītaro."
    },
    {
      "id": "thi-ap19:51.1",
      "pali": "Samaṇī samaṇaguttā ca,"
    },
    {
      "id": "thi-ap19:51.2",
      "pali": "bhikkhunī bhikkhudāyikā;"
    },
    {
      "id": "thi-ap19:51.3",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "thi-ap19:51.4",
      "pali": "sattamī saṅghadāyikā."
    },
    {
      "id": "thi-ap19:52.1",
      "pali": "Ahaṁ khemā ca sappaññā,"
    },
    {
      "id": "thi-ap19:52.2",
      "pali": "paṭācārā ca kuṇḍalā;"
    },
    {
      "id": "thi-ap19:52.3",
      "pali": "Kisāgotamī dhammadinnā,"
    },
    {
      "id": "thi-ap19:52.4",
      "pali": "visākhā hoti sattamī."
    },
    {
      "id": "thi-ap19:53.1",
      "pali": "Tehi kammehi sukatehi,"
    },
    {
      "id": "thi-ap19:53.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap19:53.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap19:53.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap19:54.1",
      "pali": "Tato cutā manussesu,"
    },
    {
      "id": "thi-ap19:54.2",
      "pali": "upapannā mahākule;"
    },
    {
      "id": "thi-ap19:54.3",
      "pali": "Pītaṁ maṭṭhaṁ varaṁ dussaṁ,"
    },
    {
      "id": "thi-ap19:54.4",
      "pali": "adaṁ arahato ahaṁ."
    },
    {
      "id": "thi-ap19:55.1",
      "pali": "Tato cutāriṭṭhapure,"
    },
    {
      "id": "thi-ap19:55.2",
      "pali": "jātā vippakule ahaṁ;"
    },
    {
      "id": "thi-ap19:55.3",
      "pali": "Dhītā tiriṭivacchassa,"
    },
    {
      "id": "thi-ap19:55.4",
      "pali": "ummādantī manoharā."
    },
    {
      "id": "thi-ap19:56.1",
      "pali": "Tato cutā janapade,"
    },
    {
      "id": "thi-ap19:56.2",
      "pali": "kule aññatare ahaṁ;"
    },
    {
      "id": "thi-ap19:56.3",
      "pali": "Pasūtā nātiphītamhi,"
    },
    {
      "id": "thi-ap19:56.4",
      "pali": "sāliṁ gopemahaṁ tadā."
    },
    {
      "id": "thi-ap19:57.1",
      "pali": "Disvā paccekasambuddhaṁ,"
    },
    {
      "id": "thi-ap19:57.2",
      "pali": "pañcalājāsatānihaṁ;"
    },
    {
      "id": "thi-ap19:57.3",
      "pali": "Datvā padumacchannāni,"
    },
    {
      "id": "thi-ap19:57.4",
      "pali": "pañca puttasatānihaṁ."
    },
    {
      "id": "thi-ap19:58.1",
      "pali": "Patthayiṁ tepi patthesuṁ,"
    },
    {
      "id": "thi-ap19:58.2",
      "pali": "madhuṁ datvā sayambhuno;"
    },
    {
      "id": "thi-ap19:58.3",
      "pali": "Tato cutā araññehaṁ,"
    },
    {
      "id": "thi-ap19:58.4",
      "pali": "ajāyiṁ padumodare."
    },
    {
      "id": "thi-ap19:59.1",
      "pali": "Kāsirañño mahesīhaṁ,"
    },
    {
      "id": "thi-ap19:59.2",
      "pali": "hutvā sakkatapūjitā;"
    },
    {
      "id": "thi-ap19:59.3",
      "pali": "Ajaniṁ rājaputtānaṁ,"
    },
    {
      "id": "thi-ap19:59.4",
      "pali": "anūnaṁ satapañcakaṁ."
    },
    {
      "id": "thi-ap19:60.1",
      "pali": "Yadā te yobbanappattā,"
    },
    {
      "id": "thi-ap19:60.2",
      "pali": "kīḷantā jalakīḷitaṁ;"
    },
    {
      "id": "thi-ap19:60.3",
      "pali": "Disvā opattapadumaṁ,"
    },
    {
      "id": "thi-ap19:60.4",
      "pali": "āsuṁ paccekanāyakā."
    },
    {
      "id": "thi-ap19:61.1",
      "pali": "Sāhaṁ tehi vinābhūtā,"
    },
    {
      "id": "thi-ap19:61.2",
      "pali": "sutavīrehi sokinī;"
    },
    {
      "id": "thi-ap19:61.3",
      "pali": "Cutā isigilipasse,"
    },
    {
      "id": "thi-ap19:61.4",
      "pali": "gāmakamhi ajāyihaṁ."
    },
    {
      "id": "thi-ap19:62.1",
      "pali": "Yadā buddhā sutamatī,"
    },
    {
      "id": "thi-ap19:62.2",
      "pali": "sutānaṁ bhattunopi ca;"
    },
    {
      "id": "thi-ap19:62.3",
      "pali": "Yāguṁ ādāya gacchantī,"
    },
    {
      "id": "thi-ap19:62.4",
      "pali": "aṭṭha paccekanāyake."
    },
    {
      "id": "thi-ap19:63.1",
      "pali": "Bhikkhāya gāmaṁ gacchante,"
    },
    {
      "id": "thi-ap19:63.2",
      "pali": "disvā putte anussariṁ;"
    },
    {
      "id": "thi-ap19:63.3",
      "pali": "Khīradhārā viniggacchi,"
    },
    {
      "id": "thi-ap19:63.4",
      "pali": "tadā me puttapemasā."
    },
    {
      "id": "thi-ap19:64.1",
      "pali": "Tato tesaṁ adaṁ yāguṁ,"
    },
    {
      "id": "thi-ap19:64.2",
      "pali": "pasannā sehi pāṇibhi;"
    },
    {
      "id": "thi-ap19:64.3",
      "pali": "Tato cutāhaṁ tidasaṁ,"
    },
    {
      "id": "thi-ap19:64.4",
      "pali": "nandanaṁ upapajjahaṁ."
    },
    {
      "id": "thi-ap19:65.1",
      "pali": "Anubhotvā sukhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap19:65.2",
      "pali": "saṁsaritvā bhavābhave;"
    },
    {
      "id": "thi-ap19:65.3",
      "pali": "Tavatthāya mahāvīra,"
    },
    {
      "id": "thi-ap19:65.4",
      "pali": "pariccattañca jīvitaṁ."
    },
    {
      "id": "thi-ap19:66.1",
      "pali": "Evaṁ bahuvidhaṁ dukkhaṁ,"
    },
    {
      "id": "thi-ap19:66.2",
      "pali": "sampattī ca bahubbidhā;"
    },
    {
      "id": "thi-ap19:66.3",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap19:66.4",
      "pali": "jātā sāvatthiyaṁ pure."
    },
    {
      "id": "thi-ap19:67.1",
      "pali": "Mahādhanaseṭṭhikule,"
    },
    {
      "id": "thi-ap19:67.2",
      "pali": "sukhite sajjite tathā;"
    },
    {
      "id": "thi-ap19:67.3",
      "pali": "Nānāratanapajjote,"
    },
    {
      "id": "thi-ap19:67.4",
      "pali": "sabbakāmasamiddhine."
    },
    {
      "id": "thi-ap19:68.1",
      "pali": "Sakkatā pūjitā ceva,"
    },
    {
      "id": "thi-ap19:68.2",
      "pali": "mānitāpacitā tathā;"
    },
    {
      "id": "thi-ap19:68.3",
      "pali": "Rūpasobhaggasampannā,"
    },
    {
      "id": "thi-ap19:68.4",
      "pali": "kulesu atisakkatā."
    },
    {
      "id": "thi-ap19:69.1",
      "pali": "Atīva patthitā cāsiṁ,"
    },
    {
      "id": "thi-ap19:69.2",
      "pali": "rūpabhogasirīhi ca;"
    },
    {
      "id": "thi-ap19:69.3",
      "pali": "Patthitā seṭṭhiputtehi,"
    },
    {
      "id": "thi-ap19:69.4",
      "pali": "anekehi satehipi."
    },
    {
      "id": "thi-ap19:70.1",
      "pali": "Agāraṁ pajahitvāna,"
    },
    {
      "id": "thi-ap19:70.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap19:70.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "thi-ap19:70.4",
      "pali": "catusaccamapāpuṇiṁ."
    },
    {
      "id": "thi-ap19:71.1",
      "pali": "Iddhiyā abhinimmitvā,"
    },
    {
      "id": "thi-ap19:71.2",
      "pali": "caturassaṁ rathaṁ ahaṁ;"
    },
    {
      "id": "thi-ap19:71.3",
      "pali": "Buddhassa pāde vandissaṁ,"
    },
    {
      "id": "thi-ap19:71.4",
      "pali": "lokanāthassa tādino."
    },
    {
      "id": "thi-ap19:72.1",
      "pali": "‘Supupphitaggaṁ upagamma pādapaṁ,"
    },
    {
      "id": "thi-ap19:72.2",
      "pali": "Ekā tuvaṁ tiṭṭhasi sālamūle;"
    },
    {
      "id": "thi-ap19:72.3",
      "pali": "Na cāpi te dutiyo atthi koci,"
    },
    {
      "id": "thi-ap19:72.4",
      "pali": "Bāle na tvaṁ bhāyasi dhuttakānaṁ’."
    },
    {
      "id": "thi-ap19:73.1",
      "pali": "‘Sataṁ sahassānipi dhuttakānaṁ,"
    },
    {
      "id": "thi-ap19:73.2",
      "pali": "Samāgatā edisakā bhaveyyuṁ;"
    },
    {
      "id": "thi-ap19:73.3",
      "pali": "Lomaṁ na iñje na sampavedhe,"
    },
    {
      "id": "thi-ap19:73.4",
      "pali": "Kiṁ me tuvaṁ māra karissaseko."
    },
    {
      "id": "thi-ap19:74.1",
      "pali": "Esā antaradhāyāmi,"
    },
    {
      "id": "thi-ap19:74.2",
      "pali": "kucchiṁ vā pavisāmi te;"
    },
    {
      "id": "thi-ap19:74.3",
      "pali": "Bhamukantarikāyampi,"
    },
    {
      "id": "thi-ap19:74.4",
      "pali": "tiṭṭhantiṁ maṁ na dakkhasi."
    },
    {
      "id": "thi-ap19:75.1",
      "pali": "Cittasmiṁ vasībhūtāmhi,"
    },
    {
      "id": "thi-ap19:75.2",
      "pali": "iddhipādā subhāvitā;"
    },
    {
      "id": "thi-ap19:75.3",
      "pali": "Sabbabandhanamuttāmhi,"
    },
    {
      "id": "thi-ap19:75.4",
      "pali": "na taṁ bhāyāmi āvuso."
    },
    {
      "id": "thi-ap19:76.1",
      "pali": "Sattisūlūpamā kāmā,"
    },
    {
      "id": "thi-ap19:76.2",
      "pali": "khandhāsaṁ adhikuṭṭanā;"
    },
    {
      "id": "thi-ap19:76.3",
      "pali": "Yaṁ tvaṁ kāmaratiṁ brūsi,"
    },
    {
      "id": "thi-ap19:76.4",
      "pali": "aratī dāni sā mama."
    },
    {
      "id": "thi-ap19:77.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thi-ap19:77.2",
      "pali": "tamokhandho padālito;"
    },
    {
      "id": "thi-ap19:77.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thi-ap19:77.4",
      "pali": "nihato tvamasi antaka’."
    },
    {
      "id": "thi-ap19:78.1",
      "pali": "Jino tamhi guṇe tuṭṭho,"
    },
    {
      "id": "thi-ap19:78.2",
      "pali": "etadagge ṭhapesi maṁ;"
    },
    {
      "id": "thi-ap19:78.3",
      "pali": "Aggā iddhimatīnanti,"
    },
    {
      "id": "thi-ap19:78.4",
      "pali": "parisāsu vināyako."
    },
    {
      "id": "thi-ap19:79.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thi-ap19:79.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thi-ap19:79.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thi-ap19:79.4",
      "pali": "bhavanettisamūhatā."
    },
    {
      "id": "thi-ap19:80.1",
      "pali": "Yassatthāya pabbajitā,"
    },
    {
      "id": "thi-ap19:80.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thi-ap19:80.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thi-ap19:80.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thi-ap19:81.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap19:81.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap19:81.3",
      "pali": "Khaṇena upanāmenti,"
    },
    {
      "id": "thi-ap19:81.4",
      "pali": "sahassāni samantato."
    },
    {
      "id": "thi-ap19:82.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap19:82.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap19:82.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap19:83.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap19:83.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap19:83.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap19:84.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap19:84.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap19:84.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap19:85.1",
      "pali": "Itthaṁ sudaṁ uppalavaṇṇā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap19:86.1",
      "pali": "Uppalavaṇṇātheriyāpadānaṁ navamaṁ."
    }
  ]
}
