{
  "uid": "bv28",
  "title": "28. Buddhapakiṇṇakakaṇḍa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv28:1.1",
      "pali": "Aparimeyyito kappe,"
    },
    {
      "id": "bv28:1.2",
      "pali": "caturo āsuṁ vināyakā;"
    },
    {
      "id": "bv28:1.3",
      "pali": "Taṇhaṅkaro medhaṅkaro,"
    },
    {
      "id": "bv28:1.4",
      "pali": "athopi saraṇaṅkaro;"
    },
    {
      "id": "bv28:1.5",
      "pali": "Dīpaṅkaro ca sambuddho,"
    },
    {
      "id": "bv28:1.6",
      "pali": "ekakappamhi te jinā."
    },
    {
      "id": "bv28:2.1",
      "pali": "Dīpaṅkarassa aparena,"
    },
    {
      "id": "bv28:2.2",
      "pali": "koṇḍañño nāma nāyako;"
    },
    {
      "id": "bv28:2.3",
      "pali": "Ekova ekakappamhi,"
    },
    {
      "id": "bv28:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv28:3.1",
      "pali": "Dīpaṅkarassa bhagavato,"
    },
    {
      "id": "bv28:3.2",
      "pali": "koṇḍaññassa ca satthuno;"
    },
    {
      "id": "bv28:3.3",
      "pali": "Etesaṁ antarā kappā,"
    },
    {
      "id": "bv28:3.4",
      "pali": "gaṇanāto asaṅkhiyā."
    },
    {
      "id": "bv28:4.1",
      "pali": "Koṇḍaññassa aparena,"
    },
    {
      "id": "bv28:4.2",
      "pali": "maṅgalo nāma nāyako;"
    },
    {
      "id": "bv28:4.3",
      "pali": "Tesampi antarā kappā,"
    },
    {
      "id": "bv28:4.4",
      "pali": "gaṇanāto asaṅkhiyā."
    },
    {
      "id": "bv28:5.1",
      "pali": "Maṅgalo ca sumano ca,"
    },
    {
      "id": "bv28:5.2",
      "pali": "revato sobhito muni;"
    },
    {
      "id": "bv28:5.3",
      "pali": "Tepi buddhā ekakappe,"
    },
    {
      "id": "bv28:5.4",
      "pali": "cakkhumanto pabhaṅkarā."
    },
    {
      "id": "bv28:6.1",
      "pali": "Sobhitassa aparena,"
    },
    {
      "id": "bv28:6.2",
      "pali": "anomadassī mahāyaso;"
    },
    {
      "id": "bv28:6.3",
      "pali": "Tesampi antarā kappā,"
    },
    {
      "id": "bv28:6.4",
      "pali": "gaṇanāto asaṅkhiyā."
    },
    {
      "id": "bv28:7.1",
      "pali": "Anomadassī padumo,"
    },
    {
      "id": "bv28:7.2",
      "pali": "nārado cāpi nāyako;"
    },
    {
      "id": "bv28:7.3",
      "pali": "Tepi buddhā ekakappe,"
    },
    {
      "id": "bv28:7.4",
      "pali": "tamantakārakā munī."
    },
    {
      "id": "bv28:8.1",
      "pali": "Nāradassa aparena,"
    },
    {
      "id": "bv28:8.2",
      "pali": "Padumuttaro nāma nāyako;"
    },
    {
      "id": "bv28:8.3",
      "pali": "Ekakappamhi uppanno,"
    },
    {
      "id": "bv28:8.4",
      "pali": "Tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv28:9.1",
      "pali": "Nāradassa bhagavato,"
    },
    {
      "id": "bv28:9.2",
      "pali": "padumuttarassa satthuno;"
    },
    {
      "id": "bv28:9.3",
      "pali": "Tesampi antarā kappā,"
    },
    {
      "id": "bv28:9.4",
      "pali": "gaṇanāto asaṅkhiyā."
    },
    {
      "id": "bv28:10.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "bv28:10.2",
      "pali": "eko āsi mahāmuni;"
    },
    {
      "id": "bv28:10.3",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "bv28:10.4",
      "pali": "āhutīnaṁ paṭiggaho."
    },
    {
      "id": "bv28:11.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "bv28:11.2",
      "pali": "duve āsuṁ vināyakā;"
    },
    {
      "id": "bv28:11.3",
      "pali": "Sumedho ca sujāto ca,"
    },
    {
      "id": "bv28:11.4",
      "pali": "orato padumuttarā."
    },
    {
      "id": "bv28:12.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "bv28:12.2",
      "pali": "tayo āsuṁ vināyakā;"
    },
    {
      "id": "bv28:12.3",
      "pali": "Piyadassī atthadassī,"
    },
    {
      "id": "bv28:12.4",
      "pali": "dhammadassī ca nāyakā."
    },
    {
      "id": "bv28:13.1",
      "pali": "Orato ca sujātassa,"
    },
    {
      "id": "bv28:13.2",
      "pali": "sambuddhā dvipaduttamā;"
    },
    {
      "id": "bv28:13.3",
      "pali": "Ekakappamhi te buddhā,"
    },
    {
      "id": "bv28:13.4",
      "pali": "loke appaṭipuggalā."
    },
    {
      "id": "bv28:14.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "bv28:14.2",
      "pali": "eko āsi mahāmuni;"
    },
    {
      "id": "bv28:14.3",
      "pali": "Siddhattho so lokavidū,"
    },
    {
      "id": "bv28:14.4",
      "pali": "sallakatto anuttaro."
    },
    {
      "id": "bv28:15.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "bv28:15.2",
      "pali": "duve āsuṁ vināyakā;"
    },
    {
      "id": "bv28:15.3",
      "pali": "Tisso phusso ca sambuddhā,"
    },
    {
      "id": "bv28:15.4",
      "pali": "asamā appaṭipuggalā."
    },
    {
      "id": "bv28:16.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "bv28:16.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "bv28:16.3",
      "pali": "Sopi buddho kāruṇiko,"
    },
    {
      "id": "bv28:16.4",
      "pali": "satte mocesi bandhanā."
    },
    {
      "id": "bv28:17.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "bv28:17.2",
      "pali": "duve āsuṁ vināyakā;"
    },
    {
      "id": "bv28:17.3",
      "pali": "Sikhī ca vessabhū ceva,"
    },
    {
      "id": "bv28:17.4",
      "pali": "asamā appaṭipuggalā."
    },
    {
      "id": "bv28:18.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "bv28:18.2",
      "pali": "tayo āsuṁ vināyakā;"
    },
    {
      "id": "bv28:18.3",
      "pali": "Kakusandho koṇāgamano,"
    },
    {
      "id": "bv28:18.4",
      "pali": "kassapo cāpi nāyako."
    },
    {
      "id": "bv28:19.1",
      "pali": "Ahametarahi sambuddho,"
    },
    {
      "id": "bv28:19.2",
      "pali": "metteyyo cāpi hessati;"
    },
    {
      "id": "bv28:19.3",
      "pali": "Etepime pañca buddhā,"
    },
    {
      "id": "bv28:19.4",
      "pali": "dhīrā lokānukampakā."
    },
    {
      "id": "bv28:20.1",
      "pali": "Etesaṁ dhammarājūnaṁ,"
    },
    {
      "id": "bv28:20.2",
      "pali": "Aññesaṁnekakoṭinaṁ;"
    },
    {
      "id": "bv28:20.3",
      "pali": "Ācikkhitvāna taṁ maggaṁ,"
    },
    {
      "id": "bv28:20.4",
      "pali": "Nibbutā te sasāvakāti."
    },
    {
      "id": "bv28:21.1",
      "pali": "Buddhapakiṇṇakakaṇḍaṁ niṭṭhitaṁ."
    }
  ]
}
