{
  "uid": "thi-ap22",
  "title": "Kisāgotamītherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap22:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap22:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap22:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap22:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap22:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap22:2.2",
      "pali": "jātā aññatare kule;"
    },
    {
      "id": "thi-ap22:2.3",
      "pali": "Upetvā taṁ naravaraṁ,"
    },
    {
      "id": "thi-ap22:2.4",
      "pali": "saraṇaṁ samupāgamiṁ."
    },
    {
      "id": "thi-ap22:3.1",
      "pali": "Dhammañca tassa assosiṁ,"
    },
    {
      "id": "thi-ap22:3.2",
      "pali": "catusaccūpasañhitaṁ;"
    },
    {
      "id": "thi-ap22:3.3",
      "pali": "Madhuraṁ paramassādaṁ,"
    },
    {
      "id": "thi-ap22:3.4",
      "pali": "vaṭṭasantisukhāvahaṁ."
    },
    {
      "id": "thi-ap22:4.1",
      "pali": "Tadā ca bhikkhuniṁ vīro,"
    },
    {
      "id": "thi-ap22:4.2",
      "pali": "lūkhacīvaradhāriniṁ;"
    },
    {
      "id": "thi-ap22:4.3",
      "pali": "Ṭhapento etadaggamhi,"
    },
    {
      "id": "thi-ap22:4.4",
      "pali": "vaṇṇayī purisuttamo."
    },
    {
      "id": "thi-ap22:5.1",
      "pali": "Janetvānappakaṁ pītiṁ,"
    },
    {
      "id": "thi-ap22:5.2",
      "pali": "sutvā bhikkhuniyā guṇe;"
    },
    {
      "id": "thi-ap22:5.3",
      "pali": "Kāraṁ katvāna buddhassa,"
    },
    {
      "id": "thi-ap22:5.4",
      "pali": "yathāsatti yathābalaṁ."
    },
    {
      "id": "thi-ap22:6.1",
      "pali": "Nipacca munivaraṁ taṁ,"
    },
    {
      "id": "thi-ap22:6.2",
      "pali": "taṁ ṭhānamabhipatthayiṁ;"
    },
    {
      "id": "thi-ap22:6.3",
      "pali": "Tadānumodi sambuddho,"
    },
    {
      "id": "thi-ap22:6.4",
      "pali": "ṭhānalābhāya nāyako."
    },
    {
      "id": "thi-ap22:7.1",
      "pali": "‘Satasahassito kappe,"
    },
    {
      "id": "thi-ap22:7.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap22:7.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap22:7.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap22:8.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap22:8.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap22:8.3",
      "pali": "Kisāgotamī nāmena,"
    },
    {
      "id": "thi-ap22:8.4",
      "pali": "hessati satthu sāvikā’."
    },
    {
      "id": "thi-ap22:9.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap22:9.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "thi-ap22:9.3",
      "pali": "Mettacittā paricariṁ,"
    },
    {
      "id": "thi-ap22:9.4",
      "pali": "paccayehi vināyakaṁ."
    },
    {
      "id": "thi-ap22:10.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap22:10.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap22:10.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap22:10.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap22:11.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap22:11.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap22:11.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap22:11.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap22:12.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap22:12.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap22:12.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap22:12.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap22:13.1",
      "pali": "Pañcamī tassa dhītāsiṁ,"
    },
    {
      "id": "thi-ap22:13.2",
      "pali": "dhammā nāmena vissutā;"
    },
    {
      "id": "thi-ap22:13.3",
      "pali": "Dhammaṁ sutvā jinaggassa,"
    },
    {
      "id": "thi-ap22:13.4",
      "pali": "pabbajjaṁ samarocayiṁ."
    },
    {
      "id": "thi-ap22:14.1",
      "pali": "Anujāni na no tāto,"
    },
    {
      "id": "thi-ap22:14.2",
      "pali": "agāreva tadā mayaṁ;"
    },
    {
      "id": "thi-ap22:14.3",
      "pali": "Vīsavassasahassāni,"
    },
    {
      "id": "thi-ap22:14.4",
      "pali": "vicarimha atanditā."
    },
    {
      "id": "thi-ap22:15.1",
      "pali": "Komāribrahmacariyaṁ,"
    },
    {
      "id": "thi-ap22:15.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap22:15.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap22:15.4",
      "pali": "muditā satta dhītaro."
    },
    {
      "id": "thi-ap22:16.1",
      "pali": "Samaṇī samaṇaguttā ca,"
    },
    {
      "id": "thi-ap22:16.2",
      "pali": "bhikkhunī bhikkhudāyikā;"
    },
    {
      "id": "thi-ap22:16.3",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "thi-ap22:16.4",
      "pali": "sattamī saṅghadāyikā."
    },
    {
      "id": "thi-ap22:17.1",
      "pali": "Khemā uppalavaṇṇā ca,"
    },
    {
      "id": "thi-ap22:17.2",
      "pali": "paṭācārā ca kuṇḍalā;"
    },
    {
      "id": "thi-ap22:17.3",
      "pali": "Ahañca dhammadinnā ca,"
    },
    {
      "id": "thi-ap22:17.4",
      "pali": "visākhā hoti sattamī."
    },
    {
      "id": "thi-ap22:18.1",
      "pali": "Tehi kammehi sukatehi,"
    },
    {
      "id": "thi-ap22:18.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap22:18.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap22:18.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap22:19.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap22:19.2",
      "pali": "jātā seṭṭhikule ahaṁ;"
    },
    {
      "id": "thi-ap22:19.3",
      "pali": "Duggate adhane naṭṭhe,"
    },
    {
      "id": "thi-ap22:19.4",
      "pali": "gatā ca sadhanaṁ kulaṁ."
    },
    {
      "id": "thi-ap22:20.1",
      "pali": "Patiṁ ṭhapetvā sesā me,"
    },
    {
      "id": "thi-ap22:20.2",
      "pali": "dessanti adhanā iti;"
    },
    {
      "id": "thi-ap22:20.3",
      "pali": "Yadā ca pasūtā āsiṁ,"
    },
    {
      "id": "thi-ap22:20.4",
      "pali": "sabbesaṁ dayitā tadā."
    },
    {
      "id": "thi-ap22:21.1",
      "pali": "Yadā so taruṇo bhaddo,"
    },
    {
      "id": "thi-ap22:21.2",
      "pali": "komalako sukhedhito;"
    },
    {
      "id": "thi-ap22:21.3",
      "pali": "Sapāṇamiva kanto me,"
    },
    {
      "id": "thi-ap22:21.4",
      "pali": "tadā yamavasaṁ gato."
    },
    {
      "id": "thi-ap22:22.1",
      "pali": "Sokaṭṭādīnavadanā,"
    },
    {
      "id": "thi-ap22:22.2",
      "pali": "assunettā rudammukhā;"
    },
    {
      "id": "thi-ap22:22.3",
      "pali": "Mataṁ kuṇapamādāya,"
    },
    {
      "id": "thi-ap22:22.4",
      "pali": "vilapantī gamāmahaṁ."
    },
    {
      "id": "thi-ap22:23.1",
      "pali": "Tadā ekena sandiṭṭhā,"
    },
    {
      "id": "thi-ap22:23.2",
      "pali": "upetvābhisakkuttamaṁ;"
    },
    {
      "id": "thi-ap22:23.3",
      "pali": "Avocaṁ ‘dehi bhesajjaṁ,"
    },
    {
      "id": "thi-ap22:23.4",
      "pali": "puttasañjīvananti bho’."
    },
    {
      "id": "thi-ap22:24.1",
      "pali": "‘Na vijjante matā yasmiṁ,"
    },
    {
      "id": "thi-ap22:24.2",
      "pali": "gehe siddhatthakaṁ tato;"
    },
    {
      "id": "thi-ap22:24.3",
      "pali": "Āharā’ti jino āha,"
    },
    {
      "id": "thi-ap22:24.4",
      "pali": "vinayopāyakovido."
    },
    {
      "id": "thi-ap22:25.1",
      "pali": "Tadā gamitvā sāvatthiṁ,"
    },
    {
      "id": "thi-ap22:25.2",
      "pali": "na labhiṁ tādisaṁ gharaṁ;"
    },
    {
      "id": "thi-ap22:25.3",
      "pali": "Kuto siddhatthakaṁ tasmā,"
    },
    {
      "id": "thi-ap22:25.4",
      "pali": "tato laddhā satiṁ ahaṁ."
    },
    {
      "id": "thi-ap22:26.1",
      "pali": "Kuṇapaṁ chaḍḍayitvāna,"
    },
    {
      "id": "thi-ap22:26.2",
      "pali": "upesiṁ lokanāyakaṁ;"
    },
    {
      "id": "thi-ap22:26.3",
      "pali": "Dūratova mamaṁ disvā,"
    },
    {
      "id": "thi-ap22:26.4",
      "pali": "avoca madhurassaro."
    },
    {
      "id": "thi-ap22:27.1",
      "pali": "‘Yo ca vassasataṁ jīve,"
    },
    {
      "id": "thi-ap22:27.2",
      "pali": "apassaṁ udayabbayaṁ;"
    },
    {
      "id": "thi-ap22:27.3",
      "pali": "Ekāhaṁ jīvitaṁ seyyo,"
    },
    {
      "id": "thi-ap22:27.4",
      "pali": "passato udayabbayaṁ."
    },
    {
      "id": "thi-ap22:28.1",
      "pali": "Na gāmadhammo nigamassa dhammo,"
    },
    {
      "id": "thi-ap22:28.2",
      "pali": "Na cāpiyaṁ ekakulassa dhammo;"
    },
    {
      "id": "thi-ap22:28.3",
      "pali": "Sabbassa lokassa sadevakassa,"
    },
    {
      "id": "thi-ap22:28.4",
      "pali": "Eseva dhammo yadidaṁ aniccatā’."
    },
    {
      "id": "thi-ap22:29.1",
      "pali": "Sāhaṁ sutvānimā gāthā,"
    },
    {
      "id": "thi-ap22:29.2",
      "pali": "dhammacakkhuṁ visodhayiṁ;"
    },
    {
      "id": "thi-ap22:29.3",
      "pali": "Tato viññātasaddhammā,"
    },
    {
      "id": "thi-ap22:29.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap22:30.1",
      "pali": "Tathā pabbajitā santī,"
    },
    {
      "id": "thi-ap22:30.2",
      "pali": "yuñjantī jinasāsane;"
    },
    {
      "id": "thi-ap22:30.3",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "thi-ap22:30.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap22:31.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap22:31.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap22:31.3",
      "pali": "Paracittāni jānāmi,"
    },
    {
      "id": "thi-ap22:31.4",
      "pali": "satthusāsanakārikā."
    },
    {
      "id": "thi-ap22:32.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap22:32.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap22:32.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thi-ap22:32.4",
      "pali": "visuddhāsiṁ sunimmalā."
    },
    {
      "id": "thi-ap22:33.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thi-ap22:33.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thi-ap22:33.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thi-ap22:33.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thi-ap22:34.1",
      "pali": "Yassatthāya pabbajitā,"
    },
    {
      "id": "thi-ap22:34.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thi-ap22:34.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thi-ap22:34.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thi-ap22:35.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap22:35.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap22:35.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap22:35.4",
      "pali": "buddhaseṭṭhassa vāhasā."
    },
    {
      "id": "thi-ap22:36.1",
      "pali": "Saṅkārakūṭā āhitvā,"
    },
    {
      "id": "thi-ap22:36.2",
      "pali": "susānā rathiyāpi ca;"
    },
    {
      "id": "thi-ap22:36.3",
      "pali": "Tato saṅghāṭikaṁ katvā,"
    },
    {
      "id": "thi-ap22:36.4",
      "pali": "lūkhaṁ dhāremi cīvaraṁ."
    },
    {
      "id": "thi-ap22:37.1",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "thi-ap22:37.2",
      "pali": "lūkhacīvaradhāraṇe;"
    },
    {
      "id": "thi-ap22:37.3",
      "pali": "Ṭhapesi etadaggamhi,"
    },
    {
      "id": "thi-ap22:37.4",
      "pali": "parisāsu vināyako."
    },
    {
      "id": "thi-ap22:38.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap22:38.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap22:38.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap22:39.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap22:39.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap22:39.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap22:40.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap22:40.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap22:40.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap22:41.1",
      "pali": "Itthaṁ sudaṁ kisāgotamī bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap22:42.1",
      "pali": "Kisāgotamītheriyāpadānaṁ dutiyaṁ."
    }
  ]
}
