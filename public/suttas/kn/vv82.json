{
  "uid": "vv82",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv82:1.1",
      "pali": "“Anekavaṇṇaṁ darasokanāsanaṁ,"
    },
    {
      "id": "vv82:1.2",
      "pali": "Vimānamāruyha anekacittaṁ;"
    },
    {
      "id": "vv82:1.3",
      "pali": "Parivārito accharāsaṅgaṇena,"
    },
    {
      "id": "vv82:1.4",
      "pali": "Sunimmito bhūtapatīva modasi."
    },
    {
      "id": "vv82:2.1",
      "pali": "Samassamo natthi kuto panuttaro,"
    },
    {
      "id": "vv82:2.2",
      "pali": "Yasena puññena ca iddhiyā ca;"
    },
    {
      "id": "vv82:2.3",
      "pali": "Sabbe ca devā tidasagaṇā samecca,"
    },
    {
      "id": "vv82:2.4",
      "pali": "Taṁ taṁ namassanti sasiṁva devā;"
    },
    {
      "id": "vv82:2.5",
      "pali": "Imā ca te accharāyo samantato,"
    },
    {
      "id": "vv82:2.6",
      "pali": "Naccanti gāyanti pamodayanti."
    },
    {
      "id": "vv82:3.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv82:3.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv82:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv82:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv82:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv82:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv82:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv82:5.1",
      "pali": "“Ahaṁ bhadante ahuvāsi pubbe,"
    },
    {
      "id": "vv82:5.2",
      "pali": "Sumedhanāmassa jinassa sāvako;"
    },
    {
      "id": "vv82:5.3",
      "pali": "Puthujjano ananubodhohamasmi,"
    },
    {
      "id": "vv82:5.4",
      "pali": "So satta vassāni paribbajissahaṁ."
    },
    {
      "id": "vv82:6.1",
      "pali": "Sohaṁ sumedhassa jinassa satthuno,"
    },
    {
      "id": "vv82:6.2",
      "pali": "Parinibbutassoghatiṇṇassa tādino;"
    },
    {
      "id": "vv82:6.3",
      "pali": "Ratanuccayaṁ hemajālena channaṁ,"
    },
    {
      "id": "vv82:6.4",
      "pali": "Vanditvā thūpasmiṁ manaṁ pasādayiṁ."
    },
    {
      "id": "vv82:7.1",
      "pali": "Na māsi dānaṁ na ca matthi dātuṁ,"
    },
    {
      "id": "vv82:7.2",
      "pali": "Pare ca kho tattha samādapesiṁ;"
    },
    {
      "id": "vv82:7.3",
      "pali": "Pūjetha naṁ pūjanīyassa dhātuṁ,"
    },
    {
      "id": "vv82:7.4",
      "pali": "Evaṁ kira saggamito gamissatha."
    },
    {
      "id": "vv82:8.1",
      "pali": "Tadeva kammaṁ kusalaṁ kataṁ mayā,"
    },
    {
      "id": "vv82:8.2",
      "pali": "Sukhañca dibbaṁ anubhomi attanā;"
    },
    {
      "id": "vv82:8.3",
      "pali": "Modāmahaṁ tidasagaṇassa majjhe,"
    },
    {
      "id": "vv82:8.4",
      "pali": "Na tassa puññassa khayampi ajjhagan”ti."
    },
    {
      "id": "vv82:9.1",
      "pali": "Anekavaṇṇavimānaṁ aṭṭhamaṁ."
    }
  ]
}
