{
  "uid": "tha-ap57",
  "title": "5 Opavayhattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap57:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap57:1.2",
      "pali": "ājānīyamadāsahaṁ;"
    },
    {
      "id": "tha-ap57:1.3",
      "pali": "Niyyādetvāna sambuddhe,"
    },
    {
      "id": "tha-ap57:1.4",
      "pali": "agamāsiṁ sakaṁ gharaṁ."
    },
    {
      "id": "tha-ap57:2.1",
      "pali": "Devalo nāma nāmena,"
    },
    {
      "id": "tha-ap57:2.2",
      "pali": "satthuno aggasāvako;"
    },
    {
      "id": "tha-ap57:2.3",
      "pali": "Varadhammassa dāyādo,"
    },
    {
      "id": "tha-ap57:2.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap57:3.1",
      "pali": "Sapattabhāro bhagavā,"
    },
    {
      "id": "tha-ap57:3.2",
      "pali": "ājāneyyo na kappati;"
    },
    {
      "id": "tha-ap57:3.3",
      "pali": "Tava saṅkappamaññāya,"
    },
    {
      "id": "tha-ap57:3.4",
      "pali": "adhivāsesi cakkhumā."
    },
    {
      "id": "tha-ap57:4.1",
      "pali": "Agghāpetvā vātajavaṁ,"
    },
    {
      "id": "tha-ap57:4.2",
      "pali": "sindhavaṁ sīghavāhanaṁ;"
    },
    {
      "id": "tha-ap57:4.3",
      "pali": "Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap57:4.4",
      "pali": "khamanīyamadāsahaṁ."
    },
    {
      "id": "tha-ap57:5.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap57:5.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap57:5.3",
      "pali": "Khamanīyaṁ vātajavaṁ,"
    },
    {
      "id": "tha-ap57:5.4",
      "pali": "cittaṁ nibbattate mama."
    },
    {
      "id": "tha-ap57:6.1",
      "pali": "Lābhaṁ tesaṁ suladdhaṁva,"
    },
    {
      "id": "tha-ap57:6.2",
      "pali": "ye labhantupasampadaṁ;"
    },
    {
      "id": "tha-ap57:6.3",
      "pali": "Punapi payirupāseyyaṁ,"
    },
    {
      "id": "tha-ap57:6.4",
      "pali": "buddho loke sace bhave."
    },
    {
      "id": "tha-ap57:7.1",
      "pali": "Aṭṭhavīsatikkhattuṁhaṁ,"
    },
    {
      "id": "tha-ap57:7.2",
      "pali": "rājā āsiṁ mahabbalo;"
    },
    {
      "id": "tha-ap57:7.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap57:7.4",
      "pali": "jambusaṇḍassa issaro."
    },
    {
      "id": "tha-ap57:8.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap57:8.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap57:8.3",
      "pali": "Pattosmi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap57:8.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap57:9.1",
      "pali": "Catutiṁsasahassamhi,"
    },
    {
      "id": "tha-ap57:9.2",
      "pali": "mahātejosi khattiyo;"
    },
    {
      "id": "tha-ap57:9.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap57:9.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap57:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap57:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap57:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap57:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā opavayho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap57:12.1",
      "pali": "Opavayhattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
