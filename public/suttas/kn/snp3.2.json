{
  "uid": "snp3.2",
  "title": "Padhānasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp3.2:1.1",
      "pali": "“Taṁ maṁ padhānapahitattaṁ,"
    },
    {
      "id": "snp3.2:1.2",
      "pali": "nadiṁ nerañjaraṁ pati;"
    },
    {
      "id": "snp3.2:1.3",
      "pali": "Viparakkamma jhāyantaṁ,"
    },
    {
      "id": "snp3.2:1.4",
      "pali": "yogakkhemassa pattiyā."
    },
    {
      "id": "snp3.2:2.1",
      "pali": "Namucī karuṇaṁ vācaṁ,"
    },
    {
      "id": "snp3.2:2.2",
      "pali": "bhāsamāno upāgami;"
    },
    {
      "id": "snp3.2:2.3",
      "pali": "‘Kiso tvamasi dubbaṇṇo,"
    },
    {
      "id": "snp3.2:2.4",
      "pali": "santike maraṇaṁ tava."
    },
    {
      "id": "snp3.2:3.1",
      "pali": "Sahassabhāgo maraṇassa,"
    },
    {
      "id": "snp3.2:3.2",
      "pali": "ekaṁso tava jīvitaṁ;"
    },
    {
      "id": "snp3.2:3.3",
      "pali": "Jīva bho jīvitaṁ seyyo,"
    },
    {
      "id": "snp3.2:3.4",
      "pali": "jīvaṁ puññāni kāhasi."
    },
    {
      "id": "snp3.2:4.1",
      "pali": "Carato ca te brahmacariyaṁ,"
    },
    {
      "id": "snp3.2:4.2",
      "pali": "Aggihuttañca jūhato;"
    },
    {
      "id": "snp3.2:4.3",
      "pali": "Pahūtaṁ cīyate puññaṁ,"
    },
    {
      "id": "snp3.2:4.4",
      "pali": "Kiṁ padhānena kāhasi."
    },
    {
      "id": "snp3.2:5.1",
      "pali": "Duggo maggo padhānāya,"
    },
    {
      "id": "snp3.2:5.2",
      "pali": "dukkaro durabhisambhavo’”;"
    },
    {
      "id": "snp3.2:5.3",
      "pali": "Imā gāthā bhaṇaṁ māro,"
    },
    {
      "id": "snp3.2:5.4",
      "pali": "aṭṭhā buddhassa santike."
    },
    {
      "id": "snp3.2:6.1",
      "pali": "Taṁ tathāvādinaṁ māraṁ,"
    },
    {
      "id": "snp3.2:6.2",
      "pali": "bhagavā etadabravi;"
    },
    {
      "id": "snp3.2:6.3",
      "pali": "“Pamattabandhu pāpima,"
    },
    {
      "id": "snp3.2:6.4",
      "pali": "yenatthena idhāgato."
    },
    {
      "id": "snp3.2:7.1",
      "pali": "Aṇumattopi puññena,"
    },
    {
      "id": "snp3.2:7.2",
      "pali": "Attho mayhaṁ na vijjati;"
    },
    {
      "id": "snp3.2:7.3",
      "pali": "Yesañca attho puññena,"
    },
    {
      "id": "snp3.2:7.4",
      "pali": "Te māro vattumarahati."
    },
    {
      "id": "snp3.2:8.1",
      "pali": "Atthi saddhā tathā viriyaṁ,"
    },
    {
      "id": "snp3.2:8.2",
      "pali": "paññā ca mama vijjati;"
    },
    {
      "id": "snp3.2:8.3",
      "pali": "Evaṁ maṁ pahitattampi,"
    },
    {
      "id": "snp3.2:8.4",
      "pali": "kiṁ jīvamanupucchasi."
    },
    {
      "id": "snp3.2:9.1",
      "pali": "Nadīnamapi sotāni,"
    },
    {
      "id": "snp3.2:9.2",
      "pali": "ayaṁ vāto visosaye;"
    },
    {
      "id": "snp3.2:9.3",
      "pali": "Kiñca me pahitattassa,"
    },
    {
      "id": "snp3.2:9.4",
      "pali": "lohitaṁ nupasussaye."
    },
    {
      "id": "snp3.2:10.1",
      "pali": "Lohite sussamānamhi,"
    },
    {
      "id": "snp3.2:10.2",
      "pali": "Pittaṁ semhañca sussati;"
    },
    {
      "id": "snp3.2:10.3",
      "pali": "Maṁsesu khīyamānesu,"
    },
    {
      "id": "snp3.2:10.4",
      "pali": "Bhiyyo cittaṁ pasīdati;"
    },
    {
      "id": "snp3.2:10.5",
      "pali": "Bhiyyo sati ca paññā ca,"
    },
    {
      "id": "snp3.2:10.6",
      "pali": "Samādhi mama tiṭṭhati."
    },
    {
      "id": "snp3.2:11.1",
      "pali": "Tassa mevaṁ viharato,"
    },
    {
      "id": "snp3.2:11.2",
      "pali": "Pattassuttamavedanaṁ;"
    },
    {
      "id": "snp3.2:11.3",
      "pali": "Kāmesu nāpekkhate cittaṁ,"
    },
    {
      "id": "snp3.2:11.4",
      "pali": "Passa sattassa suddhataṁ."
    },
    {
      "id": "snp3.2:12.1",
      "pali": "Kāmā te paṭhamā senā,"
    },
    {
      "id": "snp3.2:12.2",
      "pali": "Dutiyā arati vuccati;"
    },
    {
      "id": "snp3.2:12.3",
      "pali": "Tatiyā khuppipāsā te,"
    },
    {
      "id": "snp3.2:12.4",
      "pali": "Catutthī taṇhā pavuccati."
    },
    {
      "id": "snp3.2:13.1",
      "pali": "Pañcamaṁ thinamiddhaṁ te,"
    },
    {
      "id": "snp3.2:13.2",
      "pali": "Chaṭṭhā bhīrū pavuccati;"
    },
    {
      "id": "snp3.2:13.3",
      "pali": "Sattamī vicikicchā te,"
    },
    {
      "id": "snp3.2:13.4",
      "pali": "Makkho thambho te aṭṭhamo."
    },
    {
      "id": "snp3.2:14.1",
      "pali": "Lābho siloko sakkāro,"
    },
    {
      "id": "snp3.2:14.2",
      "pali": "Micchāladdho ca yo yaso;"
    },
    {
      "id": "snp3.2:14.3",
      "pali": "Yo cattānaṁ samukkaṁse,"
    },
    {
      "id": "snp3.2:14.4",
      "pali": "Pare ca avajānati."
    },
    {
      "id": "snp3.2:15.1",
      "pali": "Esā namuci te senā,"
    },
    {
      "id": "snp3.2:15.2",
      "pali": "Kaṇhassābhippahārinī;"
    },
    {
      "id": "snp3.2:15.3",
      "pali": "Na naṁ asūro jināti,"
    },
    {
      "id": "snp3.2:15.4",
      "pali": "Jetvā ca labhate sukhaṁ."
    },
    {
      "id": "snp3.2:16.1",
      "pali": "Esa muñjaṁ parihare,"
    },
    {
      "id": "snp3.2:16.2",
      "pali": "Dhiratthu mama jīvitaṁ;"
    },
    {
      "id": "snp3.2:16.3",
      "pali": "Saṅgāme me mataṁ seyyo,"
    },
    {
      "id": "snp3.2:16.4",
      "pali": "Yañce jīve parājito."
    },
    {
      "id": "snp3.2:17.1",
      "pali": "Pagāḷhettha na dissanti,"
    },
    {
      "id": "snp3.2:17.2",
      "pali": "Eke samaṇabrāhmaṇā;"
    },
    {
      "id": "snp3.2:17.3",
      "pali": "Tañca maggaṁ na jānanti,"
    },
    {
      "id": "snp3.2:17.4",
      "pali": "Yena gacchanti subbatā."
    },
    {
      "id": "snp3.2:18.1",
      "pali": "Samantā dhajiniṁ disvā,"
    },
    {
      "id": "snp3.2:18.2",
      "pali": "Yuttaṁ māraṁ savāhanaṁ;"
    },
    {
      "id": "snp3.2:18.3",
      "pali": "Yuddhāya paccuggacchāmi,"
    },
    {
      "id": "snp3.2:18.4",
      "pali": "Mā maṁ ṭhānā acāvayi."
    },
    {
      "id": "snp3.2:19.1",
      "pali": "Yaṁ te taṁ nappasahati,"
    },
    {
      "id": "snp3.2:19.2",
      "pali": "Senaṁ loko sadevako;"
    },
    {
      "id": "snp3.2:19.3",
      "pali": "Taṁ te paññāya bhecchāmi,"
    },
    {
      "id": "snp3.2:19.4",
      "pali": "Āmaṁ pattaṁva asmanā."
    },
    {
      "id": "snp3.2:20.1",
      "pali": "Vasīkaritvā saṅkappaṁ,"
    },
    {
      "id": "snp3.2:20.2",
      "pali": "Satiñca sūpatiṭṭhitaṁ;"
    },
    {
      "id": "snp3.2:20.3",
      "pali": "Raṭṭhā raṭṭhaṁ vicarissaṁ,"
    },
    {
      "id": "snp3.2:20.4",
      "pali": "Sāvake vinayaṁ puthū."
    },
    {
      "id": "snp3.2:21.1",
      "pali": "Te appamattā pahitattā,"
    },
    {
      "id": "snp3.2:21.2",
      "pali": "Mama sāsanakārakā;"
    },
    {
      "id": "snp3.2:21.3",
      "pali": "Akāmassa te gamissanti,"
    },
    {
      "id": "snp3.2:21.4",
      "pali": "Yattha gantvā na socare”."
    },
    {
      "id": "snp3.2:22.1",
      "pali": "“Satta vassāni bhagavantaṁ,"
    },
    {
      "id": "snp3.2:22.2",
      "pali": "Anubandhiṁ padāpadaṁ;"
    },
    {
      "id": "snp3.2:22.3",
      "pali": "Otāraṁ nādhigacchissaṁ,"
    },
    {
      "id": "snp3.2:22.4",
      "pali": "Sambuddhassa satīmato."
    },
    {
      "id": "snp3.2:23.1",
      "pali": "Medavaṇṇaṁva pāsāṇaṁ,"
    },
    {
      "id": "snp3.2:23.2",
      "pali": "Vāyaso anupariyagā;"
    },
    {
      "id": "snp3.2:23.3",
      "pali": "Apettha muduṁ vindema,"
    },
    {
      "id": "snp3.2:23.4",
      "pali": "Api assādanā siyā."
    },
    {
      "id": "snp3.2:24.1",
      "pali": "Aladdhā tattha assādaṁ,"
    },
    {
      "id": "snp3.2:24.2",
      "pali": "Vāyasetto apakkami;"
    },
    {
      "id": "snp3.2:24.3",
      "pali": "Kākova selamāsajja,"
    },
    {
      "id": "snp3.2:24.4",
      "pali": "Nibbijjāpema gotamaṁ”."
    },
    {
      "id": "snp3.2:25.1",
      "pali": "Tassa sokaparetassa,"
    },
    {
      "id": "snp3.2:25.2",
      "pali": "Vīṇā kacchā abhassatha;"
    },
    {
      "id": "snp3.2:25.3",
      "pali": "Tato so dummano yakkho,"
    },
    {
      "id": "snp3.2:25.4",
      "pali": "Tatthevantaradhāyathāti."
    },
    {
      "id": "snp3.2:25.5",
      "pali": "Padhānasuttaṁ dutiyaṁ."
    }
  ]
}
