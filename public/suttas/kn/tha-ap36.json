{
  "uid": "tha-ap36",
  "title": "Kāḷudāyittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap36:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap36:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap36:1.3",
      "pali": "Addhānaṁ paṭipannassa,"
    },
    {
      "id": "tha-ap36:1.4",
      "pali": "carato cārikaṁ tadā."
    },
    {
      "id": "tha-ap36:2.1",
      "pali": "Suphullaṁ padumaṁ gayha,"
    },
    {
      "id": "tha-ap36:2.2",
      "pali": "uppalaṁ mallikañcahaṁ;"
    },
    {
      "id": "tha-ap36:2.3",
      "pali": "Paramannaṁ gahetvāna,"
    },
    {
      "id": "tha-ap36:2.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap36:3.1",
      "pali": "Paribhuñji mahāvīro,"
    },
    {
      "id": "tha-ap36:3.2",
      "pali": "paramannaṁ subhojanaṁ;"
    },
    {
      "id": "tha-ap36:3.3",
      "pali": "Tañca pupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap36:3.4",
      "pali": "janassa sampadassayi."
    },
    {
      "id": "tha-ap36:4.1",
      "pali": "Iṭṭhaṁ kantaṁ piyaṁ loke,"
    },
    {
      "id": "tha-ap36:4.2",
      "pali": "jalajaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap36:4.3",
      "pali": "Sudukkaraṁ kataṁ tena,"
    },
    {
      "id": "tha-ap36:4.4",
      "pali": "yo me pupphaṁ adāsidaṁ."
    },
    {
      "id": "tha-ap36:5.1",
      "pali": "Yo pupphamabhiropesi,"
    },
    {
      "id": "tha-ap36:5.2",
      "pali": "paramannañcadāsi me;"
    },
    {
      "id": "tha-ap36:5.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap36:5.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap36:6.1",
      "pali": "‘Dasa aṭṭha cakkhattuṁ so,"
    },
    {
      "id": "tha-ap36:6.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap36:6.3",
      "pali": "Uppalaṁ padumañcāpi,"
    },
    {
      "id": "tha-ap36:6.4",
      "pali": "mallikañca taduttari."
    },
    {
      "id": "tha-ap36:7.1",
      "pali": "Assa puññavipākena,"
    },
    {
      "id": "tha-ap36:7.2",
      "pali": "dibbagandhasamāyutaṁ;"
    },
    {
      "id": "tha-ap36:7.3",
      "pali": "Ākāse chadanaṁ katvā,"
    },
    {
      "id": "tha-ap36:7.4",
      "pali": "dhārayissati tāvade."
    },
    {
      "id": "tha-ap36:8.1",
      "pali": "Pañcavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap36:8.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap36:8.3",
      "pali": "Pathabyā rajjaṁ pañcasataṁ,"
    },
    {
      "id": "tha-ap36:8.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap36:9.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap36:9.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap36:9.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap36:9.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap36:10.1",
      "pali": "Sakakammābhiraddho so,"
    },
    {
      "id": "tha-ap36:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap36:10.3",
      "pali": "Sakyānaṁ nandijanano,"
    },
    {
      "id": "tha-ap36:10.4",
      "pali": "ñātibandhu bhavissati."
    },
    {
      "id": "tha-ap36:11.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap36:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap36:11.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap36:11.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap36:12.1",
      "pali": "Paṭisambhidamanuppattaṁ,"
    },
    {
      "id": "tha-ap36:12.2",
      "pali": "katakiccamanāsavaṁ;"
    },
    {
      "id": "tha-ap36:12.3",
      "pali": "Gotamo lokabandhu taṁ,"
    },
    {
      "id": "tha-ap36:12.4",
      "pali": "etadagge ṭhapessati."
    },
    {
      "id": "tha-ap36:13.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap36:13.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap36:13.3",
      "pali": "Udāyī nāma nāmena,"
    },
    {
      "id": "tha-ap36:13.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap36:14.1",
      "pali": "Rāgo doso ca moho ca,"
    },
    {
      "id": "tha-ap36:14.2",
      "pali": "māno makkho ca dhaṁsito;"
    },
    {
      "id": "tha-ap36:14.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap36:14.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap36:15.1",
      "pali": "Tosayiñcāpi sambuddhaṁ,"
    },
    {
      "id": "tha-ap36:15.2",
      "pali": "ātāpī nipako ahaṁ;"
    },
    {
      "id": "tha-ap36:15.3",
      "pali": "Pasādito ca sambuddho,"
    },
    {
      "id": "tha-ap36:15.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap36:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap36:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap36:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap36:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā kāḷudāyī thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap36:18.1",
      "pali": "Kāḷudāyittherassāpadānaṁ catutthaṁ."
    }
  ]
}
