{
  "uid": "ud3.10",
  "title": "Lokasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud3.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud3.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre bodhirukkhamūle paṭhamābhisambuddho."
    },
    {
      "id": "ud3.10:1.3",
      "pali": "Tena kho pana samayena bhagavā sattāhaṁ ekapallaṅkena nisinno hoti vimuttisukhapaṭisaṁvedī."
    },
    {
      "id": "ud3.10:2.1",
      "pali": "Atha kho bhagavā tassa sattāhassa accayena tamhā samādhimhā vuṭṭhahitvā buddhacakkhunā lokaṁ volokesi."
    },
    {
      "id": "ud3.10:2.2",
      "pali": "Addasā kho bhagavā buddhacakkhunā volokento satte anekehi santāpehi santappamāne, anekehi ca pariḷāhehi pariḍayhamāne—"
    },
    {
      "id": "ud3.10:2.3",
      "pali": "rāgajehipi, dosajehipi, mohajehipi."
    },
    {
      "id": "ud3.10:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud3.10:4.1",
      "pali": "“Ayaṁ loko santāpajāto,"
    },
    {
      "id": "ud3.10:4.2",
      "pali": "Phassapareto rogaṁ vadati attato;"
    },
    {
      "id": "ud3.10:4.3",
      "pali": "Yena yena hi maññati,"
    },
    {
      "id": "ud3.10:4.4",
      "pali": "Tato taṁ hoti aññathā."
    },
    {
      "id": "ud3.10:5.1",
      "pali": "Aññathābhāvī bhavasatto loko,"
    },
    {
      "id": "ud3.10:5.2",
      "pali": "Bhavapareto bhavamevābhinandati;"
    },
    {
      "id": "ud3.10:5.3",
      "pali": "Yadabhinandati taṁ bhayaṁ,"
    },
    {
      "id": "ud3.10:5.4",
      "pali": "Yassa bhāyati taṁ dukkhaṁ;"
    },
    {
      "id": "ud3.10:5.5",
      "pali": "Bhavavippahānāya kho,"
    },
    {
      "id": "ud3.10:5.6",
      "pali": "Panidaṁ brahmacariyaṁ vussati."
    },
    {
      "id": "ud3.10:6.1",
      "pali": "‘Ye hi keci samaṇā vā brāhmaṇā vā bhavena bhavassa vippamokkhamāhaṁsu, sabbe te avippamuttā bhavasmā’ti vadāmi."
    },
    {
      "id": "ud3.10:6.2",
      "pali": "‘Ye vā pana keci samaṇā vā brāhmaṇā vā vibhavena bhavassa nissaraṇamāhaṁsu, sabbe te anissaṭā bhavasmā’ti vadāmi."
    },
    {
      "id": "ud3.10:7.1",
      "pali": "Upadhiñhi paṭicca dukkhamidaṁ sambhoti, sabbupādānakkhayā natthi dukkhassa sambhavo."
    },
    {
      "id": "ud3.10:7.2",
      "pali": "Lokamimaṁ passa;"
    },
    {
      "id": "ud3.10:7.3",
      "pali": "puthū avijjāya paretā bhūtā bhūtaratā aparimuttā;"
    },
    {
      "id": "ud3.10:7.4",
      "pali": "ye hi keci bhavā sabbadhi sabbatthatāya sabbe te bhavā aniccā dukkhā vipariṇāmadhammāti."
    },
    {
      "id": "ud3.10:8.1",
      "pali": "Evametaṁ yathābhūtaṁ,"
    },
    {
      "id": "ud3.10:8.2",
      "pali": "Sammappaññāya passato;"
    },
    {
      "id": "ud3.10:8.3",
      "pali": "Bhavataṇhā pahīyati,"
    },
    {
      "id": "ud3.10:8.4",
      "pali": "Vibhavaṁ nābhinandati;"
    },
    {
      "id": "ud3.10:8.5",
      "pali": "Sabbaso taṇhānaṁ khayā,"
    },
    {
      "id": "ud3.10:8.6",
      "pali": "Asesavirāganirodho nibbānaṁ."
    },
    {
      "id": "ud3.10:9.1",
      "pali": "Tassa nibbutassa bhikkhuno,"
    },
    {
      "id": "ud3.10:9.2",
      "pali": "Anupādā punabbhavo na hoti;"
    },
    {
      "id": "ud3.10:9.3",
      "pali": "Abhibhūto māro vijitasaṅgāmo,"
    },
    {
      "id": "ud3.10:9.4",
      "pali": "Upaccagā sabbabhavāni tādī”ti."
    },
    {
      "id": "ud3.10:9.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "ud3.10:9.6",
      "pali": "Nandavaggo tatiyo."
    },
    {
      "id": "ud3.10:10.1",
      "pali": "Kammaṁ nando yasojo ca,"
    },
    {
      "id": "ud3.10:10.2",
      "pali": "sāriputto ca kolito;"
    },
    {
      "id": "ud3.10:10.3",
      "pali": "Pilindo kassapo piṇḍo,"
    },
    {
      "id": "ud3.10:10.4",
      "pali": "sippaṁ lokena te dasāti."
    }
  ]
}
