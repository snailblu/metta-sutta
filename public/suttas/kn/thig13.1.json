{
  "uid": "thig13.1",
  "title": "Ambapālītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig13.1:1.1",
      "pali": "“Kāḷakā bhamaravaṇṇasādisā,"
    },
    {
      "id": "thig13.1:1.2",
      "pali": "Vellitaggā mama muddhajā ahuṁ;"
    },
    {
      "id": "thig13.1:1.3",
      "pali": "Te jarāya sāṇavākasādisā,"
    },
    {
      "id": "thig13.1:1.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:2.1",
      "pali": "Vāsitova surabhī karaṇḍako,"
    },
    {
      "id": "thig13.1:2.2",
      "pali": "Pupphapūra mama uttamaṅgajo;"
    },
    {
      "id": "thig13.1:2.3",
      "pali": "Taṁ jarāyatha salomagandhikaṁ,"
    },
    {
      "id": "thig13.1:2.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:3.1",
      "pali": "Kānanaṁva sahitaṁ suropitaṁ,"
    },
    {
      "id": "thig13.1:3.2",
      "pali": "Kocchasūcivicitaggasobhitaṁ;"
    },
    {
      "id": "thig13.1:3.3",
      "pali": "Taṁ jarāya viralaṁ tahiṁ tahiṁ,"
    },
    {
      "id": "thig13.1:3.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:4.1",
      "pali": "Kaṇhakhandhakasuvaṇṇamaṇḍitaṁ,"
    },
    {
      "id": "thig13.1:4.2",
      "pali": "Sobhate suveṇīhilaṅkataṁ;"
    },
    {
      "id": "thig13.1:4.3",
      "pali": "Taṁ jarāya khalitaṁ siraṁ kataṁ,"
    },
    {
      "id": "thig13.1:4.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:5.1",
      "pali": "Cittakārasukatāva lekhikā,"
    },
    {
      "id": "thig13.1:5.2",
      "pali": "Sobhare su bhamukā pure mama;"
    },
    {
      "id": "thig13.1:5.3",
      "pali": "Tā jarāya valibhippalambitā,"
    },
    {
      "id": "thig13.1:5.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:6.1",
      "pali": "Bhassarā surucirā yathā maṇī,"
    },
    {
      "id": "thig13.1:6.2",
      "pali": "Nettahesumabhinīlamāyatā;"
    },
    {
      "id": "thig13.1:6.3",
      "pali": "Te jarāyabhihatā na sobhare,"
    },
    {
      "id": "thig13.1:6.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:7.1",
      "pali": "Saṇhatuṅgasadisī ca nāsikā,"
    },
    {
      "id": "thig13.1:7.2",
      "pali": "Sobhate su abhiyobbanaṁ pati;"
    },
    {
      "id": "thig13.1:7.3",
      "pali": "Sā jarāya upakūlitā viya,"
    },
    {
      "id": "thig13.1:7.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:8.1",
      "pali": "Kaṅkaṇaṁva sukataṁ suniṭṭhitaṁ,"
    },
    {
      "id": "thig13.1:8.2",
      "pali": "Sobhare su mama kaṇṇapāḷiyo;"
    },
    {
      "id": "thig13.1:8.3",
      "pali": "Tā jarāya valibhippalambitā,"
    },
    {
      "id": "thig13.1:8.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:9.1",
      "pali": "Pattalīmakulavaṇṇasādisā,"
    },
    {
      "id": "thig13.1:9.2",
      "pali": "Sobhare su dantā pure mama;"
    },
    {
      "id": "thig13.1:9.3",
      "pali": "Te jarāya khaṇḍitā cāsitā,"
    },
    {
      "id": "thig13.1:9.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:10.1",
      "pali": "Kānanamhi vanasaṇḍacārinī,"
    },
    {
      "id": "thig13.1:10.2",
      "pali": "Kokilāva madhuraṁ nikūjihaṁ;"
    },
    {
      "id": "thig13.1:10.3",
      "pali": "Taṁ jarāya khalitaṁ tahiṁ tahiṁ,"
    },
    {
      "id": "thig13.1:10.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:11.1",
      "pali": "Saṇhakamburiva suppamajjitā,"
    },
    {
      "id": "thig13.1:11.2",
      "pali": "Sobhate su gīvā pure mama;"
    },
    {
      "id": "thig13.1:11.3",
      "pali": "Sā jarāya bhaggā vināmitā,"
    },
    {
      "id": "thig13.1:11.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:12.1",
      "pali": "Vaṭṭapalighasadisopamā ubho,"
    },
    {
      "id": "thig13.1:12.2",
      "pali": "Sobhare su bāhā pure mama;"
    },
    {
      "id": "thig13.1:12.3",
      "pali": "Tā jarāya yatha pāṭalibbalitā,"
    },
    {
      "id": "thig13.1:12.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:13.1",
      "pali": "Saṇhamuddikasuvaṇṇamaṇḍitā,"
    },
    {
      "id": "thig13.1:13.2",
      "pali": "Sobhare su hatthā pure mama;"
    },
    {
      "id": "thig13.1:13.3",
      "pali": "Te jarāya yathā mūlamūlikā,"
    },
    {
      "id": "thig13.1:13.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:14.1",
      "pali": "Pīnavaṭṭasahituggatā ubho,"
    },
    {
      "id": "thig13.1:14.2",
      "pali": "Sobhare su thanakā pure mama;"
    },
    {
      "id": "thig13.1:14.3",
      "pali": "Thevikīva lambanti nodakā,"
    },
    {
      "id": "thig13.1:14.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:15.1",
      "pali": "Kañcanassa phalakaṁva sammaṭṭhaṁ,"
    },
    {
      "id": "thig13.1:15.2",
      "pali": "Sobhate su kāyo pure mama;"
    },
    {
      "id": "thig13.1:15.3",
      "pali": "So valīhi sukhumāhi otato,"
    },
    {
      "id": "thig13.1:15.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:16.1",
      "pali": "Nāgabhogasadisopamā ubho,"
    },
    {
      "id": "thig13.1:16.2",
      "pali": "Sobhare su ūrū pure mama;"
    },
    {
      "id": "thig13.1:16.3",
      "pali": "Te jarāya yathā veḷunāḷiyo,"
    },
    {
      "id": "thig13.1:16.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:17.1",
      "pali": "Saṇhanūpurasuvaṇṇamaṇḍitā,"
    },
    {
      "id": "thig13.1:17.2",
      "pali": "Sobhare su jaṅghā pure mama;"
    },
    {
      "id": "thig13.1:17.3",
      "pali": "Tā jarāya tiladaṇḍakāriva,"
    },
    {
      "id": "thig13.1:17.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:18.1",
      "pali": "Tūlapuṇṇasadisopamā ubho,"
    },
    {
      "id": "thig13.1:18.2",
      "pali": "Sobhare su pādā pure mama;"
    },
    {
      "id": "thig13.1:18.3",
      "pali": "Te jarāya phuṭitā valīmatā,"
    },
    {
      "id": "thig13.1:18.4",
      "pali": "Saccavādivacanaṁ anaññathā."
    },
    {
      "id": "thig13.1:19.1",
      "pali": "Ediso ahu ayaṁ samussayo,"
    },
    {
      "id": "thig13.1:19.2",
      "pali": "Jajjaro bahudukkhānamālayo;"
    },
    {
      "id": "thig13.1:19.3",
      "pali": "Sopalepapatito jarāgharo,"
    },
    {
      "id": "thig13.1:19.4",
      "pali": "Saccavādivacanaṁ anaññathā”."
    },
    {
      "id": "thig13.1:20.1",
      "pali": "… Ambapālī therī …."
    }
  ]
}
