{
  "uid": "ja271",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja271:1.1",
      "pali": "“Āraññikassa isino,"
    },
    {
      "id": "ja271:1.2",
      "pali": "cirarattatapassino;"
    },
    {
      "id": "ja271:1.3",
      "pali": "Kicchākataṁ udapānaṁ,"
    },
    {
      "id": "ja271:1.4",
      "pali": "kathaṁ samma avāhayi”."
    },
    {
      "id": "ja271:2.1",
      "pali": "“Esa dhammo siṅgālānaṁ,"
    },
    {
      "id": "ja271:2.2",
      "pali": "yaṁ pitvā ohadāmase;"
    },
    {
      "id": "ja271:2.3",
      "pali": "Pitupitāmahaṁ dhammo,"
    },
    {
      "id": "ja271:2.4",
      "pali": "na taṁ ujjhātumarahasi”."
    },
    {
      "id": "ja271:3.1",
      "pali": "“Yesaṁ vo ediso dhammo,"
    },
    {
      "id": "ja271:3.2",
      "pali": "Adhammo pana kīdiso;"
    },
    {
      "id": "ja271:3.3",
      "pali": "Mā vo dhammaṁ adhammaṁ vā,"
    },
    {
      "id": "ja271:3.4",
      "pali": "Addasāma kudācanan”ti."
    },
    {
      "id": "ja271:4.1",
      "pali": "Udapānadūsakajātakaṁ paṭhamaṁ."
    }
  ]
}
