{
  "uid": "ja281",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja281:1.1",
      "pali": "“Abbhantaro nāma dumo,"
    },
    {
      "id": "ja281:1.2",
      "pali": "yassa dibyamidaṁ phalaṁ;"
    },
    {
      "id": "ja281:1.3",
      "pali": "Bhutvā dohaḷinī nārī,"
    },
    {
      "id": "ja281:1.4",
      "pali": "cakkavattiṁ vijāyati."
    },
    {
      "id": "ja281:2.1",
      "pali": "Tvampi bhadde mahesīsi,"
    },
    {
      "id": "ja281:2.2",
      "pali": "sā cāpi patino piyā;"
    },
    {
      "id": "ja281:2.3",
      "pali": "Āharissati te rājā,"
    },
    {
      "id": "ja281:2.4",
      "pali": "idaṁ abbhantaraṁ phalaṁ”."
    },
    {
      "id": "ja281:3.1",
      "pali": "“Bhatturatthe parakkanto,"
    },
    {
      "id": "ja281:3.2",
      "pali": "yaṁ ṭhānamadhigacchati;"
    },
    {
      "id": "ja281:3.3",
      "pali": "Sūro attapariccāgī,"
    },
    {
      "id": "ja281:3.4",
      "pali": "labhamāno bhavāmahan”ti."
    },
    {
      "id": "ja281:4.1",
      "pali": "Abbhantarajātakaṁ paṭhamaṁ."
    }
  ]
}
