{
  "uid": "tha-ap562",
  "title": "Upavānattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap562:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap562:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap562:1.3",
      "pali": "Jalitvā aggikkhandhova,"
    },
    {
      "id": "tha-ap562:1.4",
      "pali": "sambuddho parinibbuto."
    },
    {
      "id": "tha-ap562:2.1",
      "pali": "Mahājanā samāgamma,"
    },
    {
      "id": "tha-ap562:2.2",
      "pali": "pūjayitvā tathāgataṁ;"
    },
    {
      "id": "tha-ap562:2.3",
      "pali": "Citakaṁ katvā sugataṁ,"
    },
    {
      "id": "tha-ap562:2.4",
      "pali": "sarīraṁ abhiropayuṁ."
    },
    {
      "id": "tha-ap562:3.1",
      "pali": "Sarīrakiccaṁ katvāna,"
    },
    {
      "id": "tha-ap562:3.2",
      "pali": "dhātuṁ tattha samānayuṁ;"
    },
    {
      "id": "tha-ap562:3.3",
      "pali": "Sadevamanussā sabbe,"
    },
    {
      "id": "tha-ap562:3.4",
      "pali": "buddhathūpaṁ akaṁsu te."
    },
    {
      "id": "tha-ap562:4.1",
      "pali": "Paṭhamā kañcanamayā,"
    },
    {
      "id": "tha-ap562:4.2",
      "pali": "dutiyā ca maṇimayā;"
    },
    {
      "id": "tha-ap562:4.3",
      "pali": "Tatiyā rūpiyamayā,"
    },
    {
      "id": "tha-ap562:4.4",
      "pali": "catutthī phalikāmayā."
    },
    {
      "id": "tha-ap562:5.1",
      "pali": "Tattha pañcamikā ceva,"
    },
    {
      "id": "tha-ap562:5.2",
      "pali": "lohitaṅkamayā ahu;"
    },
    {
      "id": "tha-ap562:5.3",
      "pali": "Chaṭṭhā masāragallassa,"
    },
    {
      "id": "tha-ap562:5.4",
      "pali": "sabbaṁ ratanamayūpari."
    },
    {
      "id": "tha-ap562:6.1",
      "pali": "Jaṅghā maṇimayā āsi,"
    },
    {
      "id": "tha-ap562:6.2",
      "pali": "vedikā ratanāmayā;"
    },
    {
      "id": "tha-ap562:6.3",
      "pali": "Sabbasoṇṇamayo thūpo,"
    },
    {
      "id": "tha-ap562:6.4",
      "pali": "uddhaṁ yojanamuggato."
    },
    {
      "id": "tha-ap562:7.1",
      "pali": "Devā tattha samāgantvā,"
    },
    {
      "id": "tha-ap562:7.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:7.3",
      "pali": "‘Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:7.4",
      "pali": "lokanāthassa tādino."
    },
    {
      "id": "tha-ap562:8.1",
      "pali": "Dhātu āveṇikā natthi,"
    },
    {
      "id": "tha-ap562:8.2",
      "pali": "sarīraṁ ekapiṇḍitaṁ;"
    },
    {
      "id": "tha-ap562:8.3",
      "pali": "Imamhi buddhathūpamhi,"
    },
    {
      "id": "tha-ap562:8.4",
      "pali": "kassāma kañcukaṁ mayaṁ’."
    },
    {
      "id": "tha-ap562:9.1",
      "pali": "Devā sattahi ratnehi,"
    },
    {
      "id": "tha-ap562:9.2",
      "pali": "aññaṁ vaḍḍhesuṁ yojanaṁ;"
    },
    {
      "id": "tha-ap562:9.3",
      "pali": "Thūpo dviyojanubbedho,"
    },
    {
      "id": "tha-ap562:9.4",
      "pali": "timiraṁ byapahanti so."
    },
    {
      "id": "tha-ap562:10.1",
      "pali": "Nāgā tattha samāgantvā,"
    },
    {
      "id": "tha-ap562:10.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:10.3",
      "pali": "‘Manussā ceva devā ca,"
    },
    {
      "id": "tha-ap562:10.4",
      "pali": "buddhathūpaṁ akaṁsu te."
    },
    {
      "id": "tha-ap562:11.1",
      "pali": "Mā no pamattā assumha,"
    },
    {
      "id": "tha-ap562:11.2",
      "pali": "appamattā sadevakā;"
    },
    {
      "id": "tha-ap562:11.3",
      "pali": "Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:11.4",
      "pali": "lokanāthassa tādino’."
    },
    {
      "id": "tha-ap562:12.1",
      "pali": "Indanīlaṁ mahānīlaṁ,"
    },
    {
      "id": "tha-ap562:12.2",
      "pali": "atho jotirasaṁ maṇiṁ;"
    },
    {
      "id": "tha-ap562:12.3",
      "pali": "Ekato sannipātetvā,"
    },
    {
      "id": "tha-ap562:12.4",
      "pali": "buddhathūpaṁ achādayuṁ."
    },
    {
      "id": "tha-ap562:13.1",
      "pali": "Sabbaṁ maṇimayaṁ āsi,"
    },
    {
      "id": "tha-ap562:13.2",
      "pali": "yāvatā buddhacetiyaṁ;"
    },
    {
      "id": "tha-ap562:13.3",
      "pali": "Tiyojanasamubbedhaṁ,"
    },
    {
      "id": "tha-ap562:13.4",
      "pali": "ālokakaraṇaṁ tadā."
    },
    {
      "id": "tha-ap562:14.1",
      "pali": "Garuḷā ca samāgantvā,"
    },
    {
      "id": "tha-ap562:14.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:14.3",
      "pali": "‘Manussā devanāgā ca,"
    },
    {
      "id": "tha-ap562:14.4",
      "pali": "buddhapūjaṁ akaṁsu te."
    },
    {
      "id": "tha-ap562:15.1",
      "pali": "Mā no pamattā assumha,"
    },
    {
      "id": "tha-ap562:15.2",
      "pali": "appamattā sadevakā;"
    },
    {
      "id": "tha-ap562:15.3",
      "pali": "Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:15.4",
      "pali": "lokanāthassa tādino’."
    },
    {
      "id": "tha-ap562:16.1",
      "pali": "Sabbaṁ maṇimayaṁ thūpaṁ,"
    },
    {
      "id": "tha-ap562:16.2",
      "pali": "akaruṁ te ca kañcukaṁ;"
    },
    {
      "id": "tha-ap562:16.3",
      "pali": "Yojanaṁ tepi vaḍḍhesuṁ,"
    },
    {
      "id": "tha-ap562:16.4",
      "pali": "āyataṁ buddhacetiyaṁ."
    },
    {
      "id": "tha-ap562:17.1",
      "pali": "Catuyojanamubbedho,"
    },
    {
      "id": "tha-ap562:17.2",
      "pali": "buddhathūpo virocati;"
    },
    {
      "id": "tha-ap562:17.3",
      "pali": "Obhāseti disā sabbā,"
    },
    {
      "id": "tha-ap562:17.4",
      "pali": "sataraṁsīva uggato."
    },
    {
      "id": "tha-ap562:18.1",
      "pali": "Kumbhaṇḍā ca samāgantvā,"
    },
    {
      "id": "tha-ap562:18.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:18.3",
      "pali": "‘Manussā ceva devā ca,"
    },
    {
      "id": "tha-ap562:18.4",
      "pali": "nāgā ca garuḷā tathā."
    },
    {
      "id": "tha-ap562:19.1",
      "pali": "Paccekaṁ buddhaseṭṭhassa,"
    },
    {
      "id": "tha-ap562:19.2",
      "pali": "akaṁsu thūpamuttamaṁ;"
    },
    {
      "id": "tha-ap562:19.3",
      "pali": "Mā no pamattā assumha,"
    },
    {
      "id": "tha-ap562:19.4",
      "pali": "appamattā sadevakā."
    },
    {
      "id": "tha-ap562:20.1",
      "pali": "Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:20.2",
      "pali": "lokanāthassa tādino;"
    },
    {
      "id": "tha-ap562:20.3",
      "pali": "Ratanehi chādessāma,"
    },
    {
      "id": "tha-ap562:20.4",
      "pali": "āyataṁ buddhacetiyaṁ’."
    },
    {
      "id": "tha-ap562:21.1",
      "pali": "Yojanaṁ tepi vaḍḍhesuṁ,"
    },
    {
      "id": "tha-ap562:21.2",
      "pali": "āyataṁ buddhacetiyaṁ;"
    },
    {
      "id": "tha-ap562:21.3",
      "pali": "Pañcayojanamubbedho,"
    },
    {
      "id": "tha-ap562:21.4",
      "pali": "thūpo obhāsate tadā."
    },
    {
      "id": "tha-ap562:22.1",
      "pali": "Yakkhā tattha samāgantvā,"
    },
    {
      "id": "tha-ap562:22.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:22.3",
      "pali": "‘Manussā devanāgā ca,"
    },
    {
      "id": "tha-ap562:22.4",
      "pali": "garuḷā ca kumbhaṇḍakā."
    },
    {
      "id": "tha-ap562:23.1",
      "pali": "Paccekaṁ buddhaseṭṭhassa,"
    },
    {
      "id": "tha-ap562:23.2",
      "pali": "akaṁsu thūpamuttamaṁ;"
    },
    {
      "id": "tha-ap562:23.3",
      "pali": "Mā no pamattā assumha,"
    },
    {
      "id": "tha-ap562:23.4",
      "pali": "appamattā sadevakā."
    },
    {
      "id": "tha-ap562:24.1",
      "pali": "Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:24.2",
      "pali": "lokanāthassa tādino;"
    },
    {
      "id": "tha-ap562:24.3",
      "pali": "Phalikā chādayissāma,"
    },
    {
      "id": "tha-ap562:24.4",
      "pali": "āyataṁ buddhacetiyaṁ’."
    },
    {
      "id": "tha-ap562:25.1",
      "pali": "Yojanaṁ tepi vaḍḍhesuṁ,"
    },
    {
      "id": "tha-ap562:25.2",
      "pali": "āyataṁ buddhacetiyaṁ;"
    },
    {
      "id": "tha-ap562:25.3",
      "pali": "Chayojanikamubbedho,"
    },
    {
      "id": "tha-ap562:25.4",
      "pali": "thūpo obhāsate tadā."
    },
    {
      "id": "tha-ap562:26.1",
      "pali": "Gandhabbā ca samāgantvā,"
    },
    {
      "id": "tha-ap562:26.2",
      "pali": "ekato mantayuṁ tadā;"
    },
    {
      "id": "tha-ap562:26.3",
      "pali": "‘Manujā devatā nāgā,"
    },
    {
      "id": "tha-ap562:26.4",
      "pali": "kumbhaṇḍā guyhakā tathā."
    },
    {
      "id": "tha-ap562:27.1",
      "pali": "Sabbe akaṁsu buddhathūpaṁ,"
    },
    {
      "id": "tha-ap562:27.2",
      "pali": "mayamettha akārakā;"
    },
    {
      "id": "tha-ap562:27.3",
      "pali": "Mayampi thūpaṁ kassāma,"
    },
    {
      "id": "tha-ap562:27.4",
      "pali": "lokanāthassa tādino’."
    },
    {
      "id": "tha-ap562:28.1",
      "pali": "Vediyo satta katvāna,"
    },
    {
      "id": "tha-ap562:28.2",
      "pali": "dhajaṁ chattaṁ akaṁsu te;"
    },
    {
      "id": "tha-ap562:28.3",
      "pali": "Sabbasoṇṇamayaṁ thūpaṁ,"
    },
    {
      "id": "tha-ap562:28.4",
      "pali": "gandhabbā kārayuṁ tadā."
    },
    {
      "id": "tha-ap562:29.1",
      "pali": "Sattayojanamubbedho,"
    },
    {
      "id": "tha-ap562:29.2",
      "pali": "thūpo obhāsate tadā;"
    },
    {
      "id": "tha-ap562:29.3",
      "pali": "Rattindivā na ñāyanti,"
    },
    {
      "id": "tha-ap562:29.4",
      "pali": "āloko hoti sabbadā."
    },
    {
      "id": "tha-ap562:30.1",
      "pali": "Abhibhonti na tassābhā,"
    },
    {
      "id": "tha-ap562:30.2",
      "pali": "candasūrā satārakā;"
    },
    {
      "id": "tha-ap562:30.3",
      "pali": "Samantā yojanasate,"
    },
    {
      "id": "tha-ap562:30.4",
      "pali": "padīpopi na pajjali."
    },
    {
      "id": "tha-ap562:31.1",
      "pali": "Tena kālena ye keci,"
    },
    {
      "id": "tha-ap562:31.2",
      "pali": "thūpaṁ pūjenti mānusā;"
    },
    {
      "id": "tha-ap562:31.3",
      "pali": "Na te thūpaṁ āruhanti,"
    },
    {
      "id": "tha-ap562:31.4",
      "pali": "ambare ukkhipanti te."
    },
    {
      "id": "tha-ap562:32.1",
      "pali": "Devehi ṭhapito yakkho,"
    },
    {
      "id": "tha-ap562:32.2",
      "pali": "abhisammatanāmako;"
    },
    {
      "id": "tha-ap562:32.3",
      "pali": "Dhajaṁ vā pupphadāmaṁ vā,"
    },
    {
      "id": "tha-ap562:32.4",
      "pali": "abhiropeti uttariṁ."
    },
    {
      "id": "tha-ap562:33.1",
      "pali": "Na te passanti taṁ yakkhaṁ,"
    },
    {
      "id": "tha-ap562:33.2",
      "pali": "dāmaṁ passanti gacchato;"
    },
    {
      "id": "tha-ap562:33.3",
      "pali": "Evaṁ passitvā gacchantā,"
    },
    {
      "id": "tha-ap562:33.4",
      "pali": "sabbe gacchanti suggatiṁ."
    },
    {
      "id": "tha-ap562:34.1",
      "pali": "Viruddhā ye pāvacane,"
    },
    {
      "id": "tha-ap562:34.2",
      "pali": "pasannā ye ca sāsane;"
    },
    {
      "id": "tha-ap562:34.3",
      "pali": "Pāṭihīraṁ daṭṭhukāmā,"
    },
    {
      "id": "tha-ap562:34.4",
      "pali": "thūpaṁ pūjenti mānusā."
    },
    {
      "id": "tha-ap562:35.1",
      "pali": "Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap562:35.2",
      "pali": "ahosiṁ bhatako tadā;"
    },
    {
      "id": "tha-ap562:35.3",
      "pali": "Āmoditaṁ janaṁ disvā,"
    },
    {
      "id": "tha-ap562:35.4",
      "pali": "evaṁ cintesahaṁ tadā."
    },
    {
      "id": "tha-ap562:36.1",
      "pali": "‘Uḷāro bhagavā neso,"
    },
    {
      "id": "tha-ap562:36.2",
      "pali": "yassa dhātughare disaṁ;"
    },
    {
      "id": "tha-ap562:36.3",
      "pali": "Imā ca janatā tuṭṭhā,"
    },
    {
      "id": "tha-ap562:36.4",
      "pali": "kāraṁ kubbaṁ na tappare."
    },
    {
      "id": "tha-ap562:37.1",
      "pali": "Ahampi kāraṁ kassāmi,"
    },
    {
      "id": "tha-ap562:37.2",
      "pali": "lokanāthassa tādino;"
    },
    {
      "id": "tha-ap562:37.3",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap562:37.4",
      "pali": "bhavissāmi anāgate’."
    },
    {
      "id": "tha-ap562:38.1",
      "pali": "Sudhotaṁ rajakenāhaṁ,"
    },
    {
      "id": "tha-ap562:38.2",
      "pali": "uttareyyaṁ paṭaṁ mama;"
    },
    {
      "id": "tha-ap562:38.3",
      "pali": "Veḷagge ālaggetvāna,"
    },
    {
      "id": "tha-ap562:38.4",
      "pali": "dhajaṁ ukkhipimambare."
    },
    {
      "id": "tha-ap562:39.1",
      "pali": "Abhisammatako gayha,"
    },
    {
      "id": "tha-ap562:39.2",
      "pali": "ambare hāsi me dhajaṁ;"
    },
    {
      "id": "tha-ap562:39.3",
      "pali": "Vāteritaṁ dhajaṁ disvā,"
    },
    {
      "id": "tha-ap562:39.4",
      "pali": "bhiyyo hāsaṁ janesahaṁ."
    },
    {
      "id": "tha-ap562:40.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap562:40.2",
      "pali": "samaṇaṁ upasaṅkamiṁ;"
    },
    {
      "id": "tha-ap562:40.3",
      "pali": "Taṁ bhikkhuṁ abhivādetvā,"
    },
    {
      "id": "tha-ap562:40.4",
      "pali": "vipākaṁ pucchahaṁ dhaje."
    },
    {
      "id": "tha-ap562:41.1",
      "pali": "So me kathesi ānandī,"
    },
    {
      "id": "tha-ap562:41.2",
      "pali": "pītisañjananaṁ mama;"
    },
    {
      "id": "tha-ap562:41.3",
      "pali": "‘Tassa dhajassa vipākaṁ,"
    },
    {
      "id": "tha-ap562:41.4",
      "pali": "anubhossasi sabbadā."
    },
    {
      "id": "tha-ap562:42.1",
      "pali": "Hatthiassarathāpattī,"
    },
    {
      "id": "tha-ap562:42.2",
      "pali": "senā ca caturaṅginī;"
    },
    {
      "id": "tha-ap562:42.3",
      "pali": "Parivāressanti taṁ niccaṁ,"
    },
    {
      "id": "tha-ap562:42.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap562:43.1",
      "pali": "Saṭṭhituriyasahassāni,"
    },
    {
      "id": "tha-ap562:43.2",
      "pali": "bheriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap562:43.3",
      "pali": "Parivāressanti taṁ niccaṁ,"
    },
    {
      "id": "tha-ap562:43.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap562:44.1",
      "pali": "Chaḷasītisahassāni,"
    },
    {
      "id": "tha-ap562:44.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap562:44.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "tha-ap562:44.4",
      "pali": "āmukkamaṇikuṇḍalā."
    },
    {
      "id": "tha-ap562:45.1",
      "pali": "Aḷārapamhā hasulā,"
    },
    {
      "id": "tha-ap562:45.2",
      "pali": "susaññā tanumajjhimā;"
    },
    {
      "id": "tha-ap562:45.3",
      "pali": "Parivāressanti taṁ niccaṁ,"
    },
    {
      "id": "tha-ap562:45.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap562:46.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap562:46.2",
      "pali": "devaloke ramissasi;"
    },
    {
      "id": "tha-ap562:46.3",
      "pali": "Asītikkhattuṁ devindo,"
    },
    {
      "id": "tha-ap562:46.4",
      "pali": "devarajjaṁ karissasi."
    },
    {
      "id": "tha-ap562:47.1",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap562:47.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap562:47.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap562:47.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap562:48.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap562:48.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap562:48.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap562:48.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap562:49.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap562:49.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap562:49.3",
      "pali": "Puññakammena saññutto,"
    },
    {
      "id": "tha-ap562:49.4",
      "pali": "brahmabandhu bhavissasi."
    },
    {
      "id": "tha-ap562:50.1",
      "pali": "Asītikoṭiṁ chaḍḍetvā,"
    },
    {
      "id": "tha-ap562:50.2",
      "pali": "dāse kammakare bahū;"
    },
    {
      "id": "tha-ap562:50.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap562:50.4",
      "pali": "sāsane pabbajissasi."
    },
    {
      "id": "tha-ap562:51.1",
      "pali": "Ārādhayitvā sambuddhaṁ,"
    },
    {
      "id": "tha-ap562:51.2",
      "pali": "gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap562:51.3",
      "pali": "Upavānoti nāmena,"
    },
    {
      "id": "tha-ap562:51.4",
      "pali": "hessasi satthu sāvako’."
    },
    {
      "id": "tha-ap562:52.1",
      "pali": "Satasahasse kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap562:52.2",
      "pali": "phalaṁ dassesi me idha;"
    },
    {
      "id": "tha-ap562:52.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap562:52.4",
      "pali": "kilese jhāpayiṁ mama."
    },
    {
      "id": "tha-ap562:53.1",
      "pali": "Cakkavattissa santassa,"
    },
    {
      "id": "tha-ap562:53.2",
      "pali": "cātuddīpissarassa me;"
    },
    {
      "id": "tha-ap562:53.3",
      "pali": "Tīṇi yojanāni sāmantā,"
    },
    {
      "id": "tha-ap562:53.4",
      "pali": "ussīyanti dhajā sadā."
    },
    {
      "id": "tha-ap562:54.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap562:54.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap562:54.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap562:54.4",
      "pali": "dhajadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap562:55.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap562:55.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap562:55.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap562:56.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap562:56.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap562:56.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap562:57.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap562:57.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap562:57.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap562:58.1",
      "pali": "Itthaṁ sudaṁ āyasmā upavānatthero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap562:59.1",
      "pali": "Upavānattherassāpadānaṁ dasamaṁ."
    }
  ]
}
