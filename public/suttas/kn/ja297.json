{
  "uid": "ja297",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja297:1.1",
      "pali": "“Ucce sakuṇa ḍemāna,"
    },
    {
      "id": "ja297:1.2",
      "pali": "pattayāna vihaṅgama;"
    },
    {
      "id": "ja297:1.3",
      "pali": "Vajjāsi kho tvaṁ vāmūruṁ,"
    },
    {
      "id": "ja297:1.4",
      "pali": "ciraṁ kho sā karissati."
    },
    {
      "id": "ja297:2.1",
      "pali": "Idaṁ kho sā na jānāti,"
    },
    {
      "id": "ja297:2.2",
      "pali": "asiṁ sattiñca oḍḍitaṁ;"
    },
    {
      "id": "ja297:2.3",
      "pali": "Sā caṇḍī kāhati kodhaṁ,"
    },
    {
      "id": "ja297:2.4",
      "pali": "taṁ me tapati no idaṁ."
    },
    {
      "id": "ja297:3.1",
      "pali": "Esa uppalasannāho,"
    },
    {
      "id": "ja297:3.2",
      "pali": "nikkhañcussīsakohitaṁ;"
    },
    {
      "id": "ja297:3.3",
      "pali": "Kāsikañca muduṁ vatthaṁ,"
    },
    {
      "id": "ja297:3.4",
      "pali": "tappetu dhanikā piyā”ti."
    },
    {
      "id": "ja297:4.1",
      "pali": "Kāmavilāpajātakaṁ sattamaṁ."
    }
  ]
}
