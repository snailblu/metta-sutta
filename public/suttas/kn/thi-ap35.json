{
  "uid": "thi-ap35",
  "title": "Sukkātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap35:1.1",
      "pali": "“Ekanavutito kappe,"
    },
    {
      "id": "thi-ap35:1.2",
      "pali": "vipassī nāma nāyako;"
    },
    {
      "id": "thi-ap35:1.3",
      "pali": "Uppajji cārudassano,"
    },
    {
      "id": "thi-ap35:1.4",
      "pali": "sabbadhammavipassako."
    },
    {
      "id": "thi-ap35:2.1",
      "pali": "Tadāhaṁ bandhumatiyaṁ,"
    },
    {
      "id": "thi-ap35:2.2",
      "pali": "jātā aññatare kule;"
    },
    {
      "id": "thi-ap35:2.3",
      "pali": "Dhammaṁ sutvāna munino,"
    },
    {
      "id": "thi-ap35:2.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap35:3.1",
      "pali": "Bahussutā dhammadharā,"
    },
    {
      "id": "thi-ap35:3.2",
      "pali": "paṭibhānavatī tathā;"
    },
    {
      "id": "thi-ap35:3.3",
      "pali": "Vicittakathikā cāpi,"
    },
    {
      "id": "thi-ap35:3.4",
      "pali": "jinasāsanakārikā."
    },
    {
      "id": "thi-ap35:4.1",
      "pali": "Tadā dhammakathaṁ katvā,"
    },
    {
      "id": "thi-ap35:4.2",
      "pali": "hitāya janataṁ bahuṁ;"
    },
    {
      "id": "thi-ap35:4.3",
      "pali": "Tato cutāhaṁ tusitaṁ,"
    },
    {
      "id": "thi-ap35:4.4",
      "pali": "upapannā yasassinī."
    },
    {
      "id": "thi-ap35:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "thi-ap35:5.2",
      "pali": "sikhī viya sikhī jino;"
    },
    {
      "id": "thi-ap35:5.3",
      "pali": "Tapanto yasasā loke,"
    },
    {
      "id": "thi-ap35:5.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap35:6.1",
      "pali": "Tadāpi pabbajitvāna,"
    },
    {
      "id": "thi-ap35:6.2",
      "pali": "buddhasāsanakovidā;"
    },
    {
      "id": "thi-ap35:6.3",
      "pali": "Jotetvā jinavākyāni,"
    },
    {
      "id": "thi-ap35:6.4",
      "pali": "tatopi tidivaṁ gatā."
    },
    {
      "id": "thi-ap35:7.1",
      "pali": "Ekattiṁseva kappamhi,"
    },
    {
      "id": "thi-ap35:7.2",
      "pali": "vessabhū nāma nāyako;"
    },
    {
      "id": "thi-ap35:7.3",
      "pali": "Uppajjittha mahāñāṇī,"
    },
    {
      "id": "thi-ap35:7.4",
      "pali": "tadāpi ca tathevahaṁ."
    },
    {
      "id": "thi-ap35:8.1",
      "pali": "Pabbajitvā dhammadharā,"
    },
    {
      "id": "thi-ap35:8.2",
      "pali": "jotayiṁ jinasāsanaṁ;"
    },
    {
      "id": "thi-ap35:8.3",
      "pali": "Gantvā marupuraṁ rammaṁ,"
    },
    {
      "id": "thi-ap35:8.4",
      "pali": "anubhosiṁ mahāsukhaṁ."
    },
    {
      "id": "thi-ap35:9.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap35:9.2",
      "pali": "kakusandho jinuttamo;"
    },
    {
      "id": "thi-ap35:9.3",
      "pali": "Uppajji narasaraṇo,"
    },
    {
      "id": "thi-ap35:9.4",
      "pali": "tadāpi ca tathevahaṁ."
    },
    {
      "id": "thi-ap35:10.1",
      "pali": "Pabbajitvā munimataṁ,"
    },
    {
      "id": "thi-ap35:10.2",
      "pali": "jotayitvā yathāyukaṁ;"
    },
    {
      "id": "thi-ap35:10.3",
      "pali": "Tato cutāhaṁ tidivaṁ,"
    },
    {
      "id": "thi-ap35:10.4",
      "pali": "agaṁ sabhavanaṁ yathā."
    },
    {
      "id": "thi-ap35:11.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "thi-ap35:11.2",
      "pali": "koṇāgamananāyako;"
    },
    {
      "id": "thi-ap35:11.3",
      "pali": "Uppajji lokasaraṇo,"
    },
    {
      "id": "thi-ap35:11.4",
      "pali": "araṇo amataṅgato."
    },
    {
      "id": "thi-ap35:12.1",
      "pali": "Tadāpi pabbajitvāna,"
    },
    {
      "id": "thi-ap35:12.2",
      "pali": "sāsane tassa tādino;"
    },
    {
      "id": "thi-ap35:12.3",
      "pali": "Bahussutā dhammadharā,"
    },
    {
      "id": "thi-ap35:12.4",
      "pali": "jotayiṁ jinasāsanaṁ."
    },
    {
      "id": "thi-ap35:13.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "thi-ap35:13.2",
      "pali": "kassapo munimuttamo;"
    },
    {
      "id": "thi-ap35:13.3",
      "pali": "Uppajji lokasaraṇo,"
    },
    {
      "id": "thi-ap35:13.4",
      "pali": "araṇo maraṇantagū."
    },
    {
      "id": "thi-ap35:14.1",
      "pali": "Tassāpi naravīrassa,"
    },
    {
      "id": "thi-ap35:14.2",
      "pali": "pabbajitvāna sāsane;"
    },
    {
      "id": "thi-ap35:14.3",
      "pali": "Pariyāpuṭasaddhammā,"
    },
    {
      "id": "thi-ap35:14.4",
      "pali": "paripucchā visāradā."
    },
    {
      "id": "thi-ap35:15.1",
      "pali": "Susīlā lajjinī ceva,"
    },
    {
      "id": "thi-ap35:15.2",
      "pali": "tīsu sikkhāsu kovidā;"
    },
    {
      "id": "thi-ap35:15.3",
      "pali": "Bahuṁ dhammakathaṁ katvā,"
    },
    {
      "id": "thi-ap35:15.4",
      "pali": "yāvajīvaṁ mahāmune."
    },
    {
      "id": "thi-ap35:16.1",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "thi-ap35:16.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap35:16.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap35:16.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap35:17.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap35:17.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "thi-ap35:17.3",
      "pali": "Jātā seṭṭhikule phīte,"
    },
    {
      "id": "thi-ap35:17.4",
      "pali": "mahāratanasañcaye."
    },
    {
      "id": "thi-ap35:18.1",
      "pali": "Yadā bhikkhusahassena,"
    },
    {
      "id": "thi-ap35:18.2",
      "pali": "parivuto lokanāyako;"
    },
    {
      "id": "thi-ap35:18.3",
      "pali": "Upāgami rājagahaṁ,"
    },
    {
      "id": "thi-ap35:18.4",
      "pali": "sahassakkhena vaṇṇito."
    },
    {
      "id": "thi-ap35:19.1",
      "pali": "Danto dantehi saha purāṇajaṭilehi,"
    },
    {
      "id": "thi-ap35:19.2",
      "pali": "Vippamutto vippamuttehi;"
    },
    {
      "id": "thi-ap35:19.3",
      "pali": "Siṅgīnikkhasavaṇṇo,"
    },
    {
      "id": "thi-ap35:19.4",
      "pali": "Rājagahaṁ pāvisi bhagavā."
    },
    {
      "id": "thi-ap35:20.1",
      "pali": "Disvā buddhānubhāvaṁ taṁ,"
    },
    {
      "id": "thi-ap35:20.2",
      "pali": "sutvāva guṇasañcayaṁ;"
    },
    {
      "id": "thi-ap35:20.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "thi-ap35:20.4",
      "pali": "pūjayiṁ taṁ yathābalaṁ."
    },
    {
      "id": "thi-ap35:21.1",
      "pali": "Aparena ca kālena,"
    },
    {
      "id": "thi-ap35:21.2",
      "pali": "dhammadinnāya santike;"
    },
    {
      "id": "thi-ap35:21.3",
      "pali": "Agārā nikkhamitvāna,"
    },
    {
      "id": "thi-ap35:21.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap35:22.1",
      "pali": "Kesesu chijjamānesu,"
    },
    {
      "id": "thi-ap35:22.2",
      "pali": "kilese jhāpayiṁ ahaṁ;"
    },
    {
      "id": "thi-ap35:22.3",
      "pali": "Uggahiṁ sāsanaṁ sabbaṁ,"
    },
    {
      "id": "thi-ap35:22.4",
      "pali": "pabbajitvā cirenahaṁ."
    },
    {
      "id": "thi-ap35:23.1",
      "pali": "Tato dhammamadesesiṁ,"
    },
    {
      "id": "thi-ap35:23.2",
      "pali": "mahājanasamāgame;"
    },
    {
      "id": "thi-ap35:23.3",
      "pali": "Dhamme desiyamānamhi,"
    },
    {
      "id": "thi-ap35:23.4",
      "pali": "dhammābhisamayo ahu."
    },
    {
      "id": "thi-ap35:24.1",
      "pali": "Nekapāṇasahassānaṁ,"
    },
    {
      "id": "thi-ap35:24.2",
      "pali": "taṁ viditvātivimhito;"
    },
    {
      "id": "thi-ap35:24.3",
      "pali": "Abhippasanno me yakkho,"
    },
    {
      "id": "thi-ap35:24.4",
      "pali": "bhamitvāna giribbajaṁ."
    },
    {
      "id": "thi-ap35:25.1",
      "pali": "Kiṁ me katā rājagahe manussā,"
    },
    {
      "id": "thi-ap35:25.2",
      "pali": "Madhuṁ pītāva acchare;"
    },
    {
      "id": "thi-ap35:25.3",
      "pali": "Ye sukkaṁ na upāsanti,"
    },
    {
      "id": "thi-ap35:25.4",
      "pali": "Desentiṁ amataṁ padaṁ."
    },
    {
      "id": "thi-ap35:26.1",
      "pali": "Tañca appaṭivānīyaṁ,"
    },
    {
      "id": "thi-ap35:26.2",
      "pali": "asecanakamojavaṁ;"
    },
    {
      "id": "thi-ap35:26.3",
      "pali": "Pivanti maññe sappaññā,"
    },
    {
      "id": "thi-ap35:26.4",
      "pali": "valāhakamivaddhagū."
    },
    {
      "id": "thi-ap35:27.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap35:27.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap35:27.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap35:27.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap35:28.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap35:28.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap35:28.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap35:28.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap35:29.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap35:29.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap35:29.3",
      "pali": "Ñāṇaṁ mama mahāvīra,"
    },
    {
      "id": "thi-ap35:29.4",
      "pali": "uppannaṁ tava santike."
    },
    {
      "id": "thi-ap35:30.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap35:30.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap35:30.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap35:31.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap35:31.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap35:31.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap35:32.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap35:32.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap35:32.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap35:33.1",
      "pali": "Itthaṁ sudaṁ sukkā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap35:34.1",
      "pali": "Sukkātheriyāpadānaṁ pañcamaṁ."
    },
    {
      "id": "thi-ap35:34.2",
      "pali": "Pañcamaṁ bhāṇavāraṁ."
    }
  ]
}
