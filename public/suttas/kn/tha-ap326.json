{
  "uid": "tha-ap326",
  "title": "Yaññasāmikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap326:1.1",
      "pali": "“Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap326:1.2",
      "pali": "ahosiṁ mantapāragū;"
    },
    {
      "id": "tha-ap326:1.3",
      "pali": "Kulavattaṁ adhāresiṁ,"
    },
    {
      "id": "tha-ap326:1.4",
      "pali": "yañño ussāhito mayā."
    },
    {
      "id": "tha-ap326:2.1",
      "pali": "Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap326:2.2",
      "pali": "pasū haññanti me tadā;"
    },
    {
      "id": "tha-ap326:2.3",
      "pali": "Sārathambhupanītāni,"
    },
    {
      "id": "tha-ap326:2.4",
      "pali": "yaññatthāya upaṭṭhitā."
    },
    {
      "id": "tha-ap326:3.1",
      "pali": "Ukkāmukhapahaṭṭhova,"
    },
    {
      "id": "tha-ap326:3.2",
      "pali": "khadiraṅgārasannibho;"
    },
    {
      "id": "tha-ap326:3.3",
      "pali": "Udayantova sūriyo,"
    },
    {
      "id": "tha-ap326:3.4",
      "pali": "puṇṇamāyeva candimā."
    },
    {
      "id": "tha-ap326:4.1",
      "pali": "Siddhattho sabbasiddhattho,"
    },
    {
      "id": "tha-ap326:4.2",
      "pali": "tilokamahito hito;"
    },
    {
      "id": "tha-ap326:4.3",
      "pali": "Upagantvāna sambuddho,"
    },
    {
      "id": "tha-ap326:4.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "tha-ap326:5.1",
      "pali": "‘Ahiṁsā sabbapāṇīnaṁ,"
    },
    {
      "id": "tha-ap326:5.2",
      "pali": "kumāra mama ruccati;"
    },
    {
      "id": "tha-ap326:5.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "tha-ap326:5.4",
      "pali": "majjapānā ca ārati."
    },
    {
      "id": "tha-ap326:6.1",
      "pali": "Rati ca samacariyāya,"
    },
    {
      "id": "tha-ap326:6.2",
      "pali": "bāhusaccaṁ kataññutā;"
    },
    {
      "id": "tha-ap326:6.3",
      "pali": "Diṭṭhe dhamme parattha ca,"
    },
    {
      "id": "tha-ap326:6.4",
      "pali": "dhammā ete pasaṁsiyā."
    },
    {
      "id": "tha-ap326:7.1",
      "pali": "Ete dhamme bhāvayitvā,"
    },
    {
      "id": "tha-ap326:7.2",
      "pali": "sabbasattahite rato;"
    },
    {
      "id": "tha-ap326:7.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap326:7.4",
      "pali": "bhāvehi maggamuttamaṁ’."
    },
    {
      "id": "tha-ap326:8.1",
      "pali": "Idaṁ vatvāna sabbaññū,"
    },
    {
      "id": "tha-ap326:8.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap326:8.3",
      "pali": "Mamevaṁ anusāsitvā,"
    },
    {
      "id": "tha-ap326:8.4",
      "pali": "vehāsaṁ uggato gato."
    },
    {
      "id": "tha-ap326:9.1",
      "pali": "Pubbe cittaṁ visodhetvā,"
    },
    {
      "id": "tha-ap326:9.2",
      "pali": "pacchā cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap326:9.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap326:9.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap326:10.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap326:10.2",
      "pali": "yadā cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap326:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap326:10.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap326:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap326:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap326:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap326:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā yaññasāmiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap326:13.1",
      "pali": "Yaññasāmikattherassāpadānaṁ catutthaṁ."
    }
  ]
}
