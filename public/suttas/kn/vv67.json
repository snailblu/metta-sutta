{
  "uid": "vv67",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv67:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv67:1.2",
      "pali": "Samantato soḷasa yojanāni;"
    },
    {
      "id": "vv67:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv67:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv67:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv67:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv67:2.3",
      "pali": "Aṭṭhaṭṭhakā sikkhitā sādhurūpā,"
    },
    {
      "id": "vv67:2.4",
      "pali": "Dibbā ca kaññā tidasacarā uḷārā;"
    },
    {
      "id": "vv67:2.5",
      "pali": "Naccanti gāyanti pamodayanti."
    },
    {
      "id": "vv67:3.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv67:3.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv67:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv67:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv67:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv67:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv67:4.3",
      "pali": "Yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv67:5.1",
      "pali": "“Phaladāyī phalaṁ vipulaṁ labhati,"
    },
    {
      "id": "vv67:5.2",
      "pali": "Dadamujugatesu pasannamānaso;"
    },
    {
      "id": "vv67:5.3",
      "pali": "So hi pamodati saggagato tidive,"
    },
    {
      "id": "vv67:5.4",
      "pali": "Anubhoti ca puññaphalaṁ vipulaṁ."
    },
    {
      "id": "vv67:6.1",
      "pali": "Tavevāhaṁ mahāmuni,"
    },
    {
      "id": "vv67:6.2",
      "pali": "Adāsiṁ caturo phale."
    },
    {
      "id": "vv67:7.1",
      "pali": "Tasmā hi phalaṁ alameva dātuṁ,"
    },
    {
      "id": "vv67:7.2",
      "pali": "Niccaṁ manussena sukhatthikena;"
    },
    {
      "id": "vv67:7.3",
      "pali": "Dibbāni vā patthayatā sukhāni,"
    },
    {
      "id": "vv67:7.4",
      "pali": "Manussasobhaggatamicchatā vā."
    },
    {
      "id": "vv67:8.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv67:8.2",
      "pali": "…pe…"
    },
    {
      "id": "vv67:8.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv67:9.1",
      "pali": "Phaladāyakavimānaṁ tatiyaṁ."
    }
  ]
}
