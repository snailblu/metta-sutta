{
  "uid": "ja12",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja12:1.1",
      "pali": "“Nigrodhameva seveyya,"
    },
    {
      "id": "ja12:1.2",
      "pali": "na sākhamupasaṁvase;"
    },
    {
      "id": "ja12:1.3",
      "pali": "Nigrodhasmiṁ mataṁ seyyo,"
    },
    {
      "id": "ja12:1.4",
      "pali": "yañce sākhasmi jīvitan”ti."
    },
    {
      "id": "ja12:2.1",
      "pali": "Nigrodhamigajātakaṁ dutiyaṁ."
    }
  ]
}
