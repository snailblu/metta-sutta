{
  "uid": "bv27",
  "title": "27. Gotamabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv27:1.1",
      "pali": "“Ahametarahi sambuddho,"
    },
    {
      "id": "bv27:1.2",
      "pali": "gotamo sakyavaḍḍhano;"
    },
    {
      "id": "bv27:1.3",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv27:1.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "bv27:2.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv27:2.2",
      "pali": "dhammacakkaṁ pavattayiṁ;"
    },
    {
      "id": "bv27:2.3",
      "pali": "Aṭṭhārasannaṁ koṭīnaṁ,"
    },
    {
      "id": "bv27:2.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv27:3.1",
      "pali": "Tato parañca desente,"
    },
    {
      "id": "bv27:3.2",
      "pali": "naradevasamāgame;"
    },
    {
      "id": "bv27:3.3",
      "pali": "Gaṇanāya na vattabbo,"
    },
    {
      "id": "bv27:3.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv27:4.1",
      "pali": "Idhevāhaṁ etarahi,"
    },
    {
      "id": "bv27:4.2",
      "pali": "ovadiṁ mama atrajaṁ;"
    },
    {
      "id": "bv27:4.3",
      "pali": "Gaṇanāya na vattabbo,"
    },
    {
      "id": "bv27:4.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv27:5.1",
      "pali": "Ekosi sannipāto me,"
    },
    {
      "id": "bv27:5.2",
      "pali": "sāvakānaṁ mahesinaṁ;"
    },
    {
      "id": "bv27:5.3",
      "pali": "Aḍḍhateḷasasatānaṁ,"
    },
    {
      "id": "bv27:5.4",
      "pali": "bhikkhūnāsi samāgamo."
    },
    {
      "id": "bv27:6.1",
      "pali": "Virocamāno vimalo,"
    },
    {
      "id": "bv27:6.2",
      "pali": "bhikkhusaṅghassa majjhago;"
    },
    {
      "id": "bv27:6.3",
      "pali": "Dadāmi patthitaṁ sabbaṁ,"
    },
    {
      "id": "bv27:6.4",
      "pali": "maṇīva sabbakāmado."
    },
    {
      "id": "bv27:7.1",
      "pali": "Phalamākaṅkhamānānaṁ,"
    },
    {
      "id": "bv27:7.2",
      "pali": "bhavacchandajahesinaṁ;"
    },
    {
      "id": "bv27:7.3",
      "pali": "Catusaccaṁ pakāsemi,"
    },
    {
      "id": "bv27:7.4",
      "pali": "anukampāya pāṇinaṁ."
    },
    {
      "id": "bv27:8.1",
      "pali": "Dasavīsasahassānaṁ,"
    },
    {
      "id": "bv27:8.2",
      "pali": "dhammābhisamayo ahu;"
    },
    {
      "id": "bv27:8.3",
      "pali": "Ekadvinnaṁ abhisamayo,"
    },
    {
      "id": "bv27:8.4",
      "pali": "gaṇanāto asaṅkhiyo."
    },
    {
      "id": "bv27:9.1",
      "pali": "Vitthārikaṁ bāhujaññaṁ,"
    },
    {
      "id": "bv27:9.2",
      "pali": "iddhaṁ phītaṁ suphullitaṁ;"
    },
    {
      "id": "bv27:9.3",
      "pali": "Idha mayhaṁ sakyamunino,"
    },
    {
      "id": "bv27:9.4",
      "pali": "sāsanaṁ suvisodhitaṁ."
    },
    {
      "id": "bv27:10.1",
      "pali": "Anāsavā vītarāgā,"
    },
    {
      "id": "bv27:10.2",
      "pali": "santacittā samāhitā;"
    },
    {
      "id": "bv27:10.3",
      "pali": "Bhikkhūnekasatā sabbe,"
    },
    {
      "id": "bv27:10.4",
      "pali": "parivārenti maṁ sadā."
    },
    {
      "id": "bv27:11.1",
      "pali": "Idāni ye etarahi,"
    },
    {
      "id": "bv27:11.2",
      "pali": "jahanti mānusaṁ bhavaṁ;"
    },
    {
      "id": "bv27:11.3",
      "pali": "Appattamānasā sekhā,"
    },
    {
      "id": "bv27:11.4",
      "pali": "te bhikkhū viññugarahitā."
    },
    {
      "id": "bv27:12.1",
      "pali": "Ariyañca santhomayantā,"
    },
    {
      "id": "bv27:12.2",
      "pali": "sadā dhammaratā janā;"
    },
    {
      "id": "bv27:12.3",
      "pali": "Bujjhissanti satimanto,"
    },
    {
      "id": "bv27:12.4",
      "pali": "saṁsārasaritaṁ gatā."
    },
    {
      "id": "bv27:13.1",
      "pali": "Nagaraṁ kapilavatthu me,"
    },
    {
      "id": "bv27:13.2",
      "pali": "rājā suddhodano pitā;"
    },
    {
      "id": "bv27:13.3",
      "pali": "Mayhaṁ janettikā mātā,"
    },
    {
      "id": "bv27:13.4",
      "pali": "māyādevīti vuccati."
    },
    {
      "id": "bv27:14.1",
      "pali": "Ekūnatiṁsavassāni,"
    },
    {
      "id": "bv27:14.2",
      "pali": "agāraṁ ajjhahaṁ vasiṁ;"
    },
    {
      "id": "bv27:14.3",
      "pali": "Rammo surammo subhako,"
    },
    {
      "id": "bv27:14.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv27:15.1",
      "pali": "Cattārīsasahassāni,"
    },
    {
      "id": "bv27:15.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv27:15.3",
      "pali": "Bhaddakañcanā nāma nārī,"
    },
    {
      "id": "bv27:15.4",
      "pali": "rāhulo nāma atrajo."
    },
    {
      "id": "bv27:16.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv27:16.2",
      "pali": "assayānena nikkhamiṁ;"
    },
    {
      "id": "bv27:16.3",
      "pali": "Chabbassaṁ padhānacāraṁ,"
    },
    {
      "id": "bv27:16.4",
      "pali": "acariṁ dukkaraṁ ahaṁ."
    },
    {
      "id": "bv27:17.1",
      "pali": "Bārāṇasiyaṁ isipatane,"
    },
    {
      "id": "bv27:17.2",
      "pali": "Cakkaṁ pavattitaṁ mayā;"
    },
    {
      "id": "bv27:17.3",
      "pali": "Ahaṁ gotamasambuddho,"
    },
    {
      "id": "bv27:17.4",
      "pali": "Saraṇaṁ sabbapāṇinaṁ."
    },
    {
      "id": "bv27:18.1",
      "pali": "Kolito upatisso ca,"
    },
    {
      "id": "bv27:18.2",
      "pali": "dve bhikkhū aggasāvakā;"
    },
    {
      "id": "bv27:18.3",
      "pali": "Ānando nāmupaṭṭhāko,"
    },
    {
      "id": "bv27:18.4",
      "pali": "santikāvacaro mama;"
    },
    {
      "id": "bv27:18.5",
      "pali": "Khemā uppalavaṇṇā ca,"
    },
    {
      "id": "bv27:18.6",
      "pali": "bhikkhunī aggasāvikā."
    },
    {
      "id": "bv27:19.1",
      "pali": "Citto hatthāḷavako ca,"
    },
    {
      "id": "bv27:19.2",
      "pali": "aggupaṭṭhākupāsakā;"
    },
    {
      "id": "bv27:19.3",
      "pali": "Nandamātā ca uttarā,"
    },
    {
      "id": "bv27:19.4",
      "pali": "aggupaṭṭhākupāsikā."
    },
    {
      "id": "bv27:20.1",
      "pali": "Ahaṁ assatthamūlamhi,"
    },
    {
      "id": "bv27:20.2",
      "pali": "patto sambodhimuttamaṁ;"
    },
    {
      "id": "bv27:20.3",
      "pali": "Byāmappabhā sadā mayhaṁ,"
    },
    {
      "id": "bv27:20.4",
      "pali": "soḷasahatthamuggatā."
    },
    {
      "id": "bv27:21.1",
      "pali": "Appaṁ vassasataṁ āyu,"
    },
    {
      "id": "bv27:21.2",
      "pali": "idānetarahi vijjati;"
    },
    {
      "id": "bv27:21.3",
      "pali": "Tāvatā tiṭṭhamānohaṁ,"
    },
    {
      "id": "bv27:21.4",
      "pali": "tāremi janataṁ bahuṁ."
    },
    {
      "id": "bv27:22.1",
      "pali": "Ṭhapayitvāna dhammukkaṁ,"
    },
    {
      "id": "bv27:22.2",
      "pali": "pacchimaṁ janabodhanaṁ;"
    },
    {
      "id": "bv27:22.3",
      "pali": "Ahampi nacirasseva,"
    },
    {
      "id": "bv27:22.4",
      "pali": "saddhiṁ sāvakasaṅghato;"
    },
    {
      "id": "bv27:22.5",
      "pali": "Idheva parinibbissaṁ,"
    },
    {
      "id": "bv27:22.6",
      "pali": "aggīvāhārasaṅkhayā."
    },
    {
      "id": "bv27:23.1",
      "pali": "Tāni ca atulatejāni,"
    },
    {
      "id": "bv27:23.2",
      "pali": "Imāni ca dasabalāni;"
    },
    {
      "id": "bv27:23.3",
      "pali": "Ayañca guṇadhāraṇo deho,"
    },
    {
      "id": "bv27:23.4",
      "pali": "Dvattiṁsavaralakkhaṇavicitto."
    },
    {
      "id": "bv27:24.1",
      "pali": "Dasa disā pabhāsetvā,"
    },
    {
      "id": "bv27:24.2",
      "pali": "Sataraṁsīva chappabhā;"
    },
    {
      "id": "bv27:24.3",
      "pali": "Sabbaṁ tamantarahissanti,"
    },
    {
      "id": "bv27:24.4",
      "pali": "Nanu rittā sabbasaṅkhārā”ti."
    },
    {
      "id": "bv27:25.1",
      "pali": "Gotamassa bhagavato vaṁso pañcavīsatimo."
    }
  ]
}
