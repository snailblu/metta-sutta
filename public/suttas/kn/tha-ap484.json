{
  "uid": "tha-ap484",
  "title": "Buddhasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap484:1.1",
      "pali": "“Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap484:1.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap484:1.3",
      "pali": "Lakkhaṇe itihāse ca,"
    },
    {
      "id": "tha-ap484:1.4",
      "pali": "sanighaṇḍusakeṭubhe."
    },
    {
      "id": "tha-ap484:2.1",
      "pali": "Nadīsotapaṭibhāgā,"
    },
    {
      "id": "tha-ap484:2.2",
      "pali": "sissā āyanti me tadā;"
    },
    {
      "id": "tha-ap484:2.3",
      "pali": "Tesāhaṁ mante vācemi,"
    },
    {
      "id": "tha-ap484:2.4",
      "pali": "rattindivamatandito."
    },
    {
      "id": "tha-ap484:3.1",
      "pali": "Siddhattho nāma sambuddho,"
    },
    {
      "id": "tha-ap484:3.2",
      "pali": "loke uppajji tāvade;"
    },
    {
      "id": "tha-ap484:3.3",
      "pali": "Tamandhakāraṁ nāsetvā,"
    },
    {
      "id": "tha-ap484:3.4",
      "pali": "ñāṇālokaṁ pavattayi."
    },
    {
      "id": "tha-ap484:4.1",
      "pali": "Mama aññataro sisso,"
    },
    {
      "id": "tha-ap484:4.2",
      "pali": "sissānaṁ so kathesi me;"
    },
    {
      "id": "tha-ap484:4.3",
      "pali": "Sutvāna te etamatthaṁ,"
    },
    {
      "id": "tha-ap484:4.4",
      "pali": "ārocesuṁ mamaṁ tadā."
    },
    {
      "id": "tha-ap484:5.1",
      "pali": "‘Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap484:5.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap484:5.3",
      "pali": "Tassānuvattati jano,"
    },
    {
      "id": "tha-ap484:5.4",
      "pali": "lābho amhaṁ na vijjati."
    },
    {
      "id": "tha-ap484:6.1",
      "pali": "Adhiccuppattikā buddhā,"
    },
    {
      "id": "tha-ap484:6.2",
      "pali": "cakkhumanto mahāyasā;"
    },
    {
      "id": "tha-ap484:6.3",
      "pali": "Yannūnāhaṁ buddhaseṭṭhaṁ,"
    },
    {
      "id": "tha-ap484:6.4",
      "pali": "passeyyaṁ lokanāyakaṁ’."
    },
    {
      "id": "tha-ap484:7.1",
      "pali": "Ajinaṁ me gahetvāna,"
    },
    {
      "id": "tha-ap484:7.2",
      "pali": "vākacīraṁ kamaṇḍaluṁ;"
    },
    {
      "id": "tha-ap484:7.3",
      "pali": "Assamā abhinikkhamma,"
    },
    {
      "id": "tha-ap484:7.4",
      "pali": "sisse āmantayiṁ ahaṁ."
    },
    {
      "id": "tha-ap484:8.1",
      "pali": "Odumbarikapupphaṁva,"
    },
    {
      "id": "tha-ap484:8.2",
      "pali": "candamhi sasakaṁ yathā;"
    },
    {
      "id": "tha-ap484:8.3",
      "pali": "Vāyasānaṁ yathā khīraṁ,"
    },
    {
      "id": "tha-ap484:8.4",
      "pali": "dullabho lokanāyako."
    },
    {
      "id": "tha-ap484:9.1",
      "pali": "Buddho lokamhi uppanno,"
    },
    {
      "id": "tha-ap484:9.2",
      "pali": "manussattampi dullabhaṁ;"
    },
    {
      "id": "tha-ap484:9.3",
      "pali": "Ubhosu vijjamānesu,"
    },
    {
      "id": "tha-ap484:9.4",
      "pali": "savanañca sudullabhaṁ."
    },
    {
      "id": "tha-ap484:10.1",
      "pali": "Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap484:10.2",
      "pali": "cakkhuṁ lacchāma no bhavaṁ;"
    },
    {
      "id": "tha-ap484:10.3",
      "pali": "Etha sabbe gamissāma,"
    },
    {
      "id": "tha-ap484:10.4",
      "pali": "sammāsambuddhasantikaṁ."
    },
    {
      "id": "tha-ap484:11.1",
      "pali": "Kamaṇḍaludharā sabbe,"
    },
    {
      "id": "tha-ap484:11.2",
      "pali": "kharājinanivāsino;"
    },
    {
      "id": "tha-ap484:11.3",
      "pali": "Te jaṭā bhārabharitā,"
    },
    {
      "id": "tha-ap484:11.4",
      "pali": "nikkhamuṁ vipinā tadā."
    },
    {
      "id": "tha-ap484:12.1",
      "pali": "Yugamattaṁ pekkhamānā,"
    },
    {
      "id": "tha-ap484:12.2",
      "pali": "uttamatthaṁ gavesino;"
    },
    {
      "id": "tha-ap484:12.3",
      "pali": "Āsattidosarahitā,"
    },
    {
      "id": "tha-ap484:12.4",
      "pali": "asambhītāva kesarī."
    },
    {
      "id": "tha-ap484:13.1",
      "pali": "Appakiccā aloluppā,"
    },
    {
      "id": "tha-ap484:13.2",
      "pali": "nipakā santavuttino;"
    },
    {
      "id": "tha-ap484:13.3",
      "pali": "Uñchāya caramānā te,"
    },
    {
      "id": "tha-ap484:13.4",
      "pali": "buddhaseṭṭhamupāgamuṁ."
    },
    {
      "id": "tha-ap484:14.1",
      "pali": "Diyaḍḍhayojane sese,"
    },
    {
      "id": "tha-ap484:14.2",
      "pali": "byādhi me upapajjatha;"
    },
    {
      "id": "tha-ap484:14.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap484:14.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap484:15.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap484:15.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap484:15.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap484:15.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap484:16.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap484:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap484:16.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap484:17.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap484:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap484:17.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap484:18.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap484:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap484:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap484:19.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap484:20.1",
      "pali": "Buddhasaññakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
