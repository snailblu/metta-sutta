{
  "uid": "ja240",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja240:1.1",
      "pali": "“Sabbo jano hiṁsito piṅgalena,"
    },
    {
      "id": "ja240:1.2",
      "pali": "Tasmiṁ mate paccayā vedayanti;"
    },
    {
      "id": "ja240:1.3",
      "pali": "Piyo nu te āsi akaṇhanetto,"
    },
    {
      "id": "ja240:1.4",
      "pali": "Kasmā nu tvaṁ rodasi dvārapāla”."
    },
    {
      "id": "ja240:2.1",
      "pali": "“Na me piyo āsi akaṇhanetto,"
    },
    {
      "id": "ja240:2.2",
      "pali": "Bhāyāmi paccāgamanāya tassa;"
    },
    {
      "id": "ja240:2.3",
      "pali": "Ito gato hiṁseyya maccurājaṁ,"
    },
    {
      "id": "ja240:2.4",
      "pali": "So hiṁsito āneyya puna idha”."
    },
    {
      "id": "ja240:3.1",
      "pali": "“Daḍḍho vāhasahassehi,"
    },
    {
      "id": "ja240:3.2",
      "pali": "sitto ghaṭasatehi so;"
    },
    {
      "id": "ja240:3.3",
      "pali": "Parikkhatā ca sā bhūmi,"
    },
    {
      "id": "ja240:3.4",
      "pali": "mā bhāyi nāgamissatī”ti."
    },
    {
      "id": "ja240:4.1",
      "pali": "Mahāpiṅgalajātakaṁ dasamaṁ."
    },
    {
      "id": "ja240:4.2",
      "pali": "Upāhanavaggo navamo."
    },
    {
      "id": "ja240:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja240:6.1",
      "pali": "Varupāhana khujja vikaṇṇakako,"
    },
    {
      "id": "ja240:6.2",
      "pali": "Asitābhuya pañcamavacchanakho;"
    },
    {
      "id": "ja240:6.3",
      "pali": "Dija pemavaruttamaekapadaṁ,"
    },
    {
      "id": "ja240:6.4",
      "pali": "Kumināmukha piṅgalakena dasāti."
    }
  ]
}
