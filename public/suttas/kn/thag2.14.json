{
  "uid": "thag2.14",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.14:1.1",
      "pali": "“Parittaṁ dārumāruyha,"
    },
    {
      "id": "thag2.14:1.2",
      "pali": "yathā sīde mahaṇṇave;"
    },
    {
      "id": "thag2.14:1.3",
      "pali": "Evaṁ kusītamāgamma,"
    },
    {
      "id": "thag2.14:1.4",
      "pali": "sādhujīvīpi sīdati;"
    },
    {
      "id": "thag2.14:1.5",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "thag2.14:1.6",
      "pali": "kusītaṁ hīnavīriyaṁ."
    },
    {
      "id": "thag2.14:2.1",
      "pali": "Pavivittehi ariyehi,"
    },
    {
      "id": "thag2.14:2.2",
      "pali": "pahitattehi jhāyibhi;"
    },
    {
      "id": "thag2.14:2.3",
      "pali": "Niccaṁ āraddhavīriyehi,"
    },
    {
      "id": "thag2.14:2.4",
      "pali": "paṇḍitehi sahāvase”ti."
    },
    {
      "id": "thag2.14:2.5",
      "pali": "… Somamitto thero …."
    }
  ]
}
