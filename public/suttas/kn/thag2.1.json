{
  "uid": "thag2.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.1:1.1",
      "pali": "“Natthi koci bhavo nicco,"
    },
    {
      "id": "thag2.1:1.2",
      "pali": "saṅkhārā vāpi sassatā;"
    },
    {
      "id": "thag2.1:1.3",
      "pali": "Uppajjanti ca te khandhā,"
    },
    {
      "id": "thag2.1:1.4",
      "pali": "cavanti aparāparaṁ."
    },
    {
      "id": "thag2.1:2.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "thag2.1:2.2",
      "pali": "bhavenamhi anatthiko;"
    },
    {
      "id": "thag2.1:2.3",
      "pali": "Nissaṭo sabbakāmehi,"
    },
    {
      "id": "thag2.1:2.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag2.1:2.5",
      "pali": "Itthaṁ sudaṁ āyasmā uttaro thero gāthāyo abhāsitthāti."
    }
  ]
}
