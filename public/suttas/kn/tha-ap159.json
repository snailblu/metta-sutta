{
  "uid": "tha-ap159",
  "title": "Tiṇasūlakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap159:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap159:1.2",
      "pali": "bhūtagaṇo nāma pabbato;"
    },
    {
      "id": "tha-ap159:1.3",
      "pali": "Vasateko jino tattha,"
    },
    {
      "id": "tha-ap159:1.4",
      "pali": "sayambhū lokanissaṭo."
    },
    {
      "id": "tha-ap159:2.1",
      "pali": "Tiṇasūlaṁ gahetvāna,"
    },
    {
      "id": "tha-ap159:2.2",
      "pali": "buddhassa abhiropayiṁ;"
    },
    {
      "id": "tha-ap159:2.3",
      "pali": "Ekūnasatasahassaṁ,"
    },
    {
      "id": "tha-ap159:2.4",
      "pali": "kappaṁ na vinipātiko."
    },
    {
      "id": "tha-ap159:3.1",
      "pali": "Ito ekādase kappe,"
    },
    {
      "id": "tha-ap159:3.2",
      "pali": "ekosiṁ dharaṇīruho;"
    },
    {
      "id": "tha-ap159:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap159:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap159:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap159:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap159:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap159:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇasūlako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap159:6.1",
      "pali": "Tiṇasūlakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
