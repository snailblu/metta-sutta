{
  "uid": "thag12.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag12.1:1.1",
      "pali": "“Sīlamevidha sikkhetha,"
    },
    {
      "id": "thag12.1:1.2",
      "pali": "asmiṁ loke susikkhitaṁ;"
    },
    {
      "id": "thag12.1:1.3",
      "pali": "Sīlañhi sabbasampattiṁ,"
    },
    {
      "id": "thag12.1:1.4",
      "pali": "upanāmeti sevitaṁ."
    },
    {
      "id": "thag12.1:2.1",
      "pali": "Sīlaṁ rakkheyya medhāvī,"
    },
    {
      "id": "thag12.1:2.2",
      "pali": "patthayāno tayo sukhe;"
    },
    {
      "id": "thag12.1:2.3",
      "pali": "Pasaṁsaṁ vittilābhañca,"
    },
    {
      "id": "thag12.1:2.4",
      "pali": "pecca sagge pamodanaṁ."
    },
    {
      "id": "thag12.1:3.1",
      "pali": "Sīlavā hi bahū mitte,"
    },
    {
      "id": "thag12.1:3.2",
      "pali": "saññamenādhigacchati;"
    },
    {
      "id": "thag12.1:3.3",
      "pali": "Dussīlo pana mittehi,"
    },
    {
      "id": "thag12.1:3.4",
      "pali": "dhaṁsate pāpamācaraṁ."
    },
    {
      "id": "thag12.1:4.1",
      "pali": "Avaṇṇañca akittiñca,"
    },
    {
      "id": "thag12.1:4.2",
      "pali": "dussīlo labhate naro;"
    },
    {
      "id": "thag12.1:4.3",
      "pali": "Vaṇṇaṁ kittiṁ pasaṁsañca,"
    },
    {
      "id": "thag12.1:4.4",
      "pali": "sadā labhati sīlavā."
    },
    {
      "id": "thag12.1:5.1",
      "pali": "Ādi sīlaṁ patiṭṭhā ca,"
    },
    {
      "id": "thag12.1:5.2",
      "pali": "kalyāṇānañca mātukaṁ;"
    },
    {
      "id": "thag12.1:5.3",
      "pali": "Pamukhaṁ sabbadhammānaṁ,"
    },
    {
      "id": "thag12.1:5.4",
      "pali": "tasmā sīlaṁ visodhaye."
    },
    {
      "id": "thag12.1:6.1",
      "pali": "Velā ca saṁvaraṁ sīlaṁ,"
    },
    {
      "id": "thag12.1:6.2",
      "pali": "cittassa abhihāsanaṁ;"
    },
    {
      "id": "thag12.1:6.3",
      "pali": "Titthañca sabbabuddhānaṁ,"
    },
    {
      "id": "thag12.1:6.4",
      "pali": "tasmā sīlaṁ visodhaye."
    },
    {
      "id": "thag12.1:7.1",
      "pali": "Sīlaṁ balaṁ appaṭimaṁ,"
    },
    {
      "id": "thag12.1:7.2",
      "pali": "sīlaṁ āvudhamuttamaṁ;"
    },
    {
      "id": "thag12.1:7.3",
      "pali": "Sīlamābharaṇaṁ seṭṭhaṁ,"
    },
    {
      "id": "thag12.1:7.4",
      "pali": "sīlaṁ kavacamabbhutaṁ."
    },
    {
      "id": "thag12.1:8.1",
      "pali": "Sīlaṁ setu mahesakkho,"
    },
    {
      "id": "thag12.1:8.2",
      "pali": "sīlaṁ gandho anuttaro;"
    },
    {
      "id": "thag12.1:8.3",
      "pali": "Sīlaṁ vilepanaṁ seṭṭhaṁ,"
    },
    {
      "id": "thag12.1:8.4",
      "pali": "yena vāti disodisaṁ."
    },
    {
      "id": "thag12.1:9.1",
      "pali": "Sīlaṁ sambalamevaggaṁ,"
    },
    {
      "id": "thag12.1:9.2",
      "pali": "sīlaṁ pātheyyamuttamaṁ;"
    },
    {
      "id": "thag12.1:9.3",
      "pali": "Sīlaṁ seṭṭho ativāho,"
    },
    {
      "id": "thag12.1:9.4",
      "pali": "yena yāti disodisaṁ."
    },
    {
      "id": "thag12.1:10.1",
      "pali": "Idheva nindaṁ labhati,"
    },
    {
      "id": "thag12.1:10.2",
      "pali": "peccāpāye ca dummano;"
    },
    {
      "id": "thag12.1:10.3",
      "pali": "Sabbattha dummano bālo,"
    },
    {
      "id": "thag12.1:10.4",
      "pali": "sīlesu asamāhito."
    },
    {
      "id": "thag12.1:11.1",
      "pali": "Idheva kittiṁ labhati,"
    },
    {
      "id": "thag12.1:11.2",
      "pali": "pecca sagge ca summano;"
    },
    {
      "id": "thag12.1:11.3",
      "pali": "Sabbattha sumano dhīro,"
    },
    {
      "id": "thag12.1:11.4",
      "pali": "sīlesu susamāhito."
    },
    {
      "id": "thag12.1:12.1",
      "pali": "Sīlameva idha aggaṁ,"
    },
    {
      "id": "thag12.1:12.2",
      "pali": "paññavā pana uttamo;"
    },
    {
      "id": "thag12.1:12.3",
      "pali": "Manussesu ca devesu,"
    },
    {
      "id": "thag12.1:12.4",
      "pali": "sīlapaññāṇato jayan”ti."
    },
    {
      "id": "thag12.1:12.5",
      "pali": "… Sīlavo thero …."
    }
  ]
}
