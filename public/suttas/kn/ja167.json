{
  "uid": "ja167",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja167:1.1",
      "pali": "“Abhutvā bhikkhasi bhikkhu,"
    },
    {
      "id": "ja167:1.2",
      "pali": "Na hi bhutvāna bhikkhasi;"
    },
    {
      "id": "ja167:1.3",
      "pali": "Bhutvāna bhikkhu bhikkhassu,"
    },
    {
      "id": "ja167:1.4",
      "pali": "Mā taṁ kālo upaccagā."
    },
    {
      "id": "ja167:2.1",
      "pali": "Kālaṁ vohaṁ na jānāmi,"
    },
    {
      "id": "ja167:2.2",
      "pali": "channo kālo na dissati;"
    },
    {
      "id": "ja167:2.3",
      "pali": "Tasmā abhutvā bhikkhāmi,"
    },
    {
      "id": "ja167:2.4",
      "pali": "mā maṁ kālo upaccagā”ti."
    },
    {
      "id": "ja167:3.1",
      "pali": "Samiddhijātakaṁ sattamaṁ."
    }
  ]
}
