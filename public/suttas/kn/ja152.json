{
  "uid": "ja152",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja152:1.1",
      "pali": "“Asamekkhitakammantaṁ,"
    },
    {
      "id": "ja152:1.2",
      "pali": "turitābhinipātinaṁ;"
    },
    {
      "id": "ja152:1.3",
      "pali": "Sāni kammāni tappenti,"
    },
    {
      "id": "ja152:1.4",
      "pali": "uṇhaṁvajjhohitaṁ mukhe”."
    },
    {
      "id": "ja152:2.1",
      "pali": "“Sīho ca sīhanādena,"
    },
    {
      "id": "ja152:2.2",
      "pali": "daddaraṁ abhinādayi;"
    },
    {
      "id": "ja152:2.3",
      "pali": "Sutvā sīhassa nigghosaṁ,"
    },
    {
      "id": "ja152:2.4",
      "pali": "siṅgālo daddare vasaṁ;"
    },
    {
      "id": "ja152:2.5",
      "pali": "Bhīto santāsamāpādi,"
    },
    {
      "id": "ja152:2.6",
      "pali": "hadayañcassa apphalī”ti."
    },
    {
      "id": "ja152:3.1",
      "pali": "Siṅgālajātakaṁ dutiyaṁ."
    }
  ]
}
