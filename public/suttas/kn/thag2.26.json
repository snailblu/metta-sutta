{
  "uid": "thag2.26",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.26:1.1",
      "pali": "“Pañca nīvaraṇe hitvā,"
    },
    {
      "id": "thag2.26:1.2",
      "pali": "yogakkhemassa pattiyā;"
    },
    {
      "id": "thag2.26:1.3",
      "pali": "Dhammādāsaṁ gahetvāna,"
    },
    {
      "id": "thag2.26:1.4",
      "pali": "ñāṇadassanamattano."
    },
    {
      "id": "thag2.26:2.1",
      "pali": "Paccavekkhiṁ imaṁ kāyaṁ,"
    },
    {
      "id": "thag2.26:2.2",
      "pali": "sabbaṁ santarabāhiraṁ;"
    },
    {
      "id": "thag2.26:2.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "thag2.26:2.4",
      "pali": "tuccho kāyo adissathā”ti."
    },
    {
      "id": "thag2.26:2.5",
      "pali": "… Puṇṇamāso thero …."
    }
  ]
}
