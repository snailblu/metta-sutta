{
  "uid": "ja460",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja460:1.1",
      "pali": "“Mittāmaccaparibyūḷhaṁ,"
    },
    {
      "id": "ja460:1.2",
      "pali": "ahaṁ vande rathesabhaṁ;"
    },
    {
      "id": "ja460:1.3",
      "pali": "Pabbajissāmahaṁ rāja,"
    },
    {
      "id": "ja460:1.4",
      "pali": "taṁ devo anumaññatu”."
    },
    {
      "id": "ja460:2.1",
      "pali": "“Sace te ūnaṁ kāmehi,"
    },
    {
      "id": "ja460:2.2",
      "pali": "ahaṁ paripūrayāmi te;"
    },
    {
      "id": "ja460:2.3",
      "pali": "Yo taṁ hiṁsati vāremi,"
    },
    {
      "id": "ja460:2.4",
      "pali": "mā pabbaja yudhañcaya”."
    },
    {
      "id": "ja460:3.1",
      "pali": "“Na matthi ūnaṁ kāmehi,"
    },
    {
      "id": "ja460:3.2",
      "pali": "hiṁsitā me na vijjati;"
    },
    {
      "id": "ja460:3.3",
      "pali": "Dīpañca kātumicchāmi,"
    },
    {
      "id": "ja460:3.4",
      "pali": "yaṁ jarā nābhikīrati”."
    },
    {
      "id": "ja460:4.1",
      "pali": "“Putto vā pitaraṁ yāce,"
    },
    {
      "id": "ja460:4.2",
      "pali": "pitā vā puttamorasaṁ;"
    },
    {
      "id": "ja460:4.3",
      "pali": "Negamo taṁ yāce tāta,"
    },
    {
      "id": "ja460:4.4",
      "pali": "mā pabbaja yudhañcaya”."
    },
    {
      "id": "ja460:5.1",
      "pali": "“Mā maṁ deva nivārehi,"
    },
    {
      "id": "ja460:5.2",
      "pali": "pabbajantaṁ rathesabha;"
    },
    {
      "id": "ja460:5.3",
      "pali": "Māhaṁ kāmehi sammatto,"
    },
    {
      "id": "ja460:5.4",
      "pali": "jarāya vasamanvagū”."
    },
    {
      "id": "ja460:6.1",
      "pali": "“Ahaṁ taṁ tāta yācāmi,"
    },
    {
      "id": "ja460:6.2",
      "pali": "ahaṁ putta nivāraye;"
    },
    {
      "id": "ja460:6.3",
      "pali": "Ciraṁ taṁ daṭṭhumicchāmi,"
    },
    {
      "id": "ja460:6.4",
      "pali": "mā pabbaja yudhañcaya”."
    },
    {
      "id": "ja460:7.1",
      "pali": "“Ussāvova tiṇaggamhi,"
    },
    {
      "id": "ja460:7.2",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "ja460:7.3",
      "pali": "Evamāyu manussānaṁ,"
    },
    {
      "id": "ja460:7.4",
      "pali": "mā maṁ amma nivāraya”."
    },
    {
      "id": "ja460:8.1",
      "pali": "“Taramāno imaṁ yānaṁ,"
    },
    {
      "id": "ja460:8.2",
      "pali": "āropetu rathesabha;"
    },
    {
      "id": "ja460:8.3",
      "pali": "Mā me mātā tarantassa,"
    },
    {
      "id": "ja460:8.4",
      "pali": "antarāyakarā ahu”."
    },
    {
      "id": "ja460:9.1",
      "pali": "“Abhidhāvatha bhaddante,"
    },
    {
      "id": "ja460:9.2",
      "pali": "suññaṁ hessati rammakaṁ;"
    },
    {
      "id": "ja460:9.3",
      "pali": "Yudhañcayo anuññāto,"
    },
    {
      "id": "ja460:9.4",
      "pali": "sabbadattena rājinā."
    },
    {
      "id": "ja460:10.1",
      "pali": "Yohu seṭṭho sahassassa,"
    },
    {
      "id": "ja460:10.2",
      "pali": "yuvā kañcanasannibho;"
    },
    {
      "id": "ja460:10.3",
      "pali": "Soyaṁ kumāro pabbajito,"
    },
    {
      "id": "ja460:10.4",
      "pali": "kāsāyavasano balī”."
    },
    {
      "id": "ja460:11.1",
      "pali": "“Ubho kumārā pabbajitā,"
    },
    {
      "id": "ja460:11.2",
      "pali": "yudhañcayo yudhiṭṭhilo;"
    },
    {
      "id": "ja460:11.3",
      "pali": "Pahāya mātāpitaro,"
    },
    {
      "id": "ja460:11.4",
      "pali": "saṅgaṁ chetvāna maccuno”ti."
    },
    {
      "id": "ja460:12.1",
      "pali": "Yudhañcayajātakaṁ chaṭṭhaṁ."
    }
  ]
}
