{
  "uid": "tha-ap280",
  "title": "Āluvadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap280:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap280:1.2",
      "pali": "mahāsindhu sudassanā;"
    },
    {
      "id": "tha-ap280:1.3",
      "pali": "Tatthaddasaṁ vītarāgaṁ,"
    },
    {
      "id": "tha-ap280:1.4",
      "pali": "suppabhāsaṁ sudassanaṁ."
    },
    {
      "id": "tha-ap280:2.1",
      "pali": "Paramopasame yuttaṁ,"
    },
    {
      "id": "tha-ap280:2.2",
      "pali": "disvā vimhitamānaso;"
    },
    {
      "id": "tha-ap280:2.3",
      "pali": "Āluvaṁ tassa pādāsiṁ,"
    },
    {
      "id": "tha-ap280:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap280:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap280:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap280:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap280:3.4",
      "pali": "āluvassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap280:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap280:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap280:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap280:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā āluvadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap280:6.1",
      "pali": "Āluvadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
