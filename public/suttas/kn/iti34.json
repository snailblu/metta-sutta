{
  "uid": "iti34",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti34:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti34:2.1",
      "pali": "“Anātāpī, bhikkhave, bhikkhu anottāpī abhabbo sambodhāya, abhabbo nibbānāya, abhabbo anuttarassa yogakkhemassa adhigamāya."
    },
    {
      "id": "iti34:2.2",
      "pali": "Ātāpī ca kho, bhikkhave, bhikkhu ottāpī bhabbo sambodhāya, bhabbo nibbānāya, bhabbo anuttarassa yogakkhemassa adhigamāyā”ti."
    },
    {
      "id": "iti34:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti34:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti34:3.1",
      "pali": "“Anātāpī anottāpī,"
    },
    {
      "id": "iti34:3.2",
      "pali": "kusīto hīnavīriyo;"
    },
    {
      "id": "iti34:3.3",
      "pali": "Yo thinamiddhabahulo,"
    },
    {
      "id": "iti34:3.4",
      "pali": "ahirīko anādaro;"
    },
    {
      "id": "iti34:3.5",
      "pali": "Abhabbo tādiso bhikkhu,"
    },
    {
      "id": "iti34:3.6",
      "pali": "phuṭṭhuṁ sambodhimuttamaṁ."
    },
    {
      "id": "iti34:4.1",
      "pali": "Yo ca satimā nipako jhāyī,"
    },
    {
      "id": "iti34:4.2",
      "pali": "Ātāpī ottāpī ca appamatto;"
    },
    {
      "id": "iti34:4.3",
      "pali": "Saṁyojanaṁ jātijarāya chetvā,"
    },
    {
      "id": "iti34:4.4",
      "pali": "Idheva sambodhimanuttaraṁ phuse”ti."
    },
    {
      "id": "iti34:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti34:5.2",
      "pali": "Sattamaṁ."
    }
  ]
}
