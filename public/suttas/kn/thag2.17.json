{
  "uid": "thag2.17",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.17:1.1",
      "pali": "“Bahū sapatte labhati,"
    },
    {
      "id": "thag2.17:1.2",
      "pali": "muṇḍo saṅghāṭipāruto;"
    },
    {
      "id": "thag2.17:1.3",
      "pali": "Lābhī annassa pānassa,"
    },
    {
      "id": "thag2.17:1.4",
      "pali": "vatthassa sayanassa ca."
    },
    {
      "id": "thag2.17:2.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "thag2.17:2.2",
      "pali": "sakkāresu mahabbhayaṁ;"
    },
    {
      "id": "thag2.17:2.3",
      "pali": "Appalābho anavassuto,"
    },
    {
      "id": "thag2.17:2.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "thag2.17:2.5",
      "pali": "… Tisso thero …."
    }
  ]
}
