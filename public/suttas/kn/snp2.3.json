{
  "uid": "snp2.3",
  "title": "Hirisutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.3:1.1",
      "pali": "Hiriṁ tarantaṁ vijigucchamānaṁ,"
    },
    {
      "id": "snp2.3:1.2",
      "pali": "Tavāhamasmi iti bhāsamānaṁ;"
    },
    {
      "id": "snp2.3:1.3",
      "pali": "Sayhāni kammāni anādiyantaṁ,"
    },
    {
      "id": "snp2.3:1.4",
      "pali": "Neso mamanti iti naṁ vijaññā."
    },
    {
      "id": "snp2.3:2.1",
      "pali": "Ananvayaṁ piyaṁ vācaṁ,"
    },
    {
      "id": "snp2.3:2.2",
      "pali": "yo mittesu pakubbati;"
    },
    {
      "id": "snp2.3:2.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "snp2.3:2.4",
      "pali": "parijānanti paṇḍitā."
    },
    {
      "id": "snp2.3:3.1",
      "pali": "Na so mitto yo sadā appamatto,"
    },
    {
      "id": "snp2.3:3.2",
      "pali": "Bhedāsaṅkī randhamevānupassī;"
    },
    {
      "id": "snp2.3:3.3",
      "pali": "Yasmiñca seti urasīva putto,"
    },
    {
      "id": "snp2.3:3.4",
      "pali": "Sa ve mitto yo parehi abhejjo."
    },
    {
      "id": "snp2.3:4.1",
      "pali": "Pāmujjakaraṇaṁ ṭhānaṁ,"
    },
    {
      "id": "snp2.3:4.2",
      "pali": "pasaṁsāvahanaṁ sukhaṁ;"
    },
    {
      "id": "snp2.3:4.3",
      "pali": "Phalānisaṁso bhāveti,"
    },
    {
      "id": "snp2.3:4.4",
      "pali": "vahanto porisaṁ dhuraṁ."
    },
    {
      "id": "snp2.3:5.1",
      "pali": "Pavivekarasaṁ pitvā,"
    },
    {
      "id": "snp2.3:5.2",
      "pali": "Rasaṁ upasamassa ca;"
    },
    {
      "id": "snp2.3:5.3",
      "pali": "Niddaro hoti nippāpo,"
    },
    {
      "id": "snp2.3:5.4",
      "pali": "Dhammapītirasaṁ pivanti."
    },
    {
      "id": "snp2.3:5.5",
      "pali": "Hirisuttaṁ tatiyaṁ."
    }
  ]
}
