{
  "uid": "tha-ap555",
  "title": "Gayākassapattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap555:1.1",
      "pali": "“Ajinacammavatthohaṁ,"
    },
    {
      "id": "tha-ap555:1.2",
      "pali": "khāribhāradharo tadā;"
    },
    {
      "id": "tha-ap555:1.3",
      "pali": "Khārikaṁ hārayitvāna,"
    },
    {
      "id": "tha-ap555:1.4",
      "pali": "kolaṁ ahāsi assamaṁ."
    },
    {
      "id": "tha-ap555:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap555:2.2",
      "pali": "eko adutiyo jino;"
    },
    {
      "id": "tha-ap555:2.3",
      "pali": "Mamassamaṁ upāgacchi,"
    },
    {
      "id": "tha-ap555:2.4",
      "pali": "jotento sabbakālikaṁ."
    },
    {
      "id": "tha-ap555:3.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap555:3.2",
      "pali": "abhivādetvāna subbataṁ;"
    },
    {
      "id": "tha-ap555:3.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap555:3.4",
      "pali": "kolaṁ buddhassadāsahaṁ."
    },
    {
      "id": "tha-ap555:4.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap555:4.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap555:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap555:4.4",
      "pali": "koladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap555:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap555:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap555:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap555:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap555:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap555:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap555:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap555:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap555:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap555:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā gayākassapo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap555:9.1",
      "pali": "Gayākassapattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
