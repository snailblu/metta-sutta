{
  "uid": "ja122",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja122:1.1",
      "pali": "“Yasaṁ laddhāna dummedho,"
    },
    {
      "id": "ja122:1.2",
      "pali": "anatthaṁ carati attano;"
    },
    {
      "id": "ja122:1.3",
      "pali": "Attano ca paresañca,"
    },
    {
      "id": "ja122:1.4",
      "pali": "hiṁsāya paṭipajjatī”ti."
    },
    {
      "id": "ja122:2.1",
      "pali": "Dummedhajātakaṁ dutiyaṁ."
    }
  ]
}
