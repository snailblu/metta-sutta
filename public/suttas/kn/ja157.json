{
  "uid": "ja157",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja157:1.1",
      "pali": "“Yena kāmaṁ paṇāmeti,"
    },
    {
      "id": "ja157:1.2",
      "pali": "dhammo balavataṁ migī;"
    },
    {
      "id": "ja157:1.3",
      "pali": "Unnadantī vijānāhi,"
    },
    {
      "id": "ja157:1.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja157:2.1",
      "pali": "“Api cepi dubbalo mitto,"
    },
    {
      "id": "ja157:2.2",
      "pali": "mittadhammesu tiṭṭhati;"
    },
    {
      "id": "ja157:2.3",
      "pali": "So ñātako ca bandhu ca,"
    },
    {
      "id": "ja157:2.4",
      "pali": "so mitto so ca me sakhā;"
    },
    {
      "id": "ja157:2.5",
      "pali": "Dāṭhini mātimaññittho,"
    },
    {
      "id": "ja157:2.6",
      "pali": "siṅgālo mama pāṇado”ti."
    },
    {
      "id": "ja157:3.1",
      "pali": "Guṇajātakaṁ sattamaṁ."
    }
  ]
}
