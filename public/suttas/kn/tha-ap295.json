{
  "uid": "tha-ap295",
  "title": "Chattadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap295:1.1",
      "pali": "“Putto mama pabbajito,"
    },
    {
      "id": "tha-ap295:1.2",
      "pali": "kāsāyavasano tadā;"
    },
    {
      "id": "tha-ap295:1.3",
      "pali": "So ca buddhattaṁ sampatto,"
    },
    {
      "id": "tha-ap295:1.4",
      "pali": "nibbuto lokapūjito."
    },
    {
      "id": "tha-ap295:2.1",
      "pali": "Vicinanto sakaṁ puttaṁ,"
    },
    {
      "id": "tha-ap295:2.2",
      "pali": "agamaṁ pacchato ahaṁ;"
    },
    {
      "id": "tha-ap295:2.3",
      "pali": "Nibbutassa mahantassa,"
    },
    {
      "id": "tha-ap295:2.4",
      "pali": "citakaṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap295:3.1",
      "pali": "Paggayha añjaliṁ tattha,"
    },
    {
      "id": "tha-ap295:3.2",
      "pali": "vanditvā citakaṁ ahaṁ;"
    },
    {
      "id": "tha-ap295:3.3",
      "pali": "Setacchattañca paggayha,"
    },
    {
      "id": "tha-ap295:3.4",
      "pali": "āropesiṁ ahaṁ tadā."
    },
    {
      "id": "tha-ap295:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap295:4.2",
      "pali": "yaṁ chattamabhiropayiṁ;"
    },
    {
      "id": "tha-ap295:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap295:4.4",
      "pali": "chattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap295:5.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap295:5.2",
      "pali": "satta āsuṁ janādhipā;"
    },
    {
      "id": "tha-ap295:5.3",
      "pali": "Mahārahasanāmā te,"
    },
    {
      "id": "tha-ap295:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap295:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap295:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap295:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap295:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā chattadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap295:8.1",
      "pali": "Chattadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
