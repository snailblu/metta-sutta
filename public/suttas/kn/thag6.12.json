{
  "uid": "thag6.12",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.12:1.1",
      "pali": "“Akkodhassa kuto kodho,"
    },
    {
      "id": "thag6.12:1.2",
      "pali": "dantassa samajīvino;"
    },
    {
      "id": "thag6.12:1.3",
      "pali": "Sammadaññāvimuttassa,"
    },
    {
      "id": "thag6.12:1.4",
      "pali": "upasantassa tādino."
    },
    {
      "id": "thag6.12:2.1",
      "pali": "Tasseva tena pāpiyo,"
    },
    {
      "id": "thag6.12:2.2",
      "pali": "yo kuddhaṁ paṭikujjhati;"
    },
    {
      "id": "thag6.12:2.3",
      "pali": "Kuddhaṁ appaṭikujjhanto,"
    },
    {
      "id": "thag6.12:2.4",
      "pali": "saṅgāmaṁ jeti dujjayaṁ."
    },
    {
      "id": "thag6.12:3.1",
      "pali": "Ubhinnamatthaṁ carati,"
    },
    {
      "id": "thag6.12:3.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "thag6.12:3.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "thag6.12:3.4",
      "pali": "yo sato upasammati."
    },
    {
      "id": "thag6.12:4.1",
      "pali": "Ubhinnaṁ tikicchantaṁ taṁ,"
    },
    {
      "id": "thag6.12:4.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "thag6.12:4.3",
      "pali": "Janā maññanti bāloti,"
    },
    {
      "id": "thag6.12:4.4",
      "pali": "ye dhammassa akovidā."
    },
    {
      "id": "thag6.12:5.1",
      "pali": "Uppajje te sace kodho,"
    },
    {
      "id": "thag6.12:5.2",
      "pali": "āvajja kakacūpamaṁ;"
    },
    {
      "id": "thag6.12:5.3",
      "pali": "Uppajje ce rase taṇhā,"
    },
    {
      "id": "thag6.12:5.4",
      "pali": "puttamaṁsūpamaṁ sara."
    },
    {
      "id": "thag6.12:6.1",
      "pali": "Sace dhāvati cittaṁ te,"
    },
    {
      "id": "thag6.12:6.2",
      "pali": "kāmesu ca bhavesu ca;"
    },
    {
      "id": "thag6.12:6.3",
      "pali": "Khippaṁ niggaṇha satiyā,"
    },
    {
      "id": "thag6.12:6.4",
      "pali": "kiṭṭhādaṁ viya duppasun”ti."
    },
    {
      "id": "thag6.12:6.5",
      "pali": "… Brahmadatto thero …."
    }
  ]
}
