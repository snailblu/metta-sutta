{
  "uid": "snp2.7",
  "title": "Brāhmaṇadhammikasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.7:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp2.7:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "snp2.7:1.3",
      "pali": "Atha kho sambahulā kosalakā brāhmaṇamahāsālā jiṇṇā vuḍḍhā mahallakā addhagatā vayoanuppattā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavatā saddhiṁ sammodiṁsu."
    },
    {
      "id": "snp2.7:1.4",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdiṁsu. Ekamantaṁ nisinnā kho te brāhmaṇamahāsālā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "snp2.7:1.5",
      "pali": "“sandissanti nu kho, bho gotama, etarahi brāhmaṇā porāṇānaṁ brāhmaṇānaṁ brāhmaṇadhamme”ti?"
    },
    {
      "id": "snp2.7:1.6",
      "pali": "“Na kho, brāhmaṇā, sandissanti etarahi brāhmaṇā porāṇānaṁ brāhmaṇānaṁ brāhmaṇadhamme”ti."
    },
    {
      "id": "snp2.7:1.7",
      "pali": "“Sādhu no bhavaṁ gotamo porāṇānaṁ brāhmaṇānaṁ brāhmaṇadhammaṁ bhāsatu, sace bhoto gotamassa agarū”ti."
    },
    {
      "id": "snp2.7:1.8",
      "pali": "“Tena hi, brāhmaṇā, suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "snp2.7:1.9",
      "pali": "“Evaṁ, bho”ti kho te brāhmaṇamahāsālā bhagavato paccassosuṁ."
    },
    {
      "id": "snp2.7:1.10",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "snp2.7:2.1",
      "pali": "“Isayo pubbakā āsuṁ,"
    },
    {
      "id": "snp2.7:2.2",
      "pali": "saññatattā tapassino;"
    },
    {
      "id": "snp2.7:2.3",
      "pali": "Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "snp2.7:2.4",
      "pali": "attadatthamacārisuṁ."
    },
    {
      "id": "snp2.7:3.1",
      "pali": "Na pasū brāhmaṇānāsuṁ,"
    },
    {
      "id": "snp2.7:3.2",
      "pali": "na hiraññaṁ na dhāniyaṁ;"
    },
    {
      "id": "snp2.7:3.3",
      "pali": "Sajjhāyadhanadhaññāsuṁ,"
    },
    {
      "id": "snp2.7:3.4",
      "pali": "brahmaṁ nidhimapālayuṁ."
    },
    {
      "id": "snp2.7:4.1",
      "pali": "Yaṁ nesaṁ pakataṁ āsi,"
    },
    {
      "id": "snp2.7:4.2",
      "pali": "dvārabhattaṁ upaṭṭhitaṁ;"
    },
    {
      "id": "snp2.7:4.3",
      "pali": "Saddhāpakatamesānaṁ,"
    },
    {
      "id": "snp2.7:4.4",
      "pali": "dātave tadamaññisuṁ."
    },
    {
      "id": "snp2.7:5.1",
      "pali": "Nānārattehi vatthehi,"
    },
    {
      "id": "snp2.7:5.2",
      "pali": "sayanehāvasathehi ca;"
    },
    {
      "id": "snp2.7:5.3",
      "pali": "Phītā janapadā raṭṭhā,"
    },
    {
      "id": "snp2.7:5.4",
      "pali": "te namassiṁsu brāhmaṇe."
    },
    {
      "id": "snp2.7:6.1",
      "pali": "Avajjhā brāhmaṇā āsuṁ,"
    },
    {
      "id": "snp2.7:6.2",
      "pali": "ajeyyā dhammarakkhitā;"
    },
    {
      "id": "snp2.7:6.3",
      "pali": "Na ne koci nivāresi,"
    },
    {
      "id": "snp2.7:6.4",
      "pali": "kuladvāresu sabbaso."
    },
    {
      "id": "snp2.7:7.1",
      "pali": "Aṭṭhacattālīsaṁ vassāni,"
    },
    {
      "id": "snp2.7:7.2",
      "pali": "(komāra) Brahmacariyaṁ cariṁsu te;"
    },
    {
      "id": "snp2.7:7.3",
      "pali": "Vijjācaraṇapariyeṭṭhiṁ,"
    },
    {
      "id": "snp2.7:7.4",
      "pali": "Acaruṁ brāhmaṇā pure."
    },
    {
      "id": "snp2.7:8.1",
      "pali": "Na brāhmaṇā aññamagamuṁ,"
    },
    {
      "id": "snp2.7:8.2",
      "pali": "napi bhariyaṁ kiṇiṁsu te;"
    },
    {
      "id": "snp2.7:8.3",
      "pali": "Sampiyeneva saṁvāsaṁ,"
    },
    {
      "id": "snp2.7:8.4",
      "pali": "saṅgantvā samarocayuṁ."
    },
    {
      "id": "snp2.7:9.1",
      "pali": "Aññatra tamhā samayā,"
    },
    {
      "id": "snp2.7:9.2",
      "pali": "utuveramaṇiṁ pati;"
    },
    {
      "id": "snp2.7:9.3",
      "pali": "Antarā methunaṁ dhammaṁ,"
    },
    {
      "id": "snp2.7:9.4",
      "pali": "nāssu gacchanti brāhmaṇā."
    },
    {
      "id": "snp2.7:10.1",
      "pali": "Brahmacariyañca sīlañca,"
    },
    {
      "id": "snp2.7:10.2",
      "pali": "ajjavaṁ maddavaṁ tapaṁ;"
    },
    {
      "id": "snp2.7:10.3",
      "pali": "Soraccaṁ avihiṁsañca,"
    },
    {
      "id": "snp2.7:10.4",
      "pali": "khantiñcāpi avaṇṇayuṁ."
    },
    {
      "id": "snp2.7:11.1",
      "pali": "Yo nesaṁ paramo āsi,"
    },
    {
      "id": "snp2.7:11.2",
      "pali": "Brahmā daḷhaparakkamo;"
    },
    {
      "id": "snp2.7:11.3",
      "pali": "Sa vāpi methunaṁ dhammaṁ,"
    },
    {
      "id": "snp2.7:11.4",
      "pali": "Supinantepi nāgamā."
    },
    {
      "id": "snp2.7:12.1",
      "pali": "Tassa vattamanusikkhantā,"
    },
    {
      "id": "snp2.7:12.2",
      "pali": "Idheke viññujātikā;"
    },
    {
      "id": "snp2.7:12.3",
      "pali": "Brahmacariyañca sīlañca,"
    },
    {
      "id": "snp2.7:12.4",
      "pali": "Khantiñcāpi avaṇṇayuṁ."
    },
    {
      "id": "snp2.7:13.1",
      "pali": "Taṇḍulaṁ sayanaṁ vatthaṁ,"
    },
    {
      "id": "snp2.7:13.2",
      "pali": "Sappitelañca yāciya;"
    },
    {
      "id": "snp2.7:13.3",
      "pali": "Dhammena samodhānetvā,"
    },
    {
      "id": "snp2.7:13.4",
      "pali": "Tato yaññamakappayuṁ."
    },
    {
      "id": "snp2.7:14.1",
      "pali": "Upaṭṭhitasmiṁ yaññasmiṁ,"
    },
    {
      "id": "snp2.7:14.2",
      "pali": "Nāssu gāvo haniṁsu te;"
    },
    {
      "id": "snp2.7:14.3",
      "pali": "Yathā mātā pitā bhātā,"
    },
    {
      "id": "snp2.7:14.4",
      "pali": "Aññe vāpi ca ñātakā;"
    },
    {
      "id": "snp2.7:14.5",
      "pali": "Gāvo no paramā mittā,"
    },
    {
      "id": "snp2.7:14.6",
      "pali": "Yāsu jāyanti osadhā."
    },
    {
      "id": "snp2.7:15.1",
      "pali": "Annadā baladā cetā,"
    },
    {
      "id": "snp2.7:15.2",
      "pali": "Vaṇṇadā sukhadā tathā;"
    },
    {
      "id": "snp2.7:15.3",
      "pali": "Etamatthavasaṁ ñatvā,"
    },
    {
      "id": "snp2.7:15.4",
      "pali": "Nāssu gāvo haniṁsu te."
    },
    {
      "id": "snp2.7:16.1",
      "pali": "Sukhumālā mahākāyā,"
    },
    {
      "id": "snp2.7:16.2",
      "pali": "Vaṇṇavanto yasassino;"
    },
    {
      "id": "snp2.7:16.3",
      "pali": "Brāhmaṇā sehi dhammehi,"
    },
    {
      "id": "snp2.7:16.4",
      "pali": "Kiccākiccesu ussukā;"
    },
    {
      "id": "snp2.7:16.5",
      "pali": "Yāva loke avattiṁsu,"
    },
    {
      "id": "snp2.7:16.6",
      "pali": "Sukhamedhitthayaṁ pajā."
    },
    {
      "id": "snp2.7:17.1",
      "pali": "Tesaṁ āsi vipallāso,"
    },
    {
      "id": "snp2.7:17.2",
      "pali": "Disvāna aṇuto aṇuṁ;"
    },
    {
      "id": "snp2.7:17.3",
      "pali": "Rājino ca viyākāraṁ,"
    },
    {
      "id": "snp2.7:17.4",
      "pali": "Nāriyo samalaṅkatā."
    },
    {
      "id": "snp2.7:18.1",
      "pali": "Rathe cājaññasaṁyutte,"
    },
    {
      "id": "snp2.7:18.2",
      "pali": "Sukate cittasibbane;"
    },
    {
      "id": "snp2.7:18.3",
      "pali": "Nivesane nivese ca,"
    },
    {
      "id": "snp2.7:18.4",
      "pali": "Vibhatte bhāgaso mite."
    },
    {
      "id": "snp2.7:19.1",
      "pali": "Gomaṇḍalaparibyūḷhaṁ,"
    },
    {
      "id": "snp2.7:19.2",
      "pali": "Nārīvaragaṇāyutaṁ;"
    },
    {
      "id": "snp2.7:19.3",
      "pali": "Uḷāraṁ mānusaṁ bhogaṁ,"
    },
    {
      "id": "snp2.7:19.4",
      "pali": "Abhijjhāyiṁsu brāhmaṇā."
    },
    {
      "id": "snp2.7:20.1",
      "pali": "Te tattha mante ganthetvā,"
    },
    {
      "id": "snp2.7:20.2",
      "pali": "Okkākaṁ tadupāgamuṁ;"
    },
    {
      "id": "snp2.7:20.3",
      "pali": "Pahūtadhanadhaññosi,"
    },
    {
      "id": "snp2.7:20.4",
      "pali": "Yajassu bahu te vittaṁ;"
    },
    {
      "id": "snp2.7:20.5",
      "pali": "Yajassu bahu te dhanaṁ."
    },
    {
      "id": "snp2.7:21.1",
      "pali": "Tato ca rājā saññatto,"
    },
    {
      "id": "snp2.7:21.2",
      "pali": "Brāhmaṇehi rathesabho;"
    },
    {
      "id": "snp2.7:21.3",
      "pali": "Assamedhaṁ purisamedhaṁ,"
    },
    {
      "id": "snp2.7:21.4",
      "pali": "Sammāpāsaṁ vājapeyyaṁ niraggaḷaṁ;"
    },
    {
      "id": "snp2.7:21.5",
      "pali": "Ete yāge yajitvāna,"
    },
    {
      "id": "snp2.7:21.6",
      "pali": "Brāhmaṇānamadā dhanaṁ."
    },
    {
      "id": "snp2.7:22.1",
      "pali": "Gāvo sayanañca vatthañca,"
    },
    {
      "id": "snp2.7:22.2",
      "pali": "Nāriyo samalaṅkatā;"
    },
    {
      "id": "snp2.7:22.3",
      "pali": "Rathe cājaññasaṁyutte,"
    },
    {
      "id": "snp2.7:22.4",
      "pali": "Sukate cittasibbane."
    },
    {
      "id": "snp2.7:23.1",
      "pali": "Nivesanāni rammāni,"
    },
    {
      "id": "snp2.7:23.2",
      "pali": "Suvibhattāni bhāgaso;"
    },
    {
      "id": "snp2.7:23.3",
      "pali": "Nānādhaññassa pūretvā,"
    },
    {
      "id": "snp2.7:23.4",
      "pali": "Brāhmaṇānamadā dhanaṁ."
    },
    {
      "id": "snp2.7:24.1",
      "pali": "Te ca tattha dhanaṁ laddhā,"
    },
    {
      "id": "snp2.7:24.2",
      "pali": "Sannidhiṁ samarocayuṁ;"
    },
    {
      "id": "snp2.7:24.3",
      "pali": "Tesaṁ icchāvatiṇṇānaṁ,"
    },
    {
      "id": "snp2.7:24.4",
      "pali": "Bhiyyo taṇhā pavaḍḍhatha;"
    },
    {
      "id": "snp2.7:24.5",
      "pali": "Te tattha mante ganthetvā,"
    },
    {
      "id": "snp2.7:24.6",
      "pali": "Okkākaṁ puna mupāgamuṁ."
    },
    {
      "id": "snp2.7:25.1",
      "pali": "Yathā āpo ca pathavī ca,"
    },
    {
      "id": "snp2.7:25.2",
      "pali": "Hiraññaṁ dhanadhāniyaṁ;"
    },
    {
      "id": "snp2.7:25.3",
      "pali": "Evaṁ gāvo manussānaṁ,"
    },
    {
      "id": "snp2.7:25.4",
      "pali": "Parikkhāro so hi pāṇinaṁ;"
    },
    {
      "id": "snp2.7:25.5",
      "pali": "Yajassu bahu te vittaṁ,"
    },
    {
      "id": "snp2.7:25.6",
      "pali": "Yajassu bahu te dhanaṁ."
    },
    {
      "id": "snp2.7:26.1",
      "pali": "Tato ca rājā saññatto,"
    },
    {
      "id": "snp2.7:26.2",
      "pali": "Brāhmaṇehi rathesabho;"
    },
    {
      "id": "snp2.7:26.3",
      "pali": "Nekā satasahassiyo,"
    },
    {
      "id": "snp2.7:26.4",
      "pali": "Gāvo yaññe aghātayi."
    },
    {
      "id": "snp2.7:27.1",
      "pali": "Na pādā na visāṇena,"
    },
    {
      "id": "snp2.7:27.2",
      "pali": "Nāssu hiṁsanti kenaci;"
    },
    {
      "id": "snp2.7:27.3",
      "pali": "Gāvo eḷakasamānā,"
    },
    {
      "id": "snp2.7:27.4",
      "pali": "Soratā kumbhadūhanā;"
    },
    {
      "id": "snp2.7:27.5",
      "pali": "Tā visāṇe gahetvāna,"
    },
    {
      "id": "snp2.7:27.6",
      "pali": "Rājā satthena ghātayi."
    },
    {
      "id": "snp2.7:28.1",
      "pali": "Tato devā pitaro ca,"
    },
    {
      "id": "snp2.7:28.2",
      "pali": "Indo asurarakkhasā;"
    },
    {
      "id": "snp2.7:28.3",
      "pali": "Adhammo iti pakkanduṁ,"
    },
    {
      "id": "snp2.7:28.4",
      "pali": "Yaṁ satthaṁ nipatī gave."
    },
    {
      "id": "snp2.7:29.1",
      "pali": "Tayo rogā pure āsuṁ,"
    },
    {
      "id": "snp2.7:29.2",
      "pali": "Icchā anasanaṁ jarā;"
    },
    {
      "id": "snp2.7:29.3",
      "pali": "Pasūnañca samārambhā,"
    },
    {
      "id": "snp2.7:29.4",
      "pali": "Aṭṭhānavutimāgamuṁ."
    },
    {
      "id": "snp2.7:30.1",
      "pali": "Eso adhammo daṇḍānaṁ,"
    },
    {
      "id": "snp2.7:30.2",
      "pali": "Okkanto purāṇo ahu;"
    },
    {
      "id": "snp2.7:30.3",
      "pali": "Adūsikāyo haññanti,"
    },
    {
      "id": "snp2.7:30.4",
      "pali": "Dhammā dhaṁsanti yājakā."
    },
    {
      "id": "snp2.7:31.1",
      "pali": "Evameso aṇudhammo,"
    },
    {
      "id": "snp2.7:31.2",
      "pali": "Porāṇo viññugarahito;"
    },
    {
      "id": "snp2.7:31.3",
      "pali": "Yattha edisakaṁ passati,"
    },
    {
      "id": "snp2.7:31.4",
      "pali": "Yājakaṁ garahatī jano."
    },
    {
      "id": "snp2.7:32.1",
      "pali": "Evaṁ dhamme viyāpanne,"
    },
    {
      "id": "snp2.7:32.2",
      "pali": "Vibhinnā suddavessikā;"
    },
    {
      "id": "snp2.7:32.3",
      "pali": "Puthū vibhinnā khattiyā,"
    },
    {
      "id": "snp2.7:32.4",
      "pali": "Patiṁ bhariyāvamaññatha."
    },
    {
      "id": "snp2.7:33.1",
      "pali": "Khattiyā brahmabandhū ca,"
    },
    {
      "id": "snp2.7:33.2",
      "pali": "Ye caññe gottarakkhitā;"
    },
    {
      "id": "snp2.7:33.3",
      "pali": "Jātivādaṁ nirākatvā,"
    },
    {
      "id": "snp2.7:33.4",
      "pali": "Kāmānaṁ vasamanvagun”ti."
    },
    {
      "id": "snp2.7:34.1",
      "pali": "Evaṁ vutte, te brāhmaṇamahāsālā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "snp2.7:34.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "snp2.7:34.3",
      "pali": "upāsake no bhavaṁ gotamo dhāretu ajjatagge pāṇupete saraṇaṁ gate”ti."
    },
    {
      "id": "snp2.7:34.4",
      "pali": "Brāhmaṇadhammikasuttaṁ sattamaṁ."
    }
  ]
}
