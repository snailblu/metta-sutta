{
  "uid": "tha-ap422",
  "title": "Mañcadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap422:1.1",
      "pali": "“Parinibbute kāruṇike,"
    },
    {
      "id": "tha-ap422:1.2",
      "pali": "siddhatthe lokanāyake;"
    },
    {
      "id": "tha-ap422:1.3",
      "pali": "Vitthārike pāvacane,"
    },
    {
      "id": "tha-ap422:1.4",
      "pali": "devamānusasakkate."
    },
    {
      "id": "tha-ap422:2.1",
      "pali": "Caṇḍālo āsahaṁ tattha,"
    },
    {
      "id": "tha-ap422:2.2",
      "pali": "āsandipīṭhakārako;"
    },
    {
      "id": "tha-ap422:2.3",
      "pali": "Tena kammena jīvāmi,"
    },
    {
      "id": "tha-ap422:2.4",
      "pali": "tena posemi dārake."
    },
    {
      "id": "tha-ap422:3.1",
      "pali": "Āsandiṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap422:3.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap422:3.3",
      "pali": "Sayamevupagantvāna,"
    },
    {
      "id": "tha-ap422:3.4",
      "pali": "bhikkhusaṅghassadāsahaṁ."
    },
    {
      "id": "tha-ap422:4.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap422:4.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap422:4.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap422:4.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap422:5.1",
      "pali": "Devalokagato santo,"
    },
    {
      "id": "tha-ap422:5.2",
      "pali": "modāmi tidase gaṇe;"
    },
    {
      "id": "tha-ap422:5.3",
      "pali": "Sayanāni mahagghāni,"
    },
    {
      "id": "tha-ap422:5.4",
      "pali": "nibbattanti yadicchakaṁ."
    },
    {
      "id": "tha-ap422:6.1",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap422:6.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap422:6.3",
      "pali": "Asītikkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap422:6.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap422:7.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap422:7.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap422:7.3",
      "pali": "Sukhito yasavā homi,"
    },
    {
      "id": "tha-ap422:7.4",
      "pali": "mañcadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap422:8.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap422:8.2",
      "pali": "emi ce mānusaṁ bhavaṁ;"
    },
    {
      "id": "tha-ap422:8.3",
      "pali": "Mahārahā susayanā,"
    },
    {
      "id": "tha-ap422:8.4",
      "pali": "sayameva bhavanti me."
    },
    {
      "id": "tha-ap422:9.1",
      "pali": "Ayaṁ pacchimako mayhaṁ,"
    },
    {
      "id": "tha-ap422:9.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap422:9.3",
      "pali": "Ajjāpi sayane kāle,"
    },
    {
      "id": "tha-ap422:9.4",
      "pali": "sayanaṁ upatiṭṭhati."
    },
    {
      "id": "tha-ap422:10.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap422:10.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap422:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap422:10.4",
      "pali": "mañcadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap422:11.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap422:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap422:11.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap422:12.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap422:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap422:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap422:13.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap422:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap422:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap422:14.1",
      "pali": "Itthaṁ sudaṁ āyasmā mañcadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap422:15.1",
      "pali": "Mañcadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap422:16.1",
      "pali": "Bhaddālivaggo bācattālīsamo."
    },
    {
      "id": "tha-ap422:17.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap422:18.1",
      "pali": "Bhaddālī ekachatto ca,"
    },
    {
      "id": "tha-ap422:18.2",
      "pali": "tiṇasūlo ca maṁsado;"
    },
    {
      "id": "tha-ap422:18.3",
      "pali": "Nāgapallaviko dīpī,"
    },
    {
      "id": "tha-ap422:18.4",
      "pali": "ucchaṅgi yāgudāyako."
    },
    {
      "id": "tha-ap422:19.1",
      "pali": "Patthodanī mañcadado,"
    },
    {
      "id": "tha-ap422:19.2",
      "pali": "gāthāyo gaṇitā ciha;"
    },
    {
      "id": "tha-ap422:19.3",
      "pali": "Dvesatāni ca gāthānaṁ,"
    },
    {
      "id": "tha-ap422:19.4",
      "pali": "gāthā cekā taduttari."
    }
  ]
}
