{
  "uid": "ja142",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja142:1.1",
      "pali": "“Etañhi te durājānaṁ,"
    },
    {
      "id": "ja142:1.2",
      "pali": "yaṁ sesi matasāyikaṁ;"
    },
    {
      "id": "ja142:1.3",
      "pali": "Yassa te kaḍḍhamānassa,"
    },
    {
      "id": "ja142:1.4",
      "pali": "hatthā daṇḍo na muccatī”ti."
    },
    {
      "id": "ja142:2.1",
      "pali": "Siṅgālajātakaṁ dutiyaṁ."
    }
  ]
}
