{
  "uid": "ja1",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "ja1:2.1",
      "pali": "“Apaṇṇakaṁ ṭhānameke,"
    },
    {
      "id": "ja1:2.2",
      "pali": "Dutiyaṁ āhu takkikā;"
    },
    {
      "id": "ja1:2.3",
      "pali": "Etadaññāya medhāvī,"
    },
    {
      "id": "ja1:2.4",
      "pali": "Taṁ gaṇhe yadapaṇṇakan”ti."
    },
    {
      "id": "ja1:3.1",
      "pali": "Apaṇṇakajātakaṁ paṭhamaṁ."
    }
  ]
}
