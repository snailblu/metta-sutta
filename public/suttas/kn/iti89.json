{
  "uid": "iti89",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti89:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti89:2.1",
      "pali": "“Tīhi, bhikkhave, asaddhammehi abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "iti89:2.2",
      "pali": "Katamehi tīhi?"
    },
    {
      "id": "iti89:2.3",
      "pali": "Pāpicchatāya, bhikkhave, abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "iti89:2.4",
      "pali": "Pāpamittatāya, bhikkhave, abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "iti89:2.5",
      "pali": "Sati kho pana uttarikaraṇīye oramattakena visesādhigamena antarā vosānaṁ āpādi."
    },
    {
      "id": "iti89:2.6",
      "pali": "Imehi kho, bhikkhave, tīhi asaddhammehi abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho”ti."
    },
    {
      "id": "iti89:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti89:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti89:3.1",
      "pali": "“Mā jātu koci lokasmiṁ,"
    },
    {
      "id": "iti89:3.2",
      "pali": "pāpiccho udapajjatha;"
    },
    {
      "id": "iti89:3.3",
      "pali": "Tadamināpi jānātha,"
    },
    {
      "id": "iti89:3.4",
      "pali": "pāpicchānaṁ yathā gati."
    },
    {
      "id": "iti89:4.1",
      "pali": "Paṇḍitoti samaññāto,"
    },
    {
      "id": "iti89:4.2",
      "pali": "bhāvitattoti sammato;"
    },
    {
      "id": "iti89:4.3",
      "pali": "Jalaṁva yasasā aṭṭhā,"
    },
    {
      "id": "iti89:4.4",
      "pali": "devadattoti vissuto."
    },
    {
      "id": "iti89:5.1",
      "pali": "So samānamanuciṇṇo,"
    },
    {
      "id": "iti89:5.2",
      "pali": "āsajja naṁ tathāgataṁ;"
    },
    {
      "id": "iti89:5.3",
      "pali": "Avīcinirayaṁ patto,"
    },
    {
      "id": "iti89:5.4",
      "pali": "catudvāraṁ bhayānakaṁ."
    },
    {
      "id": "iti89:6.1",
      "pali": "Aduṭṭhassa hi yo dubbhe,"
    },
    {
      "id": "iti89:6.2",
      "pali": "pāpakammaṁ akubbato;"
    },
    {
      "id": "iti89:6.3",
      "pali": "Tameva pāpaṁ phusati,"
    },
    {
      "id": "iti89:6.4",
      "pali": "duṭṭhacittaṁ anādaraṁ."
    },
    {
      "id": "iti89:7.1",
      "pali": "Samuddaṁ visakumbhena,"
    },
    {
      "id": "iti89:7.2",
      "pali": "yo maññeyya padūsituṁ;"
    },
    {
      "id": "iti89:7.3",
      "pali": "Na so tena padūseyya,"
    },
    {
      "id": "iti89:7.4",
      "pali": "bhesmā hi udadhi mahā."
    },
    {
      "id": "iti89:8.1",
      "pali": "Evamevaṁ tathāgataṁ,"
    },
    {
      "id": "iti89:8.2",
      "pali": "yo vādena vihiṁsati;"
    },
    {
      "id": "iti89:8.3",
      "pali": "Sammaggataṁ santacittaṁ,"
    },
    {
      "id": "iti89:8.4",
      "pali": "vādo tamhi na rūhati."
    },
    {
      "id": "iti89:9.1",
      "pali": "Tādisaṁ mittaṁ kubbetha,"
    },
    {
      "id": "iti89:9.2",
      "pali": "tañca seveyya paṇḍito;"
    },
    {
      "id": "iti89:9.3",
      "pali": "Yassa maggānugo bhikkhu,"
    },
    {
      "id": "iti89:9.4",
      "pali": "khayaṁ dukkhassa pāpuṇe”ti."
    },
    {
      "id": "iti89:10.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti89:10.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti89:10.3",
      "pali": "Catuttho vaggo."
    },
    {
      "id": "iti89:11.1",
      "pali": "Vitakkāsakkārasadda,"
    },
    {
      "id": "iti89:11.2",
      "pali": "cavanaloke asubhaṁ;"
    },
    {
      "id": "iti89:11.3",
      "pali": "Dhammaandhakāramalaṁ,"
    },
    {
      "id": "iti89:11.4",
      "pali": "devadattena te dasāti."
    }
  ]
}
