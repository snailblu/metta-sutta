{
  "uid": "bv12",
  "title": "12. Padumuttarabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv12:1.1",
      "pali": "“Nāradassa aparena,"
    },
    {
      "id": "bv12:1.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "bv12:1.3",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "bv12:1.4",
      "pali": "akkhobbho sāgarūpamo."
    },
    {
      "id": "bv12:2.1",
      "pali": "Maṇḍakappova so āsi,"
    },
    {
      "id": "bv12:2.2",
      "pali": "yamhi buddho ajāyatha;"
    },
    {
      "id": "bv12:2.3",
      "pali": "Ussannakusalā janatā,"
    },
    {
      "id": "bv12:2.4",
      "pali": "tamhi kappe ajāyatha."
    },
    {
      "id": "bv12:3.1",
      "pali": "Padumuttarassa bhagavato,"
    },
    {
      "id": "bv12:3.2",
      "pali": "Paṭhame dhammadesane;"
    },
    {
      "id": "bv12:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv12:3.4",
      "pali": "Dhammābhisamayo ahu."
    },
    {
      "id": "bv12:4.1",
      "pali": "Tato parampi vassante,"
    },
    {
      "id": "bv12:4.2",
      "pali": "Tappayante ca pāṇine;"
    },
    {
      "id": "bv12:4.3",
      "pali": "Sattatiṁsasatasahassānaṁ,"
    },
    {
      "id": "bv12:4.4",
      "pali": "Dutiyābhisamayo ahu."
    },
    {
      "id": "bv12:5.1",
      "pali": "Yamhi kāle mahāvīro,"
    },
    {
      "id": "bv12:5.2",
      "pali": "ānandaṁ upasaṅkami;"
    },
    {
      "id": "bv12:5.3",
      "pali": "Pitusantikaṁ upagantvā,"
    },
    {
      "id": "bv12:5.4",
      "pali": "āhanī amatadundubhiṁ."
    },
    {
      "id": "bv12:6.1",
      "pali": "Āhate amatabherimhi,"
    },
    {
      "id": "bv12:6.2",
      "pali": "vassante dhammavuṭṭhiyā;"
    },
    {
      "id": "bv12:6.3",
      "pali": "Paññāsasatasahassānaṁ,"
    },
    {
      "id": "bv12:6.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv12:7.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "bv12:7.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "bv12:7.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "bv12:7.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv12:8.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv12:8.2",
      "pali": "padumuttarassa satthuno;"
    },
    {
      "id": "bv12:8.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv12:8.4",
      "pali": "paṭhamo āsi samāgamo."
    },
    {
      "id": "bv12:9.1",
      "pali": "Yadā buddho asamasamo,"
    },
    {
      "id": "bv12:9.2",
      "pali": "vasi vebhārapabbate;"
    },
    {
      "id": "bv12:9.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv12:9.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv12:10.1",
      "pali": "Puna cārikaṁ pakkante,"
    },
    {
      "id": "bv12:10.2",
      "pali": "gāmanigamaraṭṭhato;"
    },
    {
      "id": "bv12:10.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv12:10.4",
      "pali": "tatiyo āsi samāgamo."
    },
    {
      "id": "bv12:11.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv12:11.2",
      "pali": "Jaṭilo nāma raṭṭhiko;"
    },
    {
      "id": "bv12:11.3",
      "pali": "Sambuddhappamukhaṁ saṅghaṁ,"
    },
    {
      "id": "bv12:11.4",
      "pali": "Sabhattaṁ dussamadāsahaṁ."
    },
    {
      "id": "bv12:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv12:12.2",
      "pali": "saṅghamajjhe nisīdiya;"
    },
    {
      "id": "bv12:12.3",
      "pali": "‘Satasahassito kappe,"
    },
    {
      "id": "bv12:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv12:13.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv12:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv12:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv12:14.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv12:14.2",
      "pali": "uttariṁ vatamadhiṭṭhahiṁ;"
    },
    {
      "id": "bv12:14.3",
      "pali": "Akāsiṁ uggadaḷhaṁ dhitiṁ,"
    },
    {
      "id": "bv12:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv12:15.1",
      "pali": "Byāhatā titthiyā sabbe,"
    },
    {
      "id": "bv12:15.2",
      "pali": "Vimanā dummanā tadā;"
    },
    {
      "id": "bv12:15.3",
      "pali": "Na tesaṁ keci paricaranti,"
    },
    {
      "id": "bv12:15.4",
      "pali": "Raṭṭhato nicchubhanti te."
    },
    {
      "id": "bv12:16.1",
      "pali": "Sabbe tattha samāgantvā,"
    },
    {
      "id": "bv12:16.2",
      "pali": "upagacchuṁ buddhasantike;"
    },
    {
      "id": "bv12:16.3",
      "pali": "Tuvaṁ nātho mahāvīra,"
    },
    {
      "id": "bv12:16.4",
      "pali": "saraṇaṁ hohi cakkhuma."
    },
    {
      "id": "bv12:17.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "bv12:17.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "bv12:17.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "bv12:17.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "bv12:18.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "bv12:18.2",
      "pali": "suññataṁ titthiyehi taṁ;"
    },
    {
      "id": "bv12:18.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "bv12:18.4",
      "pali": "vasībhūtehi tādihi."
    },
    {
      "id": "bv12:19.1",
      "pali": "Nagaraṁ haṁsavatī nāma,"
    },
    {
      "id": "bv12:19.2",
      "pali": "ānando nāma khattiyo;"
    },
    {
      "id": "bv12:19.3",
      "pali": "Sujātā nāma janikā,"
    },
    {
      "id": "bv12:19.4",
      "pali": "padumuttarassa satthuno."
    },
    {
      "id": "bv12:20.1",
      "pali": "Dasavassasahassāni,"
    },
    {
      "id": "bv12:20.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv12:20.3",
      "pali": "Naravāhano yaso vasavattī,"
    },
    {
      "id": "bv12:20.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv12:21.1",
      "pali": "Ticattārīsasahassāni,"
    },
    {
      "id": "bv12:21.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv12:21.3",
      "pali": "Vasudattā nāma nārī,"
    },
    {
      "id": "bv12:21.4",
      "pali": "uttamo nāma atrajo."
    },
    {
      "id": "bv12:22.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv12:22.2",
      "pali": "pāsādenābhinikkhami;"
    },
    {
      "id": "bv12:22.3",
      "pali": "Sattāhaṁ padhānacāraṁ,"
    },
    {
      "id": "bv12:22.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv12:23.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv12:23.2",
      "pali": "padumuttaro vināyako;"
    },
    {
      "id": "bv12:23.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv12:23.4",
      "pali": "mithiluyyānamuttame."
    },
    {
      "id": "bv12:24.1",
      "pali": "Devalo ca sujāto ca,"
    },
    {
      "id": "bv12:24.2",
      "pali": "Ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv12:24.3",
      "pali": "Sumano nāmupaṭṭhāko,"
    },
    {
      "id": "bv12:24.4",
      "pali": "Padumuttarassa mahesino."
    },
    {
      "id": "bv12:25.1",
      "pali": "Amitā ca asamā ca,"
    },
    {
      "id": "bv12:25.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv12:25.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv12:25.4",
      "pali": "salaloti pavuccati."
    },
    {
      "id": "bv12:26.1",
      "pali": "Vitiṇṇo ceva tisso ca,"
    },
    {
      "id": "bv12:26.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv12:26.3",
      "pali": "Haṭṭhā ceva vicittā ca,"
    },
    {
      "id": "bv12:26.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv12:27.1",
      "pali": "Aṭṭhapaṇṇāsaratanaṁ,"
    },
    {
      "id": "bv12:27.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv12:27.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "bv12:27.4",
      "pali": "dvattiṁsavaralakkhaṇo."
    },
    {
      "id": "bv12:28.1",
      "pali": "Kuṭṭā kavāṭā bhittī ca,"
    },
    {
      "id": "bv12:28.2",
      "pali": "rukkhā nagasiluccayā;"
    },
    {
      "id": "bv12:28.3",
      "pali": "Na tassāvaraṇaṁ atthi,"
    },
    {
      "id": "bv12:28.4",
      "pali": "samantā dvādasayojane."
    },
    {
      "id": "bv12:29.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv12:29.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv12:29.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv12:29.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv12:30.1",
      "pali": "Santāretvā bahujanaṁ,"
    },
    {
      "id": "bv12:30.2",
      "pali": "chinditvā sabbasaṁsayaṁ;"
    },
    {
      "id": "bv12:30.3",
      "pali": "Jalitvā aggikkhandhova,"
    },
    {
      "id": "bv12:30.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv12:31.1",
      "pali": "Padumuttaro jino buddho,"
    },
    {
      "id": "bv12:31.2",
      "pali": "Nandārāmamhi nibbuto;"
    },
    {
      "id": "bv12:31.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv12:31.4",
      "pali": "Dvādasubbedhayojano”ti."
    },
    {
      "id": "bv12:32.1",
      "pali": "Padumuttarassa bhagavato vaṁso dasamo."
    }
  ]
}
