{
  "uid": "ne30",
  "title": "Sampāta 11",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne30:1.1",
      "pali": "Tattha katamo paññattihārasampāto?"
    },
    {
      "id": "ne30:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne30:2.2",
      "pali": "“Tasmā rakkhitacittassā”ti padaṭṭhānapaññatti satiyā."
    },
    {
      "id": "ne30:2.3",
      "pali": "“Sammāsaṅkappagocaro”ti bhāvanāpaññatti samathassa."
    },
    {
      "id": "ne30:2.4",
      "pali": "“Sammādiṭṭhipurekkhāro, ñatvāna udayabbayan”ti dassanabhūmiyā nikkhepapaññatti."
    },
    {
      "id": "ne30:2.5",
      "pali": "“Thinamiddhābhibhū bhikkhū”ti samudayassa anavasesappahānapaññatti, “sabbā duggatiyo jahe”ti bhāvanāpaññatti maggassa."
    },
    {
      "id": "ne30:2.6",
      "pali": "Niyutto paññattihārasampāto."
    }
  ]
}
