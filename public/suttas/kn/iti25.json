{
  "uid": "iti25",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti25:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti25:2.1",
      "pali": "“Ekadhammaṁ atītassa, bhikkhave, purisapuggalassa nāhaṁ tassa kiñci pāpakammaṁ akaraṇīyanti vadāmi."
    },
    {
      "id": "iti25:2.2",
      "pali": "Katamaṁ ekadhammaṁ?"
    },
    {
      "id": "iti25:2.3",
      "pali": "Yadidaṁ, bhikkhave, sampajānamusāvādo”ti."
    },
    {
      "id": "iti25:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti25:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti25:3.1",
      "pali": "“Ekadhammaṁ atītassa,"
    },
    {
      "id": "iti25:3.2",
      "pali": "musāvādissa jantuno;"
    },
    {
      "id": "iti25:3.3",
      "pali": "Vitiṇṇaparalokassa,"
    },
    {
      "id": "iti25:3.4",
      "pali": "natthi pāpaṁ akāriyan”ti."
    },
    {
      "id": "iti25:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti25:4.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
