{
  "uid": "tha-ap480",
  "title": "Vallikāraphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap480:1.1",
      "pali": "“Sumano nāma sambuddho,"
    },
    {
      "id": "tha-ap480:1.2",
      "pali": "takkarāyaṁ vasī tadā;"
    },
    {
      "id": "tha-ap480:1.3",
      "pali": "Vallikāraphalaṁ gayha,"
    },
    {
      "id": "tha-ap480:1.4",
      "pali": "sayambhussa adāsahaṁ."
    },
    {
      "id": "tha-ap480:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap480:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap480:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap480:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap480:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap480:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap480:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap480:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap480:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap480:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap480:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap480:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap480:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap480:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā vallikāraphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap480:7.1",
      "pali": "Vallikāraphaladāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
