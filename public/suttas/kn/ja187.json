{
  "uid": "ja187",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja187:1.1",
      "pali": "“Ucce viṭabhimāruyha,"
    },
    {
      "id": "ja187:1.2",
      "pali": "mantayavho rahogatā;"
    },
    {
      "id": "ja187:1.3",
      "pali": "Nīce oruyha mantavho,"
    },
    {
      "id": "ja187:1.4",
      "pali": "migarājāpi sossati."
    },
    {
      "id": "ja187:2.1",
      "pali": "Yaṁ suvaṇṇo suvaṇṇena,"
    },
    {
      "id": "ja187:2.2",
      "pali": "devo devena mantaye;"
    },
    {
      "id": "ja187:2.3",
      "pali": "Kiṁ tettha catumaṭṭhassa,"
    },
    {
      "id": "ja187:2.4",
      "pali": "bilaṁ pavisa jambukā”ti."
    },
    {
      "id": "ja187:3.1",
      "pali": "Catumaṭṭhajātakaṁ sattamaṁ."
    }
  ]
}
