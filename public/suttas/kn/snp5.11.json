{
  "uid": "snp5.11",
  "title": "Kappamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.11:1.1",
      "pali": "“Majjhe sarasmiṁ tiṭṭhataṁ,"
    },
    {
      "id": "snp5.11:1.2",
      "pali": "(iccāyasmā kappo)"
    },
    {
      "id": "snp5.11:1.3",
      "pali": "Oghe jāte mahabbhaye;"
    },
    {
      "id": "snp5.11:1.4",
      "pali": "Jarāmaccuparetānaṁ,"
    },
    {
      "id": "snp5.11:1.5",
      "pali": "Dīpaṁ pabrūhi mārisa;"
    },
    {
      "id": "snp5.11:1.6",
      "pali": "Tvañca me dīpamakkhāhi,"
    },
    {
      "id": "snp5.11:1.7",
      "pali": "Yathāyidaṁ nāparaṁ siyā”."
    },
    {
      "id": "snp5.11:2.1",
      "pali": "“Majjhe sarasmiṁ tiṭṭhataṁ,"
    },
    {
      "id": "snp5.11:2.2",
      "pali": "(kappāti bhagavā)"
    },
    {
      "id": "snp5.11:2.3",
      "pali": "Oghe jāte mahabbhaye;"
    },
    {
      "id": "snp5.11:2.4",
      "pali": "Jarāmaccuparetānaṁ,"
    },
    {
      "id": "snp5.11:2.5",
      "pali": "Dīpaṁ pabrūmi kappa te."
    },
    {
      "id": "snp5.11:3.1",
      "pali": "Akiñcanaṁ anādānaṁ,"
    },
    {
      "id": "snp5.11:3.2",
      "pali": "etaṁ dīpaṁ anāparaṁ;"
    },
    {
      "id": "snp5.11:3.3",
      "pali": "Nibbānaṁ iti naṁ brūmi,"
    },
    {
      "id": "snp5.11:3.4",
      "pali": "jarāmaccuparikkhayaṁ."
    },
    {
      "id": "snp5.11:4.1",
      "pali": "Etadaññāya ye satā,"
    },
    {
      "id": "snp5.11:4.2",
      "pali": "Diṭṭhadhammābhinibbutā;"
    },
    {
      "id": "snp5.11:4.3",
      "pali": "Na te māravasānugā,"
    },
    {
      "id": "snp5.11:4.4",
      "pali": "Na te mārassa paddhagū”ti."
    },
    {
      "id": "snp5.11:4.5",
      "pali": "Kappamāṇavapucchā dasamā."
    }
  ]
}
