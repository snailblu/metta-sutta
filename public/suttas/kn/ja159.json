{
  "uid": "ja159",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja159:1.1",
      "pali": "“Udetayañ cakkhumā ekarājā,"
    },
    {
      "id": "ja159:1.2",
      "pali": "Harissavaṇṇo pathavippabhāso;"
    },
    {
      "id": "ja159:1.3",
      "pali": "Taṁ taṁ namassāmi harissavaṇṇaṁ pathavippabhāsaṁ,"
    },
    {
      "id": "ja159:1.4",
      "pali": "Tayājja guttā viharemu divasaṁ."
    },
    {
      "id": "ja159:2.1",
      "pali": "Ye brāhmaṇā vedagū sabbadhamme,"
    },
    {
      "id": "ja159:2.2",
      "pali": "Te me namo te ca maṁ pālayantu;"
    },
    {
      "id": "ja159:2.3",
      "pali": "Namatthu buddhānaṁ namatthu bodhiyā,"
    },
    {
      "id": "ja159:2.4",
      "pali": "Namo vimuttānaṁ namo vimuttiyā;"
    },
    {
      "id": "ja159:2.5",
      "pali": "Imaṁ so parittaṁ katvā,"
    },
    {
      "id": "ja159:2.6",
      "pali": "Moro carati esanā."
    },
    {
      "id": "ja159:3.1",
      "pali": "Apetayaṁ cakkhumā ekarājā,"
    },
    {
      "id": "ja159:3.2",
      "pali": "Harissavaṇṇo pathavippabhāso;"
    },
    {
      "id": "ja159:3.3",
      "pali": "Taṁ taṁ namassāmi harissavaṇṇaṁ pathavippabhāsaṁ,"
    },
    {
      "id": "ja159:3.4",
      "pali": "Tayājja guttā viharemu rattiṁ."
    },
    {
      "id": "ja159:4.1",
      "pali": "Ye brāhmaṇā vedagū sabbadhamme,"
    },
    {
      "id": "ja159:4.2",
      "pali": "Te me namo te ca maṁ pālayantu;"
    },
    {
      "id": "ja159:4.3",
      "pali": "Namatthu buddhānaṁ namatthu bodhiyā,"
    },
    {
      "id": "ja159:4.4",
      "pali": "Namo vimuttānaṁ namo vimuttiyā;"
    },
    {
      "id": "ja159:4.5",
      "pali": "Imaṁ so parittaṁ katvā,"
    },
    {
      "id": "ja159:4.6",
      "pali": "Moro vāsamakappayī”ti."
    },
    {
      "id": "ja159:5.1",
      "pali": "Morajātakaṁ navamaṁ."
    }
  ]
}
