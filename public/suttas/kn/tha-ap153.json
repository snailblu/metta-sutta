{
  "uid": "tha-ap153",
  "title": "Bandhujīvakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap153:1.1",
      "pali": "“Candaṁva vimalaṁ suddhaṁ,"
    },
    {
      "id": "tha-ap153:1.2",
      "pali": "vippasannamanāvilaṁ;"
    },
    {
      "id": "tha-ap153:1.3",
      "pali": "Nandībhavaparikkhīṇaṁ,"
    },
    {
      "id": "tha-ap153:1.4",
      "pali": "tiṇṇaṁ loke visattikaṁ."
    },
    {
      "id": "tha-ap153:2.1",
      "pali": "Nibbāpayantaṁ janataṁ,"
    },
    {
      "id": "tha-ap153:2.2",
      "pali": "Tiṇṇaṁ tārayataṁ varaṁ;"
    },
    {
      "id": "tha-ap153:2.3",
      "pali": "Muniṁ vanamhi jhāyantaṁ,"
    },
    {
      "id": "tha-ap153:2.4",
      "pali": "Ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "tha-ap153:3.1",
      "pali": "Bandhujīvakapupphāni,"
    },
    {
      "id": "tha-ap153:3.2",
      "pali": "lagetvā suttakenahaṁ;"
    },
    {
      "id": "tha-ap153:3.3",
      "pali": "Buddhassa abhiropayiṁ,"
    },
    {
      "id": "tha-ap153:3.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap153:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap153:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap153:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap153:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap153:5.1",
      "pali": "Ito sattamake kappe,"
    },
    {
      "id": "tha-ap153:5.2",
      "pali": "manujindo mahāyaso;"
    },
    {
      "id": "tha-ap153:5.3",
      "pali": "Samantacakkhu nāmāsi,"
    },
    {
      "id": "tha-ap153:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap153:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap153:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap153:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap153:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap153:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā bandhujīvako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap153:8.1",
      "pali": "Bandhujīvakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
