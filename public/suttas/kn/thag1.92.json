{
  "uid": "thag1.92",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.92:1.1",
      "pali": "“Yassāsavā parikkhīṇā,"
    },
    {
      "id": "thag1.92:1.2",
      "pali": "āhāre ca anissito;"
    },
    {
      "id": "thag1.92:1.3",
      "pali": "Suññato animitto ca,"
    },
    {
      "id": "thag1.92:1.4",
      "pali": "vimokkho yassa gocaro;"
    },
    {
      "id": "thag1.92:1.5",
      "pali": "Ākāseva sakuntānaṁ,"
    },
    {
      "id": "thag1.92:1.6",
      "pali": "padaṁ tassa durannayan”ti."
    },
    {
      "id": "thag1.92:1.7",
      "pali": "… Vijayo thero …."
    }
  ]
}
