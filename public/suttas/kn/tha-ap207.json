{
  "uid": "tha-ap207",
  "title": "Nigguṇḍipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap207:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap207:1.2",
      "pali": "āsimārāmiko ahaṁ;"
    },
    {
      "id": "tha-ap207:1.3",
      "pali": "Nigguṇḍipupphaṁ paggayha,"
    },
    {
      "id": "tha-ap207:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap207:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap207:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap207:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap207:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap207:3.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap207:3.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap207:3.3",
      "pali": "Mahāpatāpanāmena,"
    },
    {
      "id": "tha-ap207:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap207:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap207:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap207:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap207:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā nigguṇḍipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap207:6.1",
      "pali": "Nigguṇḍipupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
