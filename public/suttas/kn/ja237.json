{
  "uid": "ja237",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja237:1.1",
      "pali": "“Ko nu kho bhagavā hetu,"
    },
    {
      "id": "ja237:1.2",
      "pali": "ekacce idha puggale;"
    },
    {
      "id": "ja237:1.3",
      "pali": "Atīva hadayaṁ nibbāti,"
    },
    {
      "id": "ja237:1.4",
      "pali": "cittañcāpi pasīdati”."
    },
    {
      "id": "ja237:2.1",
      "pali": "“Pubbeva sannivāsena,"
    },
    {
      "id": "ja237:2.2",
      "pali": "paccuppannahitena vā;"
    },
    {
      "id": "ja237:2.3",
      "pali": "Evaṁ taṁ jāyate pemaṁ,"
    },
    {
      "id": "ja237:2.4",
      "pali": "uppalaṁva yathodake”ti."
    },
    {
      "id": "ja237:3.1",
      "pali": "Sāketajātakaṁ sattamaṁ."
    }
  ]
}
