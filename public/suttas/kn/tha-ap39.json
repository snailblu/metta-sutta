{
  "uid": "tha-ap39",
  "title": "Lasuṇadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap39:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap39:1.2",
      "pali": "tāpaso āsahaṁ tadā;"
    },
    {
      "id": "tha-ap39:1.3",
      "pali": "Lasuṇaṁ upajīvāmi,"
    },
    {
      "id": "tha-ap39:1.4",
      "pali": "lasuṇaṁ mayhabhojanaṁ."
    },
    {
      "id": "tha-ap39:2.1",
      "pali": "Khāriyo pūrayitvāna,"
    },
    {
      "id": "tha-ap39:2.2",
      "pali": "saṅghārāmamagacchahaṁ;"
    },
    {
      "id": "tha-ap39:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap39:2.4",
      "pali": "saṅghassa lasuṇaṁ adaṁ."
    },
    {
      "id": "tha-ap39:3.1",
      "pali": "Vipassissa naraggassa,"
    },
    {
      "id": "tha-ap39:3.2",
      "pali": "sāsane niratassahaṁ;"
    },
    {
      "id": "tha-ap39:3.3",
      "pali": "Saṅghassa lasuṇaṁ datvā,"
    },
    {
      "id": "tha-ap39:3.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap39:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap39:4.2",
      "pali": "lasuṇaṁ yamadaṁ tadā;"
    },
    {
      "id": "tha-ap39:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap39:4.4",
      "pali": "lasuṇassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap39:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap39:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap39:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap39:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā lasuṇadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap39:7.1",
      "pali": "Lasuṇadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
