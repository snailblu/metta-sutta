{
  "uid": "tha-ap30",
  "title": "8 Uttiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap30:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap30:1.2",
      "pali": "susumāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap30:1.3",
      "pali": "Sagocarappasutohaṁ,"
    },
    {
      "id": "tha-ap30:1.4",
      "pali": "nadītitthaṁ agacchahaṁ."
    },
    {
      "id": "tha-ap30:2.1",
      "pali": "Siddhattho tamhi samaye,"
    },
    {
      "id": "tha-ap30:2.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap30:2.3",
      "pali": "Nadiṁ taritukāmo so,"
    },
    {
      "id": "tha-ap30:2.4",
      "pali": "nadītitthaṁ upāgami."
    },
    {
      "id": "tha-ap30:3.1",
      "pali": "Upāgate ca sambuddhe,"
    },
    {
      "id": "tha-ap30:3.2",
      "pali": "ahampi tatthupāgamiṁ;"
    },
    {
      "id": "tha-ap30:3.3",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap30:3.4",
      "pali": "imaṁ vācaṁ udīrayiṁ."
    },
    {
      "id": "tha-ap30:4.1",
      "pali": "‘Abhirūha mahāvīra,"
    },
    {
      "id": "tha-ap30:4.2",
      "pali": "tāressāmi ahaṁ tuvaṁ;"
    },
    {
      "id": "tha-ap30:4.3",
      "pali": "Pettikaṁ visayaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap30:4.4",
      "pali": "anukampa mahāmuni’."
    },
    {
      "id": "tha-ap30:5.1",
      "pali": "Mama uggajjanaṁ sutvā,"
    },
    {
      "id": "tha-ap30:5.2",
      "pali": "abhirūhi mahāmuni;"
    },
    {
      "id": "tha-ap30:5.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap30:5.4",
      "pali": "tāresiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap30:6.1",
      "pali": "Nadiyā pārime tīre,"
    },
    {
      "id": "tha-ap30:6.2",
      "pali": "siddhattho lokanāyako;"
    },
    {
      "id": "tha-ap30:6.3",
      "pali": "Assāsesi mamaṁ tattha,"
    },
    {
      "id": "tha-ap30:6.4",
      "pali": "amataṁ pāpuṇissasi."
    },
    {
      "id": "tha-ap30:7.1",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap30:7.2",
      "pali": "devalokaṁ āgacchahaṁ;"
    },
    {
      "id": "tha-ap30:7.3",
      "pali": "Dibbasukhaṁ anubhaviṁ,"
    },
    {
      "id": "tha-ap30:7.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap30:8.1",
      "pali": "Sattakkhattuñca devindo,"
    },
    {
      "id": "tha-ap30:8.2",
      "pali": "devarajjamakāsahaṁ;"
    },
    {
      "id": "tha-ap30:8.3",
      "pali": "Tīṇikkhattuṁ cakkavattī,"
    },
    {
      "id": "tha-ap30:8.4",
      "pali": "mahiyā issaro ahuṁ."
    },
    {
      "id": "tha-ap30:9.1",
      "pali": "Vivekamanuyuttohaṁ,"
    },
    {
      "id": "tha-ap30:9.2",
      "pali": "nipako ca susaṁvuto;"
    },
    {
      "id": "tha-ap30:9.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap30:9.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap30:10.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap30:10.2",
      "pali": "tāresiṁ yaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap30:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap30:10.4",
      "pali": "taraṇāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap30:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap30:11.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap30:11.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap30:11.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap30:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā uttiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap30:13.1",
      "pali": "Uttiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
