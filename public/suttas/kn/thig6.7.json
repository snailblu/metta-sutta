{
  "uid": "thig6.7",
  "title": "Guttātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.7:1.1",
      "pali": "“Gutte yadatthaṁ pabbajjā,"
    },
    {
      "id": "thig6.7:1.2",
      "pali": "hitvā puttaṁ vasuṁ piyaṁ;"
    },
    {
      "id": "thig6.7:1.3",
      "pali": "Tameva anubrūhehi,"
    },
    {
      "id": "thig6.7:1.4",
      "pali": "mā cittassa vasaṁ gami."
    },
    {
      "id": "thig6.7:2.1",
      "pali": "Cittena vañcitā sattā,"
    },
    {
      "id": "thig6.7:2.2",
      "pali": "mārassa visaye ratā;"
    },
    {
      "id": "thig6.7:2.3",
      "pali": "Anekajātisaṁsāraṁ,"
    },
    {
      "id": "thig6.7:2.4",
      "pali": "sandhāvanti aviddasū."
    },
    {
      "id": "thig6.7:3.1",
      "pali": "Kāmacchandañca byāpādaṁ,"
    },
    {
      "id": "thig6.7:3.2",
      "pali": "sakkāyadiṭṭhimeva ca;"
    },
    {
      "id": "thig6.7:3.3",
      "pali": "Sīlabbataparāmāsaṁ,"
    },
    {
      "id": "thig6.7:3.4",
      "pali": "vicikicchañca pañcamaṁ."
    },
    {
      "id": "thig6.7:4.1",
      "pali": "Saṁyojanāni etāni,"
    },
    {
      "id": "thig6.7:4.2",
      "pali": "pajahitvāna bhikkhunī;"
    },
    {
      "id": "thig6.7:4.3",
      "pali": "Orambhāgamanīyāni,"
    },
    {
      "id": "thig6.7:4.4",
      "pali": "nayidaṁ punarehisi."
    },
    {
      "id": "thig6.7:5.1",
      "pali": "Rāgaṁ mānaṁ avijjañca,"
    },
    {
      "id": "thig6.7:5.2",
      "pali": "uddhaccañca vivajjiya;"
    },
    {
      "id": "thig6.7:5.3",
      "pali": "Saṁyojanāni chetvāna,"
    },
    {
      "id": "thig6.7:5.4",
      "pali": "dukkhassantaṁ karissasi."
    },
    {
      "id": "thig6.7:6.1",
      "pali": "Khepetvā jātisaṁsāraṁ,"
    },
    {
      "id": "thig6.7:6.2",
      "pali": "pariññāya punabbhavaṁ;"
    },
    {
      "id": "thig6.7:6.3",
      "pali": "Diṭṭheva dhamme nicchātā,"
    },
    {
      "id": "thig6.7:6.4",
      "pali": "upasantā carissatī”ti."
    },
    {
      "id": "thig6.7:7.1",
      "pali": "… Guttā therī …."
    }
  ]
}
