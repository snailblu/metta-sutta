{
  "uid": "tha-ap342",
  "title": "Ukkhittapadumiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap342:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap342:1.2",
      "pali": "ahosiṁ māliko tadā;"
    },
    {
      "id": "tha-ap342:1.3",
      "pali": "Ogāhetvā padumasaraṁ,"
    },
    {
      "id": "tha-ap342:1.4",
      "pali": "satapattaṁ ocināmahaṁ."
    },
    {
      "id": "tha-ap342:2.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap342:2.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap342:2.3",
      "pali": "Saha satasahassehi,"
    },
    {
      "id": "tha-ap342:2.4",
      "pali": "santacittehi tādibhi."
    },
    {
      "id": "tha-ap342:3.1",
      "pali": "Khīṇāsavehi suddhehi,"
    },
    {
      "id": "tha-ap342:3.2",
      "pali": "chaḷabhiññehi jhāyibhi;"
    },
    {
      "id": "tha-ap342:3.3",
      "pali": "Mama vuddhiṁ samanvesaṁ,"
    },
    {
      "id": "tha-ap342:3.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap342:4.1",
      "pali": "Disvānahaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap342:4.2",
      "pali": "sayambhuṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap342:4.3",
      "pali": "Vaṇṭe chetvā satapattaṁ,"
    },
    {
      "id": "tha-ap342:4.4",
      "pali": "ukkhipimambare tadā."
    },
    {
      "id": "tha-ap342:5.1",
      "pali": "Yadi buddho tuvaṁ vīra,"
    },
    {
      "id": "tha-ap342:5.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap342:5.3",
      "pali": "Sayaṁ gantvā satapattā,"
    },
    {
      "id": "tha-ap342:5.4",
      "pali": "matthake dhārayantu te."
    },
    {
      "id": "tha-ap342:6.1",
      "pali": "Adhiṭṭhahi mahāvīro,"
    },
    {
      "id": "tha-ap342:6.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap342:6.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap342:6.4",
      "pali": "matthake dhārayiṁsu te."
    },
    {
      "id": "tha-ap342:7.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap342:7.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap342:7.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap342:7.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap342:8.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap342:8.2",
      "pali": "satapattanti vuccati;"
    },
    {
      "id": "tha-ap342:8.3",
      "pali": "Saṭṭhiyojanamubbiddhaṁ,"
    },
    {
      "id": "tha-ap342:8.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "tha-ap342:9.1",
      "pali": "Sahassakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap342:9.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap342:9.3",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap342:9.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap342:10.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap342:10.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap342:10.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap342:10.4",
      "pali": "pubbe sukatamattano."
    },
    {
      "id": "tha-ap342:11.1",
      "pali": "Tenevekapadumena,"
    },
    {
      "id": "tha-ap342:11.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap342:11.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap342:11.4",
      "pali": "dhammaṁ sacchikariṁ ahaṁ."
    },
    {
      "id": "tha-ap342:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap342:12.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap342:12.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap342:12.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap342:13.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap342:13.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap342:13.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap342:13.4",
      "pali": "ekapadumassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap342:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap342:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap342:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap342:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā ukkhittapadumiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap342:16.1",
      "pali": "Ukkhittapadumiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap342:17.1",
      "pali": "Gandhodakavaggo catutiṁsatimo."
    },
    {
      "id": "tha-ap342:18.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap342:19.1",
      "pali": "Gandhadhūpo udakañca,"
    },
    {
      "id": "tha-ap342:19.2",
      "pali": "punnāga ekadussakā;"
    },
    {
      "id": "tha-ap342:19.3",
      "pali": "Phusito ca pabhaṅkaro,"
    },
    {
      "id": "tha-ap342:19.4",
      "pali": "kuṭido uttarīyako."
    },
    {
      "id": "tha-ap342:20.1",
      "pali": "Savanī ekapadumī,"
    },
    {
      "id": "tha-ap342:20.2",
      "pali": "gāthāyo sabbapiṇḍitā;"
    },
    {
      "id": "tha-ap342:20.3",
      "pali": "Ekaṁ gāthāsatañceva,"
    },
    {
      "id": "tha-ap342:20.4",
      "pali": "catutālīsameva ca."
    }
  ]
}
