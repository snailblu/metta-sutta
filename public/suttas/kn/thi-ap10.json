{
  "uid": "thi-ap10",
  "title": "Udakadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap10:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "thi-ap10:1.2",
      "pali": "ahosiṁ udahārikā;"
    },
    {
      "id": "thi-ap10:1.3",
      "pali": "Udahārena jīvāmi,"
    },
    {
      "id": "thi-ap10:1.4",
      "pali": "tena posemi dārake."
    },
    {
      "id": "thi-ap10:2.1",
      "pali": "Deyyadhammo ca me natthi,"
    },
    {
      "id": "thi-ap10:2.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "thi-ap10:2.3",
      "pali": "Koṭṭhakaṁ upasaṅkamma,"
    },
    {
      "id": "thi-ap10:2.4",
      "pali": "udakaṁ paṭṭhapesahaṁ."
    },
    {
      "id": "thi-ap10:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap10:3.2",
      "pali": "tāvatiṁsamagacchahaṁ;"
    },
    {
      "id": "thi-ap10:3.3",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "thi-ap10:3.4",
      "pali": "udahārena nimmitaṁ."
    },
    {
      "id": "thi-ap10:4.1",
      "pali": "Accharānaṁ sahassassa,"
    },
    {
      "id": "thi-ap10:4.2",
      "pali": "ahañhi pavarā tadā;"
    },
    {
      "id": "thi-ap10:4.3",
      "pali": "Dasaṭṭhānehi tā sabbā,"
    },
    {
      "id": "thi-ap10:4.4",
      "pali": "abhibhomi sadā ahaṁ."
    },
    {
      "id": "thi-ap10:5.1",
      "pali": "Paññāsaṁ devarājūnaṁ,"
    },
    {
      "id": "thi-ap10:5.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap10:5.3",
      "pali": "Vīsaticakkavattīnaṁ,"
    },
    {
      "id": "thi-ap10:5.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap10:6.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "thi-ap10:6.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "thi-ap10:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap10:6.4",
      "pali": "dakadānassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap10:7.1",
      "pali": "Pabbatagge dumagge vā,"
    },
    {
      "id": "thi-ap10:7.2",
      "pali": "antalikkhe ca bhūmiyaṁ;"
    },
    {
      "id": "thi-ap10:7.3",
      "pali": "Yadā udakamicchāmi,"
    },
    {
      "id": "thi-ap10:7.4",
      "pali": "khippaṁ paṭilabhāmahaṁ."
    },
    {
      "id": "thi-ap10:8.1",
      "pali": "Avuṭṭhikā disā natthi,"
    },
    {
      "id": "thi-ap10:8.2",
      "pali": "santattā kuthitāpi ca;"
    },
    {
      "id": "thi-ap10:8.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "thi-ap10:8.4",
      "pali": "mahāmegho pavassati."
    },
    {
      "id": "thi-ap10:9.1",
      "pali": "Kadāci nīyamānāya,"
    },
    {
      "id": "thi-ap10:9.2",
      "pali": "ñātisaṅghena me tadā;"
    },
    {
      "id": "thi-ap10:9.3",
      "pali": "Yadā icchāmahaṁ vassaṁ,"
    },
    {
      "id": "thi-ap10:9.4",
      "pali": "mahāmegho ajāyatha."
    },
    {
      "id": "thi-ap10:10.1",
      "pali": "Uṇhaṁ vā pariḷāho vā,"
    },
    {
      "id": "thi-ap10:10.2",
      "pali": "sarīre me na vijjati;"
    },
    {
      "id": "thi-ap10:10.3",
      "pali": "Kāye ca me rajo natthi,"
    },
    {
      "id": "thi-ap10:10.4",
      "pali": "dakadānassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap10:11.1",
      "pali": "Visuddhamanasā ajja,"
    },
    {
      "id": "thi-ap10:11.2",
      "pali": "apetamanapāpikā;"
    },
    {
      "id": "thi-ap10:11.3",
      "pali": "Sabbāsavaparikkhīṇā,"
    },
    {
      "id": "thi-ap10:11.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap10:12.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap10:12.2",
      "pali": "yaṁ dakaṁ adadiṁ tadā;"
    },
    {
      "id": "thi-ap10:12.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap10:12.4",
      "pali": "dakadānassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap10:13.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap10:13.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap10:13.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap10:14.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap10:14.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap10:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap10:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap10:15.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap10:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap10:16.1",
      "pali": "Itthaṁ sudaṁ udakadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap10:17.1",
      "pali": "Udakadāyikātheriyāpadānaṁ dasamaṁ."
    },
    {
      "id": "thi-ap10:18.1",
      "pali": "Sumedhāvaggo paṭhamo."
    },
    {
      "id": "thi-ap10:19.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "thi-ap10:20.1",
      "pali": "Sumedhā mekhalādāyī,"
    },
    {
      "id": "thi-ap10:20.2",
      "pali": "maṇḍapaṁ saṅkamaṁ dadā;"
    },
    {
      "id": "thi-ap10:20.3",
      "pali": "Naḷamālī piṇḍadadā,"
    },
    {
      "id": "thi-ap10:20.4",
      "pali": "kaṭacchu uppalappadā."
    },
    {
      "id": "thi-ap10:21.1",
      "pali": "Dīpadā dakadā ceva,"
    },
    {
      "id": "thi-ap10:21.2",
      "pali": "gāthāyo gaṇitā iha;"
    },
    {
      "id": "thi-ap10:21.3",
      "pali": "Ekagāthāsatañceva,"
    },
    {
      "id": "thi-ap10:21.4",
      "pali": "tiṁsati ca taduttari."
    }
  ]
}
