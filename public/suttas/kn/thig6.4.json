{
  "uid": "thig6.4",
  "title": "Sujātātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.4:1.1",
      "pali": "“Alaṅkatā suvasanā,"
    },
    {
      "id": "thig6.4:1.2",
      "pali": "mālinī candanokkhitā;"
    },
    {
      "id": "thig6.4:1.3",
      "pali": "Sabbābharaṇasañchannā,"
    },
    {
      "id": "thig6.4:1.4",
      "pali": "dāsīgaṇapurakkhatā."
    },
    {
      "id": "thig6.4:2.1",
      "pali": "Annaṁ pānañca ādāya,"
    },
    {
      "id": "thig6.4:2.2",
      "pali": "khajjaṁ bhojjaṁ anappakaṁ;"
    },
    {
      "id": "thig6.4:2.3",
      "pali": "Gehato nikkhamitvāna,"
    },
    {
      "id": "thig6.4:2.4",
      "pali": "uyyānamabhihārayiṁ."
    },
    {
      "id": "thig6.4:3.1",
      "pali": "Tattha ramitvā kīḷitvā,"
    },
    {
      "id": "thig6.4:3.2",
      "pali": "āgacchantī sakaṁ gharaṁ;"
    },
    {
      "id": "thig6.4:3.3",
      "pali": "Vihāraṁ daṭṭhuṁ pāvisiṁ,"
    },
    {
      "id": "thig6.4:3.4",
      "pali": "sākete añjanaṁ vanaṁ."
    },
    {
      "id": "thig6.4:4.1",
      "pali": "Disvāna lokapajjotaṁ,"
    },
    {
      "id": "thig6.4:4.2",
      "pali": "vanditvāna upāvisiṁ;"
    },
    {
      "id": "thig6.4:4.3",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thig6.4:4.4",
      "pali": "anukampāya cakkhumā."
    },
    {
      "id": "thig6.4:5.1",
      "pali": "Sutvā ca kho mahesissa,"
    },
    {
      "id": "thig6.4:5.2",
      "pali": "saccaṁ sampaṭivijjhahaṁ;"
    },
    {
      "id": "thig6.4:5.3",
      "pali": "Tattheva virajaṁ dhammaṁ,"
    },
    {
      "id": "thig6.4:5.4",
      "pali": "phusayiṁ amataṁ padaṁ."
    },
    {
      "id": "thig6.4:6.1",
      "pali": "Tato viññātasaddhammā,"
    },
    {
      "id": "thig6.4:6.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thig6.4:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig6.4:6.4",
      "pali": "amoghaṁ buddhasāsanan”ti."
    },
    {
      "id": "thig6.4:7.1",
      "pali": "… Sujātā therī …."
    }
  ]
}
