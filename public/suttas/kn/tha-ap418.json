{
  "uid": "tha-ap418",
  "title": "Ekadīpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap418:1.1",
      "pali": "“Parinibbute sugate,"
    },
    {
      "id": "tha-ap418:1.2",
      "pali": "siddhatthe lokanāyake;"
    },
    {
      "id": "tha-ap418:1.3",
      "pali": "Sadevamānusā sabbe,"
    },
    {
      "id": "tha-ap418:1.4",
      "pali": "pūjenti dvipaduttamaṁ."
    },
    {
      "id": "tha-ap418:2.1",
      "pali": "Āropite ca citake,"
    },
    {
      "id": "tha-ap418:2.2",
      "pali": "siddhatthe lokanāyake;"
    },
    {
      "id": "tha-ap418:2.3",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap418:2.4",
      "pali": "citaṁ pūjenti satthuno."
    },
    {
      "id": "tha-ap418:3.1",
      "pali": "Avidūre citakassa,"
    },
    {
      "id": "tha-ap418:3.2",
      "pali": "dīpaṁ ujjālayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap418:3.3",
      "pali": "Yāva udeti sūriyo,"
    },
    {
      "id": "tha-ap418:3.4",
      "pali": "dīpaṁ me tāva ujjali."
    },
    {
      "id": "tha-ap418:4.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap418:4.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap418:4.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap418:4.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap418:5.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap418:5.2",
      "pali": "ekadīpīti ñāyati;"
    },
    {
      "id": "tha-ap418:5.3",
      "pali": "Dīpasatasahassāni,"
    },
    {
      "id": "tha-ap418:5.4",
      "pali": "byamhe pajjalare mama."
    },
    {
      "id": "tha-ap418:6.1",
      "pali": "Udayantova sūriyo,"
    },
    {
      "id": "tha-ap418:6.2",
      "pali": "deho me jotate sadā;"
    },
    {
      "id": "tha-ap418:6.3",
      "pali": "Sappabhāhi sarīrassa,"
    },
    {
      "id": "tha-ap418:6.4",
      "pali": "āloko hoti me sadā."
    },
    {
      "id": "tha-ap418:7.1",
      "pali": "Tirokuṭṭaṁ tiroselaṁ,"
    },
    {
      "id": "tha-ap418:7.2",
      "pali": "samatiggayha pabbataṁ;"
    },
    {
      "id": "tha-ap418:7.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap418:7.4",
      "pali": "passāmi cakkhunā ahaṁ."
    },
    {
      "id": "tha-ap418:8.1",
      "pali": "Sattasattatikkhattuñca,"
    },
    {
      "id": "tha-ap418:8.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap418:8.3",
      "pali": "Ekatiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap418:8.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap418:9.1",
      "pali": "Aṭṭhavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap418:9.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap418:9.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap418:9.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap418:10.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap418:10.2",
      "pali": "nibbattiṁ mātukucchiyaṁ;"
    },
    {
      "id": "tha-ap418:10.3",
      "pali": "Mātukucchigatassāpi,"
    },
    {
      "id": "tha-ap418:10.4",
      "pali": "akkhi me na nimīlati."
    },
    {
      "id": "tha-ap418:11.1",
      "pali": "Jātiyā catuvassohaṁ,"
    },
    {
      "id": "tha-ap418:11.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap418:11.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "tha-ap418:11.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap418:12.1",
      "pali": "Dibbacakkhuṁ visodhesiṁ,"
    },
    {
      "id": "tha-ap418:12.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap418:12.3",
      "pali": "Sabbe kilesā sañchinnā,"
    },
    {
      "id": "tha-ap418:12.4",
      "pali": "ekadīpassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap418:13.1",
      "pali": "Tirokuṭṭaṁ tiroselaṁ,"
    },
    {
      "id": "tha-ap418:13.2",
      "pali": "pabbatañcāpi kevalaṁ;"
    },
    {
      "id": "tha-ap418:13.3",
      "pali": "Samatikkamma passāmi,"
    },
    {
      "id": "tha-ap418:13.4",
      "pali": "ekadīpassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap418:14.1",
      "pali": "Visamā me samā honti,"
    },
    {
      "id": "tha-ap418:14.2",
      "pali": "andhakāro na vijjati;"
    },
    {
      "id": "tha-ap418:14.3",
      "pali": "Nāhaṁ passāmi timiraṁ,"
    },
    {
      "id": "tha-ap418:14.4",
      "pali": "ekadīpassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap418:15.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap418:15.2",
      "pali": "yaṁ dīpamadadiṁ tadā;"
    },
    {
      "id": "tha-ap418:15.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap418:15.4",
      "pali": "ekadīpassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap418:16.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap418:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap418:16.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap418:17.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap418:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap418:17.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap418:18.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap418:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap418:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap418:19.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekadīpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap418:20.1",
      "pali": "Ekadīpiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
