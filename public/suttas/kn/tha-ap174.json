{
  "uid": "tha-ap174",
  "title": "2 Nisseṇidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap174:1.1",
      "pali": "“Koṇḍaññassa bhagavato,"
    },
    {
      "id": "tha-ap174:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap174:1.3",
      "pali": "Ārohatthāya pāsādaṁ,"
    },
    {
      "id": "tha-ap174:1.4",
      "pali": "nisseṇī kāritā mayā."
    },
    {
      "id": "tha-ap174:2.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap174:2.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap174:2.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap174:2.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap174:3.1",
      "pali": "Ekattiṁsamhi kappānaṁ,"
    },
    {
      "id": "tha-ap174:3.2",
      "pali": "sahassamhi tayo ahuṁ;"
    },
    {
      "id": "tha-ap174:3.3",
      "pali": "Sambahulā nāma rājāno,"
    },
    {
      "id": "tha-ap174:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap174:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap174:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap174:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap174:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā nisseṇidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap174:6.1",
      "pali": "Nisseṇidāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
