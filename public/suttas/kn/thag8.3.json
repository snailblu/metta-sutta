{
  "uid": "thag8.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag8.3:1.1",
      "pali": "“Yadā paṭhamamaddakkhiṁ,"
    },
    {
      "id": "thag8.3:1.2",
      "pali": "satthāramakutobhayaṁ;"
    },
    {
      "id": "thag8.3:1.3",
      "pali": "Tato me ahu saṁvego,"
    },
    {
      "id": "thag8.3:1.4",
      "pali": "passitvā purisuttamaṁ."
    },
    {
      "id": "thag8.3:2.1",
      "pali": "Siriṁ hatthehi pādehi,"
    },
    {
      "id": "thag8.3:2.2",
      "pali": "yo paṇāmeyya āgataṁ;"
    },
    {
      "id": "thag8.3:2.3",
      "pali": "Etādisaṁ so satthāraṁ,"
    },
    {
      "id": "thag8.3:2.4",
      "pali": "ārādhetvā virādhaye."
    },
    {
      "id": "thag8.3:3.1",
      "pali": "Tadāhaṁ puttadārañca,"
    },
    {
      "id": "thag8.3:3.2",
      "pali": "dhanadhaññañca chaḍḍayiṁ;"
    },
    {
      "id": "thag8.3:3.3",
      "pali": "Kesamassūni chedetvā,"
    },
    {
      "id": "thag8.3:3.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thag8.3:4.1",
      "pali": "Sikkhāsājīvasampanno,"
    },
    {
      "id": "thag8.3:4.2",
      "pali": "indriyesu susaṁvuto;"
    },
    {
      "id": "thag8.3:4.3",
      "pali": "Namassamāno sambuddhaṁ,"
    },
    {
      "id": "thag8.3:4.4",
      "pali": "vihāsiṁ aparājito."
    },
    {
      "id": "thag8.3:5.1",
      "pali": "Tato me paṇidhī āsi,"
    },
    {
      "id": "thag8.3:5.2",
      "pali": "cetaso abhipatthito;"
    },
    {
      "id": "thag8.3:5.3",
      "pali": "Na nisīde muhuttampi,"
    },
    {
      "id": "thag8.3:5.4",
      "pali": "taṇhāsalle anūhate."
    },
    {
      "id": "thag8.3:6.1",
      "pali": "Tassa mevaṁ viharato,"
    },
    {
      "id": "thag8.3:6.2",
      "pali": "passa vīriyaparakkamaṁ;"
    },
    {
      "id": "thag8.3:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag8.3:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag8.3:7.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thag8.3:7.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thag8.3:7.3",
      "pali": "Arahā dakkhiṇeyyomhi,"
    },
    {
      "id": "thag8.3:7.4",
      "pali": "vippamutto nirūpadhi."
    },
    {
      "id": "thag8.3:8.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "thag8.3:8.2",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "thag8.3:8.3",
      "pali": "Sabbaṁ taṇhaṁ visosetvā,"
    },
    {
      "id": "thag8.3:8.4",
      "pali": "pallaṅkena upāvisin”ti."
    },
    {
      "id": "thag8.3:8.5",
      "pali": "… Mahāpanthako thero …"
    },
    {
      "id": "thag8.3:8.6",
      "pali": "Aṭṭhakanipāto niṭṭhito."
    },
    {
      "id": "thag8.3:9.1",
      "pali": "Mahākaccāyano thero,"
    },
    {
      "id": "thag8.3:9.2",
      "pali": "sirimitto mahāpanthako;"
    },
    {
      "id": "thag8.3:9.3",
      "pali": "Ete aṭṭhanipātamhi,"
    },
    {
      "id": "thag8.3:9.4",
      "pali": "gāthāyo catuvīsatīti."
    }
  ]
}
