{
  "uid": "tha-ap331",
  "title": "9 Pupphacchattiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap331:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap331:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap331:1.3",
      "pali": "Saccaṁ pakāsayantassa,"
    },
    {
      "id": "tha-ap331:1.4",
      "pali": "nibbāpentassa pāṇino."
    },
    {
      "id": "tha-ap331:2.1",
      "pali": "Jalajaṁ āharitvāna,"
    },
    {
      "id": "tha-ap331:2.2",
      "pali": "satapattaṁ manoramaṁ;"
    },
    {
      "id": "tha-ap331:2.3",
      "pali": "Pupphassa chattaṁ katvāna,"
    },
    {
      "id": "tha-ap331:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap331:3.1",
      "pali": "Siddhattho ca lokavidū,"
    },
    {
      "id": "tha-ap331:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap331:3.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap331:3.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap331:4.1",
      "pali": "‘Yo me cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap331:4.2",
      "pali": "pupphacchattaṁ adhārayiṁ;"
    },
    {
      "id": "tha-ap331:4.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap331:4.4",
      "pali": "duggatiṁ so na gacchati’."
    },
    {
      "id": "tha-ap331:5.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap331:5.2",
      "pali": "siddhattho lokanāyako;"
    },
    {
      "id": "tha-ap331:5.3",
      "pali": "Uyyojetvāna parisaṁ,"
    },
    {
      "id": "tha-ap331:5.4",
      "pali": "vehāsaṁ nabhamuggami."
    },
    {
      "id": "tha-ap331:6.1",
      "pali": "Vuṭṭhite naradevamhi,"
    },
    {
      "id": "tha-ap331:6.2",
      "pali": "setacchattampi vuṭṭhahi;"
    },
    {
      "id": "tha-ap331:6.3",
      "pali": "Purato buddhaseṭṭhassa,"
    },
    {
      "id": "tha-ap331:6.4",
      "pali": "gacchati chattamuttamaṁ."
    },
    {
      "id": "tha-ap331:7.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap331:7.2",
      "pali": "yaṁ chattaṁ abhiropayiṁ;"
    },
    {
      "id": "tha-ap331:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap331:7.4",
      "pali": "pupphacchattassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap331:8.1",
      "pali": "Catusattatikappamhi,"
    },
    {
      "id": "tha-ap331:8.2",
      "pali": "aṭṭha jalasikhā ahū;"
    },
    {
      "id": "tha-ap331:8.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap331:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap331:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap331:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap331:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap331:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphacchattiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap331:11.1",
      "pali": "Pupphacchattiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
