{
  "uid": "thag1.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.1:1.1",
      "pali": "Sīhānaṁva nadantānaṁ,"
    },
    {
      "id": "thag1.1:1.2",
      "pali": "dāṭhīnaṁ girigabbhare;"
    },
    {
      "id": "thag1.1:1.3",
      "pali": "Suṇātha bhāvitattānaṁ,"
    },
    {
      "id": "thag1.1:1.4",
      "pali": "gāthā atthūpanāyikā."
    },
    {
      "id": "thag1.1:2.1",
      "pali": "Yathānāmā yathāgottā,"
    },
    {
      "id": "thag1.1:2.2",
      "pali": "yathādhammavihārino;"
    },
    {
      "id": "thag1.1:2.3",
      "pali": "Yathādhimuttā sappaññā,"
    },
    {
      "id": "thag1.1:2.4",
      "pali": "vihariṁsu atanditā."
    },
    {
      "id": "thag1.1:3.1",
      "pali": "Tattha tattha vipassitvā,"
    },
    {
      "id": "thag1.1:3.2",
      "pali": "phusitvā accutaṁ padaṁ;"
    },
    {
      "id": "thag1.1:3.3",
      "pali": "Katantaṁ paccavekkhantā,"
    },
    {
      "id": "thag1.1:3.4",
      "pali": "imamatthamabhāsisuṁ."
    },
    {
      "id": "thag1.1:4.1",
      "pali": "“Channā me kuṭikā sukhā nivātā,"
    },
    {
      "id": "thag1.1:4.2",
      "pali": "Vassa deva yathāsukhaṁ;"
    },
    {
      "id": "thag1.1:4.3",
      "pali": "Cittaṁ me susamāhitaṁ vimuttaṁ,"
    },
    {
      "id": "thag1.1:4.4",
      "pali": "Ātāpī viharāmi vassa devā”ti."
    },
    {
      "id": "thag1.1:4.5",
      "pali": "Itthaṁ sudaṁ āyasmā subhūtitthero gāthaṁ abhāsitthāti."
    }
  ]
}
