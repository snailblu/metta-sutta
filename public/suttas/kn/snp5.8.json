{
  "uid": "snp5.8",
  "title": "Nandamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.8:1.1",
      "pali": "“Santi loke munayo,"
    },
    {
      "id": "snp5.8:1.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "snp5.8:1.3",
      "pali": "Janā vadanti tayidaṁ kathaṁsu;"
    },
    {
      "id": "snp5.8:1.4",
      "pali": "Ñāṇūpapannaṁ no muniṁ vadanti,"
    },
    {
      "id": "snp5.8:1.5",
      "pali": "Udāhu ve jīvitenūpapannaṁ”."
    },
    {
      "id": "snp5.8:2.1",
      "pali": "“Na diṭṭhiyā na sutiyā na ñāṇena, (…)"
    },
    {
      "id": "snp5.8:2.2",
      "pali": "Munīdha nanda kusalā vadanti;"
    },
    {
      "id": "snp5.8:2.3",
      "pali": "Visenikatvā anīghā nirāsā,"
    },
    {
      "id": "snp5.8:2.4",
      "pali": "Caranti ye te munayoti brūmi”."
    },
    {
      "id": "snp5.8:3.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "snp5.8:3.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "snp5.8:3.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "snp5.8:3.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "snp5.8:3.5",
      "pali": "Anekarūpena vadanti suddhiṁ."
    },
    {
      "id": "snp5.8:3.6",
      "pali": "Kaccissu te bhagavā tattha yatā carantā,"
    },
    {
      "id": "snp5.8:3.7",
      "pali": "Atāru jātiñca jarañca mārisa;"
    },
    {
      "id": "snp5.8:3.8",
      "pali": "Pucchāmi taṁ bhagavā brūhi me taṁ”."
    },
    {
      "id": "snp5.8:4.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "snp5.8:4.2",
      "pali": "(nandāti bhagavā)"
    },
    {
      "id": "snp5.8:4.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "snp5.8:4.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "snp5.8:4.5",
      "pali": "Anekarūpena vadanti suddhiṁ;"
    },
    {
      "id": "snp5.8:4.6",
      "pali": "Kiñcāpi te tattha yatā caranti,"
    },
    {
      "id": "snp5.8:4.7",
      "pali": "Nātariṁsu jātijaranti brūmi”."
    },
    {
      "id": "snp5.8:5.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "snp5.8:5.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "snp5.8:5.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "snp5.8:5.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "snp5.8:5.5",
      "pali": "Anekarūpena vadanti suddhiṁ."
    },
    {
      "id": "snp5.8:5.6",
      "pali": "Te ce muni brūsi anoghatiṇṇe,"
    },
    {
      "id": "snp5.8:5.7",
      "pali": "Atha ko carahi devamanussaloke;"
    },
    {
      "id": "snp5.8:5.8",
      "pali": "Atāri jātiñca jarañca mārisa,"
    },
    {
      "id": "snp5.8:5.9",
      "pali": "Pucchāmi taṁ bhagavā brūhi me taṁ”."
    },
    {
      "id": "snp5.8:6.1",
      "pali": "“Nāhaṁ sabbe samaṇabrāhmaṇāse,"
    },
    {
      "id": "snp5.8:6.2",
      "pali": "(nandāti bhagavā)"
    },
    {
      "id": "snp5.8:6.3",
      "pali": "Jātijarāya nivutāti brūmi;"
    },
    {
      "id": "snp5.8:6.4",
      "pali": "Ye sīdha diṭṭhaṁ va sutaṁ mutaṁ vā,"
    },
    {
      "id": "snp5.8:6.5",
      "pali": "Sīlabbataṁ vāpi pahāya sabbaṁ."
    },
    {
      "id": "snp5.8:6.6",
      "pali": "Anekarūpampi pahāya sabbaṁ,"
    },
    {
      "id": "snp5.8:6.7",
      "pali": "Taṇhaṁ pariññāya anāsavāse;"
    },
    {
      "id": "snp5.8:6.8",
      "pali": "Te ve narā oghatiṇṇāti brūmi”."
    },
    {
      "id": "snp5.8:7.1",
      "pali": "“Etābhinandāmi vaco mahesino,"
    },
    {
      "id": "snp5.8:7.2",
      "pali": "Sukittitaṁ gotamanūpadhīkaṁ;"
    },
    {
      "id": "snp5.8:7.3",
      "pali": "Ye sīdha diṭṭhaṁ va sutaṁ mutaṁ vā,"
    },
    {
      "id": "snp5.8:7.4",
      "pali": "Sīlabbataṁ vāpi pahāya sabbaṁ."
    },
    {
      "id": "snp5.8:7.5",
      "pali": "Anekarūpampi pahāya sabbaṁ,"
    },
    {
      "id": "snp5.8:7.6",
      "pali": "Taṇhaṁ pariññāya anāsavāse;"
    },
    {
      "id": "snp5.8:7.7",
      "pali": "Ahampi te oghatiṇṇāti brūmī”ti."
    },
    {
      "id": "snp5.8:7.8",
      "pali": "Nandamāṇavapucchā sattamā."
    }
  ]
}
