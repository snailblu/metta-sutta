{
  "uid": "tha-ap214",
  "title": "Pānadhidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap214:1.1",
      "pali": "“Āraññikassa isino,"
    },
    {
      "id": "tha-ap214:1.2",
      "pali": "cirarattatapassino;"
    },
    {
      "id": "tha-ap214:1.3",
      "pali": "Vuddhassa bhāvitattassa,"
    },
    {
      "id": "tha-ap214:1.4",
      "pali": "adāsiṁ pānadhiṁ ahaṁ."
    },
    {
      "id": "tha-ap214:2.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap214:2.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap214:2.3",
      "pali": "Dibbayānaṁ anubhomi,"
    },
    {
      "id": "tha-ap214:2.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap214:3.1",
      "pali": "Catunnavute ito kappe,"
    },
    {
      "id": "tha-ap214:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap214:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap214:3.4",
      "pali": "pānadhissa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap214:4.1",
      "pali": "Sattasattatito kappe,"
    },
    {
      "id": "tha-ap214:4.2",
      "pali": "aṭṭha āsiṁsu khattiyā;"
    },
    {
      "id": "tha-ap214:4.3",
      "pali": "Suyānā nāma nāmena,"
    },
    {
      "id": "tha-ap214:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap214:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap214:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap214:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap214:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pānadhidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap214:7.1",
      "pali": "Pānadhidāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
