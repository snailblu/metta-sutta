{
  "uid": "thag2.25",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.25:1.1",
      "pali": "“Kese me olikhissanti,"
    },
    {
      "id": "thag2.25:1.2",
      "pali": "kappako upasaṅkami;"
    },
    {
      "id": "thag2.25:1.3",
      "pali": "Tato ādāsamādāya,"
    },
    {
      "id": "thag2.25:1.4",
      "pali": "sarīraṁ paccavekkhisaṁ."
    },
    {
      "id": "thag2.25:2.1",
      "pali": "Tuccho kāyo adissittha,"
    },
    {
      "id": "thag2.25:2.2",
      "pali": "andhakāro tamo byagā;"
    },
    {
      "id": "thag2.25:2.3",
      "pali": "Sabbe coḷā samucchinnā,"
    },
    {
      "id": "thag2.25:2.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag2.25:2.5",
      "pali": "… Vītasoko thero …."
    }
  ]
}
