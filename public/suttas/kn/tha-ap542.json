{
  "uid": "tha-ap542",
  "title": "Mogharājattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap542:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap542:1.2",
      "pali": "sabbalokavidū muni;"
    },
    {
      "id": "tha-ap542:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap542:1.4",
      "pali": "kappe uppajji cakkhumā."
    },
    {
      "id": "tha-ap542:2.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "tha-ap542:2.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap542:2.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "tha-ap542:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap542:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap542:3.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap542:3.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "tha-ap542:3.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "tha-ap542:4.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "tha-ap542:4.2",
      "pali": "suññataṁ titthiyehi ca;"
    },
    {
      "id": "tha-ap542:4.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "tha-ap542:4.4",
      "pali": "vasībhūtehi tādibhi."
    },
    {
      "id": "tha-ap542:5.1",
      "pali": "Ratanānaṭṭhapaññāsaṁ,"
    },
    {
      "id": "tha-ap542:5.2",
      "pali": "uggato so mahāmuni;"
    },
    {
      "id": "tha-ap542:5.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap542:5.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap542:6.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap542:6.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap542:6.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "tha-ap542:6.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap542:7.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap542:7.2",
      "pali": "kule aññatare ahuṁ;"
    },
    {
      "id": "tha-ap542:7.3",
      "pali": "Parakammāyane yutto,"
    },
    {
      "id": "tha-ap542:7.4",
      "pali": "natthi me kiñci sandhanaṁ."
    },
    {
      "id": "tha-ap542:8.1",
      "pali": "Paṭikkamanasālāyaṁ,"
    },
    {
      "id": "tha-ap542:8.2",
      "pali": "vasanto katabhūmiyaṁ;"
    },
    {
      "id": "tha-ap542:8.3",
      "pali": "Aggiṁ ujjālayiṁ tattha,"
    },
    {
      "id": "tha-ap542:8.4",
      "pali": "daḷhaṁ kaṇhāsi sā mahī."
    },
    {
      "id": "tha-ap542:9.1",
      "pali": "Tadā parisatiṁ nātho,"
    },
    {
      "id": "tha-ap542:9.2",
      "pali": "catusaccapakāsako;"
    },
    {
      "id": "tha-ap542:9.3",
      "pali": "Sāvakaṁ sampakittesi,"
    },
    {
      "id": "tha-ap542:9.4",
      "pali": "lūkhacīvaradhārakaṁ."
    },
    {
      "id": "tha-ap542:10.1",
      "pali": "Tassa tamhi guṇe tuṭṭho,"
    },
    {
      "id": "tha-ap542:10.2",
      "pali": "paṇipacca tathāgataṁ;"
    },
    {
      "id": "tha-ap542:10.3",
      "pali": "Lūkhacīvaradhāraggaṁ,"
    },
    {
      "id": "tha-ap542:10.4",
      "pali": "patthayiṁ ṭhānamuttamaṁ."
    },
    {
      "id": "tha-ap542:11.1",
      "pali": "Tadā avoca bhagavā,"
    },
    {
      "id": "tha-ap542:11.2",
      "pali": "sāvake padumuttaro;"
    },
    {
      "id": "tha-ap542:11.3",
      "pali": "‘Passathetaṁ purisakaṁ,"
    },
    {
      "id": "tha-ap542:11.4",
      "pali": "kucelaṁ tanudehakaṁ."
    },
    {
      "id": "tha-ap542:12.1",
      "pali": "Pītippasannavadanaṁ,"
    },
    {
      "id": "tha-ap542:12.2",
      "pali": "saddhādhanasamanvitaṁ;"
    },
    {
      "id": "tha-ap542:12.3",
      "pali": "Udaggatanujaṁ haṭṭhaṁ,"
    },
    {
      "id": "tha-ap542:12.4",
      "pali": "acalaṁ sālapiṇḍitaṁ."
    },
    {
      "id": "tha-ap542:13.1",
      "pali": "Eso pattheti taṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap542:13.2",
      "pali": "saccasenassa bhikkhuno;"
    },
    {
      "id": "tha-ap542:13.3",
      "pali": "Lūkhacīvaradhārissa,"
    },
    {
      "id": "tha-ap542:13.4",
      "pali": "tassa vaṇṇasitāsayo’."
    },
    {
      "id": "tha-ap542:14.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "tha-ap542:14.2",
      "pali": "nipacca sirasā jinaṁ;"
    },
    {
      "id": "tha-ap542:14.3",
      "pali": "Yāvajīvaṁ subhaṁ kammaṁ,"
    },
    {
      "id": "tha-ap542:14.4",
      "pali": "karitvā jinasāsane."
    },
    {
      "id": "tha-ap542:15.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap542:15.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap542:15.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap542:15.4",
      "pali": "tāvatiṁsūpago ahaṁ."
    },
    {
      "id": "tha-ap542:16.1",
      "pali": "Paṭikkamanasālāyaṁ,"
    },
    {
      "id": "tha-ap542:16.2",
      "pali": "bhūmidāhakakammunā;"
    },
    {
      "id": "tha-ap542:16.3",
      "pali": "Samasahassaṁ niraye,"
    },
    {
      "id": "tha-ap542:16.4",
      "pali": "adayhiṁ vedanāṭṭito."
    },
    {
      "id": "tha-ap542:17.1",
      "pali": "Tena kammāvasesena,"
    },
    {
      "id": "tha-ap542:17.2",
      "pali": "pañca jātisatānihaṁ;"
    },
    {
      "id": "tha-ap542:17.3",
      "pali": "Manusso kulajo hutvā,"
    },
    {
      "id": "tha-ap542:17.4",
      "pali": "jātiyā lakkhaṇaṅkito."
    },
    {
      "id": "tha-ap542:18.1",
      "pali": "Pañca jātisatāneva,"
    },
    {
      "id": "tha-ap542:18.2",
      "pali": "kuṭṭharogasamappito;"
    },
    {
      "id": "tha-ap542:18.3",
      "pali": "Mahādukkhaṁ anubhaviṁ,"
    },
    {
      "id": "tha-ap542:18.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap542:19.1",
      "pali": "Imasmiṁ bhaddake kappe,"
    },
    {
      "id": "tha-ap542:19.2",
      "pali": "upariṭṭhaṁ yasassinaṁ;"
    },
    {
      "id": "tha-ap542:19.3",
      "pali": "Piṇḍapātena tappesiṁ,"
    },
    {
      "id": "tha-ap542:19.4",
      "pali": "pasannamānaso ahaṁ."
    },
    {
      "id": "tha-ap542:20.1",
      "pali": "Tena kammavisesena,"
    },
    {
      "id": "tha-ap542:20.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap542:20.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap542:20.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap542:21.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap542:21.2",
      "pali": "ajāyiṁ khattiye kule;"
    },
    {
      "id": "tha-ap542:21.3",
      "pali": "Pituno accayenāhaṁ,"
    },
    {
      "id": "tha-ap542:21.4",
      "pali": "mahārajjasamappito."
    },
    {
      "id": "tha-ap542:22.1",
      "pali": "Kuṭṭharogādhibhūtohaṁ,"
    },
    {
      "id": "tha-ap542:22.2",
      "pali": "na ratiṁ na sukhaṁ labhe;"
    },
    {
      "id": "tha-ap542:22.3",
      "pali": "Moghaṁ rajjaṁ sukhaṁ yasmā,"
    },
    {
      "id": "tha-ap542:22.4",
      "pali": "mogharājā tato ahaṁ."
    },
    {
      "id": "tha-ap542:23.1",
      "pali": "Kāyassa dosaṁ disvāna,"
    },
    {
      "id": "tha-ap542:23.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap542:23.3",
      "pali": "Bāvarissa dijaggassa,"
    },
    {
      "id": "tha-ap542:23.4",
      "pali": "sissattaṁ ajjhupāgamiṁ."
    },
    {
      "id": "tha-ap542:24.1",
      "pali": "Mahatā parivārena,"
    },
    {
      "id": "tha-ap542:24.2",
      "pali": "upecca naranāyakaṁ;"
    },
    {
      "id": "tha-ap542:24.3",
      "pali": "Apucchiṁ nipuṇaṁ pañhaṁ,"
    },
    {
      "id": "tha-ap542:24.4",
      "pali": "taṁ vīraṁ vādisūdanaṁ."
    },
    {
      "id": "tha-ap542:25.1",
      "pali": "‘Ayaṁ loko paro loko,"
    },
    {
      "id": "tha-ap542:25.2",
      "pali": "brahmaloko sadevako;"
    },
    {
      "id": "tha-ap542:25.3",
      "pali": "Diṭṭhiṁ no nābhijānāmi,"
    },
    {
      "id": "tha-ap542:25.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "tha-ap542:26.1",
      "pali": "Evābhikkantadassāviṁ,"
    },
    {
      "id": "tha-ap542:26.2",
      "pali": "atthi pañhena āgamaṁ;"
    },
    {
      "id": "tha-ap542:26.3",
      "pali": "Kathaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "tha-ap542:26.4",
      "pali": "maccurājā na passati’."
    },
    {
      "id": "tha-ap542:27.1",
      "pali": "‘Suññato lokaṁ avekkhassu,"
    },
    {
      "id": "tha-ap542:27.2",
      "pali": "mogharāja sadā sato;"
    },
    {
      "id": "tha-ap542:27.3",
      "pali": "Attānudiṭṭhiṁ uhacca,"
    },
    {
      "id": "tha-ap542:27.4",
      "pali": "evaṁ maccutaro siyā."
    },
    {
      "id": "tha-ap542:28.1",
      "pali": "Evaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "tha-ap542:28.2",
      "pali": "maccurājā na passati’;"
    },
    {
      "id": "tha-ap542:28.3",
      "pali": "Iti maṁ abhaṇi buddho,"
    },
    {
      "id": "tha-ap542:28.4",
      "pali": "sabbarogatikicchako."
    },
    {
      "id": "tha-ap542:29.1",
      "pali": "Saha gāthāvasānena,"
    },
    {
      "id": "tha-ap542:29.2",
      "pali": "kesamassuvivajjito;"
    },
    {
      "id": "tha-ap542:29.3",
      "pali": "Kāsāvavatthavasano,"
    },
    {
      "id": "tha-ap542:29.4",
      "pali": "āsiṁ bhikkhu tathārahā."
    },
    {
      "id": "tha-ap542:30.1",
      "pali": "Saṅghikesu vihāresu,"
    },
    {
      "id": "tha-ap542:30.2",
      "pali": "na vasiṁ rogapīḷito;"
    },
    {
      "id": "tha-ap542:30.3",
      "pali": "Mā vihāro padussīti,"
    },
    {
      "id": "tha-ap542:30.4",
      "pali": "vātarogehi pīḷito."
    },
    {
      "id": "tha-ap542:31.1",
      "pali": "Saṅkārakūṭā āhitvā,"
    },
    {
      "id": "tha-ap542:31.2",
      "pali": "susānā rathikāhi ca;"
    },
    {
      "id": "tha-ap542:31.3",
      "pali": "Tato saṅghāṭiṁ karitvā,"
    },
    {
      "id": "tha-ap542:31.4",
      "pali": "dhārayiṁ lūkhacīvaraṁ."
    },
    {
      "id": "tha-ap542:32.1",
      "pali": "Mahābhisakko tasmiṁ me,"
    },
    {
      "id": "tha-ap542:32.2",
      "pali": "guṇe tuṭṭho vināyako;"
    },
    {
      "id": "tha-ap542:32.3",
      "pali": "Lūkhacīvaradhārīnaṁ,"
    },
    {
      "id": "tha-ap542:32.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap542:33.1",
      "pali": "Puññapāpaparikkhīṇo,"
    },
    {
      "id": "tha-ap542:33.2",
      "pali": "sabbarogavivajjito;"
    },
    {
      "id": "tha-ap542:33.3",
      "pali": "Sikhīva anupādāno,"
    },
    {
      "id": "tha-ap542:33.4",
      "pali": "nibbāyissamanāsavo."
    },
    {
      "id": "tha-ap542:34.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap542:34.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap542:34.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap542:35.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap542:35.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap542:35.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap542:36.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap542:36.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap542:36.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap542:37.1",
      "pali": "Itthaṁ sudaṁ āyasmā mogharājā thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap542:38.1",
      "pali": "Mogharājattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap542:39.1",
      "pali": "Kaccāyanavaggo catupaññāsamo."
    },
    {
      "id": "tha-ap542:40.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap542:41.1",
      "pali": "Kaccāno vakkalī thero,"
    },
    {
      "id": "tha-ap542:41.2",
      "pali": "mahākappinasavhayo;"
    },
    {
      "id": "tha-ap542:41.3",
      "pali": "Dabbo kumāranāmo ca,"
    },
    {
      "id": "tha-ap542:41.4",
      "pali": "bāhiyo koṭṭhiko vasī."
    },
    {
      "id": "tha-ap542:42.1",
      "pali": "Uruveḷakassapo rādho,"
    },
    {
      "id": "tha-ap542:42.2",
      "pali": "mogharājā ca paṇḍito;"
    },
    {
      "id": "tha-ap542:42.3",
      "pali": "Tīṇi gāthāsatānettha,"
    },
    {
      "id": "tha-ap542:42.4",
      "pali": "bāsaṭṭhi ceva piṇḍitā."
    }
  ]
}
