{
  "uid": "ja267",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja267:1.1",
      "pali": "“Siṅgīmigo āyatacakkhunetto,"
    },
    {
      "id": "ja267:1.2",
      "pali": "Aṭṭhittaco vārisayo alomo;"
    },
    {
      "id": "ja267:1.3",
      "pali": "Tenābhibhūto kapaṇaṁ rudāmi,"
    },
    {
      "id": "ja267:1.4",
      "pali": "Mā heva maṁ pāṇasamaṁ jaheyya”."
    },
    {
      "id": "ja267:2.1",
      "pali": "“Ayya na taṁ jahissāmi,"
    },
    {
      "id": "ja267:2.2",
      "pali": "kuñjaraṁ saṭṭhihāyanaṁ;"
    },
    {
      "id": "ja267:2.3",
      "pali": "Pathabyā cāturantāya,"
    },
    {
      "id": "ja267:2.4",
      "pali": "suppiyo hosi me tuvaṁ”."
    },
    {
      "id": "ja267:3.1",
      "pali": "“Ye kuḷīrā samuddasmiṁ,"
    },
    {
      "id": "ja267:3.2",
      "pali": "gaṅgāya yamunāya ca;"
    },
    {
      "id": "ja267:3.3",
      "pali": "Tesaṁ tvaṁ vārijo seṭṭho,"
    },
    {
      "id": "ja267:3.4",
      "pali": "muñca rodantiyā patin”ti."
    },
    {
      "id": "ja267:4.1",
      "pali": "Kakkaṭakajātakaṁ sattamaṁ."
    }
  ]
}
