{
  "uid": "ja400",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja400:1.1",
      "pali": "“Anutīracārī bhaddante,"
    },
    {
      "id": "ja400:1.2",
      "pali": "sahāyamanudhāva maṁ;"
    },
    {
      "id": "ja400:1.3",
      "pali": "Mahā me gahito maccho,"
    },
    {
      "id": "ja400:1.4",
      "pali": "so maṁ harati vegasā”."
    },
    {
      "id": "ja400:2.1",
      "pali": "“Gambhīracārī bhaddante,"
    },
    {
      "id": "ja400:2.2",
      "pali": "daḷhaṁ gaṇhāhi thāmasā;"
    },
    {
      "id": "ja400:2.3",
      "pali": "Ahaṁ taṁ uddharissāmi,"
    },
    {
      "id": "ja400:2.4",
      "pali": "supaṇṇo uragāmiva”."
    },
    {
      "id": "ja400:3.1",
      "pali": "“Vivādo no samuppanno,"
    },
    {
      "id": "ja400:3.2",
      "pali": "dabbhapuppha suṇohi me;"
    },
    {
      "id": "ja400:3.3",
      "pali": "Samehi medhagaṁ samma,"
    },
    {
      "id": "ja400:3.4",
      "pali": "vivādo vūpasammataṁ”."
    },
    {
      "id": "ja400:4.1",
      "pali": "“Dhammaṭṭhohaṁ pure āsiṁ,"
    },
    {
      "id": "ja400:4.2",
      "pali": "bahū aḍḍā me tīritā;"
    },
    {
      "id": "ja400:4.3",
      "pali": "Samemi medhagaṁ samma,"
    },
    {
      "id": "ja400:4.4",
      "pali": "vivādo vūpasammataṁ."
    },
    {
      "id": "ja400:5.1",
      "pali": "Anutīracāri naṅguṭṭhaṁ,"
    },
    {
      "id": "ja400:5.2",
      "pali": "sīsaṁ gambhīracārino;"
    },
    {
      "id": "ja400:5.3",
      "pali": "Accāyaṁ majjhimo khaṇḍo,"
    },
    {
      "id": "ja400:5.4",
      "pali": "dhammaṭṭhassa bhavissati”."
    },
    {
      "id": "ja400:6.1",
      "pali": "“Cirampi bhakkho abhavissa,"
    },
    {
      "id": "ja400:6.2",
      "pali": "sace na vivademase;"
    },
    {
      "id": "ja400:6.3",
      "pali": "Asīsakaṁ anaṅguṭṭhaṁ,"
    },
    {
      "id": "ja400:6.4",
      "pali": "siṅgālo harati rohitaṁ”."
    },
    {
      "id": "ja400:7.1",
      "pali": "“Yathāpi rājā nandeyya,"
    },
    {
      "id": "ja400:7.2",
      "pali": "rajjaṁ laddhāna khattiyo;"
    },
    {
      "id": "ja400:7.3",
      "pali": "Evāhamajja nandāmi,"
    },
    {
      "id": "ja400:7.4",
      "pali": "disvā puṇṇamukhaṁ patiṁ."
    },
    {
      "id": "ja400:8.1",
      "pali": "Kathaṁ nu thalajo santo,"
    },
    {
      "id": "ja400:8.2",
      "pali": "udake macchaṁ parāmasi;"
    },
    {
      "id": "ja400:8.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja400:8.4",
      "pali": "kathaṁ adhigataṁ tayā”."
    },
    {
      "id": "ja400:9.1",
      "pali": "“Vivādena kisā honti,"
    },
    {
      "id": "ja400:9.2",
      "pali": "vivādena dhanakkhayā;"
    },
    {
      "id": "ja400:9.3",
      "pali": "Jīnā uddā vivādena,"
    },
    {
      "id": "ja400:9.4",
      "pali": "bhuñja māyāvi rohitaṁ."
    },
    {
      "id": "ja400:10.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja400:10.2",
      "pali": "vivādo yattha jāyati;"
    },
    {
      "id": "ja400:10.3",
      "pali": "Dhammaṭṭhaṁ paṭidhāvanti,"
    },
    {
      "id": "ja400:10.4",
      "pali": "so hi nesaṁ vināyako;"
    },
    {
      "id": "ja400:10.5",
      "pali": "Dhanāpi tattha jīyanti,"
    },
    {
      "id": "ja400:10.6",
      "pali": "rājakoso pavaḍḍhatī”ti."
    },
    {
      "id": "ja400:11.1",
      "pali": "Dabbhapupphajātakaṁ pañcamaṁ."
    }
  ]
}
