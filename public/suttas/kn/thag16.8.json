{
  "uid": "thag16.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.8:1.1",
      "pali": "“Gacchaṁ vadesi samaṇaṭṭhitomhi,"
    },
    {
      "id": "thag16.8:1.2",
      "pali": "Mamañca brūsi ṭhitamaṭṭhitoti;"
    },
    {
      "id": "thag16.8:1.3",
      "pali": "Pucchāmi taṁ samaṇa etamatthaṁ,"
    },
    {
      "id": "thag16.8:1.4",
      "pali": "‘Kathaṁ ṭhito tvaṁ ahamaṭṭhitomhi’”."
    },
    {
      "id": "thag16.8:2.1",
      "pali": "“Ṭhito ahaṁ aṅgulimāla sabbadā,"
    },
    {
      "id": "thag16.8:2.2",
      "pali": "Sabbesu bhūtesu nidhāya daṇḍaṁ;"
    },
    {
      "id": "thag16.8:2.3",
      "pali": "Tuvañca pāṇesu asaññatosi,"
    },
    {
      "id": "thag16.8:2.4",
      "pali": "Tasmā ṭhitohaṁ tuvamaṭṭhitosi”."
    },
    {
      "id": "thag16.8:3.1",
      "pali": "“Cirassaṁ vata me mahito mahesī,"
    },
    {
      "id": "thag16.8:3.2",
      "pali": "Mahāvanaṁ samaṇo paccapādi;"
    },
    {
      "id": "thag16.8:3.3",
      "pali": "Sohaṁ cajissāmi sahassapāpaṁ,"
    },
    {
      "id": "thag16.8:3.4",
      "pali": "Sutvāna gāthaṁ tava dhammayuttaṁ”."
    },
    {
      "id": "thag16.8:4.1",
      "pali": "Icceva coro asimāvudhañca,"
    },
    {
      "id": "thag16.8:4.2",
      "pali": "Sobbhe papāte narake anvakāsi;"
    },
    {
      "id": "thag16.8:4.3",
      "pali": "Avandi coro sugatassa pāde,"
    },
    {
      "id": "thag16.8:4.4",
      "pali": "Tattheva pabbajjamayāci buddhaṁ."
    },
    {
      "id": "thag16.8:5.1",
      "pali": "Buddho ca kho kāruṇiko mahesi,"
    },
    {
      "id": "thag16.8:5.2",
      "pali": "Yo satthā lokassa sadevakassa;"
    },
    {
      "id": "thag16.8:5.3",
      "pali": "“Tamehi bhikkhū”ti tadā avoca,"
    },
    {
      "id": "thag16.8:5.4",
      "pali": "Eseva tassa ahu bhikkhubhāvo."
    },
    {
      "id": "thag16.8:6.1",
      "pali": "“Yo ca pubbe pamajjitvā,"
    },
    {
      "id": "thag16.8:6.2",
      "pali": "pacchā so nappamajjati;"
    },
    {
      "id": "thag16.8:6.3",
      "pali": "Somaṁ lokaṁ pabhāseti,"
    },
    {
      "id": "thag16.8:6.4",
      "pali": "abbhā muttova candimā."
    },
    {
      "id": "thag16.8:7.1",
      "pali": "Yassa pāpaṁ kataṁ kammaṁ,"
    },
    {
      "id": "thag16.8:7.2",
      "pali": "kusalena pidhīyati;"
    },
    {
      "id": "thag16.8:7.3",
      "pali": "Somaṁ lokaṁ pabhāseti,"
    },
    {
      "id": "thag16.8:7.4",
      "pali": "abbhā muttova candimā."
    },
    {
      "id": "thag16.8:8.1",
      "pali": "Yo have daharo bhikkhu,"
    },
    {
      "id": "thag16.8:8.2",
      "pali": "yuñjati buddhasāsane;"
    },
    {
      "id": "thag16.8:8.3",
      "pali": "Somaṁ lokaṁ pabhāseti,"
    },
    {
      "id": "thag16.8:8.4",
      "pali": "abbhā muttova candimā."
    },
    {
      "id": "thag16.8:9.1",
      "pali": "Disāpi me dhammakathaṁ suṇantu,"
    },
    {
      "id": "thag16.8:9.2",
      "pali": "Disāpi me yuñjantu buddhasāsane;"
    },
    {
      "id": "thag16.8:9.3",
      "pali": "Disāpi me te manuje bhajantu,"
    },
    {
      "id": "thag16.8:9.4",
      "pali": "Ye dhammamevādapayanti santo."
    },
    {
      "id": "thag16.8:10.1",
      "pali": "Disā hi me khantivādānaṁ,"
    },
    {
      "id": "thag16.8:10.2",
      "pali": "avirodhappasaṁsinaṁ;"
    },
    {
      "id": "thag16.8:10.3",
      "pali": "Suṇantu dhammaṁ kālena,"
    },
    {
      "id": "thag16.8:10.4",
      "pali": "tañca anuvidhīyantu."
    },
    {
      "id": "thag16.8:11.1",
      "pali": "Na hi jātu so mamaṁ hiṁse,"
    },
    {
      "id": "thag16.8:11.2",
      "pali": "aññaṁ vā pana kiñcanaṁ;"
    },
    {
      "id": "thag16.8:11.3",
      "pali": "Pappuyya paramaṁ santiṁ,"
    },
    {
      "id": "thag16.8:11.4",
      "pali": "rakkheyya tasathāvare."
    },
    {
      "id": "thag16.8:12.1",
      "pali": "Udakañhi nayanti nettikā,"
    },
    {
      "id": "thag16.8:12.2",
      "pali": "Usukārā namayanti tejanaṁ;"
    },
    {
      "id": "thag16.8:12.3",
      "pali": "Dāruṁ namayanti tacchakā,"
    },
    {
      "id": "thag16.8:12.4",
      "pali": "Attānaṁ damayanti paṇḍitā."
    },
    {
      "id": "thag16.8:13.1",
      "pali": "Daṇḍeneke damayanti,"
    },
    {
      "id": "thag16.8:13.2",
      "pali": "aṅkusebhi kasāhi ca;"
    },
    {
      "id": "thag16.8:13.3",
      "pali": "Adaṇḍena asatthena,"
    },
    {
      "id": "thag16.8:13.4",
      "pali": "ahaṁ dantomhi tādinā."
    },
    {
      "id": "thag16.8:14.1",
      "pali": "‘Ahiṁsako’ti me nāmaṁ,"
    },
    {
      "id": "thag16.8:14.2",
      "pali": "hiṁsakassa pure sato;"
    },
    {
      "id": "thag16.8:14.3",
      "pali": "Ajjāhaṁ saccanāmomhi,"
    },
    {
      "id": "thag16.8:14.4",
      "pali": "na naṁ hiṁsāmi kiñcanaṁ."
    },
    {
      "id": "thag16.8:15.1",
      "pali": "Coro ahaṁ pure āsiṁ,"
    },
    {
      "id": "thag16.8:15.2",
      "pali": "aṅgulimāloti vissuto;"
    },
    {
      "id": "thag16.8:15.3",
      "pali": "Vuyhamāno mahoghena,"
    },
    {
      "id": "thag16.8:15.4",
      "pali": "buddhaṁ saraṇamāgamaṁ."
    },
    {
      "id": "thag16.8:16.1",
      "pali": "Lohitapāṇi pure āsiṁ,"
    },
    {
      "id": "thag16.8:16.2",
      "pali": "aṅgulimāloti vissuto;"
    },
    {
      "id": "thag16.8:16.3",
      "pali": "Saraṇagamanaṁ passa,"
    },
    {
      "id": "thag16.8:16.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag16.8:17.1",
      "pali": "Tādisaṁ kammaṁ katvāna,"
    },
    {
      "id": "thag16.8:17.2",
      "pali": "bahuṁ duggatigāminaṁ;"
    },
    {
      "id": "thag16.8:17.3",
      "pali": "Phuṭṭho kammavipākena,"
    },
    {
      "id": "thag16.8:17.4",
      "pali": "anaṇo bhuñjāmi bhojanaṁ."
    },
    {
      "id": "thag16.8:18.1",
      "pali": "Pamādamanuyuñjanti,"
    },
    {
      "id": "thag16.8:18.2",
      "pali": "bālā dummedhino janā;"
    },
    {
      "id": "thag16.8:18.3",
      "pali": "Appamādañca medhāvī,"
    },
    {
      "id": "thag16.8:18.4",
      "pali": "dhanaṁ seṭṭhaṁva rakkhati."
    },
    {
      "id": "thag16.8:19.1",
      "pali": "Mā pamādamanuyuñjetha,"
    },
    {
      "id": "thag16.8:19.2",
      "pali": "mā kāmaratisanthavaṁ;"
    },
    {
      "id": "thag16.8:19.3",
      "pali": "Appamatto hi jhāyanto,"
    },
    {
      "id": "thag16.8:19.4",
      "pali": "pappoti paramaṁ sukhaṁ."
    },
    {
      "id": "thag16.8:20.1",
      "pali": "Svāgataṁ nāpagataṁ,"
    },
    {
      "id": "thag16.8:20.2",
      "pali": "netaṁ dummantitaṁ mama;"
    },
    {
      "id": "thag16.8:20.3",
      "pali": "Savibhattesu dhammesu,"
    },
    {
      "id": "thag16.8:20.4",
      "pali": "yaṁ seṭṭhaṁ tadupāgamaṁ."
    },
    {
      "id": "thag16.8:21.1",
      "pali": "Svāgataṁ nāpagataṁ,"
    },
    {
      "id": "thag16.8:21.2",
      "pali": "netaṁ dummantitaṁ mama;"
    },
    {
      "id": "thag16.8:21.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag16.8:21.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag16.8:22.1",
      "pali": "Araññe rukkhamūle vā,"
    },
    {
      "id": "thag16.8:22.2",
      "pali": "pabbatesu guhāsu vā;"
    },
    {
      "id": "thag16.8:22.3",
      "pali": "Tattha tattheva aṭṭhāsiṁ,"
    },
    {
      "id": "thag16.8:22.4",
      "pali": "ubbiggamanaso tadā."
    },
    {
      "id": "thag16.8:23.1",
      "pali": "Sukhaṁ sayāmi ṭhāyāmi,"
    },
    {
      "id": "thag16.8:23.2",
      "pali": "sukhaṁ kappemi jīvitaṁ;"
    },
    {
      "id": "thag16.8:23.3",
      "pali": "Ahatthapāso mārassa,"
    },
    {
      "id": "thag16.8:23.4",
      "pali": "aho satthānukampito."
    },
    {
      "id": "thag16.8:24.1",
      "pali": "Brahmajacco pure āsiṁ,"
    },
    {
      "id": "thag16.8:24.2",
      "pali": "udicco ubhato ahu;"
    },
    {
      "id": "thag16.8:24.3",
      "pali": "Sojja putto sugatassa,"
    },
    {
      "id": "thag16.8:24.4",
      "pali": "dhammarājassa satthuno."
    },
    {
      "id": "thag16.8:25.1",
      "pali": "Vītataṇho anādāno,"
    },
    {
      "id": "thag16.8:25.2",
      "pali": "guttadvāro susaṁvuto;"
    },
    {
      "id": "thag16.8:25.3",
      "pali": "Aghamūlaṁ vadhitvāna,"
    },
    {
      "id": "thag16.8:25.4",
      "pali": "patto me āsavakkhayo."
    },
    {
      "id": "thag16.8:26.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag16.8:26.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thag16.8:26.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thag16.8:26.4",
      "pali": "bhavanetti samūhatā”ti."
    },
    {
      "id": "thag16.8:26.5",
      "pali": "… Aṅgulimālo thero …."
    }
  ]
}
