{
  "uid": "tha-ap41",
  "title": "Dhammacakkikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap41:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap41:1.2",
      "pali": "sīhāsanassa sammukhā;"
    },
    {
      "id": "tha-ap41:1.3",
      "pali": "Dhammacakkaṁ me ṭhapitaṁ,"
    },
    {
      "id": "tha-ap41:1.4",
      "pali": "sukataṁ viññuvaṇṇitaṁ."
    },
    {
      "id": "tha-ap41:2.1",
      "pali": "Cāruvaṇṇova sobhāmi,"
    },
    {
      "id": "tha-ap41:2.2",
      "pali": "sayoggabalavāhano;"
    },
    {
      "id": "tha-ap41:2.3",
      "pali": "Parivārenti maṁ niccaṁ,"
    },
    {
      "id": "tha-ap41:2.4",
      "pali": "anuyantā bahujjanā."
    },
    {
      "id": "tha-ap41:3.1",
      "pali": "Saṭṭhitūriyasahassehi,"
    },
    {
      "id": "tha-ap41:3.2",
      "pali": "paricāremahaṁ sadā;"
    },
    {
      "id": "tha-ap41:3.3",
      "pali": "Parivārena sobhāmi,"
    },
    {
      "id": "tha-ap41:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap41:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap41:4.2",
      "pali": "yaṁ cakkaṁ ṭhapayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap41:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap41:4.4",
      "pali": "dhammacakkassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap41:5.1",
      "pali": "Ito ekādase kappe,"
    },
    {
      "id": "tha-ap41:5.2",
      "pali": "aṭṭhāsiṁsu janādhipā;"
    },
    {
      "id": "tha-ap41:5.3",
      "pali": "Sahassarājanāmena,"
    },
    {
      "id": "tha-ap41:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap41:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap41:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap41:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap41:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhammacakkiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap41:8.1",
      "pali": "Dhammacakkikattherassāpadānaṁ navamaṁ."
    }
  ]
}
