{
  "uid": "ja177",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja177:1.1",
      "pali": "“Dhanuhatthakalāpehi,"
    },
    {
      "id": "ja177:1.2",
      "pali": "nettiṁ savaradhāribhi;"
    },
    {
      "id": "ja177:1.3",
      "pali": "Samantā parikiṇṇamha,"
    },
    {
      "id": "ja177:1.4",
      "pali": "kathaṁ mokkho bhavissati”."
    },
    {
      "id": "ja177:2.1",
      "pali": "“Appeva bahukiccānaṁ,"
    },
    {
      "id": "ja177:2.2",
      "pali": "attho jāyetha koci naṁ;"
    },
    {
      "id": "ja177:2.3",
      "pali": "Atthi rukkhassa acchinnaṁ,"
    },
    {
      "id": "ja177:2.4",
      "pali": "khajjathaññeva tindukan”ti."
    },
    {
      "id": "ja177:3.1",
      "pali": "Tindukajātakaṁ sattamaṁ."
    }
  ]
}
