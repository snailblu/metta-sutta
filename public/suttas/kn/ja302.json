{
  "uid": "ja302",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja302:1.1",
      "pali": "“Adeyyesu dadaṁ dānaṁ,"
    },
    {
      "id": "ja302:1.2",
      "pali": "deyyesu nappavecchati;"
    },
    {
      "id": "ja302:1.3",
      "pali": "Āpāsu byasanaṁ patto,"
    },
    {
      "id": "ja302:1.4",
      "pali": "sahāyaṁ nādhigacchati."
    },
    {
      "id": "ja302:2.1",
      "pali": "Nādeyyesu dadaṁ dānaṁ,"
    },
    {
      "id": "ja302:2.2",
      "pali": "deyyesu yo pavecchati;"
    },
    {
      "id": "ja302:2.3",
      "pali": "Āpāsu byasanaṁ patto,"
    },
    {
      "id": "ja302:2.4",
      "pali": "sahāyamadhigacchati."
    },
    {
      "id": "ja302:3.1",
      "pali": "Saññogasambhogavisesadassanaṁ,"
    },
    {
      "id": "ja302:3.2",
      "pali": "Anariyadhammesu saṭhesu nassati;"
    },
    {
      "id": "ja302:3.3",
      "pali": "Katañca ariyesu ca ajjavesu,"
    },
    {
      "id": "ja302:3.4",
      "pali": "Mahapphalaṁ hoti aṇumpi tādisu."
    },
    {
      "id": "ja302:4.1",
      "pali": "Yo pubbe katakalyāṇo,"
    },
    {
      "id": "ja302:4.2",
      "pali": "Akā loke sudukkaraṁ;"
    },
    {
      "id": "ja302:4.3",
      "pali": "Pacchā kayirā na vā kayirā,"
    },
    {
      "id": "ja302:4.4",
      "pali": "Accantaṁ pūjanāraho”ti."
    },
    {
      "id": "ja302:5.1",
      "pali": "Mahāassārohajātakaṁ dutiyaṁ."
    }
  ]
}
