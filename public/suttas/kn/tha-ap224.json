{
  "uid": "tha-ap224",
  "title": "Ajinadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap224:1.1",
      "pali": "“Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap224:1.2",
      "pali": "gaṇasatthārako ahaṁ;"
    },
    {
      "id": "tha-ap224:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap224:1.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap224:2.1",
      "pali": "Cammakhaṇḍaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap224:2.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap224:2.3",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap224:2.4",
      "pali": "lokajeṭṭha narāsabha."
    },
    {
      "id": "tha-ap224:3.1",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "tha-ap224:3.2",
      "pali": "kilese jhāpayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap224:3.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap224:3.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap224:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap224:4.2",
      "pali": "ajinaṁ yaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap224:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap224:4.4",
      "pali": "ajinassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap224:5.1",
      "pali": "Ito pañcamake kappe,"
    },
    {
      "id": "tha-ap224:5.2",
      "pali": "rājā āsiṁ sudāyako;"
    },
    {
      "id": "tha-ap224:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap224:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap224:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap224:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap224:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap224:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ajinadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap224:8.1",
      "pali": "Ajinadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
