{
  "uid": "cp3",
  "title": "Dānapāramī 3",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp3:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp3:1.2",
      "pali": "indapatthe puruttame;"
    },
    {
      "id": "cp3:1.3",
      "pali": "Rājā dhanañcayo nāma,"
    },
    {
      "id": "cp3:1.4",
      "pali": "kusale dasahupāgato."
    },
    {
      "id": "cp3:2.1",
      "pali": "Kaliṅgaraṭṭhavisayā,"
    },
    {
      "id": "cp3:2.2",
      "pali": "brāhmaṇā upagañchu maṁ;"
    },
    {
      "id": "cp3:2.3",
      "pali": "Āyācuṁ maṁ hatthināgaṁ,"
    },
    {
      "id": "cp3:2.4",
      "pali": "dhaññaṁ maṅgalasammataṁ."
    },
    {
      "id": "cp3:3.1",
      "pali": "‘Avuṭṭhiko janapado,"
    },
    {
      "id": "cp3:3.2",
      "pali": "dubbhikkho chātako mahā;"
    },
    {
      "id": "cp3:3.3",
      "pali": "Dadāhi pavaraṁ nāgaṁ,"
    },
    {
      "id": "cp3:3.4",
      "pali": "nīlaṁ añjanasavhayaṁ’."
    },
    {
      "id": "cp3:4.1",
      "pali": "‘Na me yācakamanuppatte,"
    },
    {
      "id": "cp3:4.2",
      "pali": "paṭikkhepo anucchavo;"
    },
    {
      "id": "cp3:4.3",
      "pali": "Mā me bhijji samādānaṁ,"
    },
    {
      "id": "cp3:4.4",
      "pali": "dassāmi vipulaṁ gajaṁ’."
    },
    {
      "id": "cp3:5.1",
      "pali": "Nāgaṁ gahetvā soṇḍāya,"
    },
    {
      "id": "cp3:5.2",
      "pali": "bhiṅgāre ratanāmaye;"
    },
    {
      "id": "cp3:5.3",
      "pali": "Jalaṁ hatthe ākiritvā,"
    },
    {
      "id": "cp3:5.4",
      "pali": "brāhmaṇānaṁ adaṁ gajaṁ."
    },
    {
      "id": "cp3:6.1",
      "pali": "Tassa nāge padinnamhi,"
    },
    {
      "id": "cp3:6.2",
      "pali": "amaccā etadabravuṁ;"
    },
    {
      "id": "cp3:6.3",
      "pali": "‘Kiṁ nu tuyhaṁ varaṁ nāgaṁ,"
    },
    {
      "id": "cp3:6.4",
      "pali": "yācakānaṁ padassasi."
    },
    {
      "id": "cp3:7.1",
      "pali": "Dhaññaṁ maṅgalasampannaṁ,"
    },
    {
      "id": "cp3:7.2",
      "pali": "saṅgāmavijayuttamaṁ;"
    },
    {
      "id": "cp3:7.3",
      "pali": "Tasmiṁ nāge padinnamhi,"
    },
    {
      "id": "cp3:7.4",
      "pali": "kiṁ te rajjaṁ karissati’."
    },
    {
      "id": "cp3:8.1",
      "pali": "‘Rajjampi me dade sabbaṁ,"
    },
    {
      "id": "cp3:8.2",
      "pali": "sarīraṁ dajjamattano;"
    },
    {
      "id": "cp3:8.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp3:8.4",
      "pali": "tasmā nāgaṁ adāsahan’”ti."
    },
    {
      "id": "cp3:9.1",
      "pali": "Kururājacariyaṁ tatiyaṁ."
    }
  ]
}
