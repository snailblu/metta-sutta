{
  "uid": "vv72",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv72:1.1",
      "pali": "“Alaṅkato malyadharo suvattho,"
    },
    {
      "id": "vv72:1.2",
      "pali": "Sukuṇḍalī kappitakesamassu;"
    },
    {
      "id": "vv72:1.3",
      "pali": "Āmuttahatthābharaṇo yasassī,"
    },
    {
      "id": "vv72:1.4",
      "pali": "Dibbe vimānamhi yathāpi candimā."
    },
    {
      "id": "vv72:2.1",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ,"
    },
    {
      "id": "vv72:2.2",
      "pali": "Aṭṭhaṭṭhakā sikkhitā sādhurūpā;"
    },
    {
      "id": "vv72:2.3",
      "pali": "Dibbā ca kaññā tidasacarā uḷārā,"
    },
    {
      "id": "vv72:2.4",
      "pali": "Naccanti gāyanti pamodayanti."
    },
    {
      "id": "vv72:3.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv72:3.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv72:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv72:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv72:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv72:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv72:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv72:5.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv72:5.2",
      "pali": "Disvāna samaṇe sīlavante;"
    },
    {
      "id": "vv72:5.3",
      "pali": "Sampannavijjācaraṇe yasassī,"
    },
    {
      "id": "vv72:5.4",
      "pali": "Bahussute taṇhakkhayūpapanne;"
    },
    {
      "id": "vv72:5.5",
      "pali": "Annañca pānañca pasannacitto,"
    },
    {
      "id": "vv72:5.6",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv72:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv72:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv72:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv72:7.1",
      "pali": "Paṭhamakuṇḍalīvimānaṁ aṭṭhamaṁ."
    }
  ]
}
