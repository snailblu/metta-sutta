{
  "uid": "ud6.4",
  "title": "Paṭhamanānātitthiyasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud6.4:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud6.4:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud6.4:1.3",
      "pali": "Tena kho pana samayena sambahulā nānātitthiyasamaṇabrāhmaṇaparibbājakā sāvatthiyaṁ paṭivasanti nānādiṭṭhikā nānākhantikā nānārucikā nānādiṭṭhinissayanissitā."
    },
    {
      "id": "ud6.4:2.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:2.2",
      "pali": "“sassato loko, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:3.1",
      "pali": "Santi paneke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:3.2",
      "pali": "“asassato loko, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:4.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:4.2",
      "pali": "“antavā loko, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:5.1",
      "pali": "Santi paneke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:5.2",
      "pali": "“anantavā loko, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:6.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:6.2",
      "pali": "“taṁ jīvaṁ taṁ sarīraṁ, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:7.1",
      "pali": "Santi paneke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:7.2",
      "pali": "“aññaṁ jīvaṁ aññaṁ sarīraṁ, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:8.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:8.2",
      "pali": "“hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:9.1",
      "pali": "Santi paneke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:9.2",
      "pali": "“na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:10.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:10.2",
      "pali": "“hoti ca na ca hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:11.1",
      "pali": "Santi paneke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:11.2",
      "pali": "“neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti."
    },
    {
      "id": "ud6.4:12.1",
      "pali": "Te bhaṇḍanajātā kalahajātā vivādāpannā aññamaññaṁ mukhasattīhi vitudantā viharanti:"
    },
    {
      "id": "ud6.4:12.2",
      "pali": "“ediso dhammo, nediso dhammo;"
    },
    {
      "id": "ud6.4:12.3",
      "pali": "nediso dhammo, ediso dhammo”ti."
    },
    {
      "id": "ud6.4:13.1",
      "pali": "Atha kho sambahulā bhikkhū pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisiṁsu."
    },
    {
      "id": "ud6.4:13.2",
      "pali": "Sāvatthiyaṁ piṇḍāya caritvā pacchābhattaṁ piṇḍapātapaṭikkantā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdiṁsu."
    },
    {
      "id": "ud6.4:13.3",
      "pali": "Ekamantaṁ nisinnā kho te bhikkhū bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "ud6.4:14.1",
      "pali": "“Idha, bhante, sambahulā nānātitthiyasamaṇabrāhmaṇaparibbājakā sāvatthiyaṁ paṭivasanti nānādiṭṭhikā nānākhantikā nānārucikā nānādiṭṭhinissayanissitā—"
    },
    {
      "id": "ud6.4:15.1",
      "pali": "Santeke samaṇabrāhmaṇā evaṁvādino evaṁdiṭṭhino:"
    },
    {
      "id": "ud6.4:15.2",
      "pali": "‘sassato loko, idameva saccaṁ moghamaññan’ti …pe…"
    },
    {
      "id": "ud6.4:15.3",
      "pali": "te bhaṇḍanajātā kalahajātā vivādāpannā aññamaññaṁ mukhasattīhi vitudantā viharanti:"
    },
    {
      "id": "ud6.4:15.4",
      "pali": "‘ediso dhammo, nediso dhammo;"
    },
    {
      "id": "ud6.4:15.5",
      "pali": "nediso dhammo, ediso dhammo’”ti."
    },
    {
      "id": "ud6.4:16.1",
      "pali": "“Aññatitthiyā, bhikkhave, paribbājakā andhā acakkhukā;"
    },
    {
      "id": "ud6.4:16.2",
      "pali": "atthaṁ na jānanti, anatthaṁ na jānanti, dhammaṁ na jānanti, adhammaṁ na jānanti."
    },
    {
      "id": "ud6.4:16.3",
      "pali": "Te atthaṁ ajānantā anatthaṁ ajānantā dhammaṁ ajānantā adhammaṁ ajānantā bhaṇḍanajātā kalahajātā vivādāpannā aññamaññaṁ mukhasattīhi vitudantā viharanti:"
    },
    {
      "id": "ud6.4:16.4",
      "pali": "‘ediso dhammo, nediso dhammo;"
    },
    {
      "id": "ud6.4:16.5",
      "pali": "nediso dhammo, ediso dhammo’ti."
    },
    {
      "id": "ud6.4:17.1",
      "pali": "Bhūtapubbaṁ, bhikkhave, imissāyeva sāvatthiyā aññataro rājā ahosi."
    },
    {
      "id": "ud6.4:17.2",
      "pali": "Atha kho, bhikkhave, so rājā aññataraṁ purisaṁ āmantesi:"
    },
    {
      "id": "ud6.4:17.3",
      "pali": "‘ehi tvaṁ, ambho purisa, yāvatakā sāvatthiyā jaccandhā te sabbe ekajjhaṁ sannipātehī’ti."
    },
    {
      "id": "ud6.4:17.4",
      "pali": "‘Evaṁ, devā’ti kho, bhikkhave, so puriso tassa rañño paṭissutvā yāvatakā sāvatthiyā jaccandhā te sabbe gahetvā yena so rājā tenupasaṅkami; upasaṅkamitvā taṁ rājānaṁ etadavoca:"
    },
    {
      "id": "ud6.4:17.5",
      "pali": "‘sannipātitā kho te, deva, yāvatakā sāvatthiyā jaccandhā’ti."
    },
    {
      "id": "ud6.4:17.6",
      "pali": "‘Tena hi, bhaṇe, jaccandhānaṁ hatthiṁ dassehī’ti."
    },
    {
      "id": "ud6.4:17.7",
      "pali": "‘Evaṁ, devā’ti kho, bhikkhave, so puriso tassa rañño paṭissutvā jaccandhānaṁ hatthiṁ dassesi—"
    },
    {
      "id": "ud6.4:18.1",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa sīsaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.2",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.3",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa kaṇṇaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.4",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.5",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa dantaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.6",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.7",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa soṇḍaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.8",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.9",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa kāyaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.10",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.11",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa pādaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.12",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.13",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa satthiṁ dassesi:"
    },
    {
      "id": "ud6.4:18.14",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.15",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa naṅguṭṭhaṁ dassesi:"
    },
    {
      "id": "ud6.4:18.16",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:18.17",
      "pali": "Ekaccānaṁ jaccandhānaṁ hatthissa vāladhiṁ dassesi:"
    },
    {
      "id": "ud6.4:18.18",
      "pali": "‘ediso, jaccandhā, hatthī’ti."
    },
    {
      "id": "ud6.4:19.1",
      "pali": "Atha kho, bhikkhave, so puriso jaccandhānaṁ hatthiṁ dassetvā yena so rājā tenupasaṅkami; upasaṅkamitvā taṁ rājānaṁ etadavoca:"
    },
    {
      "id": "ud6.4:19.2",
      "pali": "‘diṭṭho kho tehi, deva, jaccandhehi hatthī;"
    },
    {
      "id": "ud6.4:19.3",
      "pali": "yassadāni kālaṁ maññasī’ti."
    },
    {
      "id": "ud6.4:20.1",
      "pali": "Atha kho, bhikkhave, so rājā yena te jaccandhā tenupasaṅkami; upasaṅkamitvā te jaccandhe etadavoca:"
    },
    {
      "id": "ud6.4:20.2",
      "pali": "‘diṭṭho vo, jaccandhā, hatthī’ti?"
    },
    {
      "id": "ud6.4:20.3",
      "pali": "‘Evaṁ, deva, diṭṭho no hatthī’ti."
    },
    {
      "id": "ud6.4:20.4",
      "pali": "‘Vadetha, jaccandhā, kīdiso hatthī’ti?"
    },
    {
      "id": "ud6.4:21.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa sīsaṁ diṭṭhaṁ ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:21.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi kumbho’ti."
    },
    {
      "id": "ud6.4:22.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa kaṇṇo diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:22.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi suppo’ti."
    },
    {
      "id": "ud6.4:23.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa danto diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:23.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi khīlo’ti."
    },
    {
      "id": "ud6.4:24.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa soṇḍo diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:24.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi naṅgalīsā’ti."
    },
    {
      "id": "ud6.4:25.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa kāyo diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:25.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi koṭṭho’ti."
    },
    {
      "id": "ud6.4:26.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa pādo diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:26.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi thūṇo’ti."
    },
    {
      "id": "ud6.4:27.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa satthi diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:27.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi udukkhalo’ti."
    },
    {
      "id": "ud6.4:28.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa naṅguṭṭhaṁ diṭṭhaṁ ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:28.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi musalo’ti."
    },
    {
      "id": "ud6.4:29.1",
      "pali": "Yehi, bhikkhave, jaccandhehi hatthissa vāladhi diṭṭho ahosi, te evamāhaṁsu:"
    },
    {
      "id": "ud6.4:29.2",
      "pali": "‘ediso, deva, hatthī seyyathāpi sammajjanī’ti."
    },
    {
      "id": "ud6.4:30.1",
      "pali": "Te ‘ediso hatthī, nediso hatthī;"
    },
    {
      "id": "ud6.4:30.2",
      "pali": "nediso hatthī, ediso hatthī’ti aññamaññaṁ muṭṭhīhi saṁsumbhiṁsu."
    },
    {
      "id": "ud6.4:30.3",
      "pali": "Tena ca pana, bhikkhave, so rājā attamano ahosi."
    },
    {
      "id": "ud6.4:31.1",
      "pali": "Evamevaṁ kho, bhikkhave, aññatitthiyā paribbājakā andhā acakkhukā."
    },
    {
      "id": "ud6.4:31.2",
      "pali": "Te atthaṁ na jānanti anatthaṁ na jānanti, dhammaṁ na jānanti adhammaṁ na jānanti."
    },
    {
      "id": "ud6.4:31.3",
      "pali": "Te atthaṁ ajānantā anatthaṁ ajānantā, dhammaṁ ajānantā adhammaṁ ajānantā bhaṇḍanajātā kalahajātā vivādāpannā aññamaññaṁ mukhasattīhi vitudantā viharanti:"
    },
    {
      "id": "ud6.4:31.4",
      "pali": "‘ediso dhammo, nediso dhammo;"
    },
    {
      "id": "ud6.4:31.5",
      "pali": "nediso dhammo, ediso dhammo’”ti."
    },
    {
      "id": "ud6.4:32.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud6.4:33.1",
      "pali": "“Imesu kira sajjanti,"
    },
    {
      "id": "ud6.4:33.2",
      "pali": "eke samaṇabrāhmaṇā;"
    },
    {
      "id": "ud6.4:33.3",
      "pali": "Viggayha naṁ vivadanti,"
    },
    {
      "id": "ud6.4:33.4",
      "pali": "janā ekaṅgadassino”ti."
    },
    {
      "id": "ud6.4:33.5",
      "pali": "Catutthaṁ."
    }
  ]
}
