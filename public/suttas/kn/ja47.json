{
  "uid": "ja47",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja47:1.1",
      "pali": "“Na ve anatthakusalena,"
    },
    {
      "id": "ja47:1.2",
      "pali": "atthacariyā sukhāvahā;"
    },
    {
      "id": "ja47:1.3",
      "pali": "Hāpeti atthaṁ dummedho,"
    },
    {
      "id": "ja47:1.4",
      "pali": "koṇḍañño vāruṇiṁ yathā”ti."
    },
    {
      "id": "ja47:2.1",
      "pali": "Vāruṇidūsakajātakaṁ sattamaṁ."
    }
  ]
}
