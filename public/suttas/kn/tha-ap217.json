{
  "uid": "tha-ap217",
  "title": "Raṁsisaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap217:1.1",
      "pali": "“Udentaṁ sataraṁsiṁva,"
    },
    {
      "id": "tha-ap217:1.2",
      "pali": "pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap217:1.3",
      "pali": "Byagghūsabhaṁva pavaraṁ,"
    },
    {
      "id": "tha-ap217:1.4",
      "pali": "sujātaṁ pabbatantare."
    },
    {
      "id": "tha-ap217:2.1",
      "pali": "Buddhassa ānubhāvo so,"
    },
    {
      "id": "tha-ap217:2.2",
      "pali": "jalate pabbatantare;"
    },
    {
      "id": "tha-ap217:2.3",
      "pali": "Raṁse cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap217:2.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap217:3.1",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap217:3.2",
      "pali": "kusalaṁ caritaṁ mayā;"
    },
    {
      "id": "tha-ap217:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap217:3.4",
      "pali": "buddhānussatiyāpi ca."
    },
    {
      "id": "tha-ap217:4.1",
      "pali": "Tiṁsakappasahasseto,"
    },
    {
      "id": "tha-ap217:4.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap217:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap217:4.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap217:5.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap217:5.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap217:5.3",
      "pali": "Sujāto nāma nāmena,"
    },
    {
      "id": "tha-ap217:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap217:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap217:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap217:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap217:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā raṁsisaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap217:8.1",
      "pali": "Raṁsisaññakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
