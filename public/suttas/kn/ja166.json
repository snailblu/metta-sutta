{
  "uid": "ja166",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja166:1.1",
      "pali": "“Upasāḷakanāmāni,"
    },
    {
      "id": "ja166:1.2",
      "pali": "sahassāni catuddasa;"
    },
    {
      "id": "ja166:1.3",
      "pali": "Asmiṁ padese daḍḍhāni,"
    },
    {
      "id": "ja166:1.4",
      "pali": "natthi loke anāmataṁ."
    },
    {
      "id": "ja166:2.1",
      "pali": "Yamhi saccañca dhammo ca,"
    },
    {
      "id": "ja166:2.2",
      "pali": "ahiṁsā saṁyamo damo;"
    },
    {
      "id": "ja166:2.3",
      "pali": "Etaṁ ariyā sevanti,"
    },
    {
      "id": "ja166:2.4",
      "pali": "etaṁ loke anāmatan”ti."
    },
    {
      "id": "ja166:3.1",
      "pali": "Upasāḷakajātakaṁ chaṭṭhaṁ."
    }
  ]
}
