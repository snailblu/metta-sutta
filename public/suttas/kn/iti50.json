{
  "uid": "iti50",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti50:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti50:2.1",
      "pali": "“Tīṇimāni, bhikkhave, akusalamūlāni."
    },
    {
      "id": "iti50:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti50:2.3",
      "pali": "Lobho akusalamūlaṁ, doso akusalamūlaṁ, moho akusalamūlaṁ—"
    },
    {
      "id": "iti50:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi akusalamūlānī”ti."
    },
    {
      "id": "iti50:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti50:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti50:3.1",
      "pali": "“Lobho doso ca moho ca,"
    },
    {
      "id": "iti50:3.2",
      "pali": "purisaṁ pāpacetasaṁ;"
    },
    {
      "id": "iti50:3.3",
      "pali": "Hiṁsanti attasambhūtā,"
    },
    {
      "id": "iti50:3.4",
      "pali": "tacasāraṁva samphalan”ti."
    },
    {
      "id": "iti50:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti50:4.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
