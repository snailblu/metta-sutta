{
  "uid": "iti86",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti86:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti86:2.1",
      "pali": "“Dhammānudhammapaṭipannassa bhikkhuno ayamanudhammo hoti veyyākaraṇāya—"
    },
    {
      "id": "iti86:2.2",
      "pali": "dhammānudhammapaṭipannoyanti bhāsamāno dhammaññeva bhāsati no adhammaṁ, vitakkayamāno vā dhammavitakkaññeva vitakketi no adhammavitakkaṁ, tadubhayaṁ vā pana abhinivejjetvā upekkhako viharati sato sampajāno”ti."
    },
    {
      "id": "iti86:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti86:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti86:3.1",
      "pali": "“Dhammārāmo dhammarato,"
    },
    {
      "id": "iti86:3.2",
      "pali": "dhammaṁ anuvicintayaṁ;"
    },
    {
      "id": "iti86:3.3",
      "pali": "Dhammaṁ anussaraṁ bhikkhu,"
    },
    {
      "id": "iti86:3.4",
      "pali": "saddhammā na parihāyati."
    },
    {
      "id": "iti86:4.1",
      "pali": "Caraṁ vā yadi vā tiṭṭhaṁ,"
    },
    {
      "id": "iti86:4.2",
      "pali": "nisinno uda vā sayaṁ;"
    },
    {
      "id": "iti86:4.3",
      "pali": "Ajjhattaṁ samayaṁ cittaṁ,"
    },
    {
      "id": "iti86:4.4",
      "pali": "santimevādhigacchatī”ti."
    },
    {
      "id": "iti86:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti86:5.2",
      "pali": "Sattamaṁ."
    }
  ]
}
