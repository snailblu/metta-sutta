{
  "uid": "ja192",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja192:1.1",
      "pali": "“Itthī siyā rūpavatī,"
    },
    {
      "id": "ja192:1.2",
      "pali": "sā ca sīlavatī siyā;"
    },
    {
      "id": "ja192:1.3",
      "pali": "Puriso taṁ na iccheyya,"
    },
    {
      "id": "ja192:1.4",
      "pali": "saddahāsi mahosadha”."
    },
    {
      "id": "ja192:2.1",
      "pali": "“Saddahāmi mahārāja,"
    },
    {
      "id": "ja192:2.2",
      "pali": "puriso dubbhago siyā;"
    },
    {
      "id": "ja192:2.3",
      "pali": "Sirī ca kāḷakaṇṇī ca,"
    },
    {
      "id": "ja192:2.4",
      "pali": "na samenti kudācanan”ti."
    },
    {
      "id": "ja192:3.1",
      "pali": "Sirikāḷakaṇṇijātakaṁ dutiyaṁ."
    }
  ]
}
