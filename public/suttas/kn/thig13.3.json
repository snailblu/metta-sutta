{
  "uid": "thig13.3",
  "title": "Cāpātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig13.3:1.1",
      "pali": "“Laṭṭhihattho pure āsi,"
    },
    {
      "id": "thig13.3:1.2",
      "pali": "so dāni migaluddako;"
    },
    {
      "id": "thig13.3:1.3",
      "pali": "Āsāya palipā ghorā,"
    },
    {
      "id": "thig13.3:1.4",
      "pali": "nāsakkhi pārametave."
    },
    {
      "id": "thig13.3:2.1",
      "pali": "Sumattaṁ maṁ maññamānā,"
    },
    {
      "id": "thig13.3:2.2",
      "pali": "cāpā puttamatosayi;"
    },
    {
      "id": "thig13.3:2.3",
      "pali": "Cāpāya bandhanaṁ chetvā,"
    },
    {
      "id": "thig13.3:2.4",
      "pali": "pabbajissaṁ punopahaṁ”."
    },
    {
      "id": "thig13.3:3.1",
      "pali": "“Mā me kujjhi mahāvīra,"
    },
    {
      "id": "thig13.3:3.2",
      "pali": "mā me kujjhi mahāmuni;"
    },
    {
      "id": "thig13.3:3.3",
      "pali": "Na hi kodhaparetassa,"
    },
    {
      "id": "thig13.3:3.4",
      "pali": "suddhi atthi kuto tapo”."
    },
    {
      "id": "thig13.3:4.1",
      "pali": "“Pakkamissañca nāḷāto,"
    },
    {
      "id": "thig13.3:4.2",
      "pali": "kodha nāḷāya vacchati;"
    },
    {
      "id": "thig13.3:4.3",
      "pali": "Bandhantī itthirūpena,"
    },
    {
      "id": "thig13.3:4.4",
      "pali": "samaṇe dhammajīvino”."
    },
    {
      "id": "thig13.3:5.1",
      "pali": "“Ehi kāḷa nivattassu,"
    },
    {
      "id": "thig13.3:5.2",
      "pali": "bhuñja kāme yathā pure;"
    },
    {
      "id": "thig13.3:5.3",
      "pali": "Ahañca te vasīkatā,"
    },
    {
      "id": "thig13.3:5.4",
      "pali": "ye ca me santi ñātakā”."
    },
    {
      "id": "thig13.3:6.1",
      "pali": "“Etto cāpe catubbhāgaṁ,"
    },
    {
      "id": "thig13.3:6.2",
      "pali": "yathā bhāsasi tvañca me;"
    },
    {
      "id": "thig13.3:6.3",
      "pali": "Tayi rattassa posassa,"
    },
    {
      "id": "thig13.3:6.4",
      "pali": "uḷāraṁ vata taṁ siyā”."
    },
    {
      "id": "thig13.3:7.1",
      "pali": "“Kāḷaṅginiṁva takkāriṁ,"
    },
    {
      "id": "thig13.3:7.2",
      "pali": "pupphitaṁ girimuddhani;"
    },
    {
      "id": "thig13.3:7.3",
      "pali": "Phullaṁ dālimalaṭṭhiṁva,"
    },
    {
      "id": "thig13.3:7.4",
      "pali": "antodīpeva pāṭaliṁ."
    },
    {
      "id": "thig13.3:8.1",
      "pali": "Haricandanalittaṅgiṁ,"
    },
    {
      "id": "thig13.3:8.2",
      "pali": "kāsikuttamadhāriniṁ;"
    },
    {
      "id": "thig13.3:8.3",
      "pali": "Taṁ maṁ rūpavatiṁ santiṁ,"
    },
    {
      "id": "thig13.3:8.4",
      "pali": "kassa ohāya gacchasi”."
    },
    {
      "id": "thig13.3:9.1",
      "pali": "“Sākuntikova sakuṇiṁ,"
    },
    {
      "id": "thig13.3:9.2",
      "pali": "yathā bandhitumicchati;"
    },
    {
      "id": "thig13.3:9.3",
      "pali": "Āharimena rūpena,"
    },
    {
      "id": "thig13.3:9.4",
      "pali": "na maṁ tvaṁ bādhayissasi”."
    },
    {
      "id": "thig13.3:10.1",
      "pali": "“Imañca me puttaphalaṁ,"
    },
    {
      "id": "thig13.3:10.2",
      "pali": "kāḷa uppāditaṁ tayā;"
    },
    {
      "id": "thig13.3:10.3",
      "pali": "Taṁ maṁ puttavatiṁ santiṁ,"
    },
    {
      "id": "thig13.3:10.4",
      "pali": "kassa ohāya gacchasi”."
    },
    {
      "id": "thig13.3:11.1",
      "pali": "“Jahanti putte sappaññā,"
    },
    {
      "id": "thig13.3:11.2",
      "pali": "tato ñātī tato dhanaṁ;"
    },
    {
      "id": "thig13.3:11.3",
      "pali": "Pabbajanti mahāvīrā,"
    },
    {
      "id": "thig13.3:11.4",
      "pali": "nāgo chetvāva bandhanaṁ”."
    },
    {
      "id": "thig13.3:12.1",
      "pali": "“Idāni te imaṁ puttaṁ,"
    },
    {
      "id": "thig13.3:12.2",
      "pali": "Daṇḍena churikāya vā;"
    },
    {
      "id": "thig13.3:12.3",
      "pali": "Bhūmiyaṁ vā nisumbhissaṁ,"
    },
    {
      "id": "thig13.3:12.4",
      "pali": "Puttasokā na gacchasi”."
    },
    {
      "id": "thig13.3:13.1",
      "pali": "“Sace puttaṁ siṅgālānaṁ,"
    },
    {
      "id": "thig13.3:13.2",
      "pali": "kukkurānaṁ padāhisi;"
    },
    {
      "id": "thig13.3:13.3",
      "pali": "Na maṁ puttakatte jammi,"
    },
    {
      "id": "thig13.3:13.4",
      "pali": "punarāvattayissasi”."
    },
    {
      "id": "thig13.3:14.1",
      "pali": "“Handa kho dāni bhaddante,"
    },
    {
      "id": "thig13.3:14.2",
      "pali": "kuhiṁ kāḷa gamissasi;"
    },
    {
      "id": "thig13.3:14.3",
      "pali": "Katamaṁ gāmanigamaṁ,"
    },
    {
      "id": "thig13.3:14.4",
      "pali": "nagaraṁ rājadhāniyo”."
    },
    {
      "id": "thig13.3:15.1",
      "pali": "“Ahumha pubbe gaṇino,"
    },
    {
      "id": "thig13.3:15.2",
      "pali": "Assamaṇā samaṇamānino;"
    },
    {
      "id": "thig13.3:15.3",
      "pali": "Gāmena gāmaṁ vicarimha,"
    },
    {
      "id": "thig13.3:15.4",
      "pali": "Nagare rājadhāniyo."
    },
    {
      "id": "thig13.3:16.1",
      "pali": "Eso hi bhagavā buddho,"
    },
    {
      "id": "thig13.3:16.2",
      "pali": "nadiṁ nerañjaraṁ pati;"
    },
    {
      "id": "thig13.3:16.3",
      "pali": "Sabbadukkhappahānāya,"
    },
    {
      "id": "thig13.3:16.4",
      "pali": "dhammaṁ deseti pāṇinaṁ;"
    },
    {
      "id": "thig13.3:16.5",
      "pali": "Tassāhaṁ santikaṁ gacchaṁ,"
    },
    {
      "id": "thig13.3:16.6",
      "pali": "so me satthā bhavissati”."
    },
    {
      "id": "thig13.3:17.1",
      "pali": "“Vandanaṁ dāni vajjāsi,"
    },
    {
      "id": "thig13.3:17.2",
      "pali": "lokanāthaṁ anuttaraṁ;"
    },
    {
      "id": "thig13.3:17.3",
      "pali": "Padakkhiṇañca katvāna,"
    },
    {
      "id": "thig13.3:17.4",
      "pali": "ādiseyyāsi dakkhiṇaṁ”."
    },
    {
      "id": "thig13.3:18.1",
      "pali": "“Etaṁ kho labbhamamhehi,"
    },
    {
      "id": "thig13.3:18.2",
      "pali": "yathā bhāsasi tvañca me;"
    },
    {
      "id": "thig13.3:18.3",
      "pali": "Vandanaṁ dāni te vajjaṁ,"
    },
    {
      "id": "thig13.3:18.4",
      "pali": "lokanāthaṁ anuttaraṁ;"
    },
    {
      "id": "thig13.3:18.5",
      "pali": "Padakkhiṇañca katvāna,"
    },
    {
      "id": "thig13.3:18.6",
      "pali": "ādisissāmi dakkhiṇaṁ”."
    },
    {
      "id": "thig13.3:19.1",
      "pali": "Tato ca kāḷo pakkāmi,"
    },
    {
      "id": "thig13.3:19.2",
      "pali": "nadiṁ nerañjaraṁ pati;"
    },
    {
      "id": "thig13.3:19.3",
      "pali": "So addasāsi sambuddhaṁ,"
    },
    {
      "id": "thig13.3:19.4",
      "pali": "desentaṁ amataṁ padaṁ."
    },
    {
      "id": "thig13.3:20.1",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "thig13.3:20.2",
      "pali": "dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "thig13.3:20.3",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thig13.3:20.4",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "thig13.3:21.1",
      "pali": "Tassa pādāni vanditvā,"
    },
    {
      "id": "thig13.3:21.2",
      "pali": "Katvāna naṁ padakkhiṇaṁ;"
    },
    {
      "id": "thig13.3:21.3",
      "pali": "Cāpāya ādisitvāna,"
    },
    {
      "id": "thig13.3:21.4",
      "pali": "Pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thig13.3:21.5",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig13.3:21.6",
      "pali": "Kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig13.3:22.1",
      "pali": "… Cāpā therī …."
    }
  ]
}
