{
  "uid": "tha-ap368",
  "title": "Kadambapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap368:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap368:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap368:1.3",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap368:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap368:2.1",
      "pali": "Nisajja pāsādavare,"
    },
    {
      "id": "tha-ap368:2.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap368:2.3",
      "pali": "Kadambapupphaṁ paggayha,"
    },
    {
      "id": "tha-ap368:2.4",
      "pali": "vipassiṁ abhipūjayiṁ."
    },
    {
      "id": "tha-ap368:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap368:3.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap368:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap368:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap368:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap368:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap368:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap368:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kadambapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap368:6.1",
      "pali": "Kadambapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
