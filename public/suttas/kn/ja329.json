{
  "uid": "ja329",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja329:1.1",
      "pali": "“Yaṁ annapānassa pure labhāma,"
    },
    {
      "id": "ja329:1.2",
      "pali": "Taṁ dāni sākhamigameva gacchati;"
    },
    {
      "id": "ja329:1.3",
      "pali": "Gacchāma dāni vanameva rādha,"
    },
    {
      "id": "ja329:1.4",
      "pali": "Asakkatā casma dhanañjayāya”."
    },
    {
      "id": "ja329:2.1",
      "pali": "“Lābho alābho yaso ayaso ca,"
    },
    {
      "id": "ja329:2.2",
      "pali": "Nindā pasaṁsā ca sukhañca dukkhaṁ;"
    },
    {
      "id": "ja329:2.3",
      "pali": "Ete aniccā manujesu dhammā,"
    },
    {
      "id": "ja329:2.4",
      "pali": "Mā soci kiṁ socasi poṭṭhapāda”."
    },
    {
      "id": "ja329:3.1",
      "pali": "“Addhā tuvaṁ paṇḍitakosi rādha,"
    },
    {
      "id": "ja329:3.2",
      "pali": "Jānāsi atthāni anāgatāni;"
    },
    {
      "id": "ja329:3.3",
      "pali": "Kathaṁ nu sākhāmigaṁ dakkhisāma,"
    },
    {
      "id": "ja329:3.4",
      "pali": "Niddhāvitaṁ rājakulatova jammaṁ”."
    },
    {
      "id": "ja329:4.1",
      "pali": "“Cāleti kaṇṇaṁ bhakuṭiṁ karoti,"
    },
    {
      "id": "ja329:4.2",
      "pali": "Muhuṁ muhuṁ bhāyayate kumāre;"
    },
    {
      "id": "ja329:4.3",
      "pali": "Sayameva taṁ kāhati kāḷabāhu,"
    },
    {
      "id": "ja329:4.4",
      "pali": "Yenārakā ṭhassati annapānā”ti."
    },
    {
      "id": "ja329:5.1",
      "pali": "Kāḷabāhujātakaṁ navamaṁ."
    }
  ]
}
