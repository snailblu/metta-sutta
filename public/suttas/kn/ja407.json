{
  "uid": "ja407",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja407:1.1",
      "pali": "“Attānaṁ saṅkamaṁ katvā,"
    },
    {
      "id": "ja407:1.2",
      "pali": "Yo sotthiṁ samatārayi;"
    },
    {
      "id": "ja407:1.3",
      "pali": "Kiṁ tvaṁ tesaṁ kime tuyhaṁ,"
    },
    {
      "id": "ja407:1.4",
      "pali": "Honti ete mahākapi”."
    },
    {
      "id": "ja407:2.1",
      "pali": "“Rājāhaṁ issaro tesaṁ,"
    },
    {
      "id": "ja407:2.2",
      "pali": "yūthassa parihārako;"
    },
    {
      "id": "ja407:2.3",
      "pali": "Tesaṁ sokaparetānaṁ,"
    },
    {
      "id": "ja407:2.4",
      "pali": "bhītānaṁ te arindama."
    },
    {
      "id": "ja407:3.1",
      "pali": "Ullaṅghayitvā attānaṁ,"
    },
    {
      "id": "ja407:3.2",
      "pali": "vissaṭṭhadhanuno sataṁ;"
    },
    {
      "id": "ja407:3.3",
      "pali": "Tato aparapādesu,"
    },
    {
      "id": "ja407:3.4",
      "pali": "daḷhaṁ bandhaṁ latāguṇaṁ."
    },
    {
      "id": "ja407:4.1",
      "pali": "Chinnabbhamiva vātena,"
    },
    {
      "id": "ja407:4.2",
      "pali": "Nuṇṇo rukkhaṁ upāgamiṁ;"
    },
    {
      "id": "ja407:4.3",
      "pali": "Sohaṁ appabhavaṁ tattha,"
    },
    {
      "id": "ja407:4.4",
      "pali": "Sākhaṁ hatthehi aggahiṁ."
    },
    {
      "id": "ja407:5.1",
      "pali": "Taṁ maṁ viyāyataṁ santaṁ,"
    },
    {
      "id": "ja407:5.2",
      "pali": "sākhāya ca latāya ca;"
    },
    {
      "id": "ja407:5.3",
      "pali": "Samanukkamantā pādehi,"
    },
    {
      "id": "ja407:5.4",
      "pali": "sotthiṁ sākhāmigā gatā."
    },
    {
      "id": "ja407:6.1",
      "pali": "Taṁ maṁ na tapate bandho,"
    },
    {
      "id": "ja407:6.2",
      "pali": "mato me na tapessati;"
    },
    {
      "id": "ja407:6.3",
      "pali": "Sukhamāharitaṁ tesaṁ,"
    },
    {
      "id": "ja407:6.4",
      "pali": "yesaṁ rajjamakārayiṁ."
    },
    {
      "id": "ja407:7.1",
      "pali": "Esā te upamā rāja,"
    },
    {
      "id": "ja407:7.2",
      "pali": "taṁ suṇohi arindama;"
    },
    {
      "id": "ja407:7.3",
      "pali": "Raññā raṭṭhassa yoggassa,"
    },
    {
      "id": "ja407:7.4",
      "pali": "balassa nigamassa ca;"
    },
    {
      "id": "ja407:7.5",
      "pali": "Sabbesaṁ sukhameṭṭhabbaṁ,"
    },
    {
      "id": "ja407:7.6",
      "pali": "khattiyena pajānatā”ti."
    },
    {
      "id": "ja407:8.1",
      "pali": "Mahākapijātakaṁ dutiyaṁ."
    }
  ]
}
