{
  "uid": "thag1.17",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.17:1.1",
      "pali": "“Middhī yadā hoti mahagghaso ca,"
    },
    {
      "id": "thag1.17:1.2",
      "pali": "Niddāyitā samparivattasāyī;"
    },
    {
      "id": "thag1.17:1.3",
      "pali": "Mahāvarāhova nivāpapuṭṭho,"
    },
    {
      "id": "thag1.17:1.4",
      "pali": "Punappunaṁ gabbhamupeti mando”ti."
    },
    {
      "id": "thag1.17:1.5",
      "pali": "… Dāsako thero …."
    }
  ]
}
