{
  "uid": "ja54",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja54:1.1",
      "pali": "“Nāyaṁ rukkho durāruho,"
    },
    {
      "id": "ja54:1.2",
      "pali": "napi gāmato ārakā;"
    },
    {
      "id": "ja54:1.3",
      "pali": "Ākāraṇena jānāmi,"
    },
    {
      "id": "ja54:1.4",
      "pali": "nāyaṁ sāduphalo dumo”ti."
    },
    {
      "id": "ja54:2.1",
      "pali": "Kiṁphalajātakaṁ catutthaṁ."
    }
  ]
}
