{
  "uid": "ja512",
  "title": "Kiṁchandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja512:1.1",
      "pali": "“Ko pāturāsī tidivā nabhamhi,"
    },
    {
      "id": "ja512:1.2",
      "pali": "Obhāsayaṁ saṁvariṁ candimāva;"
    },
    {
      "id": "ja512:1.3",
      "pali": "Gattehi te rasmiyo niccharanti,"
    },
    {
      "id": "ja512:1.4",
      "pali": "Sateratā vijjurivantalikkhe."
    },
    {
      "id": "ja512:2.1",
      "pali": "So chinnavātaṁ kamasī aghamhi,"
    },
    {
      "id": "ja512:2.2",
      "pali": "Vehāyasaṁ gacchasi tiṭṭhasī ca;"
    },
    {
      "id": "ja512:2.3",
      "pali": "Iddhī nu te vatthukatā subhāvitā,"
    },
    {
      "id": "ja512:2.4",
      "pali": "Anaddhagūnaṁ api devatānaṁ."
    },
    {
      "id": "ja512:3.1",
      "pali": "Vehāyasaṁ gammamāgamma tiṭṭhasi,"
    },
    {
      "id": "ja512:3.2",
      "pali": "Kumbhaṁ kiṇāthāti yametamatthaṁ;"
    },
    {
      "id": "ja512:3.3",
      "pali": "Ko vā tuvaṁ kissa vā tāya kumbho,"
    },
    {
      "id": "ja512:3.4",
      "pali": "Akkhāhi me brāhmaṇa etamatthaṁ”."
    },
    {
      "id": "ja512:4.1",
      "pali": "“Na sappikumbho napi telakumbho,"
    },
    {
      "id": "ja512:4.2",
      "pali": "Na phāṇitassa na madhussa kumbho;"
    },
    {
      "id": "ja512:4.3",
      "pali": "Kumbhassa vajjāni anappakāni,"
    },
    {
      "id": "ja512:4.4",
      "pali": "Dose bahū kumbhagate suṇātha."
    },
    {
      "id": "ja512:5.1",
      "pali": "Gaḷeyya yaṁ pitvā pate papātaṁ,"
    },
    {
      "id": "ja512:5.2",
      "pali": "Sobbhaṁ guhaṁ candaniyoḷigallaṁ;"
    },
    {
      "id": "ja512:5.3",
      "pali": "Bahumpi bhuñjeyya abhojaneyyaṁ,"
    },
    {
      "id": "ja512:5.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:6.1",
      "pali": "Yaṁ pitva cittasmimanesamāno,"
    },
    {
      "id": "ja512:6.2",
      "pali": "Āhiṇḍatī goriva bhakkhasādī;"
    },
    {
      "id": "ja512:6.3",
      "pali": "Anāthamāno upagāyati naccati ca,"
    },
    {
      "id": "ja512:6.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:7.1",
      "pali": "Yaṁ ve pivitvā acelova naggo,"
    },
    {
      "id": "ja512:7.2",
      "pali": "Careyya gāme visikhantarāni;"
    },
    {
      "id": "ja512:7.3",
      "pali": "Sammūḷhacitto ativelasāyī,"
    },
    {
      "id": "ja512:7.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:8.1",
      "pali": "Yaṁ pitva uṭṭhāya pavedhamāno,"
    },
    {
      "id": "ja512:8.2",
      "pali": "Sīsañca bāhuñca pacālayanto;"
    },
    {
      "id": "ja512:8.3",
      "pali": "So naccatī dārukaṭallakova,"
    },
    {
      "id": "ja512:8.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:9.1",
      "pali": "Yaṁ ve pivitvā aggidaḍḍhā sayanti,"
    },
    {
      "id": "ja512:9.2",
      "pali": "Atho sigālehipi khāditāse;"
    },
    {
      "id": "ja512:9.3",
      "pali": "Bandhaṁ vadhaṁ bhogajāniñcupenti,"
    },
    {
      "id": "ja512:9.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:10.1",
      "pali": "Yaṁ pitva bhāseyya abhāsaneyyaṁ,"
    },
    {
      "id": "ja512:10.2",
      "pali": "Sabhāyamāsīno apetavattho;"
    },
    {
      "id": "ja512:10.3",
      "pali": "Sammakkhito vantagato byasanno,"
    },
    {
      "id": "ja512:10.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:11.1",
      "pali": "Yaṁ ve pivitvā ukkaṭṭho āvilakkho,"
    },
    {
      "id": "ja512:11.2",
      "pali": "Mameva sabbā pathavīti maññe;"
    },
    {
      "id": "ja512:11.3",
      "pali": "Na me samo cāturantopi rājā,"
    },
    {
      "id": "ja512:11.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:12.1",
      "pali": "Mānātimānā kalahāni pesuṇī,"
    },
    {
      "id": "ja512:12.2",
      "pali": "Dubbaṇṇinī naggayinī palāyinī;"
    },
    {
      "id": "ja512:12.3",
      "pali": "Corāna dhuttāna gatī niketo,"
    },
    {
      "id": "ja512:12.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:13.1",
      "pali": "Iddhāni phītāni kulāni assu,"
    },
    {
      "id": "ja512:13.2",
      "pali": "Anekasāhassadhanāni loke;"
    },
    {
      "id": "ja512:13.3",
      "pali": "Ucchinnadāyajjakatānimāya,"
    },
    {
      "id": "ja512:13.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:14.1",
      "pali": "Dhaññaṁ dhanaṁ rajataṁ jātarūpaṁ,"
    },
    {
      "id": "ja512:14.2",
      "pali": "Khettaṁ gavaṁ yattha vināsayanti;"
    },
    {
      "id": "ja512:14.3",
      "pali": "Ucchedanī vittavataṁ kulānaṁ,"
    },
    {
      "id": "ja512:14.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:15.1",
      "pali": "Yaṁ ve pitvā dittarūpova poso,"
    },
    {
      "id": "ja512:15.2",
      "pali": "Akkosati mātaraṁ pitarañca;"
    },
    {
      "id": "ja512:15.3",
      "pali": "Sassumpi gaṇheyya athopi suṇhaṁ,"
    },
    {
      "id": "ja512:15.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:16.1",
      "pali": "Yaṁ ve pitvā dittarūpāva nārī,"
    },
    {
      "id": "ja512:16.2",
      "pali": "Akkosatī sasuraṁ sāmikañca;"
    },
    {
      "id": "ja512:16.3",
      "pali": "Dāsampi gaṇhe paricārakampi,"
    },
    {
      "id": "ja512:16.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:17.1",
      "pali": "Yaṁ ve pivitvāna haneyya poso,"
    },
    {
      "id": "ja512:17.2",
      "pali": "Dhamme ṭhitaṁ samaṇaṁ brāhmaṇaṁ vā;"
    },
    {
      "id": "ja512:17.3",
      "pali": "Gacche apāyampi tatonidānaṁ,"
    },
    {
      "id": "ja512:17.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:18.1",
      "pali": "Yaṁ ve pivitvā duccaritaṁ caranti,"
    },
    {
      "id": "ja512:18.2",
      "pali": "Kāyena vācāya ca cetasā ca;"
    },
    {
      "id": "ja512:18.3",
      "pali": "Nirayaṁ vajanti duccaritaṁ caritvā,"
    },
    {
      "id": "ja512:18.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:19.1",
      "pali": "Yaṁ yācamānā na labhanti pubbe,"
    },
    {
      "id": "ja512:19.2",
      "pali": "Bahuṁ hiraññampi pariccajantā;"
    },
    {
      "id": "ja512:19.3",
      "pali": "So taṁ pivitvā alikaṁ bhaṇāti,"
    },
    {
      "id": "ja512:19.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:20.1",
      "pali": "Yaṁ ve pitvā pesane pesiyanto,"
    },
    {
      "id": "ja512:20.2",
      "pali": "Accāyike karaṇīyamhi jāte;"
    },
    {
      "id": "ja512:20.3",
      "pali": "Atthampi so nappajānāti vutto,"
    },
    {
      "id": "ja512:20.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:21.1",
      "pali": "Hirīmanāpi ahirīkabhāvaṁ,"
    },
    {
      "id": "ja512:21.2",
      "pali": "Pātuṁ karonti madanāya mattā;"
    },
    {
      "id": "ja512:21.3",
      "pali": "Dhīrāpi santā bahukaṁ bhaṇanti,"
    },
    {
      "id": "ja512:21.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:22.1",
      "pali": "Yaṁ ve pitvā ekathūpā sayanti,"
    },
    {
      "id": "ja512:22.2",
      "pali": "Anāsakā thaṇḍiladukkhaseyyaṁ;"
    },
    {
      "id": "ja512:22.3",
      "pali": "Dubbaṇṇiyaṁ āyasakyañcupenti,"
    },
    {
      "id": "ja512:22.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:23.1",
      "pali": "Yaṁ ve pitvā pattakhandhā sayanti,"
    },
    {
      "id": "ja512:23.2",
      "pali": "Gāvo kuṭahatāva na hi vāruṇiyā;"
    },
    {
      "id": "ja512:23.3",
      "pali": "Vego narena susahoriva,"
    },
    {
      "id": "ja512:23.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:24.1",
      "pali": "Yaṁ manussā vivajjenti,"
    },
    {
      "id": "ja512:24.2",
      "pali": "sappaṁ ghoravisamiva;"
    },
    {
      "id": "ja512:24.3",
      "pali": "Taṁ loke visasamānaṁ,"
    },
    {
      "id": "ja512:24.4",
      "pali": "ko naro pātumarahati."
    },
    {
      "id": "ja512:25.1",
      "pali": "Yaṁ ve pitvā andhakaveṇḍaputtā,"
    },
    {
      "id": "ja512:25.2",
      "pali": "Samuddatīre paricārayantā;"
    },
    {
      "id": "ja512:25.3",
      "pali": "Upakkamuṁ musalehaññamaññaṁ,"
    },
    {
      "id": "ja512:25.4",
      "pali": "Tassā puṇṇaṁ kumbhamimaṁ kiṇātha."
    },
    {
      "id": "ja512:26.1",
      "pali": "Yaṁ ve pitvā pubbadevā pamattā,"
    },
    {
      "id": "ja512:26.2",
      "pali": "Tidivā cutā sassatiyā samāya;"
    },
    {
      "id": "ja512:26.3",
      "pali": "Taṁ tādisaṁ majjamimaṁ niratthakaṁ,"
    },
    {
      "id": "ja512:26.4",
      "pali": "Jānaṁ mahārāja kathaṁ piveyya."
    },
    {
      "id": "ja512:27.1",
      "pali": "Nayimasmiṁ kumbhasmiṁ dadhi vā madhu vā,"
    },
    {
      "id": "ja512:27.2",
      "pali": "Evaṁ abhiññāya kiṇāhi rāja;"
    },
    {
      "id": "ja512:27.3",
      "pali": "Evañhimaṁ kumbhagatā mayā te,"
    },
    {
      "id": "ja512:27.4",
      "pali": "Akkhātarūpaṁ tava sabbamitta”."
    },
    {
      "id": "ja512:28.1",
      "pali": "“Na me pitā vā athavāpi mātā,"
    },
    {
      "id": "ja512:28.2",
      "pali": "Etādisā yādisako tuvaṁsi;"
    },
    {
      "id": "ja512:28.3",
      "pali": "Hitānukampī paramatthakāmo,"
    },
    {
      "id": "ja512:28.4",
      "pali": "Sohaṁ karissaṁ vacanaṁ tavajja."
    },
    {
      "id": "ja512:29.1",
      "pali": "Dadāmi te gāmavarāni pañca,"
    },
    {
      "id": "ja512:29.2",
      "pali": "Dāsīsataṁ satta gavaṁsatāni;"
    },
    {
      "id": "ja512:29.3",
      "pali": "Ājaññayutte ca rathe dasa ime,"
    },
    {
      "id": "ja512:29.4",
      "pali": "Ācariyo hosi mamatthakāmo”."
    },
    {
      "id": "ja512:30.1",
      "pali": "“Taveva dāsīsatamatthu rāja,"
    },
    {
      "id": "ja512:30.2",
      "pali": "Gāmā ca gāvo ca taveva hontu;"
    },
    {
      "id": "ja512:30.3",
      "pali": "Ājaññayuttā ca rathā taveva,"
    },
    {
      "id": "ja512:30.4",
      "pali": "Sakkohamasmī tidasānamindo."
    },
    {
      "id": "ja512:31.1",
      "pali": "Maṁsodanaṁ sappipāyāsaṁ bhuñja,"
    },
    {
      "id": "ja512:31.2",
      "pali": "Khādassu ca tvaṁ madhumāsapūve;"
    },
    {
      "id": "ja512:31.3",
      "pali": "Evaṁ tuvaṁ dhammarato janinda,"
    },
    {
      "id": "ja512:31.4",
      "pali": "Anindito saggamupehi ṭhānan”ti."
    },
    {
      "id": "ja512:32.1",
      "pali": "Kumbhajātakaṁ dutiyaṁ."
    }
  ]
}
