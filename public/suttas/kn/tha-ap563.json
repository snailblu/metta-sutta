{
  "uid": "tha-ap563",
  "title": "Raṭṭhapālattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap563:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap563:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap563:1.3",
      "pali": "Varanāgo mayā dinno,"
    },
    {
      "id": "tha-ap563:1.4",
      "pali": "Īsādanto urūḷhavā."
    },
    {
      "id": "tha-ap563:2.1",
      "pali": "Setacchattopasobhito,"
    },
    {
      "id": "tha-ap563:2.2",
      "pali": "sakappano sahatthipo;"
    },
    {
      "id": "tha-ap563:2.3",
      "pali": "Agghāpetvāna taṁ sabbaṁ,"
    },
    {
      "id": "tha-ap563:2.4",
      "pali": "saṅghārāmaṁ akārayiṁ."
    },
    {
      "id": "tha-ap563:3.1",
      "pali": "Catupaññāsasahassāni,"
    },
    {
      "id": "tha-ap563:3.2",
      "pali": "pāsāde kārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap563:3.3",
      "pali": "Mahoghadānaṁ karitvāna,"
    },
    {
      "id": "tha-ap563:3.4",
      "pali": "niyyādesiṁ mahesino."
    },
    {
      "id": "tha-ap563:4.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap563:4.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap563:4.3",
      "pali": "Sabbe jane hāsayanto,"
    },
    {
      "id": "tha-ap563:4.4",
      "pali": "desesi amataṁ padaṁ."
    },
    {
      "id": "tha-ap563:5.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "tha-ap563:5.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap563:5.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap563:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap563:6.1",
      "pali": "‘Catupaññāsasahassāni,"
    },
    {
      "id": "tha-ap563:6.2",
      "pali": "pāsāde kārayī ayaṁ;"
    },
    {
      "id": "tha-ap563:6.3",
      "pali": "Kathayissāmi vipākaṁ,"
    },
    {
      "id": "tha-ap563:6.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap563:7.1",
      "pali": "Aṭṭhārasasahassāni,"
    },
    {
      "id": "tha-ap563:7.2",
      "pali": "kūṭāgārā bhavissare;"
    },
    {
      "id": "tha-ap563:7.3",
      "pali": "Byamhuttamamhi nibbattā,"
    },
    {
      "id": "tha-ap563:7.4",
      "pali": "sabbasoṇṇamayā ca te."
    },
    {
      "id": "tha-ap563:8.1",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap563:8.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap563:8.3",
      "pali": "Aṭṭhapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap563:8.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap563:9.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap563:9.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap563:9.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap563:9.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap563:10.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap563:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap563:10.3",
      "pali": "Aḍḍhe kule mahābhoge,"
    },
    {
      "id": "tha-ap563:10.4",
      "pali": "nibbattissati tāvade."
    },
    {
      "id": "tha-ap563:11.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap563:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap563:11.3",
      "pali": "Raṭṭhapāloti nāmena,"
    },
    {
      "id": "tha-ap563:11.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap563:12.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap563:12.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap563:12.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap563:12.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap563:13.1",
      "pali": "Uṭṭhāya abhinikkhamma,"
    },
    {
      "id": "tha-ap563:13.2",
      "pali": "jahitā bhogasampadā;"
    },
    {
      "id": "tha-ap563:13.3",
      "pali": "Kheḷapiṇḍeva bhogamhi,"
    },
    {
      "id": "tha-ap563:13.4",
      "pali": "pemaṁ mayhaṁ na vijjati."
    },
    {
      "id": "tha-ap563:14.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "tha-ap563:14.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "tha-ap563:14.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap563:14.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap563:15.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap563:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap563:15.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap563:16.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap563:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap563:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap563:17.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap563:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap563:17.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap563:18.1",
      "pali": "Itthaṁ sudaṁ āyasmā raṭṭhapālo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap563:19.1",
      "pali": "Raṭṭhapālattherassāpadānaṁ ekādasamaṁ."
    },
    {
      "id": "tha-ap563:20.1",
      "pali": "Yasavaggo chapaññāsamo."
    },
    {
      "id": "tha-ap563:21.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap563:22.1",
      "pali": "Yaso nadīkassapo ca,"
    },
    {
      "id": "tha-ap563:22.2",
      "pali": "gayākimilavajjino;"
    },
    {
      "id": "tha-ap563:22.3",
      "pali": "Duve uttarā bhaddajī,"
    },
    {
      "id": "tha-ap563:22.4",
      "pali": "sivako upavāhano;"
    },
    {
      "id": "tha-ap563:22.5",
      "pali": "Raṭṭhapālo ekasataṁ,"
    },
    {
      "id": "tha-ap563:22.6",
      "pali": "gāthānaṁ pañcanavuti."
    },
    {
      "id": "tha-ap563:23.1",
      "pali": "Therāpadānaṁ samattaṁ."
    }
  ]
}
