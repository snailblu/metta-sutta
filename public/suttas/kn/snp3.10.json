{
  "uid": "snp3.10",
  "title": "Kokālikasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp3.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp3.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "snp3.10:1.3",
      "pali": "Atha kho kokāliko bhikkhu yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho kokāliko bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.10:1.4",
      "pali": "“pāpicchā, bhante, sāriputtamoggallānā, pāpikānaṁ icchānaṁ vasaṁ gatā”ti."
    },
    {
      "id": "snp3.10:2.1",
      "pali": "Evaṁ vutte, bhagavā kokālikaṁ bhikkhuṁ etadavoca:"
    },
    {
      "id": "snp3.10:2.2",
      "pali": "“mā hevaṁ, kokālika, mā hevaṁ, kokālika."
    },
    {
      "id": "snp3.10:2.3",
      "pali": "Pasādehi, kokālika, sāriputtamoggallānesu cittaṁ."
    },
    {
      "id": "snp3.10:2.4",
      "pali": "Pesalā sāriputtamoggallānā”ti."
    },
    {
      "id": "snp3.10:3.1",
      "pali": "Dutiyampi kho …pe…"
    },
    {
      "id": "snp3.10:3.2",
      "pali": "tatiyampi kho kokāliko bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.10:3.3",
      "pali": "“kiñcāpi me, bhante, bhagavā saddhāyiko paccayiko, atha kho pāpicchāva sāriputtamoggallānā, pāpikānaṁ icchānaṁ vasaṁ gatā”ti."
    },
    {
      "id": "snp3.10:3.4",
      "pali": "Tatiyampi kho bhagavā kokālikaṁ bhikkhuṁ etadavoca:"
    },
    {
      "id": "snp3.10:3.5",
      "pali": "“mā hevaṁ, kokālika, mā hevaṁ, kokālika."
    },
    {
      "id": "snp3.10:3.6",
      "pali": "Pasādehi, kokālika, sāriputtamoggallānesu cittaṁ."
    },
    {
      "id": "snp3.10:3.7",
      "pali": "Pesalā sāriputtamoggallānā”ti."
    },
    {
      "id": "snp3.10:4.1",
      "pali": "Atha kho kokāliko bhikkhu uṭṭhāyāsanā bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā pakkāmi."
    },
    {
      "id": "snp3.10:4.2",
      "pali": "Acirappakkantassa ca kokālikassa bhikkhuno sāsapamattīhi piḷakāhi sabbo kāyo phuṭo ahosi;"
    },
    {
      "id": "snp3.10:4.3",
      "pali": "sāsapamattiyo hutvā muggamattiyo ahesuṁ; muggamattiyo hutvā kaḷāyamattiyo ahesuṁ; kaḷāyamattiyo hutvā kolaṭṭhimattiyo ahesuṁ; kolaṭṭhimattiyo hutvā kolamattiyo ahesuṁ; kolamattiyo hutvā āmalakamattiyo ahesuṁ; āmalakamattiyo hutvā beḷuvasalāṭukamattiyo ahesuṁ; beḷuvasalāṭukamattiyo hutvā billamattiyo ahesuṁ; billamattiyo hutvā pabhijjiṁsu; pubbañca lohitañca pagghariṁsu."
    },
    {
      "id": "snp3.10:4.4",
      "pali": "Atha kho kokāliko bhikkhu tenevābādhena kālamakāsi."
    },
    {
      "id": "snp3.10:4.5",
      "pali": "Kālaṅkato ca kokāliko bhikkhu padumaṁ nirayaṁ upapajji sāriputtamoggallānesu cittaṁ āghātetvā."
    },
    {
      "id": "snp3.10:5.1",
      "pali": "Atha kho brahmā sahampati abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhito kho brahmā sahampati bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.10:5.2",
      "pali": "“kokāliko, bhante, bhikkhu kālaṅkato;"
    },
    {
      "id": "snp3.10:5.3",
      "pali": "kālaṅkato ca, bhante, kokāliko bhikkhu padumaṁ nirayaṁ upapanno sāriputtamoggallānesu cittaṁ āghātetvā”ti."
    },
    {
      "id": "snp3.10:5.4",
      "pali": "Idamavoca brahmā sahampati;"
    },
    {
      "id": "snp3.10:5.5",
      "pali": "idaṁ vatvā bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyi."
    },
    {
      "id": "snp3.10:6.1",
      "pali": "Atha kho bhagavā tassā rattiyā accayena bhikkhū āmantesi:"
    },
    {
      "id": "snp3.10:6.2",
      "pali": "“imaṁ, bhikkhave, rattiṁ brahmā sahampati abhikkantāya rattiyā …pe…"
    },
    {
      "id": "snp3.10:6.3",
      "pali": "idamavoca, bhikkhave, brahmā sahampati, idaṁ vatvā maṁ padakkhiṇaṁ katvā tatthevantaradhāyī”ti."
    },
    {
      "id": "snp3.10:7.1",
      "pali": "Evaṁ vutte, aññataro bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.10:7.2",
      "pali": "“kīvadīghaṁ nu kho, bhante, padume niraye āyuppamāṇan”ti?"
    },
    {
      "id": "snp3.10:7.3",
      "pali": "“Dīghaṁ kho, bhikkhu, padume niraye āyuppamāṇaṁ;"
    },
    {
      "id": "snp3.10:7.4",
      "pali": "taṁ na sukaraṁ saṅkhātuṁ ettakāni vassāni iti vā ettakāni vassasatāni iti vā ettakāni vassasahassāni iti vā ettakāni vassasatasahassāni iti vā”ti."
    },
    {
      "id": "snp3.10:7.5",
      "pali": "“Sakkā pana, bhante, upamā kātun”ti?"
    },
    {
      "id": "snp3.10:7.6",
      "pali": "“Sakkā, bhikkhū”ti bhagavā avoca:"
    },
    {
      "id": "snp3.10:8.1",
      "pali": "“Seyyathāpi, bhikkhu, vīsatikhāriko kosalako tilavāho; tato puriso vassasatassa vassasatassa accayena ekamekaṁ tilaṁ uddhareyya."
    },
    {
      "id": "snp3.10:8.2",
      "pali": "Khippataraṁ kho so bhikkhu vīsatikhāriko kosalako tilavāho iminā upakkamena parikkhayaṁ pariyādānaṁ gaccheyya, na tveva eko abbudo nirayo."
    },
    {
      "id": "snp3.10:8.3",
      "pali": "Seyyathāpi, bhikkhu, vīsati abbudā nirayā evameko nirabbudo nirayo."
    },
    {
      "id": "snp3.10:8.4",
      "pali": "Seyyathāpi, bhikkhu, vīsati nirabbudā nirayā evameko ababo nirayo."
    },
    {
      "id": "snp3.10:8.5",
      "pali": "Seyyathāpi, bhikkhu, vīsati ababā nirayā evameko aṭaṭo nirayo."
    },
    {
      "id": "snp3.10:8.6",
      "pali": "Seyyathāpi, bhikkhu, vīsati aṭaṭā nirayā evameko ahaho nirayo."
    },
    {
      "id": "snp3.10:8.7",
      "pali": "Seyyathāpi, bhikkhu, vīsati ahahā nirayā evameko kumudo nirayo."
    },
    {
      "id": "snp3.10:8.8",
      "pali": "Seyyathāpi, bhikkhu, vīsati kumudā nirayā evameko sogandhiko nirayo."
    },
    {
      "id": "snp3.10:8.9",
      "pali": "Seyyathāpi, bhikkhu, vīsati sogandhikā nirayā evameko uppalako nirayo."
    },
    {
      "id": "snp3.10:8.10",
      "pali": "Seyyathāpi, bhikkhu, vīsati uppalakā nirayā evameko puṇḍarīko nirayo."
    },
    {
      "id": "snp3.10:8.11",
      "pali": "Seyyathāpi, bhikkhu, vīsati puṇḍarīkā nirayā evameko padumo nirayo."
    },
    {
      "id": "snp3.10:8.12",
      "pali": "Padumaṁ kho pana bhikkhu nirayaṁ kokāliko bhikkhu upapanno sāriputtamoggallānesu cittaṁ āghātetvā”ti."
    },
    {
      "id": "snp3.10:8.13",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "snp3.10:8.14",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.10:9.1",
      "pali": "“Purisassa hi jātassa,"
    },
    {
      "id": "snp3.10:9.2",
      "pali": "kuṭhārī jāyate mukhe;"
    },
    {
      "id": "snp3.10:9.3",
      "pali": "Yāya chindati attānaṁ,"
    },
    {
      "id": "snp3.10:9.4",
      "pali": "bālo dubbhāsitaṁ bhaṇaṁ."
    },
    {
      "id": "snp3.10:10.1",
      "pali": "Yo nindiyaṁ pasaṁsati,"
    },
    {
      "id": "snp3.10:10.2",
      "pali": "Taṁ vā nindati yo pasaṁsiyo;"
    },
    {
      "id": "snp3.10:10.3",
      "pali": "Vicināti mukhena so kaliṁ,"
    },
    {
      "id": "snp3.10:10.4",
      "pali": "Kalinā tena sukhaṁ na vindati."
    },
    {
      "id": "snp3.10:11.1",
      "pali": "Appamatto ayaṁ kali,"
    },
    {
      "id": "snp3.10:11.2",
      "pali": "Yo akkhesu dhanaparājayo;"
    },
    {
      "id": "snp3.10:11.3",
      "pali": "Sabbassāpi sahāpi attanā,"
    },
    {
      "id": "snp3.10:11.4",
      "pali": "Ayameva mahattaro kali;"
    },
    {
      "id": "snp3.10:11.5",
      "pali": "Yo sugatesu manaṁ padosaye."
    },
    {
      "id": "snp3.10:12.1",
      "pali": "Sataṁ sahassānaṁ nirabbudānaṁ,"
    },
    {
      "id": "snp3.10:12.2",
      "pali": "Chattiṁsati pañca ca abbudāni;"
    },
    {
      "id": "snp3.10:12.3",
      "pali": "Yamariyagarahī nirayaṁ upeti,"
    },
    {
      "id": "snp3.10:12.4",
      "pali": "Vācaṁ manañca paṇidhāya pāpakaṁ."
    },
    {
      "id": "snp3.10:13.1",
      "pali": "Abhūtavādī nirayaṁ upeti,"
    },
    {
      "id": "snp3.10:13.2",
      "pali": "Yo vāpi katvā na karomicāha;"
    },
    {
      "id": "snp3.10:13.3",
      "pali": "Ubhopi te pecca samā bhavanti,"
    },
    {
      "id": "snp3.10:13.4",
      "pali": "Nihīnakammā manujā parattha."
    },
    {
      "id": "snp3.10:14.1",
      "pali": "Yo appaduṭṭhassa narassa dussati,"
    },
    {
      "id": "snp3.10:14.2",
      "pali": "Suddhassa posassa anaṅgaṇassa;"
    },
    {
      "id": "snp3.10:14.3",
      "pali": "Tameva bālaṁ pacceti pāpaṁ,"
    },
    {
      "id": "snp3.10:14.4",
      "pali": "Sukhumo rajo paṭivātaṁva khitto."
    },
    {
      "id": "snp3.10:15.1",
      "pali": "Yo lobhaguṇe anuyutto,"
    },
    {
      "id": "snp3.10:15.2",
      "pali": "So vacasā paribhāsati aññe;"
    },
    {
      "id": "snp3.10:15.3",
      "pali": "Asaddho kadariyo avadaññū,"
    },
    {
      "id": "snp3.10:15.4",
      "pali": "Macchari pesuṇiyaṁ anuyutto."
    },
    {
      "id": "snp3.10:16.1",
      "pali": "Mukhadugga vibhūta anariya,"
    },
    {
      "id": "snp3.10:16.2",
      "pali": "Bhūnahu pāpaka dukkaṭakāri;"
    },
    {
      "id": "snp3.10:16.3",
      "pali": "Purisanta kalī avajāta,"
    },
    {
      "id": "snp3.10:16.4",
      "pali": "Mā bahubhāṇidha nerayikosi."
    },
    {
      "id": "snp3.10:17.1",
      "pali": "Rajamākirasī ahitāya,"
    },
    {
      "id": "snp3.10:17.2",
      "pali": "Sante garahasi kibbisakārī;"
    },
    {
      "id": "snp3.10:17.3",
      "pali": "Bahūni duccaritāni caritvā,"
    },
    {
      "id": "snp3.10:17.4",
      "pali": "Gacchasi kho papataṁ cirarattaṁ."
    },
    {
      "id": "snp3.10:18.1",
      "pali": "Na hi nassati kassaci kammaṁ,"
    },
    {
      "id": "snp3.10:18.2",
      "pali": "Eti hataṁ labhateva suvāmi;"
    },
    {
      "id": "snp3.10:18.3",
      "pali": "Dukkhaṁ mando paraloke,"
    },
    {
      "id": "snp3.10:18.4",
      "pali": "Attani passati kibbisakārī."
    },
    {
      "id": "snp3.10:19.1",
      "pali": "Ayosaṅkusamāhataṭṭhānaṁ,"
    },
    {
      "id": "snp3.10:19.2",
      "pali": "Tiṇhadhāramayasūlamupeti;"
    },
    {
      "id": "snp3.10:19.3",
      "pali": "Atha tattaayoguḷasannibhaṁ,"
    },
    {
      "id": "snp3.10:19.4",
      "pali": "Bhojanamatthi tathā patirūpaṁ."
    },
    {
      "id": "snp3.10:20.1",
      "pali": "Na hi vaggu vadanti vadantā,"
    },
    {
      "id": "snp3.10:20.2",
      "pali": "Nābhijavanti na tāṇamupenti;"
    },
    {
      "id": "snp3.10:20.3",
      "pali": "Aṅgāre santhate sayanti,"
    },
    {
      "id": "snp3.10:20.4",
      "pali": "Ginisampajjalitaṁ pavisanti."
    },
    {
      "id": "snp3.10:21.1",
      "pali": "Jālena ca onahiyāna,"
    },
    {
      "id": "snp3.10:21.2",
      "pali": "Tattha hananti ayomayakuṭebhi;"
    },
    {
      "id": "snp3.10:21.3",
      "pali": "Andhaṁva timisamāyanti,"
    },
    {
      "id": "snp3.10:21.4",
      "pali": "Taṁ vitatañhi yathā mahikāyo."
    },
    {
      "id": "snp3.10:22.1",
      "pali": "Atha lohamayaṁ pana kumbhiṁ,"
    },
    {
      "id": "snp3.10:22.2",
      "pali": "Ginisampajjalitaṁ pavisanti;"
    },
    {
      "id": "snp3.10:22.3",
      "pali": "Paccanti hi tāsu cirarattaṁ,"
    },
    {
      "id": "snp3.10:22.4",
      "pali": "Agginisamāsu samuppilavāte."
    },
    {
      "id": "snp3.10:23.1",
      "pali": "Atha pubbalohitamisse,"
    },
    {
      "id": "snp3.10:23.2",
      "pali": "Tattha kiṁ paccati kibbisakārī;"
    },
    {
      "id": "snp3.10:23.3",
      "pali": "Yaṁ yaṁ disakaṁ adhiseti,"
    },
    {
      "id": "snp3.10:23.4",
      "pali": "Tattha kilissati samphusamāno."
    },
    {
      "id": "snp3.10:24.1",
      "pali": "Puḷavāvasathe salilasmiṁ,"
    },
    {
      "id": "snp3.10:24.2",
      "pali": "Tattha kiṁ paccati kibbisakārī;"
    },
    {
      "id": "snp3.10:24.3",
      "pali": "Gantuṁ na hi tīramapatthi,"
    },
    {
      "id": "snp3.10:24.4",
      "pali": "Sabbasamā hi samantakapallā."
    },
    {
      "id": "snp3.10:25.1",
      "pali": "Asipattavanaṁ pana tiṇhaṁ,"
    },
    {
      "id": "snp3.10:25.2",
      "pali": "Taṁ pavisanti samucchidagattā;"
    },
    {
      "id": "snp3.10:25.3",
      "pali": "Jivhaṁ balisena gahetvā,"
    },
    {
      "id": "snp3.10:25.4",
      "pali": "Ārajayārajayā vihananti."
    },
    {
      "id": "snp3.10:26.1",
      "pali": "Atha vetaraṇiṁ pana duggaṁ,"
    },
    {
      "id": "snp3.10:26.2",
      "pali": "Tiṇhadhārakhuradhāramupenti;"
    },
    {
      "id": "snp3.10:26.3",
      "pali": "Tattha mandā papatanti,"
    },
    {
      "id": "snp3.10:26.4",
      "pali": "Pāpakarā pāpāni karitvā."
    },
    {
      "id": "snp3.10:27.1",
      "pali": "Khādanti hi tattha rudante,"
    },
    {
      "id": "snp3.10:27.2",
      "pali": "Sāmā sabalā kākolagaṇā ca;"
    },
    {
      "id": "snp3.10:27.3",
      "pali": "Soṇā siṅgālā paṭigiddhā,"
    },
    {
      "id": "snp3.10:27.4",
      "pali": "Kulalā vāyasā ca vitudanti."
    },
    {
      "id": "snp3.10:28.1",
      "pali": "Kicchā vatayaṁ idha vutti,"
    },
    {
      "id": "snp3.10:28.2",
      "pali": "Yaṁ jano phusati kibbisakārī;"
    },
    {
      "id": "snp3.10:28.3",
      "pali": "Tasmā idha jīvitasese,"
    },
    {
      "id": "snp3.10:28.4",
      "pali": "Kiccakaro siyā naro na cappamajje."
    },
    {
      "id": "snp3.10:29.1",
      "pali": "Te gaṇitā vidūhi tilavāhā,"
    },
    {
      "id": "snp3.10:29.2",
      "pali": "Ye padume niraye upanītā;"
    },
    {
      "id": "snp3.10:29.3",
      "pali": "Nahutāni hi koṭiyo pañca bhavanti,"
    },
    {
      "id": "snp3.10:29.4",
      "pali": "Dvādasa koṭisatāni punaññā."
    },
    {
      "id": "snp3.10:30.1",
      "pali": "Yāva dukhā nirayā idha vuttā,"
    },
    {
      "id": "snp3.10:30.2",
      "pali": "Tatthapi tāva ciraṁ vasitabbaṁ;"
    },
    {
      "id": "snp3.10:30.3",
      "pali": "Tasmā sucipesalasādhuguṇesu,"
    },
    {
      "id": "snp3.10:30.4",
      "pali": "Vācaṁ manaṁ satataṁ parirakkhe”ti."
    },
    {
      "id": "snp3.10:30.5",
      "pali": "Kokālikasuttaṁ dasamaṁ."
    }
  ]
}
