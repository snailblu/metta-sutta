{
  "uid": "ne20",
  "title": "Sampāta 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne20:1.1",
      "pali": "“Soḷasa hārā paṭhamaṁ,"
    },
    {
      "id": "ne20:1.2",
      "pali": "Disalocanato disā viloketvā;"
    },
    {
      "id": "ne20:1.3",
      "pali": "Saṅkhipiya aṅkusena hi,"
    },
    {
      "id": "ne20:1.4",
      "pali": "Nayehi tīhi niddise suttan”ti."
    },
    {
      "id": "ne20:2.1",
      "pali": "Vuttā, tassā niddeso kuhiṁ daṭṭhabbo?"
    },
    {
      "id": "ne20:2.2",
      "pali": "Hārasampāte."
    },
    {
      "id": "ne20:2.3",
      "pali": "Tattha katamo desanāhārasampāto?"
    },
    {
      "id": "ne20:3.1",
      "pali": "“Arakkhitena cittena,"
    },
    {
      "id": "ne20:3.2",
      "pali": "micchādiṭṭhihatena ca;"
    },
    {
      "id": "ne20:3.3",
      "pali": "Thinamiddhābhibhūtena,"
    },
    {
      "id": "ne20:3.4",
      "pali": "vasaṁ mārassa gacchatī”ti."
    },
    {
      "id": "ne20:4.1",
      "pali": "<b>Arakkhitena cittenā</b>ti kiṁ desayati, pamādaṁ taṁ maccuno padaṁ."
    },
    {
      "id": "ne20:4.2",
      "pali": "<b>Micchādiṭṭhihatena cā</b>ti micchādiṭṭhihataṁ nāma vuccati yadā “anicce niccan”ti passati, so vipallāso."
    },
    {
      "id": "ne20:4.3",
      "pali": "So pana vipallāso kiṁlakkhaṇo?"
    },
    {
      "id": "ne20:4.4",
      "pali": "Viparītaggāhalakkhaṇo vipallāso."
    },
    {
      "id": "ne20:4.5",
      "pali": "So kiṁ vipallāsayati?"
    },
    {
      "id": "ne20:4.6",
      "pali": "Tayo dhamme saññaṁ cittaṁ diṭṭhimiti."
    },
    {
      "id": "ne20:4.7",
      "pali": "So kuhiṁ vipallāsayati?"
    },
    {
      "id": "ne20:4.8",
      "pali": "Catūsu attabhāvavatthūsu, rūpaṁ attato samanupassati, rūpavantaṁ vā attānaṁ, attani vā rūpaṁ, rūpasmiṁ vā attānaṁ."
    },
    {
      "id": "ne20:4.9",
      "pali": "Evaṁ vedanaṁ …pe…"
    },
    {
      "id": "ne20:4.10",
      "pali": "saññaṁ …pe…"
    },
    {
      "id": "ne20:4.11",
      "pali": "saṅkhāre …pe…"
    },
    {
      "id": "ne20:4.12",
      "pali": "viññāṇaṁ attato samanupassati, viññāṇavantaṁ vā attānaṁ, attani vā viññāṇaṁ, viññāṇasmiṁ vā attānaṁ."
    },
    {
      "id": "ne20:5.1",
      "pali": "Tattha rūpaṁ paṭhamaṁ vipallāsavatthu “asubhe subhan”ti."
    },
    {
      "id": "ne20:5.2",
      "pali": "Vedanā dutiyaṁ vipallāsavatthu “dukkhe sukhan”ti."
    },
    {
      "id": "ne20:5.3",
      "pali": "Saññā saṅkhārā ca tatiyaṁ vipallāsavatthu “anattani attā”ti."
    },
    {
      "id": "ne20:5.4",
      "pali": "Viññāṇaṁ catutthaṁ vipallāsavatthu “anicce niccan”ti."
    },
    {
      "id": "ne20:5.5",
      "pali": "Dve dhammā cittassa saṅkilesā—"
    },
    {
      "id": "ne20:5.6",
      "pali": "taṇhā ca avijjā ca."
    },
    {
      "id": "ne20:5.7",
      "pali": "Taṇhānivutaṁ cittaṁ dvīhi vipallāsehi vipallāsīyati “asubhe subhan”ti “dukkhe sukhan”ti."
    },
    {
      "id": "ne20:5.8",
      "pali": "Diṭṭhinivutaṁ cittaṁ dvīhi vipallāsehi vipallāsīyati “anicce niccan”ti “anattani attā”ti."
    },
    {
      "id": "ne20:6.1",
      "pali": "Tattha yo diṭṭhivipallāso, so atītaṁ rūpaṁ attato samanupassati,"
    },
    {
      "id": "ne20:6.2",
      "pali": "atītaṁ vedanaṁ …pe…"
    },
    {
      "id": "ne20:6.3",
      "pali": "atītaṁ saññaṁ,"
    },
    {
      "id": "ne20:6.4",
      "pali": "atīte saṅkhāre …"
    },
    {
      "id": "ne20:6.5",
      "pali": "atītaṁ viññāṇaṁ attato samanupassati."
    },
    {
      "id": "ne20:6.6",
      "pali": "Tattha yo taṇhāvipallāso, so anāgataṁ rūpaṁ abhinandati,"
    },
    {
      "id": "ne20:6.7",
      "pali": "anāgataṁ vedanaṁ …pe…"
    },
    {
      "id": "ne20:6.8",
      "pali": "anāgataṁ saññaṁ,"
    },
    {
      "id": "ne20:6.9",
      "pali": "anāgate saṅkhāre,"
    },
    {
      "id": "ne20:6.10",
      "pali": "anāgataṁ viññāṇaṁ abhinandati."
    },
    {
      "id": "ne20:6.11",
      "pali": "Dve dhammā cittassa upakkilesā—"
    },
    {
      "id": "ne20:6.12",
      "pali": "taṇhā ca avijjā ca."
    },
    {
      "id": "ne20:6.13",
      "pali": "Tāhi visujjhantaṁ cittaṁ visujjhati."
    },
    {
      "id": "ne20:6.14",
      "pali": "Tesaṁ avijjānīvaraṇānaṁ taṇhāsaṁyojanānaṁ pubbā koṭi na paññāyati sandhāvantānaṁ saṁsarantānaṁ sakiṁ nirayaṁ sakiṁ tiracchānayoniṁ sakiṁ pettivisayaṁ sakiṁ asurakāyaṁ sakiṁ deve sakiṁ manusse."
    },
    {
      "id": "ne20:7.1",
      "pali": "<b>Thinamiddhābhibhūtenā</b>ti."
    },
    {
      "id": "ne20:7.2",
      "pali": "Thinaṁ nāma yā cittassa akallatā akammaniyatā;"
    },
    {
      "id": "ne20:7.3",
      "pali": "middhaṁ nāma yaṁ kāyassa līnattaṁ."
    },
    {
      "id": "ne20:7.4",
      "pali": "<b>Vasaṁ mārassa gacchatī</b>ti kilesamārassa ca sattamārassa ca vasaṁ gacchati, so hi nivuto saṁsārābhimukho hoti."
    },
    {
      "id": "ne20:7.5",
      "pali": "Imāni bhagavatā dve saccāni desitāni dukkhaṁ samudayo ca."
    },
    {
      "id": "ne20:7.6",
      "pali": "Tesaṁ bhagavā pariññāya ca pahānāya ca dhammaṁ deseti dukkhassa pariññāya samudayassa pahānāya."
    },
    {
      "id": "ne20:7.7",
      "pali": "Yena ca parijānāti yena ca pajahati, ayaṁ maggo."
    },
    {
      "id": "ne20:7.8",
      "pali": "Yaṁ taṇhāya avijjāya ca pahānaṁ, ayaṁ nirodho."
    },
    {
      "id": "ne20:7.9",
      "pali": "Imāni cattāri saccāni."
    },
    {
      "id": "ne20:7.10",
      "pali": "Tenāha bhagavā “arakkhitena cittenā”ti."
    },
    {
      "id": "ne20:7.11",
      "pali": "Tenāhāyasmā mahākaccāyano “assādādīnavatā”ti."
    },
    {
      "id": "ne20:7.12",
      "pali": "Niyutto desanāhārasampāto."
    }
  ]
}
