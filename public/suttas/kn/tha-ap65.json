{
  "uid": "tha-ap65",
  "title": "Paccāgamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap65:1.1",
      "pali": "“Sindhuyā nadiyā tīre,"
    },
    {
      "id": "tha-ap65:1.2",
      "pali": "cakkavāko ahaṁ tadā;"
    },
    {
      "id": "tha-ap65:1.3",
      "pali": "Suddhasevālabhakkhohaṁ,"
    },
    {
      "id": "tha-ap65:1.4",
      "pali": "pāpesu ca susaññato."
    },
    {
      "id": "tha-ap65:2.1",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap65:2.2",
      "pali": "gacchantaṁ anilañjase;"
    },
    {
      "id": "tha-ap65:2.3",
      "pali": "Tuṇḍena sālaṁ paggayha,"
    },
    {
      "id": "tha-ap65:2.4",
      "pali": "vipassissābhiropayiṁ."
    },
    {
      "id": "tha-ap65:3.1",
      "pali": "Yassa saddhā tathāgate,"
    },
    {
      "id": "tha-ap65:3.2",
      "pali": "acalā supatiṭṭhitā;"
    },
    {
      "id": "tha-ap65:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap65:3.4",
      "pali": "duggatiṁ so na gacchati."
    },
    {
      "id": "tha-ap65:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap65:4.2",
      "pali": "buddhaseṭṭhassa santike;"
    },
    {
      "id": "tha-ap65:4.3",
      "pali": "Vihaṅgamena santena,"
    },
    {
      "id": "tha-ap65:4.4",
      "pali": "subījaṁ ropitaṁ mayā."
    },
    {
      "id": "tha-ap65:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap65:5.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap65:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap65:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap65:6.1",
      "pali": "Sucārudassanā nāma,"
    },
    {
      "id": "tha-ap65:6.2",
      "pali": "aṭṭhete ekanāmakā;"
    },
    {
      "id": "tha-ap65:6.3",
      "pali": "Kappe sattarase āsuṁ,"
    },
    {
      "id": "tha-ap65:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap65:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap65:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap65:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap65:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā paccāgamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap65:9.1",
      "pali": "Paccāgamaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
