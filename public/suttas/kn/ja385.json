{
  "uid": "ja385",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja385:1.1",
      "pali": "“Sace brāhmaṇa gacchesi,"
    },
    {
      "id": "ja385:1.2",
      "pali": "sākete ajjunaṁ vanaṁ;"
    },
    {
      "id": "ja385:1.3",
      "pali": "Vajjāsi nandiyaṁ nāma,"
    },
    {
      "id": "ja385:1.4",
      "pali": "puttaṁ asmākamorasaṁ;"
    },
    {
      "id": "ja385:1.5",
      "pali": "Mātā pitā ca te vuddhā,"
    },
    {
      "id": "ja385:1.6",
      "pali": "te taṁ icchanti passituṁ”."
    },
    {
      "id": "ja385:2.1",
      "pali": "“Bhuttā mayā nivāpāni,"
    },
    {
      "id": "ja385:2.2",
      "pali": "Rājino pānabhojanaṁ;"
    },
    {
      "id": "ja385:2.3",
      "pali": "Taṁ rājapiṇḍaṁ avabhottuṁ,"
    },
    {
      "id": "ja385:2.4",
      "pali": "Nāhaṁ brāhmaṇa mussahe”."
    },
    {
      "id": "ja385:3.1",
      "pali": "“Odahissāmahaṁ passaṁ,"
    },
    {
      "id": "ja385:3.2",
      "pali": "khurappānissa rājino;"
    },
    {
      "id": "ja385:3.3",
      "pali": "Tadāhaṁ sukhito mutto,"
    },
    {
      "id": "ja385:3.4",
      "pali": "api passeyya mātaraṁ."
    },
    {
      "id": "ja385:4.1",
      "pali": "Migarājā pure āsiṁ,"
    },
    {
      "id": "ja385:4.2",
      "pali": "kosalassa niketane;"
    },
    {
      "id": "ja385:4.3",
      "pali": "Nandiyo nāma nāmena,"
    },
    {
      "id": "ja385:4.4",
      "pali": "abhirūpo catuppado."
    },
    {
      "id": "ja385:5.1",
      "pali": "Taṁ maṁ vadhitumāgacchi,"
    },
    {
      "id": "ja385:5.2",
      "pali": "dāyasmiṁ ajjune vane;"
    },
    {
      "id": "ja385:5.3",
      "pali": "Dhanuṁ advejjhaṁ katvāna,"
    },
    {
      "id": "ja385:5.4",
      "pali": "usuṁ sannayha kosalo."
    },
    {
      "id": "ja385:6.1",
      "pali": "Tassāhaṁ odahiṁ passaṁ,"
    },
    {
      "id": "ja385:6.2",
      "pali": "khurappānissa rājino;"
    },
    {
      "id": "ja385:6.3",
      "pali": "Tadāhaṁ sukhito mutto,"
    },
    {
      "id": "ja385:6.4",
      "pali": "mātaraṁ daṭṭhumāgato”ti."
    },
    {
      "id": "ja385:7.1",
      "pali": "Nandiyamigarājajātakaṁ dasamaṁ."
    },
    {
      "id": "ja385:7.2",
      "pali": "Avāriyavaggo paṭhamo."
    },
    {
      "id": "ja385:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja385:9.1",
      "pali": "Atha kujjharathesabha ketuvaro,"
    },
    {
      "id": "ja385:9.2",
      "pali": "Sadarīmukha neru latā ca puna;"
    },
    {
      "id": "ja385:9.3",
      "pali": "Apananda sirī ca sucittavaro,"
    },
    {
      "id": "ja385:9.4",
      "pali": "Atha dhammika nandimigena dasāti."
    }
  ]
}
