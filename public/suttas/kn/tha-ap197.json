{
  "uid": "tha-ap197",
  "title": "Aṅkolakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap197:1.1",
      "pali": "“Aṅkolaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap197:1.2",
      "pali": "mālāvaraṁ sakosakaṁ;"
    },
    {
      "id": "tha-ap197:1.3",
      "pali": "Ocinitvāna taṁ pupphaṁ,"
    },
    {
      "id": "tha-ap197:1.4",
      "pali": "agamaṁ buddhasantikaṁ."
    },
    {
      "id": "tha-ap197:2.1",
      "pali": "Siddhattho tamhi samaye,"
    },
    {
      "id": "tha-ap197:2.2",
      "pali": "patilīno mahāmuni;"
    },
    {
      "id": "tha-ap197:2.3",
      "pali": "Muhuttaṁ paṭimānetvā,"
    },
    {
      "id": "tha-ap197:2.4",
      "pali": "guhāyaṁ pupphamokiriṁ."
    },
    {
      "id": "tha-ap197:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap197:3.2",
      "pali": "Yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap197:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap197:3.4",
      "pali": "Pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap197:4.1",
      "pali": "Chattiṁsamhi ito kappe,"
    },
    {
      "id": "tha-ap197:4.2",
      "pali": "āseko devagajjito;"
    },
    {
      "id": "tha-ap197:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap197:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap197:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap197:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap197:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap197:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā aṅkolako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap197:7.1",
      "pali": "Aṅkolakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
