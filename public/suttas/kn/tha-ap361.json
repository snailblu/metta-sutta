{
  "uid": "tha-ap361",
  "title": "9 Saraṇagamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap361:1.1",
      "pali": "“Āruhimha tadā nāvaṁ,"
    },
    {
      "id": "tha-ap361:1.2",
      "pali": "bhikkhu cājīvako cahaṁ;"
    },
    {
      "id": "tha-ap361:1.3",
      "pali": "Nāvāya bhijjamānāya,"
    },
    {
      "id": "tha-ap361:1.4",
      "pali": "bhikkhu me saraṇaṁ adā."
    },
    {
      "id": "tha-ap361:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap361:2.2",
      "pali": "yañca me saraṇaṁ adā;"
    },
    {
      "id": "tha-ap361:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap361:2.4",
      "pali": "saraṇāgamane phalaṁ."
    },
    {
      "id": "tha-ap361:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap361:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap361:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap361:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā saraṇagamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap361:5.1",
      "pali": "Saraṇagamaniyattherassāpadānaṁ navamaṁ."
    }
  ]
}
