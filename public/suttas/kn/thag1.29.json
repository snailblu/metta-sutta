{
  "uid": "thag1.29",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.29:1.1",
      "pali": "“Samunnamayamattānaṁ,"
    },
    {
      "id": "thag1.29:1.2",
      "pali": "usukārova tejanaṁ;"
    },
    {
      "id": "thag1.29:1.3",
      "pali": "Cittaṁ ujuṁ karitvāna,"
    },
    {
      "id": "thag1.29:1.4",
      "pali": "avijjaṁ bhinda hāritā”ti."
    },
    {
      "id": "thag1.29:1.5",
      "pali": "… Hārito thero …."
    }
  ]
}
