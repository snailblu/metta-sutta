{
  "uid": "ja234",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja234:1.1",
      "pali": "“Tvameva dānimakara,"
    },
    {
      "id": "ja234:1.2",
      "pali": "Yaṁ kāmo byagamā tayi;"
    },
    {
      "id": "ja234:1.3",
      "pali": "Soyaṁ appaṭisandhiko,"
    },
    {
      "id": "ja234:1.4",
      "pali": "Kharachinnaṁva renukaṁ”."
    },
    {
      "id": "ja234:2.1",
      "pali": "“Atricchaṁ atilobhena,"
    },
    {
      "id": "ja234:2.2",
      "pali": "atilobhamadena ca;"
    },
    {
      "id": "ja234:2.3",
      "pali": "Evaṁ hāyati atthamhā,"
    },
    {
      "id": "ja234:2.4",
      "pali": "ahaṁva asitābhuyā”ti."
    },
    {
      "id": "ja234:3.1",
      "pali": "Asitābhūjātakaṁ catutthaṁ."
    }
  ]
}
