{
  "uid": "ja451",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja451:1.1",
      "pali": "“Vaṇṇavā abhirūposi,"
    },
    {
      "id": "ja451:1.2",
      "pali": "ghano sañjātarohito;"
    },
    {
      "id": "ja451:1.3",
      "pali": "Cakkavāka surūposi,"
    },
    {
      "id": "ja451:1.4",
      "pali": "vippasannamukhindriyo."
    },
    {
      "id": "ja451:2.1",
      "pali": "Pāṭhīnaṁ pāvusaṁ macchaṁ,"
    },
    {
      "id": "ja451:2.2",
      "pali": "balajaṁ muñjarohitaṁ;"
    },
    {
      "id": "ja451:2.3",
      "pali": "Gaṅgāya tīre nisinno,"
    },
    {
      "id": "ja451:2.4",
      "pali": "evaṁ bhuñjasi bhojanaṁ”."
    },
    {
      "id": "ja451:3.1",
      "pali": "“Na vāhametaṁ bhuñjāmi,"
    },
    {
      "id": "ja451:3.2",
      "pali": "Jaṅgalānodakāni vā;"
    },
    {
      "id": "ja451:3.3",
      "pali": "Aññatra sevālapaṇakā,"
    },
    {
      "id": "ja451:3.4",
      "pali": "Etaṁ me samma bhojanaṁ”."
    },
    {
      "id": "ja451:4.1",
      "pali": "“Na vāhametaṁ saddahāmi,"
    },
    {
      "id": "ja451:4.2",
      "pali": "cakkavākassa bhojanaṁ;"
    },
    {
      "id": "ja451:4.3",
      "pali": "Ahampi samma bhuñjāmi,"
    },
    {
      "id": "ja451:4.4",
      "pali": "gāme loṇiyateliyaṁ."
    },
    {
      "id": "ja451:5.1",
      "pali": "Manussesu kataṁ bhattaṁ,"
    },
    {
      "id": "ja451:5.2",
      "pali": "suciṁ maṁsūpasecanaṁ;"
    },
    {
      "id": "ja451:5.3",
      "pali": "Na ca me tādiso vaṇṇo,"
    },
    {
      "id": "ja451:5.4",
      "pali": "cakkavāka yathā tuvaṁ”."
    },
    {
      "id": "ja451:6.1",
      "pali": "“Sampassaṁ attani veraṁ,"
    },
    {
      "id": "ja451:6.2",
      "pali": "hiṁsayaṁ mānusiṁ pajaṁ;"
    },
    {
      "id": "ja451:6.3",
      "pali": "Utrasto ghasasī bhīto,"
    },
    {
      "id": "ja451:6.4",
      "pali": "tena vaṇṇo tavediso."
    },
    {
      "id": "ja451:7.1",
      "pali": "Sabbalokaviruddhosi,"
    },
    {
      "id": "ja451:7.2",
      "pali": "dhaṅka pāpena kammunā;"
    },
    {
      "id": "ja451:7.3",
      "pali": "Laddho piṇḍo na pīṇeti,"
    },
    {
      "id": "ja451:7.4",
      "pali": "tena vaṇṇo tavediso."
    },
    {
      "id": "ja451:8.1",
      "pali": "Ahampi samma bhuñjāmi,"
    },
    {
      "id": "ja451:8.2",
      "pali": "ahiṁsaṁ sabbapāṇinaṁ;"
    },
    {
      "id": "ja451:8.3",
      "pali": "Appossukko nirāsaṅkī,"
    },
    {
      "id": "ja451:8.4",
      "pali": "asoko akutobhayo."
    },
    {
      "id": "ja451:9.1",
      "pali": "So karassu ānubhāvaṁ,"
    },
    {
      "id": "ja451:9.2",
      "pali": "vītivattassu sīliyaṁ;"
    },
    {
      "id": "ja451:9.3",
      "pali": "Ahiṁsāya cara loke,"
    },
    {
      "id": "ja451:9.4",
      "pali": "piyo hohisi maṁmiva."
    },
    {
      "id": "ja451:10.1",
      "pali": "Yo na hanti na ghāteti,"
    },
    {
      "id": "ja451:10.2",
      "pali": "na jināti na jāpaye;"
    },
    {
      "id": "ja451:10.3",
      "pali": "Mettaṁso sabbabhūtesu,"
    },
    {
      "id": "ja451:10.4",
      "pali": "veraṁ tassa na kenacī”ti."
    },
    {
      "id": "ja451:11.1",
      "pali": "Cakkavākajātakaṁ terasamaṁ."
    }
  ]
}
