{
  "uid": "ja394",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja394:1.1",
      "pali": "“Paṇītaṁ bhuñjase bhattaṁ,"
    },
    {
      "id": "ja394:1.2",
      "pali": "sappitelañca mātula;"
    },
    {
      "id": "ja394:1.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja394:1.4",
      "pali": "kiso tvamasi vāyasa”."
    },
    {
      "id": "ja394:2.1",
      "pali": "“Amittamajjhe vasato,"
    },
    {
      "id": "ja394:2.2",
      "pali": "tesu āmisamesato;"
    },
    {
      "id": "ja394:2.3",
      "pali": "Niccaṁ ubbiggahadayassa,"
    },
    {
      "id": "ja394:2.4",
      "pali": "kuto kākassa daḷhiyaṁ."
    },
    {
      "id": "ja394:3.1",
      "pali": "Niccaṁ ubbegino kākā,"
    },
    {
      "id": "ja394:3.2",
      "pali": "dhaṅkā pāpena kammunā;"
    },
    {
      "id": "ja394:3.3",
      "pali": "Laddho piṇḍo na pīṇeti,"
    },
    {
      "id": "ja394:3.4",
      "pali": "kiso tenasmi vaṭṭaka."
    },
    {
      "id": "ja394:4.1",
      "pali": "Lūkhāni tiṇabījāni,"
    },
    {
      "id": "ja394:4.2",
      "pali": "appasnehāni bhuñjasi;"
    },
    {
      "id": "ja394:4.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja394:4.4",
      "pali": "thūlo tvamasi vaṭṭaka”."
    },
    {
      "id": "ja394:5.1",
      "pali": "“Appicchā appacintāya,"
    },
    {
      "id": "ja394:5.2",
      "pali": "adūragamanena ca;"
    },
    {
      "id": "ja394:5.3",
      "pali": "Laddhāladdhena yāpento,"
    },
    {
      "id": "ja394:5.4",
      "pali": "thūlo tenasmi vāyasa."
    },
    {
      "id": "ja394:6.1",
      "pali": "Appicchassa hi posassa,"
    },
    {
      "id": "ja394:6.2",
      "pali": "appacintasukhassa ca;"
    },
    {
      "id": "ja394:6.3",
      "pali": "Susaṅgahitamānassa,"
    },
    {
      "id": "ja394:6.4",
      "pali": "vuttī susamudānayā”ti."
    },
    {
      "id": "ja394:7.1",
      "pali": "Vaṭṭakajātakaṁ navamaṁ."
    }
  ]
}
