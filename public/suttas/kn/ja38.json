{
  "uid": "ja38",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja38:1.1",
      "pali": "“Nāccantaṁ nikatippañño,"
    },
    {
      "id": "ja38:1.2",
      "pali": "nikatyā sukhamedhati;"
    },
    {
      "id": "ja38:1.3",
      "pali": "Ārādheti nikatippañño,"
    },
    {
      "id": "ja38:1.4",
      "pali": "bako kakkaṭakāmivā”ti."
    },
    {
      "id": "ja38:2.1",
      "pali": "Bakajātakaṁ aṭṭhamaṁ."
    }
  ]
}
