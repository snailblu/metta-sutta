{
  "uid": "thag2.27",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.27:1.1",
      "pali": "“Yathāpi bhaddo ājañño,"
    },
    {
      "id": "thag2.27:1.2",
      "pali": "khalitvā patitiṭṭhati;"
    },
    {
      "id": "thag2.27:1.3",
      "pali": "Bhiyyo laddhāna saṁvegaṁ,"
    },
    {
      "id": "thag2.27:1.4",
      "pali": "adīno vahate dhuraṁ."
    },
    {
      "id": "thag2.27:2.1",
      "pali": "Evaṁ dassanasampannaṁ,"
    },
    {
      "id": "thag2.27:2.2",
      "pali": "sammāsambuddhasāvakaṁ;"
    },
    {
      "id": "thag2.27:2.3",
      "pali": "Ājānīyaṁ maṁ dhāretha,"
    },
    {
      "id": "thag2.27:2.4",
      "pali": "puttaṁ buddhassa orasan”ti."
    },
    {
      "id": "thag2.27:2.5",
      "pali": "… Nandako thero …."
    }
  ]
}
