{
  "uid": "thag4.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.7:1.1",
      "pali": "“Yo dandhakāle tarati,"
    },
    {
      "id": "thag4.7:1.2",
      "pali": "taraṇīye ca dandhaye;"
    },
    {
      "id": "thag4.7:1.3",
      "pali": "Ayoni saṁvidhānena,"
    },
    {
      "id": "thag4.7:1.4",
      "pali": "bālo dukkhaṁ nigacchati."
    },
    {
      "id": "thag4.7:2.1",
      "pali": "Tassatthā parihāyanti,"
    },
    {
      "id": "thag4.7:2.2",
      "pali": "kāḷapakkheva candimā;"
    },
    {
      "id": "thag4.7:2.3",
      "pali": "Āyasakyañca pappoti,"
    },
    {
      "id": "thag4.7:2.4",
      "pali": "mittehi ca virujjhati."
    },
    {
      "id": "thag4.7:3.1",
      "pali": "Yo dandhakāle dandheti,"
    },
    {
      "id": "thag4.7:3.2",
      "pali": "taraṇīye ca tāraye;"
    },
    {
      "id": "thag4.7:3.3",
      "pali": "Yoniso saṁvidhānena,"
    },
    {
      "id": "thag4.7:3.4",
      "pali": "sukhaṁ pappoti paṇḍito."
    },
    {
      "id": "thag4.7:4.1",
      "pali": "Tassatthā paripūrenti,"
    },
    {
      "id": "thag4.7:4.2",
      "pali": "sukkapakkheva candimā;"
    },
    {
      "id": "thag4.7:4.3",
      "pali": "Yaso kittiñca pappoti,"
    },
    {
      "id": "thag4.7:4.4",
      "pali": "mittehi na virujjhatī”ti."
    },
    {
      "id": "thag4.7:4.5",
      "pali": "… Sambhūto thero …."
    }
  ]
}
