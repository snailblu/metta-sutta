{
  "uid": "tha-ap338",
  "title": "Pabhaṅkarattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap338:1.1",
      "pali": "“Padumuttarabhagavato,"
    },
    {
      "id": "tha-ap338:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap338:1.3",
      "pali": "Vipine cetiyaṁ āsi,"
    },
    {
      "id": "tha-ap338:1.4",
      "pali": "vāḷamigasamākule."
    },
    {
      "id": "tha-ap338:2.1",
      "pali": "Na koci visahi gantuṁ,"
    },
    {
      "id": "tha-ap338:2.2",
      "pali": "cetiyaṁ abhivandituṁ;"
    },
    {
      "id": "tha-ap338:2.3",
      "pali": "Tiṇakaṭṭhalatonaddhaṁ,"
    },
    {
      "id": "tha-ap338:2.4",
      "pali": "paluggaṁ āsi cetiyaṁ."
    },
    {
      "id": "tha-ap338:3.1",
      "pali": "Vanakammiko tadā āsiṁ,"
    },
    {
      "id": "tha-ap338:3.2",
      "pali": "pitumātumatenahaṁ;"
    },
    {
      "id": "tha-ap338:3.3",
      "pali": "Addasaṁ vipine thūpaṁ,"
    },
    {
      "id": "tha-ap338:3.4",
      "pali": "luggaṁ tiṇalatākulaṁ."
    },
    {
      "id": "tha-ap338:4.1",
      "pali": "Disvānāhaṁ buddhathūpaṁ,"
    },
    {
      "id": "tha-ap338:4.2",
      "pali": "garucittaṁ upaṭṭhahiṁ;"
    },
    {
      "id": "tha-ap338:4.3",
      "pali": "Buddhaseṭṭhassa thūpoyaṁ,"
    },
    {
      "id": "tha-ap338:4.4",
      "pali": "paluggo acchatī vane."
    },
    {
      "id": "tha-ap338:5.1",
      "pali": "Nacchannaṁ nappatirūpaṁ,"
    },
    {
      "id": "tha-ap338:5.2",
      "pali": "jānantassa guṇāguṇaṁ;"
    },
    {
      "id": "tha-ap338:5.3",
      "pali": "Buddhathūpaṁ asodhetvā,"
    },
    {
      "id": "tha-ap338:5.4",
      "pali": "aññaṁ kammaṁ payojaye."
    },
    {
      "id": "tha-ap338:6.1",
      "pali": "Tiṇakaṭṭhañca valliñca,"
    },
    {
      "id": "tha-ap338:6.2",
      "pali": "sodhayitvāna cetiye;"
    },
    {
      "id": "tha-ap338:6.3",
      "pali": "Vanditvā aṭṭha vārāni,"
    },
    {
      "id": "tha-ap338:6.4",
      "pali": "paṭikuṭiko agacchahaṁ."
    },
    {
      "id": "tha-ap338:7.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap338:7.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap338:7.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap338:7.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap338:8.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap338:8.2",
      "pali": "sovaṇṇaṁ sapabhassaraṁ;"
    },
    {
      "id": "tha-ap338:8.3",
      "pali": "Saṭṭhiyojanamubbiddhaṁ,"
    },
    {
      "id": "tha-ap338:8.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "tha-ap338:9.1",
      "pali": "Tisatāni ca vārāni,"
    },
    {
      "id": "tha-ap338:9.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap338:9.3",
      "pali": "Pañcavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap338:9.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap338:10.1",
      "pali": "Bhavābhave saṁsaranto,"
    },
    {
      "id": "tha-ap338:10.2",
      "pali": "mahābhogaṁ labhāmahaṁ;"
    },
    {
      "id": "tha-ap338:10.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap338:10.4",
      "pali": "sodhanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap338:11.1",
      "pali": "Sivikā hatthikhandhena,"
    },
    {
      "id": "tha-ap338:11.2",
      "pali": "vipine gacchato mama;"
    },
    {
      "id": "tha-ap338:11.3",
      "pali": "Yaṁ yaṁ disāhaṁ gacchāmi,"
    },
    {
      "id": "tha-ap338:11.4",
      "pali": "saraṇaṁ sampate vanaṁ."
    },
    {
      "id": "tha-ap338:12.1",
      "pali": "Khāṇuṁ vā kaṇṭakaṁ vāpi,"
    },
    {
      "id": "tha-ap338:12.2",
      "pali": "nāhaṁ passāmi cakkhunā;"
    },
    {
      "id": "tha-ap338:12.3",
      "pali": "Puññakammena saṁyutto,"
    },
    {
      "id": "tha-ap338:12.4",
      "pali": "sayamevāpanīyare."
    },
    {
      "id": "tha-ap338:13.1",
      "pali": "Kuṭṭhaṁ gaṇḍo kilāso ca,"
    },
    {
      "id": "tha-ap338:13.2",
      "pali": "apamāro vitacchikā;"
    },
    {
      "id": "tha-ap338:13.3",
      "pali": "Daddu kacchu ca me natthi,"
    },
    {
      "id": "tha-ap338:13.4",
      "pali": "sodhanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap338:14.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:14.2",
      "pali": "buddhathūpassa sodhane;"
    },
    {
      "id": "tha-ap338:14.3",
      "pali": "Nābhijānāmi me kāye,"
    },
    {
      "id": "tha-ap338:14.4",
      "pali": "jātaṁ piḷakabindukaṁ."
    },
    {
      "id": "tha-ap338:15.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:15.2",
      "pali": "buddhathūpamhi sodhite;"
    },
    {
      "id": "tha-ap338:15.3",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap338:15.4",
      "pali": "devatte atha mānuse."
    },
    {
      "id": "tha-ap338:16.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:16.2",
      "pali": "buddhathūpamhi sodhite;"
    },
    {
      "id": "tha-ap338:16.3",
      "pali": "Suvaṇṇavaṇṇo sabbattha,"
    },
    {
      "id": "tha-ap338:16.4",
      "pali": "sappabhāso bhavāmahaṁ."
    },
    {
      "id": "tha-ap338:17.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:17.2",
      "pali": "buddhathūpamhi sodhite;"
    },
    {
      "id": "tha-ap338:17.3",
      "pali": "Amanāpaṁ vivajjati,"
    },
    {
      "id": "tha-ap338:17.4",
      "pali": "manāpaṁ upatiṭṭhati."
    },
    {
      "id": "tha-ap338:18.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:18.2",
      "pali": "buddhathūpamhi sodhite;"
    },
    {
      "id": "tha-ap338:18.3",
      "pali": "Visuddhaṁ hoti me cittaṁ,"
    },
    {
      "id": "tha-ap338:18.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "tha-ap338:19.1",
      "pali": "Aññampi me acchariyaṁ,"
    },
    {
      "id": "tha-ap338:19.2",
      "pali": "buddhathūpamhi sodhite;"
    },
    {
      "id": "tha-ap338:19.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap338:19.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap338:20.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap338:20.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap338:20.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap338:20.4",
      "pali": "sodhanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap338:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap338:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap338:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap338:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā pabhaṅkaro thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap338:23.1",
      "pali": "Pabhaṅkarattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
