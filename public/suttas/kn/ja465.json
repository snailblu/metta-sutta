{
  "uid": "ja465",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja465:1.1",
      "pali": "“Kā tvaṁ suddhehi vatthehi,"
    },
    {
      "id": "ja465:1.2",
      "pali": "aghe vehāyasaṁ ṭhitā;"
    },
    {
      "id": "ja465:1.3",
      "pali": "Kena tyāssūni vattanti,"
    },
    {
      "id": "ja465:1.4",
      "pali": "kuto taṁ bhayamāgataṁ”."
    },
    {
      "id": "ja465:2.1",
      "pali": "“Taveva deva vijite,"
    },
    {
      "id": "ja465:2.2",
      "pali": "bhaddasāloti maṁ vidū;"
    },
    {
      "id": "ja465:2.3",
      "pali": "Saṭṭhi vassasahassāni,"
    },
    {
      "id": "ja465:2.4",
      "pali": "tiṭṭhato pūjitassa me."
    },
    {
      "id": "ja465:3.1",
      "pali": "Kārayantā nagarāni,"
    },
    {
      "id": "ja465:3.2",
      "pali": "agāre ca disampati;"
    },
    {
      "id": "ja465:3.3",
      "pali": "Vividhe cāpi pāsāde,"
    },
    {
      "id": "ja465:3.4",
      "pali": "na maṁ te accamaññisuṁ;"
    },
    {
      "id": "ja465:3.5",
      "pali": "Yatheva maṁ te pūjesuṁ,"
    },
    {
      "id": "ja465:3.6",
      "pali": "tatheva tvampi pūjaya”."
    },
    {
      "id": "ja465:4.1",
      "pali": "“Taṁ ivāhaṁ na passāmi,"
    },
    {
      "id": "ja465:4.2",
      "pali": "thūlaṁ kāyena te dumaṁ;"
    },
    {
      "id": "ja465:4.3",
      "pali": "Ārohapariṇāhena,"
    },
    {
      "id": "ja465:4.4",
      "pali": "abhirūposi jātiyā."
    },
    {
      "id": "ja465:5.1",
      "pali": "Pāsādaṁ kārayissāmi,"
    },
    {
      "id": "ja465:5.2",
      "pali": "ekatthambhaṁ manoramaṁ;"
    },
    {
      "id": "ja465:5.3",
      "pali": "Tattha taṁ upanessāmi,"
    },
    {
      "id": "ja465:5.4",
      "pali": "ciraṁ te yakkha jīvitaṁ”."
    },
    {
      "id": "ja465:6.1",
      "pali": "“Evaṁ cittaṁ udapādi,"
    },
    {
      "id": "ja465:6.2",
      "pali": "sarīrena vinābhāvo;"
    },
    {
      "id": "ja465:6.3",
      "pali": "Puthuso maṁ vikantitvā,"
    },
    {
      "id": "ja465:6.4",
      "pali": "khaṇḍaso avakantatha."
    },
    {
      "id": "ja465:7.1",
      "pali": "Agge ca chetvā majjhe ca,"
    },
    {
      "id": "ja465:7.2",
      "pali": "pacchā mūlamhi chindatha;"
    },
    {
      "id": "ja465:7.3",
      "pali": "Evaṁ me chijjamānassa,"
    },
    {
      "id": "ja465:7.4",
      "pali": "na dukkhaṁ maraṇaṁ siyā”."
    },
    {
      "id": "ja465:8.1",
      "pali": "“Hatthapādaṁ yathā chinde,"
    },
    {
      "id": "ja465:8.2",
      "pali": "Kaṇṇanāsañca jīvato;"
    },
    {
      "id": "ja465:8.3",
      "pali": "Tato pacchā siro chinde,"
    },
    {
      "id": "ja465:8.4",
      "pali": "Taṁ dukkhaṁ maraṇaṁ siyā."
    },
    {
      "id": "ja465:9.1",
      "pali": "Sukhaṁ nu khaṇḍaso chinnaṁ,"
    },
    {
      "id": "ja465:9.2",
      "pali": "bhaddasāla vanappati;"
    },
    {
      "id": "ja465:9.3",
      "pali": "Kiṁhetu kiṁ upādāya,"
    },
    {
      "id": "ja465:9.4",
      "pali": "khaṇḍaso chinnamicchasi”."
    },
    {
      "id": "ja465:10.1",
      "pali": "“Yañca hetumupādāya,"
    },
    {
      "id": "ja465:10.2",
      "pali": "hetuṁ dhammūpasaṁhitaṁ;"
    },
    {
      "id": "ja465:10.3",
      "pali": "Khaṇḍaso chinnamicchāmi,"
    },
    {
      "id": "ja465:10.4",
      "pali": "mahārāja suṇohi me."
    },
    {
      "id": "ja465:11.1",
      "pali": "Ñātī me sukhasaṁvaddhā,"
    },
    {
      "id": "ja465:11.2",
      "pali": "mama passe nivātajā;"
    },
    {
      "id": "ja465:11.3",
      "pali": "Tepihaṁ upahiṁseyyaṁ,"
    },
    {
      "id": "ja465:11.4",
      "pali": "paresaṁ asukhocitaṁ”."
    },
    {
      "id": "ja465:12.1",
      "pali": "“Ceteyyarūpaṁ cetesi,"
    },
    {
      "id": "ja465:12.2",
      "pali": "bhaddasāla vanappati;"
    },
    {
      "id": "ja465:12.3",
      "pali": "Hitakāmosi ñātīnaṁ,"
    },
    {
      "id": "ja465:12.4",
      "pali": "abhayaṁ samma dammi te”ti."
    },
    {
      "id": "ja465:13.1",
      "pali": "Bhaddasālajātakaṁ dutiyaṁ."
    }
  ]
}
