{
  "uid": "ja7",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja7:1.1",
      "pali": "“Putto tyāhaṁ mahārāja,"
    },
    {
      "id": "ja7:1.2",
      "pali": "tvaṁ maṁ posa janādhipa;"
    },
    {
      "id": "ja7:1.3",
      "pali": "Aññepi devo poseti,"
    },
    {
      "id": "ja7:1.4",
      "pali": "kiñca devo sakaṁ pajan”ti."
    },
    {
      "id": "ja7:2.1",
      "pali": "Kaṭṭhahārijātakaṁ sattamaṁ."
    }
  ]
}
