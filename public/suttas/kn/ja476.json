{
  "uid": "ja476",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja476:1.1",
      "pali": "“Idheva haṁsa nipata,"
    },
    {
      "id": "ja476:1.2",
      "pali": "piyaṁ me tava dassanaṁ;"
    },
    {
      "id": "ja476:1.3",
      "pali": "Issarosi anuppatto,"
    },
    {
      "id": "ja476:1.4",
      "pali": "yamidhatthi pavedaya”."
    },
    {
      "id": "ja476:2.1",
      "pali": "“Savanena ekassa piyā bhavanti,"
    },
    {
      "id": "ja476:2.2",
      "pali": "Disvā panekassa viyeti chando;"
    },
    {
      "id": "ja476:2.3",
      "pali": "Disvā ca sutvā ca piyā bhavanti,"
    },
    {
      "id": "ja476:2.4",
      "pali": "Kaccinnu me pīyasi dassanena."
    },
    {
      "id": "ja476:3.1",
      "pali": "Savanena piyo mesi,"
    },
    {
      "id": "ja476:3.2",
      "pali": "bhiyyo cāgamma dassanaṁ;"
    },
    {
      "id": "ja476:3.3",
      "pali": "Evaṁ piyadassano me,"
    },
    {
      "id": "ja476:3.4",
      "pali": "vasa haṁsa mamantike”."
    },
    {
      "id": "ja476:4.1",
      "pali": "“Vaseyyāma tavāgāre,"
    },
    {
      "id": "ja476:4.2",
      "pali": "niccaṁ sakkatapūjitā;"
    },
    {
      "id": "ja476:4.3",
      "pali": "Matto ca ekadā vajje,"
    },
    {
      "id": "ja476:4.4",
      "pali": "‘haṁsarājaṁ pacantu me’”."
    },
    {
      "id": "ja476:5.1",
      "pali": "“Dhiratthu taṁ majjapānaṁ,"
    },
    {
      "id": "ja476:5.2",
      "pali": "yaṁ me piyataraṁ tayā;"
    },
    {
      "id": "ja476:5.3",
      "pali": "Na cāpi majjaṁ pissāmi,"
    },
    {
      "id": "ja476:5.4",
      "pali": "yāva me vacchasī ghare”."
    },
    {
      "id": "ja476:6.1",
      "pali": "“Suvijānaṁ siṅgālānaṁ,"
    },
    {
      "id": "ja476:6.2",
      "pali": "sakuṇānañca vassitaṁ;"
    },
    {
      "id": "ja476:6.3",
      "pali": "Manussavassitaṁ rāja,"
    },
    {
      "id": "ja476:6.4",
      "pali": "dubbijānataraṁ tato."
    },
    {
      "id": "ja476:7.1",
      "pali": "Api ce maññatī poso,"
    },
    {
      "id": "ja476:7.2",
      "pali": "ñāti mitto sakhāti vā;"
    },
    {
      "id": "ja476:7.3",
      "pali": "Yo pubbe sumano hutvā,"
    },
    {
      "id": "ja476:7.4",
      "pali": "pacchā sampajjate diso."
    },
    {
      "id": "ja476:8.1",
      "pali": "Yasmiṁ mano nivisati,"
    },
    {
      "id": "ja476:8.2",
      "pali": "avidūre sahāpi so;"
    },
    {
      "id": "ja476:8.3",
      "pali": "Santikepi hi so dūre,"
    },
    {
      "id": "ja476:8.4",
      "pali": "yasmiṁ nāvisate mano."
    },
    {
      "id": "ja476:9.1",
      "pali": "Antopi so hoti pasannacitto,"
    },
    {
      "id": "ja476:9.2",
      "pali": "Pāraṁ samuddassa pasannacitto;"
    },
    {
      "id": "ja476:9.3",
      "pali": "Antopi so hoti paduṭṭhacitto,"
    },
    {
      "id": "ja476:9.4",
      "pali": "Pāraṁ samuddassa paduṭṭhacitto."
    },
    {
      "id": "ja476:10.1",
      "pali": "Saṁvasantā vivasanti,"
    },
    {
      "id": "ja476:10.2",
      "pali": "ye disā te rathesabha;"
    },
    {
      "id": "ja476:10.3",
      "pali": "Ārā santo saṁvasanti,"
    },
    {
      "id": "ja476:10.4",
      "pali": "manasā raṭṭhavaḍḍhana."
    },
    {
      "id": "ja476:11.1",
      "pali": "Aticiraṁ nivāsena,"
    },
    {
      "id": "ja476:11.2",
      "pali": "piyo bhavati appiyo;"
    },
    {
      "id": "ja476:11.3",
      "pali": "Āmanta kho taṁ gacchāma,"
    },
    {
      "id": "ja476:11.4",
      "pali": "purā te homa appiyā”."
    },
    {
      "id": "ja476:12.1",
      "pali": "“Evañce yācamānānaṁ,"
    },
    {
      "id": "ja476:12.2",
      "pali": "Añjaliṁ nāvabujjhasi;"
    },
    {
      "id": "ja476:12.3",
      "pali": "Paricārakānaṁ sataṁ,"
    },
    {
      "id": "ja476:12.4",
      "pali": "Vacanaṁ na karosi no;"
    },
    {
      "id": "ja476:12.5",
      "pali": "Evaṁ taṁ abhiyācāma,"
    },
    {
      "id": "ja476:12.6",
      "pali": "Puna kayirāsi pariyāyaṁ”."
    },
    {
      "id": "ja476:13.1",
      "pali": "“Evañce no viharataṁ,"
    },
    {
      "id": "ja476:13.2",
      "pali": "antarāyo na hessati;"
    },
    {
      "id": "ja476:13.3",
      "pali": "Tuyhañcāpi mahārāja,"
    },
    {
      "id": "ja476:13.4",
      "pali": "mayhañca raṭṭhavaḍḍhana;"
    },
    {
      "id": "ja476:13.5",
      "pali": "Appeva nāma passemu,"
    },
    {
      "id": "ja476:13.6",
      "pali": "ahorattānamaccaye”ti."
    },
    {
      "id": "ja476:14.1",
      "pali": "Javanahaṁsajātakaṁ tatiyaṁ."
    }
  ]
}
