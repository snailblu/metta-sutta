{
  "uid": "pv20",
  "title": "8. Cūḷaseṭṭhipetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv20:1.1",
      "pali": "“Naggo kiso pabbajitosi bhante,"
    },
    {
      "id": "pv20:1.2",
      "pali": "Rattiṁ kuhiṁ gacchasi kissa hetu;"
    },
    {
      "id": "pv20:1.3",
      "pali": "Ācikkha me taṁ api sakkuṇemu,"
    },
    {
      "id": "pv20:1.4",
      "pali": "Sabbena vittaṁ paṭipādaye tuvan”ti."
    },
    {
      "id": "pv20:2.1",
      "pali": "“Bārāṇasī nagaraṁ dūraghuṭṭhaṁ,"
    },
    {
      "id": "pv20:2.2",
      "pali": "Tatthāhaṁ gahapati aḍḍhako ahu dīno;"
    },
    {
      "id": "pv20:2.3",
      "pali": "Adātā gedhitamano āmisasmiṁ,"
    },
    {
      "id": "pv20:2.4",
      "pali": "Dussīlyena yamavisayamhi patto."
    },
    {
      "id": "pv20:3.1",
      "pali": "So sūcikāya kilamito tehi,"
    },
    {
      "id": "pv20:3.2",
      "pali": "Teneva ñātīsu yāmi āmisakiñcikkhahetu;"
    },
    {
      "id": "pv20:3.3",
      "pali": "Adānasīlā na ca saddahanti,"
    },
    {
      "id": "pv20:3.4",
      "pali": "Dānaphalaṁ hoti paramhi loke."
    },
    {
      "id": "pv20:4.1",
      "pali": "Dhītā ca mayhaṁ lapate abhikkhaṇaṁ,"
    },
    {
      "id": "pv20:4.2",
      "pali": "‘Dassāmi dānaṁ pitūnaṁ pitāmahānaṁ’;"
    },
    {
      "id": "pv20:4.3",
      "pali": "Tamupakkhaṭaṁ parivisayanti brāhmaṇā,"
    },
    {
      "id": "pv20:4.4",
      "pali": "‘Yāmi ahaṁ andhakavindaṁ bhottun’”ti."
    },
    {
      "id": "pv20:5.1",
      "pali": "Tamavoca rājā “anubhaviyāna tampi,"
    },
    {
      "id": "pv20:5.2",
      "pali": "Eyyāsi khippaṁ ahamapi kassaṁ pūjaṁ;"
    },
    {
      "id": "pv20:5.3",
      "pali": "Ācikkha me taṁ yadi atthi hetu,"
    },
    {
      "id": "pv20:5.4",
      "pali": "Saddhāyitaṁ hetuvaco suṇomā”ti."
    },
    {
      "id": "pv20:6.1",
      "pali": "“Tathā”ti vatvā agamāsi tattha,"
    },
    {
      "id": "pv20:6.2",
      "pali": "Bhuñjiṁsu bhattaṁ na ca dakkhiṇārahā;"
    },
    {
      "id": "pv20:6.3",
      "pali": "Paccāgami rājagahaṁ punāparaṁ,"
    },
    {
      "id": "pv20:6.4",
      "pali": "Pāturahosi purato janādhipassa."
    },
    {
      "id": "pv20:7.1",
      "pali": "Disvāna petaṁ punadeva āgataṁ,"
    },
    {
      "id": "pv20:7.2",
      "pali": "Rājā avoca “ahamapi kiṁ dadāmi;"
    },
    {
      "id": "pv20:7.3",
      "pali": "Ācikkha me taṁ yadi atthi hetu,"
    },
    {
      "id": "pv20:7.4",
      "pali": "Yena tuvaṁ cirataraṁ pīṇito siyā”ti."
    },
    {
      "id": "pv20:8.1",
      "pali": "“Buddhañca saṅghaṁ parivisiyāna rāja,"
    },
    {
      "id": "pv20:8.2",
      "pali": "Annena pānena ca cīvarena;"
    },
    {
      "id": "pv20:8.3",
      "pali": "Taṁ dakkhiṇaṁ ādisa me hitāya,"
    },
    {
      "id": "pv20:8.4",
      "pali": "Evaṁ ahaṁ cirataraṁ pīṇito siyā”ti."
    },
    {
      "id": "pv20:9.1",
      "pali": "Tato ca rājā nipatitvā tāvade,"
    },
    {
      "id": "pv20:9.2",
      "pali": "Dānaṁ sahatthā atulaṁ daditvā saṅghe;"
    },
    {
      "id": "pv20:9.3",
      "pali": "Ārocesi pakataṁ tathāgatassa,"
    },
    {
      "id": "pv20:9.4",
      "pali": "Tassa ca petassa dakkhiṇaṁ ādisittha."
    },
    {
      "id": "pv20:10.1",
      "pali": "So pūjito ativiya sobhamāno,"
    },
    {
      "id": "pv20:10.2",
      "pali": "Pāturahosi purato janādhipassa;"
    },
    {
      "id": "pv20:10.3",
      "pali": "“Yakkhohamasmi paramiddhipatto,"
    },
    {
      "id": "pv20:10.4",
      "pali": "Na mayhamatthi samā sadisā mānusā."
    },
    {
      "id": "pv20:11.1",
      "pali": "Passānubhāvaṁ aparimitaṁ mamayidaṁ,"
    },
    {
      "id": "pv20:11.2",
      "pali": "Tayānudiṭṭhaṁ atulaṁ datvā saṅghe;"
    },
    {
      "id": "pv20:11.3",
      "pali": "Santappito satataṁ sadā bahūhi,"
    },
    {
      "id": "pv20:11.4",
      "pali": "Yāmi ahaṁ sukhito manussadevā”ti."
    },
    {
      "id": "pv20:12.1",
      "pali": "Cūḷaseṭṭhipetavatthu aṭṭhamaṁ."
    },
    {
      "id": "pv20:12.2",
      "pali": "Bhāṇavāraṁ paṭhamaṁ."
    }
  ]
}
