{
  "uid": "tha-ap262",
  "title": "Aggapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap262:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap262:1.2",
      "pali": "Nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap262:1.3",
      "pali": "Obhāsayantaṁ raṁsena,"
    },
    {
      "id": "tha-ap262:1.4",
      "pali": "Sikhinaṁ sikhinaṁ yathā."
    },
    {
      "id": "tha-ap262:2.1",
      "pali": "Aggajaṁ pupphamādāya,"
    },
    {
      "id": "tha-ap262:2.2",
      "pali": "upāgacchiṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap262:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap262:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap262:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap262:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap262:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap262:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap262:4.1",
      "pali": "Pañcavīsatikappamhi,"
    },
    {
      "id": "tha-ap262:4.2",
      "pali": "ahosi amitogato;"
    },
    {
      "id": "tha-ap262:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap262:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap262:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap262:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap262:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap262:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā aggapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap262:7.1",
      "pali": "Aggapupphiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap262:8.1",
      "pali": "Thomakavaggo chabbīsatimo."
    },
    {
      "id": "tha-ap262:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap262:10.1",
      "pali": "Thomakekāsanacitakaṁ,"
    },
    {
      "id": "tha-ap262:10.2",
      "pali": "campako sattapāṭali;"
    },
    {
      "id": "tha-ap262:10.3",
      "pali": "Pānadhi mañjarī paṇṇaṁ,"
    },
    {
      "id": "tha-ap262:10.4",
      "pali": "kuṭido aggapupphiyo;"
    },
    {
      "id": "tha-ap262:10.5",
      "pali": "Gāthāyo gaṇitā cettha,"
    },
    {
      "id": "tha-ap262:10.6",
      "pali": "ekatālīsameva cāti."
    }
  ]
}
