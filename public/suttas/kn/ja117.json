{
  "uid": "ja117",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja117:1.1",
      "pali": "“Accuggatātilapatā,"
    },
    {
      "id": "ja117:1.2",
      "pali": "ativelaṁ pabhāsitā;"
    },
    {
      "id": "ja117:1.3",
      "pali": "Vācā hanati dummedhaṁ,"
    },
    {
      "id": "ja117:1.4",
      "pali": "tittiraṁvātivassitan”ti."
    },
    {
      "id": "ja117:2.1",
      "pali": "Tittirajātakaṁ sattamaṁ."
    }
  ]
}
