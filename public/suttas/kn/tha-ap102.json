{
  "uid": "tha-ap102",
  "title": "Buddhupaṭṭhākattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap102:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap102:1.2",
      "pali": "ahosiṁ saṅkhadhammako;"
    },
    {
      "id": "tha-ap102:1.3",
      "pali": "Niccupaṭṭhānayuttomhi,"
    },
    {
      "id": "tha-ap102:1.4",
      "pali": "sugatassa mahesino."
    },
    {
      "id": "tha-ap102:2.1",
      "pali": "Upaṭṭhānaphalaṁ passa,"
    },
    {
      "id": "tha-ap102:2.2",
      "pali": "lokanāthassa tādino;"
    },
    {
      "id": "tha-ap102:2.3",
      "pali": "Saṭṭhitūriyasahassāni,"
    },
    {
      "id": "tha-ap102:2.4",
      "pali": "parivārenti maṁ sadā."
    },
    {
      "id": "tha-ap102:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap102:3.2",
      "pali": "upaṭṭhahiṁ mahāisiṁ;"
    },
    {
      "id": "tha-ap102:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap102:3.4",
      "pali": "upaṭṭhānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap102:4.1",
      "pali": "Catuvīse ito kappe,"
    },
    {
      "id": "tha-ap102:4.2",
      "pali": "mahānigghosanāmakā;"
    },
    {
      "id": "tha-ap102:4.3",
      "pali": "Soḷasāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap102:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap102:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap102:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap102:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap102:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhupaṭṭhāko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap102:7.1",
      "pali": "Buddhupaṭṭhākattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap102:7.2",
      "pali": "Sudhāvaggo dasamo."
    },
    {
      "id": "tha-ap102:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap102:9.1",
      "pali": "Sudhā sucinti ceḷañca,"
    },
    {
      "id": "tha-ap102:9.2",
      "pali": "sūcī ca gandhamāliyo;"
    },
    {
      "id": "tha-ap102:9.3",
      "pali": "Tipupphiyo madhusenā,"
    },
    {
      "id": "tha-ap102:9.4",
      "pali": "veyyāvacco cupaṭṭhako;"
    },
    {
      "id": "tha-ap102:9.5",
      "pali": "Samasaṭṭhi ca gāthāyo,"
    },
    {
      "id": "tha-ap102:9.6",
      "pali": "asmiṁ vagge pakittitā."
    },
    {
      "id": "tha-ap102:10.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap102:11.1",
      "pali": "Buddhavaggo hi paṭhamo,"
    },
    {
      "id": "tha-ap102:11.2",
      "pali": "sīhāsani subhūti ca;"
    },
    {
      "id": "tha-ap102:11.3",
      "pali": "Kuṇḍadhāno upāli ca,"
    },
    {
      "id": "tha-ap102:11.4",
      "pali": "bījanisakacinti ca."
    },
    {
      "id": "tha-ap102:12.1",
      "pali": "Nāgasamālo timiro,"
    },
    {
      "id": "tha-ap102:12.2",
      "pali": "sudhāvaggena te dasa;"
    },
    {
      "id": "tha-ap102:12.3",
      "pali": "Catuddasasatā gāthā,"
    },
    {
      "id": "tha-ap102:12.4",
      "pali": "pañcapaññāsameva ca."
    },
    {
      "id": "tha-ap102:13.1",
      "pali": "Buddhavaggadasakaṁ."
    },
    {
      "id": "tha-ap102:14.1",
      "pali": "Paṭhamasatakaṁ samattaṁ."
    }
  ]
}
