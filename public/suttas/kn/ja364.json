{
  "uid": "ja364",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja364:1.1",
      "pali": "“Ko nu santamhi pajjote,"
    },
    {
      "id": "ja364:1.2",
      "pali": "aggipariyesanaṁ caraṁ;"
    },
    {
      "id": "ja364:1.3",
      "pali": "Addakkhi ratti khajjotaṁ,"
    },
    {
      "id": "ja364:1.4",
      "pali": "jātavedaṁ amaññatha."
    },
    {
      "id": "ja364:2.1",
      "pali": "Svassa gomayacuṇṇāni,"
    },
    {
      "id": "ja364:2.2",
      "pali": "abhimatthaṁ tiṇāni ca;"
    },
    {
      "id": "ja364:2.3",
      "pali": "Viparītāya saññāya,"
    },
    {
      "id": "ja364:2.4",
      "pali": "nāsakkhi pajjaletave."
    },
    {
      "id": "ja364:3.1",
      "pali": "Evampi anupāyena,"
    },
    {
      "id": "ja364:3.2",
      "pali": "atthaṁ na labhate migo;"
    },
    {
      "id": "ja364:3.3",
      "pali": "Visāṇato gavaṁ dohaṁ,"
    },
    {
      "id": "ja364:3.4",
      "pali": "yattha khīraṁ na vindati."
    },
    {
      "id": "ja364:4.1",
      "pali": "Vividhehi upāyehi,"
    },
    {
      "id": "ja364:4.2",
      "pali": "atthaṁ papponti māṇavā;"
    },
    {
      "id": "ja364:4.3",
      "pali": "Niggahena amittānaṁ,"
    },
    {
      "id": "ja364:4.4",
      "pali": "mittānaṁ paggahena ca."
    },
    {
      "id": "ja364:5.1",
      "pali": "Senāmokkhapalābhena,"
    },
    {
      "id": "ja364:5.2",
      "pali": "vallabhānaṁ nayena ca;"
    },
    {
      "id": "ja364:5.3",
      "pali": "Jagatiṁ jagatipālā,"
    },
    {
      "id": "ja364:5.4",
      "pali": "āvasanti vasundharan”ti."
    },
    {
      "id": "ja364:6.1",
      "pali": "Khajjopanakajātakaṁ catutthaṁ."
    }
  ]
}
