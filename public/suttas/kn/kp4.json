{
  "uid": "kp4",
  "title": "Kumārapañhā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "kp4:1.1",
      "pali": "Ekaṁ nāma kiṁ?"
    },
    {
      "id": "kp4:1.2",
      "pali": "Sabbe sattā āhāraṭṭhitikā."
    },
    {
      "id": "kp4:2.1",
      "pali": "Dve nāma kiṁ?"
    },
    {
      "id": "kp4:2.2",
      "pali": "Nāmañca rūpañca."
    },
    {
      "id": "kp4:3.1",
      "pali": "Tīṇi nāma kiṁ?"
    },
    {
      "id": "kp4:3.2",
      "pali": "Tisso vedanā."
    },
    {
      "id": "kp4:4.1",
      "pali": "Cattāri nāma kiṁ?"
    },
    {
      "id": "kp4:4.2",
      "pali": "Cattāri ariyasaccāni."
    },
    {
      "id": "kp4:5.1",
      "pali": "Pañca nāma kiṁ?"
    },
    {
      "id": "kp4:5.2",
      "pali": "Pañcupādānakkhandhā."
    },
    {
      "id": "kp4:6.1",
      "pali": "Cha nāma kiṁ?"
    },
    {
      "id": "kp4:6.2",
      "pali": "Cha ajjhattikāni āyatanāni."
    },
    {
      "id": "kp4:7.1",
      "pali": "Satta nāma kiṁ?"
    },
    {
      "id": "kp4:7.2",
      "pali": "Satta bojjhaṅgā."
    },
    {
      "id": "kp4:8.1",
      "pali": "Aṭṭha nāma kiṁ?"
    },
    {
      "id": "kp4:8.2",
      "pali": "Ariyo aṭṭhaṅgiko maggo."
    },
    {
      "id": "kp4:9.1",
      "pali": "Nava nāma kiṁ?"
    },
    {
      "id": "kp4:9.2",
      "pali": "Nava sattāvāsā."
    },
    {
      "id": "kp4:10.1",
      "pali": "Dasa nāma kiṁ?"
    },
    {
      "id": "kp4:10.2",
      "pali": "Dasahaṅgehi samannāgato “arahā”ti vuccatīti."
    },
    {
      "id": "kp4:11.1",
      "pali": "Kumārapañhā."
    }
  ]
}
