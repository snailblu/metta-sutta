{
  "uid": "tha-ap427",
  "title": "Koraṇḍapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap427:1.1",
      "pali": "“Vanakammiko pure āsiṁ,"
    },
    {
      "id": "tha-ap427:1.2",
      "pali": "pitumātumatenahaṁ;"
    },
    {
      "id": "tha-ap427:1.3",
      "pali": "Pasumārena jīvāmi,"
    },
    {
      "id": "tha-ap427:1.4",
      "pali": "kusalaṁ me na vijjati."
    },
    {
      "id": "tha-ap427:2.1",
      "pali": "Mama āsayasāmantā,"
    },
    {
      "id": "tha-ap427:2.2",
      "pali": "tisso lokagganāyako;"
    },
    {
      "id": "tha-ap427:2.3",
      "pali": "Padāni tīṇi dassesi,"
    },
    {
      "id": "tha-ap427:2.4",
      "pali": "anukampāya cakkhumā."
    },
    {
      "id": "tha-ap427:3.1",
      "pali": "Akkante ca pade disvā,"
    },
    {
      "id": "tha-ap427:3.2",
      "pali": "tissanāmassa satthuno;"
    },
    {
      "id": "tha-ap427:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap427:3.4",
      "pali": "pade cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap427:4.1",
      "pali": "Koraṇḍaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap427:4.2",
      "pali": "pādapaṁ dharaṇīruhaṁ;"
    },
    {
      "id": "tha-ap427:4.3",
      "pali": "Sakosakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap427:4.4",
      "pali": "padaseṭṭhamapūjayiṁ."
    },
    {
      "id": "tha-ap427:5.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap427:5.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap427:5.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap427:5.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap427:6.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap427:6.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap427:6.3",
      "pali": "Koraṇḍavaṇṇakoyeva,"
    },
    {
      "id": "tha-ap427:6.4",
      "pali": "suppabhāso bhavāmahaṁ."
    },
    {
      "id": "tha-ap427:7.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap427:7.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap427:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap427:7.4",
      "pali": "padapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap427:8.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap427:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap427:8.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap427:9.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap427:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap427:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap427:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap427:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap427:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap427:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā koraṇḍapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap427:12.1",
      "pali": "Koraṇḍapupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
