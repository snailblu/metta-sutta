{
  "uid": "tha-ap228",
  "title": "6 Aṅkolapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap228:1.1",
      "pali": "“Nārado iti me nāmaṁ,"
    },
    {
      "id": "tha-ap228:1.2",
      "pali": "kassapo iti maṁ vidū;"
    },
    {
      "id": "tha-ap228:1.3",
      "pali": "Addasaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap228:1.4",
      "pali": "vipassiṁ devasakkataṁ."
    },
    {
      "id": "tha-ap228:2.1",
      "pali": "Anubyañjanadharaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap228:2.2",
      "pali": "āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap228:2.3",
      "pali": "Aṅkolapupphaṁ paggayha,"
    },
    {
      "id": "tha-ap228:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap228:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap228:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap228:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap228:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap228:4.1",
      "pali": "Catusattatito kappe,"
    },
    {
      "id": "tha-ap228:4.2",
      "pali": "romaso nāma khattiyo;"
    },
    {
      "id": "tha-ap228:4.3",
      "pali": "Āmukkamālābharaṇo,"
    },
    {
      "id": "tha-ap228:4.4",
      "pali": "sayoggabalavāhano."
    },
    {
      "id": "tha-ap228:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap228:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap228:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap228:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā aṅkolapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap228:7.1",
      "pali": "Aṅkolapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
