{
  "uid": "thag13.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag13.1:1.1",
      "pali": "“Yāhu raṭṭhe samukkaṭṭho,"
    },
    {
      "id": "thag13.1:1.2",
      "pali": "rañño aṅgassa paddhagū;"
    },
    {
      "id": "thag13.1:1.3",
      "pali": "Svajja dhammesu ukkaṭṭho,"
    },
    {
      "id": "thag13.1:1.4",
      "pali": "soṇo dukkhassa pāragū."
    },
    {
      "id": "thag13.1:2.1",
      "pali": "Pañca chinde pañca jahe,"
    },
    {
      "id": "thag13.1:2.2",
      "pali": "pañca cuttari bhāvaye;"
    },
    {
      "id": "thag13.1:2.3",
      "pali": "Pañca saṅgātigo bhikkhu,"
    },
    {
      "id": "thag13.1:2.4",
      "pali": "oghatiṇṇoti vuccati."
    },
    {
      "id": "thag13.1:3.1",
      "pali": "Unnaḷassa pamattassa,"
    },
    {
      "id": "thag13.1:3.2",
      "pali": "bāhirāsassa bhikkhuno;"
    },
    {
      "id": "thag13.1:3.3",
      "pali": "Sīlaṁ samādhi paññā ca,"
    },
    {
      "id": "thag13.1:3.4",
      "pali": "pāripūriṁ na gacchati."
    },
    {
      "id": "thag13.1:4.1",
      "pali": "Yañhi kiccaṁ apaviddhaṁ,"
    },
    {
      "id": "thag13.1:4.2",
      "pali": "akiccaṁ pana karīyati;"
    },
    {
      "id": "thag13.1:4.3",
      "pali": "Unnaḷānaṁ pamattānaṁ,"
    },
    {
      "id": "thag13.1:4.4",
      "pali": "tesaṁ vaḍḍhanti āsavā."
    },
    {
      "id": "thag13.1:5.1",
      "pali": "Yesañca susamāraddhā,"
    },
    {
      "id": "thag13.1:5.2",
      "pali": "niccaṁ kāyagatā sati;"
    },
    {
      "id": "thag13.1:5.3",
      "pali": "Akiccaṁ te na sevanti,"
    },
    {
      "id": "thag13.1:5.4",
      "pali": "kicce sātaccakārino;"
    },
    {
      "id": "thag13.1:5.5",
      "pali": "Satānaṁ sampajānānaṁ,"
    },
    {
      "id": "thag13.1:5.6",
      "pali": "atthaṁ gacchanti āsavā."
    },
    {
      "id": "thag13.1:6.1",
      "pali": "Ujumaggamhi akkhāte,"
    },
    {
      "id": "thag13.1:6.2",
      "pali": "gacchatha mā nivattatha;"
    },
    {
      "id": "thag13.1:6.3",
      "pali": "Attanā codayattānaṁ,"
    },
    {
      "id": "thag13.1:6.4",
      "pali": "nibbānamabhihāraye."
    },
    {
      "id": "thag13.1:7.1",
      "pali": "Accāraddhamhi vīriyamhi,"
    },
    {
      "id": "thag13.1:7.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "thag13.1:7.3",
      "pali": "Vīṇopamaṁ karitvā me,"
    },
    {
      "id": "thag13.1:7.4",
      "pali": "dhammaṁ desesi cakkhumā;"
    },
    {
      "id": "thag13.1:7.5",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thag13.1:7.6",
      "pali": "vihāsiṁ sāsane rato."
    },
    {
      "id": "thag13.1:8.1",
      "pali": "Samathaṁ paṭipādesiṁ,"
    },
    {
      "id": "thag13.1:8.2",
      "pali": "uttamatthassa pattiyā;"
    },
    {
      "id": "thag13.1:8.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag13.1:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag13.1:9.1",
      "pali": "Nekkhamme adhimuttassa,"
    },
    {
      "id": "thag13.1:9.2",
      "pali": "pavivekañca cetaso;"
    },
    {
      "id": "thag13.1:9.3",
      "pali": "Abyāpajjādhimuttassa,"
    },
    {
      "id": "thag13.1:9.4",
      "pali": "upādānakkhayassa ca."
    },
    {
      "id": "thag13.1:10.1",
      "pali": "Taṇhakkhayādhimuttassa,"
    },
    {
      "id": "thag13.1:10.2",
      "pali": "asammohañca cetaso;"
    },
    {
      "id": "thag13.1:10.3",
      "pali": "Disvā āyatanuppādaṁ,"
    },
    {
      "id": "thag13.1:10.4",
      "pali": "sammā cittaṁ vimuccati."
    },
    {
      "id": "thag13.1:11.1",
      "pali": "Tassa sammā vimuttassa,"
    },
    {
      "id": "thag13.1:11.2",
      "pali": "santacittassa bhikkhuno;"
    },
    {
      "id": "thag13.1:11.3",
      "pali": "Katassa paṭicayo natthi,"
    },
    {
      "id": "thag13.1:11.4",
      "pali": "karaṇīyaṁ na vijjati."
    },
    {
      "id": "thag13.1:12.1",
      "pali": "Selo yathā ekagghano,"
    },
    {
      "id": "thag13.1:12.2",
      "pali": "vātena na samīrati;"
    },
    {
      "id": "thag13.1:12.3",
      "pali": "Evaṁ rūpā rasā saddā,"
    },
    {
      "id": "thag13.1:12.4",
      "pali": "gandhā phassā ca kevalā."
    },
    {
      "id": "thag13.1:13.1",
      "pali": "Iṭṭhā dhammā aniṭṭhā ca,"
    },
    {
      "id": "thag13.1:13.2",
      "pali": "nappavedhenti tādino;"
    },
    {
      "id": "thag13.1:13.3",
      "pali": "Ṭhitaṁ cittaṁ visaññuttaṁ,"
    },
    {
      "id": "thag13.1:13.4",
      "pali": "vayañcassānupassatī”ti."
    },
    {
      "id": "thag13.1:13.5",
      "pali": "… Soṇo koḷiviso thero …"
    },
    {
      "id": "thag13.1:13.6",
      "pali": "Terasanipāto niṭṭhito."
    },
    {
      "id": "thag13.1:14.1",
      "pali": "Soṇo koḷiviso thero,"
    },
    {
      "id": "thag13.1:14.2",
      "pali": "ekoyeva mahiddhiko;"
    },
    {
      "id": "thag13.1:14.3",
      "pali": "Terasamhi nipātamhi,"
    },
    {
      "id": "thag13.1:14.4",
      "pali": "gāthāyo cettha terasāti."
    }
  ]
}
