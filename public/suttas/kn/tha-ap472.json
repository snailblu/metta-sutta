{
  "uid": "tha-ap472",
  "title": "Nimittabyākaraṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap472:1.1",
      "pali": "“Ajjhogāhetvā himavaṁ,"
    },
    {
      "id": "tha-ap472:1.2",
      "pali": "mante vāce mahaṁ tadā;"
    },
    {
      "id": "tha-ap472:1.3",
      "pali": "Catupaññāsasahassāni,"
    },
    {
      "id": "tha-ap472:1.4",
      "pali": "sissā mayhaṁ upaṭṭhahuṁ."
    },
    {
      "id": "tha-ap472:2.1",
      "pali": "Adhitā vedagū sabbe,"
    },
    {
      "id": "tha-ap472:2.2",
      "pali": "chaḷaṅge pāramiṁ gatā;"
    },
    {
      "id": "tha-ap472:2.3",
      "pali": "Sakavijjāhupatthaddhā,"
    },
    {
      "id": "tha-ap472:2.4",
      "pali": "himavante vasanti te."
    },
    {
      "id": "tha-ap472:3.1",
      "pali": "Cavitvā tusitā kāyā,"
    },
    {
      "id": "tha-ap472:3.2",
      "pali": "devaputto mahāyaso;"
    },
    {
      "id": "tha-ap472:3.3",
      "pali": "Uppajji mātukucchismiṁ,"
    },
    {
      "id": "tha-ap472:3.4",
      "pali": "sampajāno patissato."
    },
    {
      "id": "tha-ap472:4.1",
      "pali": "Sambuddhe upapajjante,"
    },
    {
      "id": "tha-ap472:4.2",
      "pali": "dasasahassi kampatha;"
    },
    {
      "id": "tha-ap472:4.3",
      "pali": "Andhā cakkhuṁ alabhiṁsu,"
    },
    {
      "id": "tha-ap472:4.4",
      "pali": "uppajjantamhi nāyake."
    },
    {
      "id": "tha-ap472:5.1",
      "pali": "Sabbākāraṁ pakampittha,"
    },
    {
      "id": "tha-ap472:5.2",
      "pali": "kevalā vasudhā ayaṁ;"
    },
    {
      "id": "tha-ap472:5.3",
      "pali": "Nigghosasaddaṁ sutvāna,"
    },
    {
      "id": "tha-ap472:5.4",
      "pali": "ubbijjiṁsu mahājanā."
    },
    {
      "id": "tha-ap472:6.1",
      "pali": "Sabbe janā samāgamma,"
    },
    {
      "id": "tha-ap472:6.2",
      "pali": "āgacchuṁ mama santikaṁ;"
    },
    {
      "id": "tha-ap472:6.3",
      "pali": "‘Vasudhāyaṁ pakampittha,"
    },
    {
      "id": "tha-ap472:6.4",
      "pali": "kiṁ vipāko bhavissati’."
    },
    {
      "id": "tha-ap472:7.1",
      "pali": "Avacāsiṁ tadā tesaṁ,"
    },
    {
      "id": "tha-ap472:7.2",
      "pali": "‘mā bhetha natthi vo bhayaṁ;"
    },
    {
      "id": "tha-ap472:7.3",
      "pali": "Vissatthā hotha sabbepi,"
    },
    {
      "id": "tha-ap472:7.4",
      "pali": "uppādoyaṁ suvatthiko."
    },
    {
      "id": "tha-ap472:8.1",
      "pali": "Aṭṭhahetūhi samphussa,"
    },
    {
      "id": "tha-ap472:8.2",
      "pali": "vasudhāyaṁ pakampati;"
    },
    {
      "id": "tha-ap472:8.3",
      "pali": "Tathā nimittā dissanti,"
    },
    {
      "id": "tha-ap472:8.4",
      "pali": "obhāso vipulo mahā."
    },
    {
      "id": "tha-ap472:9.1",
      "pali": "Asaṁsayaṁ buddhaseṭṭho,"
    },
    {
      "id": "tha-ap472:9.2",
      "pali": "uppajjissati cakkhumā’;"
    },
    {
      "id": "tha-ap472:9.3",
      "pali": "Saññāpetvāna janataṁ,"
    },
    {
      "id": "tha-ap472:9.4",
      "pali": "pañca sīle kathesahaṁ."
    },
    {
      "id": "tha-ap472:10.1",
      "pali": "Sutvāna pañca sīlāni,"
    },
    {
      "id": "tha-ap472:10.2",
      "pali": "buddhuppādañca dullabhaṁ;"
    },
    {
      "id": "tha-ap472:10.3",
      "pali": "Ubbegajātā sumanā,"
    },
    {
      "id": "tha-ap472:10.4",
      "pali": "tuṭṭhahaṭṭhā ahaṁsu te."
    },
    {
      "id": "tha-ap472:11.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap472:11.2",
      "pali": "yaṁ nimittaṁ viyākariṁ;"
    },
    {
      "id": "tha-ap472:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap472:11.4",
      "pali": "byākaraṇassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap472:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap472:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap472:12.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap472:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap472:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap472:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap472:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap472:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap472:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap472:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā nimittabyākaraṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap472:16.1",
      "pali": "Nimittabyākaraṇiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap472:17.1",
      "pali": "Sālakusumiyavaggo sattacattālīsamo."
    },
    {
      "id": "tha-ap472:18.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap472:19.1",
      "pali": "Sālakusumiyo thero,"
    },
    {
      "id": "tha-ap472:19.2",
      "pali": "pūjā nibbāpakopi ca;"
    },
    {
      "id": "tha-ap472:19.3",
      "pali": "Setudo tālavaṇṭī ca,"
    },
    {
      "id": "tha-ap472:19.4",
      "pali": "avaṭalabujappado."
    },
    {
      "id": "tha-ap472:20.1",
      "pali": "Pilakkhapaṭibhānī ca,"
    },
    {
      "id": "tha-ap472:20.2",
      "pali": "veyyākaraṇiyo dijo;"
    },
    {
      "id": "tha-ap472:20.3",
      "pali": "Dvesattati ca gāthāyo,"
    },
    {
      "id": "tha-ap472:20.4",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
