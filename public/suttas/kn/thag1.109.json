{
  "uid": "thag1.109",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.109:1.1",
      "pali": "“Na nūnāyaṁ paramahitānukampino,"
    },
    {
      "id": "thag1.109:1.2",
      "pali": "Rahogato anuvigaṇeti sāsanaṁ;"
    },
    {
      "id": "thag1.109:1.3",
      "pali": "Tathāhayaṁ viharati pākatindriyo,"
    },
    {
      "id": "thag1.109:1.4",
      "pali": "Migī yathā taruṇajātikā vane”ti."
    },
    {
      "id": "thag1.109:1.5",
      "pali": "… Saṅgharakkhito thero …."
    }
  ]
}
