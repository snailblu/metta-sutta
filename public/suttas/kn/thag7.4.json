{
  "uid": "thag7.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag7.4:1.1",
      "pali": "“Disvā pāsādachāyāyaṁ,"
    },
    {
      "id": "thag7.4:1.2",
      "pali": "caṅkamantaṁ naruttamaṁ;"
    },
    {
      "id": "thag7.4:1.3",
      "pali": "Tattha naṁ upasaṅkamma,"
    },
    {
      "id": "thag7.4:1.4",
      "pali": "vandissaṁ purisuttamaṁ."
    },
    {
      "id": "thag7.4:2.1",
      "pali": "Ekaṁsaṁ cīvaraṁ katvā,"
    },
    {
      "id": "thag7.4:2.2",
      "pali": "saṁharitvāna pāṇayo;"
    },
    {
      "id": "thag7.4:2.3",
      "pali": "Anucaṅkamissaṁ virajaṁ,"
    },
    {
      "id": "thag7.4:2.4",
      "pali": "sabbasattānamuttamaṁ."
    },
    {
      "id": "thag7.4:3.1",
      "pali": "Tato pañhe apucchi maṁ,"
    },
    {
      "id": "thag7.4:3.2",
      "pali": "pañhānaṁ kovido vidū;"
    },
    {
      "id": "thag7.4:3.3",
      "pali": "Acchambhī ca abhīto ca,"
    },
    {
      "id": "thag7.4:3.4",
      "pali": "byākāsiṁ satthuno ahaṁ."
    },
    {
      "id": "thag7.4:4.1",
      "pali": "Vissajjitesu pañhesu,"
    },
    {
      "id": "thag7.4:4.2",
      "pali": "anumodi tathāgato;"
    },
    {
      "id": "thag7.4:4.3",
      "pali": "Bhikkhusaṅghaṁ viloketvā,"
    },
    {
      "id": "thag7.4:4.4",
      "pali": "imamatthaṁ abhāsatha."
    },
    {
      "id": "thag7.4:5.1",
      "pali": "‘Lābhā aṅgānaṁ magadhānaṁ,"
    },
    {
      "id": "thag7.4:5.2",
      "pali": "Yesāyaṁ paribhuñjati;"
    },
    {
      "id": "thag7.4:5.3",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thag7.4:5.4",
      "pali": "Paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thag7.4:5.5",
      "pali": "Paccuṭṭhānañca sāmīciṁ,"
    },
    {
      "id": "thag7.4:5.6",
      "pali": "Tesaṁ lābhāti cābravi."
    },
    {
      "id": "thag7.4:6.1",
      "pali": "Ajjatagge maṁ sopāka,"
    },
    {
      "id": "thag7.4:6.2",
      "pali": "dassanāyopasaṅkama;"
    },
    {
      "id": "thag7.4:6.3",
      "pali": "Esā ceva te sopāka,"
    },
    {
      "id": "thag7.4:6.4",
      "pali": "bhavatu upasampadā’."
    },
    {
      "id": "thag7.4:7.1",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "thag7.4:7.2",
      "pali": "laddhāna upasampadaṁ;"
    },
    {
      "id": "thag7.4:7.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "thag7.4:7.4",
      "pali": "aho dhammasudhammatā”ti."
    },
    {
      "id": "thag7.4:7.5",
      "pali": "… Sopāko thero …."
    }
  ]
}
