{
  "uid": "ja208",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja208:1.1",
      "pali": "“Alaṁ metehi ambehi,"
    },
    {
      "id": "ja208:1.2",
      "pali": "jambūhi panasehi ca;"
    },
    {
      "id": "ja208:1.3",
      "pali": "Yāni pāraṁ samuddassa,"
    },
    {
      "id": "ja208:1.4",
      "pali": "varaṁ mayhaṁ udumbaro."
    },
    {
      "id": "ja208:2.1",
      "pali": "Mahatī vata te bondi,"
    },
    {
      "id": "ja208:2.2",
      "pali": "na ca paññā tadūpikā;"
    },
    {
      "id": "ja208:2.3",
      "pali": "Susumāra vañcito mesi,"
    },
    {
      "id": "ja208:2.4",
      "pali": "gaccha dāni yathāsukhan”ti."
    },
    {
      "id": "ja208:3.1",
      "pali": "Susumārajātakaṁ aṭṭhamaṁ."
    }
  ]
}
