{
  "uid": "thag1.50",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.50:1.1",
      "pali": "“Dharaṇī ca siñcati vāti,"
    },
    {
      "id": "thag1.50:1.2",
      "pali": "Māluto vijjutā carati nabhe;"
    },
    {
      "id": "thag1.50:1.3",
      "pali": "Upasamanti vitakkā,"
    },
    {
      "id": "thag1.50:1.4",
      "pali": "Cittaṁ susamāhitaṁ mamā”ti."
    },
    {
      "id": "thag1.50:1.5",
      "pali": "… Vimalo thero …"
    },
    {
      "id": "thag1.50:1.6",
      "pali": "vaggo pañcamo."
    },
    {
      "id": "thag1.50:2.1",
      "pali": "Sirīvaḍḍho revato thero,"
    },
    {
      "id": "thag1.50:2.2",
      "pali": "sumaṅgalo sānusavhayo;"
    },
    {
      "id": "thag1.50:2.3",
      "pali": "Ramaṇīyavihārī ca,"
    },
    {
      "id": "thag1.50:2.4",
      "pali": "samiddhiujjayasañjayā;"
    },
    {
      "id": "thag1.50:2.5",
      "pali": "Rāmaṇeyyo ca so thero,"
    },
    {
      "id": "thag1.50:2.6",
      "pali": "vimalo ca raṇañjahoti."
    }
  ]
}
