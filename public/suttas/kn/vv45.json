{
  "uid": "vv45",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv45:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv45:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv45:1.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv45:2.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv45:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv45:2.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv45:3.1",
      "pali": "“Indīvarānaṁ hatthakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv45:3.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv45:3.3",
      "pali": "Esikānaṁ uṇṇatasmiṁ,"
    },
    {
      "id": "vv45:3.4",
      "pali": "Nagaravare paṇṇakate ramme."
    },
    {
      "id": "vv45:4.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv45:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv45:4.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
