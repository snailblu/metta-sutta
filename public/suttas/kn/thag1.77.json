{
  "uid": "thag1.77",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.77:1.1",
      "pali": "“Idaṁ pure cittamacāri cārikaṁ,"
    },
    {
      "id": "thag1.77:1.2",
      "pali": "Yenicchakaṁ yatthakāmaṁ yathāsukhaṁ;"
    },
    {
      "id": "thag1.77:1.3",
      "pali": "Tadajjahaṁ niggahessāmi yoniso,"
    },
    {
      "id": "thag1.77:1.4",
      "pali": "Hatthippabhinnaṁ viya aṅkusaggaho”ti."
    },
    {
      "id": "thag1.77:1.5",
      "pali": "… Hatthārohaputto thero …."
    }
  ]
}
