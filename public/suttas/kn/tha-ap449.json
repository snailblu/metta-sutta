{
  "uid": "tha-ap449",
  "title": "Sīhāsanikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap449:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap449:1.2",
      "pali": "Sabbabhūtahitesino;"
    },
    {
      "id": "tha-ap449:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap449:1.4",
      "pali": "Sīhāsanamadāsahaṁ."
    },
    {
      "id": "tha-ap449:2.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap449:2.2",
      "pali": "yattha yattha vasāmahaṁ;"
    },
    {
      "id": "tha-ap449:2.3",
      "pali": "Labhāmi vipulaṁ byamhaṁ,"
    },
    {
      "id": "tha-ap449:2.4",
      "pali": "sīhāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap449:3.1",
      "pali": "Soṇṇamayā rūpimayā,"
    },
    {
      "id": "tha-ap449:3.2",
      "pali": "lohitaṅgamayā bahū;"
    },
    {
      "id": "tha-ap449:3.3",
      "pali": "Maṇimayā ca pallaṅkā,"
    },
    {
      "id": "tha-ap449:3.4",
      "pali": "nibbattanti mamaṁ sadā."
    },
    {
      "id": "tha-ap449:4.1",
      "pali": "Bodhiyā āsanaṁ katvā,"
    },
    {
      "id": "tha-ap449:4.2",
      "pali": "jalajuttamanāmino;"
    },
    {
      "id": "tha-ap449:4.3",
      "pali": "Ucce kule pajāyāmi,"
    },
    {
      "id": "tha-ap449:4.4",
      "pali": "aho dhammasudhammatā."
    },
    {
      "id": "tha-ap449:5.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap449:5.2",
      "pali": "sīhāsanamakāsahaṁ;"
    },
    {
      "id": "tha-ap449:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap449:5.4",
      "pali": "sīhāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap449:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap449:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap449:6.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap449:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap449:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap449:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap449:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap449:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap449:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap449:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā sīhāsaniko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap449:10.1",
      "pali": "Sīhāsanikattherassāpadānaṁ sattamaṁ."
    }
  ]
}
