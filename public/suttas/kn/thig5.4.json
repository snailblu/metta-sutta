{
  "uid": "thig5.4",
  "title": "Sundarīnandātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.4:1.1",
      "pali": "“Āturaṁ asuciṁ pūtiṁ,"
    },
    {
      "id": "thig5.4:1.2",
      "pali": "passa nande samussayaṁ;"
    },
    {
      "id": "thig5.4:1.3",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "thig5.4:1.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "thig5.4:2.1",
      "pali": "Yathā idaṁ tathā etaṁ,"
    },
    {
      "id": "thig5.4:2.2",
      "pali": "yathā etaṁ tathā idaṁ;"
    },
    {
      "id": "thig5.4:2.3",
      "pali": "Duggandhaṁ pūtikaṁ vāti,"
    },
    {
      "id": "thig5.4:2.4",
      "pali": "bālānaṁ abhinanditaṁ."
    },
    {
      "id": "thig5.4:3.1",
      "pali": "Evametaṁ avekkhantī,"
    },
    {
      "id": "thig5.4:3.2",
      "pali": "rattindivamatanditā;"
    },
    {
      "id": "thig5.4:3.3",
      "pali": "Tato sakāya paññāya,"
    },
    {
      "id": "thig5.4:3.4",
      "pali": "abhinibbijjha dakkhisaṁ”."
    },
    {
      "id": "thig5.4:4.1",
      "pali": "“Tassā me appamattāya,"
    },
    {
      "id": "thig5.4:4.2",
      "pali": "vicinantiyā yoniso;"
    },
    {
      "id": "thig5.4:4.3",
      "pali": "Yathābhūtaṁ ayaṁ kāyo,"
    },
    {
      "id": "thig5.4:4.4",
      "pali": "diṭṭho santarabāhiro."
    },
    {
      "id": "thig5.4:5.1",
      "pali": "Atha nibbindahaṁ kāye,"
    },
    {
      "id": "thig5.4:5.2",
      "pali": "ajjhattañca virajjahaṁ;"
    },
    {
      "id": "thig5.4:5.3",
      "pali": "Appamattā visaṁyuttā,"
    },
    {
      "id": "thig5.4:5.4",
      "pali": "upasantāmhi nibbutā”ti."
    },
    {
      "id": "thig5.4:6.1",
      "pali": "… Sundarīnandā therī …."
    }
  ]
}
