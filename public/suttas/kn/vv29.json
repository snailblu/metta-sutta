{
  "uid": "vv29",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv29:1.1",
      "pali": "“Uḷāro te yaso vaṇṇo,"
    },
    {
      "id": "vv29:1.2",
      "pali": "sabbā obhāsate disā;"
    },
    {
      "id": "vv29:1.3",
      "pali": "Nāriyo naccanti gāyanti,"
    },
    {
      "id": "vv29:1.4",
      "pali": "devaputtā alaṅkatā."
    },
    {
      "id": "vv29:2.1",
      "pali": "Modenti parivārenti,"
    },
    {
      "id": "vv29:2.2",
      "pali": "tava pūjāya devate;"
    },
    {
      "id": "vv29:2.3",
      "pali": "Sovaṇṇāni vimānāni,"
    },
    {
      "id": "vv29:2.4",
      "pali": "tavimāni sudassane."
    },
    {
      "id": "vv29:3.1",
      "pali": "Tuvaṁsi issarā tesaṁ,"
    },
    {
      "id": "vv29:3.2",
      "pali": "sabbakāmasamiddhinī;"
    },
    {
      "id": "vv29:3.3",
      "pali": "Abhijātā mahantāsi,"
    },
    {
      "id": "vv29:3.4",
      "pali": "devakāye pamodasi;"
    },
    {
      "id": "vv29:3.5",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv29:3.6",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv29:4.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv29:4.2",
      "pali": "Purimāya jātiyā manussaloke;"
    },
    {
      "id": "vv29:4.3",
      "pali": "Dussīlakule suṇisā ahosiṁ,"
    },
    {
      "id": "vv29:4.4",
      "pali": "Assaddhesu kadariyesu ahaṁ."
    },
    {
      "id": "vv29:5.1",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "vv29:5.2",
      "pali": "saṁvibhāgaratā sadā;"
    },
    {
      "id": "vv29:5.3",
      "pali": "Piṇḍāya caramānassa,"
    },
    {
      "id": "vv29:5.4",
      "pali": "apūvaṁ te adāsahaṁ."
    },
    {
      "id": "vv29:6.1",
      "pali": "Tadāhaṁ sassuyācikkhiṁ,"
    },
    {
      "id": "vv29:6.2",
      "pali": "samaṇo āgato idha;"
    },
    {
      "id": "vv29:6.3",
      "pali": "Tassa adāsahaṁ pūvaṁ,"
    },
    {
      "id": "vv29:6.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv29:7.1",
      "pali": "Itissā sassu paribhāsi,"
    },
    {
      "id": "vv29:7.2",
      "pali": "avinītāsi tvaṁ vadhu;"
    },
    {
      "id": "vv29:7.3",
      "pali": "Na maṁ sampucchituṁ icchi,"
    },
    {
      "id": "vv29:7.4",
      "pali": "samaṇassa dadāmahaṁ."
    },
    {
      "id": "vv29:8.1",
      "pali": "Tato me sassu kupitā,"
    },
    {
      "id": "vv29:8.2",
      "pali": "pahāsi musalena maṁ;"
    },
    {
      "id": "vv29:8.3",
      "pali": "Kūṭaṅgacchi avadhi maṁ,"
    },
    {
      "id": "vv29:8.4",
      "pali": "nāsakkhiṁ jīvituṁ ciraṁ."
    },
    {
      "id": "vv29:9.1",
      "pali": "Sā ahaṁ kāyassa bhedā,"
    },
    {
      "id": "vv29:9.2",
      "pali": "vippamuttā tato cutā;"
    },
    {
      "id": "vv29:9.3",
      "pali": "Devānaṁ tāvatiṁsānaṁ,"
    },
    {
      "id": "vv29:9.4",
      "pali": "upapannā sahabyataṁ."
    },
    {
      "id": "vv29:10.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv29:10.2",
      "pali": "…pe…"
    },
    {
      "id": "vv29:10.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv29:11.1",
      "pali": "Uḷāravimānaṁ paṭhamaṁ."
    }
  ]
}
