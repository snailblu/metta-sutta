{
  "uid": "tha-ap213",
  "title": "Hatthidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap213:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap213:1.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap213:1.3",
      "pali": "Nāgaseṭṭho mayā dinno,"
    },
    {
      "id": "tha-ap213:1.4",
      "pali": "īsādanto urūḷhavā."
    },
    {
      "id": "tha-ap213:2.1",
      "pali": "Uttamatthaṁ anubhomi,"
    },
    {
      "id": "tha-ap213:2.2",
      "pali": "santipadamanuttaraṁ;"
    },
    {
      "id": "tha-ap213:2.3",
      "pali": "Nāgadānaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap213:2.4",
      "pali": "sabbalokahitesino."
    },
    {
      "id": "tha-ap213:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap213:3.2",
      "pali": "yaṁ nāga madadiṁ tadā;"
    },
    {
      "id": "tha-ap213:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap213:3.4",
      "pali": "nāgadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap213:4.1",
      "pali": "Aṭṭhasattatikappamhi,"
    },
    {
      "id": "tha-ap213:4.2",
      "pali": "soḷasāsiṁsu khattiyā;"
    },
    {
      "id": "tha-ap213:4.3",
      "pali": "Samantapāsādikā nāma,"
    },
    {
      "id": "tha-ap213:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap213:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap213:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap213:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap213:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap213:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā hatthidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap213:7.1",
      "pali": "Hatthidāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
