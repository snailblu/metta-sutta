{
  "uid": "iti54",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti54:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti54:2.1",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "iti54:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti54:2.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "iti54:2.4",
      "pali": "imā kho, bhikkhave, tisso esanā”ti."
    },
    {
      "id": "iti54:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti54:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti54:3.1",
      "pali": "“Samāhito sampajāno,"
    },
    {
      "id": "iti54:3.2",
      "pali": "sato buddhassa sāvako;"
    },
    {
      "id": "iti54:3.3",
      "pali": "Esanā ca pajānāti,"
    },
    {
      "id": "iti54:3.4",
      "pali": "esanānañca sambhavaṁ."
    },
    {
      "id": "iti54:4.1",
      "pali": "Yattha cetā nirujjhanti,"
    },
    {
      "id": "iti54:4.2",
      "pali": "maggañca khayagāminaṁ;"
    },
    {
      "id": "iti54:4.3",
      "pali": "Esanānaṁ khayā bhikkhu,"
    },
    {
      "id": "iti54:4.4",
      "pali": "nicchāto parinibbuto”ti."
    },
    {
      "id": "iti54:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti54:5.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
