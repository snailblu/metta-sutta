{
  "uid": "ja60",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja60:1.1",
      "pali": "“Dhame dhame nātidhame,"
    },
    {
      "id": "ja60:1.2",
      "pali": "atidhantañhi pāpakaṁ;"
    },
    {
      "id": "ja60:1.3",
      "pali": "Dhantenādhigatā bhogā,"
    },
    {
      "id": "ja60:1.4",
      "pali": "te tāto vidhamī dhaman”ti."
    },
    {
      "id": "ja60:2.1",
      "pali": "Saṅkhadhamajātakaṁ dasamaṁ."
    },
    {
      "id": "ja60:2.2",
      "pali": "Āsīsavaggo chaṭṭho."
    },
    {
      "id": "ja60:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja60:4.1",
      "pali": "Yathā icchiṁ tathāhudakā thalā,"
    },
    {
      "id": "ja60:4.2",
      "pali": "Sura sāduphalo ca alīnamano;"
    },
    {
      "id": "ja60:4.3",
      "pali": "Sampahaṭṭhamano caturo ca tayo,"
    },
    {
      "id": "ja60:4.4",
      "pali": "Sataladdhaka bhogadhanena dasāti."
    }
  ]
}
