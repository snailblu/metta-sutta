{
  "uid": "tha-ap420",
  "title": "Yāgudāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap420:1.1",
      "pali": "“Atithiṁ me gahetvāna,"
    },
    {
      "id": "tha-ap420:1.2",
      "pali": "agacchiṁ gāmakaṁ tadā;"
    },
    {
      "id": "tha-ap420:1.3",
      "pali": "Sampuṇṇanadikaṁ disvā,"
    },
    {
      "id": "tha-ap420:1.4",
      "pali": "saṅghārāmaṁ upāgamiṁ."
    },
    {
      "id": "tha-ap420:2.1",
      "pali": "Āraññakā dhutadharā,"
    },
    {
      "id": "tha-ap420:2.2",
      "pali": "jhāyino lūkhacīvarā;"
    },
    {
      "id": "tha-ap420:2.3",
      "pali": "Vivekābhiratā dhīrā,"
    },
    {
      "id": "tha-ap420:2.4",
      "pali": "saṅghārāme vasanti te."
    },
    {
      "id": "tha-ap420:3.1",
      "pali": "Gati tesaṁ upacchinnā,"
    },
    {
      "id": "tha-ap420:3.2",
      "pali": "suvimuttāna tādinaṁ;"
    },
    {
      "id": "tha-ap420:3.3",
      "pali": "Piṇḍāya te na gacchanti,"
    },
    {
      "id": "tha-ap420:3.4",
      "pali": "oruddhanaditāya hi."
    },
    {
      "id": "tha-ap420:4.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap420:4.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap420:4.3",
      "pali": "Taṇḍulaṁ me gahetvāna,"
    },
    {
      "id": "tha-ap420:4.4",
      "pali": "yāgudānaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap420:5.1",
      "pali": "Pañcannaṁ yāguṁ datvāna,"
    },
    {
      "id": "tha-ap420:5.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap420:5.3",
      "pali": "Sakakammābhiraddhohaṁ,"
    },
    {
      "id": "tha-ap420:5.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap420:6.1",
      "pali": "Maṇimayañca me byamhaṁ,"
    },
    {
      "id": "tha-ap420:6.2",
      "pali": "nibbatti tidase gaṇe;"
    },
    {
      "id": "tha-ap420:6.3",
      "pali": "Nārīgaṇehi sahito,"
    },
    {
      "id": "tha-ap420:6.4",
      "pali": "modāmi byamhamuttame."
    },
    {
      "id": "tha-ap420:7.1",
      "pali": "Tettiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap420:7.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap420:7.3",
      "pali": "Tiṁsakkhattuṁ cakkavattī,"
    },
    {
      "id": "tha-ap420:7.4",
      "pali": "mahārajjamakārayiṁ."
    },
    {
      "id": "tha-ap420:8.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap420:8.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap420:8.3",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap420:8.4",
      "pali": "anubhotvā sayaṁ ahaṁ."
    },
    {
      "id": "tha-ap420:9.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap420:9.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap420:9.3",
      "pali": "Saha oropite kese,"
    },
    {
      "id": "tha-ap420:9.4",
      "pali": "sabbaṁ sampaṭivijjhahaṁ."
    },
    {
      "id": "tha-ap420:10.1",
      "pali": "Khayato vayato cāpi,"
    },
    {
      "id": "tha-ap420:10.2",
      "pali": "sammasanto kaḷevaraṁ;"
    },
    {
      "id": "tha-ap420:10.3",
      "pali": "Pure sikkhāpadādānā,"
    },
    {
      "id": "tha-ap420:10.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap420:11.1",
      "pali": "Sudinnaṁ me dānavaraṁ,"
    },
    {
      "id": "tha-ap420:11.2",
      "pali": "vāṇijjaṁ sampayojitaṁ;"
    },
    {
      "id": "tha-ap420:11.3",
      "pali": "Teneva yāgudānena,"
    },
    {
      "id": "tha-ap420:11.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap420:12.1",
      "pali": "Sokaṁ pariddavaṁ byādhiṁ,"
    },
    {
      "id": "tha-ap420:12.2",
      "pali": "darathaṁ cittatāpanaṁ;"
    },
    {
      "id": "tha-ap420:12.3",
      "pali": "Nābhijānāmi uppannaṁ,"
    },
    {
      "id": "tha-ap420:12.4",
      "pali": "yāgudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap420:13.1",
      "pali": "Yāguṁ saṅghassa datvāna,"
    },
    {
      "id": "tha-ap420:13.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "tha-ap420:13.3",
      "pali": "Pañcānisaṁse anubhomi,"
    },
    {
      "id": "tha-ap420:13.4",
      "pali": "aho yāgusuyiṭṭhatā."
    },
    {
      "id": "tha-ap420:14.1",
      "pali": "Abyādhitā rūpavatā,"
    },
    {
      "id": "tha-ap420:14.2",
      "pali": "khippaṁ dhammanisantitā;"
    },
    {
      "id": "tha-ap420:14.3",
      "pali": "Lābhitā annapānassa,"
    },
    {
      "id": "tha-ap420:14.4",
      "pali": "āyu pañcamakaṁ mama."
    },
    {
      "id": "tha-ap420:15.1",
      "pali": "Yo koci vedaṁ janayaṁ,"
    },
    {
      "id": "tha-ap420:15.2",
      "pali": "saṅghe yāguṁ dadeyya so;"
    },
    {
      "id": "tha-ap420:15.3",
      "pali": "Imāni pañca ṭhānāni,"
    },
    {
      "id": "tha-ap420:15.4",
      "pali": "paṭigaṇheyya paṇḍito."
    },
    {
      "id": "tha-ap420:16.1",
      "pali": "Karaṇīyaṁ kataṁ sabbaṁ,"
    },
    {
      "id": "tha-ap420:16.2",
      "pali": "bhavā ugghāṭitā mayā;"
    },
    {
      "id": "tha-ap420:16.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap420:16.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap420:17.1",
      "pali": "So ahaṁ vicarissāmi,"
    },
    {
      "id": "tha-ap420:17.2",
      "pali": "gāmā gāmaṁ purā puraṁ;"
    },
    {
      "id": "tha-ap420:17.3",
      "pali": "Namassamāno sambuddhaṁ,"
    },
    {
      "id": "tha-ap420:17.4",
      "pali": "dhammassa ca sudhammataṁ."
    },
    {
      "id": "tha-ap420:18.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap420:18.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap420:18.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap420:18.4",
      "pali": "yāgudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap420:19.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap420:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap420:19.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap420:20.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap420:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap420:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap420:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap420:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap420:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap420:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā yāgudāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap420:23.1",
      "pali": "Yāgudāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
