{
  "uid": "thag1.112",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.112:1.1",
      "pali": "“Tevijjohaṁ mahājhāyī,"
    },
    {
      "id": "thag1.112:1.2",
      "pali": "cetosamathakovido;"
    },
    {
      "id": "thag1.112:1.3",
      "pali": "Sadattho me anuppatto,"
    },
    {
      "id": "thag1.112:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.112:1.5",
      "pali": "… Vacchagotto thero …."
    }
  ]
}
