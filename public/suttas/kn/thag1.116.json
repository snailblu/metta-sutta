{
  "uid": "thag1.116",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.116:1.1",
      "pali": "“Chaphassāyatane hitvā,"
    },
    {
      "id": "thag1.116:1.2",
      "pali": "guttadvāro susaṁvuto;"
    },
    {
      "id": "thag1.116:1.3",
      "pali": "Aghamūlaṁ vamitvāna,"
    },
    {
      "id": "thag1.116:1.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag1.116:1.5",
      "pali": "… Pārāpariyo thero …."
    }
  ]
}
