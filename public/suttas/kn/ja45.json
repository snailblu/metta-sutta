{
  "uid": "ja45",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja45:1.1",
      "pali": "“Seyyo amitto medhāvī,"
    },
    {
      "id": "ja45:1.2",
      "pali": "Yañce bālānukampako;"
    },
    {
      "id": "ja45:1.3",
      "pali": "Passa rohiṇikaṁ jammiṁ,"
    },
    {
      "id": "ja45:1.4",
      "pali": "Mātaraṁ hantvāna socatī”ti."
    },
    {
      "id": "ja45:2.1",
      "pali": "Rohiṇijātakaṁ pañcamaṁ."
    }
  ]
}
