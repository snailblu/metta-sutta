{
  "uid": "thag6.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.3:1.1",
      "pali": "“Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:1.2",
      "pali": "gāravo nūpalabbhati;"
    },
    {
      "id": "thag6.3:1.3",
      "pali": "Parihāyati saddhammā,"
    },
    {
      "id": "thag6.3:1.4",
      "pali": "maccho appodake yathā."
    },
    {
      "id": "thag6.3:2.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:2.2",
      "pali": "gāravo nūpalabbhati;"
    },
    {
      "id": "thag6.3:2.3",
      "pali": "Na virūhati saddhamme,"
    },
    {
      "id": "thag6.3:2.4",
      "pali": "khette bījaṁva pūtikaṁ."
    },
    {
      "id": "thag6.3:3.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:3.2",
      "pali": "gāravo nūpalabbhati;"
    },
    {
      "id": "thag6.3:3.3",
      "pali": "Ārakā hoti nibbānā,"
    },
    {
      "id": "thag6.3:3.4",
      "pali": "dhammarājassa sāsane."
    },
    {
      "id": "thag6.3:4.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:4.2",
      "pali": "gāravo upalabbhati;"
    },
    {
      "id": "thag6.3:4.3",
      "pali": "Na vihāyati saddhammā,"
    },
    {
      "id": "thag6.3:4.4",
      "pali": "maccho bavhodake yathā."
    },
    {
      "id": "thag6.3:5.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:5.2",
      "pali": "gāravo upalabbhati;"
    },
    {
      "id": "thag6.3:5.3",
      "pali": "So virūhati saddhamme,"
    },
    {
      "id": "thag6.3:5.4",
      "pali": "khette bījaṁva bhaddakaṁ."
    },
    {
      "id": "thag6.3:6.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag6.3:6.2",
      "pali": "gāravo upalabbhati;"
    },
    {
      "id": "thag6.3:6.3",
      "pali": "Santike hoti nibbānaṁ,"
    },
    {
      "id": "thag6.3:6.4",
      "pali": "dhammarājassa sāsane”ti."
    },
    {
      "id": "thag6.3:6.5",
      "pali": "… Mahānāgo thero …."
    }
  ]
}
