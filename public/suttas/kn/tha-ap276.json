{
  "uid": "tha-ap276",
  "title": "Abbhañjanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap276:1.1",
      "pali": "“Koṇḍaññassa bhagavato,"
    },
    {
      "id": "tha-ap276:1.2",
      "pali": "vītarāgassa tādino;"
    },
    {
      "id": "tha-ap276:1.3",
      "pali": "Ākāsasamacittassa,"
    },
    {
      "id": "tha-ap276:1.4",
      "pali": "nippapañcassa jhāyino."
    },
    {
      "id": "tha-ap276:2.1",
      "pali": "Sabbamohātivattassa,"
    },
    {
      "id": "tha-ap276:2.2",
      "pali": "sabbalokahitesino;"
    },
    {
      "id": "tha-ap276:2.3",
      "pali": "Abbhañjanaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap276:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap276:3.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap276:3.2",
      "pali": "abbhañjanamadaṁ tadā;"
    },
    {
      "id": "tha-ap276:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap276:3.4",
      "pali": "abbhañjanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap276:4.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap276:4.2",
      "pali": "cirappo nāma khattiyo;"
    },
    {
      "id": "tha-ap276:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap276:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap276:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap276:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap276:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap276:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā abbhañjanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap276:7.1",
      "pali": "Abbhañjanadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
