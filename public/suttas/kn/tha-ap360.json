{
  "uid": "tha-ap360",
  "title": "8 Mañcadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap360:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap360:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap360:1.3",
      "pali": "Ekaṁ mañcaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap360:1.4",
      "pali": "pasannena sapāṇinā."
    },
    {
      "id": "tha-ap360:2.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap360:2.2",
      "pali": "dibbayānaṁ samajjhagaṁ;"
    },
    {
      "id": "tha-ap360:2.3",
      "pali": "Tena mañcakadānena,"
    },
    {
      "id": "tha-ap360:2.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap360:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap360:3.2",
      "pali": "yaṁ mañcamadadiṁ tadā;"
    },
    {
      "id": "tha-ap360:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap360:3.4",
      "pali": "mañcadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap360:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap360:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap360:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap360:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā mañcadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap360:6.1",
      "pali": "Mañcadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
