{
  "uid": "ja459",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja459:1.1",
      "pali": "“Mitto mittassa pānīyaṁ,"
    },
    {
      "id": "ja459:1.2",
      "pali": "adinnaṁ paribhuñjisaṁ;"
    },
    {
      "id": "ja459:1.3",
      "pali": "Tena pacchā vijigucchiṁ,"
    },
    {
      "id": "ja459:1.4",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja459:1.5",
      "pali": "Mā puna akaraṁ pāpaṁ,"
    },
    {
      "id": "ja459:1.6",
      "pali": "tasmā pabbajito ahaṁ."
    },
    {
      "id": "ja459:2.1",
      "pali": "Paradārañca disvāna,"
    },
    {
      "id": "ja459:2.2",
      "pali": "chando me udapajjatha;"
    },
    {
      "id": "ja459:2.3",
      "pali": "Tena pacchā vijigucchiṁ,"
    },
    {
      "id": "ja459:2.4",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja459:2.5",
      "pali": "Mā puna akaraṁ pāpaṁ,"
    },
    {
      "id": "ja459:2.6",
      "pali": "tasmā pabbajito ahaṁ."
    },
    {
      "id": "ja459:3.1",
      "pali": "Pitaraṁ me mahārāja,"
    },
    {
      "id": "ja459:3.2",
      "pali": "corā agaṇhu kānane;"
    },
    {
      "id": "ja459:3.3",
      "pali": "Tesāhaṁ pucchito jānaṁ,"
    },
    {
      "id": "ja459:3.4",
      "pali": "aññathā naṁ viyākariṁ."
    },
    {
      "id": "ja459:4.1",
      "pali": "Tena pacchā vijigucchiṁ,"
    },
    {
      "id": "ja459:4.2",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja459:4.3",
      "pali": "Mā puna akaraṁ pāpaṁ,"
    },
    {
      "id": "ja459:4.4",
      "pali": "tasmā pabbajito ahaṁ."
    },
    {
      "id": "ja459:5.1",
      "pali": "Pāṇātipātamakaruṁ,"
    },
    {
      "id": "ja459:5.2",
      "pali": "somayāge upaṭṭhite;"
    },
    {
      "id": "ja459:5.3",
      "pali": "Tesāhaṁ samanuññāsiṁ."
    },
    {
      "id": "ja459:6.1",
      "pali": "Tena pacchā vijigucchiṁ,"
    },
    {
      "id": "ja459:6.2",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja459:6.3",
      "pali": "Mā puna akaraṁ pāpaṁ,"
    },
    {
      "id": "ja459:6.4",
      "pali": "tasmā pabbajito ahaṁ."
    },
    {
      "id": "ja459:7.1",
      "pali": "Surāmerayamādhukā,"
    },
    {
      "id": "ja459:7.2",
      "pali": "ye janā paṭhamāsu no;"
    },
    {
      "id": "ja459:7.3",
      "pali": "Bahūnaṁ te anatthāya,"
    },
    {
      "id": "ja459:7.4",
      "pali": "majjapānamakappayuṁ;"
    },
    {
      "id": "ja459:7.5",
      "pali": "Tesāhaṁ samanuññāsiṁ."
    },
    {
      "id": "ja459:8.1",
      "pali": "Tena pacchā vijigucchiṁ,"
    },
    {
      "id": "ja459:8.2",
      "pali": "taṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja459:8.3",
      "pali": "Mā puna akaraṁ pāpaṁ,"
    },
    {
      "id": "ja459:8.4",
      "pali": "tasmā pabbajito ahaṁ”."
    },
    {
      "id": "ja459:9.1",
      "pali": "“Dhiratthu subahū kāme,"
    },
    {
      "id": "ja459:9.2",
      "pali": "duggandhe bahukaṇṭake;"
    },
    {
      "id": "ja459:9.3",
      "pali": "Ye ahaṁ paṭisevanto,"
    },
    {
      "id": "ja459:9.4",
      "pali": "nālabhiṁ tādisaṁ sukhaṁ”."
    },
    {
      "id": "ja459:10.1",
      "pali": "“Mahassādā sukhā kāmā,"
    },
    {
      "id": "ja459:10.2",
      "pali": "Natthi kāmā paraṁ sukhaṁ;"
    },
    {
      "id": "ja459:10.3",
      "pali": "Ye kāme paṭisevanti,"
    },
    {
      "id": "ja459:10.4",
      "pali": "Saggaṁ te upapajjare”."
    },
    {
      "id": "ja459:11.1",
      "pali": "“Appassādā dukhā kāmā,"
    },
    {
      "id": "ja459:11.2",
      "pali": "natthi kāmā paraṁ dukhaṁ;"
    },
    {
      "id": "ja459:11.3",
      "pali": "Ye kāme paṭisevanti,"
    },
    {
      "id": "ja459:11.4",
      "pali": "nirayaṁ te upapajjare."
    },
    {
      "id": "ja459:12.1",
      "pali": "Asī yathā sunisito,"
    },
    {
      "id": "ja459:12.2",
      "pali": "nettiṁsova supāyiko;"
    },
    {
      "id": "ja459:12.3",
      "pali": "Sattīva urasi khittā,"
    },
    {
      "id": "ja459:12.4",
      "pali": "kāmā dukkhatarā tato."
    },
    {
      "id": "ja459:13.1",
      "pali": "Aṅgārānaṁva jalitaṁ,"
    },
    {
      "id": "ja459:13.2",
      "pali": "kāsuṁ sādhikaporisaṁ;"
    },
    {
      "id": "ja459:13.3",
      "pali": "Phālaṁva divasantattaṁ,"
    },
    {
      "id": "ja459:13.4",
      "pali": "kāmā dukkhatarā tato."
    },
    {
      "id": "ja459:14.1",
      "pali": "Visaṁ yathā halāhalaṁ,"
    },
    {
      "id": "ja459:14.2",
      "pali": "telaṁ pakkuthitaṁ yathā;"
    },
    {
      "id": "ja459:14.3",
      "pali": "Tambaloha vilīnaṁva,"
    },
    {
      "id": "ja459:14.4",
      "pali": "kāmā dukkhatarā tato”ti."
    },
    {
      "id": "ja459:15.1",
      "pali": "Pānīyajātakaṁ pañcamaṁ."
    }
  ]
}
