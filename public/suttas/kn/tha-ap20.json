{
  "uid": "tha-ap20",
  "title": "Raṭṭhapālattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap20:1.1",
      "pali": "“Padumuttarassa bhagavato,"
    },
    {
      "id": "tha-ap20:1.2",
      "pali": "Lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap20:1.3",
      "pali": "Varanāgo mayā dinno,"
    },
    {
      "id": "tha-ap20:1.4",
      "pali": "Īsādanto urūḷhavā."
    },
    {
      "id": "tha-ap20:2.1",
      "pali": "Setacchatto pasobhito,"
    },
    {
      "id": "tha-ap20:2.2",
      "pali": "sakappano sahatthipo;"
    },
    {
      "id": "tha-ap20:2.3",
      "pali": "Agghāpetvāna taṁ sabbaṁ,"
    },
    {
      "id": "tha-ap20:2.4",
      "pali": "saṅghārāmaṁ akārayiṁ."
    },
    {
      "id": "tha-ap20:3.1",
      "pali": "Catupaññāsasahassāni,"
    },
    {
      "id": "tha-ap20:3.2",
      "pali": "pāsāde kārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap20:3.3",
      "pali": "Mahoghadānaṁ karitvāna,"
    },
    {
      "id": "tha-ap20:3.4",
      "pali": "niyyādesiṁ mahesino."
    },
    {
      "id": "tha-ap20:4.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap20:4.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap20:4.3",
      "pali": "Sabbe jane hāsayanto,"
    },
    {
      "id": "tha-ap20:4.4",
      "pali": "desesi amataṁ padaṁ."
    },
    {
      "id": "tha-ap20:5.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "tha-ap20:5.2",
      "pali": "jalajuttaranāmako;"
    },
    {
      "id": "tha-ap20:5.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap20:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap20:6.1",
      "pali": "‘Catupaññāsasahassāni,"
    },
    {
      "id": "tha-ap20:6.2",
      "pali": "pāsāde kārayī ayaṁ;"
    },
    {
      "id": "tha-ap20:6.3",
      "pali": "Kathayissāmi vipākaṁ,"
    },
    {
      "id": "tha-ap20:6.4",
      "pali": "suṇotha mama bhāsato."
    },
    {
      "id": "tha-ap20:7.1",
      "pali": "Aṭṭhārasasahassāni,"
    },
    {
      "id": "tha-ap20:7.2",
      "pali": "kūṭāgārā bhavissare;"
    },
    {
      "id": "tha-ap20:7.3",
      "pali": "Byamhuttamamhi nibbattā,"
    },
    {
      "id": "tha-ap20:7.4",
      "pali": "sabbasoṇṇamayā ca te."
    },
    {
      "id": "tha-ap20:8.1",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap20:8.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap20:8.3",
      "pali": "Aṭṭhapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap20:8.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap20:9.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap20:9.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap20:9.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap20:9.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap20:10.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap20:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap20:10.3",
      "pali": "Aḍḍhe kule mahābhoge,"
    },
    {
      "id": "tha-ap20:10.4",
      "pali": "nibbattissati tāvade."
    },
    {
      "id": "tha-ap20:11.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap20:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap20:11.3",
      "pali": "Raṭṭhapāloti nāmena,"
    },
    {
      "id": "tha-ap20:11.4",
      "pali": "hessati satthu sāvako."
    },
    {
      "id": "tha-ap20:12.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap20:12.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap20:12.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap20:12.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap20:13.1",
      "pali": "Uṭṭhāya abhinikkhamma,"
    },
    {
      "id": "tha-ap20:13.2",
      "pali": "jahitā bhogasampadā;"
    },
    {
      "id": "tha-ap20:13.3",
      "pali": "Kheḷapiṇḍeva bhogamhi,"
    },
    {
      "id": "tha-ap20:13.4",
      "pali": "pemaṁ mayhaṁ na vijjati."
    },
    {
      "id": "tha-ap20:14.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "tha-ap20:14.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "tha-ap20:14.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap20:14.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap20:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap20:15.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap20:15.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap20:15.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap20:16.1",
      "pali": "Itthaṁ sudaṁ āyasmā raṭṭhapālo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap20:17.1",
      "pali": "Raṭṭhapālattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
