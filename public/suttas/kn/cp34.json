{
  "uid": "cp34",
  "title": "Mettāpāramī 2",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp34:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp34:1.2",
      "pali": "ekarājāti vissuto;"
    },
    {
      "id": "cp34:1.3",
      "pali": "Paramaṁ sīlaṁ adhiṭṭhāya,"
    },
    {
      "id": "cp34:1.4",
      "pali": "pasāsāmi mahāmahiṁ."
    },
    {
      "id": "cp34:2.1",
      "pali": "Dasa kusalakammapathe,"
    },
    {
      "id": "cp34:2.2",
      "pali": "vattāmi anavasesato;"
    },
    {
      "id": "cp34:2.3",
      "pali": "Catūhi saṅgahavatthūhi,"
    },
    {
      "id": "cp34:2.4",
      "pali": "saṅgaṇhāmi mahājanaṁ."
    },
    {
      "id": "cp34:3.1",
      "pali": "Evaṁ me appamattassa,"
    },
    {
      "id": "cp34:3.2",
      "pali": "idha loke parattha ca;"
    },
    {
      "id": "cp34:3.3",
      "pali": "Dabbaseno upagantvā,"
    },
    {
      "id": "cp34:3.4",
      "pali": "acchindanto puraṁ mama."
    },
    {
      "id": "cp34:4.1",
      "pali": "Rājūpajīve nigame,"
    },
    {
      "id": "cp34:4.2",
      "pali": "sabalaṭṭhe saraṭṭhake;"
    },
    {
      "id": "cp34:4.3",
      "pali": "Sabbaṁ hatthagataṁ katvā,"
    },
    {
      "id": "cp34:4.4",
      "pali": "kāsuyā nikhaṇī mamaṁ."
    },
    {
      "id": "cp34:5.1",
      "pali": "Amaccamaṇḍalaṁ rajjaṁ,"
    },
    {
      "id": "cp34:5.2",
      "pali": "phītaṁ antepuraṁ mama;"
    },
    {
      "id": "cp34:5.3",
      "pali": "Acchinditvāna gahitaṁ,"
    },
    {
      "id": "cp34:5.4",
      "pali": "piyaṁ puttaṁva passahaṁ;"
    },
    {
      "id": "cp34:5.5",
      "pali": "Mettāya me samo natthi,"
    },
    {
      "id": "cp34:5.6",
      "pali": "esā me mettāpāramī”ti."
    },
    {
      "id": "cp34:6.1",
      "pali": "Ekarājacariyaṁ cuddasamaṁ."
    }
  ]
}
