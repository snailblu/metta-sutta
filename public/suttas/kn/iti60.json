{
  "uid": "iti60",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti60:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti60:2.1",
      "pali": "“Tīṇimāni, bhikkhave, puññakiriyavatthūni."
    },
    {
      "id": "iti60:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti60:2.3",
      "pali": "Dānamayaṁ puññakiriyavatthu, sīlamayaṁ puññakiriyavatthu, bhāvanāmayaṁ puññakiriyavatthu—"
    },
    {
      "id": "iti60:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi puññakiriyavatthūnī”ti."
    },
    {
      "id": "iti60:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti60:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti60:3.1",
      "pali": "“Puññameva so sikkheyya,"
    },
    {
      "id": "iti60:3.2",
      "pali": "āyataggaṁ sukhudrayaṁ;"
    },
    {
      "id": "iti60:3.3",
      "pali": "Dānañca samacariyañca,"
    },
    {
      "id": "iti60:3.4",
      "pali": "mettacittañca bhāvaye."
    },
    {
      "id": "iti60:4.1",
      "pali": "Ete dhamme bhāvayitvā,"
    },
    {
      "id": "iti60:4.2",
      "pali": "tayo sukhasamuddaye;"
    },
    {
      "id": "iti60:4.3",
      "pali": "Abyābajjhaṁ sukhaṁ lokaṁ,"
    },
    {
      "id": "iti60:4.4",
      "pali": "paṇḍito upapajjatī”ti."
    },
    {
      "id": "iti60:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti60:5.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
