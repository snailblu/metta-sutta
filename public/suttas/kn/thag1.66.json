{
  "uid": "thag1.66",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.66:1.1",
      "pali": "“Anusāsi mahāvīro,"
    },
    {
      "id": "thag1.66:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thag1.66:1.3",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "thag1.66:1.4",
      "pali": "vihāsiṁ santike sato;"
    },
    {
      "id": "thag1.66:1.5",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag1.66:1.6",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.66:1.7",
      "pali": "… Meghiyo thero …."
    }
  ]
}
