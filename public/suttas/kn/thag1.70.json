{
  "uid": "thag1.70",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.70:1.1",
      "pali": "“Sīlameva idha aggaṁ,"
    },
    {
      "id": "thag1.70:1.2",
      "pali": "paññavā pana uttamo;"
    },
    {
      "id": "thag1.70:1.3",
      "pali": "Manussesu ca devesu,"
    },
    {
      "id": "thag1.70:1.4",
      "pali": "sīlapaññāṇato jayan”ti."
    },
    {
      "id": "thag1.70:1.5",
      "pali": "… Puṇṇo thero …"
    },
    {
      "id": "thag1.70:1.6",
      "pali": "vaggo sattamo."
    },
    {
      "id": "thag1.70:2.1",
      "pali": "Vappo ca vajjiputto ca,"
    },
    {
      "id": "thag1.70:2.2",
      "pali": "pakkho vimalakoṇḍañño;"
    },
    {
      "id": "thag1.70:2.3",
      "pali": "Ukkhepakatavaccho ca,"
    },
    {
      "id": "thag1.70:2.4",
      "pali": "meghiyo ekadhammiko;"
    },
    {
      "id": "thag1.70:2.5",
      "pali": "Ekudāniyachannā ca,"
    },
    {
      "id": "thag1.70:2.6",
      "pali": "puṇṇatthero mahabbaloti."
    }
  ]
}
