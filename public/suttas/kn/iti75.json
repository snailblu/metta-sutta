{
  "uid": "iti75",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti75:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti75:2.1",
      "pali": "“Tayome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "iti75:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti75:2.3",
      "pali": "Avuṭṭhikasamo, padesavassī, sabbatthābhivassī."
    },
    {
      "id": "iti75:3.1",
      "pali": "Kathañca, bhikkhave, puggalo avuṭṭhikasamo hoti?"
    },
    {
      "id": "iti75:3.2",
      "pali": "Idha, bhikkhave, ekacco puggalo sabbesaññeva na dātā hoti, samaṇabrāhmaṇakapaṇaddhikavanibbakayācakānaṁ annaṁ pānaṁ vatthaṁ yānaṁ mālāgandhavilepanaṁ seyyāvasathapadīpeyyaṁ."
    },
    {
      "id": "iti75:3.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo avuṭṭhikasamo hoti."
    },
    {
      "id": "iti75:4.1",
      "pali": "Kathañca, bhikkhave, puggalo padesavassī hoti?"
    },
    {
      "id": "iti75:4.2",
      "pali": "Idha, bhikkhave, ekacco puggalo ekaccānaṁ dātā hoti, ekaccānaṁ na dātā hoti samaṇabrāhmaṇakapaṇaddhikavanibbakayācakānaṁ annaṁ pānaṁ vatthaṁ yānaṁ mālāgandhavilepanaṁ seyyāvasathapadīpeyyaṁ."
    },
    {
      "id": "iti75:4.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo padesavassī hoti."
    },
    {
      "id": "iti75:5.1",
      "pali": "Kathañca, bhikkhave, puggalo sabbatthābhivassī hoti?"
    },
    {
      "id": "iti75:5.2",
      "pali": "Idha, bhikkhave, ekacco puggalo sabbesaṁva deti, samaṇabrāhmaṇakapaṇaddhikavanibbakayācakānaṁ annaṁ pānaṁ vatthaṁ yānaṁ mālāgandhavilepanaṁ seyyāvasathapadīpeyyaṁ."
    },
    {
      "id": "iti75:5.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo sabbatthābhivassī hoti."
    },
    {
      "id": "iti75:5.4",
      "pali": "Ime kho, bhikkhave, tayo puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "iti75:5.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti75:5.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti75:6.1",
      "pali": "“Na samaṇe na brāhmaṇe,"
    },
    {
      "id": "iti75:6.2",
      "pali": "Na kapaṇaddhikavanibbake;"
    },
    {
      "id": "iti75:6.3",
      "pali": "Laddhāna saṁvibhājeti,"
    },
    {
      "id": "iti75:6.4",
      "pali": "Annaṁ pānañca bhojanaṁ;"
    },
    {
      "id": "iti75:6.5",
      "pali": "Taṁ ve avuṭṭhikasamoti,"
    },
    {
      "id": "iti75:6.6",
      "pali": "Āhu naṁ purisādhamaṁ."
    },
    {
      "id": "iti75:7.1",
      "pali": "Ekaccānaṁ na dadāti,"
    },
    {
      "id": "iti75:7.2",
      "pali": "ekaccānaṁ pavecchati;"
    },
    {
      "id": "iti75:7.3",
      "pali": "Taṁ ve padesavassīti,"
    },
    {
      "id": "iti75:7.4",
      "pali": "āhu medhāvino janā."
    },
    {
      "id": "iti75:8.1",
      "pali": "Subhikkhavāco puriso,"
    },
    {
      "id": "iti75:8.2",
      "pali": "sabbabhūtānukampako;"
    },
    {
      "id": "iti75:8.3",
      "pali": "Āmodamāno pakireti,"
    },
    {
      "id": "iti75:8.4",
      "pali": "detha dethāti bhāsati."
    },
    {
      "id": "iti75:9.1",
      "pali": "Yathāpi megho thanayitvā,"
    },
    {
      "id": "iti75:9.2",
      "pali": "gajjayitvā pavassati;"
    },
    {
      "id": "iti75:9.3",
      "pali": "Thalaṁ ninnañca pūreti,"
    },
    {
      "id": "iti75:9.4",
      "pali": "abhisandantova vārinā."
    },
    {
      "id": "iti75:10.1",
      "pali": "Evamevaṁ idhekacco,"
    },
    {
      "id": "iti75:10.2",
      "pali": "puggalo hoti tādiso;"
    },
    {
      "id": "iti75:10.3",
      "pali": "Dhammena saṁharitvāna,"
    },
    {
      "id": "iti75:10.4",
      "pali": "uṭṭhānādhigataṁ dhanaṁ;"
    },
    {
      "id": "iti75:10.5",
      "pali": "Tappeti annapānena,"
    },
    {
      "id": "iti75:10.6",
      "pali": "sammā patte vanibbake”ti."
    },
    {
      "id": "iti75:11.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti75:11.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
