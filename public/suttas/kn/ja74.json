{
  "uid": "ja74",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja74:1.1",
      "pali": "“Sādhū sambahulā ñātī,"
    },
    {
      "id": "ja74:1.2",
      "pali": "api rukkhā araññajā;"
    },
    {
      "id": "ja74:1.3",
      "pali": "Vāto vahati ekaṭṭhaṁ,"
    },
    {
      "id": "ja74:1.4",
      "pali": "brahantampi vanappatin”ti."
    },
    {
      "id": "ja74:2.1",
      "pali": "Rukkhadhammajātakaṁ catutthaṁ."
    }
  ]
}
