{
  "uid": "tha-ap377",
  "title": "Sattapaṇṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap377:1.1",
      "pali": "“Sumano nāma sambuddho,"
    },
    {
      "id": "tha-ap377:1.2",
      "pali": "uppajji lokanāyako;"
    },
    {
      "id": "tha-ap377:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap377:1.4",
      "pali": "sattapaṇṇimapūjayiṁ."
    },
    {
      "id": "tha-ap377:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap377:2.2",
      "pali": "Sattapaṇṇimapūjayiṁ;"
    },
    {
      "id": "tha-ap377:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap377:2.4",
      "pali": "Sattapaṇṇipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap377:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap377:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap377:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap377:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap377:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap377:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap377:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap377:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap377:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap377:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattapaṇṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap377:7.1",
      "pali": "Sattapaṇṇiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
