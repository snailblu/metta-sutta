{
  "uid": "thag5.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.9:1.1",
      "pali": "“Olaggessāmi te citta,"
    },
    {
      "id": "thag5.9:1.2",
      "pali": "āṇidvāreva hatthinaṁ;"
    },
    {
      "id": "thag5.9:1.3",
      "pali": "Na taṁ pāpe niyojessaṁ,"
    },
    {
      "id": "thag5.9:1.4",
      "pali": "kāmajāla sarīraja."
    },
    {
      "id": "thag5.9:2.1",
      "pali": "Tvaṁ olaggo na gacchasi,"
    },
    {
      "id": "thag5.9:2.2",
      "pali": "Dvāravivaraṁ gajova alabhanto;"
    },
    {
      "id": "thag5.9:2.3",
      "pali": "Na ca cittakali punappunaṁ,"
    },
    {
      "id": "thag5.9:2.4",
      "pali": "Pasakka pāparato carissasi."
    },
    {
      "id": "thag5.9:3.1",
      "pali": "Yathā kuñjaraṁ adantaṁ,"
    },
    {
      "id": "thag5.9:3.2",
      "pali": "Navaggahamaṅkusaggaho;"
    },
    {
      "id": "thag5.9:3.3",
      "pali": "Balavā āvatteti akāmaṁ,"
    },
    {
      "id": "thag5.9:3.4",
      "pali": "Evaṁ āvattayissaṁ taṁ."
    },
    {
      "id": "thag5.9:4.1",
      "pali": "Yathā varahayadamakusalo,"
    },
    {
      "id": "thag5.9:4.2",
      "pali": "Sārathi pavaro dameti ājaññaṁ;"
    },
    {
      "id": "thag5.9:4.3",
      "pali": "Evaṁ damayissaṁ taṁ,"
    },
    {
      "id": "thag5.9:4.4",
      "pali": "Patiṭṭhito pañcasu balesu."
    },
    {
      "id": "thag5.9:5.1",
      "pali": "Satiyā taṁ nibandhissaṁ,"
    },
    {
      "id": "thag5.9:5.2",
      "pali": "Payutto te damessāmi;"
    },
    {
      "id": "thag5.9:5.3",
      "pali": "Vīriyadhuraniggahito,"
    },
    {
      "id": "thag5.9:5.4",
      "pali": "Na yito dūraṁ gamissase cittā”ti."
    },
    {
      "id": "thag5.9:5.5",
      "pali": "… Vijitaseno thero …."
    }
  ]
}
