{
  "uid": "tha-ap247",
  "title": "Kuṭidhūpakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap247:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap247:1.2",
      "pali": "ahosiṁ kuṭigopako;"
    },
    {
      "id": "tha-ap247:1.3",
      "pali": "Kālena kālaṁ dhūpesiṁ,"
    },
    {
      "id": "tha-ap247:1.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap247:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap247:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap247:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap247:2.4",
      "pali": "dhūpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap247:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap247:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap247:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap247:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā kuṭidhūpako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap247:5.1",
      "pali": "Kuṭidhūpakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
