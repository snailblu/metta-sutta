{
  "uid": "thag1.55",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.55:1.1",
      "pali": "“Āsandiṁ kuṭikaṁ katvā,"
    },
    {
      "id": "thag1.55:1.2",
      "pali": "ogayha añjanaṁ vanaṁ;"
    },
    {
      "id": "thag1.55:1.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag1.55:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.55:1.5",
      "pali": "… Añjanavaniyo thero …."
    }
  ]
}
