{
  "uid": "ja528",
  "title": "Niḷinikāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja528:1.1",
      "pali": "“Kiṁ nu daṇḍaṁ kimajinaṁ,"
    },
    {
      "id": "ja528:1.2",
      "pali": "kiṁ chattaṁ kimupāhanaṁ;"
    },
    {
      "id": "ja528:1.3",
      "pali": "Kimaṅkusañca pattañca,"
    },
    {
      "id": "ja528:1.4",
      "pali": "saṅghāṭiñcāpi brāhmaṇa;"
    },
    {
      "id": "ja528:1.5",
      "pali": "Taramānarūpohāsi,"
    },
    {
      "id": "ja528:1.6",
      "pali": "kiṁ nu patthayase disaṁ”."
    },
    {
      "id": "ja528:2.1",
      "pali": "“Dvādasetāni vassāni,"
    },
    {
      "id": "ja528:2.2",
      "pali": "vusitāni tavantike;"
    },
    {
      "id": "ja528:2.3",
      "pali": "Nābhijānāmi soṇena,"
    },
    {
      "id": "ja528:2.4",
      "pali": "piṅgalenābhikūjitaṁ."
    },
    {
      "id": "ja528:3.1",
      "pali": "Svāyaṁ dittova nadati,"
    },
    {
      "id": "ja528:3.2",
      "pali": "sukkadāṭhaṁ vidaṁsayaṁ;"
    },
    {
      "id": "ja528:3.3",
      "pali": "Tava sutvā sabhariyassa,"
    },
    {
      "id": "ja528:3.4",
      "pali": "vītasaddhassa maṁ pati”."
    },
    {
      "id": "ja528:4.1",
      "pali": "“Ahu esa kato doso,"
    },
    {
      "id": "ja528:4.2",
      "pali": "yathā bhāsasi brāhmaṇa;"
    },
    {
      "id": "ja528:4.3",
      "pali": "Esa bhiyyo pasīdāmi,"
    },
    {
      "id": "ja528:4.4",
      "pali": "vasa brāhmaṇa māgamā”."
    },
    {
      "id": "ja528:5.1",
      "pali": "“Sabbaseto pure āsi,"
    },
    {
      "id": "ja528:5.2",
      "pali": "tatopi sabalo ahu;"
    },
    {
      "id": "ja528:5.3",
      "pali": "Sabbalohitako dāni,"
    },
    {
      "id": "ja528:5.4",
      "pali": "kālo pakkamituṁ mama."
    },
    {
      "id": "ja528:6.1",
      "pali": "Abbhantaraṁ pure āsi,"
    },
    {
      "id": "ja528:6.2",
      "pali": "tato majjhe tato bahi;"
    },
    {
      "id": "ja528:6.3",
      "pali": "Purā niddhamanā hoti,"
    },
    {
      "id": "ja528:6.4",
      "pali": "sayameva vajāmahaṁ."
    },
    {
      "id": "ja528:7.1",
      "pali": "Vītasaddhaṁ na seveyya,"
    },
    {
      "id": "ja528:7.2",
      "pali": "udapānaṁvanodakaṁ;"
    },
    {
      "id": "ja528:7.3",
      "pali": "Sacepi naṁ anukhaṇe,"
    },
    {
      "id": "ja528:7.4",
      "pali": "vāri kaddamagandhikaṁ."
    },
    {
      "id": "ja528:8.1",
      "pali": "Pasannameva seveyya,"
    },
    {
      "id": "ja528:8.2",
      "pali": "appasannaṁ vivajjaye;"
    },
    {
      "id": "ja528:8.3",
      "pali": "Pasannaṁ payirupāseyya,"
    },
    {
      "id": "ja528:8.4",
      "pali": "rahadaṁ vudakatthiko."
    },
    {
      "id": "ja528:9.1",
      "pali": "Bhaje bhajantaṁ purisaṁ,"
    },
    {
      "id": "ja528:9.2",
      "pali": "abhajantaṁ na bhajjaye;"
    },
    {
      "id": "ja528:9.3",
      "pali": "Asappurisadhammo so,"
    },
    {
      "id": "ja528:9.4",
      "pali": "yo bhajantaṁ na bhajjati."
    },
    {
      "id": "ja528:10.1",
      "pali": "Yo bhajantaṁ na bhajati,"
    },
    {
      "id": "ja528:10.2",
      "pali": "sevamānaṁ na sevati;"
    },
    {
      "id": "ja528:10.3",
      "pali": "Sa ve manussapāpiṭṭho,"
    },
    {
      "id": "ja528:10.4",
      "pali": "migo sākhassito yathā."
    },
    {
      "id": "ja528:11.1",
      "pali": "Accābhikkhaṇasaṁsaggā,"
    },
    {
      "id": "ja528:11.2",
      "pali": "asamosaraṇena ca;"
    },
    {
      "id": "ja528:11.3",
      "pali": "Etena mittā jīranti,"
    },
    {
      "id": "ja528:11.4",
      "pali": "akāle yācanāya ca."
    },
    {
      "id": "ja528:12.1",
      "pali": "Tasmā nābhikkhaṇaṁ gacche,"
    },
    {
      "id": "ja528:12.2",
      "pali": "na ca gacche cirāciraṁ;"
    },
    {
      "id": "ja528:12.3",
      "pali": "Kālena yācaṁ yāceyya,"
    },
    {
      "id": "ja528:12.4",
      "pali": "evaṁ mittā na jīyare."
    },
    {
      "id": "ja528:13.1",
      "pali": "Aticiraṁ nivāsena,"
    },
    {
      "id": "ja528:13.2",
      "pali": "piyo bhavati appiyo;"
    },
    {
      "id": "ja528:13.3",
      "pali": "Āmanta kho taṁ gacchāma,"
    },
    {
      "id": "ja528:13.4",
      "pali": "purā te homa appiyā”."
    },
    {
      "id": "ja528:14.1",
      "pali": "“Evañce yācamānānaṁ,"
    },
    {
      "id": "ja528:14.2",
      "pali": "Añjaliṁ nāvabujjhasi;"
    },
    {
      "id": "ja528:14.3",
      "pali": "Paricārakānaṁ sataṁ,"
    },
    {
      "id": "ja528:14.4",
      "pali": "Vacanaṁ na karosi no;"
    },
    {
      "id": "ja528:14.5",
      "pali": "Evaṁ taṁ abhiyācāma,"
    },
    {
      "id": "ja528:14.6",
      "pali": "Puna kayirāsi pariyāyaṁ”."
    },
    {
      "id": "ja528:15.1",
      "pali": "“Evañce no viharataṁ,"
    },
    {
      "id": "ja528:15.2",
      "pali": "Antarāyo na hessati;"
    },
    {
      "id": "ja528:15.3",
      "pali": "Tuyhaṁ vāpi mahārāja,"
    },
    {
      "id": "ja528:15.4",
      "pali": "Mayhaṁ vā raṭṭhavaddhana;"
    },
    {
      "id": "ja528:15.5",
      "pali": "Appeva nāma passema,"
    },
    {
      "id": "ja528:15.6",
      "pali": "Ahorattānamaccaye."
    },
    {
      "id": "ja528:16.1",
      "pali": "Udīraṇā ce saṅgatyā,"
    },
    {
      "id": "ja528:16.2",
      "pali": "bhāvāya manuvattati;"
    },
    {
      "id": "ja528:16.3",
      "pali": "Akāmā akaraṇīyaṁ vā,"
    },
    {
      "id": "ja528:16.4",
      "pali": "karaṇīyaṁ vāpi kubbati;"
    },
    {
      "id": "ja528:16.5",
      "pali": "Akāmākaraṇīyamhi,"
    },
    {
      "id": "ja528:16.6",
      "pali": "kvidha pāpena lippati."
    },
    {
      "id": "ja528:17.1",
      "pali": "So ce attho ca dhammo ca,"
    },
    {
      "id": "ja528:17.2",
      "pali": "kalyāṇo na ca pāpako;"
    },
    {
      "id": "ja528:17.3",
      "pali": "Bhoto ce vacanaṁ saccaṁ,"
    },
    {
      "id": "ja528:17.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:18.1",
      "pali": "Attano ce hi vādassa,"
    },
    {
      "id": "ja528:18.2",
      "pali": "aparādhaṁ vijāniyā;"
    },
    {
      "id": "ja528:18.3",
      "pali": "Na maṁ tvaṁ garaheyyāsi,"
    },
    {
      "id": "ja528:18.4",
      "pali": "bhoto vādo hi tādiso."
    },
    {
      "id": "ja528:19.1",
      "pali": "Issaro sabbalokassa,"
    },
    {
      "id": "ja528:19.2",
      "pali": "sace kappeti jīvitaṁ;"
    },
    {
      "id": "ja528:19.3",
      "pali": "Iddhiṁ byasanabhāvañca,"
    },
    {
      "id": "ja528:19.4",
      "pali": "kammaṁ kalyāṇapāpakaṁ;"
    },
    {
      "id": "ja528:19.5",
      "pali": "Niddesakārī puriso,"
    },
    {
      "id": "ja528:19.6",
      "pali": "issaro tena lippati."
    },
    {
      "id": "ja528:20.1",
      "pali": "So ce attho ca dhammo ca,"
    },
    {
      "id": "ja528:20.2",
      "pali": "kalyāṇo na ca pāpako;"
    },
    {
      "id": "ja528:20.3",
      "pali": "Bhoto ce vacanaṁ saccaṁ,"
    },
    {
      "id": "ja528:20.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:21.1",
      "pali": "Attano ce hi vādassa,"
    },
    {
      "id": "ja528:21.2",
      "pali": "aparādhaṁ vijāniyā;"
    },
    {
      "id": "ja528:21.3",
      "pali": "Na maṁ tvaṁ garaheyyāsi,"
    },
    {
      "id": "ja528:21.4",
      "pali": "bhoto vādo hi tādiso."
    },
    {
      "id": "ja528:22.1",
      "pali": "Sace pubbekatahetu,"
    },
    {
      "id": "ja528:22.2",
      "pali": "sukhadukkhaṁ nigacchati;"
    },
    {
      "id": "ja528:22.3",
      "pali": "Porāṇakaṁ kataṁ pāpaṁ,"
    },
    {
      "id": "ja528:22.4",
      "pali": "tameso muccate iṇaṁ;"
    },
    {
      "id": "ja528:22.5",
      "pali": "Porāṇakaiṇamokkho,"
    },
    {
      "id": "ja528:22.6",
      "pali": "kvidha pāpena lippati."
    },
    {
      "id": "ja528:23.1",
      "pali": "So ce attho ca dhammo ca,"
    },
    {
      "id": "ja528:23.2",
      "pali": "kalyāṇo na ca pāpako;"
    },
    {
      "id": "ja528:23.3",
      "pali": "Bhoto ce vacanaṁ saccaṁ,"
    },
    {
      "id": "ja528:23.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:24.1",
      "pali": "Attano ce hi vādassa,"
    },
    {
      "id": "ja528:24.2",
      "pali": "aparādhaṁ vijāniyā;"
    },
    {
      "id": "ja528:24.3",
      "pali": "Na maṁ tvaṁ garaheyyāsi,"
    },
    {
      "id": "ja528:24.4",
      "pali": "bhoto vādo hi tādiso."
    },
    {
      "id": "ja528:25.1",
      "pali": "Catunnaṁyevupādāya,"
    },
    {
      "id": "ja528:25.2",
      "pali": "rūpaṁ sambhoti pāṇinaṁ;"
    },
    {
      "id": "ja528:25.3",
      "pali": "Yato ca rūpaṁ sambhoti,"
    },
    {
      "id": "ja528:25.4",
      "pali": "tatthevānupagacchati;"
    },
    {
      "id": "ja528:25.5",
      "pali": "Idheva jīvati jīvo,"
    },
    {
      "id": "ja528:25.6",
      "pali": "pecca pecca vinassati."
    },
    {
      "id": "ja528:26.1",
      "pali": "Ucchijjati ayaṁ loko,"
    },
    {
      "id": "ja528:26.2",
      "pali": "ye bālā ye ca paṇḍitā;"
    },
    {
      "id": "ja528:26.3",
      "pali": "Ucchijjamāne lokasmiṁ,"
    },
    {
      "id": "ja528:26.4",
      "pali": "kvidha pāpena lippati."
    },
    {
      "id": "ja528:27.1",
      "pali": "So ce attho ca dhammo ca,"
    },
    {
      "id": "ja528:27.2",
      "pali": "kalyāṇo na ca pāpako;"
    },
    {
      "id": "ja528:27.3",
      "pali": "Bhoto ce vacanaṁ saccaṁ,"
    },
    {
      "id": "ja528:27.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:28.1",
      "pali": "Attano ce hi vādassa,"
    },
    {
      "id": "ja528:28.2",
      "pali": "aparādhaṁ vijāniyā;"
    },
    {
      "id": "ja528:28.3",
      "pali": "Na maṁ tvaṁ garaheyyāsi,"
    },
    {
      "id": "ja528:28.4",
      "pali": "bhoto vādo hi tādiso."
    },
    {
      "id": "ja528:29.1",
      "pali": "Āhu khattavidā loke,"
    },
    {
      "id": "ja528:29.2",
      "pali": "bālā paṇḍitamānino;"
    },
    {
      "id": "ja528:29.3",
      "pali": "‘Mātaraṁ pitaraṁ haññe,"
    },
    {
      "id": "ja528:29.4",
      "pali": "atho jeṭṭhampi bhātaraṁ;"
    },
    {
      "id": "ja528:29.5",
      "pali": "Haneyya puttadāre ca,"
    },
    {
      "id": "ja528:29.6",
      "pali": "attho ce tādiso siyā’."
    },
    {
      "id": "ja528:30.1",
      "pali": "Yassa rukkhassa chāyāya,"
    },
    {
      "id": "ja528:30.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "ja528:30.3",
      "pali": "Na tassa sākhaṁ bhañjeyya,"
    },
    {
      "id": "ja528:30.4",
      "pali": "mittadubbho hi pāpako."
    },
    {
      "id": "ja528:31.1",
      "pali": "Atha atthe samuppanne,"
    },
    {
      "id": "ja528:31.2",
      "pali": "samūlamapi abbahe;"
    },
    {
      "id": "ja528:31.3",
      "pali": "Attho me sambalenāpi,"
    },
    {
      "id": "ja528:31.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:32.1",
      "pali": "So ce attho ca dhammo ca,"
    },
    {
      "id": "ja528:32.2",
      "pali": "kalyāṇo na ca pāpako;"
    },
    {
      "id": "ja528:32.3",
      "pali": "Bhoto ce vacanaṁ saccaṁ,"
    },
    {
      "id": "ja528:32.4",
      "pali": "suhato vānaro mayā."
    },
    {
      "id": "ja528:33.1",
      "pali": "Attano ce hi vādassa,"
    },
    {
      "id": "ja528:33.2",
      "pali": "aparādhaṁ vijāniyā;"
    },
    {
      "id": "ja528:33.3",
      "pali": "Na maṁ tvaṁ garaheyyāsi,"
    },
    {
      "id": "ja528:33.4",
      "pali": "bhoto vādo hi tādiso."
    },
    {
      "id": "ja528:34.1",
      "pali": "Ahetuvādo puriso,"
    },
    {
      "id": "ja528:34.2",
      "pali": "yo ca issarakuttiko;"
    },
    {
      "id": "ja528:34.3",
      "pali": "Pubbekatī ca ucchedī,"
    },
    {
      "id": "ja528:34.4",
      "pali": "yo ca khattavido naro."
    },
    {
      "id": "ja528:35.1",
      "pali": "Ete asappurisā loke,"
    },
    {
      "id": "ja528:35.2",
      "pali": "bālā paṇḍitamānino;"
    },
    {
      "id": "ja528:35.3",
      "pali": "Kareyya tādiso pāpaṁ,"
    },
    {
      "id": "ja528:35.4",
      "pali": "atho aññampi kāraye;"
    },
    {
      "id": "ja528:35.5",
      "pali": "Asappurisasaṁsaggo,"
    },
    {
      "id": "ja528:35.6",
      "pali": "dukkhanto kaṭukudrayo."
    },
    {
      "id": "ja528:36.1",
      "pali": "Urabbharūpena vakassu pubbe,"
    },
    {
      "id": "ja528:36.2",
      "pali": "Asaṅkito ajayūthaṁ upeti;"
    },
    {
      "id": "ja528:36.3",
      "pali": "Hantvā uraṇiṁ ajikaṁ ajañca,"
    },
    {
      "id": "ja528:36.4",
      "pali": "Utrāsayitvā yena kāmaṁ paleti."
    },
    {
      "id": "ja528:37.1",
      "pali": "Tathāvidheke samaṇabrāhmaṇāse,"
    },
    {
      "id": "ja528:37.2",
      "pali": "Chadanaṁ katvā vañcayanti manusse;"
    },
    {
      "id": "ja528:37.3",
      "pali": "Anāsakā thaṇḍilaseyyakā ca,"
    },
    {
      "id": "ja528:37.4",
      "pali": "Rajojallaṁ ukkuṭikappadhānaṁ;"
    },
    {
      "id": "ja528:37.5",
      "pali": "Pariyāyabhattañca apānakattā,"
    },
    {
      "id": "ja528:37.6",
      "pali": "Pāpācārā arahanto vadānā."
    },
    {
      "id": "ja528:38.1",
      "pali": "Ete asappurisā loke,"
    },
    {
      "id": "ja528:38.2",
      "pali": "bālā paṇḍitamānino;"
    },
    {
      "id": "ja528:38.3",
      "pali": "Kareyya tādiso pāpaṁ,"
    },
    {
      "id": "ja528:38.4",
      "pali": "atho aññampi kāraye;"
    },
    {
      "id": "ja528:38.5",
      "pali": "Asappurisasaṁsaggo,"
    },
    {
      "id": "ja528:38.6",
      "pali": "dukkhanto kaṭukudrayo."
    },
    {
      "id": "ja528:39.1",
      "pali": "Yamāhu natthi vīriyanti,"
    },
    {
      "id": "ja528:39.2",
      "pali": "ahetuñca pavadanti ye;"
    },
    {
      "id": "ja528:39.3",
      "pali": "Parakāraṁ attakārañca,"
    },
    {
      "id": "ja528:39.4",
      "pali": "ye tucchaṁ samavaṇṇayuṁ."
    },
    {
      "id": "ja528:40.1",
      "pali": "Ete asappurisā loke,"
    },
    {
      "id": "ja528:40.2",
      "pali": "bālā paṇḍitamānino;"
    },
    {
      "id": "ja528:40.3",
      "pali": "Kareyya tādiso pāpaṁ,"
    },
    {
      "id": "ja528:40.4",
      "pali": "atho aññampi kāraye;"
    },
    {
      "id": "ja528:40.5",
      "pali": "Asappurisasaṁsaggo,"
    },
    {
      "id": "ja528:40.6",
      "pali": "dukkhanto kaṭukudrayo."
    },
    {
      "id": "ja528:41.1",
      "pali": "Sace hi vīriyaṁ nāssa,"
    },
    {
      "id": "ja528:41.2",
      "pali": "kammaṁ kalyāṇapāpakaṁ;"
    },
    {
      "id": "ja528:41.3",
      "pali": "Na bhare vaḍḍhakiṁ rājā,"
    },
    {
      "id": "ja528:41.4",
      "pali": "napi yantāni kāraye."
    },
    {
      "id": "ja528:42.1",
      "pali": "Yasmā ca vīriyaṁ atthi,"
    },
    {
      "id": "ja528:42.2",
      "pali": "kammaṁ kalyāṇapāpakaṁ;"
    },
    {
      "id": "ja528:42.3",
      "pali": "Tasmā yantāni kāreti,"
    },
    {
      "id": "ja528:42.4",
      "pali": "rājā bharati vaḍḍhakiṁ."
    },
    {
      "id": "ja528:43.1",
      "pali": "Yadi vassasataṁ devo,"
    },
    {
      "id": "ja528:43.2",
      "pali": "na vasse na himaṁ pate;"
    },
    {
      "id": "ja528:43.3",
      "pali": "Ucchijjeyya ayaṁ loko,"
    },
    {
      "id": "ja528:43.4",
      "pali": "vinasseyya ayaṁ pajā."
    },
    {
      "id": "ja528:44.1",
      "pali": "Yasmā ca vassatī devo,"
    },
    {
      "id": "ja528:44.2",
      "pali": "himañcānuphusāyati;"
    },
    {
      "id": "ja528:44.3",
      "pali": "Tasmā sassāni paccanti,"
    },
    {
      "id": "ja528:44.4",
      "pali": "raṭṭhañca pālite ciraṁ."
    },
    {
      "id": "ja528:45.1",
      "pali": "Gavañce taramānānaṁ,"
    },
    {
      "id": "ja528:45.2",
      "pali": "jimhaṁ gacchati puṅgavo;"
    },
    {
      "id": "ja528:45.3",
      "pali": "Sabbā tā jimhaṁ gacchanti,"
    },
    {
      "id": "ja528:45.4",
      "pali": "nette jimhaṁ gate sati."
    },
    {
      "id": "ja528:46.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja528:46.2",
      "pali": "yo hoti seṭṭhasammato;"
    },
    {
      "id": "ja528:46.3",
      "pali": "So ce adhammaṁ carati,"
    },
    {
      "id": "ja528:46.4",
      "pali": "pageva itarā pajā;"
    },
    {
      "id": "ja528:46.5",
      "pali": "Sabbaṁ raṭṭhaṁ dukhaṁ seti,"
    },
    {
      "id": "ja528:46.6",
      "pali": "rājā ce hoti adhammiko."
    },
    {
      "id": "ja528:47.1",
      "pali": "Gavañce taramānānaṁ,"
    },
    {
      "id": "ja528:47.2",
      "pali": "ujuṁ gacchati puṅgavo;"
    },
    {
      "id": "ja528:47.3",
      "pali": "Sabbā gāvī ujuṁ yanti,"
    },
    {
      "id": "ja528:47.4",
      "pali": "nette ujuṁ gate sati."
    },
    {
      "id": "ja528:48.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja528:48.2",
      "pali": "yo hoti seṭṭhasammato;"
    },
    {
      "id": "ja528:48.3",
      "pali": "So sace dhammaṁ carati,"
    },
    {
      "id": "ja528:48.4",
      "pali": "pageva itarā pajā;"
    },
    {
      "id": "ja528:48.5",
      "pali": "Sabbaṁ raṭṭhaṁ sukhaṁ seti,"
    },
    {
      "id": "ja528:48.6",
      "pali": "rājā ce hoti dhammiko."
    },
    {
      "id": "ja528:49.1",
      "pali": "Mahārukkhassa phalino,"
    },
    {
      "id": "ja528:49.2",
      "pali": "āmaṁ chindati yo phalaṁ;"
    },
    {
      "id": "ja528:49.3",
      "pali": "Rasañcassa na jānāti,"
    },
    {
      "id": "ja528:49.4",
      "pali": "bījañcassa vinassati."
    },
    {
      "id": "ja528:50.1",
      "pali": "Mahārukkhūpamaṁ raṭṭhaṁ,"
    },
    {
      "id": "ja528:50.2",
      "pali": "adhammena pasāsati;"
    },
    {
      "id": "ja528:50.3",
      "pali": "Rasañcassa na jānāti,"
    },
    {
      "id": "ja528:50.4",
      "pali": "raṭṭhañcassa vinassati."
    },
    {
      "id": "ja528:51.1",
      "pali": "Mahārukkhassa phalino,"
    },
    {
      "id": "ja528:51.2",
      "pali": "pakkaṁ chindati yo phalaṁ;"
    },
    {
      "id": "ja528:51.3",
      "pali": "Rasañcassa vijānāti,"
    },
    {
      "id": "ja528:51.4",
      "pali": "bījañcassa na nassati."
    },
    {
      "id": "ja528:52.1",
      "pali": "Mahārukkhūpamaṁ raṭṭhaṁ,"
    },
    {
      "id": "ja528:52.2",
      "pali": "dhammena yo pasāsati;"
    },
    {
      "id": "ja528:52.3",
      "pali": "Rasañcassa vijānāti,"
    },
    {
      "id": "ja528:52.4",
      "pali": "raṭṭhañcassa na nassati."
    },
    {
      "id": "ja528:53.1",
      "pali": "Yo ca rājā janapadaṁ,"
    },
    {
      "id": "ja528:53.2",
      "pali": "adhammena pasāsati;"
    },
    {
      "id": "ja528:53.3",
      "pali": "Sabbosadhīhi so rājā,"
    },
    {
      "id": "ja528:53.4",
      "pali": "viruddho hoti khattiyo."
    },
    {
      "id": "ja528:54.1",
      "pali": "Tatheva negame hiṁsaṁ,"
    },
    {
      "id": "ja528:54.2",
      "pali": "ye yuttā kayavikkaye;"
    },
    {
      "id": "ja528:54.3",
      "pali": "Ojadānabalīkāre,"
    },
    {
      "id": "ja528:54.4",
      "pali": "sa kosena virujjhati."
    },
    {
      "id": "ja528:55.1",
      "pali": "Pahāravarakhettaññū,"
    },
    {
      "id": "ja528:55.2",
      "pali": "saṅgāme katanissame;"
    },
    {
      "id": "ja528:55.3",
      "pali": "Ussite hiṁsayaṁ rājā,"
    },
    {
      "id": "ja528:55.4",
      "pali": "sa balena virujjhati."
    },
    {
      "id": "ja528:56.1",
      "pali": "Tatheva isayo hiṁsaṁ,"
    },
    {
      "id": "ja528:56.2",
      "pali": "saññate brahmacārino;"
    },
    {
      "id": "ja528:56.3",
      "pali": "Adhammacārī khattiyo,"
    },
    {
      "id": "ja528:56.4",
      "pali": "so saggena virujjhati."
    },
    {
      "id": "ja528:57.1",
      "pali": "Yo ca rājā adhammaṭṭho,"
    },
    {
      "id": "ja528:57.2",
      "pali": "bhariyaṁ hanti adūsikaṁ;"
    },
    {
      "id": "ja528:57.3",
      "pali": "Luddaṁ pasavate ṭhānaṁ,"
    },
    {
      "id": "ja528:57.4",
      "pali": "puttehi ca virujjhati."
    },
    {
      "id": "ja528:58.1",
      "pali": "Dhammaṁ care jānapade,"
    },
    {
      "id": "ja528:58.2",
      "pali": "negamesu balesu ca;"
    },
    {
      "id": "ja528:58.3",
      "pali": "Isayo ca na hiṁseyya,"
    },
    {
      "id": "ja528:58.4",
      "pali": "puttadāre samaṁ care."
    },
    {
      "id": "ja528:59.1",
      "pali": "Sa tādiso bhūmipati,"
    },
    {
      "id": "ja528:59.2",
      "pali": "Raṭṭhapālo akodhano;"
    },
    {
      "id": "ja528:59.3",
      "pali": "Sapatte sampakampeti,"
    },
    {
      "id": "ja528:59.4",
      "pali": "Indova asurādhipo”ti."
    },
    {
      "id": "ja528:60.1",
      "pali": "Mahābodhijātakaṁ tatiyaṁ."
    },
    {
      "id": "ja528:61.1",
      "pali": "Paṇṇāsanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja528:62.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja528:63.1",
      "pali": "Saniḷīnikamavhayano paṭhamo,"
    },
    {
      "id": "ja528:63.2",
      "pali": "Dutiyo pana saummadantivaro;"
    },
    {
      "id": "ja528:63.3",
      "pali": "Tatiyo pana bodhisirīvhayano,"
    },
    {
      "id": "ja528:63.4",
      "pali": "Kathitā pana tīṇi jinena subhāti."
    }
  ]
}
