{
  "uid": "pv10",
  "title": "10. Khallāṭiyapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv10:1.1",
      "pali": "“Kā nu antovimānasmiṁ,"
    },
    {
      "id": "pv10:1.2",
      "pali": "tiṭṭhantī nūpanikkhami;"
    },
    {
      "id": "pv10:1.3",
      "pali": "Upanikkhamassu bhadde,"
    },
    {
      "id": "pv10:1.4",
      "pali": "passāma taṁ bahiṭṭhitan”ti."
    },
    {
      "id": "pv10:2.1",
      "pali": "“Aṭṭīyāmi harāyāmi,"
    },
    {
      "id": "pv10:2.2",
      "pali": "naggā nikkhamituṁ bahi;"
    },
    {
      "id": "pv10:2.3",
      "pali": "Kesehamhi paṭicchannā,"
    },
    {
      "id": "pv10:2.4",
      "pali": "puññaṁ me appakaṁ katan”ti."
    },
    {
      "id": "pv10:3.1",
      "pali": "“Handuttarīyaṁ dadāmi te,"
    },
    {
      "id": "pv10:3.2",
      "pali": "idaṁ dussaṁ nivāsaya;"
    },
    {
      "id": "pv10:3.3",
      "pali": "Idaṁ dussaṁ nivāsetvā,"
    },
    {
      "id": "pv10:3.4",
      "pali": "ehi nikkhama sobhane;"
    },
    {
      "id": "pv10:3.5",
      "pali": "Upanikkhamassu bhadde,"
    },
    {
      "id": "pv10:3.6",
      "pali": "passāma taṁ bahiṭṭhitan”ti."
    },
    {
      "id": "pv10:4.1",
      "pali": "“Hatthena hatthe te dinnaṁ,"
    },
    {
      "id": "pv10:4.2",
      "pali": "na mayhaṁ upakappati;"
    },
    {
      "id": "pv10:4.3",
      "pali": "Esetthupāsako saddho,"
    },
    {
      "id": "pv10:4.4",
      "pali": "sammāsambuddhasāvako."
    },
    {
      "id": "pv10:5.1",
      "pali": "Etaṁ acchādayitvāna,"
    },
    {
      "id": "pv10:5.2",
      "pali": "mama dakkhiṇamādisa;"
    },
    {
      "id": "pv10:5.3",
      "pali": "Tathāhaṁ sukhitā hessaṁ,"
    },
    {
      "id": "pv10:5.4",
      "pali": "sabbakāmasamiddhinī”ti."
    },
    {
      "id": "pv10:6.1",
      "pali": "Tañca te nhāpayitvāna,"
    },
    {
      "id": "pv10:6.2",
      "pali": "vilimpetvāna vāṇijā;"
    },
    {
      "id": "pv10:6.3",
      "pali": "Vatthehacchādayitvāna,"
    },
    {
      "id": "pv10:6.4",
      "pali": "tassā dakkhiṇamādisuṁ."
    },
    {
      "id": "pv10:7.1",
      "pali": "Samanantarānuddiṭṭhe,"
    },
    {
      "id": "pv10:7.2",
      "pali": "vipāko udapajjatha;"
    },
    {
      "id": "pv10:7.3",
      "pali": "Bhojanacchādanapānīyaṁ,"
    },
    {
      "id": "pv10:7.4",
      "pali": "dakkhiṇāya idaṁ phalaṁ."
    },
    {
      "id": "pv10:8.1",
      "pali": "Tato suddhā sucivasanā,"
    },
    {
      "id": "pv10:8.2",
      "pali": "kāsikuttamadhārinī;"
    },
    {
      "id": "pv10:8.3",
      "pali": "Hasantī vimānā nikkhami,"
    },
    {
      "id": "pv10:8.4",
      "pali": "dakkhiṇāya idaṁ phalanti."
    },
    {
      "id": "pv10:9.1",
      "pali": "“Sucittarūpaṁ ruciraṁ,"
    },
    {
      "id": "pv10:9.2",
      "pali": "vimānaṁ te pabhāsati;"
    },
    {
      "id": "pv10:9.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "pv10:9.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "pv10:10.1",
      "pali": "“Bhikkhuno caramānassa,"
    },
    {
      "id": "pv10:10.2",
      "pali": "doṇinimmajjaniṁ ahaṁ;"
    },
    {
      "id": "pv10:10.3",
      "pali": "Adāsiṁ ujubhūtassa,"
    },
    {
      "id": "pv10:10.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "pv10:11.1",
      "pali": "Tassa kammassa kusalassa,"
    },
    {
      "id": "pv10:11.2",
      "pali": "vipākaṁ dīghamantaraṁ;"
    },
    {
      "id": "pv10:11.3",
      "pali": "Anubhomi vimānasmiṁ,"
    },
    {
      "id": "pv10:11.4",
      "pali": "tañca dāni parittakaṁ."
    },
    {
      "id": "pv10:12.1",
      "pali": "Uddhaṁ catūhi māsehi,"
    },
    {
      "id": "pv10:12.2",
      "pali": "kālakiriyā bhavissati;"
    },
    {
      "id": "pv10:12.3",
      "pali": "Ekantakaṭukaṁ ghoraṁ,"
    },
    {
      "id": "pv10:12.4",
      "pali": "nirayaṁ papatissahaṁ."
    },
    {
      "id": "pv10:13.1",
      "pali": "Catukkaṇṇaṁ catudvāraṁ,"
    },
    {
      "id": "pv10:13.2",
      "pali": "vibhattaṁ bhāgaso mitaṁ;"
    },
    {
      "id": "pv10:13.3",
      "pali": "Ayopākārapariyantaṁ,"
    },
    {
      "id": "pv10:13.4",
      "pali": "ayasā paṭikujjitaṁ."
    },
    {
      "id": "pv10:14.1",
      "pali": "Tassa ayomayā bhūmi,"
    },
    {
      "id": "pv10:14.2",
      "pali": "jalitā tejasā yutā;"
    },
    {
      "id": "pv10:14.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "pv10:14.4",
      "pali": "pharitvā tiṭṭhati sabbadā."
    },
    {
      "id": "pv10:15.1",
      "pali": "Tatthāhaṁ dīghamaddhānaṁ,"
    },
    {
      "id": "pv10:15.2",
      "pali": "dukkhaṁ vedissa vedanaṁ;"
    },
    {
      "id": "pv10:15.3",
      "pali": "Phalañca pāpakammassa,"
    },
    {
      "id": "pv10:15.4",
      "pali": "tasmā socāmahaṁ bhusan”ti."
    },
    {
      "id": "pv10:16.1",
      "pali": "Khallāṭiyapetivatthu dasamaṁ."
    }
  ]
}
