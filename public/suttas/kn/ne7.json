{
  "uid": "ne7",
  "title": "Vibhaṅga 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne7:1.1",
      "pali": "Tattha katamo padaṭṭhāno hāro?"
    },
    {
      "id": "ne7:1.2",
      "pali": "“Dhammaṁ deseti jino”ti, ayaṁ padaṭṭhāno hāro."
    },
    {
      "id": "ne7:1.3",
      "pali": "Kiṁ deseti?"
    },
    {
      "id": "ne7:1.4",
      "pali": "Sabbadhammayāthāvaasampaṭivedhalakkhaṇā avijjā, tassā vipallāsā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.5",
      "pali": "Ajjhosānalakkhaṇā taṇhā, tassā piyarūpaṁ sātarūpaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.6",
      "pali": "Patthanalakkhaṇo lobho, tassa adinnādānaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.7",
      "pali": "Vaṇṇasaṇṭhānabyañjanaggahaṇalakkhaṇā subhasaññā, tassā indriyā saṁvaro padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.8",
      "pali": "Sāsavaphassaupagamanalakkhaṇā sukhasaññā, tassā assādo padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.9",
      "pali": "Saṅkhatalakkhaṇānaṁ dhammānaṁ asamanupassanalakkhaṇā niccasaññā, tassā viññāṇaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.10",
      "pali": "Aniccasaññādukkhasaññāasamanupassanalakkhaṇā attasaññā, tassā nāmakāyo padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.11",
      "pali": "Sabbadhammasampaṭivedhalakkhaṇā vijjā, tassā sabbaṁ neyyaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.12",
      "pali": "Cittavikkhepapaṭisaṁharaṇalakkhaṇo samatho, tassa asubhā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.13",
      "pali": "Icchāvacarapaṭisaṁharaṇalakkhaṇo alobho, tassa adinnādānā veramaṇī padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.14",
      "pali": "Abyāpajjalakkhaṇo adoso, tassa pāṇātipātā veramaṇī padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.15",
      "pali": "Vatthuavippaṭipattilakkhaṇo amoho, tassa sammāpaṭipatti padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.16",
      "pali": "Vinīlakavipubbakagahaṇalakkhaṇā asubhasaññā, tassā nibbidā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.17",
      "pali": "Sāsavaphassaparijānanalakkhaṇā dukkhasaññā, tassā vedanā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.18",
      "pali": "Saṅkhatalakkhaṇānaṁ dhammānaṁ samanupassanalakkhaṇā aniccasaññā, tassā uppādavayā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:1.19",
      "pali": "Sabbadhammaabhinivesalakkhaṇā anattasaññā, tassā dhammasaññā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.1",
      "pali": "Pañca kāmaguṇā kāmarāgassa padaṭṭhānaṁ, pañcindriyāni rūpīni rūparāgassa padaṭṭhānaṁ, chaṭṭhāyatanaṁ bhavarāgassa padaṭṭhānaṁ, nibbattabhavānupassitā pañcannaṁ upādānakkhandhānaṁ padaṭṭhānaṁ, pubbenivāsānussatiñāṇadassanassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.2",
      "pali": "Okappanalakkhaṇā saddhā adhimuttipaccupaṭṭhānā ca, anāvilalakkhaṇo pasādo sampasīdanapaccupaṭṭhāno ca."
    },
    {
      "id": "ne7:2.3",
      "pali": "Abhipatthiyanalakkhaṇā saddhā, tassā aveccappasādo padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.4",
      "pali": "Anāvilalakkhaṇo pasādo, tassa saddhā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.5",
      "pali": "Ārambhalakkhaṇaṁ vīriyaṁ, tassa sammappadhānaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.6",
      "pali": "Apilāpanalakkhaṇā sati, tassā satipaṭṭhānaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.7",
      "pali": "Ekaggalakkhaṇo samādhi, tassa jhānāni padaṭṭhānaṁ."
    },
    {
      "id": "ne7:2.8",
      "pali": "Pajānanalakkhaṇā paññā, tassā saccāni padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.1",
      "pali": "Aparo nayo, assādamanasikāralakkhaṇo ayonisomanasikāro, tassa avijjā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.2",
      "pali": "Saccasammohanalakkhaṇā avijjā, sā saṅkhārānaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.3",
      "pali": "Punabbhavavirohaṇalakkhaṇā saṅkhārā, te viññāṇassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.4",
      "pali": "Opapaccayikanibbattilakkhaṇaṁ viññāṇaṁ, taṁ nāmarūpassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.5",
      "pali": "Nāmakāyarūpakāyasaṅghātalakkhaṇaṁ nāmarūpaṁ, taṁ chaḷāyatanassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.6",
      "pali": "Indriyavavatthānalakkhaṇaṁ chaḷāyatanaṁ, taṁ phassassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.7",
      "pali": "Cakkhurūpaviññāṇasannipātalakkhaṇo phasso, so vedanāya padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.8",
      "pali": "Iṭṭhāniṭṭhaanubhavanalakkhaṇā vedanā, sā taṇhāya padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.9",
      "pali": "Ajjhosānalakkhaṇā taṇhā, sā upādānassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.10",
      "pali": "Opapaccayikaṁ upādānaṁ, taṁ bhavassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.11",
      "pali": "Nāmakāyarūpakāyasambhavanalakkhaṇo bhavo, so jātiyā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.12",
      "pali": "Khandhapātubhavanalakkhaṇā jāti, sā jarāya padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.13",
      "pali": "Upadhiparipākalakkhaṇā jarā, sā maraṇassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.14",
      "pali": "Jīvitindriyupacchedalakkhaṇaṁ maraṇaṁ, taṁ sokassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.15",
      "pali": "Ussukkakārako soko, so paridevassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.16",
      "pali": "Lālappakārako paridevo, so dukkhassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.17",
      "pali": "Kāyasampīḷanaṁ dukkhaṁ, taṁ domanassassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.18",
      "pali": "Cittasampīḷanaṁ domanassaṁ, taṁ upāyāsassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.19",
      "pali": "Odahanakārako upāyāso, so bhavassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.20",
      "pali": "Imāni bhavaṅgāni yadā samaggāni nibbattāni bhavanti so bhavo, taṁ saṁsārassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:3.21",
      "pali": "Niyyānikalakkhaṇo maggo, so nirodhassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:4.1",
      "pali": "Titthaññutā pītaññutāya padaṭṭhānaṁ, pītaññutā pattaññutāya padaṭṭhānaṁ, pattaññutā attaññutāya padaṭṭhānaṁ, attaññutā pubbekatapuññatāya padaṭṭhānaṁ, pubbekatapuññatā patirūpadesavāsassa padaṭṭhānaṁ, patirūpadesavāso sappurisūpanissayassa padaṭṭhānaṁ, sappurisūpanissayo attasammāpaṇidhānassa padaṭṭhānaṁ, attasammāpaṇidhānaṁ sīlānaṁ padaṭṭhānaṁ, sīlāni avippaṭisārassa padaṭṭhānaṁ, avippaṭisāro pāmojjassa padaṭṭhānaṁ, pāmojjaṁ pītiyā padaṭṭhānaṁ, pīti passaddhiyā padaṭṭhānaṁ, passaddhi sukhassa padaṭṭhānaṁ, sukhaṁ samādhissa padaṭṭhānaṁ, samādhi yathābhūtañāṇadassanassa padaṭṭhānaṁ, yathābhūtañāṇadassanaṁ nibbidāya padaṭṭhānaṁ, nibbidā virāgassa padaṭṭhānaṁ, virāgo vimuttiyā padaṭṭhānaṁ."
    },
    {
      "id": "ne7:4.2",
      "pali": "Vimutti vimuttiñāṇadassanassa padaṭṭhānaṁ."
    },
    {
      "id": "ne7:4.3",
      "pali": "Evaṁ yo koci upanissayo yo koci paccayo, sabbo so padaṭṭhānaṁ."
    },
    {
      "id": "ne7:4.4",
      "pali": "Tenāha āyasmā mahākaccāyano “dhammaṁ deseti jino”ti."
    },
    {
      "id": "ne7:4.5",
      "pali": "Niyutto padaṭṭhāno hāro."
    }
  ]
}
