{
  "uid": "tha-ap208",
  "title": "Udakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap208:1.1",
      "pali": "“Bhuñjantaṁ samaṇaṁ disvā,"
    },
    {
      "id": "tha-ap208:1.2",
      "pali": "vippasannamanāvilaṁ;"
    },
    {
      "id": "tha-ap208:1.3",
      "pali": "Ghaṭenodakamādāya,"
    },
    {
      "id": "tha-ap208:1.4",
      "pali": "siddhatthassa adāsahaṁ."
    },
    {
      "id": "tha-ap208:2.1",
      "pali": "Nimmalo homahaṁ ajja,"
    },
    {
      "id": "tha-ap208:2.2",
      "pali": "vimalo khīṇasaṁsayo;"
    },
    {
      "id": "tha-ap208:2.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap208:2.4",
      "pali": "phalaṁ nibbattate mama."
    },
    {
      "id": "tha-ap208:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap208:3.2",
      "pali": "udakaṁ yamadāsahaṁ;"
    },
    {
      "id": "tha-ap208:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap208:3.4",
      "pali": "dakadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap208:4.1",
      "pali": "Ekasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap208:4.2",
      "pali": "ekova vimalo ahu;"
    },
    {
      "id": "tha-ap208:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap208:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap208:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap208:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap208:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap208:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā udakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap208:7.1",
      "pali": "Udakadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
