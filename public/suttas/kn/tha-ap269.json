{
  "uid": "tha-ap269",
  "title": "Javahaṁsakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap269:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap269:1.2",
      "pali": "Āsiṁ vanacaro tadā;"
    },
    {
      "id": "tha-ap269:1.3",
      "pali": "Siddhatthaṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap269:1.4",
      "pali": "Gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap269:2.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap269:2.2",
      "pali": "ullokento mahāmuniṁ;"
    },
    {
      "id": "tha-ap269:2.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap269:2.4",
      "pali": "avandiṁ nāyakaṁ ahaṁ."
    },
    {
      "id": "tha-ap269:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap269:3.2",
      "pali": "yamavandiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap269:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap269:3.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap269:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap269:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap269:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap269:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā javahaṁsako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap269:6.1",
      "pali": "Javahaṁsakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
