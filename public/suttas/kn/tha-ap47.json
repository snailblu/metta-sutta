{
  "uid": "tha-ap47",
  "title": "Pañcahatthiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap47:1.1",
      "pali": "“Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap47:1.2",
      "pali": "gacchate antarāpaṇe;"
    },
    {
      "id": "tha-ap47:1.3",
      "pali": "Okkhittacakkhu mitabhāṇī,"
    },
    {
      "id": "tha-ap47:1.4",
      "pali": "satimā saṁvutindriyo."
    },
    {
      "id": "tha-ap47:2.1",
      "pali": "Pañca uppalahatthāni,"
    },
    {
      "id": "tha-ap47:2.2",
      "pali": "āveḷatthaṁ ahaṁsu me;"
    },
    {
      "id": "tha-ap47:2.3",
      "pali": "Tena buddhaṁ apūjesiṁ,"
    },
    {
      "id": "tha-ap47:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap47:3.1",
      "pali": "Āropitā ca te pupphā,"
    },
    {
      "id": "tha-ap47:3.2",
      "pali": "chadanaṁ assu satthuno;"
    },
    {
      "id": "tha-ap47:3.3",
      "pali": "Samādhiṁsu mahānāgaṁ,"
    },
    {
      "id": "tha-ap47:3.4",
      "pali": "sissā ācariyaṁ yathā."
    },
    {
      "id": "tha-ap47:4.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap47:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap47:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap47:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap47:5.1",
      "pali": "Ito vīsakappasate,"
    },
    {
      "id": "tha-ap47:5.2",
      "pali": "ahesuṁ pañca khattiyā;"
    },
    {
      "id": "tha-ap47:5.3",
      "pali": "Hatthiyā nāma nāmena,"
    },
    {
      "id": "tha-ap47:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap47:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap47:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap47:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap47:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pañcahatthiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap47:8.1",
      "pali": "Pañcahatthiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
