{
  "uid": "iti63",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti63:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti63:2.1",
      "pali": "“Tayome, bhikkhave, addhā."
    },
    {
      "id": "iti63:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti63:2.3",
      "pali": "Atīto addhā, anāgato addhā, paccuppanno addhā—"
    },
    {
      "id": "iti63:2.4",
      "pali": "ime kho, bhikkhave, tayo addhā”ti."
    },
    {
      "id": "iti63:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti63:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti63:3.1",
      "pali": "“Akkheyyasaññino sattā,"
    },
    {
      "id": "iti63:3.2",
      "pali": "akkheyyasmiṁ patiṭṭhitā;"
    },
    {
      "id": "iti63:3.3",
      "pali": "Akkheyyaṁ apariññāya,"
    },
    {
      "id": "iti63:3.4",
      "pali": "yogamāyanti maccuno."
    },
    {
      "id": "iti63:4.1",
      "pali": "Akkheyyañca pariññāya,"
    },
    {
      "id": "iti63:4.2",
      "pali": "akkhātāraṁ na maññati;"
    },
    {
      "id": "iti63:4.3",
      "pali": "Phuṭṭho vimokkho manasā,"
    },
    {
      "id": "iti63:4.4",
      "pali": "santipadamanuttaraṁ."
    },
    {
      "id": "iti63:5.1",
      "pali": "Sa ve akkheyyasampanno,"
    },
    {
      "id": "iti63:5.2",
      "pali": "santo santipade rato;"
    },
    {
      "id": "iti63:5.3",
      "pali": "Saṅkhāya sevī dhammaṭṭho,"
    },
    {
      "id": "iti63:5.4",
      "pali": "saṅkhyaṁ nopeti vedagū”ti."
    },
    {
      "id": "iti63:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti63:6.2",
      "pali": "Catutthaṁ."
    }
  ]
}
