{
  "uid": "ja503",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja503:1.1",
      "pali": "Migaluddo mahārājā,"
    },
    {
      "id": "ja503:1.2",
      "pali": "pañcālānaṁ rathesabho;"
    },
    {
      "id": "ja503:1.3",
      "pali": "Nikkhanto saha senāya,"
    },
    {
      "id": "ja503:1.4",
      "pali": "ogaṇo vanamāgamā."
    },
    {
      "id": "ja503:2.1",
      "pali": "Tatthaddasā araññasmiṁ,"
    },
    {
      "id": "ja503:2.2",
      "pali": "takkarānaṁ kuṭiṁ kataṁ;"
    },
    {
      "id": "ja503:2.3",
      "pali": "Tassā kuṭiyā nikkhamma,"
    },
    {
      "id": "ja503:2.4",
      "pali": "suvo luddāni bhāsati."
    },
    {
      "id": "ja503:3.1",
      "pali": "“Sampannavāhano poso,"
    },
    {
      "id": "ja503:3.2",
      "pali": "yuvā sammaṭṭhakuṇḍalo;"
    },
    {
      "id": "ja503:3.3",
      "pali": "Sobhati lohituṇhīso,"
    },
    {
      "id": "ja503:3.4",
      "pali": "divā sūriyova bhāsati."
    },
    {
      "id": "ja503:4.1",
      "pali": "Majjhanhike sampatike,"
    },
    {
      "id": "ja503:4.2",
      "pali": "sutto rājā sasārathi;"
    },
    {
      "id": "ja503:4.3",
      "pali": "Handassābharaṇaṁ sabbaṁ,"
    },
    {
      "id": "ja503:4.4",
      "pali": "gaṇhāma sāhasā mayaṁ."
    },
    {
      "id": "ja503:5.1",
      "pali": "Nisīthepi raho dāni,"
    },
    {
      "id": "ja503:5.2",
      "pali": "Sutto rājā sasārathi;"
    },
    {
      "id": "ja503:5.3",
      "pali": "Ādāya vatthaṁ maṇikuṇḍalañca,"
    },
    {
      "id": "ja503:5.4",
      "pali": "Hantvāna sākhāhi avattharāma”."
    },
    {
      "id": "ja503:6.1",
      "pali": "“Kiṁ nu ummattarūpova,"
    },
    {
      "id": "ja503:6.2",
      "pali": "sattigumba pabhāsasi;"
    },
    {
      "id": "ja503:6.3",
      "pali": "Durāsadā hi rājāno,"
    },
    {
      "id": "ja503:6.4",
      "pali": "aggi pajjalito yathā”."
    },
    {
      "id": "ja503:7.1",
      "pali": "“Atha tvaṁ patikolamba,"
    },
    {
      "id": "ja503:7.2",
      "pali": "matto thullāni gajjasi;"
    },
    {
      "id": "ja503:7.3",
      "pali": "Mātari mayhaṁ naggāya,"
    },
    {
      "id": "ja503:7.4",
      "pali": "kiṁ nu tvaṁ vijigucchase”."
    },
    {
      "id": "ja503:8.1",
      "pali": "“Uṭṭhehi samma taramāno,"
    },
    {
      "id": "ja503:8.2",
      "pali": "rathaṁ yojehi sārathi;"
    },
    {
      "id": "ja503:8.3",
      "pali": "Sakuṇo me na ruccati,"
    },
    {
      "id": "ja503:8.4",
      "pali": "aññaṁ gacchāma assamaṁ”."
    },
    {
      "id": "ja503:9.1",
      "pali": "“Yutto ratho mahārāja,"
    },
    {
      "id": "ja503:9.2",
      "pali": "yutto ca balavāhano;"
    },
    {
      "id": "ja503:9.3",
      "pali": "Adhitiṭṭha mahārāja,"
    },
    {
      "id": "ja503:9.4",
      "pali": "aññaṁ gacchāma assamaṁ”."
    },
    {
      "id": "ja503:10.1",
      "pali": "“Ko numeva gatā sabbe,"
    },
    {
      "id": "ja503:10.2",
      "pali": "ye asmiṁ paricārakā;"
    },
    {
      "id": "ja503:10.3",
      "pali": "Esa gacchati pañcālo,"
    },
    {
      "id": "ja503:10.4",
      "pali": "mutto tesaṁ adassanā."
    },
    {
      "id": "ja503:11.1",
      "pali": "Kodaṇḍakāni gaṇhatha,"
    },
    {
      "id": "ja503:11.2",
      "pali": "sattiyo tomarāni ca;"
    },
    {
      "id": "ja503:11.3",
      "pali": "Esa gacchati pañcālo,"
    },
    {
      "id": "ja503:11.4",
      "pali": "mā vo muñcittha jīvataṁ”."
    },
    {
      "id": "ja503:12.1",
      "pali": "Athāparo paṭinandittha,"
    },
    {
      "id": "ja503:12.2",
      "pali": "suvo lohitatuṇḍako;"
    },
    {
      "id": "ja503:12.3",
      "pali": "“Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja503:12.4",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja503:12.5",
      "pali": "Issarosi anuppatto,"
    },
    {
      "id": "ja503:12.6",
      "pali": "yaṁ idhatthi pavedaya."
    },
    {
      "id": "ja503:13.1",
      "pali": "Tindukāni piyālāni,"
    },
    {
      "id": "ja503:13.2",
      "pali": "madhuke kāsumāriyo;"
    },
    {
      "id": "ja503:13.3",
      "pali": "Phalāni khuddakappāni,"
    },
    {
      "id": "ja503:13.4",
      "pali": "bhuñja rāja varaṁ varaṁ."
    },
    {
      "id": "ja503:14.1",
      "pali": "Idampi pānīyaṁ sītaṁ,"
    },
    {
      "id": "ja503:14.2",
      "pali": "ābhataṁ girigabbharā;"
    },
    {
      "id": "ja503:14.3",
      "pali": "Tato piva mahārāja,"
    },
    {
      "id": "ja503:14.4",
      "pali": "sace tvaṁ abhikaṅkhasi."
    },
    {
      "id": "ja503:15.1",
      "pali": "Araññaṁ uñchāya gatā,"
    },
    {
      "id": "ja503:15.2",
      "pali": "ye asmiṁ paricārakā;"
    },
    {
      "id": "ja503:15.3",
      "pali": "Sayaṁ uṭṭhāya gaṇhavho,"
    },
    {
      "id": "ja503:15.4",
      "pali": "hatthā me natthi dātave”."
    },
    {
      "id": "ja503:16.1",
      "pali": "“Bhaddako vatayaṁ pakkhī,"
    },
    {
      "id": "ja503:16.2",
      "pali": "dijo paramadhammiko;"
    },
    {
      "id": "ja503:16.3",
      "pali": "Atheso itaro pakkhī,"
    },
    {
      "id": "ja503:16.4",
      "pali": "suvo luddāni bhāsati."
    },
    {
      "id": "ja503:17.1",
      "pali": "‘Etaṁ hanatha bandhatha,"
    },
    {
      "id": "ja503:17.2",
      "pali": "Mā vo muñcittha jīvataṁ’;"
    },
    {
      "id": "ja503:17.3",
      "pali": "Iccevaṁ vilapantassa,"
    },
    {
      "id": "ja503:17.4",
      "pali": "Sotthiṁ pattosmi assamaṁ”."
    },
    {
      "id": "ja503:18.1",
      "pali": "“Bhātarosma mahārāja,"
    },
    {
      "id": "ja503:18.2",
      "pali": "sodariyā ekamātukā;"
    },
    {
      "id": "ja503:18.3",
      "pali": "Ekarukkhasmiṁ saṁvaḍḍhā,"
    },
    {
      "id": "ja503:18.4",
      "pali": "nānākhettagatā ubho."
    },
    {
      "id": "ja503:19.1",
      "pali": "Sattigumbo ca corānaṁ,"
    },
    {
      "id": "ja503:19.2",
      "pali": "ahañca isīnaṁ idha;"
    },
    {
      "id": "ja503:19.3",
      "pali": "Asataṁ so, sataṁ ahaṁ,"
    },
    {
      "id": "ja503:19.4",
      "pali": "tena dhammena no vinā”."
    },
    {
      "id": "ja503:20.1",
      "pali": "“Tattha vadho ca bandho ca,"
    },
    {
      "id": "ja503:20.2",
      "pali": "nikatī vañcanāni ca;"
    },
    {
      "id": "ja503:20.3",
      "pali": "Ālopā sāhasākārā,"
    },
    {
      "id": "ja503:20.4",
      "pali": "tāni so tattha sikkhati."
    },
    {
      "id": "ja503:21.1",
      "pali": "Idha saccañca dhammo ca,"
    },
    {
      "id": "ja503:21.2",
      "pali": "Ahiṁsā saṁyamo damo;"
    },
    {
      "id": "ja503:21.3",
      "pali": "Āsanūdakadāyīnaṁ,"
    },
    {
      "id": "ja503:21.4",
      "pali": "Aṅke vaddhosmi bhāradha”."
    },
    {
      "id": "ja503:22.1",
      "pali": "“Yaṁ yañhi rāja bhajati,"
    },
    {
      "id": "ja503:22.2",
      "pali": "santaṁ vā yadi vā asaṁ;"
    },
    {
      "id": "ja503:22.3",
      "pali": "Sīlavantaṁ visīlaṁ vā,"
    },
    {
      "id": "ja503:22.4",
      "pali": "vasaṁ tasseva gacchati."
    },
    {
      "id": "ja503:23.1",
      "pali": "Yādisaṁ kurute mittaṁ,"
    },
    {
      "id": "ja503:23.2",
      "pali": "yādisaṁ cūpasevati;"
    },
    {
      "id": "ja503:23.3",
      "pali": "Sopi tādisako hoti,"
    },
    {
      "id": "ja503:23.4",
      "pali": "sahavāso hi tādiso."
    },
    {
      "id": "ja503:24.1",
      "pali": "Sevamāno sevamānaṁ,"
    },
    {
      "id": "ja503:24.2",
      "pali": "samphuṭṭho samphusaṁ paraṁ;"
    },
    {
      "id": "ja503:24.3",
      "pali": "Saro diddho kalāpaṁva,"
    },
    {
      "id": "ja503:24.4",
      "pali": "alittamupalimpati;"
    },
    {
      "id": "ja503:24.5",
      "pali": "Upalepabhayā dhīro,"
    },
    {
      "id": "ja503:24.6",
      "pali": "neva pāpasakhā siyā."
    },
    {
      "id": "ja503:25.1",
      "pali": "Pūtimacchaṁ kusaggena,"
    },
    {
      "id": "ja503:25.2",
      "pali": "yo naro upanayhati;"
    },
    {
      "id": "ja503:25.3",
      "pali": "Kusāpi pūti vāyanti,"
    },
    {
      "id": "ja503:25.4",
      "pali": "evaṁ bālūpasevanā."
    },
    {
      "id": "ja503:26.1",
      "pali": "Tagarañca palāsena,"
    },
    {
      "id": "ja503:26.2",
      "pali": "yo naro upanayhati;"
    },
    {
      "id": "ja503:26.3",
      "pali": "Pattāpi surabhi vāyanti,"
    },
    {
      "id": "ja503:26.4",
      "pali": "evaṁ dhīrūpasevanā."
    },
    {
      "id": "ja503:27.1",
      "pali": "Tasmā pattapuṭasseva,"
    },
    {
      "id": "ja503:27.2",
      "pali": "ñatvā sampākamattano;"
    },
    {
      "id": "ja503:27.3",
      "pali": "Asante nopaseveyya,"
    },
    {
      "id": "ja503:27.4",
      "pali": "sante seveyya paṇḍito;"
    },
    {
      "id": "ja503:27.5",
      "pali": "Asanto nirayaṁ nenti,"
    },
    {
      "id": "ja503:27.6",
      "pali": "santo pāpenti suggatin”ti."
    },
    {
      "id": "ja503:28.1",
      "pali": "Sattigumbajātakaṁ sattamaṁ."
    }
  ]
}
