{
  "uid": "ja427",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja427:1.1",
      "pali": "“Parisaṅkupatho nāma,"
    },
    {
      "id": "ja427:1.2",
      "pali": "gijjhapantho sanantano;"
    },
    {
      "id": "ja427:1.3",
      "pali": "Tatrāsi mātāpitaro,"
    },
    {
      "id": "ja427:1.4",
      "pali": "gijjho posesi jiṇṇake;"
    },
    {
      "id": "ja427:1.5",
      "pali": "Tesaṁ ajagaramedaṁ,"
    },
    {
      "id": "ja427:1.6",
      "pali": "accahāsi bahuttaso."
    },
    {
      "id": "ja427:2.1",
      "pali": "Pitā ca puttaṁ avaca,"
    },
    {
      "id": "ja427:2.2",
      "pali": "Jānaṁ uccaṁ papātinaṁ;"
    },
    {
      "id": "ja427:2.3",
      "pali": "Supattaṁ thāmasampannaṁ,"
    },
    {
      "id": "ja427:2.4",
      "pali": "Tejassiṁ dūragāminaṁ."
    },
    {
      "id": "ja427:3.1",
      "pali": "Pariplavantaṁ pathaviṁ,"
    },
    {
      "id": "ja427:3.2",
      "pali": "yadā tāta vijānahi;"
    },
    {
      "id": "ja427:3.3",
      "pali": "Sāgarena parikkhittaṁ,"
    },
    {
      "id": "ja427:3.4",
      "pali": "cakkaṁva parimaṇḍalaṁ;"
    },
    {
      "id": "ja427:3.5",
      "pali": "Tato tāta nivattassu,"
    },
    {
      "id": "ja427:3.6",
      "pali": "māssu etto paraṁ gami."
    },
    {
      "id": "ja427:4.1",
      "pali": "Udapattosi vegena,"
    },
    {
      "id": "ja427:4.2",
      "pali": "balī pakkhī dijuttamo;"
    },
    {
      "id": "ja427:4.3",
      "pali": "Olokayanto vakkaṅgo,"
    },
    {
      "id": "ja427:4.4",
      "pali": "pabbatāni vanāni ca."
    },
    {
      "id": "ja427:5.1",
      "pali": "Addassa pathaviṁ gijjho,"
    },
    {
      "id": "ja427:5.2",
      "pali": "yathāsāsi pitussutaṁ;"
    },
    {
      "id": "ja427:5.3",
      "pali": "Sāgarena parikkhittaṁ,"
    },
    {
      "id": "ja427:5.4",
      "pali": "cakkaṁva parimaṇḍalaṁ."
    },
    {
      "id": "ja427:6.1",
      "pali": "Tañca so samatikkamma,"
    },
    {
      "id": "ja427:6.2",
      "pali": "paramevaccavattatha;"
    },
    {
      "id": "ja427:6.3",
      "pali": "Tañca vātasikhā tikkhā,"
    },
    {
      "id": "ja427:6.4",
      "pali": "accahāsi baliṁ dijaṁ."
    },
    {
      "id": "ja427:7.1",
      "pali": "Nāsakkhātigato poso,"
    },
    {
      "id": "ja427:7.2",
      "pali": "punadeva nivattituṁ;"
    },
    {
      "id": "ja427:7.3",
      "pali": "Dijo byasanamāpādi,"
    },
    {
      "id": "ja427:7.4",
      "pali": "verambhānaṁ vasaṁ gato."
    },
    {
      "id": "ja427:8.1",
      "pali": "Tassa puttā ca dārā ca,"
    },
    {
      "id": "ja427:8.2",
      "pali": "ye caññe anujīvino;"
    },
    {
      "id": "ja427:8.3",
      "pali": "Sabbe byasanamāpāduṁ,"
    },
    {
      "id": "ja427:8.4",
      "pali": "anovādakare dije."
    },
    {
      "id": "ja427:9.1",
      "pali": "Evampi idha vuḍḍhānaṁ,"
    },
    {
      "id": "ja427:9.2",
      "pali": "yo vākyaṁ nāvabujjhati;"
    },
    {
      "id": "ja427:9.3",
      "pali": "Atisīmacaro ditto,"
    },
    {
      "id": "ja427:9.4",
      "pali": "gijjhovātītasāsano;"
    },
    {
      "id": "ja427:9.5",
      "pali": "Sa ve byasanaṁ pappoti,"
    },
    {
      "id": "ja427:9.6",
      "pali": "akatvā vuḍḍhasāsanan”ti."
    },
    {
      "id": "ja427:10.1",
      "pali": "Gijjhajātakaṁ paṭhamaṁ."
    }
  ]
}
