{
  "uid": "ja13",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja13:1.1",
      "pali": "“Dhiratthu kaṇḍinaṁ sallaṁ,"
    },
    {
      "id": "ja13:1.2",
      "pali": "purisaṁ gāḷhavedhinaṁ;"
    },
    {
      "id": "ja13:1.3",
      "pali": "Dhiratthu taṁ janapadaṁ,"
    },
    {
      "id": "ja13:1.4",
      "pali": "yatthitthī pariṇāyikā;"
    },
    {
      "id": "ja13:1.5",
      "pali": "Te cāpi dhikkitā sattā,"
    },
    {
      "id": "ja13:1.6",
      "pali": "ye itthīnaṁ vasaṅgatā”ti."
    },
    {
      "id": "ja13:2.1",
      "pali": "Kaṇḍijātakaṁ tatiyaṁ."
    }
  ]
}
