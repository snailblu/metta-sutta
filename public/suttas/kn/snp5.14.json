{
  "uid": "snp5.14",
  "title": "Udayamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.14:1.1",
      "pali": "“Jhāyiṁ virajamāsīnaṁ,"
    },
    {
      "id": "snp5.14:1.2",
      "pali": "(iccāyasmā udayo)"
    },
    {
      "id": "snp5.14:1.3",
      "pali": "Katakiccaṁ anāsavaṁ;"
    },
    {
      "id": "snp5.14:1.4",
      "pali": "Pāraguṁ sabbadhammānaṁ,"
    },
    {
      "id": "snp5.14:1.5",
      "pali": "Atthi pañhena āgamaṁ;"
    },
    {
      "id": "snp5.14:1.6",
      "pali": "Aññāvimokkhaṁ pabrūhi,"
    },
    {
      "id": "snp5.14:1.7",
      "pali": "Avijjāya pabhedanaṁ”."
    },
    {
      "id": "snp5.14:2.1",
      "pali": "“Pahānaṁ kāmacchandānaṁ,"
    },
    {
      "id": "snp5.14:2.2",
      "pali": "(udayāti bhagavā)"
    },
    {
      "id": "snp5.14:2.3",
      "pali": "Domanassāna cūbhayaṁ;"
    },
    {
      "id": "snp5.14:2.4",
      "pali": "Thinassa ca panūdanaṁ,"
    },
    {
      "id": "snp5.14:2.5",
      "pali": "Kukkuccānaṁ nivāraṇaṁ."
    },
    {
      "id": "snp5.14:3.1",
      "pali": "Upekkhāsatisaṁsuddhaṁ,"
    },
    {
      "id": "snp5.14:3.2",
      "pali": "dhammatakkapurejavaṁ;"
    },
    {
      "id": "snp5.14:3.3",
      "pali": "Aññāvimokkhaṁ pabrūmi,"
    },
    {
      "id": "snp5.14:3.4",
      "pali": "avijjāya pabhedanaṁ”."
    },
    {
      "id": "snp5.14:4.1",
      "pali": "“Kiṁsu saṁyojano loko,"
    },
    {
      "id": "snp5.14:4.2",
      "pali": "kiṁsu tassa vicāraṇaṁ;"
    },
    {
      "id": "snp5.14:4.3",
      "pali": "Kissassa vippahānena,"
    },
    {
      "id": "snp5.14:4.4",
      "pali": "nibbānaṁ iti vuccati”."
    },
    {
      "id": "snp5.14:5.1",
      "pali": "“Nandisaṁyojano loko,"
    },
    {
      "id": "snp5.14:5.2",
      "pali": "vitakkassa vicāraṇaṁ;"
    },
    {
      "id": "snp5.14:5.3",
      "pali": "Taṇhāya vippahānena,"
    },
    {
      "id": "snp5.14:5.4",
      "pali": "nibbānaṁ iti vuccati”."
    },
    {
      "id": "snp5.14:6.1",
      "pali": "“Kathaṁ satassa carato,"
    },
    {
      "id": "snp5.14:6.2",
      "pali": "viññāṇaṁ uparujjhati;"
    },
    {
      "id": "snp5.14:6.3",
      "pali": "Bhagavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "snp5.14:6.4",
      "pali": "taṁ suṇoma vaco tava”."
    },
    {
      "id": "snp5.14:7.1",
      "pali": "“Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "snp5.14:7.2",
      "pali": "Vedanaṁ nābhinandato;"
    },
    {
      "id": "snp5.14:7.3",
      "pali": "Evaṁ satassa carato,"
    },
    {
      "id": "snp5.14:7.4",
      "pali": "Viññāṇaṁ uparujjhatī”ti."
    },
    {
      "id": "snp5.14:7.5",
      "pali": "Udayamāṇavapucchā terasamā."
    }
  ]
}
