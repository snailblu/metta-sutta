{
  "uid": "ja252",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja252:1.1",
      "pali": "“Ajjāpi me taṁ manasi,"
    },
    {
      "id": "ja252:1.2",
      "pali": "yaṁ maṁ tvaṁ tilamuṭṭhiyā;"
    },
    {
      "id": "ja252:1.3",
      "pali": "Bāhāya maṁ gahetvāna,"
    },
    {
      "id": "ja252:1.4",
      "pali": "laṭṭhiyā anutāḷayi."
    },
    {
      "id": "ja252:2.1",
      "pali": "Nanu jīvite na ramasi,"
    },
    {
      "id": "ja252:2.2",
      "pali": "yenāsi brāhmaṇāgato;"
    },
    {
      "id": "ja252:2.3",
      "pali": "Yaṁ maṁ bāhā gahetvāna,"
    },
    {
      "id": "ja252:2.4",
      "pali": "tikkhattuṁ anutāḷayi”."
    },
    {
      "id": "ja252:3.1",
      "pali": "“Ariyo anariyaṁ kubbantaṁ,"
    },
    {
      "id": "ja252:3.2",
      "pali": "Yo daṇḍena nisedhati;"
    },
    {
      "id": "ja252:3.3",
      "pali": "Sāsanaṁ taṁ na taṁ veraṁ,"
    },
    {
      "id": "ja252:3.4",
      "pali": "Iti naṁ paṇḍitā vidū”ti."
    },
    {
      "id": "ja252:4.1",
      "pali": "Tilamuṭṭhijātakaṁ dutiyaṁ."
    }
  ]
}
