{
  "uid": "ja44",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja44:1.1",
      "pali": "“Seyyo amitto matiyā upeto,"
    },
    {
      "id": "ja44:1.2",
      "pali": "Na tveva mitto mativippahīno;"
    },
    {
      "id": "ja44:1.3",
      "pali": "Makasaṁ vadhissanti hi eḷamūgo,"
    },
    {
      "id": "ja44:1.4",
      "pali": "Putto pitu abbhidā uttamaṅgan”ti."
    },
    {
      "id": "ja44:2.1",
      "pali": "Makasajātakaṁ catutthaṁ."
    }
  ]
}
