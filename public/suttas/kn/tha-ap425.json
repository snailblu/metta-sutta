{
  "uid": "tha-ap425",
  "title": "Ekāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap425:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap425:1.2",
      "pali": "gosito nāma pabbato;"
    },
    {
      "id": "tha-ap425:1.3",
      "pali": "Assamo sukato mayhaṁ,"
    },
    {
      "id": "tha-ap425:1.4",
      "pali": "paṇṇasālā sumāpitā."
    },
    {
      "id": "tha-ap425:2.1",
      "pali": "Nārado nāma nāmena,"
    },
    {
      "id": "tha-ap425:2.2",
      "pali": "kassapo iti maṁ vidū;"
    },
    {
      "id": "tha-ap425:2.3",
      "pali": "Suddhimaggaṁ gavesanto,"
    },
    {
      "id": "tha-ap425:2.4",
      "pali": "vasāmi gosite tadā."
    },
    {
      "id": "tha-ap425:3.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap425:3.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap425:3.3",
      "pali": "Vivekakāmo sambuddho,"
    },
    {
      "id": "tha-ap425:3.4",
      "pali": "agañchi anilañjasā."
    },
    {
      "id": "tha-ap425:4.1",
      "pali": "Vanagge gacchamānassa,"
    },
    {
      "id": "tha-ap425:4.2",
      "pali": "disvā raṁsiṁ mahesino;"
    },
    {
      "id": "tha-ap425:4.3",
      "pali": "Kaṭṭhamañcaṁ paññāpetvā,"
    },
    {
      "id": "tha-ap425:4.4",
      "pali": "ajinañca apatthariṁ."
    },
    {
      "id": "tha-ap425:5.1",
      "pali": "Āsanaṁ paññapetvāna,"
    },
    {
      "id": "tha-ap425:5.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap425:5.3",
      "pali": "Somanassaṁ paveditvā,"
    },
    {
      "id": "tha-ap425:5.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap425:6.1",
      "pali": "‘Sallakatto mahāvīra,"
    },
    {
      "id": "tha-ap425:6.2",
      "pali": "āturānaṁ tikicchako;"
    },
    {
      "id": "tha-ap425:6.3",
      "pali": "Mamaṁ rogaparetassa,"
    },
    {
      "id": "tha-ap425:6.4",
      "pali": "tikicchaṁ dehi nāyaka."
    },
    {
      "id": "tha-ap425:7.1",
      "pali": "Kallatthikā ye passanti,"
    },
    {
      "id": "tha-ap425:7.2",
      "pali": "buddhaseṭṭha tuvaṁ mune;"
    },
    {
      "id": "tha-ap425:7.3",
      "pali": "Dhuvatthasiddhiṁ papponti,"
    },
    {
      "id": "tha-ap425:7.4",
      "pali": "etesaṁ ajaro bhave."
    },
    {
      "id": "tha-ap425:8.1",
      "pali": "Na me deyyadhammo atthi,"
    },
    {
      "id": "tha-ap425:8.2",
      "pali": "pavattaphalabhojihaṁ;"
    },
    {
      "id": "tha-ap425:8.3",
      "pali": "Idaṁ me āsanaṁ atthi,"
    },
    {
      "id": "tha-ap425:8.4",
      "pali": "nisīda kaṭṭhamañcake’."
    },
    {
      "id": "tha-ap425:9.1",
      "pali": "Nisīdi tattha bhagavā,"
    },
    {
      "id": "tha-ap425:9.2",
      "pali": "asambhītova kesarī;"
    },
    {
      "id": "tha-ap425:9.3",
      "pali": "Muhuttaṁ vītināmetvā,"
    },
    {
      "id": "tha-ap425:9.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "tha-ap425:10.1",
      "pali": "‘Vissattho hohi mā bhāyi,"
    },
    {
      "id": "tha-ap425:10.2",
      "pali": "laddho jotiraso tayā;"
    },
    {
      "id": "tha-ap425:10.3",
      "pali": "Yaṁ tuyhaṁ patthitaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap425:10.4",
      "pali": "paripūrissatināgate."
    },
    {
      "id": "tha-ap425:11.1",
      "pali": "Na moghaṁ taṁ kataṁ tuyhaṁ,"
    },
    {
      "id": "tha-ap425:11.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "tha-ap425:11.3",
      "pali": "Sakkā uddharituṁ attā,"
    },
    {
      "id": "tha-ap425:11.4",
      "pali": "yassa cittaṁ paṇīhitaṁ."
    },
    {
      "id": "tha-ap425:12.1",
      "pali": "Imināsanadānena,"
    },
    {
      "id": "tha-ap425:12.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap425:12.3",
      "pali": "Kappasatasahassāni,"
    },
    {
      "id": "tha-ap425:12.4",
      "pali": "vinipātaṁ na gacchasi."
    },
    {
      "id": "tha-ap425:13.1",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap425:13.2",
      "pali": "devarajjaṁ karissasi;"
    },
    {
      "id": "tha-ap425:13.3",
      "pali": "Asītikkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap425:13.4",
      "pali": "cakkavattī bhavissasi."
    },
    {
      "id": "tha-ap425:14.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap425:14.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap425:14.3",
      "pali": "Sabbattha sukhito hutvā,"
    },
    {
      "id": "tha-ap425:14.4",
      "pali": "saṁsāre saṁsarissasi’."
    },
    {
      "id": "tha-ap425:15.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap425:15.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap425:15.3",
      "pali": "Nabhaṁ abbhuggamī vīro,"
    },
    {
      "id": "tha-ap425:15.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap425:16.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap425:16.2",
      "pali": "sarathaṁ sandamānikaṁ;"
    },
    {
      "id": "tha-ap425:16.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "tha-ap425:16.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap425:17.1",
      "pali": "Kānanaṁ pavisitvāpi,"
    },
    {
      "id": "tha-ap425:17.2",
      "pali": "yadā icchāmi āsanaṁ;"
    },
    {
      "id": "tha-ap425:17.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap425:17.4",
      "pali": "pallaṅko upatiṭṭhati."
    },
    {
      "id": "tha-ap425:18.1",
      "pali": "Vārimajjhagato santo,"
    },
    {
      "id": "tha-ap425:18.2",
      "pali": "yadā icchāmi āsanaṁ;"
    },
    {
      "id": "tha-ap425:18.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap425:18.4",
      "pali": "pallaṅko upatiṭṭhati."
    },
    {
      "id": "tha-ap425:19.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap425:19.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap425:19.3",
      "pali": "Pallaṅkasatasahassāni,"
    },
    {
      "id": "tha-ap425:19.4",
      "pali": "parivārenti maṁ sadā."
    },
    {
      "id": "tha-ap425:20.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap425:20.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap425:20.3",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap425:20.4",
      "pali": "khattiye atha brāhmaṇe."
    },
    {
      "id": "tha-ap425:21.1",
      "pali": "Ekāsanaṁ daditvāna,"
    },
    {
      "id": "tha-ap425:21.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "tha-ap425:21.3",
      "pali": "Dhammapallaṅkamādāya,"
    },
    {
      "id": "tha-ap425:21.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap425:22.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap425:22.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap425:22.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap425:22.4",
      "pali": "ekāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap425:23.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap425:23.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap425:23.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap425:24.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap425:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap425:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap425:25.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap425:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap425:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap425:26.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap425:27.1",
      "pali": "Ekāsanadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
