{
  "uid": "kp2",
  "title": "Dasasikkhāpada",
  "nikaya": "kn",
  "segments": [
    {
      "id": "kp2:1.1",
      "pali": "Pāṇātipātā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:2.1",
      "pali": "Adinnādānā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:3.1",
      "pali": "Abrahmacariyā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:4.1",
      "pali": "Musāvādā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:5.1",
      "pali": "Surāmerayamajjapamādaṭṭhānā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:6.1",
      "pali": "Vikālabhojanā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:7.1",
      "pali": "Naccagītavāditavisūkadassanā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:8.1",
      "pali": "Mālāgandhavilepanadhāraṇamaṇḍanavibhūsanaṭṭhānā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:9.1",
      "pali": "Uccāsayanamahāsayanā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:10.1",
      "pali": "Jātarūparajatapaṭiggahaṇā veramaṇisikkhāpadaṁ samādiyāmi."
    },
    {
      "id": "kp2:11.1",
      "pali": "Dasasikkhāpadaṁ."
    }
  ]
}
