{
  "uid": "snp4.1",
  "title": "Kāmasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.1:1.1",
      "pali": "Kāmaṁ kāmayamānassa,"
    },
    {
      "id": "snp4.1:1.2",
      "pali": "tassa ce taṁ samijjhati;"
    },
    {
      "id": "snp4.1:1.3",
      "pali": "Addhā pītimano hoti,"
    },
    {
      "id": "snp4.1:1.4",
      "pali": "laddhā macco yadicchati."
    },
    {
      "id": "snp4.1:2.1",
      "pali": "Tassa ce kāmayānassa,"
    },
    {
      "id": "snp4.1:2.2",
      "pali": "chandajātassa jantuno;"
    },
    {
      "id": "snp4.1:2.3",
      "pali": "Te kāmā parihāyanti,"
    },
    {
      "id": "snp4.1:2.4",
      "pali": "sallaviddhova ruppati."
    },
    {
      "id": "snp4.1:3.1",
      "pali": "Yo kāme parivajjeti,"
    },
    {
      "id": "snp4.1:3.2",
      "pali": "sappasseva padā siro;"
    },
    {
      "id": "snp4.1:3.3",
      "pali": "Somaṁ visattikaṁ loke,"
    },
    {
      "id": "snp4.1:3.4",
      "pali": "sato samativattati."
    },
    {
      "id": "snp4.1:4.1",
      "pali": "Khettaṁ vatthuṁ hiraññaṁ vā,"
    },
    {
      "id": "snp4.1:4.2",
      "pali": "gavāssaṁ dāsaporisaṁ;"
    },
    {
      "id": "snp4.1:4.3",
      "pali": "Thiyo bandhū puthu kāme,"
    },
    {
      "id": "snp4.1:4.4",
      "pali": "yo naro anugijjhati."
    },
    {
      "id": "snp4.1:5.1",
      "pali": "Abalā naṁ balīyanti,"
    },
    {
      "id": "snp4.1:5.2",
      "pali": "maddantenaṁ parissayā;"
    },
    {
      "id": "snp4.1:5.3",
      "pali": "Tato naṁ dukkhamanveti,"
    },
    {
      "id": "snp4.1:5.4",
      "pali": "nāvaṁ bhinnamivodakaṁ."
    },
    {
      "id": "snp4.1:6.1",
      "pali": "Tasmā jantu sadā sato,"
    },
    {
      "id": "snp4.1:6.2",
      "pali": "Kāmāni parivajjaye;"
    },
    {
      "id": "snp4.1:6.3",
      "pali": "Te pahāya tare oghaṁ,"
    },
    {
      "id": "snp4.1:6.4",
      "pali": "Nāvaṁ sitvāva pāragūti."
    },
    {
      "id": "snp4.1:6.5",
      "pali": "Kāmasuttaṁ paṭhamaṁ."
    }
  ]
}
