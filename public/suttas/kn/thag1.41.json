{
  "uid": "thag1.41",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.41:1.1",
      "pali": "“Vivaramanupatanti vijjutā,"
    },
    {
      "id": "thag1.41:1.2",
      "pali": "Vebhārassa ca paṇḍavassa ca;"
    },
    {
      "id": "thag1.41:1.3",
      "pali": "Nagavivaragato ca jhāyati,"
    },
    {
      "id": "thag1.41:1.4",
      "pali": "Putto appaṭimassa tādino”ti."
    },
    {
      "id": "thag1.41:1.5",
      "pali": "… Sirivaḍḍho thero …."
    }
  ]
}
