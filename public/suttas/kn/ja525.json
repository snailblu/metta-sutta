    },
    {
      "id": "ja525:47.1",
      "pali": "Ayamassa pokkharaṇī,"
    },
    {
      "id": "ja525:47.2",
      "pali": "Sañchannā aṇḍajehi vītikiṇṇā;"
    },
    {
      "id": "ja525:47.3",
      "pali": "Yahimanuvicari rājā,"
    },
    {
      "id": "ja525:47.4",
      "pali": "Parikiṇṇo itthāgārehi."
    },
    {
      "id": "ja525:48.1",
      "pali": "Ayamassa pokkharaṇī,"
    },
    {
      "id": "ja525:48.2",
      "pali": "Sañchannā aṇḍajehi vītikiṇṇā;"
    },
    {
      "id": "ja525:48.3",
      "pali": "Yahimanuvicari rājā,"
    },
    {
      "id": "ja525:48.4",
      "pali": "Parikiṇṇo ñātisaṅghena."
    },
    {
      "id": "ja525:49.1",
      "pali": "Rājā vo kho pabbajito,"
    },
    {
      "id": "ja525:49.2",
      "pali": "Sutasomo rajjaṁ imaṁ pahatvāna;"
    },
    {
      "id": "ja525:49.3",
      "pali": "Kāsāyavatthavasano,"
    },
    {
      "id": "ja525:49.4",
      "pali": "Nāgova ekako carati”."
    },
    {
      "id": "ja525:50.1",
      "pali": "“Māssu pubbe ratikīḷitāni,"
    },
    {
      "id": "ja525:50.2",
      "pali": "Hasitāni ca anussarittha;"
    },
    {
      "id": "ja525:50.3",
      "pali": "Mā vo kāmā haniṁsu,"
    },
    {
      "id": "ja525:50.4",
      "pali": "Rammaṁ hi sudassanaṁ nagaraṁ."
    },
    {
      "id": "ja525:51.1",
      "pali": "Mettacittañca bhāvetha,"
    },
    {
      "id": "ja525:51.2",
      "pali": "Appamāṇaṁ divā ca ratto ca;"
    },
    {
      "id": "ja525:51.3",
      "pali": "Agacchittha devapuraṁ,"
    },
    {
      "id": "ja525:51.4",
      "pali": "Āvāsaṁ puññakamminan”ti."
    },
    {
      "id": "ja525:52.1",
      "pali": "Cūḷasutasomajātakaṁ pañcamaṁ."
    },
    {
      "id": "ja525:53.1",
      "pali": "Cattālīsanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja525:54.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja525:55.1",
      "pali": "Suvapaṇḍitajambukakuṇḍalino,"
    },
    {
      "id": "ja525:55.2",
      "pali": "Varakaññamalambusajātakañca;"
    },
    {
      "id": "ja525:55.3",
      "pali": "Pavaruttamasaṅkhasirīvhayako,"
    },
    {
      "id": "ja525:55.4",
      "pali": "Sutasomaarindhamarājavaro."
    }
  ]
}
