{
  "uid": "tha-ap69",
  "title": "Vatthadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap69:1.1",
      "pali": "“Pakkhijāto tadā āsiṁ,"
    },
    {
      "id": "tha-ap69:1.2",
      "pali": "supaṇṇo garuḷādhipo;"
    },
    {
      "id": "tha-ap69:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap69:1.4",
      "pali": "gacchantaṁ gandhamādanaṁ."
    },
    {
      "id": "tha-ap69:2.1",
      "pali": "Jahitvā garuḷavaṇṇaṁ,"
    },
    {
      "id": "tha-ap69:2.2",
      "pali": "māṇavakaṁ adhārayiṁ;"
    },
    {
      "id": "tha-ap69:2.3",
      "pali": "Ekaṁ vatthaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap69:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap69:3.1",
      "pali": "Tañca dussaṁ paṭiggayha,"
    },
    {
      "id": "tha-ap69:3.2",
      "pali": "buddho lokagganāyako;"
    },
    {
      "id": "tha-ap69:3.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap69:3.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap69:4.1",
      "pali": "‘Iminā vatthadānena,"
    },
    {
      "id": "tha-ap69:4.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap69:4.3",
      "pali": "Pahāya garuḷaṁ yoniṁ,"
    },
    {
      "id": "tha-ap69:4.4",
      "pali": "devaloke ramissati’."
    },
    {
      "id": "tha-ap69:5.1",
      "pali": "Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap69:5.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap69:5.3",
      "pali": "Vatthadānaṁ pasaṁsitvā,"
    },
    {
      "id": "tha-ap69:5.4",
      "pali": "pakkāmi uttarāmukho."
    },
    {
      "id": "tha-ap69:6.1",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap69:6.2",
      "pali": "honti me vatthasampadā;"
    },
    {
      "id": "tha-ap69:6.3",
      "pali": "Ākāse chadanaṁ hoti,"
    },
    {
      "id": "tha-ap69:6.4",
      "pali": "vatthadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap69:7.1",
      "pali": "Aruṇavā satta janā,"
    },
    {
      "id": "tha-ap69:7.2",
      "pali": "cakkavattī mahabbalā;"
    },
    {
      "id": "tha-ap69:7.3",
      "pali": "Chattiṁsatimhi āsiṁsu,"
    },
    {
      "id": "tha-ap69:7.4",
      "pali": "kappamhi manujādhipā."
    },
    {
      "id": "tha-ap69:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap69:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap69:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap69:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā vatthadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap69:10.1",
      "pali": "Vatthadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
