{
  "uid": "pv31",
  "title": "6. Seriṇīpetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv31:1.1",
      "pali": "“Naggā dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv31:1.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv31:1.3",
      "pali": "Upphāsulike kisike,"
    },
    {
      "id": "pv31:1.4",
      "pali": "kā nu tvaṁ idha tiṭṭhasī”ti."
    },
    {
      "id": "pv31:2.1",
      "pali": "“Ahaṁ bhadante petīmhi,"
    },
    {
      "id": "pv31:2.2",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv31:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv31:2.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv31:3.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv31:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv31:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv31:3.4",
      "pali": "petalokaṁ ito gatā”ti."
    },
    {
      "id": "pv31:4.1",
      "pali": "“Anāvaṭesu titthesu,"
    },
    {
      "id": "pv31:4.2",
      "pali": "viciniṁ aḍḍhamāsakaṁ;"
    },
    {
      "id": "pv31:4.3",
      "pali": "Santesu deyyadhammesu,"
    },
    {
      "id": "pv31:4.4",
      "pali": "dīpaṁ nākāsimattano."
    },
    {
      "id": "pv31:5.1",
      "pali": "Nadiṁ upemi tasitā,"
    },
    {
      "id": "pv31:5.2",
      "pali": "rittakā parivattati;"
    },
    {
      "id": "pv31:5.3",
      "pali": "Chāyaṁ upemi uṇhesu,"
    },
    {
      "id": "pv31:5.4",
      "pali": "ātapo parivattati."
    },
    {
      "id": "pv31:6.1",
      "pali": "Aggivaṇṇo ca me vāto,"
    },
    {
      "id": "pv31:6.2",
      "pali": "ḍahanto upavāyati;"
    },
    {
      "id": "pv31:6.3",
      "pali": "Etañca bhante arahāmi,"
    },
    {
      "id": "pv31:6.4",
      "pali": "aññañca pāpakaṁ tato."
    },
    {
      "id": "pv31:7.1",
      "pali": "Gantvāna hatthiniṁ puraṁ,"
    },
    {
      "id": "pv31:7.2",
      "pali": "vajjesi mayha mātaraṁ;"
    },
    {
      "id": "pv31:7.3",
      "pali": "‘Dhītā ca te mayā diṭṭhā,"
    },
    {
      "id": "pv31:7.4",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv31:7.5",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv31:7.6",
      "pali": "petalokaṁ ito gatā’."
    },
    {
      "id": "pv31:8.1",
      "pali": "Atthi me ettha nikkhittaṁ,"
    },
    {
      "id": "pv31:8.2",
      "pali": "anakkhātañca taṁ mayā;"
    },
    {
      "id": "pv31:8.3",
      "pali": "Cattārisatasahassāni,"
    },
    {
      "id": "pv31:8.4",
      "pali": "pallaṅkassa ca heṭṭhato."
    },
    {
      "id": "pv31:9.1",
      "pali": "Tato me dānaṁ dadatu,"
    },
    {
      "id": "pv31:9.2",
      "pali": "tassā ca hotu jīvikā;"
    },
    {
      "id": "pv31:9.3",
      "pali": "Dānaṁ datvā ca me mātā,"
    },
    {
      "id": "pv31:9.4",
      "pali": "dakkhiṇaṁ anudicchatu;"
    },
    {
      "id": "pv31:9.5",
      "pali": "Tadāhaṁ sukhitā hessaṁ,"
    },
    {
      "id": "pv31:9.6",
      "pali": "sabbakāmasamiddhinī”ti."
    },
    {
      "id": "pv31:10.1",
      "pali": "“Sādhū”ti so paṭissutvā,"
    },
    {
      "id": "pv31:10.2",
      "pali": "gantvāna hatthiniṁ puraṁ;"
    },
    {
      "id": "pv31:10.3",
      "pali": "Avoca tassā mātaraṁ—"
    },
    {
      "id": "pv31:11.1",
      "pali": "“Dhītā ca te mayā diṭṭhā,"
    },
    {
      "id": "pv31:11.2",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv31:11.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv31:11.4",
      "pali": "petalokaṁ ito gatā."
    },
    {
      "id": "pv31:12.1",
      "pali": "Sā maṁ tattha samādapesi, (…)"
    },
    {
      "id": "pv31:12.2",
      "pali": "Vajjesi mayha mātaraṁ;"
    },
    {
      "id": "pv31:12.3",
      "pali": "‘Dhītā ca te mayā diṭṭhā,"
    },
    {
      "id": "pv31:12.4",
      "pali": "Duggatā yamalokikā;"
    },
    {
      "id": "pv31:12.5",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv31:12.6",
      "pali": "Petalokaṁ ito gatā."
    },
    {
      "id": "pv31:13.1",
      "pali": "Atthi ca me ettha nikkhittaṁ,"
    },
    {
      "id": "pv31:13.2",
      "pali": "anakkhātañca taṁ mayā;"
    },
    {
      "id": "pv31:13.3",
      "pali": "Cattārisatasahassāni,"
    },
    {
      "id": "pv31:13.4",
      "pali": "pallaṅkassa ca heṭṭhato."
    },
    {
      "id": "pv31:14.1",
      "pali": "Tato me dānaṁ dadatu,"
    },
    {
      "id": "pv31:14.2",
      "pali": "tassā ca hotu jīvikā;"
    },
    {
      "id": "pv31:14.3",
      "pali": "Dānaṁ datvā ca me mātā,"
    },
    {
      "id": "pv31:14.4",
      "pali": "dakkhiṇaṁ anudicchatu (…);"
    },
    {
      "id": "pv31:14.5",
      "pali": "Tadāhaṁ sukhitā hessaṁ,"
    },
    {
      "id": "pv31:14.6",
      "pali": "sabbakāmasamiddhinī’”ti."
    },
    {
      "id": "pv31:15.1",
      "pali": "Tato hi sā dānamadā,"
    },
    {
      "id": "pv31:15.2",
      "pali": "tassā dakkhiṇamādisī;"
    },
    {
      "id": "pv31:15.3",
      "pali": "Petī ca sukhitā āsi,"
    },
    {
      "id": "pv31:15.4",
      "pali": "tassā cāsi sujīvikāti."
    },
    {
      "id": "pv31:16.1",
      "pali": "Seriṇīpetivatthu chaṭṭhaṁ."
    }
  ]
}
