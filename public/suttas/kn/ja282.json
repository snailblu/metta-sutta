{
  "uid": "ja282",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja282:1.1",
      "pali": "“Seyyaṁso seyyaso hoti,"
    },
    {
      "id": "ja282:1.2",
      "pali": "yo seyyamupasevati;"
    },
    {
      "id": "ja282:1.3",
      "pali": "Ekena sandhiṁ katvāna,"
    },
    {
      "id": "ja282:1.4",
      "pali": "sataṁ vajjhe amocayiṁ."
    },
    {
      "id": "ja282:2.1",
      "pali": "Tasmā sabbena lokena,"
    },
    {
      "id": "ja282:2.2",
      "pali": "sandhiṁ katvāna ekato;"
    },
    {
      "id": "ja282:2.3",
      "pali": "Pecca saggaṁ nigaccheyya,"
    },
    {
      "id": "ja282:2.4",
      "pali": "idaṁ suṇātha kāsiyā”."
    },
    {
      "id": "ja282:3.1",
      "pali": "Idaṁ vatvā mahārājā,"
    },
    {
      "id": "ja282:3.2",
      "pali": "Kaṁso bārāṇasiggaho;"
    },
    {
      "id": "ja282:3.3",
      "pali": "Dhanuṁ kaṇḍañca nikkhippa,"
    },
    {
      "id": "ja282:3.4",
      "pali": "Saṁyamaṁ ajjhupāgamīti."
    },
    {
      "id": "ja282:4.1",
      "pali": "Seyyajātakaṁ dutiyaṁ."
    }
  ]
}
