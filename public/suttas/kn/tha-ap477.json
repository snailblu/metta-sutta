{
  "uid": "tha-ap477",
  "title": "Kummāsadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap477:1.1",
      "pali": "“Esanāya carantassa,"
    },
    {
      "id": "tha-ap477:1.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap477:1.3",
      "pali": "Rittakaṁ pattaṁ disvāna,"
    },
    {
      "id": "tha-ap477:1.4",
      "pali": "kummāsaṁ pūrayiṁ ahaṁ."
    },
    {
      "id": "tha-ap477:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap477:2.2",
      "pali": "yaṁ bhikkhaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap477:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap477:2.4",
      "pali": "kummāsassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap477:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap477:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap477:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap477:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap477:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap477:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap477:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap477:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap477:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap477:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kummāsadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap477:7.1",
      "pali": "Kummāsadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
