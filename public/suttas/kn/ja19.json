{
  "uid": "ja19",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja19:1.1",
      "pali": "“Sace mucce pecca mucce,"
    },
    {
      "id": "ja19:1.2",
      "pali": "Muccamāno hi bajjhati;"
    },
    {
      "id": "ja19:1.3",
      "pali": "Na hevaṁ dhīrā muccanti,"
    },
    {
      "id": "ja19:1.4",
      "pali": "Mutti bālassa bandhanan”ti."
    },
    {
      "id": "ja19:2.1",
      "pali": "Āyācitabhattajātakaṁ navamaṁ."
    }
  ]
}
