{
  "uid": "tha-ap169",
  "title": "7 Yūthikapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap169:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap169:1.2",
      "pali": "anusotaṁ vajāmahaṁ;"
    },
    {
      "id": "tha-ap169:1.3",
      "pali": "Sayambhuṁ addasaṁ tattha,"
    },
    {
      "id": "tha-ap169:1.4",
      "pali": "sālarājaṁva phullitaṁ."
    },
    {
      "id": "tha-ap169:2.1",
      "pali": "Pupphaṁ yūthikamādāya,"
    },
    {
      "id": "tha-ap169:2.2",
      "pali": "upagacchiṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap169:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap169:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap169:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap169:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap169:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap169:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap169:4.1",
      "pali": "Sattasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap169:4.2",
      "pali": "eko sāmuddharo ahuṁ;"
    },
    {
      "id": "tha-ap169:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap169:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap169:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap169:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap169:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap169:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā yūthikapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap169:7.1",
      "pali": "Yūthikapupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
