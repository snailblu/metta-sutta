{
  "uid": "snp5.18",
  "title": "Pārāyanatthutigāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.18:1.1",
      "pali": "Idamavoca bhagavā magadhesu viharanto pāsāṇake cetiye,"
    },
    {
      "id": "snp5.18:1.2",
      "pali": "paricārakasoḷasānaṁ brāhmaṇānaṁ ajjhiṭṭho puṭṭho puṭṭho pañhaṁ byākāsi."
    },
    {
      "id": "snp5.18:1.3",
      "pali": "Ekamekassa cepi pañhassa atthamaññāya dhammamaññāya dhammānudhammaṁ paṭipajjeyya, gaccheyyeva jarāmaraṇassa pāraṁ."
    },
    {
      "id": "snp5.18:1.4",
      "pali": "Pāraṅgamanīyā ime dhammāti, tasmā imassa dhammapariyāyassa pārāyananteva adhivacanaṁ."
    },
    {
      "id": "snp5.18:2.1",
      "pali": "Ajito tissametteyyo,"
    },
    {
      "id": "snp5.18:2.2",
      "pali": "puṇṇako atha mettagū;"
    },
    {
      "id": "snp5.18:2.3",
      "pali": "Dhotako upasīvo ca,"
    },
    {
      "id": "snp5.18:2.4",
      "pali": "nando ca atha hemako."
    },
    {
      "id": "snp5.18:3.1",
      "pali": "Todeyya-kappā dubhayo,"
    },
    {
      "id": "snp5.18:3.2",
      "pali": "jatukaṇṇī ca paṇḍito;"
    },
    {
      "id": "snp5.18:3.3",
      "pali": "Bhadrāvudho udayo ca,"
    },
    {
      "id": "snp5.18:3.4",
      "pali": "posālo cāpi brāhmaṇo;"
    },
    {
      "id": "snp5.18:3.5",
      "pali": "Mogharājā ca medhāvī,"
    },
    {
      "id": "snp5.18:3.6",
      "pali": "piṅgiyo ca mahāisi."
    },
    {
      "id": "snp5.18:4.1",
      "pali": "Ete buddhaṁ upāgacchuṁ,"
    },
    {
      "id": "snp5.18:4.2",
      "pali": "sampannacaraṇaṁ isiṁ;"
    },
    {
      "id": "snp5.18:4.3",
      "pali": "Pucchantā nipuṇe pañhe,"
    },
    {
      "id": "snp5.18:4.4",
      "pali": "buddhaseṭṭhaṁ upāgamuṁ."
    },
    {
      "id": "snp5.18:5.1",
      "pali": "Tesaṁ buddho pabyākāsi,"
    },
    {
      "id": "snp5.18:5.2",
      "pali": "pañhe puṭṭho yathātathaṁ;"
    },
    {
      "id": "snp5.18:5.3",
      "pali": "Pañhānaṁ veyyākaraṇena,"
    },
    {
      "id": "snp5.18:5.4",
      "pali": "tosesi brāhmaṇe muni."
    },
    {
      "id": "snp5.18:6.1",
      "pali": "Te tositā cakkhumatā,"
    },
    {
      "id": "snp5.18:6.2",
      "pali": "buddhenādiccabandhunā;"
    },
    {
      "id": "snp5.18:6.3",
      "pali": "Brahmacariyamacariṁsu,"
    },
    {
      "id": "snp5.18:6.4",
      "pali": "varapaññassa santike."
    },
    {
      "id": "snp5.18:7.1",
      "pali": "Ekamekassa pañhassa,"
    },
    {
      "id": "snp5.18:7.2",
      "pali": "yathā buddhena desitaṁ;"
    },
    {
      "id": "snp5.18:7.3",
      "pali": "Tathā yo paṭipajjeyya,"
    },
    {
      "id": "snp5.18:7.4",
      "pali": "gacche pāraṁ apārato."
    },
    {
      "id": "snp5.18:8.1",
      "pali": "Apārā pāraṁ gaccheyya,"
    },
    {
      "id": "snp5.18:8.2",
      "pali": "bhāvento maggamuttamaṁ;"
    },
    {
      "id": "snp5.18:8.3",
      "pali": "Maggo so pāraṁ gamanāya,"
    },
    {
      "id": "snp5.18:8.4",
      "pali": "tasmā pārāyanaṁ iti."
    }
  ]
}
