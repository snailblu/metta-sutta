{
  "uid": "thi-ap8",
  "title": "Sattuppalamālikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap8:1.1",
      "pali": "“Nagare aruṇavatiyā,"
    },
    {
      "id": "thi-ap8:1.2",
      "pali": "aruṇo nāma khattiyo;"
    },
    {
      "id": "thi-ap8:1.3",
      "pali": "Tassa rañño ahuṁ bhariyā,"
    },
    {
      "id": "thi-ap8:1.4",
      "pali": "vāritaṁ vārayāmahaṁ."
    },
    {
      "id": "thi-ap8:2.1",
      "pali": "Satta mālā gahetvāna,"
    },
    {
      "id": "thi-ap8:2.2",
      "pali": "uppalā devagandhikā;"
    },
    {
      "id": "thi-ap8:2.3",
      "pali": "Nisajja pāsādavare,"
    },
    {
      "id": "thi-ap8:2.4",
      "pali": "evaṁ cintesi tāvade."
    },
    {
      "id": "thi-ap8:3.1",
      "pali": "‘Kiṁ me imāhi mālāhi,"
    },
    {
      "id": "thi-ap8:3.2",
      "pali": "sirasāropitāhi me;"
    },
    {
      "id": "thi-ap8:3.3",
      "pali": "Varaṁ me buddhaseṭṭhassa,"
    },
    {
      "id": "thi-ap8:3.4",
      "pali": "ñāṇamhi abhiropitaṁ’."
    },
    {
      "id": "thi-ap8:4.1",
      "pali": "Sambuddhaṁ paṭimānentī,"
    },
    {
      "id": "thi-ap8:4.2",
      "pali": "dvārāsanne nisīdahaṁ;"
    },
    {
      "id": "thi-ap8:4.3",
      "pali": "‘Yadā ehiti sambuddho,"
    },
    {
      "id": "thi-ap8:4.4",
      "pali": "pūjayissaṁ mahāmuniṁ’."
    },
    {
      "id": "thi-ap8:5.1",
      "pali": "Kakudho vilasantova,"
    },
    {
      "id": "thi-ap8:5.2",
      "pali": "migarājāva kesarī;"
    },
    {
      "id": "thi-ap8:5.3",
      "pali": "Bhikkhusaṅghena sahito,"
    },
    {
      "id": "thi-ap8:5.4",
      "pali": "āgacchi vīthiyā jino."
    },
    {
      "id": "thi-ap8:6.1",
      "pali": "Buddhassa raṁsiṁ disvāna,"
    },
    {
      "id": "thi-ap8:6.2",
      "pali": "haṭṭhā saṁviggamānasā;"
    },
    {
      "id": "thi-ap8:6.3",
      "pali": "Dvāraṁ avāpuritvāna,"
    },
    {
      "id": "thi-ap8:6.4",
      "pali": "buddhaseṭṭhamapūjayiṁ."
    },
    {
      "id": "thi-ap8:7.1",
      "pali": "Satta uppalapupphāni,"
    },
    {
      "id": "thi-ap8:7.2",
      "pali": "parikiṇṇāni ambare;"
    },
    {
      "id": "thi-ap8:7.3",
      "pali": "Chadiṁ karonto buddhassa,"
    },
    {
      "id": "thi-ap8:7.4",
      "pali": "matthake dhārayanti te."
    },
    {
      "id": "thi-ap8:8.1",
      "pali": "Udaggacittā sumanā,"
    },
    {
      "id": "thi-ap8:8.2",
      "pali": "vedajātā katañjalī;"
    },
    {
      "id": "thi-ap8:8.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "thi-ap8:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap8:9.1",
      "pali": "Mahānelassa chādanaṁ,"
    },
    {
      "id": "thi-ap8:9.2",
      "pali": "dhārenti mama muddhani;"
    },
    {
      "id": "thi-ap8:9.3",
      "pali": "Dibbagandhaṁ pavāyāmi,"
    },
    {
      "id": "thi-ap8:9.4",
      "pali": "sattuppalassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap8:10.1",
      "pali": "Kadāci nīyamānāya,"
    },
    {
      "id": "thi-ap8:10.2",
      "pali": "ñātisaṅghena me tadā;"
    },
    {
      "id": "thi-ap8:10.3",
      "pali": "Yāvatā parisā mayhaṁ,"
    },
    {
      "id": "thi-ap8:10.4",
      "pali": "mahānelaṁ dharīyati."
    },
    {
      "id": "thi-ap8:11.1",
      "pali": "Sattatidevarājūnaṁ,"
    },
    {
      "id": "thi-ap8:11.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap8:11.3",
      "pali": "Sabbattha issarā hutvā,"
    },
    {
      "id": "thi-ap8:11.4",
      "pali": "saṁsarāmi bhavābhave."
    },
    {
      "id": "thi-ap8:12.1",
      "pali": "Tesaṭṭhi cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap8:12.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap8:12.3",
      "pali": "Sabbe mamanuvattanti,"
    },
    {
      "id": "thi-ap8:12.4",
      "pali": "ādeyyavacanā ahuṁ."
    },
    {
      "id": "thi-ap8:13.1",
      "pali": "Uppalasseva me vaṇṇo,"
    },
    {
      "id": "thi-ap8:13.2",
      "pali": "gandho ceva pavāyati;"
    },
    {
      "id": "thi-ap8:13.3",
      "pali": "Dubbaṇṇiyaṁ na jānāmi,"
    },
    {
      "id": "thi-ap8:13.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap8:14.1",
      "pali": "Iddhipādesu kusalā,"
    },
    {
      "id": "thi-ap8:14.2",
      "pali": "bojjhaṅgabhāvanāratā;"
    },
    {
      "id": "thi-ap8:14.3",
      "pali": "Abhiññāpāramippattā,"
    },
    {
      "id": "thi-ap8:14.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap8:15.1",
      "pali": "Satipaṭṭhānakusalā,"
    },
    {
      "id": "thi-ap8:15.2",
      "pali": "samādhijhānagocarā;"
    },
    {
      "id": "thi-ap8:15.3",
      "pali": "Sammappadhānamanuyuttā,"
    },
    {
      "id": "thi-ap8:15.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap8:16.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "thi-ap8:16.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "thi-ap8:16.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap8:16.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap8:17.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "thi-ap8:17.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "thi-ap8:17.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap8:17.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap8:18.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap8:18.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap8:18.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap8:19.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap8:19.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap8:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap8:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap8:20.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap8:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap8:21.1",
      "pali": "Itthaṁ sudaṁ sattuppalamālikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap8:22.1",
      "pali": "Sattuppalamālikātheriyāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
