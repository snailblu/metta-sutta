{
  "uid": "ja52",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja52:1.1",
      "pali": "“Vāyametheva puriso,"
    },
    {
      "id": "ja52:1.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja52:1.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja52:1.4",
      "pali": "udakā thalamubbhatan”ti."
    },
    {
      "id": "ja52:2.1",
      "pali": "Cūḷajanakajātakaṁ dutiyaṁ."
    }
  ]
}
