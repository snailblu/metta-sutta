{
  "uid": "thag2.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.10:1.1",
      "pali": "“Pubbe hanati attānaṁ,"
    },
    {
      "id": "thag2.10:1.2",
      "pali": "pacchā hanati so pare;"
    },
    {
      "id": "thag2.10:1.3",
      "pali": "Suhataṁ hanti attānaṁ,"
    },
    {
      "id": "thag2.10:1.4",
      "pali": "vītaṁseneva pakkhimā."
    },
    {
      "id": "thag2.10:2.1",
      "pali": "Na brāhmaṇo bahivaṇṇo,"
    },
    {
      "id": "thag2.10:2.2",
      "pali": "anto vaṇṇo hi brāhmaṇo;"
    },
    {
      "id": "thag2.10:2.3",
      "pali": "Yasmiṁ pāpāni kammāni,"
    },
    {
      "id": "thag2.10:2.4",
      "pali": "sa ve kaṇho sujampatī”ti."
    },
    {
      "id": "thag2.10:2.5",
      "pali": "… Vasabho thero …"
    },
    {
      "id": "thag2.10:2.6",
      "pali": "vaggo paṭhamo."
    },
    {
      "id": "thag2.10:3.1",
      "pali": "Uttaro ceva piṇḍolo,"
    },
    {
      "id": "thag2.10:3.2",
      "pali": "valliyo tīriyo isi;"
    },
    {
      "id": "thag2.10:3.3",
      "pali": "Ajino ca meḷajino,"
    },
    {
      "id": "thag2.10:3.4",
      "pali": "rādho surādho gotamo;"
    },
    {
      "id": "thag2.10:3.5",
      "pali": "Vasabhena ime honti,"
    },
    {
      "id": "thag2.10:3.6",
      "pali": "dasa therā mahiddhikāti."
    }
  ]
}
