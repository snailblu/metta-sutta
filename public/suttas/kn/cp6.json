{
  "uid": "cp6",
  "title": "Dānapāramī 6",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp6:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp6:1.2",
      "pali": "mithilāyaṁ puruttame;"
    },
    {
      "id": "cp6:1.3",
      "pali": "Nimi nāma mahārājā,"
    },
    {
      "id": "cp6:1.4",
      "pali": "paṇḍito kusalatthiko."
    },
    {
      "id": "cp6:2.1",
      "pali": "Tadāhaṁ māpayitvāna,"
    },
    {
      "id": "cp6:2.2",
      "pali": "catussālaṁ catummukhaṁ;"
    },
    {
      "id": "cp6:2.3",
      "pali": "Tattha dānaṁ pavattesiṁ,"
    },
    {
      "id": "cp6:2.4",
      "pali": "migapakkhinarādinaṁ."
    },
    {
      "id": "cp6:3.1",
      "pali": "Acchādanañca sayanaṁ,"
    },
    {
      "id": "cp6:3.2",
      "pali": "annaṁ pānañca bhojanaṁ;"
    },
    {
      "id": "cp6:3.3",
      "pali": "Abbocchinnaṁ karitvāna,"
    },
    {
      "id": "cp6:3.4",
      "pali": "mahādānaṁ pavattayiṁ."
    },
    {
      "id": "cp6:4.1",
      "pali": "Yathāpi sevako sāmiṁ,"
    },
    {
      "id": "cp6:4.2",
      "pali": "dhanahetumupāgato;"
    },
    {
      "id": "cp6:4.3",
      "pali": "Kāyena vācā manasā,"
    },
    {
      "id": "cp6:4.4",
      "pali": "ārādhanīyamesati."
    },
    {
      "id": "cp6:5.1",
      "pali": "Tathevāhaṁ sabbabhave,"
    },
    {
      "id": "cp6:5.2",
      "pali": "pariyesissāmi bodhijaṁ;"
    },
    {
      "id": "cp6:5.3",
      "pali": "Dānena satte tappetvā,"
    },
    {
      "id": "cp6:5.4",
      "pali": "icchāmi bodhimuttaman”ti."
    },
    {
      "id": "cp6:6.1",
      "pali": "Nimirājacariyaṁ chaṭṭhaṁ."
    }
  ]
}
