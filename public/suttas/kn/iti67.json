{
  "uid": "iti67",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti67:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti67:2.1",
      "pali": "“Tīṇimāni, bhikkhave, moneyyāni."
    },
    {
      "id": "iti67:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti67:2.3",
      "pali": "Kāyamoneyyaṁ, vacīmoneyyaṁ, manomoneyyaṁ—"
    },
    {
      "id": "iti67:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi moneyyānī”ti."
    },
    {
      "id": "iti67:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti67:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti67:3.1",
      "pali": "“Kāyamuniṁ vacīmuniṁ,"
    },
    {
      "id": "iti67:3.2",
      "pali": "manomunimanāsavaṁ;"
    },
    {
      "id": "iti67:3.3",
      "pali": "Muniṁ moneyyasampannaṁ,"
    },
    {
      "id": "iti67:3.4",
      "pali": "āhu ninhātapāpakan”ti."
    },
    {
      "id": "iti67:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti67:4.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
