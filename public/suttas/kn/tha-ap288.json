{
  "uid": "tha-ap288",
  "title": "6 Upaṭṭhākadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap288:1.1",
      "pali": "“Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap288:1.2",
      "pali": "āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap288:1.3",
      "pali": "Dvipadindaṁ mahānāgaṁ,"
    },
    {
      "id": "tha-ap288:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap288:2.1",
      "pali": "Pakkosāpiya tassāhaṁ,"
    },
    {
      "id": "tha-ap288:2.2",
      "pali": "sabbalokahitesino;"
    },
    {
      "id": "tha-ap288:2.3",
      "pali": "Upaṭṭhāko mayā dinno,"
    },
    {
      "id": "tha-ap288:2.4",
      "pali": "siddhatthassa mahesino."
    },
    {
      "id": "tha-ap288:3.1",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "tha-ap288:3.2",
      "pali": "niyyādesi mahāmuni;"
    },
    {
      "id": "tha-ap288:3.3",
      "pali": "Uṭṭhāya āsanā tamhā,"
    },
    {
      "id": "tha-ap288:3.4",
      "pali": "pakkāmi pācināmukho."
    },
    {
      "id": "tha-ap288:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap288:4.2",
      "pali": "upaṭṭhākamadaṁ tadā;"
    },
    {
      "id": "tha-ap288:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap288:4.4",
      "pali": "upaṭṭhānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap288:5.1",
      "pali": "Sattapaññāsito kappe,"
    },
    {
      "id": "tha-ap288:5.2",
      "pali": "balasenasanāmako;"
    },
    {
      "id": "tha-ap288:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap288:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap288:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap288:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap288:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap288:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā upaṭṭhākadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap288:8.1",
      "pali": "Upaṭṭhākadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
