{
  "uid": "ja345",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja345:1.1",
      "pali": "“Vanaṁ yadaggi dahati,"
    },
    {
      "id": "ja345:1.2",
      "pali": "pāvako kaṇhavattanī;"
    },
    {
      "id": "ja345:1.3",
      "pali": "Kathaṁ karosi pacalaka,"
    },
    {
      "id": "ja345:1.4",
      "pali": "evaṁ dandhaparakkamo”."
    },
    {
      "id": "ja345:2.1",
      "pali": "“Bahūni rukkhachiddāni,"
    },
    {
      "id": "ja345:2.2",
      "pali": "pathabyā vivarāni ca;"
    },
    {
      "id": "ja345:2.3",
      "pali": "Tāni ce nābhisambhoma,"
    },
    {
      "id": "ja345:2.4",
      "pali": "hoti no kālapariyāyo”."
    },
    {
      "id": "ja345:3.1",
      "pali": "“Yo dandhakāle tarati,"
    },
    {
      "id": "ja345:3.2",
      "pali": "taraṇīye ca dandhati;"
    },
    {
      "id": "ja345:3.3",
      "pali": "Sukkhapaṇṇaṁva akkamma,"
    },
    {
      "id": "ja345:3.4",
      "pali": "atthaṁ bhañjati attano."
    },
    {
      "id": "ja345:4.1",
      "pali": "Yo dandhakāle dandheti,"
    },
    {
      "id": "ja345:4.2",
      "pali": "taraṇīye ca tārayi;"
    },
    {
      "id": "ja345:4.3",
      "pali": "Sasīva rattiṁ vibhajaṁ,"
    },
    {
      "id": "ja345:4.4",
      "pali": "tassattho paripūratī”ti."
    },
    {
      "id": "ja345:5.1",
      "pali": "Gajakumbhajātakaṁ pañcamaṁ."
    }
  ]
}
