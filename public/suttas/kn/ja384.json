{
  "uid": "ja384",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja384:1.1",
      "pali": "“Dhammaṁ caratha ñātayo,"
    },
    {
      "id": "ja384:1.2",
      "pali": "Dhammaṁ caratha bhaddaṁ vo;"
    },
    {
      "id": "ja384:1.3",
      "pali": "Dhammacārī sukhaṁ seti,"
    },
    {
      "id": "ja384:1.4",
      "pali": "Asmiṁ loke paramhi ca”."
    },
    {
      "id": "ja384:2.1",
      "pali": "“Bhaddako vatayaṁ pakkhī,"
    },
    {
      "id": "ja384:2.2",
      "pali": "dijo paramadhammiko;"
    },
    {
      "id": "ja384:2.3",
      "pali": "Ekapādena tiṭṭhanto,"
    },
    {
      "id": "ja384:2.4",
      "pali": "dhammamevānusāsati”."
    },
    {
      "id": "ja384:3.1",
      "pali": "“Nāssa sīlaṁ vijānātha,"
    },
    {
      "id": "ja384:3.2",
      "pali": "anaññāya pasaṁsatha;"
    },
    {
      "id": "ja384:3.3",
      "pali": "Bhutvā aṇḍañca potañca,"
    },
    {
      "id": "ja384:3.4",
      "pali": "dhammo dhammoti bhāsati."
    },
    {
      "id": "ja384:4.1",
      "pali": "Aññaṁ bhaṇati vācāya,"
    },
    {
      "id": "ja384:4.2",
      "pali": "aññaṁ kāyena kubbati;"
    },
    {
      "id": "ja384:4.3",
      "pali": "Vācāya no ca kāyena,"
    },
    {
      "id": "ja384:4.4",
      "pali": "na taṁ dhammaṁ adhiṭṭhito."
    },
    {
      "id": "ja384:5.1",
      "pali": "Vācāya sakhilo manoviduggo,"
    },
    {
      "id": "ja384:5.2",
      "pali": "Channo kūpasayova kaṇhasappo;"
    },
    {
      "id": "ja384:5.3",
      "pali": "Dhammadhajo gāmanigamāsu sādhu,"
    },
    {
      "id": "ja384:5.4",
      "pali": "Dujjāno purisena bālisena."
    },
    {
      "id": "ja384:6.1",
      "pali": "Imaṁ tuṇḍehi pakkhehi,"
    },
    {
      "id": "ja384:6.2",
      "pali": "pādā cimaṁ viheṭhatha;"
    },
    {
      "id": "ja384:6.3",
      "pali": "Chavañhimaṁ vināsetha,"
    },
    {
      "id": "ja384:6.4",
      "pali": "nāyaṁ saṁvāsanāraho”ti."
    },
    {
      "id": "ja384:7.1",
      "pali": "Dhammadhajajātakaṁ navamaṁ."
    }
  ]
}
