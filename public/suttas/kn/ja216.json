{
  "uid": "ja216",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja216:1.1",
      "pali": "“Na māyamaggi tapati,"
    },
    {
      "id": "ja216:1.2",
      "pali": "na sūlo sādhutacchito;"
    },
    {
      "id": "ja216:1.3",
      "pali": "Yañca maṁ maññate macchī,"
    },
    {
      "id": "ja216:1.4",
      "pali": "aññaṁ so ratiyā gato."
    },
    {
      "id": "ja216:2.1",
      "pali": "So maṁ dahati rāgaggi,"
    },
    {
      "id": "ja216:2.2",
      "pali": "cittaṁ cūpatapeti maṁ;"
    },
    {
      "id": "ja216:2.3",
      "pali": "Jālino muñcathāyirā maṁ,"
    },
    {
      "id": "ja216:2.4",
      "pali": "na kāme haññate kvacī”ti."
    },
    {
      "id": "ja216:3.1",
      "pali": "Macchajātakaṁ chaṭṭhaṁ."
    }
  ]
}
