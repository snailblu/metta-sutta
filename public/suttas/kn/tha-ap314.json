{
  "uid": "tha-ap314",
  "title": "Bhojanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap314:1.1",
      "pali": "“Sujāto sālalaṭṭhīva,"
    },
    {
      "id": "tha-ap314:1.2",
      "pali": "sobhañjanamivuggato;"
    },
    {
      "id": "tha-ap314:1.3",
      "pali": "Indalaṭṭhirivākāse,"
    },
    {
      "id": "tha-ap314:1.4",
      "pali": "virocati sadā jino."
    },
    {
      "id": "tha-ap314:2.1",
      "pali": "Tassa devātidevassa,"
    },
    {
      "id": "tha-ap314:2.2",
      "pali": "vessabhussa mahesino;"
    },
    {
      "id": "tha-ap314:2.3",
      "pali": "Adāsi bhojanamahaṁ,"
    },
    {
      "id": "tha-ap314:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap314:3.1",
      "pali": "Taṁ me buddho anumodi,"
    },
    {
      "id": "tha-ap314:3.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap314:3.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap314:3.4",
      "pali": "phalaṁ nibbattatū tava."
    },
    {
      "id": "tha-ap314:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap314:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap314:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap314:4.4",
      "pali": "bhojanassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap314:5.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap314:5.2",
      "pali": "eko āsiṁ amittako;"
    },
    {
      "id": "tha-ap314:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap314:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap314:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap314:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap314:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap314:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhojanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap314:8.1",
      "pali": "Bhojanadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
