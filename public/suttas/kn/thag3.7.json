{
  "uid": "thag3.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.7:1.1",
      "pali": "“Yodha koci manussesu,"
    },
    {
      "id": "thag3.7:1.2",
      "pali": "parapāṇāni hiṁsati;"
    },
    {
      "id": "thag3.7:1.3",
      "pali": "Asmā lokā paramhā ca,"
    },
    {
      "id": "thag3.7:1.4",
      "pali": "ubhayā dhaṁsate naro."
    },
    {
      "id": "thag3.7:2.1",
      "pali": "Yo ca mettena cittena,"
    },
    {
      "id": "thag3.7:2.2",
      "pali": "sabbapāṇānukampati;"
    },
    {
      "id": "thag3.7:2.3",
      "pali": "Bahuñhi so pasavati,"
    },
    {
      "id": "thag3.7:2.4",
      "pali": "puññaṁ tādisako naro."
    },
    {
      "id": "thag3.7:3.1",
      "pali": "Subhāsitassa sikkhetha,"
    },
    {
      "id": "thag3.7:3.2",
      "pali": "samaṇūpāsanassa ca;"
    },
    {
      "id": "thag3.7:3.3",
      "pali": "Ekāsanassa ca raho,"
    },
    {
      "id": "thag3.7:3.4",
      "pali": "cittavūpasamassa cā”ti."
    },
    {
      "id": "thag3.7:3.5",
      "pali": "… Vāraṇo thero …."
    }
  ]
}
