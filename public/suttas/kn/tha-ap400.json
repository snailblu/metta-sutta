{
  "uid": "tha-ap400",
  "title": "8 Saḷalamaṇḍapiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap400:1.1",
      "pali": "“Nibbute kakusandhamhi,"
    },
    {
      "id": "tha-ap400:1.2",
      "pali": "brāhmaṇamhi vusīmati;"
    },
    {
      "id": "tha-ap400:1.3",
      "pali": "Gahetvā saḷalaṁ mālaṁ,"
    },
    {
      "id": "tha-ap400:1.4",
      "pali": "maṇḍapaṁ kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap400:2.1",
      "pali": "Tāvatiṁsagato santo,"
    },
    {
      "id": "tha-ap400:2.2",
      "pali": "labhāmi byamhamuttamaṁ;"
    },
    {
      "id": "tha-ap400:2.3",
      "pali": "Aññe devetirocāmi,"
    },
    {
      "id": "tha-ap400:2.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap400:3.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "tha-ap400:3.2",
      "pali": "caṅkamanto ṭhito cahaṁ;"
    },
    {
      "id": "tha-ap400:3.3",
      "pali": "Channo saḷalapupphehi,"
    },
    {
      "id": "tha-ap400:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap400:4.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "tha-ap400:4.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap400:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap400:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap400:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap400:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap400:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap400:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap400:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap400:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap400:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap400:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap400:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap400:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā saḷalamaṇḍapiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap400:9.1",
      "pali": "Saḷalamaṇḍapiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
