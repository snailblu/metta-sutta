{
  "uid": "tha-ap356",
  "title": "4 Sakosakakoraṇḍadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap356:1.1",
      "pali": "“Akkantañca padaṁ disvā,"
    },
    {
      "id": "tha-ap356:1.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap356:1.3",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "tha-ap356:1.4",
      "pali": "padaseṭṭhaṁ avandahaṁ."
    },
    {
      "id": "tha-ap356:2.1",
      "pali": "Koraṇḍaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap356:2.2",
      "pali": "pādapaṁ dharaṇīruhaṁ;"
    },
    {
      "id": "tha-ap356:2.3",
      "pali": "Sakosakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap356:2.4",
      "pali": "padacakkaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap356:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap356:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap356:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap356:3.4",
      "pali": "padapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap356:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap356:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap356:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap356:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā sakosakakoraṇḍadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap356:6.1",
      "pali": "Sakosakakoraṇḍadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
