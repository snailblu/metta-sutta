{
  "uid": "iti49",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti49:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti49:2.1",
      "pali": "“Dvīhi, bhikkhave, diṭṭhigatehi pariyuṭṭhitā devamanussā olīyanti eke, atidhāvanti eke; cakkhumanto ca passanti."
    },
    {
      "id": "iti49:3.1",
      "pali": "Kathañca, bhikkhave, olīyanti eke?"
    },
    {
      "id": "iti49:3.2",
      "pali": "Bhavārāmā, bhikkhave, devamanussā bhavaratā bhavasammuditā tesaṁ bhavanirodhāya dhamme desiyamāne cittaṁ na pakkhandati na pasīdati na santiṭṭhati nādhimuccati."
    },
    {
      "id": "iti49:3.3",
      "pali": "Evaṁ kho, bhikkhave, olīyanti eke."
    },
    {
      "id": "iti49:4.1",
      "pali": "Kathañca, bhikkhave, atidhāvanti eke?"
    },
    {
      "id": "iti49:4.2",
      "pali": "Bhaveneva kho paneke aṭṭīyamānā harāyamānā jigucchamānā vibhavaṁ abhinandanti—"
    },
    {
      "id": "iti49:4.3",
      "pali": "yato kira, bho, ayaṁ attā kāyassa bhedā paraṁ maraṇā ucchijjati vinassati na hoti paraṁ maraṇā;"
    },
    {
      "id": "iti49:4.4",
      "pali": "etaṁ santaṁ etaṁ paṇītaṁ etaṁ yāthāvanti."
    },
    {
      "id": "iti49:4.5",
      "pali": "Evaṁ kho, bhikkhave, atidhāvanti eke."
    },
    {
      "id": "iti49:5.1",
      "pali": "Kathañca, bhikkhave, cakkhumanto passanti?"
    },
    {
      "id": "iti49:5.2",
      "pali": "Idha bhikkhu bhūtaṁ bhūtato passati;"
    },
    {
      "id": "iti49:5.3",
      "pali": "bhūtaṁ bhūtato disvā bhūtassa nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "iti49:5.4",
      "pali": "Evaṁ kho, bhikkhave, cakkhumanto passantī”ti."
    },
    {
      "id": "iti49:5.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti49:5.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti49:6.1",
      "pali": "“Ye bhūtaṁ bhūtato disvā,"
    },
    {
      "id": "iti49:6.2",
      "pali": "bhūtassa ca atikkamaṁ;"
    },
    {
      "id": "iti49:6.3",
      "pali": "Yathābhūte vimuccanti,"
    },
    {
      "id": "iti49:6.4",
      "pali": "bhavataṇhā parikkhayā."
    },
    {
      "id": "iti49:7.1",
      "pali": "Sa ve bhūtapariñño so,"
    },
    {
      "id": "iti49:7.2",
      "pali": "vītataṇho bhavābhave;"
    },
    {
      "id": "iti49:7.3",
      "pali": "Bhūtassa vibhavā bhikkhu,"
    },
    {
      "id": "iti49:7.4",
      "pali": "nāgacchati punabbhavan”ti."
    },
    {
      "id": "iti49:8.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti49:8.2",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "iti49:8.3",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "iti49:9.1",
      "pali": "Dve indriyā dve tapanīyā,"
    },
    {
      "id": "iti49:9.2",
      "pali": "sīlena apare duve;"
    },
    {
      "id": "iti49:9.3",
      "pali": "Anottāpī kuhanā dve ca,"
    },
    {
      "id": "iti49:9.4",
      "pali": "saṁvejanīyena te dasa."
    },
    {
      "id": "iti49:10.1",
      "pali": "Vitakkā desanā vijjā,"
    },
    {
      "id": "iti49:10.2",
      "pali": "paññā dhammena pañcamaṁ;"
    },
    {
      "id": "iti49:10.3",
      "pali": "Ajātaṁ dhātusallānaṁ,"
    },
    {
      "id": "iti49:10.4",
      "pali": "sikkhā jāgariyena ca;"
    },
    {
      "id": "iti49:10.5",
      "pali": "Apāyadiṭṭhiyā ceva,"
    },
    {
      "id": "iti49:10.6",
      "pali": "bāvīsati pakāsitāti."
    },
    {
      "id": "iti49:10.7",
      "pali": "Dukanipāto niṭṭhito."
    }
  ]
}
