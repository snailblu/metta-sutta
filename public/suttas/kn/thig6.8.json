{
  "uid": "thig6.8",
  "title": "Vijayātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.8:1.1",
      "pali": "“Catukkhattuṁ pañcakkhattuṁ,"
    },
    {
      "id": "thig6.8:1.2",
      "pali": "vihārā upanikkhamiṁ;"
    },
    {
      "id": "thig6.8:1.3",
      "pali": "Aladdhā cetaso santiṁ,"
    },
    {
      "id": "thig6.8:1.4",
      "pali": "citte avasavattinī."
    },
    {
      "id": "thig6.8:2.1",
      "pali": "Bhikkhuniṁ upasaṅkamma,"
    },
    {
      "id": "thig6.8:2.2",
      "pali": "sakkaccaṁ paripucchahaṁ;"
    },
    {
      "id": "thig6.8:2.3",
      "pali": "Sā me dhammamadesesi,"
    },
    {
      "id": "thig6.8:2.4",
      "pali": "dhātuāyatanāni ca."
    },
    {
      "id": "thig6.8:3.1",
      "pali": "Cattāri ariyasaccāni,"
    },
    {
      "id": "thig6.8:3.2",
      "pali": "indriyāni balāni ca;"
    },
    {
      "id": "thig6.8:3.3",
      "pali": "Bojjhaṅgaṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thig6.8:3.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "thig6.8:4.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig6.8:4.2",
      "pali": "karontī anusāsaniṁ;"
    },
    {
      "id": "thig6.8:4.3",
      "pali": "Rattiyā purime yāme,"
    },
    {
      "id": "thig6.8:4.4",
      "pali": "pubbajātimanussariṁ."
    },
    {
      "id": "thig6.8:5.1",
      "pali": "Rattiyā majjhime yāme,"
    },
    {
      "id": "thig6.8:5.2",
      "pali": "dibbacakkhuṁ visodhayiṁ;"
    },
    {
      "id": "thig6.8:5.3",
      "pali": "Rattiyā pacchime yāme,"
    },
    {
      "id": "thig6.8:5.4",
      "pali": "tamokhandhaṁ padālayiṁ."
    },
    {
      "id": "thig6.8:6.1",
      "pali": "Pītisukhena ca kāyaṁ,"
    },
    {
      "id": "thig6.8:6.2",
      "pali": "Pharitvā vihariṁ tadā;"
    },
    {
      "id": "thig6.8:6.3",
      "pali": "Sattamiyā pāde pasāresiṁ,"
    },
    {
      "id": "thig6.8:6.4",
      "pali": "Tamokhandhaṁ padāliyā”ti."
    },
    {
      "id": "thig6.8:7.1",
      "pali": "… Vijayā therī …."
    },
    {
      "id": "thig6.8:8.1",
      "pali": "Chakkanipāto niṭṭhito."
    }
  ]
}
