{
  "uid": "ja82",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja82:1.1",
      "pali": "“Atikkamma ramaṇakaṁ,"
    },
    {
      "id": "ja82:1.2",
      "pali": "sadāmattañca dūbhakaṁ;"
    },
    {
      "id": "ja82:1.3",
      "pali": "Svāsi pāsāṇamāsīno,"
    },
    {
      "id": "ja82:1.4",
      "pali": "yasmā jīvaṁ na mokkhasī”ti."
    },
    {
      "id": "ja82:2.1",
      "pali": "Mittavindakajātakaṁ dutiyaṁ."
    }
  ]
}
