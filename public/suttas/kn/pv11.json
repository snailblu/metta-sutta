{
  "uid": "pv11",
  "title": "11. Nāgapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv11:1.1",
      "pali": "“Puratova setena paleti hatthinā,"
    },
    {
      "id": "pv11:1.2",
      "pali": "Majjhe pana assatarīrathena;"
    },
    {
      "id": "pv11:1.3",
      "pali": "Pacchā ca kaññā sivikāya nīyati,"
    },
    {
      "id": "pv11:1.4",
      "pali": "Obhāsayantī dasa sabbaso disā."
    },
    {
      "id": "pv11:2.1",
      "pali": "Tumhe pana muggarahatthapāṇino,"
    },
    {
      "id": "pv11:2.2",
      "pali": "Rudammukhā chinnapabhinnagattā;"
    },
    {
      "id": "pv11:2.3",
      "pali": "Manussabhūtā kimakattha pāpaṁ,"
    },
    {
      "id": "pv11:2.4",
      "pali": "Yenaññamaññassa pivātha lohitan”ti."
    },
    {
      "id": "pv11:3.1",
      "pali": "“Puratova yo gacchati kuñjarena,"
    },
    {
      "id": "pv11:3.2",
      "pali": "Setena nāgena catukkamena;"
    },
    {
      "id": "pv11:3.3",
      "pali": "Amhāka putto ahu jeṭṭhako so,"
    },
    {
      "id": "pv11:3.4",
      "pali": "Dānāni datvāna sukhī pamodati."
    },
    {
      "id": "pv11:4.1",
      "pali": "Yo so majjhe assatarīrathena,"
    },
    {
      "id": "pv11:4.2",
      "pali": "Catubbhi yuttena suvaggitena;"
    },
    {
      "id": "pv11:4.3",
      "pali": "Amhāka putto ahu majjhimo so,"
    },
    {
      "id": "pv11:4.4",
      "pali": "Amaccharī dānavatī virocati."
    },
    {
      "id": "pv11:5.1",
      "pali": "Yā sā ca pacchā sivikāya nīyati,"
    },
    {
      "id": "pv11:5.2",
      "pali": "Nārī sapaññā migamandalocanā;"
    },
    {
      "id": "pv11:5.3",
      "pali": "Amhāka dhītā ahu sā kaniṭṭhikā,"
    },
    {
      "id": "pv11:5.4",
      "pali": "Bhāgaḍḍhabhāgena sukhī pamodati."
    },
    {
      "id": "pv11:6.1",
      "pali": "Ete ca dānāni adaṁsu pubbe,"
    },
    {
      "id": "pv11:6.2",
      "pali": "Pasannacittā samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "pv11:6.3",
      "pali": "Mayaṁ pana maccharino ahumha,"
    },
    {
      "id": "pv11:6.4",
      "pali": "Paribhāsakā samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "pv11:6.5",
      "pali": "Ete ca datvā paricārayanti,"
    },
    {
      "id": "pv11:6.6",
      "pali": "Mayañca sussāma naḷova chinno”ti."
    },
    {
      "id": "pv11:7.1",
      "pali": "“Kiṁ tumhākaṁ bhojanaṁ kiṁ sayānaṁ,"
    },
    {
      "id": "pv11:7.2",
      "pali": "Kathañca yāpetha supāpadhammino;"
    },
    {
      "id": "pv11:7.3",
      "pali": "Pahūtabhogesu anappakesu,"
    },
    {
      "id": "pv11:7.4",
      "pali": "Sukhaṁ virādhāya dukkhajja pattā”ti."
    },
    {
      "id": "pv11:8.1",
      "pali": "“Aññamaññaṁ vadhitvāna,"
    },
    {
      "id": "pv11:8.2",
      "pali": "pivāma pubbalohitaṁ;"
    },
    {
      "id": "pv11:8.3",
      "pali": "Bahuṁ pitvā na dhātā homa,"
    },
    {
      "id": "pv11:8.4",
      "pali": "nacchādimhase mayaṁ."
    },
    {
      "id": "pv11:9.1",
      "pali": "Icceva maccā paridevayanti,"
    },
    {
      "id": "pv11:9.2",
      "pali": "Adāyakā pecca yamassa ṭhāyino;"
    },
    {
      "id": "pv11:9.3",
      "pali": "Ye te vidicca adhigamma bhoge,"
    },
    {
      "id": "pv11:9.4",
      "pali": "Na bhuñjare nāpi karonti puññaṁ."
    },
    {
      "id": "pv11:10.1",
      "pali": "Te khuppipāsūpagatā parattha,"
    },
    {
      "id": "pv11:10.2",
      "pali": "Pacchā ciraṁ jhāyare ḍayhamānā;"
    },
    {
      "id": "pv11:10.3",
      "pali": "Kammāni katvāna dukhudrāni,"
    },
    {
      "id": "pv11:10.4",
      "pali": "Anubhonti dukkhaṁ kaṭukapphalāni."
    },
    {
      "id": "pv11:11.1",
      "pali": "Ittaraṁ hi dhanaṁ dhaññaṁ,"
    },
    {
      "id": "pv11:11.2",
      "pali": "ittaraṁ idha jīvitaṁ;"
    },
    {
      "id": "pv11:11.3",
      "pali": "Ittaraṁ ittarato ñatvā,"
    },
    {
      "id": "pv11:11.4",
      "pali": "dīpaṁ kayirātha paṇḍito."
    },
    {
      "id": "pv11:12.1",
      "pali": "Ye te evaṁ pajānanti,"
    },
    {
      "id": "pv11:12.2",
      "pali": "narā dhammassa kovidā;"
    },
    {
      "id": "pv11:12.3",
      "pali": "Te dāne nappamajjanti,"
    },
    {
      "id": "pv11:12.4",
      "pali": "sutvā arahataṁ vaco”ti."
    },
    {
      "id": "pv11:13.1",
      "pali": "Nāgapetavatthu ekādasamaṁ."
    }
  ]
}
