{
  "uid": "tha-ap483",
  "title": "Paṁsukūlasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap483:1.1",
      "pali": "“Tisso nāmāsi bhagavā,"
    },
    {
      "id": "tha-ap483:1.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap483:1.3",
      "pali": "Paṁsukūlaṁ ṭhapetvāna,"
    },
    {
      "id": "tha-ap483:1.4",
      "pali": "vihāraṁ pāvisī jino."
    },
    {
      "id": "tha-ap483:2.1",
      "pali": "Vinataṁ dhanumādāya,"
    },
    {
      "id": "tha-ap483:2.2",
      "pali": "bhakkhatthāya cariṁ ahaṁ;"
    },
    {
      "id": "tha-ap483:2.3",
      "pali": "Maṇḍalaggaṁ gahetvāna,"
    },
    {
      "id": "tha-ap483:2.4",
      "pali": "kānanaṁ pāvisiṁ ahaṁ."
    },
    {
      "id": "tha-ap483:3.1",
      "pali": "Tatthaddasaṁ paṁsukūlaṁ,"
    },
    {
      "id": "tha-ap483:3.2",
      "pali": "dumagge laggitaṁ tadā;"
    },
    {
      "id": "tha-ap483:3.3",
      "pali": "Cāpaṁ tattheva nikkhippa,"
    },
    {
      "id": "tha-ap483:3.4",
      "pali": "sire katvāna añjaliṁ."
    },
    {
      "id": "tha-ap483:4.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap483:4.2",
      "pali": "vipulāya ca pītiyā;"
    },
    {
      "id": "tha-ap483:4.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap483:4.4",
      "pali": "paṁsukūlaṁ avandahaṁ."
    },
    {
      "id": "tha-ap483:5.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap483:5.2",
      "pali": "paṁsukūlamavandahaṁ;"
    },
    {
      "id": "tha-ap483:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap483:5.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap483:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap483:6.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap483:6.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap483:6.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap483:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap483:7.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap483:7.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap483:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap483:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap483:8.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap483:8.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap483:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap483:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṁsukūlasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap483:10.1",
      "pali": "Paṁsukūlasaññakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
