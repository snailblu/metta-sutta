{
  "uid": "thig6.6",
  "title": "Mahāpajāpatigotamītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.6:1.1",
      "pali": "“Buddha vīra namo tyatthu,"
    },
    {
      "id": "thig6.6:1.2",
      "pali": "sabbasattānamuttama;"
    },
    {
      "id": "thig6.6:1.3",
      "pali": "Yo maṁ dukkhā pamocesi,"
    },
    {
      "id": "thig6.6:1.4",
      "pali": "aññañca bahukaṁ janaṁ."
    },
    {
      "id": "thig6.6:2.1",
      "pali": "Sabbadukkhaṁ pariññātaṁ,"
    },
    {
      "id": "thig6.6:2.2",
      "pali": "Hetutaṇhā visositā;"
    },
    {
      "id": "thig6.6:2.3",
      "pali": "Bhāvito aṭṭhaṅgiko maggo,"
    },
    {
      "id": "thig6.6:2.4",
      "pali": "Nirodho phusito mayā."
    },
    {
      "id": "thig6.6:3.1",
      "pali": "Mātā putto pitā bhātā,"
    },
    {
      "id": "thig6.6:3.2",
      "pali": "ayyakā ca pure ahuṁ;"
    },
    {
      "id": "thig6.6:3.3",
      "pali": "Yathābhuccamajānantī,"
    },
    {
      "id": "thig6.6:3.4",
      "pali": "saṁsariṁhaṁ anibbisaṁ."
    },
    {
      "id": "thig6.6:4.1",
      "pali": "Diṭṭho hi me so bhagavā,"
    },
    {
      "id": "thig6.6:4.2",
      "pali": "antimoyaṁ samussayo;"
    },
    {
      "id": "thig6.6:4.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thig6.6:4.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thig6.6:5.1",
      "pali": "Āraddhavīriye pahitatte,"
    },
    {
      "id": "thig6.6:5.2",
      "pali": "Niccaṁ daḷhaparakkame;"
    },
    {
      "id": "thig6.6:5.3",
      "pali": "Samagge sāvake passe,"
    },
    {
      "id": "thig6.6:5.4",
      "pali": "Esā buddhāna vandanā."
    },
    {
      "id": "thig6.6:6.1",
      "pali": "Bahūnaṁ vata atthāya,"
    },
    {
      "id": "thig6.6:6.2",
      "pali": "Māyā janayi gotamaṁ;"
    },
    {
      "id": "thig6.6:6.3",
      "pali": "Byādhimaraṇatunnānaṁ,"
    },
    {
      "id": "thig6.6:6.4",
      "pali": "Dukkhakkhandhaṁ byapānudī”ti."
    },
    {
      "id": "thig6.6:7.1",
      "pali": "… Mahāpajāpatigotamī therī …."
    }
  ]
}
