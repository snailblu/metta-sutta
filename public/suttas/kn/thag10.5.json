{
  "uid": "thag10.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.5:1.1",
      "pali": "“Nānākulamalasampuṇṇo,"
    },
    {
      "id": "thag10.5:1.2",
      "pali": "mahāukkārasambhavo;"
    },
    {
      "id": "thag10.5:1.3",
      "pali": "Candanikaṁva paripakkaṁ,"
    },
    {
      "id": "thag10.5:1.4",
      "pali": "mahāgaṇḍo mahāvaṇo."
    },
    {
      "id": "thag10.5:2.1",
      "pali": "Pubbaruhirasampuṇṇo,"
    },
    {
      "id": "thag10.5:2.2",
      "pali": "gūthakūpena gāḷhito;"
    },
    {
      "id": "thag10.5:2.3",
      "pali": "Āpopaggharaṇo kāyo,"
    },
    {
      "id": "thag10.5:2.4",
      "pali": "sadā sandati pūtikaṁ."
    },
    {
      "id": "thag10.5:3.1",
      "pali": "Saṭṭhikaṇḍarasambandho,"
    },
    {
      "id": "thag10.5:3.2",
      "pali": "maṁsalepanalepito;"
    },
    {
      "id": "thag10.5:3.3",
      "pali": "Cammakañcukasannaddho,"
    },
    {
      "id": "thag10.5:3.4",
      "pali": "pūtikāyo niratthako."
    },
    {
      "id": "thag10.5:4.1",
      "pali": "Aṭṭhisaṅghātaghaṭito,"
    },
    {
      "id": "thag10.5:4.2",
      "pali": "nhārusuttanibandhano;"
    },
    {
      "id": "thag10.5:4.3",
      "pali": "Nekesaṁ saṅgatībhāvā,"
    },
    {
      "id": "thag10.5:4.4",
      "pali": "kappeti iriyāpathaṁ."
    },
    {
      "id": "thag10.5:5.1",
      "pali": "Dhuvappayāto maraṇāya,"
    },
    {
      "id": "thag10.5:5.2",
      "pali": "maccurājassa santike;"
    },
    {
      "id": "thag10.5:5.3",
      "pali": "Idheva chaḍḍayitvāna,"
    },
    {
      "id": "thag10.5:5.4",
      "pali": "yenakāmaṅgamo naro."
    },
    {
      "id": "thag10.5:6.1",
      "pali": "Avijjāya nivuto kāyo,"
    },
    {
      "id": "thag10.5:6.2",
      "pali": "catuganthena ganthito;"
    },
    {
      "id": "thag10.5:6.3",
      "pali": "Oghasaṁsīdano kāyo,"
    },
    {
      "id": "thag10.5:6.4",
      "pali": "anusayajālamotthato."
    },
    {
      "id": "thag10.5:7.1",
      "pali": "Pañcanīvaraṇe yutto,"
    },
    {
      "id": "thag10.5:7.2",
      "pali": "vitakkena samappito;"
    },
    {
      "id": "thag10.5:7.3",
      "pali": "Taṇhāmūlenānugato,"
    },
    {
      "id": "thag10.5:7.4",
      "pali": "mohacchādanachādito."
    },
    {
      "id": "thag10.5:8.1",
      "pali": "Evāyaṁ vattate kāyo,"
    },
    {
      "id": "thag10.5:8.2",
      "pali": "kammayantena yantito;"
    },
    {
      "id": "thag10.5:8.3",
      "pali": "Sampatti ca vipatyantā,"
    },
    {
      "id": "thag10.5:8.4",
      "pali": "nānābhāvo vipajjati."
    },
    {
      "id": "thag10.5:9.1",
      "pali": "Yemaṁ kāyaṁ mamāyanti,"
    },
    {
      "id": "thag10.5:9.2",
      "pali": "andhabālā puthujjanā;"
    },
    {
      "id": "thag10.5:9.3",
      "pali": "Vaḍḍhenti kaṭasiṁ ghoraṁ,"
    },
    {
      "id": "thag10.5:9.4",
      "pali": "ādiyanti punabbhavaṁ."
    },
    {
      "id": "thag10.5:10.1",
      "pali": "Yemaṁ kāyaṁ vivajjenti,"
    },
    {
      "id": "thag10.5:10.2",
      "pali": "Gūthalittaṁva pannagaṁ;"
    },
    {
      "id": "thag10.5:10.3",
      "pali": "Bhavamūlaṁ vamitvāna,"
    },
    {
      "id": "thag10.5:10.4",
      "pali": "Parinibbissantināsavā”ti."
    },
    {
      "id": "thag10.5:10.5",
      "pali": "… Kappo thero …."
    }
  ]
}
