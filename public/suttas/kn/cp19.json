{
  "uid": "cp19",
  "title": "Sīlapāramī 9",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp19:1.1",
      "pali": "“Pañcālaraṭṭhe nagaravare,"
    },
    {
      "id": "cp19:1.2",
      "pali": "Kapilāyaṁ puruttame;"
    },
    {
      "id": "cp19:1.3",
      "pali": "Rājā jayaddiso nāma,"
    },
    {
      "id": "cp19:1.4",
      "pali": "Sīlaguṇamupāgato."
    },
    {
      "id": "cp19:2.1",
      "pali": "Tassa rañño ahaṁ putto,"
    },
    {
      "id": "cp19:2.2",
      "pali": "Sutadhammo susīlavā;"
    },
    {
      "id": "cp19:2.3",
      "pali": "Alīnasatto guṇavā,"
    },
    {
      "id": "cp19:2.4",
      "pali": "Anurakkhaparijano sadā."
    },
    {
      "id": "cp19:3.1",
      "pali": "Pitā me migavaṁ gantvā,"
    },
    {
      "id": "cp19:3.2",
      "pali": "porisādaṁ upāgami;"
    },
    {
      "id": "cp19:3.3",
      "pali": "So me pitumaggahesi,"
    },
    {
      "id": "cp19:3.4",
      "pali": "‘bhakkhosi mama mā cali’."
    },
    {
      "id": "cp19:4.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp19:4.2",
      "pali": "bhīto tasitavedhito;"
    },
    {
      "id": "cp19:4.3",
      "pali": "Ūrukkhambho ahu tassa,"
    },
    {
      "id": "cp19:4.4",
      "pali": "disvāna porisādakaṁ."
    },
    {
      "id": "cp19:5.1",
      "pali": "Migavaṁ gahetvā muñcassu,"
    },
    {
      "id": "cp19:5.2",
      "pali": "katvā āgamanaṁ puna;"
    },
    {
      "id": "cp19:5.3",
      "pali": "Brāhmaṇassa dhanaṁ datvā,"
    },
    {
      "id": "cp19:5.4",
      "pali": "pitā āmantayī mamaṁ."
    },
    {
      "id": "cp19:6.1",
      "pali": "‘Rajjaṁ putta paṭipajja,"
    },
    {
      "id": "cp19:6.2",
      "pali": "mā pamajji puraṁ idaṁ;"
    },
    {
      "id": "cp19:6.3",
      "pali": "Kataṁ me porisādena,"
    },
    {
      "id": "cp19:6.4",
      "pali": "mama āgamanaṁ puna’."
    },
    {
      "id": "cp19:7.1",
      "pali": "Mātāpitū ca vanditvā,"
    },
    {
      "id": "cp19:7.2",
      "pali": "nimminitvāna attanā;"
    },
    {
      "id": "cp19:7.3",
      "pali": "Nikkhipitvā dhanuṁ khaggaṁ,"
    },
    {
      "id": "cp19:7.4",
      "pali": "porisādaṁ upāgamiṁ."
    },
    {
      "id": "cp19:8.1",
      "pali": "Sasatthahatthūpagataṁ,"
    },
    {
      "id": "cp19:8.2",
      "pali": "kadāci so tasissati;"
    },
    {
      "id": "cp19:8.3",
      "pali": "Tena bhijjissati sīlaṁ,"
    },
    {
      "id": "cp19:8.4",
      "pali": "parittāsaṁ kate mayi."
    },
    {
      "id": "cp19:9.1",
      "pali": "Sīlakhaṇḍabhayā mayhaṁ,"
    },
    {
      "id": "cp19:9.2",
      "pali": "tassa dessaṁ na byāhariṁ;"
    },
    {
      "id": "cp19:9.3",
      "pali": "Mettacitto hitavādī,"
    },
    {
      "id": "cp19:9.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "cp19:10.1",
      "pali": "‘Ujjālehi mahāaggiṁ,"
    },
    {
      "id": "cp19:10.2",
      "pali": "papatissāmi rukkhato;"
    },
    {
      "id": "cp19:10.3",
      "pali": "Tvaṁ pakkakālamaññāya,"
    },
    {
      "id": "cp19:10.4",
      "pali": "bhakkhaya maṁ pitāmaha’."
    },
    {
      "id": "cp19:11.1",
      "pali": "Iti sīlavataṁ hetu,"
    },
    {
      "id": "cp19:11.2",
      "pali": "nārakkhiṁ mama jīvitaṁ;"
    },
    {
      "id": "cp19:11.3",
      "pali": "Pabbājesiṁ cahaṁ tassa,"
    },
    {
      "id": "cp19:11.4",
      "pali": "sadā pāṇātipātikan”ti."
    },
    {
      "id": "cp19:12.1",
      "pali": "Alīnasattucariyaṁ navamaṁ."
    }
  ]
}
