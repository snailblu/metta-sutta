{
  "uid": "ja156",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja156:1.1",
      "pali": "“Alīnacittaṁ nissāya,"
    },
    {
      "id": "ja156:1.2",
      "pali": "pahaṭṭhā mahatī camū;"
    },
    {
      "id": "ja156:1.3",
      "pali": "Kosalaṁ senāsantuṭṭhaṁ,"
    },
    {
      "id": "ja156:1.4",
      "pali": "jīvaggāhaṁ agāhayi."
    },
    {
      "id": "ja156:2.1",
      "pali": "Evaṁ nissayasampanno,"
    },
    {
      "id": "ja156:2.2",
      "pali": "bhikkhu āraddhavīriyo;"
    },
    {
      "id": "ja156:2.3",
      "pali": "Bhāvayaṁ kusalaṁ dhammaṁ,"
    },
    {
      "id": "ja156:2.4",
      "pali": "yogakkhemassa pattiyā;"
    },
    {
      "id": "ja156:2.5",
      "pali": "Pāpuṇe anupubbena,"
    },
    {
      "id": "ja156:2.6",
      "pali": "sabbasaṁyojanakkhayan”ti."
    },
    {
      "id": "ja156:3.1",
      "pali": "Alīnacittajātakaṁ chaṭṭhaṁ."
    }
  ]
}
