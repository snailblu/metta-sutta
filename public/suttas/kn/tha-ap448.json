{
  "uid": "tha-ap448",
  "title": "Ambāṭakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap448:1.1",
      "pali": "“Supupphitaṁ sālavanaṁ,"
    },
    {
      "id": "tha-ap448:1.2",
      "pali": "ogayha vessabhū muni;"
    },
    {
      "id": "tha-ap448:1.3",
      "pali": "Nisīdi giriduggesu,"
    },
    {
      "id": "tha-ap448:1.4",
      "pali": "abhijātova kesarī."
    },
    {
      "id": "tha-ap448:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap448:2.2",
      "pali": "ambāṭakamapūjayiṁ;"
    },
    {
      "id": "tha-ap448:2.3",
      "pali": "Puññakkhettaṁ anuttaraṁ,"
    },
    {
      "id": "tha-ap448:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap448:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap448:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap448:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap448:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap448:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap448:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap448:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap448:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap448:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap448:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap448:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap448:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap448:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap448:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambāṭakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap448:8.1",
      "pali": "Ambāṭakiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
