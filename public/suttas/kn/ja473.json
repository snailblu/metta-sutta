{
  "uid": "ja473",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja473:1.1",
      "pali": "“Kāni kammāni kubbānaṁ,"
    },
    {
      "id": "ja473:1.2",
      "pali": "kathaṁ viññū parakkame;"
    },
    {
      "id": "ja473:1.3",
      "pali": "Amittaṁ jāneyya medhāvī,"
    },
    {
      "id": "ja473:1.4",
      "pali": "disvā sutvā ca paṇḍito”."
    },
    {
      "id": "ja473:2.1",
      "pali": "“Na naṁ umhayate disvā,"
    },
    {
      "id": "ja473:2.2",
      "pali": "na ca naṁ paṭinandati;"
    },
    {
      "id": "ja473:2.3",
      "pali": "Cakkhūni cassa na dadāti,"
    },
    {
      "id": "ja473:2.4",
      "pali": "paṭilomañca vattati."
    },
    {
      "id": "ja473:3.1",
      "pali": "Amitte tassa bhajati,"
    },
    {
      "id": "ja473:3.2",
      "pali": "mitte tassa na sevati;"
    },
    {
      "id": "ja473:3.3",
      "pali": "Vaṇṇakāme nivāreti,"
    },
    {
      "id": "ja473:3.4",
      "pali": "akkosante pasaṁsati."
    },
    {
      "id": "ja473:4.1",
      "pali": "Guyhañca tassa nakkhāti,"
    },
    {
      "id": "ja473:4.2",
      "pali": "tassa guyhaṁ na gūhati;"
    },
    {
      "id": "ja473:4.3",
      "pali": "Kammaṁ tassa na vaṇṇeti,"
    },
    {
      "id": "ja473:4.4",
      "pali": "paññassa nappasaṁsati."
    },
    {
      "id": "ja473:5.1",
      "pali": "Abhave nandati tassa,"
    },
    {
      "id": "ja473:5.2",
      "pali": "bhave tassa na nandati;"
    },
    {
      "id": "ja473:5.3",
      "pali": "Accheraṁ bhojanaṁ laddhā,"
    },
    {
      "id": "ja473:5.4",
      "pali": "tassa nuppajjate sati;"
    },
    {
      "id": "ja473:5.5",
      "pali": "Tato naṁ nānukampati,"
    },
    {
      "id": "ja473:5.6",
      "pali": "aho sopi labheyyito."
    },
    {
      "id": "ja473:6.1",
      "pali": "Iccete soḷasākārā,"
    },
    {
      "id": "ja473:6.2",
      "pali": "amittasmiṁ patiṭṭhitā;"
    },
    {
      "id": "ja473:6.3",
      "pali": "Yehi amittaṁ jāneyya,"
    },
    {
      "id": "ja473:6.4",
      "pali": "disvā sutvā ca paṇḍito”."
    },
    {
      "id": "ja473:7.1",
      "pali": "“Kāni kammāni kubbānaṁ,"
    },
    {
      "id": "ja473:7.2",
      "pali": "kathaṁ viññū parakkame;"
    },
    {
      "id": "ja473:7.3",
      "pali": "Mittaṁ jāneyya medhāvī,"
    },
    {
      "id": "ja473:7.4",
      "pali": "disvā sutvā ca paṇḍito."
    },
    {
      "id": "ja473:8.1",
      "pali": "Pavutthaṁ tassa sarati,"
    },
    {
      "id": "ja473:8.2",
      "pali": "āgataṁ abhinandati;"
    },
    {
      "id": "ja473:8.3",
      "pali": "Tato kelāyito hoti,"
    },
    {
      "id": "ja473:8.4",
      "pali": "vācāya paṭinandati."
    },
    {
      "id": "ja473:9.1",
      "pali": "Mitte tasseva bhajati,"
    },
    {
      "id": "ja473:9.2",
      "pali": "amitte tassa na sevati;"
    },
    {
      "id": "ja473:9.3",
      "pali": "Akkosante nivāreti,"
    },
    {
      "id": "ja473:9.4",
      "pali": "vaṇṇakāme pasaṁsati."
    },
    {
      "id": "ja473:10.1",
      "pali": "Guyhañca tassa akkhāti,"
    },
    {
      "id": "ja473:10.2",
      "pali": "tassa guyhañca gūhati;"
    },
    {
      "id": "ja473:10.3",
      "pali": "Kammañca tassa vaṇṇeti,"
    },
    {
      "id": "ja473:10.4",
      "pali": "paññaṁ tassa pasaṁsati."
    },
    {
      "id": "ja473:11.1",
      "pali": "Bhave ca nandati tassa,"
    },
    {
      "id": "ja473:11.2",
      "pali": "abhave tassa na nandati;"
    },
    {
      "id": "ja473:11.3",
      "pali": "Accheraṁ bhojanaṁ laddhā,"
    },
    {
      "id": "ja473:11.4",
      "pali": "tassa uppajjate sati;"
    },
    {
      "id": "ja473:11.5",
      "pali": "Tato naṁ anukampati,"
    },
    {
      "id": "ja473:11.6",
      "pali": "aho sopi labheyyito."
    },
    {
      "id": "ja473:12.1",
      "pali": "Iccete soḷasākārā,"
    },
    {
      "id": "ja473:12.2",
      "pali": "Mittasmiṁ suppatiṭṭhitā;"
    },
    {
      "id": "ja473:12.3",
      "pali": "Yehi mittañca jāneyya,"
    },
    {
      "id": "ja473:12.4",
      "pali": "Disvā sutvā ca paṇḍito”ti."
    },
    {
      "id": "ja473:13.1",
      "pali": "Mittāmittajātakaṁ dasamaṁ."
    },
    {
      "id": "ja473:14.1",
      "pali": "Dvādasakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja473:15.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja473:16.1",
      "pali": "Lahucitta sasāla kasanti puna,"
    },
    {
      "id": "ja473:16.2",
      "pali": "Atha kāma dasakhaluṭṭhānavaro;"
    },
    {
      "id": "ja473:16.3",
      "pali": "Atha kaṇha sukosiya meṇḍavaro,"
    },
    {
      "id": "ja473:16.4",
      "pali": "Padumo puna mittavarena dasāti."
    }
  ]
}
