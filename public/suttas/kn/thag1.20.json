{
  "uid": "thag1.20",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.20:1.1",
      "pali": "“Maraṇe me bhayaṁ natthi,"
    },
    {
      "id": "thag1.20:1.2",
      "pali": "nikanti natthi jīvite;"
    },
    {
      "id": "thag1.20:1.3",
      "pali": "Sandehaṁ nikkhipissāmi,"
    },
    {
      "id": "thag1.20:1.4",
      "pali": "sampajāno paṭissato”ti."
    },
    {
      "id": "thag1.20:1.5",
      "pali": "… Ajito thero …"
    },
    {
      "id": "thag1.20:1.6",
      "pali": "vaggo dutiyo."
    },
    {
      "id": "thag1.20:2.1",
      "pali": "Cūḷavaccho mahāvaccho,"
    },
    {
      "id": "thag1.20:2.2",
      "pali": "vanavaccho ca sīvako;"
    },
    {
      "id": "thag1.20:2.3",
      "pali": "Kuṇḍadhāno ca belaṭṭhi,"
    },
    {
      "id": "thag1.20:2.4",
      "pali": "dāsako ca tatopari;"
    },
    {
      "id": "thag1.20:2.5",
      "pali": "Siṅgālapitiko thero,"
    },
    {
      "id": "thag1.20:2.6",
      "pali": "kulo ca ajito dasāti."
    }
  ]
}
