{
  "uid": "ja18",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja18:1.1",
      "pali": "“Evañce sattā jāneyyuṁ,"
    },
    {
      "id": "ja18:1.2",
      "pali": "dukkhāyaṁ jātisambhavo;"
    },
    {
      "id": "ja18:1.3",
      "pali": "Na pāṇo pāṇinaṁ haññe,"
    },
    {
      "id": "ja18:1.4",
      "pali": "pāṇaghātī hi socatī”ti."
    },
    {
      "id": "ja18:2.1",
      "pali": "Matakabhattajātakaṁ aṭṭhamaṁ."
    }
  ]
}
