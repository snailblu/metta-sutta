{
  "uid": "ja179",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja179:1.1",
      "pali": "“Tañca appañca ucchiṭṭhaṁ,"
    },
    {
      "id": "ja179:1.2",
      "pali": "tañca kicchena no adā;"
    },
    {
      "id": "ja179:1.3",
      "pali": "Sohaṁ brāhmaṇajātiko,"
    },
    {
      "id": "ja179:1.4",
      "pali": "yaṁ bhuttaṁ tampi uggataṁ”."
    },
    {
      "id": "ja179:2.1",
      "pali": "“Evaṁ dhammaṁ niraṅkatvā,"
    },
    {
      "id": "ja179:2.2",
      "pali": "Yo adhammena jīvati;"
    },
    {
      "id": "ja179:2.3",
      "pali": "Satadhammova lābhena,"
    },
    {
      "id": "ja179:2.4",
      "pali": "Laddhenapi na nandatī”ti."
    },
    {
      "id": "ja179:3.1",
      "pali": "Satadhammajātakaṁ navamaṁ."
    }
  ]
}
