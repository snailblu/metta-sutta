{
  "uid": "tha-ap122",
  "title": "Jātipūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap122:1.1",
      "pali": "“Jāyantassa vipassissa,"
    },
    {
      "id": "tha-ap122:1.2",
      "pali": "āloko vipulo ahu;"
    },
    {
      "id": "tha-ap122:1.3",
      "pali": "Pathavī ca pakampittha,"
    },
    {
      "id": "tha-ap122:1.4",
      "pali": "sasāgarā sapabbatā."
    },
    {
      "id": "tha-ap122:2.1",
      "pali": "Nemittā ca viyākaṁsu,"
    },
    {
      "id": "tha-ap122:2.2",
      "pali": "buddho loke bhavissati;"
    },
    {
      "id": "tha-ap122:2.3",
      "pali": "Aggo ca sabbasattānaṁ,"
    },
    {
      "id": "tha-ap122:2.4",
      "pali": "janataṁ uddharissati."
    },
    {
      "id": "tha-ap122:3.1",
      "pali": "Nemittānaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap122:3.2",
      "pali": "jātipūjamakāsahaṁ;"
    },
    {
      "id": "tha-ap122:3.3",
      "pali": "Edisā pūjanā natthi,"
    },
    {
      "id": "tha-ap122:3.4",
      "pali": "yādisā jātipūjanā."
    },
    {
      "id": "tha-ap122:4.1",
      "pali": "Saṅkharitvāna kusalaṁ,"
    },
    {
      "id": "tha-ap122:4.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap122:4.3",
      "pali": "Jātipūjaṁ karitvāna,"
    },
    {
      "id": "tha-ap122:4.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap122:5.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap122:5.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap122:5.3",
      "pali": "Sabbe satte abhibhomi,"
    },
    {
      "id": "tha-ap122:5.4",
      "pali": "jātipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap122:6.1",
      "pali": "Dhātiyo maṁ upaṭṭhanti,"
    },
    {
      "id": "tha-ap122:6.2",
      "pali": "mama cittavasānugā;"
    },
    {
      "id": "tha-ap122:6.3",
      "pali": "Na tā sakkonti kopetuṁ,"
    },
    {
      "id": "tha-ap122:6.4",
      "pali": "jātipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap122:7.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap122:7.2",
      "pali": "yaṁ pūjamakariṁ tadā;"
    },
    {
      "id": "tha-ap122:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap122:7.4",
      "pali": "jātipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap122:8.1",
      "pali": "Supāricariyā nāma,"
    },
    {
      "id": "tha-ap122:8.2",
      "pali": "catuttiṁsa janādhipā;"
    },
    {
      "id": "tha-ap122:8.3",
      "pali": "Ito tatiyakappamhi,"
    },
    {
      "id": "tha-ap122:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap122:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap122:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap122:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap122:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā jātipūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap122:11.1",
      "pali": "Jātipūjakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap122:12.1",
      "pali": "Mahāparivāravaggo dvādasamo."
    },
    {
      "id": "tha-ap122:13.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap122:14.1",
      "pali": "Parivārasumaṅgalā,"
    },
    {
      "id": "tha-ap122:14.2",
      "pali": "saraṇāsanapupphiyā;"
    },
    {
      "id": "tha-ap122:14.3",
      "pali": "Citapūjī buddhasaññī,"
    },
    {
      "id": "tha-ap122:14.4",
      "pali": "maggupaṭṭhānajātinā;"
    },
    {
      "id": "tha-ap122:14.5",
      "pali": "Gāthāyo navuti vuttā,"
    },
    {
      "id": "tha-ap122:14.6",
      "pali": "gaṇitāyo vibhāvihi."
    }
  ]
}
