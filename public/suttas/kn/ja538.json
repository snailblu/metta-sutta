{
  "uid": "ja538",
  "title": "Mūgapakkhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja538:1.1",
      "pali": "“Mā paṇḍiccayaṁ vibhāvaya,"
    },
    {
      "id": "ja538:1.2",
      "pali": "Bālamato bhava sabbapāṇinaṁ;"
    },
    {
      "id": "ja538:1.3",
      "pali": "Sabbo taṁ jano ocināyatu,"
    },
    {
      "id": "ja538:1.4",
      "pali": "Evaṁ tava attho bhavissati”."
    },
    {
      "id": "ja538:2.1",
      "pali": "“Karomi te taṁ vacanaṁ,"
    },
    {
      "id": "ja538:2.2",
      "pali": "yaṁ maṁ bhaṇasi devate;"
    },
    {
      "id": "ja538:2.3",
      "pali": "Atthakāmāsi me amma,"
    },
    {
      "id": "ja538:2.4",
      "pali": "hitakāmāsi devate”."
    },
    {
      "id": "ja538:3.1",
      "pali": "“Kiṁ nu santaramānova,"
    },
    {
      "id": "ja538:3.2",
      "pali": "kāsuṁ khaṇasi sārathi;"
    },
    {
      "id": "ja538:3.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja538:3.4",
      "pali": "kiṁ kāsuyā karissasi”."
    },
    {
      "id": "ja538:4.1",
      "pali": "“Rañño mūgo ca pakkho ca,"
    },
    {
      "id": "ja538:4.2",
      "pali": "putto jāto acetaso;"
    },
    {
      "id": "ja538:4.3",
      "pali": "Somhi raññā samajjhiṭṭho,"
    },
    {
      "id": "ja538:4.4",
      "pali": "puttaṁ me nikhaṇaṁ vane”."
    },
    {
      "id": "ja538:5.1",
      "pali": "“Na badhiro na mūgosmi,"
    },
    {
      "id": "ja538:5.2",
      "pali": "na pakkho na ca vīkalo;"
    },
    {
      "id": "ja538:5.3",
      "pali": "Adhammaṁ sārathi kayirā,"
    },
    {
      "id": "ja538:5.4",
      "pali": "mañce tvaṁ nikhaṇaṁ vane."
    },
    {
      "id": "ja538:6.1",
      "pali": "Ūrū bāhuñca me passa,"
    },
    {
      "id": "ja538:6.2",
      "pali": "bhāsitañca suṇohi me;"
    },
    {
      "id": "ja538:6.3",
      "pali": "Adhammaṁ sārathi kayirā,"
    },
    {
      "id": "ja538:6.4",
      "pali": "mañce tvaṁ nikhaṇaṁ vane”."
    },
    {
      "id": "ja538:7.1",
      "pali": "“Devatā nusi gandhabbo,"
    },
    {
      "id": "ja538:7.2",
      "pali": "adu sakko purindado;"
    },
    {
      "id": "ja538:7.3",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "ja538:7.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja538:8.1",
      "pali": "“Namhi devo na gandhabbo,"
    },
    {
      "id": "ja538:8.2",
      "pali": "nāpi sakko purindado;"
    },
    {
      "id": "ja538:8.3",
      "pali": "Kāsirañño ahaṁ putto,"
    },
    {
      "id": "ja538:8.4",
      "pali": "yaṁ kāsuyā nikhaññasi."
    },
    {
      "id": "ja538:9.1",
      "pali": "Tassa rañño ahaṁ putto,"
    },
    {
      "id": "ja538:9.2",
      "pali": "yaṁ tvaṁ sammūpajīvasi;"
    },
    {
      "id": "ja538:9.3",
      "pali": "Adhammaṁ sārathi kayirā,"
    },
    {
      "id": "ja538:9.4",
      "pali": "mañce tvaṁ nikhaṇaṁ vane."
    },
    {
      "id": "ja538:10.1",
      "pali": "Yassa rukkhassa chāyāya,"
    },
    {
      "id": "ja538:10.2",
      "pali": "nisīdeyya sayeyya vā;"
    },
    {
      "id": "ja538:10.3",
      "pali": "Na tassa sākhaṁ bhañjeyya,"
    },
    {
      "id": "ja538:10.4",
      "pali": "mittadubbho hi pāpako."
    },
    {
      "id": "ja538:11.1",
      "pali": "Yathā rukkho tathā rājā,"
    },
    {
      "id": "ja538:11.2",
      "pali": "yathā sākhā tathā ahaṁ;"
    },
    {
      "id": "ja538:11.3",
      "pali": "Yathā chāyūpago poso,"
    },
    {
      "id": "ja538:11.4",
      "pali": "evaṁ tvamasi sārathi;"
    },
    {
      "id": "ja538:11.5",
      "pali": "Adhammaṁ sārathi kayirā,"
    },
    {
      "id": "ja538:11.6",
      "pali": "mañce tvaṁ nikhaṇaṁ vane."
    },
    {
      "id": "ja538:12.1",
      "pali": "Pahūtabhakkho bhavati,"
    },
    {
      "id": "ja538:12.2",
      "pali": "vippavuttho sakaṁ gharā;"
    },
    {
      "id": "ja538:12.3",
      "pali": "Bahū naṁ upajīvanti,"
    },
    {
      "id": "ja538:12.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:13.1",
      "pali": "Yaṁ yaṁ janapadaṁ yāti,"
    },
    {
      "id": "ja538:13.2",
      "pali": "nigame rājadhāniyo;"
    },
    {
      "id": "ja538:13.3",
      "pali": "Sabbattha pūjito hoti,"
    },
    {
      "id": "ja538:13.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:14.1",
      "pali": "Nāssa corā pasāhanti,"
    },
    {
      "id": "ja538:14.2",
      "pali": "nātimaññanti khattiyā;"
    },
    {
      "id": "ja538:14.3",
      "pali": "Sabbe amitte tarati,"
    },
    {
      "id": "ja538:14.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:15.1",
      "pali": "Akkuddho sagharaṁ eti,"
    },
    {
      "id": "ja538:15.2",
      "pali": "sabhāyaṁ paṭinandito;"
    },
    {
      "id": "ja538:15.3",
      "pali": "Ñātīnaṁ uttamo hoti,"
    },
    {
      "id": "ja538:15.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:16.1",
      "pali": "Sakkatvā sakkato hoti,"
    },
    {
      "id": "ja538:16.2",
      "pali": "garu hoti sagāravo;"
    },
    {
      "id": "ja538:16.3",
      "pali": "Vaṇṇakittibhato hoti,"
    },
    {
      "id": "ja538:16.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:17.1",
      "pali": "Pūjako labhate pūjaṁ,"
    },
    {
      "id": "ja538:17.2",
      "pali": "vandako paṭivandanaṁ;"
    },
    {
      "id": "ja538:17.3",
      "pali": "Yaso kittiñca pappoti,"
    },
    {
      "id": "ja538:17.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:18.1",
      "pali": "Aggi yathā pajjalati,"
    },
    {
      "id": "ja538:18.2",
      "pali": "devatāva virocati;"
    },
    {
      "id": "ja538:18.3",
      "pali": "Siriyā ajahito hoti,"
    },
    {
      "id": "ja538:18.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:19.1",
      "pali": "Gāvo tassa pajāyanti,"
    },
    {
      "id": "ja538:19.2",
      "pali": "khette vuttaṁ virūhati;"
    },
    {
      "id": "ja538:19.3",
      "pali": "Vuttānaṁ phalamasnāti,"
    },
    {
      "id": "ja538:19.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:20.1",
      "pali": "Darito pabbatāto vā,"
    },
    {
      "id": "ja538:20.2",
      "pali": "rukkhato patito naro;"
    },
    {
      "id": "ja538:20.3",
      "pali": "Cuto patiṭṭhaṁ labhati,"
    },
    {
      "id": "ja538:20.4",
      "pali": "yo mittānaṁ na dubbhati."
    },
    {
      "id": "ja538:21.1",
      "pali": "Virūḷhamūlasantānaṁ,"
    },
    {
      "id": "ja538:21.2",
      "pali": "nigrodhamiva māluto;"
    },
    {
      "id": "ja538:21.3",
      "pali": "Amittā nappasāhanti,"
    },
    {
      "id": "ja538:21.4",
      "pali": "yo mittānaṁ na dubbhati”."
    },
    {
      "id": "ja538:22.1",
      "pali": "“Ehi taṁ paṭinessāmi,"
    },
    {
      "id": "ja538:22.2",
      "pali": "rājaputta sakaṁ gharaṁ;"
    },
    {
      "id": "ja538:22.3",
      "pali": "Rajjaṁ kārehi bhaddante,"
    },
    {
      "id": "ja538:22.4",
      "pali": "kiṁ araññe karissasi”."
    },
    {
      "id": "ja538:23.1",
      "pali": "“Alaṁ me tena rajjena,"
    },
    {
      "id": "ja538:23.2",
      "pali": "ñātakehi dhanena vā;"
    },
    {
      "id": "ja538:23.3",
      "pali": "Yaṁ me adhammacariyāya,"
    },
    {
      "id": "ja538:23.4",
      "pali": "rajjaṁ labbhetha sārathi”."
    },
    {
      "id": "ja538:24.1",
      "pali": "“Puṇṇapattaṁ maṁ lābhehi,"
    },
    {
      "id": "ja538:24.2",
      "pali": "rājaputta ito gato;"
    },
    {
      "id": "ja538:24.3",
      "pali": "Pitā mātā ca me dajjuṁ,"
    },
    {
      "id": "ja538:24.4",
      "pali": "rājaputta tayī gate."
    },
    {
      "id": "ja538:25.1",
      "pali": "Orodhā ca kumārā ca,"
    },
    {
      "id": "ja538:25.2",
      "pali": "vesiyānā ca brāhmaṇā;"
    },
    {
      "id": "ja538:25.3",
      "pali": "Tepi attamanā dajjuṁ,"
    },
    {
      "id": "ja538:25.4",
      "pali": "rājaputta tayī gate."
    },
    {
      "id": "ja538:26.1",
      "pali": "Hatthārohā anīkaṭṭhā,"
    },
    {
      "id": "ja538:26.2",
      "pali": "rathikā pattikārakā;"
    },
    {
      "id": "ja538:26.3",
      "pali": "Tepi attamanā dajjuṁ,"
    },
    {
      "id": "ja538:26.4",
      "pali": "rājaputta tayī gate."
    },
    {
      "id": "ja538:27.1",
      "pali": "Bahudhaññā jānapadā,"
    },
    {
      "id": "ja538:27.2",
      "pali": "negamā ca samāgatā;"
    },
    {
      "id": "ja538:27.3",
      "pali": "Upāyanāni me dajjuṁ,"
    },
    {
      "id": "ja538:27.4",
      "pali": "rājaputta tayī gate”."
    },
    {
      "id": "ja538:28.1",
      "pali": "“Pitu mātu cahaṁ catto,"
    },
    {
      "id": "ja538:28.2",
      "pali": "raṭṭhassa nigamassa ca;"
    },
    {
      "id": "ja538:28.3",
      "pali": "Atho sabbakumārānaṁ,"
    },
    {
      "id": "ja538:28.4",
      "pali": "natthi mayhaṁ sakaṁ gharaṁ."
    },
    {
      "id": "ja538:29.1",
      "pali": "Anuññāto ahaṁ matyā,"
    },
    {
      "id": "ja538:29.2",
      "pali": "sañcatto pitarā mahaṁ;"
    },
    {
      "id": "ja538:29.3",
      "pali": "Ekoraññe pabbajito,"
    },
    {
      "id": "ja538:29.4",
      "pali": "na kāme abhipatthaye."
    },
    {
      "id": "ja538:30.1",
      "pali": "Api ataramānānaṁ,"
    },
    {
      "id": "ja538:30.2",
      "pali": "phalāsāva samijjhati;"
    },
    {
      "id": "ja538:30.3",
      "pali": "Vipakkabrahmacariyosmi,"
    },
    {
      "id": "ja538:30.4",
      "pali": "evaṁ jānāhi sārathi."
    },
    {
      "id": "ja538:31.1",
      "pali": "Api ataramānānaṁ,"
    },
    {
      "id": "ja538:31.2",
      "pali": "sammadattho vipaccati;"
    },
    {
      "id": "ja538:31.3",
      "pali": "Vipakkabrahmacariyosmi,"
    },
    {
      "id": "ja538:31.4",
      "pali": "nikkhanto akutobhayo”."
    },
    {
      "id": "ja538:32.1",
      "pali": "“Evaṁ vaggukatho santo,"
    },
    {
      "id": "ja538:32.2",
      "pali": "visaṭṭhavacano casi;"
    },
    {
      "id": "ja538:32.3",
      "pali": "Kasmā pitu ca mātucca,"
    },
    {
      "id": "ja538:32.4",
      "pali": "santike na bhaṇī tadā”."
    },
    {
      "id": "ja538:33.1",
      "pali": "“Nāhaṁ asandhitā pakkho,"
    },
    {
      "id": "ja538:33.2",
      "pali": "na badhiro asotatā;"
    },
    {
      "id": "ja538:33.3",
      "pali": "Nāhaṁ ajivhatā mūgo,"
    },
    {
      "id": "ja538:33.4",
      "pali": "mā maṁ mūgamadhārayi."
    },
    {
      "id": "ja538:34.1",
      "pali": "Purimaṁ sarāmahaṁ jātiṁ,"
    },
    {
      "id": "ja538:34.2",
      "pali": "yattha rajjamakārayiṁ;"
    },
    {
      "id": "ja538:34.3",
      "pali": "Kārayitvā tahiṁ rajjaṁ,"
    },
    {
      "id": "ja538:34.4",
      "pali": "pāpatthaṁ nirayaṁ bhusaṁ."
    },
    {
      "id": "ja538:35.1",
      "pali": "Vīsatiñceva vassāni,"
    },
    {
      "id": "ja538:35.2",
      "pali": "tahiṁ rajjamakārayiṁ;"
    },
    {
      "id": "ja538:35.3",
      "pali": "Asītivassasahassāni,"
    },
    {
      "id": "ja538:35.4",
      "pali": "nirayamhi apaccisaṁ."
    },
    {
      "id": "ja538:36.1",
      "pali": "Tassa rajjassahaṁ bhīto,"
    },
    {
      "id": "ja538:36.2",
      "pali": "mā maṁ rajjābhisecayuṁ;"
    },
    {
      "id": "ja538:36.3",
      "pali": "Tasmā pitu ca mātucca,"
    },
    {
      "id": "ja538:36.4",
      "pali": "santike na bhaṇiṁ tadā."
    },
    {
      "id": "ja538:37.1",
      "pali": "Ucchaṅge maṁ nisādetvā,"
    },
    {
      "id": "ja538:37.2",
      "pali": "pitā atthānusāsati;"
    },
    {
      "id": "ja538:37.3",
      "pali": "Ekaṁ hanatha bandhatha,"
    },
    {
      "id": "ja538:37.4",
      "pali": "ekaṁ khārāpatacchikaṁ;"
    },
    {
      "id": "ja538:37.5",
      "pali": "Ekaṁ sūlasmiṁ uppetha,"
    },
    {
      "id": "ja538:37.6",
      "pali": "iccassa manusāsati."
    },
    {
      "id": "ja538:38.1",
      "pali": "Tāyāhaṁ pharusaṁ sutvā,"
    },
    {
      "id": "ja538:38.2",
      "pali": "vācāyo samudīritā;"
    },
    {
      "id": "ja538:38.3",
      "pali": "Amūgo mūgavaṇṇena,"
    },
    {
      "id": "ja538:38.4",
      "pali": "apakkho pakkhasammato;"
    },
    {
      "id": "ja538:38.5",
      "pali": "Sake muttakarīsasmiṁ,"
    },
    {
      "id": "ja538:38.6",
      "pali": "acchāhaṁ samparipluto."
    },
    {
      "id": "ja538:39.1",
      "pali": "Kasirañca parittañca,"
    },
    {
      "id": "ja538:39.2",
      "pali": "tañca dukkhena saṁyutaṁ;"
    },
    {
      "id": "ja538:39.3",
      "pali": "Komaṁ jīvitamāgamma,"
    },
    {
      "id": "ja538:39.4",
      "pali": "veraṁ kayirātha kenaci."
    },
    {
      "id": "ja538:40.1",
      "pali": "Paññāya ca alābhena,"
    },
    {
      "id": "ja538:40.2",
      "pali": "dhammassa ca adassanā;"
    },
    {
      "id": "ja538:40.3",
      "pali": "Komaṁ jīvitamāgamma,"
    },
    {
      "id": "ja538:40.4",
      "pali": "veraṁ kayirātha kenaci."
    },
    {
      "id": "ja538:41.1",
      "pali": "Api ataramānānaṁ,"
    },
    {
      "id": "ja538:41.2",
      "pali": "phalāsāva samijjhati;"
    },
    {
      "id": "ja538:41.3",
      "pali": "Vipakkabrahmacariyosmi,"
    },
    {
      "id": "ja538:41.4",
      "pali": "evaṁ jānāhi sārathi."
    },
    {
      "id": "ja538:42.1",
      "pali": "Api ataramānānaṁ,"
    },
    {
      "id": "ja538:42.2",
      "pali": "sammadattho vipaccati;"
    },
    {
      "id": "ja538:42.3",
      "pali": "Vipakkabrahmacariyosmi,"
    },
    {
      "id": "ja538:42.4",
      "pali": "nikkhanto akutobhayo”."
    },
    {
      "id": "ja538:43.1",
      "pali": "“Ahampi pabbajissāmi,"
    },
    {
      "id": "ja538:43.2",
      "pali": "rājaputta tavantike;"
    },
    {
      "id": "ja538:43.3",
      "pali": "Avhāyassu maṁ bhaddante,"
    },
    {
      "id": "ja538:43.4",
      "pali": "pabbajjā mama ruccati”."
    },
    {
      "id": "ja538:44.1",
      "pali": "“Rathaṁ niyyādayitvāna,"
    },
    {
      "id": "ja538:44.2",
      "pali": "anaṇo ehi sārathi;"
    },
    {
      "id": "ja538:44.3",
      "pali": "Anaṇassa hi pabbajjā,"
    },
    {
      "id": "ja538:44.4",
      "pali": "etaṁ isīhi vaṇṇitaṁ”."
    },
    {
      "id": "ja538:45.1",
      "pali": "“Yadeva tyāhaṁ vacanaṁ,"
    },
    {
      "id": "ja538:45.2",
      "pali": "akaraṁ bhaddamatthu te;"
    },
    {
      "id": "ja538:45.3",
      "pali": "Tadeva me tvaṁ vacanaṁ,"
    },
    {
      "id": "ja538:45.4",
      "pali": "yācito kattumarahasi."
    },
    {
      "id": "ja538:46.1",
      "pali": "Idheva tāva acchassu,"
    },
    {
      "id": "ja538:46.2",
      "pali": "yāva rājānamānaye;"
    },
    {
      "id": "ja538:46.3",
      "pali": "Appeva te pitā disvā,"
    },
    {
      "id": "ja538:46.4",
      "pali": "patīto sumano siyā”."
    },
    {
      "id": "ja538:47.1",
      "pali": "“Karomi tetaṁ vacanaṁ,"
    },
    {
      "id": "ja538:47.2",
      "pali": "yaṁ maṁ bhaṇasi sārathi;"
    },
    {
      "id": "ja538:47.3",
      "pali": "Ahampi daṭṭhukāmosmi,"
    },
    {
      "id": "ja538:47.4",
      "pali": "pitaraṁ me idhāgataṁ."
    },
    {
      "id": "ja538:48.1",
      "pali": "Ehi samma nivattassu,"
    },
    {
      "id": "ja538:48.2",
      "pali": "kusalaṁ vajjāsi ñātinaṁ;"
    },
    {
      "id": "ja538:48.3",
      "pali": "Mātaraṁ pitaraṁ mayhaṁ,"
    },
    {
      "id": "ja538:48.4",
      "pali": "vutto vajjāsi vandanaṁ”."
    },
    {
      "id": "ja538:49.1",
      "pali": "Tassa pāde gahetvāna,"
    },
    {
      "id": "ja538:49.2",
      "pali": "katvā ca naṁ padakkhiṇaṁ;"
    },
    {
      "id": "ja538:49.3",
      "pali": "Sārathi rathamāruyha,"
    },
    {
      "id": "ja538:49.4",
      "pali": "rājadvāraṁ upāgami."
    },
    {
      "id": "ja538:50.1",
      "pali": "Suññaṁ mātā rathaṁ disvā,"
    },
    {
      "id": "ja538:50.2",
      "pali": "ekaṁ sārathimāgataṁ;"
    },
    {
      "id": "ja538:50.3",
      "pali": "Assupuṇṇehi nettehi,"
    },
    {
      "id": "ja538:50.4",
      "pali": "rodantī naṁ udikkhati."
    },
    {
      "id": "ja538:51.1",
      "pali": "“Ayaṁ so sārathi eti,"
    },
    {
      "id": "ja538:51.2",
      "pali": "nihantvā mama atrajaṁ;"
    },
    {
      "id": "ja538:51.3",
      "pali": "Nihato nūna me putto,"
    },
    {
      "id": "ja538:51.4",
      "pali": "pathabyā bhūmivaḍḍhano."
    },
    {
      "id": "ja538:52.1",
      "pali": "Amittā nūna nandanti,"
    },
    {
      "id": "ja538:52.2",
      "pali": "patītā nūna verino;"
    },
    {
      "id": "ja538:52.3",
      "pali": "Āgataṁ sārathiṁ disvā,"
    },
    {
      "id": "ja538:52.4",
      "pali": "nihantvā mama atrajaṁ”."
    },
    {
      "id": "ja538:53.1",
      "pali": "Suññaṁ mātā rathaṁ disvā,"
    },
    {
      "id": "ja538:53.2",
      "pali": "ekaṁ sārathimāgataṁ;"
    },
    {
      "id": "ja538:53.3",
      "pali": "Assupuṇṇehi nettehi,"
    },
    {
      "id": "ja538:53.4",
      "pali": "rodantī paripucchi naṁ."
    },
    {
      "id": "ja538:54.1",
      "pali": "“Kiṁ nu mūgo kiṁ nu pakkho,"
    },
    {
      "id": "ja538:54.2",
      "pali": "kiṁ nu so vilapī tadā;"
    },
    {
      "id": "ja538:54.3",
      "pali": "Nihaññamāno bhūmiyā,"
    },
    {
      "id": "ja538:54.4",
      "pali": "taṁ me akkhāhi sārathi."
    },
    {
      "id": "ja538:55.1",
      "pali": "Kathaṁ hatthehi pādehi,"
    },
    {
      "id": "ja538:55.2",
      "pali": "mūgapakkho vivajjayi;"
    },
    {
      "id": "ja538:55.3",
      "pali": "Nihaññamāno bhūmiyā,"
    },
    {
      "id": "ja538:55.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja538:56.1",
      "pali": "“Akkheyyaṁ te ahaṁ ayye,"
    },
    {
      "id": "ja538:56.2",
      "pali": "dajjāsi abhayaṁ mama;"
    },
    {
      "id": "ja538:56.3",
      "pali": "Yaṁ me sutaṁ vā diṭṭhaṁ vā,"
    },
    {
      "id": "ja538:56.4",
      "pali": "rājaputtassa santike”."
    },
    {
      "id": "ja538:57.1",
      "pali": "“Abhayaṁ samma te dammi,"
    },
    {
      "id": "ja538:57.2",
      "pali": "abhīto bhaṇa sārathi;"
    },
    {
      "id": "ja538:57.3",
      "pali": "Yaṁ te sutaṁ vā diṭṭhaṁ vā,"
    },
    {
      "id": "ja538:57.4",
      "pali": "rājaputtassa santike”."
    },
    {
      "id": "ja538:58.1",
      "pali": "“Na so mūgo na so pakkho,"
    },
    {
      "id": "ja538:58.2",
      "pali": "visaṭṭhavacano ca so;"
    },
    {
      "id": "ja538:58.3",
      "pali": "Rajjassa kira so bhīto,"
    },
    {
      "id": "ja538:58.4",
      "pali": "akarā ālaye bahū."
    },
    {
      "id": "ja538:59.1",
      "pali": "Purimaṁ sarati so jātiṁ,"
    },
    {
      "id": "ja538:59.2",
      "pali": "yattha rajjamakārayi;"
    },
    {
      "id": "ja538:59.3",
      "pali": "Kārayitvā tahiṁ rajjaṁ,"
    },
    {
      "id": "ja538:59.4",
      "pali": "pāpattha nirayaṁ bhusaṁ."
    },
    {
      "id": "ja538:60.1",
      "pali": "Vīsatiñceva vassāni,"
    },
    {
      "id": "ja538:60.2",
      "pali": "tahiṁ rajjamakārayi;"
    },
    {
      "id": "ja538:60.3",
      "pali": "Asītivassasahassāni,"
    },
    {
      "id": "ja538:60.4",
      "pali": "nirayamhi apacci so."
    },
    {
      "id": "ja538:61.1",
      "pali": "Tassa rajjassa so bhīto,"
    },
    {
      "id": "ja538:61.2",
      "pali": "mā maṁ rajjābhisecayuṁ;"
    },
    {
      "id": "ja538:61.3",
      "pali": "Tasmā pitu ca mātucca,"
    },
    {
      "id": "ja538:61.4",
      "pali": "santike na bhaṇī tadā."
    },
    {
      "id": "ja538:62.1",
      "pali": "Aṅgapaccaṅgasampanno,"
    },
    {
      "id": "ja538:62.2",
      "pali": "ārohapariṇāhavā;"
    },
    {
      "id": "ja538:62.3",
      "pali": "Visaṭṭhavacano pañño,"
    },
    {
      "id": "ja538:62.4",
      "pali": "magge saggassa tiṭṭhati."
    },
    {
      "id": "ja538:63.1",
      "pali": "Sace tvaṁ daṭṭhukāmāsi,"
    },
    {
      "id": "ja538:63.2",
      "pali": "rājaputtaṁ tavatrajaṁ;"
    },
    {
      "id": "ja538:63.3",
      "pali": "Ehi taṁ pāpayissāmi,"
    },
    {
      "id": "ja538:63.4",
      "pali": "yattha sammati temiyo”."
    },
    {
      "id": "ja538:64.1",
      "pali": "“Yojayantu rathe asse,"
    },
    {
      "id": "ja538:64.2",
      "pali": "Kacchaṁ nāgāna bandhatha;"
    },
    {
      "id": "ja538:64.3",
      "pali": "Udīrayantu saṅkhapaṇavā,"
    },
    {
      "id": "ja538:64.4",
      "pali": "Vādantu ekapokkharā."
    },
    {
      "id": "ja538:65.1",
      "pali": "Vādantu bherī sannaddhā,"
    },
    {
      "id": "ja538:65.2",
      "pali": "vaggū vādantu dundubhī;"
    },
    {
      "id": "ja538:65.3",
      "pali": "Negamā ca maṁ anventu,"
    },
    {
      "id": "ja538:65.4",
      "pali": "gacchaṁ puttanivedako."
    },
    {
      "id": "ja538:66.1",
      "pali": "Orodhā ca kumārā ca,"
    },
    {
      "id": "ja538:66.2",
      "pali": "vesiyānā ca brāhmaṇā;"
    },
    {
      "id": "ja538:66.3",
      "pali": "Khippaṁ yānāni yojentu,"
    },
    {
      "id": "ja538:66.4",
      "pali": "gacchaṁ puttanivedako."
    },
    {
      "id": "ja538:67.1",
      "pali": "Hatthārohā anīkaṭṭhā,"
    },
    {
      "id": "ja538:67.2",
      "pali": "rathikā pattikārakā;"
    },
    {
      "id": "ja538:67.3",
      "pali": "Khippaṁ yānāni yojentu,"
    },
    {
      "id": "ja538:67.4",
      "pali": "gacchaṁ puttanivedako."
    },
    {
      "id": "ja538:68.1",
      "pali": "Samāgatā jānapadā,"
    },
    {
      "id": "ja538:68.2",
      "pali": "negamā ca samāgatā;"
    },
    {
      "id": "ja538:68.3",
      "pali": "Khippaṁ yānāni yojentu,"
    },
    {
      "id": "ja538:68.4",
      "pali": "gacchaṁ puttanivedako”."
    },
    {
      "id": "ja538:69.1",
      "pali": "Asse ca sārathī yutte,"
    },
    {
      "id": "ja538:69.2",
      "pali": "sindhave sīghavāhane;"
    },
    {
      "id": "ja538:69.3",
      "pali": "Rājadvāraṁ upāgacchuṁ,"
    },
    {
      "id": "ja538:69.4",
      "pali": "“yuttā deva ime hayā”."
    },
    {
      "id": "ja538:70.1",
      "pali": "“Thūlā javena hāyanti,"
    },
    {
      "id": "ja538:70.2",
      "pali": "kisā hāyanti thāmunā;"
    },
    {
      "id": "ja538:70.3",
      "pali": "Kise thūle vivajjetvā,"
    },
    {
      "id": "ja538:70.4",
      "pali": "saṁsaṭṭhā yojitā hayā”."
    },
    {
      "id": "ja538:71.1",
      "pali": "Tato rājā taramāno,"
    },
    {
      "id": "ja538:71.2",
      "pali": "yuttamāruyha sandanaṁ;"
    },
    {
      "id": "ja538:71.3",
      "pali": "Itthāgāraṁ ajjhabhāsi,"
    },
    {
      "id": "ja538:71.4",
      "pali": "“sabbāva anuyātha maṁ."
    },
    {
      "id": "ja538:72.1",
      "pali": "Vālabījanimuṇhīsaṁ,"
    },
    {
      "id": "ja538:72.2",
      "pali": "khaggaṁ chattañca paṇḍaraṁ;"
    },
    {
      "id": "ja538:72.3",
      "pali": "Upādhī rathamāruyha,"
    },
    {
      "id": "ja538:72.4",
      "pali": "suvaṇṇehi alaṅkatā”."
    },
    {
      "id": "ja538:73.1",
      "pali": "Tato sa rājā pāyāsi,"
    },
    {
      "id": "ja538:73.2",
      "pali": "purakkhatvāna sārathiṁ;"
    },
    {
      "id": "ja538:73.3",
      "pali": "Khippameva upāgacchi,"
    },
    {
      "id": "ja538:73.4",
      "pali": "yattha sammati temiyo."
    },
    {
      "id": "ja538:74.1",
      "pali": "Tañca disvāna āyantaṁ,"
    },
    {
      "id": "ja538:74.2",
      "pali": "jalantamiva tejasā;"
    },
    {
      "id": "ja538:74.3",
      "pali": "Khattasaṅghaparibyūḷhaṁ,"
    },
    {
      "id": "ja538:74.4",
      "pali": "temiyo etadabravi."
    },
    {
      "id": "ja538:75.1",
      "pali": "“Kacci nu tāta kusalaṁ,"
    },
    {
      "id": "ja538:75.2",
      "pali": "kacci tāta anāmayaṁ;"
    },
    {
      "id": "ja538:75.3",
      "pali": "Sabbā ca rājakaññāyo,"
    },
    {
      "id": "ja538:75.4",
      "pali": "arogā mayha mātaro”."
    },
    {
      "id": "ja538:76.1",
      "pali": "“Kusalañceva me putta,"
    },
    {
      "id": "ja538:76.2",
      "pali": "atho putta anāmayaṁ;"
    },
    {
      "id": "ja538:76.3",
      "pali": "Sabbā ca rājakaññāyo,"
    },
    {
      "id": "ja538:76.4",
      "pali": "arogā tuyha mātaro”."
    },
    {
      "id": "ja538:77.1",
      "pali": "“Kacci amajjapo tāta,"
    },
    {
      "id": "ja538:77.2",
      "pali": "kacci te suramappiyaṁ;"
    },
    {
      "id": "ja538:77.3",
      "pali": "Kacci sacce ca dhamme ca,"
    },
    {
      "id": "ja538:77.4",
      "pali": "dāne te ramate mano”."
    },
    {
      "id": "ja538:78.1",
      "pali": "“Amajjapo ahaṁ putta,"
    },
    {
      "id": "ja538:78.2",
      "pali": "atho me suramappiyaṁ;"
    },
    {
      "id": "ja538:78.3",
      "pali": "Atho sacce ca dhamme ca,"
    },
    {
      "id": "ja538:78.4",
      "pali": "dāne me ramate mano”."
    },
    {
      "id": "ja538:79.1",
      "pali": "“Kacci arogaṁ yoggaṁ te,"
    },
    {
      "id": "ja538:79.2",
      "pali": "kacci vahati vāhanaṁ;"
    },
    {
      "id": "ja538:79.3",
      "pali": "Kacci te byādhayo natthi,"
    },
    {
      "id": "ja538:79.4",
      "pali": "sarīrassupatāpanā”."
    },
    {
      "id": "ja538:80.1",
      "pali": "“Atho arogaṁ yoggaṁ me,"
    },
    {
      "id": "ja538:80.2",
      "pali": "atho vahati vāhanaṁ;"
    },
    {
      "id": "ja538:80.3",
      "pali": "Atho me byādhayo natthi,"
    },
    {
      "id": "ja538:80.4",
      "pali": "sarīrassupatāpanā”."
    },
    {
      "id": "ja538:81.1",
      "pali": "“Kacci antā ca te phītā,"
    },
    {
      "id": "ja538:81.2",
      "pali": "majjhe ca bahalā tava;"
    },
    {
      "id": "ja538:81.3",
      "pali": "Koṭṭhāgārañca kosañca,"
    },
    {
      "id": "ja538:81.4",
      "pali": "kacci te paṭisanthataṁ”."
    },
    {
      "id": "ja538:82.1",
      "pali": "“Atho antā ca me phītā,"
    },
    {
      "id": "ja538:82.2",
      "pali": "majjhe ca bahalā mama;"
    },
    {
      "id": "ja538:82.3",
      "pali": "Koṭṭhāgārañca kosañca,"
    },
    {
      "id": "ja538:82.4",
      "pali": "sabbaṁ me paṭisanthataṁ”."
    },
    {
      "id": "ja538:83.1",
      "pali": "“Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja538:83.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja538:83.3",
      "pali": "Patiṭṭhapentu pallaṅkaṁ,"
    },
    {
      "id": "ja538:83.4",
      "pali": "yattha rājā nisakkati."
    },
    {
      "id": "ja538:84.1",
      "pali": "Idheva te nisīdassu,"
    },
    {
      "id": "ja538:84.2",
      "pali": "niyate paṇṇasanthare;"
    },
    {
      "id": "ja538:84.3",
      "pali": "Etto udakamādāya,"
    },
    {
      "id": "ja538:84.4",
      "pali": "pāde pakkhālayassu te."
    },
    {
      "id": "ja538:85.1",
      "pali": "Idampi paṇṇakaṁ mayhaṁ,"
    },
    {
      "id": "ja538:85.2",
      "pali": "randhaṁ rāja aloṇakaṁ;"
    },
    {
      "id": "ja538:85.3",
      "pali": "Paribhuñja mahārāja,"
    },
    {
      "id": "ja538:85.4",
      "pali": "pāhuno mesidhāgato”."
    },
    {
      "id": "ja538:86.1",
      "pali": "“Na cāhaṁ paṇṇaṁ bhuñjāmi,"
    },
    {
      "id": "ja538:86.2",
      "pali": "Na hetaṁ mayha bhojanaṁ;"
    },
    {
      "id": "ja538:86.3",
      "pali": "Sālīnaṁ odanaṁ bhuñje,"
    },
    {
      "id": "ja538:86.4",
      "pali": "Suciṁ maṁsūpasecanaṁ”."
    },
    {
      "id": "ja538:87.1",
      "pali": "“Accherakaṁ maṁ paṭibhāti,"
    },
    {
      "id": "ja538:87.2",
      "pali": "ekakampi rahogataṁ;"
    },
    {
      "id": "ja538:87.3",
      "pali": "Edisaṁ bhuñjamānānaṁ,"
    },
    {
      "id": "ja538:87.4",
      "pali": "kena vaṇṇo pasīdati”."
    },
    {
      "id": "ja538:88.1",
      "pali": "“Eko rāja nipajjāmi,"
    },
    {
      "id": "ja538:88.2",
      "pali": "niyate paṇṇasanthare;"
    },
    {
      "id": "ja538:88.3",
      "pali": "Tāya me ekaseyyāya,"
    },
    {
      "id": "ja538:88.4",
      "pali": "rāja vaṇṇo pasīdati."
    },
    {
      "id": "ja538:89.1",
      "pali": "Na ca nettiṁsabandhā me,"
    },
    {
      "id": "ja538:89.2",
      "pali": "rājarakkhā upaṭṭhitā;"
    },
    {
      "id": "ja538:89.3",
      "pali": "Tāya me sukhaseyyāya,"
    },
    {
      "id": "ja538:89.4",
      "pali": "rāja vaṇṇo pasīdati."
    },
    {
      "id": "ja538:90.1",
      "pali": "Atītaṁ nānusocāmi,"
    },
    {
      "id": "ja538:90.2",
      "pali": "nappajappāmināgataṁ;"
    },
    {
      "id": "ja538:90.3",
      "pali": "Paccuppannena yāpemi,"
    },
    {
      "id": "ja538:90.4",
      "pali": "tena vaṇṇo pasīdati."
    },
    {
      "id": "ja538:91.1",
      "pali": "Anāgatappajappāya,"
    },
    {
      "id": "ja538:91.2",
      "pali": "atītassānusocanā;"
    },
    {
      "id": "ja538:91.3",
      "pali": "Etena bālā sussanti,"
    },
    {
      "id": "ja538:91.4",
      "pali": "naḷova harito luto”."
    },
    {
      "id": "ja538:92.1",
      "pali": "“Hatthānīkaṁ rathānīkaṁ,"
    },
    {
      "id": "ja538:92.2",
      "pali": "asse pattī ca vammino;"
    },
    {
      "id": "ja538:92.3",
      "pali": "Nivesanāni rammāni,"
    },
    {
      "id": "ja538:92.4",
      "pali": "ahaṁ putta dadāmi te."
    },
    {
      "id": "ja538:93.1",
      "pali": "Itthāgārampi te dammi,"
    },
    {
      "id": "ja538:93.2",
      "pali": "sabbālaṅkārabhūsitaṁ;"
    },
    {
      "id": "ja538:93.3",
      "pali": "Tā putta paṭipajjassu,"
    },
    {
      "id": "ja538:93.4",
      "pali": "tvaṁ no rājā bhavissasi."
    },
    {
      "id": "ja538:94.1",
      "pali": "Kusalā naccagītassa,"
    },
    {
      "id": "ja538:94.2",
      "pali": "sikkhitā cāturitthiyo;"
    },
    {
      "id": "ja538:94.3",
      "pali": "Kāme taṁ ramayissanti,"
    },
    {
      "id": "ja538:94.4",
      "pali": "kiṁ araññe karissasi."
    },
    {
      "id": "ja538:95.1",
      "pali": "Paṭirājūhi te kaññā,"
    },
    {
      "id": "ja538:95.2",
      "pali": "ānayissaṁ alaṅkatā;"
    },
    {
      "id": "ja538:95.3",
      "pali": "Tāsu putte janetvāna,"
    },
    {
      "id": "ja538:95.4",
      "pali": "atha pacchā pabbajissasi."
    },
    {
      "id": "ja538:96.1",
      "pali": "Yuvā ca daharo cāsi,"
    },
    {
      "id": "ja538:96.2",
      "pali": "paṭhamuppattiko susu;"
    },
    {
      "id": "ja538:96.3",
      "pali": "Rajjaṁ kārehi bhaddante,"
    },
    {
      "id": "ja538:96.4",
      "pali": "kiṁ araññe karissasi”."
    },
    {
      "id": "ja538:97.1",
      "pali": "“Yuvā care brahmacariyaṁ,"
    },
    {
      "id": "ja538:97.2",
      "pali": "brahmacārī yuvā siyā;"
    },
    {
      "id": "ja538:97.3",
      "pali": "Daharassa hi pabbajjā,"
    },
    {
      "id": "ja538:97.4",
      "pali": "etaṁ isīhi vaṇṇitaṁ."
    },
    {
      "id": "ja538:98.1",
      "pali": "Yuvā care brahmacariyaṁ,"
    },
    {
      "id": "ja538:98.2",
      "pali": "brahmacārī yuvā siyā;"
    },
    {
      "id": "ja538:98.3",
      "pali": "Brahmacariyaṁ carissāmi,"
    },
    {
      "id": "ja538:98.4",
      "pali": "nāhaṁ rajjena matthiko."
    },
    {
      "id": "ja538:99.1",
      "pali": "Passāmi vohaṁ daharaṁ,"
    },
    {
      "id": "ja538:99.2",
      "pali": "amma tāta vadantaraṁ;"
    },
    {
      "id": "ja538:99.3",
      "pali": "Kicchāladdhaṁ piyaṁ puttaṁ,"
    },
    {
      "id": "ja538:99.4",
      "pali": "appatvāva jaraṁ mataṁ."
    },
    {
      "id": "ja538:100.1",
      "pali": "Passāmi vohaṁ dahariṁ,"
    },
    {
      "id": "ja538:100.2",
      "pali": "kumāriṁ cārudassaniṁ;"
    },
    {
      "id": "ja538:100.3",
      "pali": "Navavaṁsakaḷīraṁva,"
    },
    {
      "id": "ja538:100.4",
      "pali": "paluggaṁ jīvitakkhayaṁ."
    },
    {
      "id": "ja538:101.1",
      "pali": "Daharāpi hi miyyanti,"
    },
    {
      "id": "ja538:101.2",
      "pali": "narā ca atha nāriyo;"
    },
    {
      "id": "ja538:101.3",
      "pali": "Tattha ko vissase poso,"
    },
    {
      "id": "ja538:101.4",
      "pali": "daharomhīti jīvite."
    },
    {
      "id": "ja538:102.1",
      "pali": "Yassa ratyā vivasāne,"
    },
    {
      "id": "ja538:102.2",
      "pali": "āyu appataraṁ siyā;"
    },
    {
      "id": "ja538:102.3",
      "pali": "Appodakeva macchānaṁ,"
    },
    {
      "id": "ja538:102.4",
      "pali": "kiṁ nu komārakaṁ tahiṁ."
    },
    {
      "id": "ja538:103.1",
      "pali": "Niccamabbhāhato loko,"
    },
    {
      "id": "ja538:103.2",
      "pali": "niccañca parivārito;"
    },
    {
      "id": "ja538:103.3",
      "pali": "Amoghāsu vajantīsu,"
    },
    {
      "id": "ja538:103.4",
      "pali": "kiṁ maṁ rajjebhisiñcasi”."
    },
    {
      "id": "ja538:104.1",
      "pali": "“Kena mabbhāhato loko,"
    },
    {
      "id": "ja538:104.2",
      "pali": "kena ca parivārito;"
    },
    {
      "id": "ja538:104.3",
      "pali": "Kāyo amoghā gacchanti,"
    },
    {
      "id": "ja538:104.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja538:105.1",
      "pali": "“Maccunābbhāhato loko,"
    },
    {
      "id": "ja538:105.2",
      "pali": "jarāya parivārito;"
    },
    {
      "id": "ja538:105.3",
      "pali": "Ratyo amoghā gacchanti,"
    },
    {
      "id": "ja538:105.4",
      "pali": "evaṁ jānāhi khattiya."
    },
    {
      "id": "ja538:106.1",
      "pali": "Yathāpi tante vitate,"
    },
    {
      "id": "ja538:106.2",
      "pali": "yaṁ yadevūpaviyyati;"
    },
    {
      "id": "ja538:106.3",
      "pali": "Appakaṁ hoti vetabbaṁ,"
    },
    {
      "id": "ja538:106.4",
      "pali": "evaṁ maccāna jīvitaṁ."
    },
    {
      "id": "ja538:107.1",
      "pali": "Yathā vārivaho pūro,"
    },
    {
      "id": "ja538:107.2",
      "pali": "gacchannupanivattati;"
    },
    {
      "id": "ja538:107.3",
      "pali": "Evamāyu manussānaṁ,"
    },
    {
      "id": "ja538:107.4",
      "pali": "gacchannupanivattati."
    },
    {
      "id": "ja538:108.1",
      "pali": "Yathā vārivaho pūro,"
    },
    {
      "id": "ja538:108.2",
      "pali": "vahe rukkhepakūlaje;"
    },
    {
      "id": "ja538:108.3",
      "pali": "Evaṁ jarāmaraṇena,"
    },
    {
      "id": "ja538:108.4",
      "pali": "vuyhante sabbapāṇino”."
    },
    {
      "id": "ja538:109.1",
      "pali": "“Hatthānīkaṁ rathānīkaṁ,"
    },
    {
      "id": "ja538:109.2",
      "pali": "asse pattī ca vammino;"
    },
    {
      "id": "ja538:109.3",
      "pali": "Nivesanāni rammāni,"
    },
    {
      "id": "ja538:109.4",
      "pali": "ahaṁ putta dadāmi te."
    },
    {
      "id": "ja538:110.1",
      "pali": "Itthāgārampi te dammi,"
    },
    {
      "id": "ja538:110.2",
      "pali": "sabbālaṅkārabhūsitaṁ;"
    },
    {
      "id": "ja538:110.3",
      "pali": "Tā putta paṭipajjassu,"
    },
    {
      "id": "ja538:110.4",
      "pali": "tvaṁ no rājā bhavissasi."
    },
    {
      "id": "ja538:111.1",
      "pali": "Kusalā naccagītassa,"
    },
    {
      "id": "ja538:111.2",
      "pali": "sikkhitā cāturitthiyo;"
    },
    {
      "id": "ja538:111.3",
      "pali": "Kāme taṁ ramayissanti,"
    },
    {
      "id": "ja538:111.4",
      "pali": "kiṁ araññe karissasi."
    },
    {
      "id": "ja538:112.1",
      "pali": "Paṭirājūhi te kaññā,"
    },
    {
      "id": "ja538:112.2",
      "pali": "ānayissaṁ alaṅkatā;"
    },
    {
      "id": "ja538:112.3",
      "pali": "Tāsu putte janetvāna,"
    },
    {
      "id": "ja538:112.4",
      "pali": "atha pacchā pabbajissasi."
    },
    {
      "id": "ja538:113.1",
      "pali": "Yuvā ca daharo cāsi,"
    },
    {
      "id": "ja538:113.2",
      "pali": "paṭhamuppattiko susu;"
    },
    {
      "id": "ja538:113.3",
      "pali": "Rajjaṁ kārehi bhaddante,"
    },
    {
      "id": "ja538:113.4",
      "pali": "kiṁ araññe karissasi."
    },
    {
      "id": "ja538:114.1",
      "pali": "Koṭṭhāgārañca kosañca,"
    },
    {
      "id": "ja538:114.2",
      "pali": "vāhanāni balāni ca;"
    },
    {
      "id": "ja538:114.3",
      "pali": "Nivesanāni rammāni,"
    },
    {
      "id": "ja538:114.4",
      "pali": "ahaṁ putta dadāmi te."
    },
    {
      "id": "ja538:115.1",
      "pali": "Gomaṇḍalaparibyūḷho,"
    },
    {
      "id": "ja538:115.2",
      "pali": "dāsisaṅghapurakkhato;"
    },
    {
      "id": "ja538:115.3",
      "pali": "Rajjaṁ kārehi bhaddante,"
    },
    {
      "id": "ja538:115.4",
      "pali": "kiṁ araññe karissasi”."
    },
    {
      "id": "ja538:116.1",
      "pali": "“Kiṁ dhanena yaṁ khīyetha,"
    },
    {
      "id": "ja538:116.2",
      "pali": "Kiṁ bhariyāya marissati;"
    },
    {
      "id": "ja538:116.3",
      "pali": "Kiṁ yobbanena jiṇṇena,"
    },
    {
      "id": "ja538:116.4",
      "pali": "Yaṁ jarāyābhibhuyyati."
    },
    {
      "id": "ja538:117.1",
      "pali": "Tattha kā nandi kā khiḍḍā,"
    },
    {
      "id": "ja538:117.2",
      "pali": "kā rati kā dhanesanā;"
    },
    {
      "id": "ja538:117.3",
      "pali": "Kiṁ me puttehi dārehi,"
    },
    {
      "id": "ja538:117.4",
      "pali": "rāja muttosmi bandhanā."
    },
    {
      "id": "ja538:118.1",
      "pali": "Yohaṁ evaṁ pajānāmi,"
    },
    {
      "id": "ja538:118.2",
      "pali": "maccu me nappamajjati;"
    },
    {
      "id": "ja538:118.3",
      "pali": "Antakenādhipannassa,"
    },
    {
      "id": "ja538:118.4",
      "pali": "kā ratī kā dhanesanā."
    },
    {
      "id": "ja538:119.1",
      "pali": "Phalānamiva pakkānaṁ,"
    },
    {
      "id": "ja538:119.2",
      "pali": "niccaṁ patanato bhayaṁ;"
    },
    {
      "id": "ja538:119.3",
      "pali": "Evaṁ jātāna maccānaṁ,"
    },
    {
      "id": "ja538:119.4",
      "pali": "niccaṁ maraṇato bhayaṁ."
    },
    {
      "id": "ja538:120.1",
      "pali": "Sāyameke na dissanti,"
    },
    {
      "id": "ja538:120.2",
      "pali": "pāto diṭṭhā bahū janā;"
    },
    {
      "id": "ja538:120.3",
      "pali": "Pāto eke na dissanti,"
    },
    {
      "id": "ja538:120.4",
      "pali": "sāyaṁ diṭṭhā bahū janā."
    },
    {
      "id": "ja538:121.1",
      "pali": "Ajjeva kiccaṁ ātapaṁ,"
    },
    {
      "id": "ja538:121.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja538:121.3",
      "pali": "Na hi no saṅgaraṁ tena,"
    },
    {
      "id": "ja538:121.4",
      "pali": "mahāsenena maccunā."
    },
    {
      "id": "ja538:122.1",
      "pali": "Corā dhanassa patthenti,"
    },
    {
      "id": "ja538:122.2",
      "pali": "rāja muttosmi bandhanā;"
    },
    {
      "id": "ja538:122.3",
      "pali": "Ehi rāja nivattassu,"
    },
    {
      "id": "ja538:122.4",
      "pali": "nāhaṁ rajjena matthiko”ti."
    },
    {
      "id": "ja538:123.1",
      "pali": "Mūgapakkhajātakaṁ paṭhamaṁ."
    }
  ]
}
