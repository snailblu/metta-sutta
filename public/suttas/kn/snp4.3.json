{
  "uid": "snp4.3",
  "title": "Duṭṭhaṭṭhakasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.3:1.1",
      "pali": "Vadanti ve duṭṭhamanāpi eke,"
    },
    {
      "id": "snp4.3:1.2",
      "pali": "Athopi ve saccamanā vadanti;"
    },
    {
      "id": "snp4.3:1.3",
      "pali": "Vādañca jātaṁ muni no upeti,"
    },
    {
      "id": "snp4.3:1.4",
      "pali": "Tasmā munī natthi khilo kuhiñci."
    },
    {
      "id": "snp4.3:2.1",
      "pali": "Sakañhi diṭṭhiṁ kathamaccayeyya,"
    },
    {
      "id": "snp4.3:2.2",
      "pali": "Chandānunīto ruciyā niviṭṭho;"
    },
    {
      "id": "snp4.3:2.3",
      "pali": "Sayaṁ samattāni pakubbamāno,"
    },
    {
      "id": "snp4.3:2.4",
      "pali": "Yathā hi jāneyya tathā vadeyya."
    },
    {
      "id": "snp4.3:3.1",
      "pali": "Yo attano sīlavatāni jantu,"
    },
    {
      "id": "snp4.3:3.2",
      "pali": "Anānupuṭṭhova paresa pāva;"
    },
    {
      "id": "snp4.3:3.3",
      "pali": "Anariyadhammaṁ kusalā tamāhu,"
    },
    {
      "id": "snp4.3:3.4",
      "pali": "Yo ātumānaṁ sayameva pāva."
    },
    {
      "id": "snp4.3:4.1",
      "pali": "Santo ca bhikkhu abhinibbutatto,"
    },
    {
      "id": "snp4.3:4.2",
      "pali": "Itihanti sīlesu akatthamāno;"
    },
    {
      "id": "snp4.3:4.3",
      "pali": "Tamariyadhammaṁ kusalā vadanti,"
    },
    {
      "id": "snp4.3:4.4",
      "pali": "Yassussadā natthi kuhiñci loke."
    },
    {
      "id": "snp4.3:5.1",
      "pali": "Pakappitā saṅkhatā yassa dhammā,"
    },
    {
      "id": "snp4.3:5.2",
      "pali": "Purakkhatā santi avīvadātā;"
    },
    {
      "id": "snp4.3:5.3",
      "pali": "Yadattani passati ānisaṁsaṁ,"
    },
    {
      "id": "snp4.3:5.4",
      "pali": "Taṁ nissito kuppapaṭiccasantiṁ."
    },
    {
      "id": "snp4.3:6.1",
      "pali": "Diṭṭhīnivesā na hi svātivattā,"
    },
    {
      "id": "snp4.3:6.2",
      "pali": "Dhammesu niccheyya samuggahītaṁ;"
    },
    {
      "id": "snp4.3:6.3",
      "pali": "Tasmā naro tesu nivesanesu,"
    },
    {
      "id": "snp4.3:6.4",
      "pali": "Nirassatī ādiyatī ca dhammaṁ."
    },
    {
      "id": "snp4.3:7.1",
      "pali": "Dhonassa hi natthi kuhiñci loke,"
    },
    {
      "id": "snp4.3:7.2",
      "pali": "Pakappitā diṭṭhi bhavābhavesu;"
    },
    {
      "id": "snp4.3:7.3",
      "pali": "Māyañca mānañca pahāya dhono,"
    },
    {
      "id": "snp4.3:7.4",
      "pali": "Sa kena gaccheyya anūpayo so."
    },
    {
      "id": "snp4.3:8.1",
      "pali": "Upayo hi dhammesu upeti vādaṁ,"
    },
    {
      "id": "snp4.3:8.2",
      "pali": "Anūpayaṁ kena kathaṁ vadeyya;"
    },
    {
      "id": "snp4.3:8.3",
      "pali": "Attā nirattā na hi tassa atthi,"
    },
    {
      "id": "snp4.3:8.4",
      "pali": "Adhosi so diṭṭhimidheva sabbanti."
    },
    {
      "id": "snp4.3:8.5",
      "pali": "Duṭṭhaṭṭhakasuttaṁ tatiyaṁ."
    }
  ]
}
