{
  "uid": "vv56",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv56:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv56:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv56:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv56:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv56:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv56:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv56:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv56:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv56:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv56:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv56:3.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv56:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv56:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv56:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv56:5.1",
      "pali": "“Karaṇīyāni puññāni,"
    },
    {
      "id": "vv56:5.2",
      "pali": "paṇḍitena vijānatā;"
    },
    {
      "id": "vv56:5.3",
      "pali": "Sammaggatesu buddhesu,"
    },
    {
      "id": "vv56:5.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv56:6.1",
      "pali": "Atthāya vata me buddho,"
    },
    {
      "id": "vv56:6.2",
      "pali": "araññā gāmamāgato;"
    },
    {
      "id": "vv56:6.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "vv56:6.4",
      "pali": "tāvatiṁsūpago ahaṁ."
    },
    {
      "id": "vv56:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv56:7.2",
      "pali": "…pe…"
    },
    {
      "id": "vv56:7.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv56:8.1",
      "pali": "Paṭhamakaraṇīyavimānaṁ chaṭṭhaṁ."
    }
  ]
}
