{
  "uid": "tha-ap235",
  "title": "Sālapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap235:1.1",
      "pali": "“Aruṇavatiyā nagare,"
    },
    {
      "id": "tha-ap235:1.2",
      "pali": "ahosiṁ pūpiko tadā;"
    },
    {
      "id": "tha-ap235:1.3",
      "pali": "Mama dvārena gacchantaṁ,"
    },
    {
      "id": "tha-ap235:1.4",
      "pali": "sikhinaṁ addasaṁ jinaṁ."
    },
    {
      "id": "tha-ap235:2.1",
      "pali": "Buddhassa pattaṁ paggayha,"
    },
    {
      "id": "tha-ap235:2.2",
      "pali": "sālapupphaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap235:2.3",
      "pali": "Sammaggatassa buddhassa,"
    },
    {
      "id": "tha-ap235:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap235:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap235:3.2",
      "pali": "Yaṁ pupphamabhidāsahaṁ;"
    },
    {
      "id": "tha-ap235:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap235:3.4",
      "pali": "Sālapupphassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap235:4.1",
      "pali": "Ito cuddasakappamhi,"
    },
    {
      "id": "tha-ap235:4.2",
      "pali": "ahosiṁ amitañjalo;"
    },
    {
      "id": "tha-ap235:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap235:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap235:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap235:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap235:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap235:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sālapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap235:7.1",
      "pali": "Sālapupphiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
