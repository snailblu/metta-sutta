{
  "uid": "mil3.7.14",
  "title": "14. Sukhumapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.7.14:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.7.14:1.2",
      "pali": "“bhante nāgasena, sakkā sabbaṁ sukhumaṁ chinditun”ti?"
    },
    {
      "id": "mil3.7.14:1.3",
      "pali": "“Āma, mahārāja, sakkā sabbaṁ sukhumaṁ chinditun”ti."
    },
    {
      "id": "mil3.7.14:1.4",
      "pali": "“Kiṁ pana, bhante, sabbaṁ sukhuman”ti?"
    },
    {
      "id": "mil3.7.14:1.5",
      "pali": "“Dhammo kho, mahārāja, sabbasukhumo, na kho, mahārāja, dhammā sabbe sukhumā, ‘sukhuman’ti vā ‘thūlan’ti vā dhammānametamadhivacanaṁ."
    },
    {
      "id": "mil3.7.14:1.6",
      "pali": "Yaṁ kiñci chinditabbaṁ, sabbaṁ taṁ paññāya chindati, natthi dutiyaṁ paññāya chedanan”ti."
    },
    {
      "id": "mil3.7.14:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.7.14:3.1",
      "pali": "Sukhumapañho cuddasamo."
    }
  ]
}
