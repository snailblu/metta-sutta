{
  "uid": "ja346",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja346:1.1",
      "pali": "“Manussindaṁ jahitvāna,"
    },
    {
      "id": "ja346:1.2",
      "pali": "sabbakāmasamiddhinaṁ;"
    },
    {
      "id": "ja346:1.3",
      "pali": "Kathaṁ nu bhagavā kesī,"
    },
    {
      "id": "ja346:1.4",
      "pali": "kappassa ramati assame”."
    },
    {
      "id": "ja346:2.1",
      "pali": "“Sādūni ramaṇīyāni,"
    },
    {
      "id": "ja346:2.2",
      "pali": "santi vakkhā manoramā;"
    },
    {
      "id": "ja346:2.3",
      "pali": "Subhāsitāni kappassa,"
    },
    {
      "id": "ja346:2.4",
      "pali": "nārada ramayanti maṁ”."
    },
    {
      "id": "ja346:3.1",
      "pali": "“Sālīnaṁ odanaṁ bhuñje,"
    },
    {
      "id": "ja346:3.2",
      "pali": "suciṁ maṁsūpasecanaṁ;"
    },
    {
      "id": "ja346:3.3",
      "pali": "Kathaṁ sāmākanīvāraṁ,"
    },
    {
      "id": "ja346:3.4",
      "pali": "aloṇaṁ chādayanti taṁ”."
    },
    {
      "id": "ja346:4.1",
      "pali": "“Sāduṁ vā yadi vāsāduṁ,"
    },
    {
      "id": "ja346:4.2",
      "pali": "appaṁ vā yadi vā bahuṁ;"
    },
    {
      "id": "ja346:4.3",
      "pali": "Vissattho yattha bhuñjeyya,"
    },
    {
      "id": "ja346:4.4",
      "pali": "vissāsaparamā rasā”ti."
    },
    {
      "id": "ja346:5.1",
      "pali": "Kesavajātakaṁ chaṭṭhaṁ."
    }
  ]
}
