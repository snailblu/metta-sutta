{
  "uid": "cp26",
  "title": "Adiṭṭhānapāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp26:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp26:1.2",
      "pali": "kāsirājassa atrajo;"
    },
    {
      "id": "cp26:1.3",
      "pali": "Mūgapakkhoti nāmena,"
    },
    {
      "id": "cp26:1.4",
      "pali": "temiyoti vadanti maṁ."
    },
    {
      "id": "cp26:2.1",
      "pali": "Soḷasitthisahassānaṁ,"
    },
    {
      "id": "cp26:2.2",
      "pali": "na vijjati pumo tadā;"
    },
    {
      "id": "cp26:2.3",
      "pali": "Ahorattānaṁ accayena,"
    },
    {
      "id": "cp26:2.4",
      "pali": "nibbatto ahamekako."
    },
    {
      "id": "cp26:3.1",
      "pali": "Kicchā laddhaṁ piyaṁ puttaṁ,"
    },
    {
      "id": "cp26:3.2",
      "pali": "abhijātaṁ jutindharaṁ;"
    },
    {
      "id": "cp26:3.3",
      "pali": "Setacchattaṁ dhārayitvāna,"
    },
    {
      "id": "cp26:3.4",
      "pali": "sayane poseti maṁ pitā."
    },
    {
      "id": "cp26:4.1",
      "pali": "Niddāyamāno sayanavare,"
    },
    {
      "id": "cp26:4.2",
      "pali": "Pabujjhitvānahaṁ tadā;"
    },
    {
      "id": "cp26:4.3",
      "pali": "Addasaṁ paṇḍaraṁ chattaṁ,"
    },
    {
      "id": "cp26:4.4",
      "pali": "Yenāhaṁ nirayaṁ gato."
    },
    {
      "id": "cp26:5.1",
      "pali": "Saha diṭṭhassa me chattaṁ,"
    },
    {
      "id": "cp26:5.2",
      "pali": "tāso uppajji bheravo;"
    },
    {
      "id": "cp26:5.3",
      "pali": "Vinicchayaṁ samāpanno,"
    },
    {
      "id": "cp26:5.4",
      "pali": "‘kathāhaṁ imaṁ muñcissaṁ’."
    },
    {
      "id": "cp26:6.1",
      "pali": "Pubbasālohitā mayhaṁ,"
    },
    {
      "id": "cp26:6.2",
      "pali": "devatā atthakāminī;"
    },
    {
      "id": "cp26:6.3",
      "pali": "Sā maṁ disvāna dukkhitaṁ,"
    },
    {
      "id": "cp26:6.4",
      "pali": "tīsu ṭhānesu yojayi."
    },
    {
      "id": "cp26:7.1",
      "pali": "‘Mā paṇḍiccayaṁ vibhāvaya,"
    },
    {
      "id": "cp26:7.2",
      "pali": "Bālamato bhava sabbapāṇinaṁ;"
    },
    {
      "id": "cp26:7.3",
      "pali": "Sabbo taṁ jano ocināyatu,"
    },
    {
      "id": "cp26:7.4",
      "pali": "Evaṁ tava attho bhavissati’."
    },
    {
      "id": "cp26:8.1",
      "pali": "Evaṁ vuttāyahaṁ tassā,"
    },
    {
      "id": "cp26:8.2",
      "pali": "idaṁ vacanamabraviṁ;"
    },
    {
      "id": "cp26:8.3",
      "pali": "‘Karomi te taṁ vacanaṁ,"
    },
    {
      "id": "cp26:8.4",
      "pali": "yaṁ tvaṁ bhaṇasi devate;"
    },
    {
      "id": "cp26:8.5",
      "pali": "Atthakāmāsi me amma,"
    },
    {
      "id": "cp26:8.6",
      "pali": "hitakāmāsi devate’."
    },
    {
      "id": "cp26:9.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp26:9.2",
      "pali": "sāgareva thalaṁ labhiṁ;"
    },
    {
      "id": "cp26:9.3",
      "pali": "Haṭṭho saṁviggamānaso,"
    },
    {
      "id": "cp26:9.4",
      "pali": "tayo aṅge adhiṭṭhahiṁ."
    },
    {
      "id": "cp26:10.1",
      "pali": "Mūgo ahosiṁ badhiro,"
    },
    {
      "id": "cp26:10.2",
      "pali": "pakkho gativivajjito;"
    },
    {
      "id": "cp26:10.3",
      "pali": "Ete aṅge adhiṭṭhāya,"
    },
    {
      "id": "cp26:10.4",
      "pali": "vassāni soḷasaṁ vasiṁ."
    },
    {
      "id": "cp26:11.1",
      "pali": "Tato me hatthapāde ca,"
    },
    {
      "id": "cp26:11.2",
      "pali": "jivhaṁ sotañca maddiya;"
    },
    {
      "id": "cp26:11.3",
      "pali": "Anūnataṁ me passitvā,"
    },
    {
      "id": "cp26:11.4",
      "pali": "‘kāḷakaṇṇī’ti nindisuṁ."
    },
    {
      "id": "cp26:12.1",
      "pali": "Tato jānapadā sabbe,"
    },
    {
      "id": "cp26:12.2",
      "pali": "senāpatipurohitā;"
    },
    {
      "id": "cp26:12.3",
      "pali": "Sabbe ekamanā hutvā,"
    },
    {
      "id": "cp26:12.4",
      "pali": "chaḍḍanaṁ anumodisuṁ."
    },
    {
      "id": "cp26:13.1",
      "pali": "Sohaṁ tesaṁ matiṁ sutvā,"
    },
    {
      "id": "cp26:13.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "cp26:13.3",
      "pali": "‘Yassatthāya tapociṇṇo,"
    },
    {
      "id": "cp26:13.4",
      "pali": "so me attho samijjhatha’."
    },
    {
      "id": "cp26:14.1",
      "pali": "Nhāpetvā anulimpitvā,"
    },
    {
      "id": "cp26:14.2",
      "pali": "veṭhetvā rājaveṭhanaṁ;"
    },
    {
      "id": "cp26:14.3",
      "pali": "Chattena abhisiñcitvā,"
    },
    {
      "id": "cp26:14.4",
      "pali": "kāresuṁ puraṁ padakkhiṇaṁ."
    },
    {
      "id": "cp26:15.1",
      "pali": "Sattāhaṁ dhārayitvāna,"
    },
    {
      "id": "cp26:15.2",
      "pali": "uggate ravimaṇḍale;"
    },
    {
      "id": "cp26:15.3",
      "pali": "Rathena maṁ nīharitvā,"
    },
    {
      "id": "cp26:15.4",
      "pali": "sārathī vanamupāgami."
    },
    {
      "id": "cp26:16.1",
      "pali": "Ekokāse rathaṁ katvā,"
    },
    {
      "id": "cp26:16.2",
      "pali": "sajjassaṁ hatthamuccito;"
    },
    {
      "id": "cp26:16.3",
      "pali": "Sārathī khaṇatī kāsuṁ,"
    },
    {
      "id": "cp26:16.4",
      "pali": "nikhātuṁ pathaviyā mamaṁ."
    },
    {
      "id": "cp26:17.1",
      "pali": "Adhiṭṭhitamadhiṭṭhānaṁ,"
    },
    {
      "id": "cp26:17.2",
      "pali": "tajjento vividhakāraṇā;"
    },
    {
      "id": "cp26:17.3",
      "pali": "Na bhindiṁ tamadhiṭṭhānaṁ,"
    },
    {
      "id": "cp26:17.4",
      "pali": "bodhiyāyeva kāraṇā."
    },
    {
      "id": "cp26:18.1",
      "pali": "Mātāpitā na me dessā,"
    },
    {
      "id": "cp26:18.2",
      "pali": "attā me na ca dessiyo;"
    },
    {
      "id": "cp26:18.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp26:18.4",
      "pali": "tasmā vatamadhiṭṭhahiṁ."
    },
    {
      "id": "cp26:19.1",
      "pali": "Ete aṅge adhiṭṭhāya,"
    },
    {
      "id": "cp26:19.2",
      "pali": "Vassāni soḷasaṁ vasiṁ;"
    },
    {
      "id": "cp26:19.3",
      "pali": "Adhiṭṭhānena me samo natthi,"
    },
    {
      "id": "cp26:19.4",
      "pali": "Esā me adhiṭṭhānapāramī”ti."
    },
    {
      "id": "cp26:20.1",
      "pali": "Temiyacariyaṁ chaṭṭhaṁ."
    }
  ]
}
