{
  "uid": "tha-ap419",
  "title": "Ucchaṅgapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap419:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap419:1.2",
      "pali": "ahosiṁ māliko tadā;"
    },
    {
      "id": "tha-ap419:1.3",
      "pali": "Ucchaṅgaṁ pūrayitvāna,"
    },
    {
      "id": "tha-ap419:1.4",
      "pali": "agamaṁ antarāpaṇaṁ."
    },
    {
      "id": "tha-ap419:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap419:2.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap419:2.3",
      "pali": "Mahatā ānubhāvena,"
    },
    {
      "id": "tha-ap419:2.4",
      "pali": "niyyāti lokanāyako."
    },
    {
      "id": "tha-ap419:3.1",
      "pali": "Disvāna lokapajjotaṁ,"
    },
    {
      "id": "tha-ap419:3.2",
      "pali": "vipassiṁ lokatāraṇaṁ;"
    },
    {
      "id": "tha-ap419:3.3",
      "pali": "Pupphaṁ paggayha ucchaṅgā,"
    },
    {
      "id": "tha-ap419:3.4",
      "pali": "buddhaseṭṭhaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap419:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap419:4.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap419:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap419:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap419:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap419:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap419:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap419:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap419:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap419:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap419:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap419:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap419:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap419:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā ucchaṅgapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap419:9.1",
      "pali": "Ucchaṅgapupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
