{
  "uid": "thag2.12",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.12:1.1",
      "pali": "“Ye kho te veṭhamissena,"
    },
    {
      "id": "thag2.12:1.2",
      "pali": "nānattena ca kammunā;"
    },
    {
      "id": "thag2.12:1.3",
      "pali": "Manusse uparundhanti,"
    },
    {
      "id": "thag2.12:1.4",
      "pali": "pharusūpakkamā janā;"
    },
    {
      "id": "thag2.12:1.5",
      "pali": "Tepi tattheva kīranti,"
    },
    {
      "id": "thag2.12:1.6",
      "pali": "na hi kammaṁ panassati."
    },
    {
      "id": "thag2.12:2.1",
      "pali": "Yaṁ karoti naro kammaṁ,"
    },
    {
      "id": "thag2.12:2.2",
      "pali": "Kalyāṇaṁ yadi pāpakaṁ;"
    },
    {
      "id": "thag2.12:2.3",
      "pali": "Tassa tasseva dāyādo,"
    },
    {
      "id": "thag2.12:2.4",
      "pali": "Yaṁ yaṁ kammaṁ pakubbatī”ti."
    },
    {
      "id": "thag2.12:2.5",
      "pali": "… Jotidāso thero …."
    }
  ]
}
