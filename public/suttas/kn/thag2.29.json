{
  "uid": "thag2.29",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.29:1.1",
      "pali": "“Nadanti evaṁ sappaññā,"
    },
    {
      "id": "thag2.29:1.2",
      "pali": "sīhāva girigabbhare;"
    },
    {
      "id": "thag2.29:1.3",
      "pali": "Vīrā vijitasaṅgāmā,"
    },
    {
      "id": "thag2.29:1.4",
      "pali": "jetvā māraṁ savāhiniṁ."
    },
    {
      "id": "thag2.29:2.1",
      "pali": "Satthā ca pariciṇṇo me,"
    },
    {
      "id": "thag2.29:2.2",
      "pali": "dhammo saṅgho ca pūjito;"
    },
    {
      "id": "thag2.29:2.3",
      "pali": "Ahañca vitto sumano,"
    },
    {
      "id": "thag2.29:2.4",
      "pali": "puttaṁ disvā anāsavan”ti."
    },
    {
      "id": "thag2.29:2.5",
      "pali": "… Bhāradvājo thero …."
    }
  ]
}
