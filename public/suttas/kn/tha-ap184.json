{
  "uid": "tha-ap184",
  "title": "Bandhujīvakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap184:1.1",
      "pali": "“Siddhattho nāma sambuddho,"
    },
    {
      "id": "tha-ap184:1.2",
      "pali": "sayambhū sabbhi vaṇṇito;"
    },
    {
      "id": "tha-ap184:1.3",
      "pali": "Samādhiṁ so samāpanno,"
    },
    {
      "id": "tha-ap184:1.4",
      "pali": "nisīdi pabbatantare."
    },
    {
      "id": "tha-ap184:2.1",
      "pali": "Jātassare gavesanto,"
    },
    {
      "id": "tha-ap184:2.2",
      "pali": "dakajaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap184:2.3",
      "pali": "Bandhujīvakapupphāni,"
    },
    {
      "id": "tha-ap184:2.4",
      "pali": "addasaṁ samanantaraṁ."
    },
    {
      "id": "tha-ap184:3.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap184:3.2",
      "pali": "upāgacchiṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap184:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap184:3.4",
      "pali": "siddhatthassābhiropayiṁ."
    },
    {
      "id": "tha-ap184:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap184:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap184:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap184:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap184:5.1",
      "pali": "Ito cātuddase kappe,"
    },
    {
      "id": "tha-ap184:5.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap184:5.3",
      "pali": "Samuddakappo nāmena,"
    },
    {
      "id": "tha-ap184:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap184:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap184:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap184:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap184:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā bandhujīvako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap184:8.1",
      "pali": "Bandhujīvakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
