{
  "uid": "tha-ap382",
  "title": "Kāsumāriphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap382:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap382:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap382:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap382:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap382:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap382:2.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap382:2.3",
      "pali": "Kāsumāriphalaṁ gayha,"
    },
    {
      "id": "tha-ap382:2.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap382:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap382:3.2",
      "pali": "yaṁ phalamadadiṁ ahaṁ;"
    },
    {
      "id": "tha-ap382:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap382:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap382:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap382:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap382:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap382:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap382:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap382:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap382:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap382:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap382:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap382:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kāsumāriphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap382:8.1",
      "pali": "Kāsumāriphaladāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap382:9.1",
      "pali": "Bodhivandanavaggo aṭṭhatiṁsatimo."
    },
    {
      "id": "tha-ap382:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap382:11.1",
      "pali": "Bodhi pāṭali uppalī,"
    },
    {
      "id": "tha-ap382:11.2",
      "pali": "paṭṭi ca sattapaṇṇiyo;"
    },
    {
      "id": "tha-ap382:11.3",
      "pali": "Gandhamuṭṭhi ca citako,"
    },
    {
      "id": "tha-ap382:11.4",
      "pali": "tālaṁ sumanadāmako;"
    },
    {
      "id": "tha-ap382:11.5",
      "pali": "Kāsumāriphalī ceva,"
    },
    {
      "id": "tha-ap382:11.6",
      "pali": "gāthā ekūnasaṭṭhikā."
    }
  ]
}
