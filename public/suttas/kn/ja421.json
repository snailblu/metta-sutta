{
  "uid": "ja421",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja421:1.1",
      "pali": "“Aṅgārajātā pathavī,"
    },
    {
      "id": "ja421:1.2",
      "pali": "kukkuḷānugatā mahī;"
    },
    {
      "id": "ja421:1.3",
      "pali": "Atha gāyasi vattāni,"
    },
    {
      "id": "ja421:1.4",
      "pali": "na taṁ tapati ātapo."
    },
    {
      "id": "ja421:2.1",
      "pali": "Uddhaṁ tapati ādicco,"
    },
    {
      "id": "ja421:2.2",
      "pali": "adho tapati vālukā;"
    },
    {
      "id": "ja421:2.3",
      "pali": "Atha gāyasi vattāni,"
    },
    {
      "id": "ja421:2.4",
      "pali": "na taṁ tapati ātapo”."
    },
    {
      "id": "ja421:3.1",
      "pali": "“Na maṁ tapati ātapo,"
    },
    {
      "id": "ja421:3.2",
      "pali": "ātapā tapayanti maṁ;"
    },
    {
      "id": "ja421:3.3",
      "pali": "Atthā hi vividhā rāja,"
    },
    {
      "id": "ja421:3.4",
      "pali": "te tapanti na ātapo”."
    },
    {
      "id": "ja421:4.1",
      "pali": "“Addasaṁ kāma te mūlaṁ,"
    },
    {
      "id": "ja421:4.2",
      "pali": "saṅkappā kāma jāyasi;"
    },
    {
      "id": "ja421:4.3",
      "pali": "Na taṁ saṅkappayissāmi,"
    },
    {
      "id": "ja421:4.4",
      "pali": "evaṁ kāma na hehisi”."
    },
    {
      "id": "ja421:5.1",
      "pali": "“Appāpi kāmā na alaṁ,"
    },
    {
      "id": "ja421:5.2",
      "pali": "bahūhipi na tappati;"
    },
    {
      "id": "ja421:5.3",
      "pali": "Ahahā bālalapanā,"
    },
    {
      "id": "ja421:5.4",
      "pali": "parivajjetha jaggato”."
    },
    {
      "id": "ja421:6.1",
      "pali": "“Appassa kammassa phalaṁ mamedaṁ,"
    },
    {
      "id": "ja421:6.2",
      "pali": "Udayo ajjhāgamā mahattapattaṁ;"
    },
    {
      "id": "ja421:6.3",
      "pali": "Suladdhalābho vata māṇavassa,"
    },
    {
      "id": "ja421:6.4",
      "pali": "Yo pabbajī kāmarāgaṁ pahāya”."
    },
    {
      "id": "ja421:7.1",
      "pali": "“Tapasā pajahanti pāpakammaṁ,"
    },
    {
      "id": "ja421:7.2",
      "pali": "Tapasā nhāpitakumbhakārabhāvaṁ;"
    },
    {
      "id": "ja421:7.3",
      "pali": "Tapasā abhibhuyya gaṅgamāla,"
    },
    {
      "id": "ja421:7.4",
      "pali": "Nāmenālapasajja brahmadattaṁ”."
    },
    {
      "id": "ja421:8.1",
      "pali": "“Sandiṭṭhikameva ‘amma’ passatha,"
    },
    {
      "id": "ja421:8.2",
      "pali": "Khantīsoraccassa ayaṁ vipāko;"
    },
    {
      "id": "ja421:8.3",
      "pali": "Yo sabbajanassa vanditohu,"
    },
    {
      "id": "ja421:8.4",
      "pali": "Taṁ vandāma sarājikā samaccā”."
    },
    {
      "id": "ja421:9.1",
      "pali": "“Mā kiñci avacuttha gaṅgamālaṁ,"
    },
    {
      "id": "ja421:9.2",
      "pali": "Muninaṁ monapathesu sikkhamānaṁ;"
    },
    {
      "id": "ja421:9.3",
      "pali": "Eso hi atari aṇṇavaṁ,"
    },
    {
      "id": "ja421:9.4",
      "pali": "Yaṁ taritvā caranti vītasokā”ti."
    },
    {
      "id": "ja421:10.1",
      "pali": "Gaṅgamālajātakaṁ pañcamaṁ."
    }
  ]
}
