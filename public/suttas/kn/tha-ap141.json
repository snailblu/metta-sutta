{
  "uid": "tha-ap141",
  "title": "9 Sālapupphadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap141:1.1",
      "pali": "“Migarājā tadā āsiṁ,"
    },
    {
      "id": "tha-ap141:1.2",
      "pali": "abhijāto sukesarī;"
    },
    {
      "id": "tha-ap141:1.3",
      "pali": "Giriduggaṁ gavesanto,"
    },
    {
      "id": "tha-ap141:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap141:2.1",
      "pali": "Ayaṁ nu kho mahāvīro,"
    },
    {
      "id": "tha-ap141:2.2",
      "pali": "nibbāpeti mahājanaṁ;"
    },
    {
      "id": "tha-ap141:2.3",
      "pali": "Yannūnāhaṁ upāseyyaṁ,"
    },
    {
      "id": "tha-ap141:2.4",
      "pali": "devadevaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap141:3.1",
      "pali": "Sākhaṁ sālassa bhañjitvā,"
    },
    {
      "id": "tha-ap141:3.2",
      "pali": "sakosaṁ pupphamāhariṁ;"
    },
    {
      "id": "tha-ap141:3.3",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap141:3.4",
      "pali": "adāsiṁ pupphamuttamaṁ."
    },
    {
      "id": "tha-ap141:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap141:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap141:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap141:4.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap141:5.1",
      "pali": "Ito ca navame kappe,"
    },
    {
      "id": "tha-ap141:5.2",
      "pali": "virocanasanāmakā;"
    },
    {
      "id": "tha-ap141:5.3",
      "pali": "Tayo āsiṁsu rājāno,"
    },
    {
      "id": "tha-ap141:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap141:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap141:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap141:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap141:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sālapupphadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap141:8.1",
      "pali": "Sālapupphadāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
