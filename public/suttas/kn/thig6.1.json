{
  "uid": "thig6.1",
  "title": "Pañcasatamattātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig6.1:1.1",
      "pali": "“Yassa maggaṁ na jānāsi,"
    },
    {
      "id": "thig6.1:1.2",
      "pali": "āgatassa gatassa vā;"
    },
    {
      "id": "thig6.1:1.3",
      "pali": "Taṁ kuto cāgataṁ sattaṁ,"
    },
    {
      "id": "thig6.1:1.4",
      "pali": "‘mama putto’ti rodasi."
    },
    {
      "id": "thig6.1:2.1",
      "pali": "Maggañca khossa jānāsi,"
    },
    {
      "id": "thig6.1:2.2",
      "pali": "āgatassa gatassa vā;"
    },
    {
      "id": "thig6.1:2.3",
      "pali": "Na naṁ samanusocesi,"
    },
    {
      "id": "thig6.1:2.4",
      "pali": "evaṁdhammā hi pāṇino."
    },
    {
      "id": "thig6.1:3.1",
      "pali": "Ayācito tatāgacchi,"
    },
    {
      "id": "thig6.1:3.2",
      "pali": "nānuññāto ito gato;"
    },
    {
      "id": "thig6.1:3.3",
      "pali": "Kutoci nūna āgantvā,"
    },
    {
      "id": "thig6.1:3.4",
      "pali": "vasitvā katipāhakaṁ;"
    },
    {
      "id": "thig6.1:3.5",
      "pali": "Itopi aññena gato,"
    },
    {
      "id": "thig6.1:3.6",
      "pali": "tatopaññena gacchati."
    },
    {
      "id": "thig6.1:4.1",
      "pali": "Peto manussarūpena,"
    },
    {
      "id": "thig6.1:4.2",
      "pali": "saṁsaranto gamissati;"
    },
    {
      "id": "thig6.1:4.3",
      "pali": "Yathāgato tathā gato,"
    },
    {
      "id": "thig6.1:4.4",
      "pali": "kā tattha paridevanā”."
    },
    {
      "id": "thig6.1:5.1",
      "pali": "“Abbahī vata me sallaṁ,"
    },
    {
      "id": "thig6.1:5.2",
      "pali": "duddasaṁ hadayassitaṁ;"
    },
    {
      "id": "thig6.1:5.3",
      "pali": "Yā me sokaparetāya,"
    },
    {
      "id": "thig6.1:5.4",
      "pali": "puttasokaṁ byapānudi."
    },
    {
      "id": "thig6.1:6.1",
      "pali": "Sājja abbūḷhasallāhaṁ,"
    },
    {
      "id": "thig6.1:6.2",
      "pali": "Nicchātā parinibbutā;"
    },
    {
      "id": "thig6.1:6.3",
      "pali": "Buddhaṁ dhammañca saṅghañca,"
    },
    {
      "id": "thig6.1:6.4",
      "pali": "Upemi saraṇaṁ muniṁ”."
    },
    {
      "id": "thig6.1:7.1",
      "pali": "Itthaṁ sudaṁ pañcasatamattā therī bhikkhuniyo … pe…."
    }
  ]
}
