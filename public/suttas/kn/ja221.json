{
  "uid": "ja221",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja221:1.1",
      "pali": "“Anikkasāvo kāsāvaṁ,"
    },
    {
      "id": "ja221:1.2",
      "pali": "yo vatthaṁ paridahissati;"
    },
    {
      "id": "ja221:1.3",
      "pali": "Apeto damasaccena,"
    },
    {
      "id": "ja221:1.4",
      "pali": "na so kāsāvamarahati."
    },
    {
      "id": "ja221:2.1",
      "pali": "Yo ca vantakasāvassa,"
    },
    {
      "id": "ja221:2.2",
      "pali": "Sīlesu susamāhito;"
    },
    {
      "id": "ja221:2.3",
      "pali": "Upeto damasaccena,"
    },
    {
      "id": "ja221:2.4",
      "pali": "Sa ve kāsāvamarahatī”ti."
    },
    {
      "id": "ja221:3.1",
      "pali": "Kāsāvajātakaṁ paṭhamaṁ."
    }
  ]
}
