{
  "uid": "tha-ap292",
  "title": "10 Pubbaṅgamiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap292:1.1",
      "pali": "“Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap292:1.2",
      "pali": "pabbajimha akiñcanā;"
    },
    {
      "id": "tha-ap292:1.3",
      "pali": "Tesaṁ pubbaṅgamo āsiṁ,"
    },
    {
      "id": "tha-ap292:1.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "tha-ap292:2.1",
      "pali": "Sarāgā sabhavā cete,"
    },
    {
      "id": "tha-ap292:2.2",
      "pali": "vippasannamanāvilā;"
    },
    {
      "id": "tha-ap292:2.3",
      "pali": "Upaṭṭhahiṁsu sakkaccaṁ,"
    },
    {
      "id": "tha-ap292:2.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "tha-ap292:3.1",
      "pali": "Khīṇāsavā vantadosā,"
    },
    {
      "id": "tha-ap292:3.2",
      "pali": "katakiccā anāsavā;"
    },
    {
      "id": "tha-ap292:3.3",
      "pali": "Phariṁsu mettacittena,"
    },
    {
      "id": "tha-ap292:3.4",
      "pali": "sayambhū aparājitā."
    },
    {
      "id": "tha-ap292:4.1",
      "pali": "Tesaṁ upaṭṭhahitvāna,"
    },
    {
      "id": "tha-ap292:4.2",
      "pali": "sambuddhānaṁ patissato;"
    },
    {
      "id": "tha-ap292:4.3",
      "pali": "Maraṇañca anuppatto,"
    },
    {
      "id": "tha-ap292:4.4",
      "pali": "devattañca agamhase."
    },
    {
      "id": "tha-ap292:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap292:5.2",
      "pali": "yaṁ sīlamanupālayiṁ;"
    },
    {
      "id": "tha-ap292:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap292:5.4",
      "pali": "saññamassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap292:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap292:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap292:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap292:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pubbaṅgamiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap292:8.1",
      "pali": "Pubbaṅgamiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap292:9.1",
      "pali": "Paṇṇadāyakavaggo ekūnatiṁsatimo."
    },
    {
      "id": "tha-ap292:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap292:11.1",
      "pali": "Paṇṇaṁ phalaṁ paccuggamaṁ,"
    },
    {
      "id": "tha-ap292:11.2",
      "pali": "ekapupphi ca maghavā;"
    },
    {
      "id": "tha-ap292:11.3",
      "pali": "Upaṭṭhākāpadānañca,"
    },
    {
      "id": "tha-ap292:11.4",
      "pali": "pabbajjā buddhupaṭṭhāko;"
    },
    {
      "id": "tha-ap292:11.5",
      "pali": "Pubbaṅgamo ca gāthāyo,"
    },
    {
      "id": "tha-ap292:11.6",
      "pali": "aṭṭhatālīsa kittitā."
    }
  ]
}
