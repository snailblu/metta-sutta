{
  "uid": "thag10.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.6:1.1",
      "pali": "“Vivittaṁ appanigghosaṁ,"
    },
    {
      "id": "thag10.6:1.2",
      "pali": "vāḷamiganisevitaṁ;"
    },
    {
      "id": "thag10.6:1.3",
      "pali": "Seve senāsanaṁ bhikkhu,"
    },
    {
      "id": "thag10.6:1.4",
      "pali": "paṭisallānakāraṇā."
    },
    {
      "id": "thag10.6:2.1",
      "pali": "Saṅkārapuñjā āhatvā,"
    },
    {
      "id": "thag10.6:2.2",
      "pali": "susānā rathiyāhi ca;"
    },
    {
      "id": "thag10.6:2.3",
      "pali": "Tato saṅghāṭikaṁ katvā,"
    },
    {
      "id": "thag10.6:2.4",
      "pali": "lūkhaṁ dhāreyya cīvaraṁ."
    },
    {
      "id": "thag10.6:3.1",
      "pali": "Nīcaṁ manaṁ karitvāna,"
    },
    {
      "id": "thag10.6:3.2",
      "pali": "sapadānaṁ kulā kulaṁ;"
    },
    {
      "id": "thag10.6:3.3",
      "pali": "Piṇḍikāya care bhikkhu,"
    },
    {
      "id": "thag10.6:3.4",
      "pali": "guttadvāro susaṁvuto."
    },
    {
      "id": "thag10.6:4.1",
      "pali": "Lūkhenapi vā santusse,"
    },
    {
      "id": "thag10.6:4.2",
      "pali": "nāññaṁ patthe rasaṁ bahuṁ;"
    },
    {
      "id": "thag10.6:4.3",
      "pali": "Rasesu anugiddhassa,"
    },
    {
      "id": "thag10.6:4.4",
      "pali": "jhāne na ramatī mano."
    },
    {
      "id": "thag10.6:5.1",
      "pali": "Appiccho ceva santuṭṭho,"
    },
    {
      "id": "thag10.6:5.2",
      "pali": "pavivitto vase muni;"
    },
    {
      "id": "thag10.6:5.3",
      "pali": "Asaṁsaṭṭho gahaṭṭhehi,"
    },
    {
      "id": "thag10.6:5.4",
      "pali": "anāgārehi cūbhayaṁ."
    },
    {
      "id": "thag10.6:6.1",
      "pali": "Yathā jaḷo va mūgo va,"
    },
    {
      "id": "thag10.6:6.2",
      "pali": "attānaṁ dassaye tathā;"
    },
    {
      "id": "thag10.6:6.3",
      "pali": "Nātivelaṁ sambhāseyya,"
    },
    {
      "id": "thag10.6:6.4",
      "pali": "saṅghamajjhamhi paṇḍito."
    },
    {
      "id": "thag10.6:7.1",
      "pali": "Na so upavade kañci,"
    },
    {
      "id": "thag10.6:7.2",
      "pali": "upaghātaṁ vivajjaye;"
    },
    {
      "id": "thag10.6:7.3",
      "pali": "Saṁvuto pātimokkhasmiṁ,"
    },
    {
      "id": "thag10.6:7.4",
      "pali": "mattaññū cassa bhojane."
    },
    {
      "id": "thag10.6:8.1",
      "pali": "Suggahītanimittassa,"
    },
    {
      "id": "thag10.6:8.2",
      "pali": "cittassuppādakovido;"
    },
    {
      "id": "thag10.6:8.3",
      "pali": "Samathaṁ anuyuñjeyya,"
    },
    {
      "id": "thag10.6:8.4",
      "pali": "kālena ca vipassanaṁ."
    },
    {
      "id": "thag10.6:9.1",
      "pali": "Vīriyasātaccasampanno,"
    },
    {
      "id": "thag10.6:9.2",
      "pali": "yuttayogo sadā siyā;"
    },
    {
      "id": "thag10.6:9.3",
      "pali": "Na ca appatvā dukkhantaṁ,"
    },
    {
      "id": "thag10.6:9.4",
      "pali": "vissāsaṁ eyya paṇḍito."
    },
    {
      "id": "thag10.6:10.1",
      "pali": "Evaṁ viharamānassa,"
    },
    {
      "id": "thag10.6:10.2",
      "pali": "suddhikāmassa bhikkhuno;"
    },
    {
      "id": "thag10.6:10.3",
      "pali": "Khīyanti āsavā sabbe,"
    },
    {
      "id": "thag10.6:10.4",
      "pali": "nibbutiñcādhigacchatī”ti."
    },
    {
      "id": "thag10.6:10.5",
      "pali": "… Upaseno vaṅgantaputto thero …."
    }
  ]
}
