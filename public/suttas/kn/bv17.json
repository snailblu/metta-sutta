{
  "uid": "bv17",
  "title": "17 Dhammadassībuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv17:1.1",
      "pali": "“Tattheva maṇḍakappamhi,"
    },
    {
      "id": "bv17:1.2",
      "pali": "dhammadassī mahāyaso;"
    },
    {
      "id": "bv17:1.3",
      "pali": "Tamandhakāraṁ vidhamitvā,"
    },
    {
      "id": "bv17:1.4",
      "pali": "atirocati sadevake."
    },
    {
      "id": "bv17:2.1",
      "pali": "Tassāpi atulatejassa,"
    },
    {
      "id": "bv17:2.2",
      "pali": "dhammacakkappavattane;"
    },
    {
      "id": "bv17:2.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv17:2.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv17:3.1",
      "pali": "Yadā buddho dhammadassī,"
    },
    {
      "id": "bv17:3.2",
      "pali": "vinesi sañjayaṁ isiṁ;"
    },
    {
      "id": "bv17:3.3",
      "pali": "Tadā navutikoṭīnaṁ,"
    },
    {
      "id": "bv17:3.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv17:4.1",
      "pali": "Yadā sakko upāgañchi,"
    },
    {
      "id": "bv17:4.2",
      "pali": "sapariso vināyakaṁ;"
    },
    {
      "id": "bv17:4.3",
      "pali": "Tadā asītikoṭīnaṁ,"
    },
    {
      "id": "bv17:4.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv17:5.1",
      "pali": "Tassāpi devadevassa,"
    },
    {
      "id": "bv17:5.2",
      "pali": "sannipātā tayo ahuṁ;"
    },
    {
      "id": "bv17:5.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv17:5.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv17:6.1",
      "pali": "Yadā buddho dhammadassī,"
    },
    {
      "id": "bv17:6.2",
      "pali": "Saraṇe vassaṁ upāgami;"
    },
    {
      "id": "bv17:6.3",
      "pali": "Tadā koṭisatasahassānaṁ,"
    },
    {
      "id": "bv17:6.4",
      "pali": "Paṭhamo āsi samāgamo."
    },
    {
      "id": "bv17:7.1",
      "pali": "Punāparaṁ yadā buddho,"
    },
    {
      "id": "bv17:7.2",
      "pali": "devato eti mānusaṁ;"
    },
    {
      "id": "bv17:7.3",
      "pali": "Tadāpi satakoṭīnaṁ,"
    },
    {
      "id": "bv17:7.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv17:8.1",
      "pali": "Punāparaṁ yadā buddho,"
    },
    {
      "id": "bv17:8.2",
      "pali": "pakāsesi dhute guṇe;"
    },
    {
      "id": "bv17:8.3",
      "pali": "Tadā asītikoṭīnaṁ,"
    },
    {
      "id": "bv17:8.4",
      "pali": "tatiyo āsi samāgamo."
    },
    {
      "id": "bv17:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv17:9.2",
      "pali": "sakko āsiṁ purindado;"
    },
    {
      "id": "bv17:9.3",
      "pali": "Dibbena gandhamālena,"
    },
    {
      "id": "bv17:9.4",
      "pali": "tūriyenābhipūjayiṁ."
    },
    {
      "id": "bv17:10.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv17:10.2",
      "pali": "devamajjhe nisīdiya;"
    },
    {
      "id": "bv17:10.3",
      "pali": "‘Aṭṭhārase kappasate,"
    },
    {
      "id": "bv17:10.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv17:11.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv17:11.2",
      "pali": "…pe…"
    },
    {
      "id": "bv17:11.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv17:12.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv17:12.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv17:12.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv17:12.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv17:13.1",
      "pali": "Saraṇaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv17:13.2",
      "pali": "saraṇo nāma khattiyo;"
    },
    {
      "id": "bv17:13.3",
      "pali": "Sunandā nāma janikā,"
    },
    {
      "id": "bv17:13.4",
      "pali": "dhammadassissa satthuno."
    },
    {
      "id": "bv17:14.1",
      "pali": "Aṭṭhavassasahassāni,"
    },
    {
      "id": "bv17:14.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv17:14.3",
      "pali": "Arajo virajo sudassano,"
    },
    {
      "id": "bv17:14.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv17:15.1",
      "pali": "Ticattārīsasahassāni,"
    },
    {
      "id": "bv17:15.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv17:15.3",
      "pali": "Vicikoḷi nāma nārī,"
    },
    {
      "id": "bv17:15.4",
      "pali": "atrajo puññavaḍḍhano."
    },
    {
      "id": "bv17:16.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv17:16.2",
      "pali": "pāsādenābhinikkhami;"
    },
    {
      "id": "bv17:16.3",
      "pali": "Sattāhaṁ padhānacāraṁ,"
    },
    {
      "id": "bv17:16.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv17:17.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv17:17.2",
      "pali": "dhammadassī narāsabho;"
    },
    {
      "id": "bv17:17.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv17:17.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv17:18.1",
      "pali": "Padumo phussadevo ca,"
    },
    {
      "id": "bv17:18.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv17:18.3",
      "pali": "Sunetto nāmupaṭṭhāko,"
    },
    {
      "id": "bv17:18.4",
      "pali": "dhammadassissa satthuno."
    },
    {
      "id": "bv17:19.1",
      "pali": "Khemā ca saccanāmā ca,"
    },
    {
      "id": "bv17:19.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv17:19.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv17:19.4",
      "pali": "bimbijāloti vuccati."
    },
    {
      "id": "bv17:20.1",
      "pali": "Subhaddo kaṭissaho ceva,"
    },
    {
      "id": "bv17:20.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv17:20.3",
      "pali": "Sāḷiyā ca kaḷiyā ca,"
    },
    {
      "id": "bv17:20.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv17:21.1",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv17:21.2",
      "pali": "asītihatthamuggato;"
    },
    {
      "id": "bv17:21.3",
      "pali": "Atirocati tejena,"
    },
    {
      "id": "bv17:21.4",
      "pali": "dasasahassimhi dhātuyā."
    },
    {
      "id": "bv17:22.1",
      "pali": "Suphullo sālarājāva,"
    },
    {
      "id": "bv17:22.2",
      "pali": "vijjūva gagane yathā;"
    },
    {
      "id": "bv17:22.3",
      "pali": "Majjhanhikeva sūriyo,"
    },
    {
      "id": "bv17:22.4",
      "pali": "evaṁ so upasobhatha."
    },
    {
      "id": "bv17:23.1",
      "pali": "Tassāpi atulatejassa,"
    },
    {
      "id": "bv17:23.2",
      "pali": "samakaṁ āsi jīvitaṁ;"
    },
    {
      "id": "bv17:23.3",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv17:23.4",
      "pali": "loke aṭṭhāsi cakkhumā."
    },
    {
      "id": "bv17:24.1",
      "pali": "Obhāsaṁ dassayitvāna,"
    },
    {
      "id": "bv17:24.2",
      "pali": "vimalaṁ katvāna sāsanaṁ;"
    },
    {
      "id": "bv17:24.3",
      "pali": "Cavi candova gagane,"
    },
    {
      "id": "bv17:24.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv17:25.1",
      "pali": "Dhammadassī mahāvīro,"
    },
    {
      "id": "bv17:25.2",
      "pali": "Sālārāmamhi nibbuto;"
    },
    {
      "id": "bv17:25.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv17:25.4",
      "pali": "Tīṇiyojanamuggato”ti."
    },
    {
      "id": "bv17:26.1",
      "pali": "Dhammadassissa bhagavato vaṁso pannarasamo."
    }
  ]
}
