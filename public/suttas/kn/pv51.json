{
  "uid": "pv51",
  "title": "16. Saṭṭhikūṭapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv51:1.1",
      "pali": "“Kiṁ nu ummattarūpova,"
    },
    {
      "id": "pv51:1.2",
      "pali": "Migo bhantova dhāvasi;"
    },
    {
      "id": "pv51:1.3",
      "pali": "Nissaṁsayaṁ pāpakammanto,"
    },
    {
      "id": "pv51:1.4",
      "pali": "Kiṁ nu saddāyase tuvan”ti."
    },
    {
      "id": "pv51:2.1",
      "pali": "“Ahaṁ bhadante petomhi,"
    },
    {
      "id": "pv51:2.2",
      "pali": "duggato yamalokiko;"
    },
    {
      "id": "pv51:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv51:2.4",
      "pali": "petalokaṁ ito gato."
    },
    {
      "id": "pv51:3.1",
      "pali": "Saṭṭhi kūṭasahassāni,"
    },
    {
      "id": "pv51:3.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "pv51:3.3",
      "pali": "Sīse mayhaṁ nipatanti,"
    },
    {
      "id": "pv51:3.4",
      "pali": "te bhindanti ca matthakan”ti."
    },
    {
      "id": "pv51:4.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv51:4.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv51:4.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv51:4.4",
      "pali": "idaṁ dukkhaṁ nigacchasi."
    },
    {
      "id": "pv51:5.1",
      "pali": "Saṭṭhi kūṭasahassāni,"
    },
    {
      "id": "pv51:5.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "pv51:5.3",
      "pali": "Sīse tuyhaṁ nipatanti,"
    },
    {
      "id": "pv51:5.4",
      "pali": "te bhindanti ca matthakan”ti."
    },
    {
      "id": "pv51:6.1",
      "pali": "“Athaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "pv51:6.2",
      "pali": "sunettaṁ bhāvitindriyaṁ;"
    },
    {
      "id": "pv51:6.3",
      "pali": "Nisinnaṁ rukkhamūlasmiṁ,"
    },
    {
      "id": "pv51:6.4",
      "pali": "jhāyantaṁ akutobhayaṁ."
    },
    {
      "id": "pv51:7.1",
      "pali": "Sālittakappahārena,"
    },
    {
      "id": "pv51:7.2",
      "pali": "bhindissaṁ tassa matthakaṁ;"
    },
    {
      "id": "pv51:7.3",
      "pali": "Tassa kammavipākena,"
    },
    {
      "id": "pv51:7.4",
      "pali": "idaṁ dukkhaṁ nigacchisaṁ."
    },
    {
      "id": "pv51:8.1",
      "pali": "Saṭṭhi kūṭasahassāni,"
    },
    {
      "id": "pv51:8.2",
      "pali": "Paripuṇṇāni sabbaso;"
    },
    {
      "id": "pv51:8.3",
      "pali": "Sīse mayhaṁ nipatanti,"
    },
    {
      "id": "pv51:8.4",
      "pali": "Te bhindanti ca matthakan”ti."
    },
    {
      "id": "pv51:9.1",
      "pali": "“Dhammena te kāpurisa,"
    },
    {
      "id": "pv51:9.2",
      "pali": "saṭṭhikūṭasahassāni;"
    },
    {
      "id": "pv51:9.3",
      "pali": "Paripuṇṇāni sabbaso,"
    },
    {
      "id": "pv51:9.4",
      "pali": "sīse tuyhaṁ nipatanti;"
    },
    {
      "id": "pv51:9.5",
      "pali": "Te bhindanti ca matthakan”ti."
    },
    {
      "id": "pv51:10.1",
      "pali": "Saṭṭhikūṭapetavatthu soḷasamaṁ."
    },
    {
      "id": "pv51:11.1",
      "pali": "Mahāvaggo catuttho."
    },
    {
      "id": "pv51:12.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "pv51:13.1",
      "pali": "Ambasakkaro serīsako,"
    },
    {
      "id": "pv51:13.2",
      "pali": "piṅgalo revati ucchu;"
    },
    {
      "id": "pv51:13.3",
      "pali": "Dve kumārā duve gūthā,"
    },
    {
      "id": "pv51:13.4",
      "pali": "gaṇapāṭaliambavanaṁ."
    },
    {
      "id": "pv51:14.1",
      "pali": "Akkharukkhabhogasaṁharā,"
    },
    {
      "id": "pv51:14.2",
      "pali": "seṭṭhiputtasaṭṭhikūṭā;"
    },
    {
      "id": "pv51:14.3",
      "pali": "Iti soḷasavatthūni,"
    },
    {
      "id": "pv51:14.4",
      "pali": "vaggo tena pavuccati."
    },
    {
      "id": "pv51:15.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "pv51:16.1",
      "pali": "Urago uparivaggo,"
    },
    {
      "id": "pv51:16.2",
      "pali": "cūḷamahāti catudhā;"
    },
    {
      "id": "pv51:16.3",
      "pali": "Vatthūni ekapaññāsaṁ,"
    },
    {
      "id": "pv51:16.4",
      "pali": "catudhā bhāṇavārato."
    },
    {
      "id": "pv51:17.1",
      "pali": "Petavatthupāḷi niṭṭhitā."
    }
  ]
}
