{
  "uid": "thag5.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.1:1.1",
      "pali": "“Bhikkhu sivathikaṁ gantvā,"
    },
    {
      "id": "thag5.1:1.2",
      "pali": "Addasa itthimujjhitaṁ;"
    },
    {
      "id": "thag5.1:1.3",
      "pali": "Apaviddhaṁ susānasmiṁ,"
    },
    {
      "id": "thag5.1:1.4",
      "pali": "Khajjantiṁ kimihī phuṭaṁ."
    },
    {
      "id": "thag5.1:2.1",
      "pali": "Yañhi eke jigucchanti,"
    },
    {
      "id": "thag5.1:2.2",
      "pali": "mataṁ disvāna pāpakaṁ;"
    },
    {
      "id": "thag5.1:2.3",
      "pali": "Kāmarāgo pāturahu,"
    },
    {
      "id": "thag5.1:2.4",
      "pali": "andhova savatī ahuṁ."
    },
    {
      "id": "thag5.1:3.1",
      "pali": "Oraṁ odanapākamhā,"
    },
    {
      "id": "thag5.1:3.2",
      "pali": "tamhā ṭhānā apakkamiṁ;"
    },
    {
      "id": "thag5.1:3.3",
      "pali": "Satimā sampajānohaṁ,"
    },
    {
      "id": "thag5.1:3.4",
      "pali": "ekamantaṁ upāvisiṁ."
    },
    {
      "id": "thag5.1:4.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag5.1:4.2",
      "pali": "yoniso udapajjatha;"
    },
    {
      "id": "thag5.1:4.3",
      "pali": "Ādīnavo pāturahu,"
    },
    {
      "id": "thag5.1:4.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag5.1:5.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag5.1:5.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag5.1:5.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag5.1:5.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag5.1:5.5",
      "pali": "… Rājadatto thero …."
    }
  ]
}
