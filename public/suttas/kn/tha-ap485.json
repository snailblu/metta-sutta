{
  "uid": "tha-ap485",
  "title": "Bhisadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap485:1.1",
      "pali": "“Ogayha yaṁ pokkharaṇiṁ,"
    },
    {
      "id": "tha-ap485:1.2",
      "pali": "nānākuñjarasevitaṁ;"
    },
    {
      "id": "tha-ap485:1.3",
      "pali": "Uddharāmi bhisaṁ tattha,"
    },
    {
      "id": "tha-ap485:1.4",
      "pali": "ghāsahetu ahaṁ tadā."
    },
    {
      "id": "tha-ap485:2.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap485:2.2",
      "pali": "padumuttarasavhayo;"
    },
    {
      "id": "tha-ap485:2.3",
      "pali": "Rattambaradharo buddho,"
    },
    {
      "id": "tha-ap485:2.4",
      "pali": "gacchati anilañjase."
    },
    {
      "id": "tha-ap485:3.1",
      "pali": "Dhunanto paṁsukūlāni,"
    },
    {
      "id": "tha-ap485:3.2",
      "pali": "saddamassosahaṁ tadā;"
    },
    {
      "id": "tha-ap485:3.3",
      "pali": "Uddhaṁ nijjhāyamānohaṁ,"
    },
    {
      "id": "tha-ap485:3.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap485:4.1",
      "pali": "Tattheva ṭhitako santo,"
    },
    {
      "id": "tha-ap485:4.2",
      "pali": "āyāciṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap485:4.3",
      "pali": "‘Madhuṁ bhisehi savati,"
    },
    {
      "id": "tha-ap485:4.4",
      "pali": "khīraṁ sappiṁ muḷālibhi."
    },
    {
      "id": "tha-ap485:5.1",
      "pali": "Paṭiggaṇhātu me buddho,"
    },
    {
      "id": "tha-ap485:5.2",
      "pali": "anukampāya cakkhumā’;"
    },
    {
      "id": "tha-ap485:5.3",
      "pali": "Tato kāruṇiko satthā,"
    },
    {
      "id": "tha-ap485:5.4",
      "pali": "oruhitvā mahāyaso."
    },
    {
      "id": "tha-ap485:6.1",
      "pali": "Paṭiggaṇhi mamaṁ bhikkhaṁ,"
    },
    {
      "id": "tha-ap485:6.2",
      "pali": "anukampāya cakkhumā;"
    },
    {
      "id": "tha-ap485:6.3",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "tha-ap485:6.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap485:7.1",
      "pali": "‘Sukhī hotu mahāpuñña,"
    },
    {
      "id": "tha-ap485:7.2",
      "pali": "gati tuyhaṁ samijjhatu;"
    },
    {
      "id": "tha-ap485:7.3",
      "pali": "Iminā bhisadānena,"
    },
    {
      "id": "tha-ap485:7.4",
      "pali": "labhassu vipulaṁ sukhaṁ’."
    },
    {
      "id": "tha-ap485:8.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap485:8.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap485:8.3",
      "pali": "Bhikkhamādāya sambuddho,"
    },
    {
      "id": "tha-ap485:8.4",
      "pali": "ambarenāgamā jino."
    },
    {
      "id": "tha-ap485:9.1",
      "pali": "Tato bhisaṁ gahetvāna,"
    },
    {
      "id": "tha-ap485:9.2",
      "pali": "āgacchiṁ mama assamaṁ;"
    },
    {
      "id": "tha-ap485:9.3",
      "pali": "Bhisaṁ rukkhe lagetvāna,"
    },
    {
      "id": "tha-ap485:9.4",
      "pali": "mama dānamanussariṁ."
    },
    {
      "id": "tha-ap485:10.1",
      "pali": "Mahāvāto vuṭṭhahitvā,"
    },
    {
      "id": "tha-ap485:10.2",
      "pali": "sañcālesi vanaṁ tadā;"
    },
    {
      "id": "tha-ap485:10.3",
      "pali": "Ākāso abhinādittha,"
    },
    {
      "id": "tha-ap485:10.4",
      "pali": "asaniyā phalantiyā."
    },
    {
      "id": "tha-ap485:11.1",
      "pali": "Tato me asanīpāto,"
    },
    {
      "id": "tha-ap485:11.2",
      "pali": "matthake nipatī tadā;"
    },
    {
      "id": "tha-ap485:11.3",
      "pali": "Sohaṁ nisinnako santo,"
    },
    {
      "id": "tha-ap485:11.4",
      "pali": "tattha kālaṅkato ahuṁ."
    },
    {
      "id": "tha-ap485:12.1",
      "pali": "Puññakammena saṁyutto,"
    },
    {
      "id": "tha-ap485:12.2",
      "pali": "tusitaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap485:12.3",
      "pali": "Kaḷevaraṁ me patitaṁ,"
    },
    {
      "id": "tha-ap485:12.4",
      "pali": "devaloke ramiṁ ahaṁ."
    },
    {
      "id": "tha-ap485:13.1",
      "pali": "Chaḷasītisahassāni,"
    },
    {
      "id": "tha-ap485:13.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap485:13.3",
      "pali": "Sāyaṁ pātaṁ upaṭṭhanti,"
    },
    {
      "id": "tha-ap485:13.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap485:14.1",
      "pali": "Manussayonimāgantvā,"
    },
    {
      "id": "tha-ap485:14.2",
      "pali": "sukhito homahaṁ sadā;"
    },
    {
      "id": "tha-ap485:14.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap485:14.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap485:15.1",
      "pali": "Anukampitako tena,"
    },
    {
      "id": "tha-ap485:15.2",
      "pali": "devadevena tādinā;"
    },
    {
      "id": "tha-ap485:15.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap485:15.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap485:16.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap485:16.2",
      "pali": "yaṁ bhisaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap485:16.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap485:16.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap485:17.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap485:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap485:17.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap485:18.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap485:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap485:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap485:19.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap485:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap485:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap485:20.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhisadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap485:21.1",
      "pali": "Bhisadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
