{
  "uid": "tha-ap550",
  "title": "8 Lomasakaṅgiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap550:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap550:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap550:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap550:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap550:2.1",
      "pali": "Tadāhaṁ candano ceva,"
    },
    {
      "id": "tha-ap550:2.2",
      "pali": "pabbajitvāna sāsane;"
    },
    {
      "id": "tha-ap550:2.3",
      "pali": "Āpāṇakoṭikaṁ dhammaṁ,"
    },
    {
      "id": "tha-ap550:2.4",
      "pali": "pūrayitvāna sāsane."
    },
    {
      "id": "tha-ap550:3.1",
      "pali": "Tato cutā santusitaṁ,"
    },
    {
      "id": "tha-ap550:3.2",
      "pali": "upapannā ubho mayaṁ;"
    },
    {
      "id": "tha-ap550:3.3",
      "pali": "Tattha dibbehi naccehi,"
    },
    {
      "id": "tha-ap550:3.4",
      "pali": "gītehi vāditehi ca."
    },
    {
      "id": "tha-ap550:4.1",
      "pali": "Rūpādidasahaṅgehi,"
    },
    {
      "id": "tha-ap550:4.2",
      "pali": "abhibhotvāna sesake;"
    },
    {
      "id": "tha-ap550:4.3",
      "pali": "Yāvatāyuṁ vasitvāna,"
    },
    {
      "id": "tha-ap550:4.4",
      "pali": "anubhotvā mahāsukhaṁ."
    },
    {
      "id": "tha-ap550:5.1",
      "pali": "Tato cavitvā tidasaṁ,"
    },
    {
      "id": "tha-ap550:5.2",
      "pali": "candano upapajjatha;"
    },
    {
      "id": "tha-ap550:5.3",
      "pali": "Ahaṁ kapilavatthusmiṁ,"
    },
    {
      "id": "tha-ap550:5.4",
      "pali": "ajāyiṁ sākiyatrajo."
    },
    {
      "id": "tha-ap550:6.1",
      "pali": "Yadā udāyittherena,"
    },
    {
      "id": "tha-ap550:6.2",
      "pali": "ajjhiṭṭho lokanāyako;"
    },
    {
      "id": "tha-ap550:6.3",
      "pali": "Anukampiya sakyānaṁ,"
    },
    {
      "id": "tha-ap550:6.4",
      "pali": "upesi kapilavhayaṁ."
    },
    {
      "id": "tha-ap550:7.1",
      "pali": "Tadātimānino sakyā,"
    },
    {
      "id": "tha-ap550:7.2",
      "pali": "na buddhassa guṇaññuno;"
    },
    {
      "id": "tha-ap550:7.3",
      "pali": "Paṇamanti na sambuddhaṁ,"
    },
    {
      "id": "tha-ap550:7.4",
      "pali": "jātithaddhā anādarā."
    },
    {
      "id": "tha-ap550:8.1",
      "pali": "Tesaṁ saṅkappamaññāya,"
    },
    {
      "id": "tha-ap550:8.2",
      "pali": "ākāse caṅkamī jino;"
    },
    {
      "id": "tha-ap550:8.3",
      "pali": "Pajjunno viya vassittha,"
    },
    {
      "id": "tha-ap550:8.4",
      "pali": "pajjalittha yathā sikhī."
    },
    {
      "id": "tha-ap550:9.1",
      "pali": "Dassetvā rūpamatulaṁ,"
    },
    {
      "id": "tha-ap550:9.2",
      "pali": "puna antaradhāyatha;"
    },
    {
      "id": "tha-ap550:9.3",
      "pali": "Ekopi hutvā bahudhā,"
    },
    {
      "id": "tha-ap550:9.4",
      "pali": "ahosi punarekako."
    },
    {
      "id": "tha-ap550:10.1",
      "pali": "Andhakāraṁ pakāsañca,"
    },
    {
      "id": "tha-ap550:10.2",
      "pali": "dassayitvā anekadhā;"
    },
    {
      "id": "tha-ap550:10.3",
      "pali": "Pāṭiheraṁ karitvāna,"
    },
    {
      "id": "tha-ap550:10.4",
      "pali": "vinayī ñātake muni."
    },
    {
      "id": "tha-ap550:11.1",
      "pali": "Cātuddīpo mahāmegho,"
    },
    {
      "id": "tha-ap550:11.2",
      "pali": "tāvadeva pavassatha;"
    },
    {
      "id": "tha-ap550:11.3",
      "pali": "Tadā hi jātakaṁ buddho,"
    },
    {
      "id": "tha-ap550:11.4",
      "pali": "vessantaramadesayi."
    },
    {
      "id": "tha-ap550:12.1",
      "pali": "Tadā te khattiyā sabbe,"
    },
    {
      "id": "tha-ap550:12.2",
      "pali": "nihantvā jātijaṁ madaṁ;"
    },
    {
      "id": "tha-ap550:12.3",
      "pali": "Upesuṁ saraṇaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap550:12.4",
      "pali": "āha suddhodano tadā."
    },
    {
      "id": "tha-ap550:13.1",
      "pali": "‘Idaṁ tatiyaṁ tava bhūripañña,"
    },
    {
      "id": "tha-ap550:13.2",
      "pali": "Pādāni vandāmi samantacakkhu;"
    },
    {
      "id": "tha-ap550:13.3",
      "pali": "Yadābhijāto pathavī pakampayī,"
    },
    {
      "id": "tha-ap550:13.4",
      "pali": "Yadā ca taṁ najjahi jambuchāyā’."
    },
    {
      "id": "tha-ap550:14.1",
      "pali": "Tadā buddhānubhāvaṁ taṁ,"
    },
    {
      "id": "tha-ap550:14.2",
      "pali": "disvā vimhitamānaso;"
    },
    {
      "id": "tha-ap550:14.3",
      "pali": "Pabbajitvāna tattheva,"
    },
    {
      "id": "tha-ap550:14.4",
      "pali": "nivasiṁ mātupūjako."
    },
    {
      "id": "tha-ap550:15.1",
      "pali": "Candano devaputto maṁ,"
    },
    {
      "id": "tha-ap550:15.2",
      "pali": "upagantvānupucchatha;"
    },
    {
      "id": "tha-ap550:15.3",
      "pali": "Bhaddekarattassa tadā,"
    },
    {
      "id": "tha-ap550:15.4",
      "pali": "saṅkhepavitthāraṁ nayaṁ."
    },
    {
      "id": "tha-ap550:16.1",
      "pali": "Coditohaṁ tadā tena,"
    },
    {
      "id": "tha-ap550:16.2",
      "pali": "upecca naranāyakaṁ;"
    },
    {
      "id": "tha-ap550:16.3",
      "pali": "Bhaddekarattaṁ sutvāna,"
    },
    {
      "id": "tha-ap550:16.4",
      "pali": "saṁviggo vanamāmako."
    },
    {
      "id": "tha-ap550:17.1",
      "pali": "Tadā mātaramapucchiṁ,"
    },
    {
      "id": "tha-ap550:17.2",
      "pali": "‘vane vacchāmi ekako’;"
    },
    {
      "id": "tha-ap550:17.3",
      "pali": "‘Sukhumālo’ti me mātā,"
    },
    {
      "id": "tha-ap550:17.4",
      "pali": "vārayī taṁ tadā vacaṁ."
    },
    {
      "id": "tha-ap550:18.1",
      "pali": "‘Kāsaṁ kusaṁ poṭakilaṁ,"
    },
    {
      "id": "tha-ap550:18.2",
      "pali": "usīraṁ muñjapabbajaṁ;"
    },
    {
      "id": "tha-ap550:18.3",
      "pali": "Urasā panudissāmi,"
    },
    {
      "id": "tha-ap550:18.4",
      "pali": "vivekamanubrūhayaṁ’."
    },
    {
      "id": "tha-ap550:19.1",
      "pali": "Tadā vanaṁ paviṭṭhohaṁ,"
    },
    {
      "id": "tha-ap550:19.2",
      "pali": "saritvā jinasāsanaṁ;"
    },
    {
      "id": "tha-ap550:19.3",
      "pali": "Bhaddekarattaovādaṁ,"
    },
    {
      "id": "tha-ap550:19.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap550:20.1",
      "pali": "‘Atītaṁ nānvāgameyya,"
    },
    {
      "id": "tha-ap550:20.2",
      "pali": "nappaṭikaṅkhe anāgataṁ;"
    },
    {
      "id": "tha-ap550:20.3",
      "pali": "Yadatītaṁ pahīnaṁ taṁ,"
    },
    {
      "id": "tha-ap550:20.4",
      "pali": "appattañca anāgataṁ."
    },
    {
      "id": "tha-ap550:21.1",
      "pali": "Paccuppannañca yo dhammaṁ,"
    },
    {
      "id": "tha-ap550:21.2",
      "pali": "tattha tattha vipassati;"
    },
    {
      "id": "tha-ap550:21.3",
      "pali": "Asaṁhīraṁ asaṅkuppaṁ,"
    },
    {
      "id": "tha-ap550:21.4",
      "pali": "taṁ vidvā manubrūhaye."
    },
    {
      "id": "tha-ap550:22.1",
      "pali": "Ajjeva kiccamātappaṁ,"
    },
    {
      "id": "tha-ap550:22.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "tha-ap550:22.3",
      "pali": "Na hi no saṅgaraṁ tena,"
    },
    {
      "id": "tha-ap550:22.4",
      "pali": "mahāsenena maccunā."
    },
    {
      "id": "tha-ap550:23.1",
      "pali": "Evaṁvihāriṁ ātāpiṁ,"
    },
    {
      "id": "tha-ap550:23.2",
      "pali": "ahorattamatanditaṁ;"
    },
    {
      "id": "tha-ap550:23.3",
      "pali": "Taṁ ve bhaddekarattoti,"
    },
    {
      "id": "tha-ap550:23.4",
      "pali": "santo ācikkhate muni’."
    },
    {
      "id": "tha-ap550:24.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap550:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap550:24.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap550:25.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap550:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap550:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap550:26.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap550:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap550:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap550:27.1",
      "pali": "Itthaṁ sudaṁ āyasmā lomasakaṅgiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap550:28.1",
      "pali": "Lomasakaṅgiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
