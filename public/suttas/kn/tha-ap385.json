{
  "uid": "tha-ap385",
  "title": "Udumbaraphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap385:1.1",
      "pali": "“Vinatānadiyā tīre,"
    },
    {
      "id": "tha-ap385:1.2",
      "pali": "vihāsi purisuttamo;"
    },
    {
      "id": "tha-ap385:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap385:1.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "tha-ap385:2.1",
      "pali": "Tasmiṁ pasannamānaso,"
    },
    {
      "id": "tha-ap385:2.2",
      "pali": "kilesamaladhovane;"
    },
    {
      "id": "tha-ap385:2.3",
      "pali": "Udumbaraphalaṁ gayha,"
    },
    {
      "id": "tha-ap385:2.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap385:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap385:3.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap385:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap385:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap385:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap385:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap385:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap385:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap385:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap385:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap385:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap385:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap385:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap385:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā udumbaraphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap385:8.1",
      "pali": "Udumbaraphaladāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
