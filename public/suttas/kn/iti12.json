{
  "uid": "iti12",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti12:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti12:2.1",
      "pali": "“Kodhaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti12:2.2",
      "pali": "Kodhañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti12:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti12:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti12:3.1",
      "pali": "“Yena kodhena kuddhāse,"
    },
    {
      "id": "iti12:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti12:3.3",
      "pali": "Taṁ kodhaṁ sammadaññāya,"
    },
    {
      "id": "iti12:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti12:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti12:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti12:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti12:4.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
