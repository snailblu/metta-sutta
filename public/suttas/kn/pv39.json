{
  "uid": "pv39",
  "title": "4. Revatīpetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv39:1.1",
      "pali": "“Uṭṭhehi revate supāpadhamme,"
    },
    {
      "id": "pv39:1.2",
      "pali": "Apārutadvāre adānasīle;"
    },
    {
      "id": "pv39:1.3",
      "pali": "Nessāma taṁ yattha thunanti duggatā,"
    },
    {
      "id": "pv39:1.4",
      "pali": "Samappitā nerayikā dukhenā”ti."
    },
    {
      "id": "pv39:2.1",
      "pali": "Icceva vatvāna yamassa dūtā,"
    },
    {
      "id": "pv39:2.2",
      "pali": "Te dve yakkhā lohitakkhā brahantā;"
    },
    {
      "id": "pv39:2.3",
      "pali": "Paccekabāhāsu gahetvā revataṁ,"
    },
    {
      "id": "pv39:2.4",
      "pali": "Pakkāmayuṁ devagaṇassa santike."
    },
    {
      "id": "pv39:3.1",
      "pali": "“Ādiccavaṇṇaṁ ruciraṁ pabhassaraṁ,"
    },
    {
      "id": "pv39:3.2",
      "pali": "Byamhaṁ subhaṁ kañcanajālachannaṁ;"
    },
    {
      "id": "pv39:3.3",
      "pali": "Kassetamākiṇṇajanaṁ vimānaṁ,"
    },
    {
      "id": "pv39:3.4",
      "pali": "Suriyassa raṁsīriva jotamānaṁ."
    },
    {
      "id": "pv39:4.1",
      "pali": "Nārīgaṇā candanasāralittā,"
    },
    {
      "id": "pv39:4.2",
      "pali": "Ubhato vimānaṁ upasobhayanti;"
    },
    {
      "id": "pv39:4.3",
      "pali": "Taṁ dissati suriyasamānavaṇṇaṁ,"
    },
    {
      "id": "pv39:4.4",
      "pali": "Ko modati saggapatto vimāne”ti."
    },
    {
      "id": "pv39:5.1",
      "pali": "“Bārāṇasiyaṁ nandiyo nāmāsi,"
    },
    {
      "id": "pv39:5.2",
      "pali": "Upāsako amaccharī dānapati vadaññū;"
    },
    {
      "id": "pv39:5.3",
      "pali": "Tassetamākiṇṇajanaṁ vimānaṁ,"
    },
    {
      "id": "pv39:5.4",
      "pali": "Suriyassa raṁsīriva jotamānaṁ."
    },
    {
      "id": "pv39:6.1",
      "pali": "Nārīgaṇā candanasāralittā,"
    },
    {
      "id": "pv39:6.2",
      "pali": "Ubhato vimānaṁ upasobhayanti;"
    },
    {
      "id": "pv39:6.3",
      "pali": "Taṁ dissati suriyasamānavaṇṇaṁ,"
    },
    {
      "id": "pv39:6.4",
      "pali": "So modati saggapatto vimāne”ti."
    },
    {
      "id": "pv39:7.1",
      "pali": "“Nandiyassāhaṁ bhariyā,"
    },
    {
      "id": "pv39:7.2",
      "pali": "Agārinī sabbakulassa issarā;"
    },
    {
      "id": "pv39:7.3",
      "pali": "Bhattu vimāne ramissāmi dānahaṁ,"
    },
    {
      "id": "pv39:7.4",
      "pali": "Na patthaye nirayadassanāyā”ti."
    },
    {
      "id": "pv39:8.1",
      "pali": "“Eso te nirayo supāpadhamme,"
    },
    {
      "id": "pv39:8.2",
      "pali": "Puññaṁ tayā akataṁ jīvaloke;"
    },
    {
      "id": "pv39:8.3",
      "pali": "Na hi maccharī rosako pāpadhammo,"
    },
    {
      "id": "pv39:8.4",
      "pali": "Saggūpagānaṁ labhati sahabyatan”ti."
    },
    {
      "id": "pv39:9.1",
      "pali": "“Kiṁ nu gūthañca muttañca,"
    },
    {
      "id": "pv39:9.2",
      "pali": "asucī paṭidissati;"
    },
    {
      "id": "pv39:9.3",
      "pali": "Duggandhaṁ kimidaṁ mīḷhaṁ,"
    },
    {
      "id": "pv39:9.4",
      "pali": "kimetaṁ upavāyatī”ti."
    },
    {
      "id": "pv39:10.1",
      "pali": "“Esa saṁsavako nāma,"
    },
    {
      "id": "pv39:10.2",
      "pali": "gambhīro sataporiso;"
    },
    {
      "id": "pv39:10.3",
      "pali": "Yattha vassasahassāni,"
    },
    {
      "id": "pv39:10.4",
      "pali": "tuvaṁ paccasi revate”ti."
    },
    {
      "id": "pv39:11.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv39:11.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv39:11.3",
      "pali": "Kena saṁsavako laddho,"
    },
    {
      "id": "pv39:11.4",
      "pali": "gambhīro sataporiso”ti."
    },
    {
      "id": "pv39:12.1",
      "pali": "“Samaṇe brāhmaṇe cāpi,"
    },
    {
      "id": "pv39:12.2",
      "pali": "aññe vāpi vanibbake;"
    },
    {
      "id": "pv39:12.3",
      "pali": "Musāvādena vañcesi,"
    },
    {
      "id": "pv39:12.4",
      "pali": "taṁ pāpaṁ pakataṁ tayā."
    },
    {
      "id": "pv39:13.1",
      "pali": "Tena saṁsavako laddho,"
    },
    {
      "id": "pv39:13.2",
      "pali": "gambhīro sataporiso;"
    },
    {
      "id": "pv39:13.3",
      "pali": "Tattha vassasahassāni,"
    },
    {
      "id": "pv39:13.4",
      "pali": "tuvaṁ paccasi revate."
    },
    {
      "id": "pv39:14.1",
      "pali": "Hatthepi chindanti athopi pāde,"
    },
    {
      "id": "pv39:14.2",
      "pali": "Kaṇṇepi chindanti athopi nāsaṁ;"
    },
    {
      "id": "pv39:14.3",
      "pali": "Athopi kākoḷagaṇā samecca,"
    },
    {
      "id": "pv39:14.4",
      "pali": "Saṅgamma khādanti viphandamānan”ti."
    },
    {
      "id": "pv39:15.1",
      "pali": "“Sādhu kho maṁ paṭinetha,"
    },
    {
      "id": "pv39:15.2",
      "pali": "kāhāmi kusalaṁ bahuṁ;"
    },
    {
      "id": "pv39:15.3",
      "pali": "Dānena samacariyāya,"
    },
    {
      "id": "pv39:15.4",
      "pali": "saṁyamena damena ca;"
    },
    {
      "id": "pv39:15.5",
      "pali": "Yaṁ katvā sukhitā honti,"
    },
    {
      "id": "pv39:15.6",
      "pali": "na ca pacchānutappare”ti."
    },
    {
      "id": "pv39:16.1",
      "pali": "“Pure tuvaṁ pamajjitvā,"
    },
    {
      "id": "pv39:16.2",
      "pali": "idāni paridevasi;"
    },
    {
      "id": "pv39:16.3",
      "pali": "Sayaṁ katānaṁ kammānaṁ,"
    },
    {
      "id": "pv39:16.4",
      "pali": "vipākaṁ anubhossasī”ti."
    },
    {
      "id": "pv39:17.1",
      "pali": "“Ko devalokato manussalokaṁ,"
    },
    {
      "id": "pv39:17.2",
      "pali": "Gantvāna puṭṭho me evaṁ vadeyya;"
    },
    {
      "id": "pv39:17.3",
      "pali": "‘Nikkhittadaṇḍesu dadātha dānaṁ,"
    },
    {
      "id": "pv39:17.4",
      "pali": "Acchādanaṁ seyya mathannapānaṁ;"
    },
    {
      "id": "pv39:17.5",
      "pali": "Na hi maccharī rosako pāpadhammo,"
    },
    {
      "id": "pv39:17.6",
      "pali": "Saggūpagānaṁ labhati sahabyataṁ’."
    },
    {
      "id": "pv39:18.1",
      "pali": "Sāhaṁ nūna ito gantvā,"
    },
    {
      "id": "pv39:18.2",
      "pali": "yoniṁ laddhāna mānusiṁ;"
    },
    {
      "id": "pv39:18.3",
      "pali": "Vadaññū sīlasampannā,"
    },
    {
      "id": "pv39:18.4",
      "pali": "kāhāmi kusalaṁ bahuṁ;"
    },
    {
      "id": "pv39:18.5",
      "pali": "Dānena samacariyāya,"
    },
    {
      "id": "pv39:18.6",
      "pali": "saṁyamena damena ca."
    },
    {
      "id": "pv39:19.1",
      "pali": "Ārāmāni ca ropissaṁ,"
    },
    {
      "id": "pv39:19.2",
      "pali": "dugge saṅkamanāni ca;"
    },
    {
      "id": "pv39:19.3",
      "pali": "Papañca udapānañca,"
    },
    {
      "id": "pv39:19.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "pv39:20.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "pv39:20.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "pv39:20.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "pv39:20.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "pv39:21.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "pv39:21.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "pv39:21.3",
      "pali": "Na ca dāne pamajjissaṁ,"
    },
    {
      "id": "pv39:21.4",
      "pali": "sāmaṁ diṭṭhamidaṁ mayā”ti."
    },
    {
      "id": "pv39:22.1",
      "pali": "Iccevaṁ vippalapantiṁ,"
    },
    {
      "id": "pv39:22.2",
      "pali": "phandamānaṁ tato tato;"
    },
    {
      "id": "pv39:22.3",
      "pali": "Khipiṁsu niraye ghore,"
    },
    {
      "id": "pv39:22.4",
      "pali": "uddhampādaṁ avaṁsiraṁ."
    },
    {
      "id": "pv39:23.1",
      "pali": "“Ahaṁ pure maccharinī ahosiṁ,"
    },
    {
      "id": "pv39:23.2",
      "pali": "Paribhāsikā samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "pv39:23.3",
      "pali": "Vitathena ca sāmikaṁ vañcayitvā,"
    },
    {
      "id": "pv39:23.4",
      "pali": "Paccāmahaṁ niraye ghorarūpe”ti."
    },
    {
      "id": "pv39:24.1",
      "pali": "Revatīpetavatthu catutthaṁ."
    }
  ]
}
