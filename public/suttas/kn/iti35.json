{
  "uid": "iti35",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti35:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti35:2.1",
      "pali": "“Nayidaṁ, bhikkhave, brahmacariyaṁ vussati janakuhanatthaṁ, na janalapanatthaṁ, na lābhasakkārasilokānisaṁsatthaṁ, na ‘iti maṁ jano jānātū’ti."
    },
    {
      "id": "iti35:2.2",
      "pali": "Atha kho idaṁ, bhikkhave, brahmacariyaṁ vussati saṁvaratthañceva pahānatthañcā”ti."
    },
    {
      "id": "iti35:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti35:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti35:3.1",
      "pali": "“Saṁvaratthaṁ pahānatthaṁ,"
    },
    {
      "id": "iti35:3.2",
      "pali": "brahmacariyaṁ anītihaṁ;"
    },
    {
      "id": "iti35:3.3",
      "pali": "Adesayi so bhagavā,"
    },
    {
      "id": "iti35:3.4",
      "pali": "nibbānogadhagāminaṁ."
    },
    {
      "id": "iti35:4.1",
      "pali": "Esa maggo mahattehi,"
    },
    {
      "id": "iti35:4.2",
      "pali": "anuyāto mahesibhi;"
    },
    {
      "id": "iti35:4.3",
      "pali": "Ye ye taṁ paṭipajjanti,"
    },
    {
      "id": "iti35:4.4",
      "pali": "yathā buddhena desitaṁ;"
    },
    {
      "id": "iti35:4.5",
      "pali": "Dukkhassantaṁ karissanti,"
    },
    {
      "id": "iti35:4.6",
      "pali": "satthusāsanakārino”ti."
    },
    {
      "id": "iti35:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti35:5.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
