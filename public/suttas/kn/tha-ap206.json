{
  "uid": "tha-ap206",
  "title": "Taraṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap206:1.1",
      "pali": "“Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap206:1.2",
      "pali": "dvipadindo narāsabho;"
    },
    {
      "id": "tha-ap206:1.3",
      "pali": "Purakkhato sāvakehi,"
    },
    {
      "id": "tha-ap206:1.4",
      "pali": "gaṅgātīramupāgami."
    },
    {
      "id": "tha-ap206:2.1",
      "pali": "Samatitti kākapeyyā,"
    },
    {
      "id": "tha-ap206:2.2",
      "pali": "gaṅgā āsi duruttarā;"
    },
    {
      "id": "tha-ap206:2.3",
      "pali": "Uttārayiṁ bhikkhusaṅghaṁ,"
    },
    {
      "id": "tha-ap206:2.4",
      "pali": "buddhañca dvipaduttamaṁ."
    },
    {
      "id": "tha-ap206:3.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap206:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap206:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap206:3.4",
      "pali": "taraṇāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap206:4.1",
      "pali": "Teraseto kappasate,"
    },
    {
      "id": "tha-ap206:4.2",
      "pali": "pañca sabbobhavā ahuṁ;"
    },
    {
      "id": "tha-ap206:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap206:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap206:5.1",
      "pali": "Pacchime ca bhave asmiṁ,"
    },
    {
      "id": "tha-ap206:5.2",
      "pali": "jātohaṁ brāhmaṇe kule;"
    },
    {
      "id": "tha-ap206:5.3",
      "pali": "Saddhiṁ tīhi sahāyehi,"
    },
    {
      "id": "tha-ap206:5.4",
      "pali": "pabbajiṁ satthu sāsane."
    },
    {
      "id": "tha-ap206:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap206:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap206:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap206:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā taraṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap206:8.1",
      "pali": "Taraṇiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
