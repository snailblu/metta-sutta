{
  "uid": "ja372",
  "title": "Aḍḍhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja372:1.1",
      "pali": "“Agārā paccupetassa,"
    },
    {
      "id": "ja372:1.2",
      "pali": "anagārassa te sato;"
    },
    {
      "id": "ja372:1.3",
      "pali": "Samaṇassa na taṁ sādhu,"
    },
    {
      "id": "ja372:1.4",
      "pali": "yaṁ petamanusocasi”."
    },
    {
      "id": "ja372:2.1",
      "pali": "“Saṁvāsena have sakka,"
    },
    {
      "id": "ja372:2.2",
      "pali": "manussassa migassa vā;"
    },
    {
      "id": "ja372:2.3",
      "pali": "Hadaye jāyate pemaṁ,"
    },
    {
      "id": "ja372:2.4",
      "pali": "na taṁ sakkā asocituṁ”."
    },
    {
      "id": "ja372:3.1",
      "pali": "“Mataṁ marissaṁ rodanti,"
    },
    {
      "id": "ja372:3.2",
      "pali": "ye rudanti lapanti ca;"
    },
    {
      "id": "ja372:3.3",
      "pali": "Tasmā tvaṁ isi mā rodi,"
    },
    {
      "id": "ja372:3.4",
      "pali": "roditaṁ moghamāhu santo."
    },
    {
      "id": "ja372:4.1",
      "pali": "Roditena have brahme,"
    },
    {
      "id": "ja372:4.2",
      "pali": "mato peto samuṭṭhahe;"
    },
    {
      "id": "ja372:4.3",
      "pali": "Sabbe saṅgamma rodāma,"
    },
    {
      "id": "ja372:4.4",
      "pali": "aññamaññassa ñātake”."
    },
    {
      "id": "ja372:5.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "ja372:5.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "ja372:5.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "ja372:5.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "ja372:6.1",
      "pali": "Abbahi vata me sallaṁ,"
    },
    {
      "id": "ja372:6.2",
      "pali": "yamāsi hadayassitaṁ;"
    },
    {
      "id": "ja372:6.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "ja372:6.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "ja372:7.1",
      "pali": "Sohaṁ abbūḷhasallosmi,"
    },
    {
      "id": "ja372:7.2",
      "pali": "vītasoko anāvilo;"
    },
    {
      "id": "ja372:7.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "ja372:7.4",
      "pali": "tava sutvāna vāsavā”ti."
    },
    {
      "id": "ja372:8.1",
      "pali": "Migapotakajātakaṁ dutiyaṁ."
    }
  ]
}
