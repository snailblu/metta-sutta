{
  "uid": "tha-ap371",
  "title": "Timirapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap371:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap371:1.2",
      "pali": "anusotaṁ vajāmahaṁ;"
    },
    {
      "id": "tha-ap371:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap371:1.4",
      "pali": "sālarājaṁva phullitaṁ."
    },
    {
      "id": "tha-ap371:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap371:2.2",
      "pali": "paccekamunimuttamaṁ;"
    },
    {
      "id": "tha-ap371:2.3",
      "pali": "Gahetvā timiraṁ pupphaṁ,"
    },
    {
      "id": "tha-ap371:2.4",
      "pali": "matthake okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap371:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap371:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap371:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap371:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap371:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap371:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap371:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap371:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā timirapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap371:6.1",
      "pali": "Timirapupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
