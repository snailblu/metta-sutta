{
  "uid": "tha-ap287",
  "title": "Maghavapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap287:1.1",
      "pali": "“Nammadānadiyā tīre,"
    },
    {
      "id": "tha-ap287:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap287:1.3",
      "pali": "Samādhiṁ so samāpanno,"
    },
    {
      "id": "tha-ap287:1.4",
      "pali": "vippasanno anāvilo."
    },
    {
      "id": "tha-ap287:2.1",
      "pali": "Disvā pasannasumano,"
    },
    {
      "id": "tha-ap287:2.2",
      "pali": "sambuddhaṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap287:2.3",
      "pali": "Tāhaṁ maghavapupphena,"
    },
    {
      "id": "tha-ap287:2.4",
      "pali": "sayambhuṁ pūjayiṁ tadā."
    },
    {
      "id": "tha-ap287:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap287:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap287:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap287:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap287:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap287:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap287:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap287:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā maghavapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap287:6.1",
      "pali": "Maghavapupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
