{
  "uid": "snp1.2",
  "title": "Dhaniyasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp1.2:1.1",
      "pali": "“Pakkodano duddhakhīrohamasmi,"
    },
    {
      "id": "snp1.2:1.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:1.3",
      "pali": "Anutīre mahiyā samānavāso;"
    },
    {
      "id": "snp1.2:1.4",
      "pali": "Channā kuṭi āhito gini,"
    },
    {
      "id": "snp1.2:1.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:2.1",
      "pali": "“Akkodhano vigatakhilohamasmi,"
    },
    {
      "id": "snp1.2:2.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:2.3",
      "pali": "Anutīre mahiyekarattivāso;"
    },
    {
      "id": "snp1.2:2.4",
      "pali": "Vivaṭā kuṭi nibbuto gini,"
    },
    {
      "id": "snp1.2:2.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:3.1",
      "pali": "“Andhakamakasā na vijjare,"
    },
    {
      "id": "snp1.2:3.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:3.3",
      "pali": "Kacche rūḷhatiṇe caranti gāvo;"
    },
    {
      "id": "snp1.2:3.4",
      "pali": "Vuṭṭhimpi saheyyumāgataṁ,"
    },
    {
      "id": "snp1.2:3.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:4.1",
      "pali": "“Baddhāsi bhisī susaṅkhatā,"
    },
    {
      "id": "snp1.2:4.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:4.3",
      "pali": "Tiṇṇo pāragato vineyya oghaṁ;"
    },
    {
      "id": "snp1.2:4.4",
      "pali": "Attho bhisiyā na vijjati,"
    },
    {
      "id": "snp1.2:4.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:5.1",
      "pali": "“Gopī mama assavā alolā,"
    },
    {
      "id": "snp1.2:5.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:5.3",
      "pali": "Dīgharattaṁ saṁvāsiyā manāpā;"
    },
    {
      "id": "snp1.2:5.4",
      "pali": "Tassā na suṇāmi kiñci pāpaṁ,"
    },
    {
      "id": "snp1.2:5.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:6.1",
      "pali": "“Cittaṁ mama assavaṁ vimuttaṁ,"
    },
    {
      "id": "snp1.2:6.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:6.3",
      "pali": "Dīgharattaṁ paribhāvitaṁ sudantaṁ;"
    },
    {
      "id": "snp1.2:6.4",
      "pali": "Pāpaṁ pana me na vijjati,"
    },
    {
      "id": "snp1.2:6.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:7.1",
      "pali": "“Attavetanabhatohamasmi,"
    },
    {
      "id": "snp1.2:7.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:7.3",
      "pali": "Puttā ca me samāniyā arogā;"
    },
    {
      "id": "snp1.2:7.4",
      "pali": "Tesaṁ na suṇāmi kiñci pāpaṁ,"
    },
    {
      "id": "snp1.2:7.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:8.1",
      "pali": "“Nāhaṁ bhatakosmi kassaci,"
    },
    {
      "id": "snp1.2:8.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:8.3",
      "pali": "Nibbiṭṭhena carāmi sabbaloke;"
    },
    {
      "id": "snp1.2:8.4",
      "pali": "Attho bhatiyā na vijjati,"
    },
    {
      "id": "snp1.2:8.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:9.1",
      "pali": "“Atthi vasā atthi dhenupā,"
    },
    {
      "id": "snp1.2:9.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:9.3",
      "pali": "Godharaṇiyo paveṇiyopi atthi;"
    },
    {
      "id": "snp1.2:9.4",
      "pali": "Usabhopi gavampatīdha atthi,"
    },
    {
      "id": "snp1.2:9.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:10.1",
      "pali": "“Natthi vasā natthi dhenupā,"
    },
    {
      "id": "snp1.2:10.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:10.3",
      "pali": "Godharaṇiyo paveṇiyopi natthi;"
    },
    {
      "id": "snp1.2:10.4",
      "pali": "Usabhopi gavampatīdha natthi,"
    },
    {
      "id": "snp1.2:10.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:11.1",
      "pali": "“Khilā nikhātā asampavedhī,"
    },
    {
      "id": "snp1.2:11.2",
      "pali": "(iti dhaniyo gopo)"
    },
    {
      "id": "snp1.2:11.3",
      "pali": "Dāmā muñjamayā navā susaṇṭhānā;"
    },
    {
      "id": "snp1.2:11.4",
      "pali": "Na hi sakkhinti dhenupāpi chettuṁ,"
    },
    {
      "id": "snp1.2:11.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:12.1",
      "pali": "“Usabhoriva chetva bandhanāni,"
    },
    {
      "id": "snp1.2:12.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:12.3",
      "pali": "Nāgo pūtilataṁva dālayitvā;"
    },
    {
      "id": "snp1.2:12.4",
      "pali": "Nāhaṁ punupessaṁ gabbhaseyyaṁ,"
    },
    {
      "id": "snp1.2:12.5",
      "pali": "Atha ce patthayasī pavassa deva”."
    },
    {
      "id": "snp1.2:13.1",
      "pali": "Ninnañca thalañca pūrayanto,"
    },
    {
      "id": "snp1.2:13.2",
      "pali": "Mahāmegho pavassi tāvadeva;"
    },
    {
      "id": "snp1.2:13.3",
      "pali": "Sutvā devassa vassato,"
    },
    {
      "id": "snp1.2:13.4",
      "pali": "Imamatthaṁ dhaniyo abhāsatha."
    },
    {
      "id": "snp1.2:14.1",
      "pali": "“Lābhā vata no anappakā,"
    },
    {
      "id": "snp1.2:14.2",
      "pali": "Ye mayaṁ bhagavantaṁ addasāma;"
    },
    {
      "id": "snp1.2:14.3",
      "pali": "Saraṇaṁ taṁ upema cakkhuma,"
    },
    {
      "id": "snp1.2:14.4",
      "pali": "Satthā no hohi tuvaṁ mahāmuni."
    },
    {
      "id": "snp1.2:15.1",
      "pali": "Gopī ca ahañca assavā,"
    },
    {
      "id": "snp1.2:15.2",
      "pali": "Brahmacariyaṁ sugate carāmase;"
    },
    {
      "id": "snp1.2:15.3",
      "pali": "Jātimaraṇassa pāragū,"
    },
    {
      "id": "snp1.2:15.4",
      "pali": "Dukkhassantakarā bhavāmase”."
    },
    {
      "id": "snp1.2:16.1",
      "pali": "“Nandati puttehi puttimā,"
    },
    {
      "id": "snp1.2:16.2",
      "pali": "(iti māro pāpimā)"
    },
    {
      "id": "snp1.2:16.3",
      "pali": "Gomā gohi tatheva nandati;"
    },
    {
      "id": "snp1.2:16.4",
      "pali": "Upadhī hi narassa nandanā,"
    },
    {
      "id": "snp1.2:16.5",
      "pali": "Na hi so nandati yo nirūpadhi”."
    },
    {
      "id": "snp1.2:17.1",
      "pali": "“Socati puttehi puttimā,"
    },
    {
      "id": "snp1.2:17.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp1.2:17.3",
      "pali": "Gomā gohi tatheva socati;"
    },
    {
      "id": "snp1.2:17.4",
      "pali": "Upadhī hi narassa socanā,"
    },
    {
      "id": "snp1.2:17.5",
      "pali": "Na hi so socati yo nirūpadhī”ti."
    },
    {
      "id": "snp1.2:17.6",
      "pali": "Dhaniyasuttaṁ dutiyaṁ."
    }
  ]
}
