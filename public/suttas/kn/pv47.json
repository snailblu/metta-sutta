{
  "uid": "pv47",
  "title": "12. Ambavanapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv47:1.1",
      "pali": "“Ayañca te pokkharaṇī surammā,"
    },
    {
      "id": "pv47:1.2",
      "pali": "Samā sutitthā ca mahodakā ca;"
    },
    {
      "id": "pv47:1.3",
      "pali": "Supupphitā bhamaragaṇānukiṇṇā,"
    },
    {
      "id": "pv47:1.4",
      "pali": "Kathaṁ tayā laddhā ayaṁ manuññā."
    },
    {
      "id": "pv47:2.1",
      "pali": "Idañca te ambavanaṁ surammaṁ,"
    },
    {
      "id": "pv47:2.2",
      "pali": "Sabbotukaṁ dhārayate phalāni;"
    },
    {
      "id": "pv47:2.3",
      "pali": "Supupphitaṁ bhamaragaṇānukiṇṇaṁ,"
    },
    {
      "id": "pv47:2.4",
      "pali": "Kathaṁ tayā laddhamidaṁ vimānaṁ”."
    },
    {
      "id": "pv47:3.1",
      "pali": "“Ambapakkaṁ dakaṁ yāgu,"
    },
    {
      "id": "pv47:3.2",
      "pali": "sītacchāyā manoramā;"
    },
    {
      "id": "pv47:3.3",
      "pali": "Dhītāya dinnadānena,"
    },
    {
      "id": "pv47:3.4",
      "pali": "tena me idha labbhati”."
    },
    {
      "id": "pv47:4.1",
      "pali": "“Sandiṭṭhikaṁ kammaṁ evaṁ passatha,"
    },
    {
      "id": "pv47:4.2",
      "pali": "Dānassa damassa saṁyamassa vipākaṁ;"
    },
    {
      "id": "pv47:4.3",
      "pali": "Dāsī ahaṁ ayyakulesu hutvā,"
    },
    {
      "id": "pv47:4.4",
      "pali": "Suṇisā homi agārassa issarā”ti."
    },
    {
      "id": "pv47:5.1",
      "pali": "Ambavanapetavatthu dvādasamaṁ."
    }
  ]
}
