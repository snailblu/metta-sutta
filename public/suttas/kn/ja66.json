{
  "uid": "ja66",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja66:1.1",
      "pali": "“Ekā icchā pure āsi,"
    },
    {
      "id": "ja66:1.2",
      "pali": "aladdhā mudulakkhaṇaṁ;"
    },
    {
      "id": "ja66:1.3",
      "pali": "Yato laddhā aḷārakkhī,"
    },
    {
      "id": "ja66:1.4",
      "pali": "icchā icchaṁ vijāyathā”ti."
    },
    {
      "id": "ja66:2.1",
      "pali": "Mudulakkhaṇajātakaṁ chaṭṭhaṁ."
    }
  ]
}
