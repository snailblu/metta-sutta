{
  "uid": "thag21.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag21.1:1.1",
      "pali": "“Nikkhantaṁ vata maṁ santaṁ,"
    },
    {
      "id": "thag21.1:1.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag21.1:1.3",
      "pali": "Vitakkā upadhāvanti,"
    },
    {
      "id": "thag21.1:1.4",
      "pali": "pagabbhā kaṇhato ime."
    },
    {
      "id": "thag21.1:2.1",
      "pali": "Uggaputtā mahissāsā,"
    },
    {
      "id": "thag21.1:2.2",
      "pali": "sikkhitā daḷhadhammino;"
    },
    {
      "id": "thag21.1:2.3",
      "pali": "Samantā parikireyyuṁ,"
    },
    {
      "id": "thag21.1:2.4",
      "pali": "sahassaṁ apalāyinaṁ."
    },
    {
      "id": "thag21.1:3.1",
      "pali": "Sacepi ettakā bhiyyo,"
    },
    {
      "id": "thag21.1:3.2",
      "pali": "āgamissanti itthiyo;"
    },
    {
      "id": "thag21.1:3.3",
      "pali": "Neva maṁ byādhayissanti,"
    },
    {
      "id": "thag21.1:3.4",
      "pali": "dhamme samhi patiṭṭhito."
    },
    {
      "id": "thag21.1:4.1",
      "pali": "Sakkhī hi me sutaṁ etaṁ,"
    },
    {
      "id": "thag21.1:4.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "thag21.1:4.3",
      "pali": "Nibbānagamanaṁ maggaṁ,"
    },
    {
      "id": "thag21.1:4.4",
      "pali": "tattha me nirato mano."
    },
    {
      "id": "thag21.1:5.1",
      "pali": "Evañce maṁ viharantaṁ,"
    },
    {
      "id": "thag21.1:5.2",
      "pali": "pāpima upagacchasi;"
    },
    {
      "id": "thag21.1:5.3",
      "pali": "Tathā maccu karissāmi,"
    },
    {
      "id": "thag21.1:5.4",
      "pali": "na me maggampi dakkhasi."
    },
    {
      "id": "thag21.1:6.1",
      "pali": "Aratiñca ratiñca pahāya,"
    },
    {
      "id": "thag21.1:6.2",
      "pali": "Sabbaso gehasitañca vitakkaṁ;"
    },
    {
      "id": "thag21.1:6.3",
      "pali": "Vanathaṁ na kareyya kuhiñci,"
    },
    {
      "id": "thag21.1:6.4",
      "pali": "Nibbanatho avanatho sa bhikkhu."
    },
    {
      "id": "thag21.1:7.1",
      "pali": "Yamidha pathaviñca vehāsaṁ,"
    },
    {
      "id": "thag21.1:7.2",
      "pali": "Rūpagataṁ jagatogadhaṁ kiñci;"
    },
    {
      "id": "thag21.1:7.3",
      "pali": "Parijīyati sabbamaniccaṁ,"
    },
    {
      "id": "thag21.1:7.4",
      "pali": "Evaṁ samecca caranti mutattā."
    },
    {
      "id": "thag21.1:8.1",
      "pali": "Upadhīsu janā gadhitāse,"
    },
    {
      "id": "thag21.1:8.2",
      "pali": "Diṭṭhasute paṭighe ca mute ca;"
    },
    {
      "id": "thag21.1:8.3",
      "pali": "Ettha vinodaya chandamanejo,"
    },
    {
      "id": "thag21.1:8.4",
      "pali": "Yo hettha na limpati muni tamāhu."
    },
    {
      "id": "thag21.1:9.1",
      "pali": "Atha saṭṭhisitā savitakkā,"
    },
    {
      "id": "thag21.1:9.2",
      "pali": "Puthujjanatāya adhammā niviṭṭhā;"
    },
    {
      "id": "thag21.1:9.3",
      "pali": "Na ca vaggagatassa kuhiñci,"
    },
    {
      "id": "thag21.1:9.4",
      "pali": "No pana duṭṭhullagāhī sa bhikkhu."
    },
    {
      "id": "thag21.1:10.1",
      "pali": "Dabbo cirarattasamāhito,"
    },
    {
      "id": "thag21.1:10.2",
      "pali": "Akuhako nipako apihālu;"
    },
    {
      "id": "thag21.1:10.3",
      "pali": "Santaṁ padaṁ ajjhagamā muni,"
    },
    {
      "id": "thag21.1:10.4",
      "pali": "Paṭicca parinibbuto kaṅkhati kālaṁ."
    },
    {
      "id": "thag21.1:11.1",
      "pali": "Mānaṁ pajahassu gotama,"
    },
    {
      "id": "thag21.1:11.2",
      "pali": "Mānapathañca jahassu asesaṁ;"
    },
    {
      "id": "thag21.1:11.3",
      "pali": "Mānapathamhi sa mucchito,"
    },
    {
      "id": "thag21.1:11.4",
      "pali": "Vippaṭisārīhuvā cirarattaṁ."
    },
    {
      "id": "thag21.1:12.1",
      "pali": "Makkhena makkhitā pajā,"
    },
    {
      "id": "thag21.1:12.2",
      "pali": "Mānahatā nirayaṁ papatanti;"
    },
    {
      "id": "thag21.1:12.3",
      "pali": "Socanti janā cirarattaṁ,"
    },
    {
      "id": "thag21.1:12.4",
      "pali": "Mānahatā nirayaṁ upapannā."
    },
    {
      "id": "thag21.1:13.1",
      "pali": "Na hi socati bhikkhu kadāci,"
    },
    {
      "id": "thag21.1:13.2",
      "pali": "Maggajino sammā paṭipanno;"
    },
    {
      "id": "thag21.1:13.3",
      "pali": "Kittiñca sukhañcānubhoti,"
    },
    {
      "id": "thag21.1:13.4",
      "pali": "Dhammadasoti tamāhu tathattaṁ."
    },
    {
      "id": "thag21.1:14.1",
      "pali": "Tasmā akhilo idha padhānavā,"
    },
    {
      "id": "thag21.1:14.2",
      "pali": "Nīvaraṇāni pahāya visuddho;"
    },
    {
      "id": "thag21.1:14.3",
      "pali": "Mānañca pahāya asesaṁ,"
    },
    {
      "id": "thag21.1:14.4",
      "pali": "Vijjāyantakaro samitāvī”."
    },
    {
      "id": "thag21.1:15.1",
      "pali": "“Kāmarāgena ḍayhāmi,"
    },
    {
      "id": "thag21.1:15.2",
      "pali": "cittaṁ me pariḍayhati;"
    },
    {
      "id": "thag21.1:15.3",
      "pali": "Sādhu nibbāpanaṁ brūhi,"
    },
    {
      "id": "thag21.1:15.4",
      "pali": "anukampāya gotama”."
    },
    {
      "id": "thag21.1:16.1",
      "pali": "“Saññāya vipariyesā,"
    },
    {
      "id": "thag21.1:16.2",
      "pali": "cittaṁ te pariḍayhati;"
    },
    {
      "id": "thag21.1:16.3",
      "pali": "Nimittaṁ parivajjehi,"
    },
    {
      "id": "thag21.1:16.4",
      "pali": "subhaṁ rāgūpasaṁhitaṁ. (…)"
    },
    {
      "id": "thag21.1:17.1",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "thag21.1:17.2",
      "pali": "ekaggaṁ susamāhitaṁ;"
    },
    {
      "id": "thag21.1:17.3",
      "pali": "Sati kāyagatā tyatthu,"
    },
    {
      "id": "thag21.1:17.4",
      "pali": "nibbidābahulo bhava."
    },
    {
      "id": "thag21.1:18.1",
      "pali": "Animittañca bhāvehi,"
    },
    {
      "id": "thag21.1:18.2",
      "pali": "mānānusayamujjaha;"
    },
    {
      "id": "thag21.1:18.3",
      "pali": "Tato mānābhisamayā,"
    },
    {
      "id": "thag21.1:18.4",
      "pali": "upasanto carissasi”."
    },
    {
      "id": "thag21.1:19.1",
      "pali": "“Tameva vācaṁ bhāseyya,"
    },
    {
      "id": "thag21.1:19.2",
      "pali": "yāyattānaṁ na tāpaye;"
    },
    {
      "id": "thag21.1:19.3",
      "pali": "Pare ca na vihiṁseyya,"
    },
    {
      "id": "thag21.1:19.4",
      "pali": "sā ve vācā subhāsitā."
    },
    {
      "id": "thag21.1:20.1",
      "pali": "Piyavācameva bhāseyya,"
    },
    {
      "id": "thag21.1:20.2",
      "pali": "yā vācā paṭinanditā;"
    },
    {
      "id": "thag21.1:20.3",
      "pali": "Yaṁ anādāya pāpāni,"
    },
    {
      "id": "thag21.1:20.4",
      "pali": "paresaṁ bhāsate piyaṁ."
    },
    {
      "id": "thag21.1:21.1",
      "pali": "Saccaṁ ve amatā vācā,"
    },
    {
      "id": "thag21.1:21.2",
      "pali": "esa dhammo sanantano;"
    },
    {
      "id": "thag21.1:21.3",
      "pali": "Sacce atthe ca dhamme ca,"
    },
    {
      "id": "thag21.1:21.4",
      "pali": "āhu santo patiṭṭhitā."
    },
    {
      "id": "thag21.1:22.1",
      "pali": "Yaṁ buddho bhāsati vācaṁ,"
    },
    {
      "id": "thag21.1:22.2",
      "pali": "khemaṁ nibbānapattiyā;"
    },
    {
      "id": "thag21.1:22.3",
      "pali": "Dukkhassantakiriyāya,"
    },
    {
      "id": "thag21.1:22.4",
      "pali": "sā ve vācānamuttamā”."
    },
    {
      "id": "thag21.1:23.1",
      "pali": "“Gambhīrapañño medhāvī,"
    },
    {
      "id": "thag21.1:23.2",
      "pali": "maggāmaggassa kovido;"
    },
    {
      "id": "thag21.1:23.3",
      "pali": "Sāriputto mahāpañño,"
    },
    {
      "id": "thag21.1:23.4",
      "pali": "dhammaṁ deseti bhikkhunaṁ."
    },
    {
      "id": "thag21.1:24.1",
      "pali": "Saṅkhittenapi deseti,"
    },
    {
      "id": "thag21.1:24.2",
      "pali": "vitthārenapi bhāsati;"
    },
    {
      "id": "thag21.1:24.3",
      "pali": "Sālikāyiva nigghoso,"
    },
    {
      "id": "thag21.1:24.4",
      "pali": "paṭibhānaṁ udiyyati."
    },
    {
      "id": "thag21.1:25.1",
      "pali": "Tassa taṁ desayantassa,"
    },
    {
      "id": "thag21.1:25.2",
      "pali": "suṇanti madhuraṁ giraṁ;"
    },
    {
      "id": "thag21.1:25.3",
      "pali": "Sarena rajanīyena,"
    },
    {
      "id": "thag21.1:25.4",
      "pali": "savanīyena vaggunā;"
    },
    {
      "id": "thag21.1:25.5",
      "pali": "Udaggacittā muditā,"
    },
    {
      "id": "thag21.1:25.6",
      "pali": "sotaṁ odhenti bhikkhavo”."
    },
    {
      "id": "thag21.1:26.1",
      "pali": "“Ajja pannarase visuddhiyā,"
    },
    {
      "id": "thag21.1:26.2",
      "pali": "Bhikkhū pañcasatā samāgatā;"
    },
    {
      "id": "thag21.1:26.3",
      "pali": "Saṁyojanabandhanacchidā,"
    },
    {
      "id": "thag21.1:26.4",
      "pali": "Anīghā khīṇapunabbhavā isī."
    },
    {
      "id": "thag21.1:27.1",
      "pali": "Cakkavattī yathā rājā,"
    },
    {
      "id": "thag21.1:27.2",
      "pali": "amaccaparivārito;"
    },
    {
      "id": "thag21.1:27.3",
      "pali": "Samantā anupariyeti,"
    },
    {
      "id": "thag21.1:27.4",
      "pali": "sāgarantaṁ mahiṁ imaṁ."
    },
    {
      "id": "thag21.1:28.1",
      "pali": "Evaṁ vijitasaṅgāmaṁ,"
    },
    {
      "id": "thag21.1:28.2",
      "pali": "satthavāhaṁ anuttaraṁ;"
    },
    {
      "id": "thag21.1:28.3",
      "pali": "Sāvakā payirupāsanti,"
    },
    {
      "id": "thag21.1:28.4",
      "pali": "tevijjā maccuhāyino."
    },
    {
      "id": "thag21.1:29.1",
      "pali": "Sabbe bhagavato puttā,"
    },
    {
      "id": "thag21.1:29.2",
      "pali": "palāpettha na vijjati;"
    },
    {
      "id": "thag21.1:29.3",
      "pali": "Taṇhāsallassa hantāraṁ,"
    },
    {
      "id": "thag21.1:29.4",
      "pali": "vande ādiccabandhunaṁ."
    },
    {
      "id": "thag21.1:30.1",
      "pali": "Parosahassaṁ bhikkhūnaṁ,"
    },
    {
      "id": "thag21.1:30.2",
      "pali": "sugataṁ payirupāsati;"
    },
    {
      "id": "thag21.1:30.3",
      "pali": "Desentaṁ virajaṁ dhammaṁ,"
    },
    {
      "id": "thag21.1:30.4",
      "pali": "nibbānaṁ akutobhayaṁ."
    },
    {
      "id": "thag21.1:31.1",
      "pali": "Suṇanti dhammaṁ vimalaṁ,"
    },
    {
      "id": "thag21.1:31.2",
      "pali": "sammāsambuddhadesitaṁ;"
    },
    {
      "id": "thag21.1:31.3",
      "pali": "Sobhati vata sambuddho,"
    },
    {
      "id": "thag21.1:31.4",
      "pali": "bhikkhusaṅghapurakkhato."
    },
    {
      "id": "thag21.1:32.1",
      "pali": "‘Nāganāmo’si bhagavā,"
    },
    {
      "id": "thag21.1:32.2",
      "pali": "isīnaṁ isisattamo;"
    },
    {
      "id": "thag21.1:32.3",
      "pali": "Mahāmeghova hutvāna,"
    },
    {
      "id": "thag21.1:32.4",
      "pali": "sāvake abhivassasi."
    },
    {
      "id": "thag21.1:33.1",
      "pali": "Divā vihārā nikkhamma,"
    },
    {
      "id": "thag21.1:33.2",
      "pali": "satthudassanakamyatā;"
    },
    {
      "id": "thag21.1:33.3",
      "pali": "Sāvako te mahāvīra,"
    },
    {
      "id": "thag21.1:33.4",
      "pali": "pāde vandati vaṅgiso”."
    },
    {
      "id": "thag21.1:34.1",
      "pali": "“Ummaggapathaṁ mārassa,"
    },
    {
      "id": "thag21.1:34.2",
      "pali": "Abhibhuyya carati pabhijja khīlāni;"
    },
    {
      "id": "thag21.1:34.3",
      "pali": "Taṁ passatha bandhapamuñcakaraṁ,"
    },
    {
      "id": "thag21.1:34.4",
      "pali": "Asitaṁva bhāgaso pavibhajja."
    },
    {
      "id": "thag21.1:35.1",
      "pali": "Oghassa hi nitaraṇatthaṁ,"
    },
    {
      "id": "thag21.1:35.2",
      "pali": "Anekavihitaṁ maggaṁ akkhāsi;"
    },
    {
      "id": "thag21.1:35.3",
      "pali": "Tasmiñca amate akkhāte,"
    },
    {
      "id": "thag21.1:35.4",
      "pali": "Dhammadasā ṭhitā asaṁhīrā."
    },
    {
      "id": "thag21.1:36.1",
      "pali": "Pajjotakaro ativijjha,"
    },
    {
      "id": "thag21.1:36.2",
      "pali": "Sabbaṭhitīnaṁ atikkamamaddasa;"
    },
    {
      "id": "thag21.1:36.3",
      "pali": "Ñatvā ca sacchikatvā ca,"
    },
    {
      "id": "thag21.1:36.4",
      "pali": "Aggaṁ so desayi dasaddhānaṁ."
    },
    {
      "id": "thag21.1:37.1",
      "pali": "Evaṁ sudesite dhamme,"
    },
    {
      "id": "thag21.1:37.2",
      "pali": "Ko pamādo vijānataṁ dhammaṁ;"
    },
    {
      "id": "thag21.1:37.3",
      "pali": "Tasmā hi tassa bhagavato sāsane,"
    },
    {
      "id": "thag21.1:37.4",
      "pali": "Appamatto sadā namassamanusikkhe”."
    },
    {
      "id": "thag21.1:38.1",
      "pali": "“Buddhānubuddho yo thero,"
    },
    {
      "id": "thag21.1:38.2",
      "pali": "koṇḍañño tibbanikkamo;"
    },
    {
      "id": "thag21.1:38.3",
      "pali": "Lābhī sukhavihārānaṁ,"
    },
    {
      "id": "thag21.1:38.4",
      "pali": "vivekānaṁ abhiṇhaso."
    },
    {
      "id": "thag21.1:39.1",
      "pali": "Yaṁ sāvakena pattabbaṁ,"
    },
    {
      "id": "thag21.1:39.2",
      "pali": "satthu sāsanakārinā;"
    },
    {
      "id": "thag21.1:39.3",
      "pali": "Sabbassa taṁ anuppattaṁ,"
    },
    {
      "id": "thag21.1:39.4",
      "pali": "appamattassa sikkhato."
    },
    {
      "id": "thag21.1:40.1",
      "pali": "Mahānubhāvo tevijjo,"
    },
    {
      "id": "thag21.1:40.2",
      "pali": "cetopariyakovido;"
    },
    {
      "id": "thag21.1:40.3",
      "pali": "Koṇḍañño buddhadāyādo,"
    },
    {
      "id": "thag21.1:40.4",
      "pali": "pāde vandati satthuno”."
    },
    {
      "id": "thag21.1:41.1",
      "pali": "“Nagassa passe āsīnaṁ,"
    },
    {
      "id": "thag21.1:41.2",
      "pali": "muniṁ dukkhassa pāraguṁ;"
    },
    {
      "id": "thag21.1:41.3",
      "pali": "Sāvakā payirupāsanti,"
    },
    {
      "id": "thag21.1:41.4",
      "pali": "tevijjā maccuhāyino."
    },
    {
      "id": "thag21.1:42.1",
      "pali": "Cetasā anupariyeti,"
    },
    {
      "id": "thag21.1:42.2",
      "pali": "moggallāno mahiddhiko;"
    },
    {
      "id": "thag21.1:42.3",
      "pali": "Cittaṁ nesaṁ samanvesaṁ,"
    },
    {
      "id": "thag21.1:42.4",
      "pali": "vippamuttaṁ nirūpadhiṁ."
    },
    {
      "id": "thag21.1:43.1",
      "pali": "Evaṁ sabbaṅgasampannaṁ,"
    },
    {
      "id": "thag21.1:43.2",
      "pali": "muniṁ dukkhassa pāraguṁ;"
    },
    {
      "id": "thag21.1:43.3",
      "pali": "Anekākārasampannaṁ,"
    },
    {
      "id": "thag21.1:43.4",
      "pali": "payirupāsanti gotamaṁ”."
    },
    {
      "id": "thag21.1:44.1",
      "pali": "“Cando yathā vigatavalāhake nabhe,"
    },
    {
      "id": "thag21.1:44.2",
      "pali": "Virocati vītamalova bhāṇumā;"
    },
    {
      "id": "thag21.1:44.3",
      "pali": "Evampi aṅgīrasa tvaṁ mahāmuni,"
    },
    {
      "id": "thag21.1:44.4",
      "pali": "Atirocasi yasasā sabbalokaṁ”."
    },
    {
      "id": "thag21.1:45.1",
      "pali": "“Kāveyyamattā vicarimha pubbe,"
    },
    {
      "id": "thag21.1:45.2",
      "pali": "Gāmā gāmaṁ purā puraṁ;"
    },
    {
      "id": "thag21.1:45.3",
      "pali": "Athaddasāma sambuddhaṁ,"
    },
    {
      "id": "thag21.1:45.4",
      "pali": "Sabbadhammāna pāraguṁ."
    },
    {
      "id": "thag21.1:46.1",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "thag21.1:46.2",
      "pali": "muni dukkhassa pāragū;"
    },
    {
      "id": "thag21.1:46.3",
      "pali": "Dhammaṁ sutvā pasīdimha,"
    },
    {
      "id": "thag21.1:46.4",
      "pali": "saddhā no udapajjatha."
    },
    {
      "id": "thag21.1:47.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thag21.1:47.2",
      "pali": "khandhe āyatanāni ca;"
    },
    {
      "id": "thag21.1:47.3",
      "pali": "Dhātuyo ca viditvāna,"
    },
    {
      "id": "thag21.1:47.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thag21.1:48.1",
      "pali": "Bahūnaṁ vata atthāya,"
    },
    {
      "id": "thag21.1:48.2",
      "pali": "uppajjanti tathāgatā;"
    },
    {
      "id": "thag21.1:48.3",
      "pali": "Itthīnaṁ purisānañca,"
    },
    {
      "id": "thag21.1:48.4",
      "pali": "ye te sāsanakārakā."
    },
    {
      "id": "thag21.1:49.1",
      "pali": "Tesaṁ kho vata atthāya,"
    },
    {
      "id": "thag21.1:49.2",
      "pali": "bodhimajjhagamā muni;"
    },
    {
      "id": "thag21.1:49.3",
      "pali": "Bhikkhūnaṁ bhikkhunīnañca,"
    },
    {
      "id": "thag21.1:49.4",
      "pali": "ye nirāmagataddasā."
    },
    {
      "id": "thag21.1:50.1",
      "pali": "Sudesitā cakkhumatā,"
    },
    {
      "id": "thag21.1:50.2",
      "pali": "buddhenādiccabandhunā;"
    },
    {
      "id": "thag21.1:50.3",
      "pali": "Cattāri ariyasaccāni,"
    },
    {
      "id": "thag21.1:50.4",
      "pali": "anukampāya pāṇinaṁ."
    },
    {
      "id": "thag21.1:51.1",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "thag21.1:51.2",
      "pali": "Dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "thag21.1:51.3",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thag21.1:51.4",
      "pali": "Dukkhūpasamagāminaṁ."
    },
    {
      "id": "thag21.1:52.1",
      "pali": "Evamete tathā vuttā,"
    },
    {
      "id": "thag21.1:52.2",
      "pali": "diṭṭhā me te yathā tathā;"
    },
    {
      "id": "thag21.1:52.3",
      "pali": "Sadattho me anuppatto,"
    },
    {
      "id": "thag21.1:52.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag21.1:53.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thag21.1:53.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "thag21.1:53.3",
      "pali": "Suvibhattesu dhammesu,"
    },
    {
      "id": "thag21.1:53.4",
      "pali": "yaṁ seṭṭhaṁ tadupāgamiṁ."
    },
    {
      "id": "thag21.1:54.1",
      "pali": "Abhiññāpāramippatto,"
    },
    {
      "id": "thag21.1:54.2",
      "pali": "sotadhātu visodhitā;"
    },
    {
      "id": "thag21.1:54.3",
      "pali": "Tevijjo iddhipattomhi,"
    },
    {
      "id": "thag21.1:54.4",
      "pali": "cetopariyakovido”."
    },
    {
      "id": "thag21.1:55.1",
      "pali": "“Pucchāmi satthāramanomapaññaṁ,"
    },
    {
      "id": "thag21.1:55.2",
      "pali": "Diṭṭheva dhamme yo vicikicchānaṁ chettā;"
    },
    {
      "id": "thag21.1:55.3",
      "pali": "Aggāḷave kālamakāsi bhikkhu,"
    },
    {
      "id": "thag21.1:55.4",
      "pali": "Ñāto yasassī abhinibbutatto."
    },
    {
      "id": "thag21.1:56.1",
      "pali": "Nigrodhakappo iti tassa nāmaṁ,"
    },
    {
      "id": "thag21.1:56.2",
      "pali": "Tayā kataṁ bhagavā brāhmaṇassa;"
    },
    {
      "id": "thag21.1:56.3",
      "pali": "So taṁ namassaṁ acari mutyapekho,"
    },
    {
      "id": "thag21.1:56.4",
      "pali": "Āraddhavīriyo daḷhadhammadassī."
    },
    {
      "id": "thag21.1:57.1",
      "pali": "Taṁ sāvakaṁ sakka mayampi sabbe,"
    },
    {
      "id": "thag21.1:57.2",
      "pali": "Aññātumicchāma samantacakkhu;"
    },
    {
      "id": "thag21.1:57.3",
      "pali": "Samavaṭṭhitā no savanāya sotā,"
    },
    {
      "id": "thag21.1:57.4",
      "pali": "Tuvaṁ no satthā tvamanuttarosi."
    },
    {
      "id": "thag21.1:58.1",
      "pali": "Chinda no vicikicchaṁ brūhi metaṁ,"
    },
    {
      "id": "thag21.1:58.2",
      "pali": "Parinibbutaṁ vedaya bhūripañña;"
    },
    {
      "id": "thag21.1:58.3",
      "pali": "Majjheva no bhāsa samantacakkhu,"
    },
    {
      "id": "thag21.1:58.4",
      "pali": "Sakkova devāna sahassanetto."
    },
    {
      "id": "thag21.1:59.1",
      "pali": "Ye keci ganthā idha mohamaggā,"
    },
    {
      "id": "thag21.1:59.2",
      "pali": "Aññāṇapakkhā vicikicchaṭhānā;"
    },
    {
      "id": "thag21.1:59.3",
      "pali": "Tathāgataṁ patvā na te bhavanti,"
    },
    {
      "id": "thag21.1:59.4",
      "pali": "Cakkhuñhi etaṁ paramaṁ narānaṁ."
    },
    {
      "id": "thag21.1:60.1",
      "pali": "No ce hi jātu puriso kilese,"
    },
    {
      "id": "thag21.1:60.2",
      "pali": "Vāto yathā abbhaghanaṁ vihāne;"
    },
    {
      "id": "thag21.1:60.3",
      "pali": "Tamovassa nivuto sabbaloko,"
    },
    {
      "id": "thag21.1:60.4",
      "pali": "Jotimantopi na pabhāseyyuṁ."
    },
    {
      "id": "thag21.1:61.1",
      "pali": "Dhīrā ca pajjotakarā bhavanti,"
    },
    {
      "id": "thag21.1:61.2",
      "pali": "Taṁ taṁ ahaṁ vīra tatheva maññe;"
    },
    {
      "id": "thag21.1:61.3",
      "pali": "Vipassinaṁ jānamupāgamimha,"
    },
    {
      "id": "thag21.1:61.4",
      "pali": "Parisāsu no āvikarohi kappaṁ."
    },
    {
      "id": "thag21.1:62.1",
      "pali": "Khippaṁ giraṁ eraya vaggu vagguṁ,"
    },
    {
      "id": "thag21.1:62.2",
      "pali": "Haṁsova paggayha saṇikaṁ nikūja;"
    },
    {
      "id": "thag21.1:62.3",
      "pali": "Bindussarena suvikappitena,"
    },
    {
      "id": "thag21.1:62.4",
      "pali": "Sabbeva te ujjugatā suṇoma."
    },
    {
      "id": "thag21.1:63.1",
      "pali": "Pahīnajātimaraṇaṁ asesaṁ,"
    },
    {
      "id": "thag21.1:63.2",
      "pali": "Niggayha dhonaṁ vadessāmi dhammaṁ;"
    },
    {
      "id": "thag21.1:63.3",
      "pali": "Na kāmakāro hi puthujjanānaṁ,"
    },
    {
      "id": "thag21.1:63.4",
      "pali": "Saṅkheyyakāro ca tathāgatānaṁ."
    },
    {
      "id": "thag21.1:64.1",
      "pali": "Sampannaveyyākaraṇaṁ tavedaṁ,"
    },
    {
      "id": "thag21.1:64.2",
      "pali": "Samujjupaññassa samuggahītaṁ;"
    },
    {
      "id": "thag21.1:64.3",
      "pali": "Ayamañjali pacchimo suppaṇāmito,"
    },
    {
      "id": "thag21.1:64.4",
      "pali": "Mā mohayī jānamanomapañña."
    },
    {
      "id": "thag21.1:65.1",
      "pali": "Paroparaṁ ariyadhammaṁ viditvā,"
    },
    {
      "id": "thag21.1:65.2",
      "pali": "Mā mohayī jānamanomavīriya;"
    },
    {
      "id": "thag21.1:65.3",
      "pali": "Vāriṁ yathā ghammani ghammatatto,"
    },
    {
      "id": "thag21.1:65.4",
      "pali": "Vācābhikaṅkhāmi sutaṁ pavassa."
    },
    {
      "id": "thag21.1:66.1",
      "pali": "Yadatthikaṁ brahmacariyaṁ acarī,"
    },
    {
      "id": "thag21.1:66.2",
      "pali": "Kappāyano kaccissataṁ amoghaṁ;"
    },
    {
      "id": "thag21.1:66.3",
      "pali": "Nibbāyi so ādu saupādiseso,"
    },
    {
      "id": "thag21.1:66.4",
      "pali": "Yathā vimutto ahu taṁ suṇoma”."
    },
    {
      "id": "thag21.1:67.1",
      "pali": "“Acchecchi taṇhaṁ idha nāmarūpe,"
    },
    {
      "id": "thag21.1:67.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "thag21.1:67.3",
      "pali": "Kaṇhassa sotaṁ dīgharattānusayitaṁ;"
    },
    {
      "id": "thag21.1:67.4",
      "pali": "Atāri jātiṁ maraṇaṁ asesaṁ,"
    },
    {
      "id": "thag21.1:67.5",
      "pali": "Iccabravi bhagavā pañcaseṭṭho”."
    },
    {
      "id": "thag21.1:68.1",
      "pali": "“Esa sutvā pasīdāmi,"
    },
    {
      "id": "thag21.1:68.2",
      "pali": "vaco te isisattama;"
    },
    {
      "id": "thag21.1:68.3",
      "pali": "Amoghaṁ kira me puṭṭhaṁ,"
    },
    {
      "id": "thag21.1:68.4",
      "pali": "na maṁ vañcesi brāhmaṇo."
    },
    {
      "id": "thag21.1:69.1",
      "pali": "Yathā vādī tathā kārī,"
    },
    {
      "id": "thag21.1:69.2",
      "pali": "ahu buddhassa sāvako;"
    },
    {
      "id": "thag21.1:69.3",
      "pali": "Acchecchi maccuno jālaṁ,"
    },
    {
      "id": "thag21.1:69.4",
      "pali": "tataṁ māyāvino daḷhaṁ."
    },
    {
      "id": "thag21.1:70.1",
      "pali": "Addasa bhagavā ādiṁ,"
    },
    {
      "id": "thag21.1:70.2",
      "pali": "upādānassa kappiyo;"
    },
    {
      "id": "thag21.1:70.3",
      "pali": "Accagā vata kappāno,"
    },
    {
      "id": "thag21.1:70.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "thag21.1:71.1",
      "pali": "Taṁ devadevaṁ vandāmi,"
    },
    {
      "id": "thag21.1:71.2",
      "pali": "puttaṁ te dvipaduttama;"
    },
    {
      "id": "thag21.1:71.3",
      "pali": "Anujātaṁ mahāvīraṁ,"
    },
    {
      "id": "thag21.1:71.4",
      "pali": "nāgaṁ nāgassa orasan”ti."
    },
    {
      "id": "thag21.1:71.5",
      "pali": "Itthaṁ sudaṁ āyasmā vaṅgīso thero gāthāyo abhāsitthāti."
    },
    {
      "id": "thag21.1:71.6",
      "pali": "Mahānipāto niṭṭhito."
    },
    {
      "id": "thag21.1:72.1",
      "pali": "Sattatimhi nipātamhi,"
    },
    {
      "id": "thag21.1:72.2",
      "pali": "vaṅgīso paṭibhāṇavā;"
    },
    {
      "id": "thag21.1:72.3",
      "pali": "Ekova thero natthañño,"
    },
    {
      "id": "thag21.1:72.4",
      "pali": "gāthāyo ekasattatīti."
    },
    {
      "id": "thag21.1:72.5",
      "pali": "Niṭṭhitā theragāthāyo."
    },
    {
      "id": "thag21.1:73.1",
      "pali": "Sahassaṁ honti tā gāthā,"
    },
    {
      "id": "thag21.1:73.2",
      "pali": "tīṇi saṭṭhisatāni ca;"
    },
    {
      "id": "thag21.1:73.3",
      "pali": "Therā ca dve satā saṭṭhi,"
    },
    {
      "id": "thag21.1:73.4",
      "pali": "cattāro ca pakāsitā."
    },
    {
      "id": "thag21.1:74.1",
      "pali": "Sīhanādaṁ naditvāna,"
    },
    {
      "id": "thag21.1:74.2",
      "pali": "buddhaputtā anāsavā;"
    },
    {
      "id": "thag21.1:74.3",
      "pali": "Khemantaṁ pāpuṇitvāna,"
    },
    {
      "id": "thag21.1:74.4",
      "pali": "aggikhandhāva nibbutāti."
    },
    {
      "id": "thag21.1:74.5",
      "pali": "Theragāthāpāḷi niṭṭhitā."
    }
  ]
}
