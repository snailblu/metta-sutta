{
  "uid": "vv19",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv19:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv19:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv19:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv19:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv19:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv19:2.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv19:2.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv19:2.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv19:3.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv19:3.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv19:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv19:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv19:4.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv19:4.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv19:4.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv19:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv19:5.1",
      "pali": "“Kevaṭṭadvārā nikkhamma,"
    },
    {
      "id": "vv19:5.2",
      "pali": "ahu mayhaṁ nivesanaṁ;"
    },
    {
      "id": "vv19:5.3",
      "pali": "Tattha sañcaramānānaṁ,"
    },
    {
      "id": "vv19:5.4",
      "pali": "sāvakānaṁ mahesinaṁ."
    },
    {
      "id": "vv19:6.1",
      "pali": "Odanaṁ kummāsaṁ ḍākaṁ,"
    },
    {
      "id": "vv19:6.2",
      "pali": "loṇasovīrakañcahaṁ;"
    },
    {
      "id": "vv19:6.3",
      "pali": "Adāsiṁ ujubhūtesu,"
    },
    {
      "id": "vv19:6.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "vv19:7.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv19:7.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv19:7.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv19:7.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "vv19:8.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "vv19:8.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "vv19:8.3",
      "pali": "Saññamā saṁvibhāgā ca,"
    },
    {
      "id": "vv19:8.4",
      "pali": "vimānaṁ āvasāmahaṁ."
    },
    {
      "id": "vv19:9.1",
      "pali": "Pāṇātipātā viratā,"
    },
    {
      "id": "vv19:9.2",
      "pali": "musāvādā ca saññatā;"
    },
    {
      "id": "vv19:9.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv19:9.4",
      "pali": "majjapānā ca ārakā."
    },
    {
      "id": "vv19:10.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv19:10.2",
      "pali": "ariyasaccāna kovidā;"
    },
    {
      "id": "vv19:10.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv19:10.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv19:11.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv19:11.2",
      "pali": "…pe…"
    },
    {
      "id": "vv19:11.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatīti."
    },
    {
      "id": "vv19:12.1",
      "pali": "Mama ca, bhante, vacanena bhagavato pāde sirasā vandeyyāsi—"
    },
    {
      "id": "vv19:12.2",
      "pali": "‘lakhumā nāma, bhante, upāsikā bhagavato pāde sirasā vandatī’ti."
    },
    {
      "id": "vv19:12.3",
      "pali": "Anacchariyaṁ kho panetaṁ, bhante, yaṁ maṁ bhagavā aññatarasmiṁ sāmaññaphale byākareyya."
    },
    {
      "id": "vv19:12.4",
      "pali": "Taṁ bhagavā sakadāgāmiphale byākāsī”ti."
    },
    {
      "id": "vv19:13.1",
      "pali": "Lakhumāvimānaṁ dutiyaṁ."
    }
  ]
}
