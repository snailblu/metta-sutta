{
  "uid": "tha-ap442",
  "title": "10 Ambaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap442:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap442:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap442:1.3",
      "pali": "Piṇḍāya vicarantassa,"
    },
    {
      "id": "tha-ap442:1.4",
      "pali": "dhārato uttamaṁ yasaṁ."
    },
    {
      "id": "tha-ap442:2.1",
      "pali": "Aggaphalaṁ gahetvāna,"
    },
    {
      "id": "tha-ap442:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap442:2.3",
      "pali": "Dakkhiṇeyyassa vīrassa,"
    },
    {
      "id": "tha-ap442:2.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap442:3.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap442:3.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap442:3.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap442:3.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap442:4.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap442:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap442:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap442:4.4",
      "pali": "aggadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap442:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap442:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap442:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap442:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap442:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap442:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap442:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap442:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap442:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap442:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap442:9.1",
      "pali": "Ambaphaliyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap442:10.1",
      "pali": "Ekavihārivaggo catucattālīsamo."
    },
    {
      "id": "tha-ap442:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap442:12.1",
      "pali": "Thero ekavihārī ca,"
    },
    {
      "id": "tha-ap442:12.2",
      "pali": "saṅkhiyo pāṭihīrako;"
    },
    {
      "id": "tha-ap442:12.3",
      "pali": "Thaviko ucchukhaṇḍī ca,"
    },
    {
      "id": "tha-ap442:12.4",
      "pali": "kaḷambaambāṭakado."
    },
    {
      "id": "tha-ap442:13.1",
      "pali": "Harītakambapiṇḍī ca,"
    },
    {
      "id": "tha-ap442:13.2",
      "pali": "ambado dasamo yati;"
    },
    {
      "id": "tha-ap442:13.3",
      "pali": "Chaḷasīti ca gāthāyo,"
    },
    {
      "id": "tha-ap442:13.4",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
