{
  "uid": "tha-ap194",
  "title": "2 Tiṇasanthārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap194:1.1",
      "pali": "“Yaṁ dāyavāsiko isi,"
    },
    {
      "id": "tha-ap194:1.2",
      "pali": "tiṇaṁ lāyati satthuno;"
    },
    {
      "id": "tha-ap194:1.3",
      "pali": "Sabbe padakkhiṇāvaṭṭā,"
    },
    {
      "id": "tha-ap194:1.4",
      "pali": "pathabyā nipatiṁsu te."
    },
    {
      "id": "tha-ap194:2.1",
      "pali": "Tamahaṁ tiṇamādāya,"
    },
    {
      "id": "tha-ap194:2.2",
      "pali": "santhariṁ dharaṇuttame;"
    },
    {
      "id": "tha-ap194:2.3",
      "pali": "Tīṇeva tālapattāni,"
    },
    {
      "id": "tha-ap194:2.4",
      "pali": "āharitvānahaṁ tadā."
    },
    {
      "id": "tha-ap194:3.1",
      "pali": "Tiṇena chadanaṁ katvā,"
    },
    {
      "id": "tha-ap194:3.2",
      "pali": "siddhatthassa adāsahaṁ;"
    },
    {
      "id": "tha-ap194:3.3",
      "pali": "Sattāhaṁ dhārayuṁ tassa,"
    },
    {
      "id": "tha-ap194:3.4",
      "pali": "devamānusasatthuno."
    },
    {
      "id": "tha-ap194:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap194:4.2",
      "pali": "yaṁ tiṇaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap194:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap194:4.4",
      "pali": "tiṇadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap194:5.1",
      "pali": "Pañcasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap194:5.2",
      "pali": "cattārosuṁ mahaddhanā;"
    },
    {
      "id": "tha-ap194:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap194:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap194:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap194:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap194:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap194:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇasanthārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap194:8.1",
      "pali": "Tiṇasanthārakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
