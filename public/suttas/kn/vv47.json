{
  "uid": "vv47",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv47:1.1",
      "pali": "“Pītavatthe pītadhaje,"
    },
    {
      "id": "vv47:1.2",
      "pali": "pītālaṅkārabhūsite;"
    },
    {
      "id": "vv47:1.3",
      "pali": "Pītacandanalittaṅge,"
    },
    {
      "id": "vv47:1.4",
      "pali": "pītauppalamālinī."
    },
    {
      "id": "vv47:2.1",
      "pali": "Pītapāsādasayane,"
    },
    {
      "id": "vv47:2.2",
      "pali": "pītāsane pītabhājane;"
    },
    {
      "id": "vv47:2.3",
      "pali": "Pītachatte pītarathe,"
    },
    {
      "id": "vv47:2.4",
      "pali": "pītasse pītabījane."
    },
    {
      "id": "vv47:3.1",
      "pali": "Kiṁ kammamakarī bhadde,"
    },
    {
      "id": "vv47:3.2",
      "pali": "pubbe mānusake bhave;"
    },
    {
      "id": "vv47:3.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv47:3.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv47:4.1",
      "pali": "“Kosātakī nāma latatthi bhante,"
    },
    {
      "id": "vv47:4.2",
      "pali": "Tittikā anabhicchitā;"
    },
    {
      "id": "vv47:4.3",
      "pali": "Tassā cattāri pupphāni,"
    },
    {
      "id": "vv47:4.4",
      "pali": "Thūpaṁ abhihariṁ ahaṁ."
    },
    {
      "id": "vv47:5.1",
      "pali": "Satthu sarīramuddissa,"
    },
    {
      "id": "vv47:5.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "vv47:5.3",
      "pali": "Nāssa maggaṁ avekkhissaṁ,"
    },
    {
      "id": "vv47:5.4",
      "pali": "na taggamanasā satī."
    },
    {
      "id": "vv47:6.1",
      "pali": "Tato maṁ avadhī gāvī,"
    },
    {
      "id": "vv47:6.2",
      "pali": "thūpaṁ apattamānasaṁ;"
    },
    {
      "id": "vv47:6.3",
      "pali": "Tañcāhaṁ abhisañceyyaṁ,"
    },
    {
      "id": "vv47:6.4",
      "pali": "bhiyyo nūna ito siyā."
    },
    {
      "id": "vv47:7.1",
      "pali": "Tena kammena devinda,"
    },
    {
      "id": "vv47:7.2",
      "pali": "maghavā devakuñjara;"
    },
    {
      "id": "vv47:7.3",
      "pali": "Pahāya mānusaṁ dehaṁ,"
    },
    {
      "id": "vv47:7.4",
      "pali": "tava sahabyamāgatā”ti."
    },
    {
      "id": "vv47:8.1",
      "pali": "Idaṁ sutvā tidasādhipati,"
    },
    {
      "id": "vv47:8.2",
      "pali": "Maghavā devakuñjaro;"
    },
    {
      "id": "vv47:8.3",
      "pali": "Tāvatiṁse pasādento,"
    },
    {
      "id": "vv47:8.4",
      "pali": "Mātaliṁ etadabravi."
    },
    {
      "id": "vv47:9.1",
      "pali": "“Passa mātali accheraṁ,"
    },
    {
      "id": "vv47:9.2",
      "pali": "cittaṁ kammaphalaṁ idaṁ;"
    },
    {
      "id": "vv47:9.3",
      "pali": "Appakampi kataṁ deyyaṁ,"
    },
    {
      "id": "vv47:9.4",
      "pali": "puññaṁ hoti mahapphalaṁ."
    },
    {
      "id": "vv47:10.1",
      "pali": "Natthi citte pasannamhi,"
    },
    {
      "id": "vv47:10.2",
      "pali": "appakā nāma dakkhiṇā;"
    },
    {
      "id": "vv47:10.3",
      "pali": "Tathāgate vā sambuddhe,"
    },
    {
      "id": "vv47:10.4",
      "pali": "atha vā tassa sāvake."
    },
    {
      "id": "vv47:11.1",
      "pali": "Ehi mātali amhepi,"
    },
    {
      "id": "vv47:11.2",
      "pali": "bhiyyo bhiyyo mahemase;"
    },
    {
      "id": "vv47:11.3",
      "pali": "Tathāgatassa dhātuyo,"
    },
    {
      "id": "vv47:11.4",
      "pali": "sukho puññāna muccayo."
    },
    {
      "id": "vv47:12.1",
      "pali": "Tiṭṭhante nibbute cāpi,"
    },
    {
      "id": "vv47:12.2",
      "pali": "same citte samaṁ phalaṁ;"
    },
    {
      "id": "vv47:12.3",
      "pali": "Cetopaṇidhihetu hi,"
    },
    {
      "id": "vv47:12.4",
      "pali": "sattā gacchanti suggatiṁ."
    },
    {
      "id": "vv47:13.1",
      "pali": "Bahūnaṁ vata atthāya,"
    },
    {
      "id": "vv47:13.2",
      "pali": "uppajjanti tathāgatā;"
    },
    {
      "id": "vv47:13.3",
      "pali": "Yattha kāraṁ karitvāna,"
    },
    {
      "id": "vv47:13.4",
      "pali": "saggaṁ gacchanti dāyakā”ti."
    },
    {
      "id": "vv47:14.1",
      "pali": "Pītavimānaṁ navamaṁ."
    }
  ]
}
