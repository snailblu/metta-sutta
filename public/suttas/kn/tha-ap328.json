{
  "uid": "tha-ap328",
  "title": "Annasaṁsāvakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap328:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap328:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap328:1.3",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap328:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap328:2.1",
      "pali": "Siddhatthaṁ sabbasiddhatthaṁ,"
    },
    {
      "id": "tha-ap328:2.2",
      "pali": "anejaṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap328:2.3",
      "pali": "Sambuddhaṁ atināmetvā,"
    },
    {
      "id": "tha-ap328:2.4",
      "pali": "bhojayiṁ taṁ mahāmuniṁ."
    },
    {
      "id": "tha-ap328:3.1",
      "pali": "Muni kāruṇiko loke,"
    },
    {
      "id": "tha-ap328:3.2",
      "pali": "obhāsayi mamaṁ tadā;"
    },
    {
      "id": "tha-ap328:3.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap328:3.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap328:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap328:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap328:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap328:4.4",
      "pali": "bhikkhādānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap328:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap328:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap328:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap328:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā annasaṁsāvako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap328:7.1",
      "pali": "Annasaṁsāvakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
