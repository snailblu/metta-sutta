{
  "uid": "ja120",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja120:1.1",
      "pali": "“Abaddhā tattha bajjhanti,"
    },
    {
      "id": "ja120:1.2",
      "pali": "yattha bālā pabhāsare;"
    },
    {
      "id": "ja120:1.3",
      "pali": "Baddhāpi tattha muccanti,"
    },
    {
      "id": "ja120:1.4",
      "pali": "yattha dhīrā pabhāsare”ti."
    },
    {
      "id": "ja120:2.1",
      "pali": "Bandhanamokkhajātakaṁ dasamaṁ."
    },
    {
      "id": "ja120:2.2",
      "pali": "Haṁcivaggo dvādasamo."
    },
    {
      "id": "ja120:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja120:4.1",
      "pali": "Atha gadrabha sattuva kaṁsasataṁ,"
    },
    {
      "id": "ja120:4.2",
      "pali": "Bahucinti sāsikāyātikara;"
    },
    {
      "id": "ja120:4.3",
      "pali": "Ativela visesamanācariyova,"
    },
    {
      "id": "ja120:4.4",
      "pali": "Dhīrāpabhāsaratena dasāti."
    }
  ]
}
