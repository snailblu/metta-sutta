{
  "uid": "ja443",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja443:1.1",
      "pali": "“Yo te imaṁ visālakkhiṁ,"
    },
    {
      "id": "ja443:1.2",
      "pali": "piyaṁ sammhitabhāsiniṁ;"
    },
    {
      "id": "ja443:1.3",
      "pali": "Ādāya balā gaccheyya,"
    },
    {
      "id": "ja443:1.4",
      "pali": "kiṁ nu kayirāsi brāhmaṇa”."
    },
    {
      "id": "ja443:2.1",
      "pali": "“Uppajje me na mucceyya,"
    },
    {
      "id": "ja443:2.2",
      "pali": "na me mucceyya jīvato;"
    },
    {
      "id": "ja443:2.3",
      "pali": "Rajaṁva vipulā vuṭṭhi,"
    },
    {
      "id": "ja443:2.4",
      "pali": "khippameva nivāraye”."
    },
    {
      "id": "ja443:3.1",
      "pali": "“Yannu pubbe vikatthittho,"
    },
    {
      "id": "ja443:3.2",
      "pali": "balamhiva apassito;"
    },
    {
      "id": "ja443:3.3",
      "pali": "Svajja tuṇhikato dāni,"
    },
    {
      "id": "ja443:3.4",
      "pali": "saṅghāṭiṁ sibbamacchasi”."
    },
    {
      "id": "ja443:4.1",
      "pali": "“Uppajji me na muccittha,"
    },
    {
      "id": "ja443:4.2",
      "pali": "na me muccittha jīvato;"
    },
    {
      "id": "ja443:4.3",
      "pali": "Rajaṁva vipulā vuṭṭhi,"
    },
    {
      "id": "ja443:4.4",
      "pali": "khippameva nivārayiṁ”."
    },
    {
      "id": "ja443:5.1",
      "pali": "“Kiṁ te uppajji no mucci,"
    },
    {
      "id": "ja443:5.2",
      "pali": "kiṁ te na mucci jīvato;"
    },
    {
      "id": "ja443:5.3",
      "pali": "Rajaṁva vipulā vuṭṭhi,"
    },
    {
      "id": "ja443:5.4",
      "pali": "katamaṁ tvaṁ nivārayi”."
    },
    {
      "id": "ja443:6.1",
      "pali": "“Yamhi jāte na passati,"
    },
    {
      "id": "ja443:6.2",
      "pali": "ajāte sādhu passati;"
    },
    {
      "id": "ja443:6.3",
      "pali": "So me uppajji no mucci,"
    },
    {
      "id": "ja443:6.4",
      "pali": "kodho dummedhagocaro."
    },
    {
      "id": "ja443:7.1",
      "pali": "Yena jātena nandanti,"
    },
    {
      "id": "ja443:7.2",
      "pali": "amittā dukkhamesino;"
    },
    {
      "id": "ja443:7.3",
      "pali": "So me uppajji no mucci,"
    },
    {
      "id": "ja443:7.4",
      "pali": "kodho dummedhagocaro."
    },
    {
      "id": "ja443:8.1",
      "pali": "Yasmiñca jāyamānamhi,"
    },
    {
      "id": "ja443:8.2",
      "pali": "sadatthaṁ nāvabujjhati;"
    },
    {
      "id": "ja443:8.3",
      "pali": "So me uppajji no mucci,"
    },
    {
      "id": "ja443:8.4",
      "pali": "kodho dummedhagocaro."
    },
    {
      "id": "ja443:9.1",
      "pali": "Yenābhibhūto kusalaṁ jahāti,"
    },
    {
      "id": "ja443:9.2",
      "pali": "Parakkare vipulañcāpi atthaṁ;"
    },
    {
      "id": "ja443:9.3",
      "pali": "Sa bhīmaseno balavā pamaddī,"
    },
    {
      "id": "ja443:9.4",
      "pali": "Kodho mahārāja na me amuccatha."
    },
    {
      "id": "ja443:10.1",
      "pali": "Kaṭṭhasmiṁ matthamānasmiṁ,"
    },
    {
      "id": "ja443:10.2",
      "pali": "Pāvako nāma jāyati;"
    },
    {
      "id": "ja443:10.3",
      "pali": "Tameva kaṭṭhaṁ ḍahati,"
    },
    {
      "id": "ja443:10.4",
      "pali": "Yasmā so jāyate gini."
    },
    {
      "id": "ja443:11.1",
      "pali": "Evaṁ mandassa posassa,"
    },
    {
      "id": "ja443:11.2",
      "pali": "bālassa avijānato;"
    },
    {
      "id": "ja443:11.3",
      "pali": "Sārambhā jāyate kodho,"
    },
    {
      "id": "ja443:11.4",
      "pali": "sopi teneva ḍayhati."
    },
    {
      "id": "ja443:12.1",
      "pali": "Aggīva tiṇakaṭṭhasmiṁ,"
    },
    {
      "id": "ja443:12.2",
      "pali": "kodho yassa pavaḍḍhati;"
    },
    {
      "id": "ja443:12.3",
      "pali": "Nihīyati tassa yaso,"
    },
    {
      "id": "ja443:12.4",
      "pali": "kāḷapakkheva candimā."
    },
    {
      "id": "ja443:13.1",
      "pali": "Anedho dhūmaketūva,"
    },
    {
      "id": "ja443:13.2",
      "pali": "kodho yassūpasammati;"
    },
    {
      "id": "ja443:13.3",
      "pali": "Āpūrati tassa yaso,"
    },
    {
      "id": "ja443:13.4",
      "pali": "sukkapakkheva candimā”ti."
    },
    {
      "id": "ja443:14.1",
      "pali": "Cūḷabodhijātakaṁ pañcamaṁ."
    }
  ]
}
