{
  "uid": "ja48",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja48:1.1",
      "pali": "“Anupāyena yo atthaṁ,"
    },
    {
      "id": "ja48:1.2",
      "pali": "Icchati so vihaññati;"
    },
    {
      "id": "ja48:1.3",
      "pali": "Cetā haniṁsu vedabbaṁ,"
    },
    {
      "id": "ja48:1.4",
      "pali": "Sabbe te byasanamajjhagūti."
    },
    {
      "id": "ja48:2.1",
      "pali": "Vedabbajātakaṁ aṭṭhamaṁ."
    }
  ]
}
