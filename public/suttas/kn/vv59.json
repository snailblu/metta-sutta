{
  "uid": "vv59",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv59:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv59:1.2",
      "pali": "Samantato dvādasa yojanāni;"
    },
    {
      "id": "vv59:1.3",
      "pali": "Kūṭāgārā sattasatā uḷārā,"
    },
    {
      "id": "vv59:1.4",
      "pali": "Veḷuriyathambhā rucakatthatā subhā."
    },
    {
      "id": "vv59:2.1",
      "pali": "Tatthacchasi pivasi khādasi ca,"
    },
    {
      "id": "vv59:2.2",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ;"
    },
    {
      "id": "vv59:2.3",
      "pali": "Dibbā rasā kāmaguṇettha pañca,"
    },
    {
      "id": "vv59:2.4",
      "pali": "Nāriyo ca naccanti suvaṇṇachannā."
    },
    {
      "id": "vv59:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv59:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv59:3.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv59:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv59:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv59:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv59:5.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv59:5.2",
      "pali": "Purimajātiyā manussaloke."
    },
    {
      "id": "vv59:6.1",
      "pali": "Addasaṁ virajaṁ bhikkhuṁ,"
    },
    {
      "id": "vv59:6.2",
      "pali": "vippasannamanāvilaṁ;"
    },
    {
      "id": "vv59:6.3",
      "pali": "Tassa adāsahaṁ sūciṁ,"
    },
    {
      "id": "vv59:6.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "vv59:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv59:7.2",
      "pali": "…pe…"
    },
    {
      "id": "vv59:7.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv59:8.1",
      "pali": "Dutiyasūcivimānaṁ navamaṁ."
    }
  ]
}
