{
  "uid": "ja397",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja397:1.1",
      "pali": "“Yathā cāpo ninnamati,"
    },
    {
      "id": "ja397:1.2",
      "pali": "jiyā cāpi nikūjati;"
    },
    {
      "id": "ja397:1.3",
      "pali": "Haññate nūna manojo,"
    },
    {
      "id": "ja397:1.4",
      "pali": "migarājā sakhā mama."
    },
    {
      "id": "ja397:2.1",
      "pali": "Handa dāni vanantāni,"
    },
    {
      "id": "ja397:2.2",
      "pali": "pakkamāmi yathāsukhaṁ;"
    },
    {
      "id": "ja397:2.3",
      "pali": "Netādisā sakhā honti,"
    },
    {
      "id": "ja397:2.4",
      "pali": "labbhā me jīvato sakhā”."
    },
    {
      "id": "ja397:3.1",
      "pali": "“Na pāpajanasaṁsevī,"
    },
    {
      "id": "ja397:3.2",
      "pali": "accantaṁ sukhamedhati;"
    },
    {
      "id": "ja397:3.3",
      "pali": "Manojaṁ passa semānaṁ,"
    },
    {
      "id": "ja397:3.4",
      "pali": "giriyassānusāsanī”."
    },
    {
      "id": "ja397:4.1",
      "pali": "“Na pāpasampavaṅkena,"
    },
    {
      "id": "ja397:4.2",
      "pali": "mātā puttena nandati;"
    },
    {
      "id": "ja397:4.3",
      "pali": "Manojaṁ passa semānaṁ,"
    },
    {
      "id": "ja397:4.4",
      "pali": "acchannaṁ samhi lohite”."
    },
    {
      "id": "ja397:5.1",
      "pali": "“Evamāpajjate poso,"
    },
    {
      "id": "ja397:5.2",
      "pali": "pāpiyo ca nigacchati;"
    },
    {
      "id": "ja397:5.3",
      "pali": "Yo ve hitānaṁ vacanaṁ,"
    },
    {
      "id": "ja397:5.4",
      "pali": "na karoti atthadassinaṁ”."
    },
    {
      "id": "ja397:6.1",
      "pali": "“Evañca so hoti tato ca pāpiyo,"
    },
    {
      "id": "ja397:6.2",
      "pali": "Yo uttamo adhamajanūpasevī;"
    },
    {
      "id": "ja397:6.3",
      "pali": "Passuttamaṁ adhamajanūpasevitaṁ,"
    },
    {
      "id": "ja397:6.4",
      "pali": "Migādhipaṁ saravaraveganiddhutaṁ”."
    },
    {
      "id": "ja397:7.1",
      "pali": "“Nihīyati puriso nihīnasevī,"
    },
    {
      "id": "ja397:7.2",
      "pali": "Na ca hāyetha kadāci tulyasevī;"
    },
    {
      "id": "ja397:7.3",
      "pali": "Seṭṭhamupagamaṁ udeti khippaṁ,"
    },
    {
      "id": "ja397:7.4",
      "pali": "Tasmāttanā uttaritaraṁ bhajethā”ti."
    },
    {
      "id": "ja397:8.1",
      "pali": "Manojajātakaṁ dutiyaṁ."
    }
  ]
}
