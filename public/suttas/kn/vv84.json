{
  "uid": "vv84",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv84:1.1",
      "pali": "“Suṇotha yakkhassa ca vāṇijāna ca,"
    },
    {
      "id": "vv84:1.2",
      "pali": "Samāgamo yattha tadā ahosi;"
    },
    {
      "id": "vv84:1.3",
      "pali": "Yathā kathaṁ itaritarena cāpi,"
    },
    {
      "id": "vv84:1.4",
      "pali": "Subhāsitaṁ tañca suṇātha sabbe."
    },
    {
      "id": "vv84:2.1",
      "pali": "Yo so ahu rājā pāyāsi nāma,"
    },
    {
      "id": "vv84:2.2",
      "pali": "Bhummānaṁ sahabyagato yasassī;"
    },
    {
      "id": "vv84:2.3",
      "pali": "So modamānova sake vimāne,"
    },
    {
      "id": "vv84:2.4",
      "pali": "Amānuso mānuse ajjhabhāsī”ti."
    },
    {
      "id": "vv84:3.1",
      "pali": "“Vaṅke araññe amanussaṭṭhāne,"
    },
    {
      "id": "vv84:3.2",
      "pali": "Kantāre appodake appabhakkhe;"
    },
    {
      "id": "vv84:3.3",
      "pali": "Suduggame vaṇṇupathassa majjhe,"
    },
    {
      "id": "vv84:3.4",
      "pali": "Vaṅkaṁ bhayā naṭṭhamanā manussā."
    },
    {
      "id": "vv84:4.1",
      "pali": "Nayidha phalā mūlamayā ca santi,"
    },
    {
      "id": "vv84:4.2",
      "pali": "Upādānaṁ natthi kutodha bhakkho;"
    },
    {
      "id": "vv84:4.3",
      "pali": "Aññatra paṁsūhi ca vālukāhi ca,"
    },
    {
      "id": "vv84:4.4",
      "pali": "Tatāhi uṇhāhi ca dāruṇāhi ca."
    },
    {
      "id": "vv84:5.1",
      "pali": "Ujjaṅgalaṁ tattamivaṁ kapālaṁ,"
    },
    {
      "id": "vv84:5.2",
      "pali": "Anāyasaṁ paralokena tulyaṁ;"
    },
    {
      "id": "vv84:5.3",
      "pali": "Luddānamāvāsamidaṁ purāṇaṁ,"
    },
    {
      "id": "vv84:5.4",
      "pali": "Bhūmippadeso abhisattarūpo."
    },
    {
      "id": "vv84:6.1",
      "pali": "Atha tumhe kena vaṇṇena,"
    },
    {
      "id": "vv84:6.2",
      "pali": "Kimāsamānā imaṁ padesaṁ hi;"
    },
    {
      "id": "vv84:6.3",
      "pali": "Anupaviṭṭhā sahasā samecca,"
    },
    {
      "id": "vv84:6.4",
      "pali": "Lobhā bhayā atha vā sampamūḷhā”ti."
    },
    {
      "id": "vv84:7.1",
      "pali": "“Magadhesu aṅgesu ca satthavāhā,"
    },
    {
      "id": "vv84:7.2",
      "pali": "Āropayitvā paṇiyaṁ puthuttaṁ;"
    },
    {
      "id": "vv84:7.3",
      "pali": "Te yāmase sindhusovīrabhūmiṁ,"
    },
    {
      "id": "vv84:7.4",
      "pali": "Dhanatthikā uddayaṁ patthayānā."
    },
    {
      "id": "vv84:8.1",
      "pali": "Divā pipāsaṁ nadhivāsayantā,"
    },
    {
      "id": "vv84:8.2",
      "pali": "Yoggānukampañca samekkhamānā;"
    },
    {
      "id": "vv84:8.3",
      "pali": "Etena vegena āyāma sabbe,"
    },
    {
      "id": "vv84:8.4",
      "pali": "Rattiṁ maggaṁ paṭipannā vikāle."
    },
    {
      "id": "vv84:9.1",
      "pali": "Te duppayātā aparaddhamaggā,"
    },
    {
      "id": "vv84:9.2",
      "pali": "Andhākulā vippanaṭṭhā araññe;"
    },
    {
      "id": "vv84:9.3",
      "pali": "Suduggame vaṇṇupathassa majjhe,"
    },
    {
      "id": "vv84:9.4",
      "pali": "Disaṁ na jānāma pamūḷhacittā."
    },
    {
      "id": "vv84:10.1",
      "pali": "Idañca disvāna adiṭṭhapubbaṁ,"
    },
    {
      "id": "vv84:10.2",
      "pali": "Vimānaseṭṭhañca tavañca yakkha;"
    },
    {
      "id": "vv84:10.3",
      "pali": "Tatuttariṁ jīvitamāsamānā,"
    },
    {
      "id": "vv84:10.4",
      "pali": "Disvā patītā sumanā udaggā”ti."
    },
    {
      "id": "vv84:11.1",
      "pali": "“Pāraṁ samuddassa imañca vaṇṇuṁ,"
    },
    {
      "id": "vv84:11.2",
      "pali": "Vettācaraṁ saṅkupathañca maggaṁ;"
    },
    {
      "id": "vv84:11.3",
      "pali": "Nadiyo pana pabbatānañca duggā,"
    },
    {
      "id": "vv84:11.4",
      "pali": "Puthuddisā gacchatha bhogahetu."
    },
    {
      "id": "vv84:12.1",
      "pali": "Pakkhandiyāna vijitaṁ paresaṁ,"
    },
    {
      "id": "vv84:12.2",
      "pali": "Verajjake mānuse pekkhamānā;"
    },
    {
      "id": "vv84:12.3",
      "pali": "Yaṁ vo sutaṁ vā atha vāpi diṭṭhaṁ,"
    },
    {
      "id": "vv84:12.4",
      "pali": "Accherakaṁ taṁ vo suṇoma tātā”ti."
    },
    {
      "id": "vv84:13.1",
      "pali": "“Itopi accherataraṁ kumāra,"
    },
    {
      "id": "vv84:13.2",
      "pali": "Na no sutaṁ vā atha vāpi diṭṭhaṁ;"
    },
    {
      "id": "vv84:13.3",
      "pali": "Atītamānussakameva sabbaṁ,"
    },
    {
      "id": "vv84:13.4",
      "pali": "Disvā na tappāma anomavaṇṇaṁ."
    },
    {
      "id": "vv84:14.1",
      "pali": "Vehāyasaṁ pokkharañño savanti,"
    },
    {
      "id": "vv84:14.2",
      "pali": "Pahūtamalyā bahupuṇḍarīkā;"
    },
    {
      "id": "vv84:14.3",
      "pali": "Dumā cime niccaphalūpapannā,"
    },
    {
      "id": "vv84:14.4",
      "pali": "Atīva gandhā surabhiṁ pavāyanti."
    },
    {
      "id": "vv84:15.1",
      "pali": "Veḷūriyathambhā satamussitāse,"
    },
    {
      "id": "vv84:15.2",
      "pali": "Silāpavāḷassa ca āyataṁsā;"
    },
    {
      "id": "vv84:15.3",
      "pali": "Masāragallā sahalohitaṅgā,"
    },
    {
      "id": "vv84:15.4",
      "pali": "Thambhā ime jotirasāmayāse."
    },
    {
      "id": "vv84:16.1",
      "pali": "Sahassathambhaṁ atulānubhāvaṁ,"
    },
    {
      "id": "vv84:16.2",
      "pali": "Tesūpari sādhumidaṁ vimānaṁ;"
    },
    {
      "id": "vv84:16.3",
      "pali": "Ratanantaraṁ kañcanavedimissaṁ,"
    },
    {
      "id": "vv84:16.4",
      "pali": "Tapanīyapaṭṭehi ca sādhuchannaṁ."
    },
    {
      "id": "vv84:17.1",
      "pali": "Jambonaduttattamidaṁ sumaṭṭho,"
    },
    {
      "id": "vv84:17.2",
      "pali": "Pāsādasopānaphalūpapanno;"
    },
    {
      "id": "vv84:17.3",
      "pali": "Daḷho ca vaggu ca susaṅgato ca,"
    },
    {
      "id": "vv84:17.4",
      "pali": "Atīva nijjhānakhamo manuñño."
    },
    {
      "id": "vv84:18.1",
      "pali": "Ratanantarasmiṁ bahuannapānaṁ,"
    },
    {
      "id": "vv84:18.2",
      "pali": "Parivārito accharāsaṅgaṇena;"
    },
    {
      "id": "vv84:18.3",
      "pali": "Murajaālambaratūriyaghuṭṭho,"
    },
    {
      "id": "vv84:18.4",
      "pali": "Abhivanditosi thutivandanāya."
    },
    {
      "id": "vv84:19.1",
      "pali": "So modasi nārigaṇappabodhano,"
    },
    {
      "id": "vv84:19.2",
      "pali": "Vimānapāsādavare manorame;"
    },
    {
      "id": "vv84:19.3",
      "pali": "Acintiyo sabbaguṇūpapanno,"
    },
    {
      "id": "vv84:19.4",
      "pali": "Rājā yathā vessavaṇo naḷinyā."
    },
    {
      "id": "vv84:20.1",
      "pali": "Devo nu āsi udavāsi yakkho,"
    },
    {
      "id": "vv84:20.2",
      "pali": "Udāhu devindo manussabhūto;"
    },
    {
      "id": "vv84:20.3",
      "pali": "Pucchanti taṁ vāṇijā satthavāhā,"
    },
    {
      "id": "vv84:20.4",
      "pali": "Ācikkha ko nāma tuvaṁsi yakkho”ti."
    },
    {
      "id": "vv84:21.1",
      "pali": "“Serīsako nāma ahamhi yakkho,"
    },
    {
      "id": "vv84:21.2",
      "pali": "Kantāriyo vaṇṇupathamhi gutto;"
    },
    {
      "id": "vv84:21.3",
      "pali": "Imaṁ padesaṁ abhipālayāmi,"
    },
    {
      "id": "vv84:21.4",
      "pali": "Vacanakaro vessavaṇassa rañño”ti."
    },
    {
      "id": "vv84:22.1",
      "pali": "“Adhiccaladdhaṁ pariṇāmajaṁ te,"
    },
    {
      "id": "vv84:22.2",
      "pali": "Sayaṅkataṁ udāhu devehi dinnaṁ;"
    },
    {
      "id": "vv84:22.3",
      "pali": "Pucchanti taṁ vāṇijā satthavāhā,"
    },
    {
      "id": "vv84:22.4",
      "pali": "Kathaṁ tayā laddhamidaṁ manuññan”ti."
    },
    {
      "id": "vv84:23.1",
      "pali": "“Nādhiccaladdhaṁ na pariṇāmajaṁ me,"
    },
    {
      "id": "vv84:23.2",
      "pali": "Na sayaṅkataṁ na hi devehi dinnaṁ;"
    },
    {
      "id": "vv84:23.3",
      "pali": "Sakehi kammehi apāpakehi,"
    },
    {
      "id": "vv84:23.4",
      "pali": "Puññehi me laddhamidaṁ manuññan”ti."
    },
    {
      "id": "vv84:24.1",
      "pali": "“Kiṁ te vataṁ kiṁ pana brahmacariyaṁ,"
    },
    {
      "id": "vv84:24.2",
      "pali": "Kissa suciṇṇassa ayaṁ vipāko;"
    },
    {
      "id": "vv84:24.3",
      "pali": "Pucchanti taṁ vāṇijā satthavāhā,"
    },
    {
      "id": "vv84:24.4",
      "pali": "Kathaṁ tayā laddhamidaṁ vimānan”ti."
    },
    {
      "id": "vv84:25.1",
      "pali": "“Mamaṁ pāyāsīti ahu samaññā,"
    },
    {
      "id": "vv84:25.2",
      "pali": "Rajjaṁ yadā kārayiṁ kosalānaṁ;"
    },
    {
      "id": "vv84:25.3",
      "pali": "Natthikadiṭṭhi kadariyo pāpadhammo,"
    },
    {
      "id": "vv84:25.4",
      "pali": "Ucchedavādī ca tadā ahosiṁ."
    },
    {
      "id": "vv84:26.1",
      "pali": "Samaṇo ca kho āsi kumārakassapo,"
    },
    {
      "id": "vv84:26.2",
      "pali": "Bahussuto cittakathī uḷāro;"
    },
    {
      "id": "vv84:26.3",
      "pali": "So me tadā dhammakathaṁ abhāsi,"
    },
    {
      "id": "vv84:26.4",
      "pali": "Diṭṭhivisūkāni vinodayī me."
    },
    {
      "id": "vv84:27.1",
      "pali": "Tāhaṁ tassa dhammakathaṁ suṇitvā,"
    },
    {
      "id": "vv84:27.2",
      "pali": "Upāsakattaṁ paṭivedayissaṁ;"
    },
    {
      "id": "vv84:27.3",
      "pali": "Pāṇātipātā virato ahosiṁ,"
    },
    {
      "id": "vv84:27.4",
      "pali": "Loke adinnaṁ parivajjayissaṁ;"
    },
    {
      "id": "vv84:27.5",
      "pali": "Amajjapo no ca musā abhāṇiṁ,"
    },
    {
      "id": "vv84:27.6",
      "pali": "Sakena dārena ca ahosi tuṭṭho."
    },
    {
      "id": "vv84:28.1",
      "pali": "Taṁ me vataṁ taṁ pana brahmacariyaṁ,"
    },
    {
      "id": "vv84:28.2",
      "pali": "Tassa suciṇṇassa ayaṁ vipāko;"
    },
    {
      "id": "vv84:28.3",
      "pali": "Teheva kammehi apāpakehi,"
    },
    {
      "id": "vv84:28.4",
      "pali": "Puññehi me laddhamidaṁ vimānan”ti."
    },
    {
      "id": "vv84:29.1",
      "pali": "“Saccaṁ kirāhaṁsu narā sapaññā,"
    },
    {
      "id": "vv84:29.2",
      "pali": "Anaññathā vacanaṁ paṇḍitānaṁ;"
    },
    {
      "id": "vv84:29.3",
      "pali": "Yahiṁ yahiṁ gacchati puññakammo,"
    },
    {
      "id": "vv84:29.4",
      "pali": "Tahiṁ tahiṁ modati kāmakāmī."
    },
    {
      "id": "vv84:30.1",
      "pali": "Yahiṁ yahiṁ sokapariddavo ca,"
    },
    {
      "id": "vv84:30.2",
      "pali": "Vadho ca bandho ca parikkileso;"
    },
    {
      "id": "vv84:30.3",
      "pali": "Tahiṁ tahiṁ gacchati pāpakammo,"
    },
    {
      "id": "vv84:30.4",
      "pali": "Na muccati duggatiyā kadācīti."
    },
    {
      "id": "vv84:31.1",
      "pali": "Sammūḷharūpova jano ahosi,"
    },
    {
      "id": "vv84:31.2",
      "pali": "Asmiṁ muhutte kalalīkatova;"
    },
    {
      "id": "vv84:31.3",
      "pali": "Janassimassa tuyhañca kumāra,"
    },
    {
      "id": "vv84:31.4",
      "pali": "Appaccayo kena nu kho ahosī”ti."
    },
    {
      "id": "vv84:32.1",
      "pali": "“Ime ca sirīsavanā tātā,"
    },
    {
      "id": "vv84:32.2",
      "pali": "Dibbā gandhā surabhī sampavanti;"
    },
    {
      "id": "vv84:32.3",
      "pali": "Te sampavāyanti imaṁ vimānaṁ,"
    },
    {
      "id": "vv84:32.4",
      "pali": "Divā ca ratto ca tamaṁ nihantvā."
    },
    {
      "id": "vv84:33.1",
      "pali": "Imesañca kho vassasataccayena,"
    },
    {
      "id": "vv84:33.2",
      "pali": "Sipāṭikā phalati ekamekā;"
    },
    {
      "id": "vv84:33.3",
      "pali": "Mānussakaṁ vassasataṁ atītaṁ,"
    },
    {
      "id": "vv84:33.4",
      "pali": "Yadagge kāyamhi idhūpapanno."
    },
    {
      "id": "vv84:34.1",
      "pali": "Disvānahaṁ vassasatāni pañca,"
    },
    {
      "id": "vv84:34.2",
      "pali": "Asmiṁ vimāne ṭhatvāna tātā;"
    },
    {
      "id": "vv84:34.3",
      "pali": "Āyukkhayā puññakkhayā cavissaṁ,"
    },
    {
      "id": "vv84:34.4",
      "pali": "Teneva sokena pamucchitosmī”ti."
    },
    {
      "id": "vv84:35.1",
      "pali": "“Kathaṁ nu soceyya tathāvidho so,"
    },
    {
      "id": "vv84:35.2",
      "pali": "Laddhā vimānaṁ atulaṁ cirāya;"
    },
    {
      "id": "vv84:35.3",
      "pali": "Ye cāpi kho ittaramupapannā,"
    },
    {
      "id": "vv84:35.4",
      "pali": "Te nūna soceyyuṁ parittapuññā”ti."
    },
    {
      "id": "vv84:36.1",
      "pali": "“Anucchaviṁ ovadiyañca me taṁ,"
    },
    {
      "id": "vv84:36.2",
      "pali": "Yaṁ maṁ tumhe peyyavācaṁ vadetha;"
    },
    {
      "id": "vv84:36.3",
      "pali": "Tumhe ca kho tātā mayānuguttā,"
    },
    {
      "id": "vv84:36.4",
      "pali": "Yenicchakaṁ tena paletha sotthin”ti."
    },
    {
      "id": "vv84:37.1",
      "pali": "“Gantvā mayaṁ sindhusovīrabhūmiṁ,"
    },
    {
      "id": "vv84:37.2",
      "pali": "Dhanatthikā uddayaṁ patthayānā;"
    },
    {
      "id": "vv84:37.3",
      "pali": "Yathāpayogā paripuṇṇacāgā,"
    },
    {
      "id": "vv84:37.4",
      "pali": "Kāhāma serīsamahaṁ uḷāran”ti."
    },
    {
      "id": "vv84:38.1",
      "pali": "“Mā ceva serīsamahaṁ akattha,"
    },
    {
      "id": "vv84:38.2",
      "pali": "Sabbañca vo bhavissati yaṁ vadetha;"
    },
    {
      "id": "vv84:38.3",
      "pali": "Pāpāni kammāni vivajjayātha,"
    },
    {
      "id": "vv84:38.4",
      "pali": "Dhammānuyogañca adhiṭṭhahātha."
    },
    {
      "id": "vv84:39.1",
      "pali": "Upāsako atthi imamhi saṅghe,"
    },
    {
      "id": "vv84:39.2",
      "pali": "Bahussuto sīlavatūpapanno;"
    },
    {
      "id": "vv84:39.3",
      "pali": "Saddho ca cāgī ca supesalo ca,"
    },
    {
      "id": "vv84:39.4",
      "pali": "Vicakkhaṇo santusito mutīmā."
    },
    {
      "id": "vv84:40.1",
      "pali": "Sañjānamāno na musā bhaṇeyya,"
    },
    {
      "id": "vv84:40.2",
      "pali": "Parūpaghātāya na cetayeyya;"
    },
    {
      "id": "vv84:40.3",
      "pali": "Vebhūtikaṁ pesuṇaṁ no kareyya,"
    },
    {
      "id": "vv84:40.4",
      "pali": "Saṇhañca vācaṁ sakhilaṁ bhaṇeyya."
    },
    {
      "id": "vv84:41.1",
      "pali": "Sagāravo sappatisso vinīto,"
    },
    {
      "id": "vv84:41.2",
      "pali": "Apāpako adhisīle visuddho;"
    },
    {
      "id": "vv84:41.3",
      "pali": "So mātaraṁ pitarañcāpi jantu,"
    },
    {
      "id": "vv84:41.4",
      "pali": "Dhammena poseti ariyavutti."
    },
    {
      "id": "vv84:42.1",
      "pali": "Maññe so mātāpitūnaṁ kāraṇā,"
    },
    {
      "id": "vv84:42.2",
      "pali": "Bhogāni pariyesati na attahetu;"
    },
    {
      "id": "vv84:42.3",
      "pali": "Mātāpitūnañca yo accayena,"
    },
    {
      "id": "vv84:42.4",
      "pali": "Nekkhammapoṇo carissati brahmacariyaṁ."
    },
    {
      "id": "vv84:43.1",
      "pali": "Ujū avaṅko asaṭho amāyo,"
    },
    {
      "id": "vv84:43.2",
      "pali": "Na lesakappena ca vohareyya;"
    },
    {
      "id": "vv84:43.3",
      "pali": "So tādiso sukatakammakārī,"
    },
    {
      "id": "vv84:43.4",
      "pali": "Dhamme ṭhito kinti labhetha dukkhaṁ."
    },
    {
      "id": "vv84:44.1",
      "pali": "Taṁ kāraṇā pātukatomhi attanā,"
    },
    {
      "id": "vv84:44.2",
      "pali": "Tasmā dhammaṁ passatha vāṇijāse;"
    },
    {
      "id": "vv84:44.3",
      "pali": "Aññatra teniha bhasmī bhavetha,"
    },
    {
      "id": "vv84:44.4",
      "pali": "Andhākulā vippanaṭṭhā araññe;"
    },
    {
      "id": "vv84:44.5",
      "pali": "Taṁ khippamānena lahuṁ parena,"
    },
    {
      "id": "vv84:44.6",
      "pali": "Sukho have sappurisena saṅgamo”ti."
    },
    {
      "id": "vv84:45.1",
      "pali": "“Kiṁ nāma so kiñca karoti kammaṁ,"
    },
    {
      "id": "vv84:45.2",
      "pali": "Kiṁ nāmadheyyaṁ kiṁ pana tassa gottaṁ;"
    },
    {
      "id": "vv84:45.3",
      "pali": "Mayampi naṁ daṭṭhukāmamha yakkha,"
    },
    {
      "id": "vv84:45.4",
      "pali": "Yassānukampāya idhāgatosi;"
    },
    {
      "id": "vv84:45.5",
      "pali": "Lābhā hi tassa yassa tuvaṁ pihesī”ti."
    },
    {
      "id": "vv84:46.1",
      "pali": "“Yo kappako sambhavanāmadheyyo,"
    },
    {
      "id": "vv84:46.2",
      "pali": "Upāsako kocchaphalūpajīvī;"
    },
    {
      "id": "vv84:46.3",
      "pali": "Jānātha naṁ tumhākaṁ pesiyo so,"
    },
    {
      "id": "vv84:46.4",
      "pali": "Mā kho naṁ hīḷittha supesalo so”ti."
    },
    {
      "id": "vv84:47.1",
      "pali": "“Jānāmase yaṁ tvaṁ pavadesi yakkha,"
    },
    {
      "id": "vv84:47.2",
      "pali": "Na kho naṁ jānāma sa edisoti;"
    },
    {
      "id": "vv84:47.3",
      "pali": "Mayampi naṁ pūjayissāma yakkha,"
    },
    {
      "id": "vv84:47.4",
      "pali": "Sutvāna tuyhaṁ vacanaṁ uḷāran”ti."
    },
    {
      "id": "vv84:48.1",
      "pali": "“Ye keci imasmiṁ satthe manussā,"
    },
    {
      "id": "vv84:48.2",
      "pali": "Daharā mahantā athavāpi majjhimā;"
    },
    {
      "id": "vv84:48.3",
      "pali": "Sabbeva te ālambantu vimānaṁ,"
    },
    {
      "id": "vv84:48.4",
      "pali": "Passantu puññānaṁ phalaṁ kadariyā”ti."
    },
    {
      "id": "vv84:49.1",
      "pali": "Te tattha sabbeva “ahaṁ pure”ti,"
    },
    {
      "id": "vv84:49.2",
      "pali": "Taṁ kappakaṁ tattha purakkhatvā;"
    },
    {
      "id": "vv84:49.3",
      "pali": "Sabbeva te ālambiṁsu vimānaṁ,"
    },
    {
      "id": "vv84:49.4",
      "pali": "Masakkasāraṁ viya vāsavassa."
    },
    {
      "id": "vv84:50.1",
      "pali": "Te tattha sabbeva “ahaṁ pure”ti,"
    },
    {
      "id": "vv84:50.2",
      "pali": "Upāsakattaṁ paṭivedayiṁsu;"
    },
    {
      "id": "vv84:50.3",
      "pali": "Pāṇātipātā viratā ahesuṁ,"
    },
    {
      "id": "vv84:50.4",
      "pali": "Loke adinnaṁ parivajjayiṁsu;"
    },
    {
      "id": "vv84:50.5",
      "pali": "Amajjapā no ca musā bhaṇiṁsu,"
    },
    {
      "id": "vv84:50.6",
      "pali": "Sakena dārena ca ahesuṁ tuṭṭhā."
    },
    {
      "id": "vv84:51.1",
      "pali": "Te tattha sabbeva “ahaṁ pure”ti,"
    },
    {
      "id": "vv84:51.2",
      "pali": "Upāsakattaṁ paṭivedayitvā;"
    },
    {
      "id": "vv84:51.3",
      "pali": "Pakkāmi sattho anumodamāno,"
    },
    {
      "id": "vv84:51.4",
      "pali": "Yakkhiddhiyā anumato punappunaṁ."
    },
    {
      "id": "vv84:52.1",
      "pali": "Gantvāna te sindhusovīrabhūmiṁ,"
    },
    {
      "id": "vv84:52.2",
      "pali": "Dhanatthikā uddayaṁ patthayānā;"
    },
    {
      "id": "vv84:52.3",
      "pali": "Yathāpayogā paripuṇṇalābhā,"
    },
    {
      "id": "vv84:52.4",
      "pali": "Paccāgamuṁ pāṭaliputtamakkhataṁ."
    },
    {
      "id": "vv84:53.1",
      "pali": "Gantvāna te saṅgharaṁ sotthivanto,"
    },
    {
      "id": "vv84:53.2",
      "pali": "Puttehi dārehi samaṅgibhūtā;"
    },
    {
      "id": "vv84:53.3",
      "pali": "Ānandī vittā sumanā patītā,"
    },
    {
      "id": "vv84:53.4",
      "pali": "Akaṁsu serīsamahaṁ uḷāraṁ;"
    },
    {
      "id": "vv84:53.5",
      "pali": "Serīsakaṁ te pariveṇaṁ māpayiṁsu."
    },
    {
      "id": "vv84:54.1",
      "pali": "Etādisā sappurisāna sevanā,"
    },
    {
      "id": "vv84:54.2",
      "pali": "Mahatthikā dhammaguṇāna sevanā;"
    },
    {
      "id": "vv84:54.3",
      "pali": "Ekassa atthāya upāsakassa,"
    },
    {
      "id": "vv84:54.4",
      "pali": "Sabbeva sattā sukhitā ahesunti."
    },
    {
      "id": "vv84:55.1",
      "pali": "Serīsakavimānaṁ dasamaṁ."
    }
  ]
}
