{
  "uid": "tha-ap491",
  "title": "9 Dhammaruciyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap491:1.1",
      "pali": "“Yadā dīpaṅkaro buddho,"
    },
    {
      "id": "tha-ap491:1.2",
      "pali": "sumedhaṁ byākarī jino;"
    },
    {
      "id": "tha-ap491:1.3",
      "pali": "‘Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap491:1.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "tha-ap491:2.1",
      "pali": "Imassa janikā mātā,"
    },
    {
      "id": "tha-ap491:2.2",
      "pali": "māyā nāma bhavissati;"
    },
    {
      "id": "tha-ap491:2.3",
      "pali": "Pitā suddhodano nāma,"
    },
    {
      "id": "tha-ap491:2.4",
      "pali": "ayaṁ hessati gotamo."
    },
    {
      "id": "tha-ap491:3.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "tha-ap491:3.2",
      "pali": "katvā dukkarakārikaṁ;"
    },
    {
      "id": "tha-ap491:3.3",
      "pali": "Assatthamūle sambuddho,"
    },
    {
      "id": "tha-ap491:3.4",
      "pali": "bujjhissati mahāyaso."
    },
    {
      "id": "tha-ap491:4.1",
      "pali": "Upatisso kolito ca,"
    },
    {
      "id": "tha-ap491:4.2",
      "pali": "aggā hessanti sāvakā;"
    },
    {
      "id": "tha-ap491:4.3",
      "pali": "Ānando nāma nāmena,"
    },
    {
      "id": "tha-ap491:4.4",
      "pali": "upaṭṭhissatimaṁ jinaṁ."
    },
    {
      "id": "tha-ap491:5.1",
      "pali": "Khemā uppalavaṇṇā ca,"
    },
    {
      "id": "tha-ap491:5.2",
      "pali": "aggā hessanti sāvikā;"
    },
    {
      "id": "tha-ap491:5.3",
      "pali": "Citto āḷavako ceva,"
    },
    {
      "id": "tha-ap491:5.4",
      "pali": "aggā hessantupāsakā."
    },
    {
      "id": "tha-ap491:6.1",
      "pali": "Khujjuttarā nandamātā,"
    },
    {
      "id": "tha-ap491:6.2",
      "pali": "aggā hessantupāsikā;"
    },
    {
      "id": "tha-ap491:6.3",
      "pali": "Bodhi imassa vīrassa,"
    },
    {
      "id": "tha-ap491:6.4",
      "pali": "assatthoti pavuccati’."
    },
    {
      "id": "tha-ap491:7.1",
      "pali": "Idaṁ sutvāna vacanaṁ,"
    },
    {
      "id": "tha-ap491:7.2",
      "pali": "asamassa mahesino;"
    },
    {
      "id": "tha-ap491:7.3",
      "pali": "Āmoditā naramarū,"
    },
    {
      "id": "tha-ap491:7.4",
      "pali": "namassanti katañjalī."
    },
    {
      "id": "tha-ap491:8.1",
      "pali": "Tadāhaṁ māṇavo āsiṁ,"
    },
    {
      "id": "tha-ap491:8.2",
      "pali": "megho nāma susikkhito;"
    },
    {
      "id": "tha-ap491:8.3",
      "pali": "Sutvā byākaraṇaṁ seṭṭhaṁ,"
    },
    {
      "id": "tha-ap491:8.4",
      "pali": "sumedhassa mahāmune."
    },
    {
      "id": "tha-ap491:9.1",
      "pali": "Saṁvisaṭṭho bhavitvāna,"
    },
    {
      "id": "tha-ap491:9.2",
      "pali": "sumedhe karuṇāsaye;"
    },
    {
      "id": "tha-ap491:9.3",
      "pali": "Pabbajantañca taṁ vīraṁ,"
    },
    {
      "id": "tha-ap491:9.4",
      "pali": "sahāva anupabbajiṁ."
    },
    {
      "id": "tha-ap491:10.1",
      "pali": "Saṁvuto pātimokkhasmiṁ,"
    },
    {
      "id": "tha-ap491:10.2",
      "pali": "indriyesu ca pañcasu;"
    },
    {
      "id": "tha-ap491:10.3",
      "pali": "Suddhājīvo sato vīro,"
    },
    {
      "id": "tha-ap491:10.4",
      "pali": "jinasāsanakārako."
    },
    {
      "id": "tha-ap491:11.1",
      "pali": "Evaṁ viharamānohaṁ,"
    },
    {
      "id": "tha-ap491:11.2",
      "pali": "pāpamittena kenaci;"
    },
    {
      "id": "tha-ap491:11.3",
      "pali": "Niyojito anācāre,"
    },
    {
      "id": "tha-ap491:11.4",
      "pali": "sumaggā paridhaṁsito."
    },
    {
      "id": "tha-ap491:12.1",
      "pali": "Vitakkavasiko hutvā,"
    },
    {
      "id": "tha-ap491:12.2",
      "pali": "sāsanato apakkamiṁ;"
    },
    {
      "id": "tha-ap491:12.3",
      "pali": "Pacchā tena kumittena,"
    },
    {
      "id": "tha-ap491:12.4",
      "pali": "payutto mātughātanaṁ."
    },
    {
      "id": "tha-ap491:13.1",
      "pali": "Akariṁ ānantariyaṁ,"
    },
    {
      "id": "tha-ap491:13.2",
      "pali": "ghātayiṁ duṭṭhamānaso;"
    },
    {
      "id": "tha-ap491:13.3",
      "pali": "Tato cuto mahāvīciṁ,"
    },
    {
      "id": "tha-ap491:13.4",
      "pali": "upapanno sudāruṇaṁ."
    },
    {
      "id": "tha-ap491:14.1",
      "pali": "Vinipātagato santo,"
    },
    {
      "id": "tha-ap491:14.2",
      "pali": "saṁsariṁ dukkhito ciraṁ;"
    },
    {
      "id": "tha-ap491:14.3",
      "pali": "Na puno addasaṁ vīraṁ,"
    },
    {
      "id": "tha-ap491:14.4",
      "pali": "sumedhaṁ narapuṅgavaṁ."
    },
    {
      "id": "tha-ap491:15.1",
      "pali": "Asmiṁ kappe samuddamhi,"
    },
    {
      "id": "tha-ap491:15.2",
      "pali": "maccho āsiṁ timiṅgalo;"
    },
    {
      "id": "tha-ap491:15.3",
      "pali": "Disvāhaṁ sāgare nāvaṁ,"
    },
    {
      "id": "tha-ap491:15.4",
      "pali": "gocaratthamupāgamiṁ."
    },
    {
      "id": "tha-ap491:16.1",
      "pali": "Disvā maṁ vāṇijā bhītā,"
    },
    {
      "id": "tha-ap491:16.2",
      "pali": "buddhaseṭṭhamanussaruṁ;"
    },
    {
      "id": "tha-ap491:16.3",
      "pali": "Gotamoti mahāghosaṁ,"
    },
    {
      "id": "tha-ap491:16.4",
      "pali": "sutvā tehi udīritaṁ."
    },
    {
      "id": "tha-ap491:17.1",
      "pali": "Pubbasaññaṁ saritvāna,"
    },
    {
      "id": "tha-ap491:17.2",
      "pali": "tato kālaṅkato ahaṁ;"
    },
    {
      "id": "tha-ap491:17.3",
      "pali": "Sāvatthiyaṁ kule iddhe,"
    },
    {
      "id": "tha-ap491:17.4",
      "pali": "jāto brāhmaṇajātiyaṁ."
    },
    {
      "id": "tha-ap491:18.1",
      "pali": "Āsiṁ dhammaruci nāma,"
    },
    {
      "id": "tha-ap491:18.2",
      "pali": "sabbapāpajigucchako;"
    },
    {
      "id": "tha-ap491:18.3",
      "pali": "Disvāhaṁ lokapajjotaṁ,"
    },
    {
      "id": "tha-ap491:18.4",
      "pali": "jātiyā sattavassiko."
    },
    {
      "id": "tha-ap491:19.1",
      "pali": "Mahājetavanaṁ gantvā,"
    },
    {
      "id": "tha-ap491:19.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap491:19.3",
      "pali": "Upemi buddhaṁ tikkhattuṁ,"
    },
    {
      "id": "tha-ap491:19.4",
      "pali": "rattiyā divasassa ca."
    },
    {
      "id": "tha-ap491:20.1",
      "pali": "Tadā disvā muni āha,"
    },
    {
      "id": "tha-ap491:20.2",
      "pali": "ciraṁ dhammarucīti maṁ;"
    },
    {
      "id": "tha-ap491:20.3",
      "pali": "Tatohaṁ avacaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap491:20.4",
      "pali": "pubbakammapabhāvitaṁ."
    },
    {
      "id": "tha-ap491:21.1",
      "pali": "Suciraṁ satapuññalakkhaṇaṁ,"
    },
    {
      "id": "tha-ap491:21.2",
      "pali": "Patipubbena visuddhapaccayaṁ;"
    },
    {
      "id": "tha-ap491:21.3",
      "pali": "Ahamajjasupekkhanaṁ vata,"
    },
    {
      "id": "tha-ap491:21.4",
      "pali": "Tava passāmi nirupamaṁ viggahaṁ."
    },
    {
      "id": "tha-ap491:22.1",
      "pali": "Suciraṁ vihatattamo mayā,"
    },
    {
      "id": "tha-ap491:22.2",
      "pali": "Sucirakkhena nadī visositā;"
    },
    {
      "id": "tha-ap491:22.3",
      "pali": "Suciraṁ amalaṁ visodhitaṁ,"
    },
    {
      "id": "tha-ap491:22.4",
      "pali": "Nayanaṁ ñāṇamayaṁ mahāmune."
    },
    {
      "id": "tha-ap491:23.1",
      "pali": "Cirakālasamaṅgito tayā,"
    },
    {
      "id": "tha-ap491:23.2",
      "pali": "Avinaṭṭho punarantaraṁ ciraṁ;"
    },
    {
      "id": "tha-ap491:23.3",
      "pali": "Punarajjasamāgato tayā,"
    },
    {
      "id": "tha-ap491:23.4",
      "pali": "Na hi nassanti katāni gotama."
    },
    {
      "id": "tha-ap491:24.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap491:24.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap491:24.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap491:25.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap491:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap491:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap491:26.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap491:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap491:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap491:27.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhammaruciyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap491:28.1",
      "pali": "Dhammaruciyattherassāpadānaṁ navamaṁ."
    }
  ]
}
