{
  "uid": "thag1.36",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.36:1.1",
      "pali": "“Sādhu sutaṁ sādhu caritakaṁ,"
    },
    {
      "id": "thag1.36:1.2",
      "pali": "Sādhu sadā aniketavihāro;"
    },
    {
      "id": "thag1.36:1.3",
      "pali": "Atthapucchanaṁ padakkhiṇakammaṁ,"
    },
    {
      "id": "thag1.36:1.4",
      "pali": "Etaṁ sāmaññamakiñcanassā”ti."
    },
    {
      "id": "thag1.36:1.5",
      "pali": "… Kumāputto thero …."
    }
  ]
}
