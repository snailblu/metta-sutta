{
  "uid": "thag5.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.7:1.1",
      "pali": "“Pāto majjhanhikaṁ sāyaṁ,"
    },
    {
      "id": "thag5.7:1.2",
      "pali": "tikkhattuṁ divasassahaṁ;"
    },
    {
      "id": "thag5.7:1.3",
      "pali": "Otariṁ udakaṁ sohaṁ,"
    },
    {
      "id": "thag5.7:1.4",
      "pali": "gayāya gayaphagguyā."
    },
    {
      "id": "thag5.7:2.1",
      "pali": "‘Yaṁ mayā pakataṁ pāpaṁ,"
    },
    {
      "id": "thag5.7:2.2",
      "pali": "pubbe aññāsu jātisu;"
    },
    {
      "id": "thag5.7:2.3",
      "pali": "Taṁ dānīdha pavāhemi’,"
    },
    {
      "id": "thag5.7:2.4",
      "pali": "evaṁdiṭṭhi pure ahuṁ."
    },
    {
      "id": "thag5.7:3.1",
      "pali": "Sutvā subhāsitaṁ vācaṁ,"
    },
    {
      "id": "thag5.7:3.2",
      "pali": "dhammatthasahitaṁ padaṁ;"
    },
    {
      "id": "thag5.7:3.3",
      "pali": "Tathaṁ yāthāvakaṁ atthaṁ,"
    },
    {
      "id": "thag5.7:3.4",
      "pali": "yoniso paccavekkhisaṁ."
    },
    {
      "id": "thag5.7:4.1",
      "pali": "Ninhātasabbapāpomhi,"
    },
    {
      "id": "thag5.7:4.2",
      "pali": "nimmalo payato suci;"
    },
    {
      "id": "thag5.7:4.3",
      "pali": "Suddho suddhassa dāyādo,"
    },
    {
      "id": "thag5.7:4.4",
      "pali": "putto buddhassa oraso."
    },
    {
      "id": "thag5.7:5.1",
      "pali": "Ogayhaṭṭhaṅgikaṁ sotaṁ,"
    },
    {
      "id": "thag5.7:5.2",
      "pali": "sabbapāpaṁ pavāhayiṁ;"
    },
    {
      "id": "thag5.7:5.3",
      "pali": "Tisso vijjā ajjhagamiṁ,"
    },
    {
      "id": "thag5.7:5.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag5.7:5.5",
      "pali": "… Gayākassapo thero …."
    }
  ]
}
