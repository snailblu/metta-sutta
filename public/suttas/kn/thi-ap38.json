{
  "uid": "thi-ap38",
  "title": "8 Puṇṇikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap38:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "thi-ap38:1.2",
      "pali": "sikhino vessabhussa ca;"
    },
    {
      "id": "thi-ap38:1.3",
      "pali": "Kakusandhassa munino,"
    },
    {
      "id": "thi-ap38:1.4",
      "pali": "koṇāgamanatādino."
    },
    {
      "id": "thi-ap38:2.1",
      "pali": "Kassapassa ca buddhassa,"
    },
    {
      "id": "thi-ap38:2.2",
      "pali": "pabbajitvāna sāsane;"
    },
    {
      "id": "thi-ap38:2.3",
      "pali": "Bhikkhunī sīlasampannā,"
    },
    {
      "id": "thi-ap38:2.4",
      "pali": "nipakā saṁvutindriyā."
    },
    {
      "id": "thi-ap38:3.1",
      "pali": "Bahussutā dhammadharā,"
    },
    {
      "id": "thi-ap38:3.2",
      "pali": "dhammatthapaṭipucchikā;"
    },
    {
      "id": "thi-ap38:3.3",
      "pali": "Uggahetā ca dhammānaṁ,"
    },
    {
      "id": "thi-ap38:3.4",
      "pali": "sotā payirupāsitā."
    },
    {
      "id": "thi-ap38:4.1",
      "pali": "Desentī janamajjhehaṁ,"
    },
    {
      "id": "thi-ap38:4.2",
      "pali": "ahosiṁ jinasāsane;"
    },
    {
      "id": "thi-ap38:4.3",
      "pali": "Bāhusaccena tenāhaṁ,"
    },
    {
      "id": "thi-ap38:4.4",
      "pali": "pesalā atimaññisaṁ."
    },
    {
      "id": "thi-ap38:5.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap38:5.2",
      "pali": "sāvatthiyaṁ puruttame;"
    },
    {
      "id": "thi-ap38:5.3",
      "pali": "Anāthapiṇḍino gehe,"
    },
    {
      "id": "thi-ap38:5.4",
      "pali": "jātāhaṁ kumbhadāsiyā."
    },
    {
      "id": "thi-ap38:6.1",
      "pali": "Gatā udakahāriyaṁ,"
    },
    {
      "id": "thi-ap38:6.2",
      "pali": "sotthiyaṁ dijamaddasaṁ;"
    },
    {
      "id": "thi-ap38:6.3",
      "pali": "Sītaṭṭaṁ toyamajjhamhi,"
    },
    {
      "id": "thi-ap38:6.4",
      "pali": "taṁ disvā idamabraviṁ."
    },
    {
      "id": "thi-ap38:7.1",
      "pali": "‘Udahārī ahaṁ sīte,"
    },
    {
      "id": "thi-ap38:7.2",
      "pali": "sadā udakamotariṁ;"
    },
    {
      "id": "thi-ap38:7.3",
      "pali": "Ayyānaṁ daṇḍabhayabhītā,"
    },
    {
      "id": "thi-ap38:7.4",
      "pali": "vācādosabhayaṭṭitā."
    },
    {
      "id": "thi-ap38:8.1",
      "pali": "Kassa brāhmaṇa tvaṁ bhīto,"
    },
    {
      "id": "thi-ap38:8.2",
      "pali": "sadā udakamotari;"
    },
    {
      "id": "thi-ap38:8.3",
      "pali": "Vedhamānehi gattehi,"
    },
    {
      "id": "thi-ap38:8.4",
      "pali": "sītaṁ vedayase bhusaṁ’."
    },
    {
      "id": "thi-ap38:9.1",
      "pali": "‘Jānantī vata maṁ bhoti,"
    },
    {
      "id": "thi-ap38:9.2",
      "pali": "puṇṇike paripucchasi;"
    },
    {
      "id": "thi-ap38:9.3",
      "pali": "Karontaṁ kusalaṁ kammaṁ,"
    },
    {
      "id": "thi-ap38:9.4",
      "pali": "rundhantaṁ katapāpakaṁ."
    },
    {
      "id": "thi-ap38:10.1",
      "pali": "Yo ce vuḍḍho daharo vā,"
    },
    {
      "id": "thi-ap38:10.2",
      "pali": "pāpakammaṁ pakubbati;"
    },
    {
      "id": "thi-ap38:10.3",
      "pali": "Dakābhisiñcanā sopi,"
    },
    {
      "id": "thi-ap38:10.4",
      "pali": "pāpakammā pamuccati’."
    },
    {
      "id": "thi-ap38:11.1",
      "pali": "Uttarantassa akkhāsiṁ,"
    },
    {
      "id": "thi-ap38:11.2",
      "pali": "dhammatthasaṁhitaṁ padaṁ;"
    },
    {
      "id": "thi-ap38:11.3",
      "pali": "Tañca sutvā sa saṁviggo,"
    },
    {
      "id": "thi-ap38:11.4",
      "pali": "pabbajitvārahā ahu."
    },
    {
      "id": "thi-ap38:12.1",
      "pali": "Pūrentī ūnakasataṁ,"
    },
    {
      "id": "thi-ap38:12.2",
      "pali": "jātā dāsikule yato;"
    },
    {
      "id": "thi-ap38:12.3",
      "pali": "Tato puṇṇāti nāmaṁ me,"
    },
    {
      "id": "thi-ap38:12.4",
      "pali": "bhujissaṁ maṁ akaṁsu te."
    },
    {
      "id": "thi-ap38:13.1",
      "pali": "Seṭṭhiṁ tatonujānetvā,"
    },
    {
      "id": "thi-ap38:13.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap38:13.3",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "thi-ap38:13.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap38:14.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap38:14.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap38:14.3",
      "pali": "Cetopariyañāṇassa,"
    },
    {
      "id": "thi-ap38:14.4",
      "pali": "vasī homi mahāmune."
    },
    {
      "id": "thi-ap38:15.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap38:15.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap38:15.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap38:15.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap38:16.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "thi-ap38:16.2",
      "pali": "paṭibhāne tatheva ca;"
    },
    {
      "id": "thi-ap38:16.3",
      "pali": "Ñāṇaṁ me vimalaṁ suddhaṁ,"
    },
    {
      "id": "thi-ap38:16.4",
      "pali": "buddhaseṭṭhassa vāhasā."
    },
    {
      "id": "thi-ap38:17.1",
      "pali": "Bhāvanāya mahāpaññā,"
    },
    {
      "id": "thi-ap38:17.2",
      "pali": "suteneva sutāvinī;"
    },
    {
      "id": "thi-ap38:17.3",
      "pali": "Mānena nīcakulajā,"
    },
    {
      "id": "thi-ap38:17.4",
      "pali": "na hi kammaṁ vinassati."
    },
    {
      "id": "thi-ap38:18.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap38:18.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap38:18.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap38:19.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap38:19.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap38:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap38:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap38:20.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap38:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap38:21.1",
      "pali": "Itthaṁ sudaṁ puṇṇikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap38:22.1",
      "pali": "Puṇṇikātheriyāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
