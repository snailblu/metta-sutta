{
  "uid": "thig13.2",
  "title": "Rohinītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig13.2:1.1",
      "pali": "“‘Samaṇā’ti bhoti supi,"
    },
    {
      "id": "thig13.2:1.2",
      "pali": "‘samaṇā’ti pabujjhasi;"
    },
    {
      "id": "thig13.2:1.3",
      "pali": "Samaṇāneva kittesi,"
    },
    {
      "id": "thig13.2:1.4",
      "pali": "samaṇī nūna bhavissasi."
    },
    {
      "id": "thig13.2:2.1",
      "pali": "Vipulaṁ annañca pānañca,"
    },
    {
      "id": "thig13.2:2.2",
      "pali": "samaṇānaṁ paveccasi;"
    },
    {
      "id": "thig13.2:2.3",
      "pali": "Rohinī dāni pucchāmi,"
    },
    {
      "id": "thig13.2:2.4",
      "pali": "kena te samaṇā piyā."
    },
    {
      "id": "thig13.2:3.1",
      "pali": "Akammakāmā alasā,"
    },
    {
      "id": "thig13.2:3.2",
      "pali": "paradattūpajīvino;"
    },
    {
      "id": "thig13.2:3.3",
      "pali": "Āsaṁsukā sādukāmā,"
    },
    {
      "id": "thig13.2:3.4",
      "pali": "kena te samaṇā piyā”."
    },
    {
      "id": "thig13.2:4.1",
      "pali": "“Cirassaṁ vata maṁ tāta,"
    },
    {
      "id": "thig13.2:4.2",
      "pali": "samaṇānaṁ paripucchasi;"
    },
    {
      "id": "thig13.2:4.3",
      "pali": "Tesaṁ te kittayissāmi,"
    },
    {
      "id": "thig13.2:4.4",
      "pali": "paññāsīlaparakkamaṁ."
    },
    {
      "id": "thig13.2:5.1",
      "pali": "Kammakāmā analasā,"
    },
    {
      "id": "thig13.2:5.2",
      "pali": "kammaseṭṭhassa kārakā;"
    },
    {
      "id": "thig13.2:5.3",
      "pali": "Rāgaṁ dosaṁ pajahanti,"
    },
    {
      "id": "thig13.2:5.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:6.1",
      "pali": "Tīṇi pāpassa mūlāni,"
    },
    {
      "id": "thig13.2:6.2",
      "pali": "dhunanti sucikārino;"
    },
    {
      "id": "thig13.2:6.3",
      "pali": "Sabbaṁ pāpaṁ pahīnesaṁ,"
    },
    {
      "id": "thig13.2:6.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:7.1",
      "pali": "Kāyakammaṁ suci nesaṁ,"
    },
    {
      "id": "thig13.2:7.2",
      "pali": "vacīkammañca tādisaṁ;"
    },
    {
      "id": "thig13.2:7.3",
      "pali": "Manokammaṁ suci nesaṁ,"
    },
    {
      "id": "thig13.2:7.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:8.1",
      "pali": "Vimalā saṅkhamuttāva,"
    },
    {
      "id": "thig13.2:8.2",
      "pali": "suddhā santarabāhirā;"
    },
    {
      "id": "thig13.2:8.3",
      "pali": "Puṇṇā sukkāna dhammānaṁ,"
    },
    {
      "id": "thig13.2:8.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:9.1",
      "pali": "Bahussutā dhammadharā,"
    },
    {
      "id": "thig13.2:9.2",
      "pali": "ariyā dhammajīvino;"
    },
    {
      "id": "thig13.2:9.3",
      "pali": "Atthaṁ dhammañca desenti,"
    },
    {
      "id": "thig13.2:9.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:10.1",
      "pali": "Bahussutā dhammadharā,"
    },
    {
      "id": "thig13.2:10.2",
      "pali": "ariyā dhammajīvino;"
    },
    {
      "id": "thig13.2:10.3",
      "pali": "Ekaggacittā satimanto,"
    },
    {
      "id": "thig13.2:10.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:11.1",
      "pali": "Dūraṅgamā satimanto,"
    },
    {
      "id": "thig13.2:11.2",
      "pali": "mantabhāṇī anuddhatā;"
    },
    {
      "id": "thig13.2:11.3",
      "pali": "Dukkhassantaṁ pajānanti,"
    },
    {
      "id": "thig13.2:11.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:12.1",
      "pali": "Yasmā gāmā pakkamanti,"
    },
    {
      "id": "thig13.2:12.2",
      "pali": "na vilokenti kiñcanaṁ;"
    },
    {
      "id": "thig13.2:12.3",
      "pali": "Anapekkhāva gacchanti,"
    },
    {
      "id": "thig13.2:12.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:13.1",
      "pali": "Na te saṁ koṭṭhe openti,"
    },
    {
      "id": "thig13.2:13.2",
      "pali": "na kumbhiṁ na khaḷopiyaṁ;"
    },
    {
      "id": "thig13.2:13.3",
      "pali": "Pariniṭṭhitamesānā,"
    },
    {
      "id": "thig13.2:13.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:14.1",
      "pali": "Na te hiraññaṁ gaṇhanti,"
    },
    {
      "id": "thig13.2:14.2",
      "pali": "na suvaṇṇaṁ na rūpiyaṁ;"
    },
    {
      "id": "thig13.2:14.3",
      "pali": "Paccuppannena yāpenti,"
    },
    {
      "id": "thig13.2:14.4",
      "pali": "tena me samaṇā piyā."
    },
    {
      "id": "thig13.2:15.1",
      "pali": "Nānākulā pabbajitā,"
    },
    {
      "id": "thig13.2:15.2",
      "pali": "nānājanapadehi ca;"
    },
    {
      "id": "thig13.2:15.3",
      "pali": "Aññamaññaṁ piyāyanti,"
    },
    {
      "id": "thig13.2:15.4",
      "pali": "tena me samaṇā piyā”."
    },
    {
      "id": "thig13.2:16.1",
      "pali": "“Atthāya vata no bhoti,"
    },
    {
      "id": "thig13.2:16.2",
      "pali": "kule jātāsi rohinī;"
    },
    {
      "id": "thig13.2:16.3",
      "pali": "Saddhā buddhe ca dhamme ca,"
    },
    {
      "id": "thig13.2:16.4",
      "pali": "saṅghe ca tibbagāravā."
    },
    {
      "id": "thig13.2:17.1",
      "pali": "Tuvaṁ hetaṁ pajānāsi,"
    },
    {
      "id": "thig13.2:17.2",
      "pali": "puññakkhettaṁ anuttaraṁ;"
    },
    {
      "id": "thig13.2:17.3",
      "pali": "Amhampi ete samaṇā,"
    },
    {
      "id": "thig13.2:17.4",
      "pali": "paṭigaṇhanti dakkhiṇaṁ."
    },
    {
      "id": "thig13.2:18.1",
      "pali": "Patiṭṭhito hettha yañño,"
    },
    {
      "id": "thig13.2:18.2",
      "pali": "vipulo no bhavissati”;"
    },
    {
      "id": "thig13.2:18.3",
      "pali": "“Sace bhāyasi dukkhassa,"
    },
    {
      "id": "thig13.2:18.4",
      "pali": "sace te dukkhamappiyaṁ."
    },
    {
      "id": "thig13.2:19.1",
      "pali": "Upehi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "thig13.2:19.2",
      "pali": "dhammaṁ saṅghañca tādinaṁ;"
    },
    {
      "id": "thig13.2:19.3",
      "pali": "Samādiyāhi sīlāni,"
    },
    {
      "id": "thig13.2:19.4",
      "pali": "taṁ te atthāya hehiti”."
    },
    {
      "id": "thig13.2:20.1",
      "pali": "“Upemi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "thig13.2:20.2",
      "pali": "dhammaṁ saṅghañca tādinaṁ;"
    },
    {
      "id": "thig13.2:20.3",
      "pali": "Samādiyāmi sīlāni,"
    },
    {
      "id": "thig13.2:20.4",
      "pali": "taṁ me atthāya hehiti."
    },
    {
      "id": "thig13.2:21.1",
      "pali": "Brahmabandhu pure āsiṁ,"
    },
    {
      "id": "thig13.2:21.2",
      "pali": "so idānimhi brāhmaṇo;"
    },
    {
      "id": "thig13.2:21.3",
      "pali": "Tevijjo sottiyo camhi,"
    },
    {
      "id": "thig13.2:21.4",
      "pali": "vedagū camhi nhātako”."
    },
    {
      "id": "thig13.2:22.1",
      "pali": "… Rohinī therī …."
    }
  ]
}
