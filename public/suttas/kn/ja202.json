{
  "uid": "ja202",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja202:1.1",
      "pali": "“Haṁsā koñcā mayūrā ca,"
    },
    {
      "id": "ja202:1.2",
      "pali": "hatthayo pasadā migā;"
    },
    {
      "id": "ja202:1.3",
      "pali": "Sabbe sīhassa bhāyanti,"
    },
    {
      "id": "ja202:1.4",
      "pali": "natthi kāyasmi tulyatā."
    },
    {
      "id": "ja202:2.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja202:2.2",
      "pali": "daharo cepi paññavā;"
    },
    {
      "id": "ja202:2.3",
      "pali": "So hi tattha mahā hoti,"
    },
    {
      "id": "ja202:2.4",
      "pali": "neva bālo sarīravā”ti."
    },
    {
      "id": "ja202:3.1",
      "pali": "Keḷisīlajātakaṁ dutiyaṁ."
    }
  ]
}
