{
  "uid": "tha-ap238",
  "title": "6 Vaṇṇakārattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap238:1.1",
      "pali": "“Nagare aruṇavatiyā,"
    },
    {
      "id": "tha-ap238:1.2",
      "pali": "vaṇṇakāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap238:1.3",
      "pali": "Cetiye dussabhaṇḍāni,"
    },
    {
      "id": "tha-ap238:1.4",
      "pali": "nānāvaṇṇaṁ rajesahaṁ."
    },
    {
      "id": "tha-ap238:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap238:2.2",
      "pali": "yaṁ vaṇṇaṁ rajayiṁ tadā;"
    },
    {
      "id": "tha-ap238:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap238:2.4",
      "pali": "vaṇṇadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap238:3.1",
      "pali": "Ito tevīsatikappe,"
    },
    {
      "id": "tha-ap238:3.2",
      "pali": "vaṇṇasamasanāmako;"
    },
    {
      "id": "tha-ap238:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap238:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap238:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap238:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap238:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap238:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā vaṇṇakāro thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap238:6.1",
      "pali": "Vaṇṇakārattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
