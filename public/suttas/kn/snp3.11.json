{
  "uid": "snp3.11",
  "title": "Nālakasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp3.11:1.1",
      "pali": "Ānandajāte tidasagaṇe patīte,"
    },
    {
      "id": "snp3.11:1.2",
      "pali": "Sakkañca indaṁ sucivasane ca deve;"
    },
    {
      "id": "snp3.11:1.3",
      "pali": "Dussaṁ gahetvā atiriva thomayante,"
    },
    {
      "id": "snp3.11:1.4",
      "pali": "Asito isi addasa divāvihāre."
    },
    {
      "id": "snp3.11:2.1",
      "pali": "Disvāna deve muditamane udagge,"
    },
    {
      "id": "snp3.11:2.2",
      "pali": "Cittiṁ karitvāna idamavoca tattha;"
    },
    {
      "id": "snp3.11:2.3",
      "pali": "“Kiṁ devasaṅgho atiriva kalyarūpo,"
    },
    {
      "id": "snp3.11:2.4",
      "pali": "Dussaṁ gahetvā ramayatha kiṁ paṭicca."
    },
    {
      "id": "snp3.11:3.1",
      "pali": "Yadāpi āsī asurehi saṅgamo,"
    },
    {
      "id": "snp3.11:3.2",
      "pali": "Jayo surānaṁ asurā parājitā;"
    },
    {
      "id": "snp3.11:3.3",
      "pali": "Tadāpi netādiso lomahaṁsano,"
    },
    {
      "id": "snp3.11:3.4",
      "pali": "Kimabbhutaṁ daṭṭhu marū pamoditā."
    },
    {
      "id": "snp3.11:4.1",
      "pali": "Seḷenti gāyanti ca vādayanti ca,"
    },
    {
      "id": "snp3.11:4.2",
      "pali": "Bhujāni phoṭenti ca naccayanti ca;"
    },
    {
      "id": "snp3.11:4.3",
      "pali": "Pucchāmi vohaṁ merumuddhavāsine,"
    },
    {
      "id": "snp3.11:4.4",
      "pali": "Dhunātha me saṁsayaṁ khippa mārisā”."
    },
    {
      "id": "snp3.11:5.1",
      "pali": "“So bodhisatto ratanavaro atulyo,"
    },
    {
      "id": "snp3.11:5.2",
      "pali": "Manussaloke hitasukhatthāya jāto;"
    },
    {
      "id": "snp3.11:5.3",
      "pali": "Sakyāna gāme janapade lumbineyye,"
    },
    {
      "id": "snp3.11:5.4",
      "pali": "Tenamha tuṭṭhā atiriva kalyarūpā."
    },
    {
      "id": "snp3.11:6.1",
      "pali": "So sabbasattuttamo aggapuggalo,"
    },
    {
      "id": "snp3.11:6.2",
      "pali": "Narāsabho sabbapajānamuttamo;"
    },
    {
      "id": "snp3.11:6.3",
      "pali": "Vattessati cakkamisivhaye vane,"
    },
    {
      "id": "snp3.11:6.4",
      "pali": "Nadaṁva sīho balavā migābhibhū”."
    },
    {
      "id": "snp3.11:7.1",
      "pali": "Taṁ saddaṁ sutvā turitamavasarī so,"
    },
    {
      "id": "snp3.11:7.2",
      "pali": "Suddhodanassa tada bhavanaṁ upāvisi;"
    },
    {
      "id": "snp3.11:7.3",
      "pali": "Nisajja tattha idamavocāsi sakye,"
    },
    {
      "id": "snp3.11:7.4",
      "pali": "“Kuhiṁ kumāro ahamapi daṭṭhukāmo”."
    },
    {
      "id": "snp3.11:8.1",
      "pali": "Tato kumāraṁ jalitamiva suvaṇṇaṁ,"
    },
    {
      "id": "snp3.11:8.2",
      "pali": "Ukkāmukheva sukusalasampahaṭṭhaṁ;"
    },
    {
      "id": "snp3.11:8.3",
      "pali": "Daddallamānaṁ siriyā anomavaṇṇaṁ,"
    },
    {
      "id": "snp3.11:8.4",
      "pali": "Dassesu puttaṁ asitavhayassa sakyā."
    },
    {
      "id": "snp3.11:9.1",
      "pali": "Disvā kumāraṁ sikhimiva pajjalantaṁ,"
    },
    {
      "id": "snp3.11:9.2",
      "pali": "Tārāsabhaṁva nabhasigamaṁ visuddhaṁ;"
    },
    {
      "id": "snp3.11:9.3",
      "pali": "Suriyaṁ tapantaṁ saradarivabbhamuttaṁ,"
    },
    {
      "id": "snp3.11:9.4",
      "pali": "Ānandajāto vipulamalattha pītiṁ."
    },
    {
      "id": "snp3.11:10.1",
      "pali": "Anekasākhañca sahassamaṇḍalaṁ,"
    },
    {
      "id": "snp3.11:10.2",
      "pali": "Chattaṁ marū dhārayumantalikkhe;"
    },
    {
      "id": "snp3.11:10.3",
      "pali": "Suvaṇṇadaṇḍā vītipatanti cāmarā,"
    },
    {
      "id": "snp3.11:10.4",
      "pali": "Na dissare cāmarachattagāhakā."
    },
    {
      "id": "snp3.11:11.1",
      "pali": "Disvā jaṭī kaṇhasirivhayo isi,"
    },
    {
      "id": "snp3.11:11.2",
      "pali": "Suvaṇṇanikkhaṁ viya paṇḍukambale;"
    },
    {
      "id": "snp3.11:11.3",
      "pali": "Setañca chattaṁ dhariyanta muddhani,"
    },
    {
      "id": "snp3.11:11.4",
      "pali": "Udaggacitto sumano paṭiggahe."
    },
    {
      "id": "snp3.11:12.1",
      "pali": "Paṭiggahetvā pana sakyapuṅgavaṁ,"
    },
    {
      "id": "snp3.11:12.2",
      "pali": "Jigīsako lakkhaṇamantapāragū;"
    },
    {
      "id": "snp3.11:12.3",
      "pali": "Pasannacitto giramabbhudīrayi,"
    },
    {
      "id": "snp3.11:12.4",
      "pali": "“Anuttarāyaṁ dvipadānamuttamo”."
    },
    {
      "id": "snp3.11:13.1",
      "pali": "Athattano gamanamanussaranto,"
    },
    {
      "id": "snp3.11:13.2",
      "pali": "Akalyarūpo gaḷayati assukāni;"
    },
    {
      "id": "snp3.11:13.3",
      "pali": "Disvāna sakyā isimavocuṁ rudantaṁ,"
    },
    {
      "id": "snp3.11:13.4",
      "pali": "“No ce kumāre bhavissati antarāyo”."
    },
    {
      "id": "snp3.11:14.1",
      "pali": "Disvāna sakye isimavoca akalye,"
    },
    {
      "id": "snp3.11:14.2",
      "pali": "“Nāhaṁ kumāre ahitamanussarāmi;"
    },
    {
      "id": "snp3.11:14.3",
      "pali": "Na cāpimassa bhavissati antarāyo,"
    },
    {
      "id": "snp3.11:14.4",
      "pali": "Na orakāyaṁ adhimānasā bhavātha."
    },
    {
      "id": "snp3.11:15.1",
      "pali": "Sambodhiyaggaṁ phusissatāyaṁ kumāro,"
    },
    {
      "id": "snp3.11:15.2",
      "pali": "So dhammacakkaṁ paramavisuddhadassī;"
    },
    {
      "id": "snp3.11:15.3",
      "pali": "Vattessatāyaṁ bahujanahitānukampī,"
    },
    {
      "id": "snp3.11:15.4",
      "pali": "Vitthārikassa bhavissati brahmacariyaṁ."
    },
    {
      "id": "snp3.11:16.1",
      "pali": "Mamañca āyu na ciramidhāvaseso,"
    },
    {
      "id": "snp3.11:16.2",
      "pali": "Athantarā me bhavissati kālakiriyā;"
    },
    {
      "id": "snp3.11:16.3",
      "pali": "Sohaṁ na sossaṁ asamadhurassa dhammaṁ,"
    },
    {
      "id": "snp3.11:16.4",
      "pali": "Tenamhi aṭṭo byasanaṅgato aghāvī”."
    },
    {
      "id": "snp3.11:17.1",
      "pali": "So sākiyānaṁ vipulaṁ janetvā pītiṁ,"
    },
    {
      "id": "snp3.11:17.2",
      "pali": "Antepuramhā niggamā brahmacārī;"
    },
    {
      "id": "snp3.11:17.3",
      "pali": "So bhāgineyyaṁ sayaṁ anukampamāno,"
    },
    {
      "id": "snp3.11:17.4",
      "pali": "Samādapesi asamadhurassa dhamme."
    },
    {
      "id": "snp3.11:18.1",
      "pali": "“Buddhoti ghosaṁ yada parato suṇāsi,"
    },
    {
      "id": "snp3.11:18.2",
      "pali": "Sambodhipatto vivarati dhammamaggaṁ;"
    },
    {
      "id": "snp3.11:18.3",
      "pali": "Gantvāna tattha samayaṁ paripucchamāno,"
    },
    {
      "id": "snp3.11:18.4",
      "pali": "Carassu tasmiṁ bhagavati brahmacariyaṁ”."
    },
    {
      "id": "snp3.11:19.1",
      "pali": "Tenānusiṭṭho hitamanena tādinā,"
    },
    {
      "id": "snp3.11:19.2",
      "pali": "Anāgate paramavisuddhadassinā;"
    },
    {
      "id": "snp3.11:19.3",
      "pali": "So nālako upacitapuññasañcayo,"
    },
    {
      "id": "snp3.11:19.4",
      "pali": "Jinaṁ patikkhaṁ parivasi rakkhitindriyo."
    },
    {
      "id": "snp3.11:20.1",
      "pali": "Sutvāna ghosaṁ jinavaracakkavattane,"
    },
    {
      "id": "snp3.11:20.2",
      "pali": "Gantvāna disvā isinisabhaṁ pasanno;"
    },
    {
      "id": "snp3.11:20.3",
      "pali": "Moneyyaseṭṭhaṁ munipavaraṁ apucchi,"
    },
    {
      "id": "snp3.11:20.4",
      "pali": "Samāgate asitāvhayassa sāsaneti."
    },
    {
      "id": "snp3.11:20.5",
      "pali": "Vatthugāthā niṭṭhitā."
    },
    {
      "id": "snp3.11:21.1",
      "pali": "“Aññātametaṁ vacanaṁ,"
    },
    {
      "id": "snp3.11:21.2",
      "pali": "Asitassa yathātathaṁ;"
    },
    {
      "id": "snp3.11:21.3",
      "pali": "Taṁ taṁ gotama pucchāmi,"
    },
    {
      "id": "snp3.11:21.4",
      "pali": "Sabbadhammāna pāraguṁ."
    },
    {
      "id": "snp3.11:22.1",
      "pali": "Anagāriyupetassa,"
    },
    {
      "id": "snp3.11:22.2",
      "pali": "Bhikkhācariyaṁ jigīsato;"
    },
    {
      "id": "snp3.11:22.3",
      "pali": "Muni pabrūhi me puṭṭho,"
    },
    {
      "id": "snp3.11:22.4",
      "pali": "Moneyyaṁ uttamaṁ padaṁ”."
    },
    {
      "id": "snp3.11:23.1",
      "pali": "“Moneyyaṁ te upaññissaṁ,"
    },
    {
      "id": "snp3.11:23.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp3.11:23.3",
      "pali": "Dukkaraṁ durabhisambhavaṁ;"
    },
    {
      "id": "snp3.11:23.4",
      "pali": "Handa te naṁ pavakkhāmi,"
    },
    {
      "id": "snp3.11:23.5",
      "pali": "Santhambhassu daḷho bhava."
    },
    {
      "id": "snp3.11:24.1",
      "pali": "Samānabhāgaṁ kubbetha,"
    },
    {
      "id": "snp3.11:24.2",
      "pali": "Gāme akkuṭṭhavanditaṁ;"
    },
    {
      "id": "snp3.11:24.3",
      "pali": "Manopadosaṁ rakkheyya,"
    },
    {
      "id": "snp3.11:24.4",
      "pali": "Santo anuṇṇato care."
    },
    {
      "id": "snp3.11:25.1",
      "pali": "Uccāvacā niccharanti,"
    },
    {
      "id": "snp3.11:25.2",
      "pali": "Dāye aggisikhūpamā;"
    },
    {
      "id": "snp3.11:25.3",
      "pali": "Nāriyo muniṁ palobhenti,"
    },
    {
      "id": "snp3.11:25.4",
      "pali": "Tā su taṁ mā palobhayuṁ."
    },
    {
      "id": "snp3.11:26.1",
      "pali": "Virato methunā dhammā,"
    },
    {
      "id": "snp3.11:26.2",
      "pali": "Hitvā kāme paropare;"
    },
    {
      "id": "snp3.11:26.3",
      "pali": "Aviruddho asāratto,"
    },
    {
      "id": "snp3.11:26.4",
      "pali": "Pāṇesu tasathāvare."
    },
    {
      "id": "snp3.11:27.1",
      "pali": "Yathā ahaṁ tathā ete,"
    },
    {
      "id": "snp3.11:27.2",
      "pali": "Yathā ete tathā ahaṁ;"
    },
    {
      "id": "snp3.11:27.3",
      "pali": "Attānaṁ upamaṁ katvā,"
    },
    {
      "id": "snp3.11:27.4",
      "pali": "Na haneyya na ghātaye."
    },
    {
      "id": "snp3.11:28.1",
      "pali": "Hitvā icchañca lobhañca,"
    },
    {
      "id": "snp3.11:28.2",
      "pali": "Yattha satto puthujjano;"
    },
    {
      "id": "snp3.11:28.3",
      "pali": "Cakkhumā paṭipajjeyya,"
    },
    {
      "id": "snp3.11:28.4",
      "pali": "Tareyya narakaṁ imaṁ."
    },
    {
      "id": "snp3.11:29.1",
      "pali": "Ūnūdaro mitāhāro,"
    },
    {
      "id": "snp3.11:29.2",
      "pali": "Appicchassa alolupo;"
    },
    {
      "id": "snp3.11:29.3",
      "pali": "Sadā icchāya nicchāto,"
    },
    {
      "id": "snp3.11:29.4",
      "pali": "Aniccho hoti nibbuto."
    },
    {
      "id": "snp3.11:30.1",
      "pali": "Sa piṇḍacāraṁ caritvā,"
    },
    {
      "id": "snp3.11:30.2",
      "pali": "Vanantamabhihāraye;"
    },
    {
      "id": "snp3.11:30.3",
      "pali": "Upaṭṭhito rukkhamūlasmiṁ,"
    },
    {
      "id": "snp3.11:30.4",
      "pali": "Āsanūpagato muni."
    },
    {
      "id": "snp3.11:31.1",
      "pali": "Sa jhānapasuto dhīro,"
    },
    {
      "id": "snp3.11:31.2",
      "pali": "Vanante ramito siyā;"
    },
    {
      "id": "snp3.11:31.3",
      "pali": "Jhāyetha rukkhamūlasmiṁ,"
    },
    {
      "id": "snp3.11:31.4",
      "pali": "Attānamabhitosayaṁ."
    },
    {
      "id": "snp3.11:32.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "snp3.11:32.2",
      "pali": "Gāmantamabhihāraye;"
    },
    {
      "id": "snp3.11:32.3",
      "pali": "Avhānaṁ nābhinandeyya,"
    },
    {
      "id": "snp3.11:32.4",
      "pali": "Abhihārañca gāmato."
    },
    {
      "id": "snp3.11:33.1",
      "pali": "Na munī gāmamāgamma,"
    },
    {
      "id": "snp3.11:33.2",
      "pali": "Kulesu sahasā care;"
    },
    {
      "id": "snp3.11:33.3",
      "pali": "Ghāsesanaṁ chinnakatho,"
    },
    {
      "id": "snp3.11:33.4",
      "pali": "Na vācaṁ payutaṁ bhaṇe."
    },
    {
      "id": "snp3.11:34.1",
      "pali": "Alatthaṁ yadidaṁ sādhu,"
    },
    {
      "id": "snp3.11:34.2",
      "pali": "Nālatthaṁ kusalaṁ iti;"
    },
    {
      "id": "snp3.11:34.3",
      "pali": "Ubhayeneva so tādī,"
    },
    {
      "id": "snp3.11:34.4",
      "pali": "Rukkhaṁvupanivattati."
    },
    {
      "id": "snp3.11:35.1",
      "pali": "Sa pattapāṇi vicaranto,"
    },
    {
      "id": "snp3.11:35.2",
      "pali": "Amūgo mūgasammato;"
    },
    {
      "id": "snp3.11:35.3",
      "pali": "Appaṁ dānaṁ na hīḷeyya,"
    },
    {
      "id": "snp3.11:35.4",
      "pali": "Dātāraṁ nāvajāniyā."
    },
    {
      "id": "snp3.11:36.1",
      "pali": "Uccāvacā hi paṭipadā,"
    },
    {
      "id": "snp3.11:36.2",
      "pali": "Samaṇena pakāsitā;"
    },
    {
      "id": "snp3.11:36.3",
      "pali": "Na pāraṁ diguṇaṁ yanti,"
    },
    {
      "id": "snp3.11:36.4",
      "pali": "Nayidaṁ ekaguṇaṁ mutaṁ."
    },
    {
      "id": "snp3.11:37.1",
      "pali": "Yassa ca visatā natthi,"
    },
    {
      "id": "snp3.11:37.2",
      "pali": "Chinnasotassa bhikkhuno;"
    },
    {
      "id": "snp3.11:37.3",
      "pali": "Kiccākiccappahīnassa,"
    },
    {
      "id": "snp3.11:37.4",
      "pali": "Pariḷāho na vijjati."
    },
    {
      "id": "snp3.11:38.1",
      "pali": "Moneyyaṁ te upaññissaṁ,"
    },
    {
      "id": "snp3.11:38.2",
      "pali": "Khuradhārūpamo bhave;"
    },
    {
      "id": "snp3.11:38.3",
      "pali": "Jivhāya tālumāhacca,"
    },
    {
      "id": "snp3.11:38.4",
      "pali": "Udare saññato siyā."
    },
    {
      "id": "snp3.11:39.1",
      "pali": "Alīnacitto ca siyā,"
    },
    {
      "id": "snp3.11:39.2",
      "pali": "Na cāpi bahu cintaye;"
    },
    {
      "id": "snp3.11:39.3",
      "pali": "Nirāmagandho asito,"
    },
    {
      "id": "snp3.11:39.4",
      "pali": "Brahmacariyaparāyaṇo."
    },
    {
      "id": "snp3.11:40.1",
      "pali": "Ekāsanassa sikkhetha,"
    },
    {
      "id": "snp3.11:40.2",
      "pali": "Samaṇūpāsanassa ca;"
    },
    {
      "id": "snp3.11:40.3",
      "pali": "Ekattaṁ monamakkhātaṁ,"
    },
    {
      "id": "snp3.11:40.4",
      "pali": "Eko ce abhiramissasi;"
    },
    {
      "id": "snp3.11:40.5",
      "pali": "Atha bhāhisi dasadisā."
    },
    {
      "id": "snp3.11:41.1",
      "pali": "Sutvā dhīrānaṁ nighosaṁ,"
    },
    {
      "id": "snp3.11:41.2",
      "pali": "Jhāyīnaṁ kāmacāginaṁ;"
    },
    {
      "id": "snp3.11:41.3",
      "pali": "Tato hiriñca saddhañca,"
    },
    {
      "id": "snp3.11:41.4",
      "pali": "Bhiyyo kubbetha māmako."
    },
    {
      "id": "snp3.11:42.1",
      "pali": "Taṁ nadīhi vijānātha,"
    },
    {
      "id": "snp3.11:42.2",
      "pali": "Sobbhesu padaresu ca;"
    },
    {
      "id": "snp3.11:42.3",
      "pali": "Saṇantā yanti kusobbhā,"
    },
    {
      "id": "snp3.11:42.4",
      "pali": "Tuṇhī yanti mahodadhī."
    },
    {
      "id": "snp3.11:43.1",
      "pali": "Yadūnakaṁ taṁ saṇati,"
    },
    {
      "id": "snp3.11:43.2",
      "pali": "Yaṁ pūraṁ santameva taṁ;"
    },
    {
      "id": "snp3.11:43.3",
      "pali": "Aḍḍhakumbhūpamo bālo,"
    },
    {
      "id": "snp3.11:43.4",
      "pali": "Rahado pūrova paṇḍito."
    },
    {
      "id": "snp3.11:44.1",
      "pali": "Yaṁ samaṇo bahuṁ bhāsati,"
    },
    {
      "id": "snp3.11:44.2",
      "pali": "Upetaṁ atthasañhitaṁ;"
    },
    {
      "id": "snp3.11:44.3",
      "pali": "Jānaṁ so dhammaṁ deseti,"
    },
    {
      "id": "snp3.11:44.4",
      "pali": "Jānaṁ so bahu bhāsati."
    },
    {
      "id": "snp3.11:45.1",
      "pali": "Yo ca jānaṁ saṁyatatto,"
    },
    {
      "id": "snp3.11:45.2",
      "pali": "Jānaṁ na bahu bhāsati;"
    },
    {
      "id": "snp3.11:45.3",
      "pali": "Sa munī monamarahati,"
    },
    {
      "id": "snp3.11:45.4",
      "pali": "Sa munī monamajjhagā”ti."
    },
    {
      "id": "snp3.11:45.5",
      "pali": "Nālakasuttaṁ ekādasamaṁ."
    }
  ]
}
