{
  "uid": "tha-ap274",
  "title": "2 Tilamuṭṭhidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap274:1.1",
      "pali": "“Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap274:1.2",
      "pali": "satthā lokagganāyako;"
    },
    {
      "id": "tha-ap274:1.3",
      "pali": "Manomayena kāyena,"
    },
    {
      "id": "tha-ap274:1.4",
      "pali": "iddhiyā upasaṅkami."
    },
    {
      "id": "tha-ap274:2.1",
      "pali": "Satthāraṁ upasaṅkantaṁ,"
    },
    {
      "id": "tha-ap274:2.2",
      "pali": "vanditvā purisuttamaṁ;"
    },
    {
      "id": "tha-ap274:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap274:2.4",
      "pali": "tilamuṭṭhimadāsahaṁ."
    },
    {
      "id": "tha-ap274:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap274:3.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap274:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap274:3.4",
      "pali": "tilamuṭṭhiyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap274:4.1",
      "pali": "Ito soḷasakappamhi,"
    },
    {
      "id": "tha-ap274:4.2",
      "pali": "tantiso nāma khattiyo;"
    },
    {
      "id": "tha-ap274:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap274:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap274:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap274:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap274:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap274:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā tilamuṭṭhidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap274:7.1",
      "pali": "Tilamuṭṭhidāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
