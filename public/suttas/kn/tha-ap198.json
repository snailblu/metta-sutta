{
  "uid": "tha-ap198",
  "title": "Kisalayapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap198:1.1",
      "pali": "“Nagare dvāravatiyā,"
    },
    {
      "id": "tha-ap198:1.2",
      "pali": "mālāvaccho mamaṁ ahu;"
    },
    {
      "id": "tha-ap198:1.3",
      "pali": "Udapāno ca tattheva,"
    },
    {
      "id": "tha-ap198:1.4",
      "pali": "pādapānaṁ virohano."
    },
    {
      "id": "tha-ap198:2.1",
      "pali": "Sabalena upatthaddho,"
    },
    {
      "id": "tha-ap198:2.2",
      "pali": "siddhattho aparājito;"
    },
    {
      "id": "tha-ap198:2.3",
      "pali": "Mamānukampamāno so,"
    },
    {
      "id": "tha-ap198:2.4",
      "pali": "gacchate anilañjase."
    },
    {
      "id": "tha-ap198:3.1",
      "pali": "Aññaṁ kiñci na passāmi,"
    },
    {
      "id": "tha-ap198:3.2",
      "pali": "pūjāyoggaṁ mahesino;"
    },
    {
      "id": "tha-ap198:3.3",
      "pali": "Asokaṁ pallavaṁ disvā,"
    },
    {
      "id": "tha-ap198:3.4",
      "pali": "ākāse ukkhipiṁ ahaṁ."
    },
    {
      "id": "tha-ap198:4.1",
      "pali": "Buddhassa te kisalayā,"
    },
    {
      "id": "tha-ap198:4.2",
      "pali": "gacchato yanti pacchato;"
    },
    {
      "id": "tha-ap198:4.3",
      "pali": "Tāhaṁ disvāna saṁvijiṁ,"
    },
    {
      "id": "tha-ap198:4.4",
      "pali": "aho buddhassuḷāratā."
    },
    {
      "id": "tha-ap198:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap198:5.2",
      "pali": "pallavaṁ abhiropayiṁ;"
    },
    {
      "id": "tha-ap198:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap198:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap198:6.1",
      "pali": "Sattatiṁse ito kappe,"
    },
    {
      "id": "tha-ap198:6.2",
      "pali": "eko ekissaro ahu;"
    },
    {
      "id": "tha-ap198:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap198:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap198:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap198:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap198:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap198:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā kisalayapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap198:9.1",
      "pali": "Kisalayapūjakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
