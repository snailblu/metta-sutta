{
  "uid": "ja337",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja337:1.1",
      "pali": "“Na te pīṭhamadāyimhā,"
    },
    {
      "id": "ja337:1.2",
      "pali": "na pānaṁ napi bhojanaṁ;"
    },
    {
      "id": "ja337:1.3",
      "pali": "Brahmacāri khamassu me,"
    },
    {
      "id": "ja337:1.4",
      "pali": "etaṁ passāmi accayaṁ”."
    },
    {
      "id": "ja337:2.1",
      "pali": "“Nevābhisajjāmi na cāpi kuppe,"
    },
    {
      "id": "ja337:2.2",
      "pali": "Na cāpi me appiyamāsi kiñci;"
    },
    {
      "id": "ja337:2.3",
      "pali": "Athopi me āsi manovitakko,"
    },
    {
      "id": "ja337:2.4",
      "pali": "Etādiso nūna kulassa dhammo”."
    },
    {
      "id": "ja337:3.1",
      "pali": "“Esasmākaṁ kule dhammo,"
    },
    {
      "id": "ja337:3.2",
      "pali": "pitupitāmaho sadā;"
    },
    {
      "id": "ja337:3.3",
      "pali": "Āsanaṁ udakaṁ pajjaṁ,"
    },
    {
      "id": "ja337:3.4",
      "pali": "sabbetaṁ nipadāmase."
    },
    {
      "id": "ja337:4.1",
      "pali": "Esasmākaṁ kule dhammo,"
    },
    {
      "id": "ja337:4.2",
      "pali": "pitupitāmaho sadā;"
    },
    {
      "id": "ja337:4.3",
      "pali": "Sakkaccaṁ upatiṭṭhāma,"
    },
    {
      "id": "ja337:4.4",
      "pali": "uttamaṁ viya ñātakan”ti."
    },
    {
      "id": "ja337:5.1",
      "pali": "Pīṭhajātakaṁ sattamaṁ."
    }
  ]
}
