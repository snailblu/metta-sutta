{
  "uid": "ja375",
  "title": "Aḍḍhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja375:1.1",
      "pali": "“Idāni khomhi sukhito arogo,"
    },
    {
      "id": "ja375:1.2",
      "pali": "Nikkaṇṭako nippatito kapoto;"
    },
    {
      "id": "ja375:1.3",
      "pali": "Kāhāmi dānī hadayassa tuṭṭhiṁ,"
    },
    {
      "id": "ja375:1.4",
      "pali": "Tathāhimaṁ maṁsasākaṁ baleti”."
    },
    {
      "id": "ja375:2.1",
      "pali": "“Kāyaṁ balākā sikhinī,"
    },
    {
      "id": "ja375:2.2",
      "pali": "corī laṅghipitāmahā;"
    },
    {
      "id": "ja375:2.3",
      "pali": "Oraṁ balāke āgaccha,"
    },
    {
      "id": "ja375:2.4",
      "pali": "caṇḍo me vāyaso sakhā”."
    },
    {
      "id": "ja375:3.1",
      "pali": "“Alañhi te jagghitāye,"
    },
    {
      "id": "ja375:3.2",
      "pali": "Mamaṁ disvāna edisaṁ;"
    },
    {
      "id": "ja375:3.3",
      "pali": "Vilūnaṁ sūdaputtena,"
    },
    {
      "id": "ja375:3.4",
      "pali": "Piṭṭhamaṇḍena makkhitaṁ”."
    },
    {
      "id": "ja375:4.1",
      "pali": "“Sunhāto suvilittosi,"
    },
    {
      "id": "ja375:4.2",
      "pali": "annapānena tappito;"
    },
    {
      "id": "ja375:4.3",
      "pali": "Kaṇṭhe ca te veḷuriyo,"
    },
    {
      "id": "ja375:4.4",
      "pali": "agamā nu kajaṅgalaṁ”."
    },
    {
      "id": "ja375:5.1",
      "pali": "“Mā te mitto amitto vā,"
    },
    {
      "id": "ja375:5.2",
      "pali": "agamāsi kajaṅgalaṁ;"
    },
    {
      "id": "ja375:5.3",
      "pali": "Piñchāni tattha lāyitvā,"
    },
    {
      "id": "ja375:5.4",
      "pali": "kaṇṭhe bandhanti vaṭṭanaṁ”."
    },
    {
      "id": "ja375:6.1",
      "pali": "“Punapāpajjasī samma,"
    },
    {
      "id": "ja375:6.2",
      "pali": "Sīlañhi tava tādisaṁ;"
    },
    {
      "id": "ja375:6.3",
      "pali": "Na hi mānusakā bhogā,"
    },
    {
      "id": "ja375:6.4",
      "pali": "Subhuñjā honti pakkhinā”ti."
    },
    {
      "id": "ja375:7.1",
      "pali": "Kapotajātakaṁ pañcamaṁ."
    },
    {
      "id": "ja375:7.2",
      "pali": "Aḍḍhavaggo tatiyo."
    },
    {
      "id": "ja375:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja375:9.1",
      "pali": "Atha vaṇṇa sasīla hiri labhate,"
    },
    {
      "id": "ja375:9.2",
      "pali": "Sumukhā visa sāḷiyamittavaro;"
    },
    {
      "id": "ja375:9.3",
      "pali": "Atha cakka palāsa sarāja sato,"
    },
    {
      "id": "ja375:9.4",
      "pali": "Yava bāla kapotaka pannarasāti."
    },
    {
      "id": "ja375:10.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja375:11.1",
      "pali": "Jīnañca vaṇṇaṁ asamaṁvaguppari,"
    },
    {
      "id": "ja375:11.2",
      "pali": "Sudesitā jātakanti santi vīsati;"
    },
    {
      "id": "ja375:11.3",
      "pali": "Mahesino brahmacarittamutta-"
    },
    {
      "id": "ja375:11.4",
      "pali": "Mavoca gāthā atthavatī subyañjanāti."
    },
    {
      "id": "ja375:12.1",
      "pali": "Pañcakanipātaṁ niṭṭhitaṁ."
    }
  ]
}
