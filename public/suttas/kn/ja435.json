{
  "uid": "ja435",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja435:1.1",
      "pali": "“Sutitikkhaṁ araññamhi,"
    },
    {
      "id": "ja435:1.2",
      "pali": "pantamhi sayanāsane;"
    },
    {
      "id": "ja435:1.3",
      "pali": "Ye ca gāme titikkhanti,"
    },
    {
      "id": "ja435:1.4",
      "pali": "te uḷāratarā tayā”."
    },
    {
      "id": "ja435:2.1",
      "pali": "“Araññā gāmamāgamma,"
    },
    {
      "id": "ja435:2.2",
      "pali": "kiṁsīlaṁ kiṁvataṁ ahaṁ;"
    },
    {
      "id": "ja435:2.3",
      "pali": "Purisaṁ tāta seveyyaṁ,"
    },
    {
      "id": "ja435:2.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja435:3.1",
      "pali": "“Yo te vissāsaye tāta,"
    },
    {
      "id": "ja435:3.2",
      "pali": "vissāsañca khameyya te;"
    },
    {
      "id": "ja435:3.3",
      "pali": "Sussūsī ca titikkhī ca,"
    },
    {
      "id": "ja435:3.4",
      "pali": "taṁ bhajehi ito gato."
    },
    {
      "id": "ja435:4.1",
      "pali": "Yassa kāyena vācāya,"
    },
    {
      "id": "ja435:4.2",
      "pali": "manasā natthi dukkaṭaṁ;"
    },
    {
      "id": "ja435:4.3",
      "pali": "Urasīva patiṭṭhāya,"
    },
    {
      "id": "ja435:4.4",
      "pali": "taṁ bhajehi ito gato."
    },
    {
      "id": "ja435:5.1",
      "pali": "Yo ca dhammena carati,"
    },
    {
      "id": "ja435:5.2",
      "pali": "carantopi na maññati;"
    },
    {
      "id": "ja435:5.3",
      "pali": "Visuddhakāriṁ sappaññaṁ,"
    },
    {
      "id": "ja435:5.4",
      "pali": "taṁ bhajehi ito gato."
    },
    {
      "id": "ja435:6.1",
      "pali": "Haliddirāgaṁ kapicittaṁ,"
    },
    {
      "id": "ja435:6.2",
      "pali": "purisaṁ rāgavirāginaṁ;"
    },
    {
      "id": "ja435:6.3",
      "pali": "Tādisaṁ tāta mā sevi,"
    },
    {
      "id": "ja435:6.4",
      "pali": "nimmanussampi ce siyā."
    },
    {
      "id": "ja435:7.1",
      "pali": "Āsīvisaṁva kupitaṁ,"
    },
    {
      "id": "ja435:7.2",
      "pali": "mīḷhalittaṁ mahāpathaṁ;"
    },
    {
      "id": "ja435:7.3",
      "pali": "Ārakā parivajjehi,"
    },
    {
      "id": "ja435:7.4",
      "pali": "yānīva visamaṁ pathaṁ."
    },
    {
      "id": "ja435:8.1",
      "pali": "Anatthā tāta vaḍḍhanti,"
    },
    {
      "id": "ja435:8.2",
      "pali": "bālaṁ accupasevato;"
    },
    {
      "id": "ja435:8.3",
      "pali": "Māssu bālena saṅgacchi,"
    },
    {
      "id": "ja435:8.4",
      "pali": "amitteneva sabbadā."
    },
    {
      "id": "ja435:9.1",
      "pali": "Taṁ tāhaṁ tāta yācāmi,"
    },
    {
      "id": "ja435:9.2",
      "pali": "karassu vacanaṁ mama;"
    },
    {
      "id": "ja435:9.3",
      "pali": "Māssu bālena saṅgacchi,"
    },
    {
      "id": "ja435:9.4",
      "pali": "dukkho bālehi saṅgamo”ti."
    },
    {
      "id": "ja435:10.1",
      "pali": "Haliddirāgajātakaṁ navamaṁ."
    }
  ]
}
