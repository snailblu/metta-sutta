{
  "uid": "snp4.8",
  "title": "Pasūrasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp4.8:1.1",
      "pali": "Idheva suddhī iti vādayanti,"
    },
    {
      "id": "snp4.8:1.2",
      "pali": "Nāññesu dhammesu visuddhimāhu;"
    },
    {
      "id": "snp4.8:1.3",
      "pali": "Yaṁ nissitā tattha subhaṁ vadānā,"
    },
    {
      "id": "snp4.8:1.4",
      "pali": "Paccekasaccesu puthū niviṭṭhā."
    },
    {
      "id": "snp4.8:2.1",
      "pali": "Te vādakāmā parisaṁ vigayha,"
    },
    {
      "id": "snp4.8:2.2",
      "pali": "Bālaṁ dahantī mithu aññamaññaṁ;"
    },
    {
      "id": "snp4.8:2.3",
      "pali": "Vadanti te aññasitā kathojjaṁ,"
    },
    {
      "id": "snp4.8:2.4",
      "pali": "Pasaṁsakāmā kusalā vadānā."
    },
    {
      "id": "snp4.8:3.1",
      "pali": "Yutto kathāyaṁ parisāya majjhe,"
    },
    {
      "id": "snp4.8:3.2",
      "pali": "Pasaṁsamicchaṁ vinighāti hoti;"
    },
    {
      "id": "snp4.8:3.3",
      "pali": "Apāhatasmiṁ pana maṅku hoti,"
    },
    {
      "id": "snp4.8:3.4",
      "pali": "Nindāya so kuppati randhamesī."
    },
    {
      "id": "snp4.8:4.1",
      "pali": "Yamassa vādaṁ parihīnamāhu,"
    },
    {
      "id": "snp4.8:4.2",
      "pali": "Apāhataṁ pañhavimaṁsakāse;"
    },
    {
      "id": "snp4.8:4.3",
      "pali": "Paridevati socati hīnavādo,"
    },
    {
      "id": "snp4.8:4.4",
      "pali": "Upaccagā manti anutthunāti."
    },
    {
      "id": "snp4.8:5.1",
      "pali": "Ete vivādā samaṇesu jātā,"
    },
    {
      "id": "snp4.8:5.2",
      "pali": "Etesu ugghātinighāti hoti;"
    },
    {
      "id": "snp4.8:5.3",
      "pali": "Etampi disvā virame kathojjaṁ,"
    },
    {
      "id": "snp4.8:5.4",
      "pali": "Na haññadatthatthi pasaṁsalābhā."
    },
    {
      "id": "snp4.8:6.1",
      "pali": "Pasaṁsito vā pana tattha hoti,"
    },
    {
      "id": "snp4.8:6.2",
      "pali": "Akkhāya vādaṁ parisāya majjhe;"
    },
    {
      "id": "snp4.8:6.3",
      "pali": "So hassatī unnamatī ca tena,"
    },
    {
      "id": "snp4.8:6.4",
      "pali": "Pappuyya tamatthaṁ yathā mano ahu."
    },
    {
      "id": "snp4.8:7.1",
      "pali": "Yā unnatī sāssa vighātabhūmi,"
    },
    {
      "id": "snp4.8:7.2",
      "pali": "Mānātimānaṁ vadate paneso;"
    },
    {
      "id": "snp4.8:7.3",
      "pali": "Etampi disvā na vivādayetha,"
    },
    {
      "id": "snp4.8:7.4",
      "pali": "Na hi tena suddhiṁ kusalā vadanti."
    },
    {
      "id": "snp4.8:8.1",
      "pali": "Sūro yathā rājakhādāya puṭṭho,"
    },
    {
      "id": "snp4.8:8.2",
      "pali": "Abhigajjameti paṭisūramicchaṁ;"
    },
    {
      "id": "snp4.8:8.3",
      "pali": "Yeneva so tena palehi sūra,"
    },
    {
      "id": "snp4.8:8.4",
      "pali": "Pubbeva natthi yadidaṁ yudhāya."
    },
    {
      "id": "snp4.8:9.1",
      "pali": "Ye diṭṭhimuggayha vivādayanti,"
    },
    {
      "id": "snp4.8:9.2",
      "pali": "Idameva saccanti ca vādayanti;"
    },
    {
      "id": "snp4.8:9.3",
      "pali": "Te tvaṁ vadassū na hi tedha atthi,"
    },
    {
      "id": "snp4.8:9.4",
      "pali": "Vādamhi jāte paṭisenikattā."
    },
    {
      "id": "snp4.8:10.1",
      "pali": "Visenikatvā pana ye caranti,"
    },
    {
      "id": "snp4.8:10.2",
      "pali": "Diṭṭhīhi diṭṭhiṁ avirujjhamānā;"
    },
    {
      "id": "snp4.8:10.3",
      "pali": "Tesu tvaṁ kiṁ labhetho pasūra,"
    },
    {
      "id": "snp4.8:10.4",
      "pali": "Yesīdha natthī paramuggahītaṁ."
    },
    {
      "id": "snp4.8:11.1",
      "pali": "Atha tvaṁ pavitakkamāgamā,"
    },
    {
      "id": "snp4.8:11.2",
      "pali": "Manasā diṭṭhigatāni cintayanto;"
    },
    {
      "id": "snp4.8:11.3",
      "pali": "Dhonena yugaṁ samāgamā,"
    },
    {
      "id": "snp4.8:11.4",
      "pali": "Na hi tvaṁ sakkhasi sampayātaveti."
    },
    {
      "id": "snp4.8:11.5",
      "pali": "Pasūrasuttaṁ aṭṭhamaṁ."
    }
  ]
}
