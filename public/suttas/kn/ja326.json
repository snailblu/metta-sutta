{
  "uid": "ja326",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja326:1.1",
      "pali": "“Kāyena yo nāvahare,"
    },
    {
      "id": "ja326:1.2",
      "pali": "vācāya na musā bhaṇe;"
    },
    {
      "id": "ja326:1.3",
      "pali": "Yaso laddhā na majjeyya,"
    },
    {
      "id": "ja326:1.4",
      "pali": "sa ve kakkārumarahati”."
    },
    {
      "id": "ja326:2.1",
      "pali": "“Dhammena vittameseyya,"
    },
    {
      "id": "ja326:2.2",
      "pali": "na nikatyā dhanaṁ hare;"
    },
    {
      "id": "ja326:2.3",
      "pali": "Bhoge laddhā na majjeyya,"
    },
    {
      "id": "ja326:2.4",
      "pali": "sa ve kakkārumarahati”."
    },
    {
      "id": "ja326:3.1",
      "pali": "“Yassa cittaṁ ahāliddaṁ,"
    },
    {
      "id": "ja326:3.2",
      "pali": "saddhā ca avirāginī;"
    },
    {
      "id": "ja326:3.3",
      "pali": "Eko sāduṁ na bhuñjeyya,"
    },
    {
      "id": "ja326:3.4",
      "pali": "sa ve kakkārumarahati”."
    },
    {
      "id": "ja326:4.1",
      "pali": "“Sammukhā vā tirokkhā vā,"
    },
    {
      "id": "ja326:4.2",
      "pali": "Yo sante na paribhāsati;"
    },
    {
      "id": "ja326:4.3",
      "pali": "Yathāvādī tathākārī,"
    },
    {
      "id": "ja326:4.4",
      "pali": "Sa ve kakkārumarahatī”ti."
    },
    {
      "id": "ja326:5.1",
      "pali": "Kakkārujātakaṁ chaṭṭhaṁ."
    }
  ]
}
