{
  "uid": "thag1.21",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.21:1.1",
      "pali": "“Nāhaṁ bhayassa bhāyāmi,"
    },
    {
      "id": "thag1.21:1.2",
      "pali": "Satthā no amatassa kovido;"
    },
    {
      "id": "thag1.21:1.3",
      "pali": "Yattha bhayaṁ nāvatiṭṭhati,"
    },
    {
      "id": "thag1.21:1.4",
      "pali": "Tena maggena vajanti bhikkhavo”ti."
    },
    {
      "id": "thag1.21:1.5",
      "pali": "… Nigrodho thero …."
    }
  ]
}
