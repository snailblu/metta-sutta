{
  "uid": "tha-ap51",
  "title": "Subhaddattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap51:1.1",
      "pali": "“Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap51:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap51:1.3",
      "pali": "Janataṁ uddharitvāna,"
    },
    {
      "id": "tha-ap51:1.4",
      "pali": "nibbāyati mahāyaso."
    },
    {
      "id": "tha-ap51:2.1",
      "pali": "Nibbāyante ca sambuddhe,"
    },
    {
      "id": "tha-ap51:2.2",
      "pali": "dasasahassi kampatha;"
    },
    {
      "id": "tha-ap51:2.3",
      "pali": "Janakāyo mahā āsi,"
    },
    {
      "id": "tha-ap51:2.4",
      "pali": "devā sannipatuṁ tadā."
    },
    {
      "id": "tha-ap51:3.1",
      "pali": "Candanaṁ pūrayitvāna,"
    },
    {
      "id": "tha-ap51:3.2",
      "pali": "tagarāmallikāhi ca;"
    },
    {
      "id": "tha-ap51:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap51:3.4",
      "pali": "āropayiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap51:4.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap51:4.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap51:4.3",
      "pali": "Nipannakova sambuddho,"
    },
    {
      "id": "tha-ap51:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap51:5.1",
      "pali": "‘Yo me pacchimake kāle,"
    },
    {
      "id": "tha-ap51:5.2",
      "pali": "gandhamālena chādayi;"
    },
    {
      "id": "tha-ap51:5.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap51:5.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap51:6.1",
      "pali": "Ito cuto ayaṁ poso,"
    },
    {
      "id": "tha-ap51:6.2",
      "pali": "tusitakāyaṁ gamissati;"
    },
    {
      "id": "tha-ap51:6.3",
      "pali": "Tattha rajjaṁ karitvāna,"
    },
    {
      "id": "tha-ap51:6.4",
      "pali": "nimmānaṁ so gamissati."
    },
    {
      "id": "tha-ap51:7.1",
      "pali": "Eteneva upāyena,"
    },
    {
      "id": "tha-ap51:7.2",
      "pali": "datvā mālaṁ varuttamaṁ;"
    },
    {
      "id": "tha-ap51:7.3",
      "pali": "Sakakammābhiraddho so,"
    },
    {
      "id": "tha-ap51:7.4",
      "pali": "sampattiṁ anubhossati."
    },
    {
      "id": "tha-ap51:8.1",
      "pali": "Punāpi tusite kāye,"
    },
    {
      "id": "tha-ap51:8.2",
      "pali": "nibbattissatiyaṁ naro;"
    },
    {
      "id": "tha-ap51:8.3",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap51:8.4",
      "pali": "manussattaṁ gamissati."
    },
    {
      "id": "tha-ap51:9.1",
      "pali": "Sakyaputto mahānāgo,"
    },
    {
      "id": "tha-ap51:9.2",
      "pali": "aggo loke sadevake;"
    },
    {
      "id": "tha-ap51:9.3",
      "pali": "Bodhayitvā bahū satte,"
    },
    {
      "id": "tha-ap51:9.4",
      "pali": "nibbāyissati cakkhumā."
    },
    {
      "id": "tha-ap51:10.1",
      "pali": "Tadā sopagato santo,"
    },
    {
      "id": "tha-ap51:10.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap51:10.3",
      "pali": "Upasaṅkamma sambuddhaṁ,"
    },
    {
      "id": "tha-ap51:10.4",
      "pali": "pañhaṁ pucchissati tadā."
    },
    {
      "id": "tha-ap51:11.1",
      "pali": "Hāsayitvāna sambuddho,"
    },
    {
      "id": "tha-ap51:11.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap51:11.3",
      "pali": "Puññakammaṁ pariññāya,"
    },
    {
      "id": "tha-ap51:11.4",
      "pali": "saccāni vivarissati."
    },
    {
      "id": "tha-ap51:12.1",
      "pali": "Āraddho ca ayaṁ pañho,"
    },
    {
      "id": "tha-ap51:12.2",
      "pali": "tuṭṭho ekaggamānaso;"
    },
    {
      "id": "tha-ap51:12.3",
      "pali": "Satthāraṁ abhivādetvā,"
    },
    {
      "id": "tha-ap51:12.4",
      "pali": "pabbajjaṁ yācayissati."
    },
    {
      "id": "tha-ap51:13.1",
      "pali": "Pasannamānasaṁ disvā,"
    },
    {
      "id": "tha-ap51:13.2",
      "pali": "sakakammena tositaṁ;"
    },
    {
      "id": "tha-ap51:13.3",
      "pali": "Pabbājessati so buddho,"
    },
    {
      "id": "tha-ap51:13.4",
      "pali": "aggamaggassa kovido."
    },
    {
      "id": "tha-ap51:14.1",
      "pali": "Vāyamitvānayaṁ poso,"
    },
    {
      "id": "tha-ap51:14.2",
      "pali": "sammāsambuddhasāsane;"
    },
    {
      "id": "tha-ap51:14.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap51:14.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap51:15.1",
      "pali": "Pañcamabhāṇavāraṁ."
    },
    {
      "id": "tha-ap51:16.1",
      "pali": "Pubbakammena saṁyutto,"
    },
    {
      "id": "tha-ap51:16.2",
      "pali": "ekaggo susamāhito;"
    },
    {
      "id": "tha-ap51:16.3",
      "pali": "Buddhassa oraso putto,"
    },
    {
      "id": "tha-ap51:16.4",
      "pali": "dhammajomhi sunimmito."
    },
    {
      "id": "tha-ap51:17.1",
      "pali": "Dhammarājaṁ upagamma,"
    },
    {
      "id": "tha-ap51:17.2",
      "pali": "apucchiṁ pañhamuttamaṁ;"
    },
    {
      "id": "tha-ap51:17.3",
      "pali": "Kathayanto ca me pañhaṁ,"
    },
    {
      "id": "tha-ap51:17.4",
      "pali": "dhammasotaṁ upānayi."
    },
    {
      "id": "tha-ap51:18.1",
      "pali": "Tassāhaṁ dhammamaññāya,"
    },
    {
      "id": "tha-ap51:18.2",
      "pali": "vihāsiṁ sāsane rato;"
    },
    {
      "id": "tha-ap51:18.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap51:18.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap51:19.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap51:19.2",
      "pali": "jalajuttamanāyako;"
    },
    {
      "id": "tha-ap51:19.3",
      "pali": "Nibbāyi anupādāno,"
    },
    {
      "id": "tha-ap51:19.4",
      "pali": "dīpova telasaṅkhayā."
    },
    {
      "id": "tha-ap51:20.1",
      "pali": "Sattayojanikaṁ āsi,"
    },
    {
      "id": "tha-ap51:20.2",
      "pali": "thūpañca ratanāmayaṁ;"
    },
    {
      "id": "tha-ap51:20.3",
      "pali": "Dhajaṁ tattha apūjesiṁ,"
    },
    {
      "id": "tha-ap51:20.4",
      "pali": "sabbabhaddaṁ manoramaṁ."
    },
    {
      "id": "tha-ap51:21.1",
      "pali": "Kassapassa ca buddhassa,"
    },
    {
      "id": "tha-ap51:21.2",
      "pali": "tisso nāmaggasāvako;"
    },
    {
      "id": "tha-ap51:21.3",
      "pali": "Putto me oraso āsi,"
    },
    {
      "id": "tha-ap51:21.4",
      "pali": "dāyādo jinasāsane."
    },
    {
      "id": "tha-ap51:22.1",
      "pali": "Tassa hīnena manasā,"
    },
    {
      "id": "tha-ap51:22.2",
      "pali": "vācaṁ bhāsiṁ abhaddakaṁ;"
    },
    {
      "id": "tha-ap51:22.3",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "tha-ap51:22.4",
      "pali": "pacchā me āsi bhaddakaṁ."
    },
    {
      "id": "tha-ap51:23.1",
      "pali": "Upavattane sālavane,"
    },
    {
      "id": "tha-ap51:23.2",
      "pali": "pacchime sayane muni;"
    },
    {
      "id": "tha-ap51:23.3",
      "pali": "Pabbājesi mahāvīro,"
    },
    {
      "id": "tha-ap51:23.4",
      "pali": "hito kāruṇiko jino."
    },
    {
      "id": "tha-ap51:24.1",
      "pali": "Ajjeva dāni pabbajjā,"
    },
    {
      "id": "tha-ap51:24.2",
      "pali": "ajjeva upasampadā;"
    },
    {
      "id": "tha-ap51:24.3",
      "pali": "Ajjeva parinibbānaṁ,"
    },
    {
      "id": "tha-ap51:24.4",
      "pali": "sammukhā dvipaduttame."
    },
    {
      "id": "tha-ap51:25.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap51:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap51:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap51:26.1",
      "pali": "Itthaṁ sudaṁ āyasmā subhaddo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap51:27.1",
      "pali": "Subhaddattherassāpadānaṁ navamaṁ."
    }
  ]
}
