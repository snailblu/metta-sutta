{
  "uid": "ja150",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja150:1.1",
      "pali": "“Asantaṁ yo paggaṇhāti,"
    },
    {
      "id": "ja150:1.2",
      "pali": "asantaṁ cūpasevati;"
    },
    {
      "id": "ja150:1.3",
      "pali": "Tameva ghāsaṁ kurute,"
    },
    {
      "id": "ja150:1.4",
      "pali": "byaggho sañjīvako yathā”ti."
    },
    {
      "id": "ja150:2.1",
      "pali": "Sañjīvajātakaṁ dasamaṁ."
    },
    {
      "id": "ja150:2.2",
      "pali": "Kakaṇṭakavaggo pannarasamo."
    },
    {
      "id": "ja150:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja150:4.1",
      "pali": "Sukhamedhati daṇḍavaro ca puna,"
    },
    {
      "id": "ja150:4.2",
      "pali": "Lasi vāladhi pañcamarādhavaro;"
    },
    {
      "id": "ja150:4.3",
      "pali": "Samahodadhi kattika bondi puna,"
    },
    {
      "id": "ja150:4.4",
      "pali": "Caturaṅgulabyagghavarena dasāti."
    },
    {
      "id": "ja150:5.1",
      "pali": "Uparimapaṇṇāsako."
    },
    {
      "id": "ja150:6.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja150:7.1",
      "pali": "Apaṇṇakaṁ sīlavaggakuruṅga,"
    },
    {
      "id": "ja150:7.2",
      "pali": "Kulāvakaṁ atthakāmena pañcamaṁ;"
    },
    {
      "id": "ja150:7.3",
      "pali": "Āsīso itthivaruṇaṁ apāyi,"
    },
    {
      "id": "ja150:7.4",
      "pali": "Littavaggena te dasa;"
    },
    {
      "id": "ja150:7.5",
      "pali": "Parosataṁ haṁci kusanāḷi,"
    },
    {
      "id": "ja150:7.6",
      "pali": "Asampadaṁ kakaṇṭakavaggo."
    },
    {
      "id": "ja150:8.1",
      "pali": "Ekanipātamhilaṅkatanti."
    },
    {
      "id": "ja150:9.1",
      "pali": "Ekakanipātaṁ niṭṭhitaṁ."
    }
  ]
}
