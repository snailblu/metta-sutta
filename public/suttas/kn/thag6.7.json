{
  "uid": "thag6.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.7:1.1",
      "pali": "“Uṭṭhehi nisīda kātiyāna,"
    },
    {
      "id": "thag6.7:1.2",
      "pali": "Mā niddābahulo ahu jāgarassu;"
    },
    {
      "id": "thag6.7:1.3",
      "pali": "Mā taṁ alasaṁ pamattabandhu,"
    },
    {
      "id": "thag6.7:1.4",
      "pali": "Kūṭeneva jinātu maccurājā."
    },
    {
      "id": "thag6.7:2.1",
      "pali": "Seyyathāpi mahāsamuddavego,"
    },
    {
      "id": "thag6.7:2.2",
      "pali": "Evaṁ jātijarātivattate taṁ;"
    },
    {
      "id": "thag6.7:2.3",
      "pali": "So karohi sudīpamattano tvaṁ,"
    },
    {
      "id": "thag6.7:2.4",
      "pali": "Na hi tāṇaṁ tava vijjateva aññaṁ."
    },
    {
      "id": "thag6.7:3.1",
      "pali": "Satthā hi vijesi maggametaṁ,"
    },
    {
      "id": "thag6.7:3.2",
      "pali": "Saṅgā jātijarābhayā atītaṁ;"
    },
    {
      "id": "thag6.7:3.3",
      "pali": "Pubbāpararattamappamatto,"
    },
    {
      "id": "thag6.7:3.4",
      "pali": "Anuyuñjassu daḷhaṁ karohi yogaṁ."
    },
    {
      "id": "thag6.7:4.1",
      "pali": "Purimāni pamuñca bandhanāni,"
    },
    {
      "id": "thag6.7:4.2",
      "pali": "Saṅghāṭikhuramuṇḍabhikkhabhojī;"
    },
    {
      "id": "thag6.7:4.3",
      "pali": "Mā khiḍḍāratiñca mā niddaṁ,"
    },
    {
      "id": "thag6.7:4.4",
      "pali": "Anuyuñjittha jhāya kātiyāna."
    },
    {
      "id": "thag6.7:5.1",
      "pali": "Jhāyāhi jināhi kātiyāna,"
    },
    {
      "id": "thag6.7:5.2",
      "pali": "Yogakkhemapathesu kovidosi;"
    },
    {
      "id": "thag6.7:5.3",
      "pali": "Pappuyya anuttaraṁ visuddhiṁ,"
    },
    {
      "id": "thag6.7:5.4",
      "pali": "Parinibbāhisi vārināva joti."
    },
    {
      "id": "thag6.7:6.1",
      "pali": "Pajjotakaro parittaraṁso,"
    },
    {
      "id": "thag6.7:6.2",
      "pali": "Vātena vinamyate latāva;"
    },
    {
      "id": "thag6.7:6.3",
      "pali": "Evampi tuvaṁ anādiyāno,"
    },
    {
      "id": "thag6.7:6.4",
      "pali": "Māraṁ indasagotta niddhunāhi;"
    },
    {
      "id": "thag6.7:6.5",
      "pali": "So vedayitāsu vītarāgo,"
    },
    {
      "id": "thag6.7:6.6",
      "pali": "Kālaṁ kaṅkha idheva sītibhūto”ti."
    },
    {
      "id": "thag6.7:6.7",
      "pali": "… Kātiyāno thero …."
    }
  ]
}
