{
  "uid": "ja342",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja342:1.1",
      "pali": "“Asakkhiṁ vata attānaṁ,"
    },
    {
      "id": "ja342:1.2",
      "pali": "uddhātuṁ udakā thalaṁ;"
    },
    {
      "id": "ja342:1.3",
      "pali": "Na dānāhaṁ puna tuyhaṁ,"
    },
    {
      "id": "ja342:1.4",
      "pali": "vasaṁ gacchāmi vārija."
    },
    {
      "id": "ja342:2.1",
      "pali": "Alametehi ambehi,"
    },
    {
      "id": "ja342:2.2",
      "pali": "jambūhi panasehi ca;"
    },
    {
      "id": "ja342:2.3",
      "pali": "Yāni pāraṁ samuddassa,"
    },
    {
      "id": "ja342:2.4",
      "pali": "varaṁ mayhaṁ udumbaro."
    },
    {
      "id": "ja342:3.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja342:3.2",
      "pali": "na khippamanubujjhati;"
    },
    {
      "id": "ja342:3.3",
      "pali": "Amittavasamanveti,"
    },
    {
      "id": "ja342:3.4",
      "pali": "pacchā ca anutappati."
    },
    {
      "id": "ja342:4.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja342:4.2",
      "pali": "khippameva nibodhati;"
    },
    {
      "id": "ja342:4.3",
      "pali": "Muccate sattusambādhā,"
    },
    {
      "id": "ja342:4.4",
      "pali": "na ca pacchānutappatī”ti."
    },
    {
      "id": "ja342:5.1",
      "pali": "Vānarajātakaṁ dutiyaṁ."
    }
  ]
}
