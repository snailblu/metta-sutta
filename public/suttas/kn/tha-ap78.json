{
  "uid": "tha-ap78",
  "title": "6 Tiṇasantharadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap78:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap78:1.2",
      "pali": "mahājātassaro ahu;"
    },
    {
      "id": "tha-ap78:1.3",
      "pali": "Satapattehi sañchanno,"
    },
    {
      "id": "tha-ap78:1.4",
      "pali": "nānāsakuṇamālayo."
    },
    {
      "id": "tha-ap78:2.1",
      "pali": "Tamhi nhatvā ca pitvā ca,"
    },
    {
      "id": "tha-ap78:2.2",
      "pali": "avidūre vasāmahaṁ;"
    },
    {
      "id": "tha-ap78:2.3",
      "pali": "Addasaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap78:2.4",
      "pali": "gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap78:3.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap78:3.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap78:3.3",
      "pali": "Abbhato oruhitvāna,"
    },
    {
      "id": "tha-ap78:3.4",
      "pali": "bhūmiyaṁṭhāsi tāvade."
    },
    {
      "id": "tha-ap78:4.1",
      "pali": "Visāṇena tiṇaṁ gayha,"
    },
    {
      "id": "tha-ap78:4.2",
      "pali": "nisīdanamadāsahaṁ;"
    },
    {
      "id": "tha-ap78:4.3",
      "pali": "Nisīdi bhagavā tattha,"
    },
    {
      "id": "tha-ap78:4.4",
      "pali": "tisso lokagganāyako."
    },
    {
      "id": "tha-ap78:5.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap78:5.2",
      "pali": "avandi lokanāyakaṁ;"
    },
    {
      "id": "tha-ap78:5.3",
      "pali": "Paṭikuṭiko apasakkiṁ,"
    },
    {
      "id": "tha-ap78:5.4",
      "pali": "nijjhāyanto mahāmuniṁ."
    },
    {
      "id": "tha-ap78:6.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap78:6.2",
      "pali": "nimmānaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap78:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap78:6.4",
      "pali": "santharassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap78:7.1",
      "pali": "Ito dutiyake kappe,"
    },
    {
      "id": "tha-ap78:7.2",
      "pali": "miga sammatakhattiyo;"
    },
    {
      "id": "tha-ap78:7.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap78:7.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap78:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap78:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap78:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap78:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇasantharadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap78:10.1",
      "pali": "Tiṇasantharadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
