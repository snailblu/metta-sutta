{
  "uid": "tha-ap457",
  "title": "Akkamanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap457:1.1",
      "pali": "“Kakusandhassa munino,"
    },
    {
      "id": "tha-ap457:1.2",
      "pali": "brāhmaṇassa vusīmato;"
    },
    {
      "id": "tha-ap457:1.3",
      "pali": "Divāvihāraṁ vajato,"
    },
    {
      "id": "tha-ap457:1.4",
      "pali": "akkamanamadāsahaṁ."
    },
    {
      "id": "tha-ap457:2.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "tha-ap457:2.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap457:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap457:2.4",
      "pali": "akkamanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap457:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap457:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap457:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap457:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap457:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap457:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap457:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap457:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap457:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap457:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā akkamanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap457:7.1",
      "pali": "Akkamanadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
