{
  "uid": "kp6",
  "title": "Ratanasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "kp6:1.1",
      "pali": "Yānīdha bhūtāni samāgatāni,"
    },
    {
      "id": "kp6:1.2",
      "pali": "Bhummāni vā yāni va antalikkhe;"
    },
    {
      "id": "kp6:1.3",
      "pali": "Sabbeva bhūtā sumanā bhavantu,"
    },
    {
      "id": "kp6:1.4",
      "pali": "Athopi sakkacca suṇantu bhāsitaṁ."
    },
    {
      "id": "kp6:2.1",
      "pali": "Tasmā hi bhūtā nisāmetha sabbe,"
    },
    {
      "id": "kp6:2.2",
      "pali": "Mettaṁ karotha mānusiyā pajāya;"
    },
    {
      "id": "kp6:2.3",
      "pali": "Divā ca ratto ca haranti ye baliṁ,"
    },
    {
      "id": "kp6:2.4",
      "pali": "Tasmā hi ne rakkhatha appamattā."
    },
    {
      "id": "kp6:3.1",
      "pali": "Yaṁ kiñci vittaṁ idha vā huraṁ vā,"
    },
    {
      "id": "kp6:3.2",
      "pali": "Saggesu vā yaṁ ratanaṁ paṇītaṁ;"
    },
    {
      "id": "kp6:3.3",
      "pali": "Na no samaṁ atthi tathāgatena,"
    },
    {
      "id": "kp6:3.4",
      "pali": "Idampi buddhe ratanaṁ paṇītaṁ;"
    },
    {
      "id": "kp6:3.5",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:4.1",
      "pali": "Khayaṁ virāgaṁ amataṁ paṇītaṁ,"
    },
    {
      "id": "kp6:4.2",
      "pali": "Yadajjhagā sakyamunī samāhito;"
    },
    {
      "id": "kp6:4.3",
      "pali": "Na tena dhammena samatthi kiñci,"
    },
    {
      "id": "kp6:4.4",
      "pali": "Idampi dhamme ratanaṁ paṇītaṁ;"
    },
    {
      "id": "kp6:4.5",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:5.1",
      "pali": "Yaṁ buddhaseṭṭho parivaṇṇayī suciṁ,"
    },
    {
      "id": "kp6:5.2",
      "pali": "Samādhimānantarikaññamāhu;"
    },
    {
      "id": "kp6:5.3",
      "pali": "Samādhinā tena samo na vijjati,"
    },
    {
      "id": "kp6:5.4",
      "pali": "Idampi dhamme ratanaṁ paṇītaṁ;"
    },
    {
      "id": "kp6:5.5",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:6.1",
      "pali": "Ye puggalā aṭṭha sataṁ pasatthā,"
    },
    {
      "id": "kp6:6.2",
      "pali": "Cattāri etāni yugāni honti;"
    },
    {
      "id": "kp6:6.3",
      "pali": "Te dakkhiṇeyyā sugatassa sāvakā,"
    },
    {
      "id": "kp6:6.4",
      "pali": "Etesu dinnāni mahapphalāni;"
    },
    {
      "id": "kp6:6.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:6.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:7.1",
      "pali": "Ye suppayuttā manasā daḷhena,"
    },
    {
      "id": "kp6:7.2",
      "pali": "Nikkāmino gotamasāsanamhi;"
    },
    {
      "id": "kp6:7.3",
      "pali": "Te pattipattā amataṁ vigayha,"
    },
    {
      "id": "kp6:7.4",
      "pali": "Laddhā mudhā nibbutiṁ bhuñjamānā;"
    },
    {
      "id": "kp6:7.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:7.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:8.1",
      "pali": "Yathindakhīlo pathavissito siyā,"
    },
    {
      "id": "kp6:8.2",
      "pali": "Catubbhi vātehi asampakampiyo;"
    },
    {
      "id": "kp6:8.3",
      "pali": "Tathūpamaṁ sappurisaṁ vadāmi,"
    },
    {
      "id": "kp6:8.4",
      "pali": "Yo ariyasaccāni avecca passati;"
    },
    {
      "id": "kp6:8.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:8.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:9.1",
      "pali": "Ye ariyasaccāni vibhāvayanti,"
    },
    {
      "id": "kp6:9.2",
      "pali": "Gambhīrapaññena sudesitāni;"
    },
    {
      "id": "kp6:9.3",
      "pali": "Kiñcāpi te honti bhusaṁ pamattā,"
    },
    {
      "id": "kp6:9.4",
      "pali": "Na te bhavaṁ aṭṭhamamādiyanti;"
    },
    {
      "id": "kp6:9.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:9.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:10.1",
      "pali": "Sahāvassa dassanasampadāya,"
    },
    {
      "id": "kp6:10.2",
      "pali": "Tayassu dhammā jahitā bhavanti;"
    },
    {
      "id": "kp6:10.3",
      "pali": "Sakkāyadiṭṭhī vicikicchitañca,"
    },
    {
      "id": "kp6:10.4",
      "pali": "Sīlabbataṁ vāpi yadatthi kiñci."
    },
    {
      "id": "kp6:11.1",
      "pali": "Catūhapāyehi ca vippamutto,"
    },
    {
      "id": "kp6:11.2",
      "pali": "Chaccābhiṭhānāni abhabba kātuṁ;"
    },
    {
      "id": "kp6:11.3",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:11.4",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:12.1",
      "pali": "Kiñcāpi so kamma karoti pāpakaṁ,"
    },
    {
      "id": "kp6:12.2",
      "pali": "Kāyena vācā uda cetasā vā;"
    },
    {
      "id": "kp6:12.3",
      "pali": "Abhabba so tassa paṭicchadāya,"
    },
    {
      "id": "kp6:12.4",
      "pali": "Abhabbatā diṭṭhapadassa vuttā;"
    },
    {
      "id": "kp6:12.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:12.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:13.1",
      "pali": "Vanappagumbe yatha phussitagge,"
    },
    {
      "id": "kp6:13.2",
      "pali": "Gimhānamāse paṭhamasmiṁ gimhe;"
    },
    {
      "id": "kp6:13.3",
      "pali": "Tathūpamaṁ dhammavaraṁ adesayi,"
    },
    {
      "id": "kp6:13.4",
      "pali": "Nibbānagāmiṁ paramaṁ hitāya;"
    },
    {
      "id": "kp6:13.5",
      "pali": "Idampi buddhe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:13.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:14.1",
      "pali": "Varo varaññū varado varāharo,"
    },
    {
      "id": "kp6:14.2",
      "pali": "Anuttaro dhammavaraṁ adesayi;"
    },
    {
      "id": "kp6:14.3",
      "pali": "Idampi buddhe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:14.4",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:15.1",
      "pali": "Khīṇaṁ purāṇaṁ nava natthi sambhavaṁ,"
    },
    {
      "id": "kp6:15.2",
      "pali": "Virattacittāyatike bhavasmiṁ;"
    },
    {
      "id": "kp6:15.3",
      "pali": "Te khīṇabījā avirūḷhichandā,"
    },
    {
      "id": "kp6:15.4",
      "pali": "Nibbanti dhīrā yathāyaṁ padīpo;"
    },
    {
      "id": "kp6:15.5",
      "pali": "Idampi saṅghe ratanaṁ paṇītaṁ,"
    },
    {
      "id": "kp6:15.6",
      "pali": "Etena saccena suvatthi hotu."
    },
    {
      "id": "kp6:16.1",
      "pali": "Yānīdha bhūtāni samāgatāni,"
    },
    {
      "id": "kp6:16.2",
      "pali": "Bhummāni vā yāni va antalikkhe;"
    },
    {
      "id": "kp6:16.3",
      "pali": "Tathāgataṁ devamanussapūjitaṁ,"
    },
    {
      "id": "kp6:16.4",
      "pali": "Buddhaṁ namassāma suvatthi hotu."
    },
    {
      "id": "kp6:17.1",
      "pali": "Yānīdha bhūtāni samāgatāni,"
    },
    {
      "id": "kp6:17.2",
      "pali": "Bhummāni vā yāni va antalikkhe;"
    },
    {
      "id": "kp6:17.3",
      "pali": "Tathāgataṁ devamanussapūjitaṁ,"
    },
    {
      "id": "kp6:17.4",
      "pali": "Dhammaṁ namassāma suvatthi hotu."
    },
    {
      "id": "kp6:18.1",
      "pali": "Yānīdha bhūtāni samāgatāni,"
    },
    {
      "id": "kp6:18.2",
      "pali": "Bhummāni vā yāni va antalikkhe;"
    },
    {
      "id": "kp6:18.3",
      "pali": "Tathāgataṁ devamanussapūjitaṁ,"
    },
    {
      "id": "kp6:18.4",
      "pali": "Saṅghaṁ namassāma suvatthi hotūti."
    },
    {
      "id": "kp6:19.1",
      "pali": "Ratanasuttaṁ."
    }
  ]
}
