{
  "uid": "ja489",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja489:1.1",
      "pali": "“Mahesī surucino bhariyā,"
    },
    {
      "id": "ja489:1.2",
      "pali": "Ānītā paṭhamaṁ ahaṁ;"
    },
    {
      "id": "ja489:1.3",
      "pali": "Dasa vassasahassāni,"
    },
    {
      "id": "ja489:1.4",
      "pali": "Yaṁ maṁ surucimānayi."
    },
    {
      "id": "ja489:2.1",
      "pali": "Sāhaṁ brāhmaṇa rājānaṁ,"
    },
    {
      "id": "ja489:2.2",
      "pali": "vedehaṁ mithilaggahaṁ;"
    },
    {
      "id": "ja489:2.3",
      "pali": "Nābhijānāmi kāyena,"
    },
    {
      "id": "ja489:2.4",
      "pali": "vācāya uda cetasā;"
    },
    {
      "id": "ja489:2.5",
      "pali": "Suruciṁ atimaññittha,"
    },
    {
      "id": "ja489:2.6",
      "pali": "āvi vā yadi vā raho."
    },
    {
      "id": "ja489:3.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:3.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:3.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:3.4",
      "pali": "muddhā phalatu sattadhā."
    },
    {
      "id": "ja489:4.1",
      "pali": "Bhattu mama sassu mātā,"
    },
    {
      "id": "ja489:4.2",
      "pali": "pitā cāpi ca sassuro;"
    },
    {
      "id": "ja489:4.3",
      "pali": "Te maṁ brahme vinetāro,"
    },
    {
      "id": "ja489:4.4",
      "pali": "yāva aṭṭhaṁsu jīvitaṁ."
    },
    {
      "id": "ja489:5.1",
      "pali": "Sāhaṁ ahiṁsāratinī,"
    },
    {
      "id": "ja489:5.2",
      "pali": "kāmasā dhammacārinī;"
    },
    {
      "id": "ja489:5.3",
      "pali": "Sakkaccaṁ te upaṭṭhāsiṁ,"
    },
    {
      "id": "ja489:5.4",
      "pali": "rattindivamatanditā."
    },
    {
      "id": "ja489:6.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:6.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:6.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:6.4",
      "pali": "muddhā phalatu sattadhā."
    },
    {
      "id": "ja489:7.1",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "ja489:7.2",
      "pali": "sahabhariyāni brāhmaṇa;"
    },
    {
      "id": "ja489:7.3",
      "pali": "Tāsu issā vā kodho vā,"
    },
    {
      "id": "ja489:7.4",
      "pali": "nāhu mayhaṁ kudācanaṁ."
    },
    {
      "id": "ja489:8.1",
      "pali": "Hitena tāsaṁ nandāmi,"
    },
    {
      "id": "ja489:8.2",
      "pali": "na ca me kāci appiyā;"
    },
    {
      "id": "ja489:8.3",
      "pali": "Attānaṁvānukampāmi,"
    },
    {
      "id": "ja489:8.4",
      "pali": "sadā sabbā sapattiyo."
    },
    {
      "id": "ja489:9.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:9.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:9.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:9.4",
      "pali": "muddhā phalatu sattadhā."
    },
    {
      "id": "ja489:10.1",
      "pali": "Dāse kammakare pesse,"
    },
    {
      "id": "ja489:10.2",
      "pali": "ye caññe anujīvino;"
    },
    {
      "id": "ja489:10.3",
      "pali": "Pesemi sahadhammena,"
    },
    {
      "id": "ja489:10.4",
      "pali": "sadā pamuditindriyā."
    },
    {
      "id": "ja489:11.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:11.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:11.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:11.4",
      "pali": "muddhā phalatu sattadhā."
    },
    {
      "id": "ja489:12.1",
      "pali": "Samaṇe brāhmaṇe cāpi,"
    },
    {
      "id": "ja489:12.2",
      "pali": "aññe cāpi vanibbake;"
    },
    {
      "id": "ja489:12.3",
      "pali": "Tappemi annapānena,"
    },
    {
      "id": "ja489:12.4",
      "pali": "sadā payatapāṇinī."
    },
    {
      "id": "ja489:13.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:13.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:13.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:13.4",
      "pali": "muddhā phalatu sattadhā."
    },
    {
      "id": "ja489:14.1",
      "pali": "Cātuddasiṁ pañcaddasiṁ,"
    },
    {
      "id": "ja489:14.2",
      "pali": "Yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "ja489:14.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "ja489:14.4",
      "pali": "Aṭṭhaṅgasusamāgataṁ;"
    },
    {
      "id": "ja489:14.5",
      "pali": "Uposathaṁ upavasāmi,"
    },
    {
      "id": "ja489:14.6",
      "pali": "Sadā sīlesu saṁvutā."
    },
    {
      "id": "ja489:15.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja489:15.2",
      "pali": "putto uppajjataṁ ise;"
    },
    {
      "id": "ja489:15.3",
      "pali": "Musā me bhaṇamānāya,"
    },
    {
      "id": "ja489:15.4",
      "pali": "muddhā phalatu sattadhā”."
    },
    {
      "id": "ja489:16.1",
      "pali": "“Sabbeva te dhammaguṇā,"
    },
    {
      "id": "ja489:16.2",
      "pali": "rājaputti yasassini;"
    },
    {
      "id": "ja489:16.3",
      "pali": "Saṁvijjanti tayi bhadde,"
    },
    {
      "id": "ja489:16.4",
      "pali": "ye tvaṁ kittesi attani."
    },
    {
      "id": "ja489:17.1",
      "pali": "Khattiyo jātisampanno,"
    },
    {
      "id": "ja489:17.2",
      "pali": "abhijāto yasassimā;"
    },
    {
      "id": "ja489:17.3",
      "pali": "Dhammarājā videhānaṁ,"
    },
    {
      "id": "ja489:17.4",
      "pali": "putto uppajjate tava”."
    },
    {
      "id": "ja489:18.1",
      "pali": "“Dummī rajojalladharo,"
    },
    {
      "id": "ja489:18.2",
      "pali": "aghe vehāyasaṁ ṭhito;"
    },
    {
      "id": "ja489:18.3",
      "pali": "Manuññaṁ bhāsase vācaṁ,"
    },
    {
      "id": "ja489:18.4",
      "pali": "yaṁ mayhaṁ hadayaṅgamaṁ."
    },
    {
      "id": "ja489:19.1",
      "pali": "Devatānusi saggamhā,"
    },
    {
      "id": "ja489:19.2",
      "pali": "isi vāsi mahiddhiko;"
    },
    {
      "id": "ja489:19.3",
      "pali": "Ko vāsi tvaṁ anuppatto,"
    },
    {
      "id": "ja489:19.4",
      "pali": "attānaṁ me pavedaya”."
    },
    {
      "id": "ja489:20.1",
      "pali": "“Yaṁ devasaṅghā vandanti,"
    },
    {
      "id": "ja489:20.2",
      "pali": "sudhammāyaṁ samāgatā;"
    },
    {
      "id": "ja489:20.3",
      "pali": "Sohaṁ sakko sahassakkho,"
    },
    {
      "id": "ja489:20.4",
      "pali": "āgatosmi tavantike."
    },
    {
      "id": "ja489:21.1",
      "pali": "Itthiyo jīvalokasmiṁ,"
    },
    {
      "id": "ja489:21.2",
      "pali": "yā hoti samacārinī;"
    },
    {
      "id": "ja489:21.3",
      "pali": "Medhāvinī sīlavatī,"
    },
    {
      "id": "ja489:21.4",
      "pali": "sassudevā patibbatā."
    },
    {
      "id": "ja489:22.1",
      "pali": "Tādisāya sumedhāya,"
    },
    {
      "id": "ja489:22.2",
      "pali": "sucikammāya nāriyā;"
    },
    {
      "id": "ja489:22.3",
      "pali": "Devā dassanamāyanti,"
    },
    {
      "id": "ja489:22.4",
      "pali": "mānusiyā amānusā."
    },
    {
      "id": "ja489:23.1",
      "pali": "Tvañca bhadde suciṇṇena,"
    },
    {
      "id": "ja489:23.2",
      "pali": "pubbe sucaritena ca;"
    },
    {
      "id": "ja489:23.3",
      "pali": "Idha rājakule jātā,"
    },
    {
      "id": "ja489:23.4",
      "pali": "sabbakāmasamiddhinī."
    },
    {
      "id": "ja489:24.1",
      "pali": "Ayañca te rājaputti,"
    },
    {
      "id": "ja489:24.2",
      "pali": "ubhayattha kaṭaggaho;"
    },
    {
      "id": "ja489:24.3",
      "pali": "Devalokūpapattī ca,"
    },
    {
      "id": "ja489:24.4",
      "pali": "kittī ca idha jīvite."
    },
    {
      "id": "ja489:25.1",
      "pali": "Ciraṁ sumedhe sukhinī,"
    },
    {
      "id": "ja489:25.2",
      "pali": "dhammamattani pālaya;"
    },
    {
      "id": "ja489:25.3",
      "pali": "Esāhaṁ tidivaṁ yāmi,"
    },
    {
      "id": "ja489:25.4",
      "pali": "piyaṁ me tava dassanan”ti."
    },
    {
      "id": "ja489:26.1",
      "pali": "Surucijātakaṁ chaṭṭhaṁ."
    }
  ]
}
