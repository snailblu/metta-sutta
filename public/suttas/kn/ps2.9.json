{
  "uid": "ps2.9",
  "title": "2.9. Balakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps2.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "ps2.9:1.2",
      "pali": "“Pañcimāni, bhikkhave, balāni."
    },
    {
      "id": "ps2.9:1.3",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "ps2.9:1.4",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—"
    },
    {
      "id": "ps2.9:1.5",
      "pali": "imāni kho, bhikkhave, pañca balāni."
    },
    {
      "id": "ps2.9:2.1",
      "pali": "Api ca aṭṭhasaṭṭhi balāni—"
    },
    {
      "id": "ps2.9:2.2",
      "pali": "saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ, hiribalaṁ, ottappabalaṁ, paṭisaṅkhānabalaṁ, bhāvanābalaṁ, anavajjabalaṁ, saṅgahabalaṁ, khantibalaṁ, paññattibalaṁ, nijjhattibalaṁ, issariyabalaṁ, adhiṭṭhānabalaṁ, samathabalaṁ, vipassanābalaṁ, dasa sekhabalāni, dasa asekhabalāni, dasa khīṇāsavabalāni, dasa iddhibalāni, dasa tathāgatabalāni”."
    },
    {
      "id": "ps2.9:3.1",
      "pali": "Katamaṁ <b>saddhābalaṁ?</b>"
    },
    {
      "id": "ps2.9:3.2",
      "pali": "Assaddhiye na kampatīti—saddhābalaṁ."
    },
    {
      "id": "ps2.9:3.3",
      "pali": "Sahajātānaṁ dhammānaṁ upatthambhanaṭṭhena saddhābalaṁ, kilesānaṁ pariyādānaṭṭhena saddhābalaṁ, paṭivedhādivisodhanaṭṭhena saddhābalaṁ, cittassa adhiṭṭhānaṭṭhena saddhābalaṁ, cittassa vodānaṭṭhena saddhābalaṁ, visesādhigamaṭṭhena saddhābalaṁ, uttaripaṭivedhaṭṭhena saddhābalaṁ, saccābhisamayaṭṭhena saddhābalaṁ, nirodhe patiṭṭhāpakaṭṭhena saddhābalaṁ."
    },
    {
      "id": "ps2.9:3.4",
      "pali": "Idaṁ saddhābalaṁ."
    },
    {
      "id": "ps2.9:4.1",
      "pali": "Katamaṁ <b>vīriyabalaṁ?</b>"
    },
    {
      "id": "ps2.9:4.2",
      "pali": "Kosajje na kampatīti—vīriyabalaṁ."
    },
    {
      "id": "ps2.9:4.3",
      "pali": "Sahajātānaṁ dhammānaṁ upatthambhanaṭṭhena vīriyabalaṁ, kilesānaṁ pariyādānaṭṭhena vīriyabalaṁ, paṭivedhādivisodhanaṭṭhena vīriyabalaṁ, cittassa adhiṭṭhānaṭṭhena vīriyabalaṁ, cittassa vodānaṭṭhena vīriyabalaṁ, visesādhigamaṭṭhena vīriyabalaṁ, uttaripaṭivedhaṭṭhena vīriyabalaṁ, saccābhisamayaṭṭhena vīriyabalaṁ, nirodhe patiṭṭhāpakaṭṭhena vīriyabalaṁ."
    },
    {
      "id": "ps2.9:4.4",
      "pali": "Idaṁ vīriyabalaṁ."
    },
    {
      "id": "ps2.9:5.1",
      "pali": "Katamaṁ <b>satibalaṁ?</b>"
    },
    {
      "id": "ps2.9:5.2",
      "pali": "Pamāde na kampatīti—satibalaṁ."
    },
    {
      "id": "ps2.9:5.3",
      "pali": "Sahajātānaṁ dhammānaṁ upatthambhanaṭṭhena satibalaṁ …pe…"
    },
    {
      "id": "ps2.9:5.4",
      "pali": "nirodhe patiṭṭhāpakaṭṭhena satibalaṁ."
    },
    {
      "id": "ps2.9:5.5",
      "pali": "Idaṁ satibalaṁ."
    },
    {
      "id": "ps2.9:6.1",
      "pali": "Katamaṁ <b>samādhibalaṁ?</b>"
    },
    {
      "id": "ps2.9:6.2",
      "pali": "Uddhacce na kampatīti—samādhibalaṁ."
    },
    {
      "id": "ps2.9:6.3",
      "pali": "Sahajātānaṁ dhammānaṁ upatthambhanaṭṭhena samādhibalaṁ …pe…"
    },
    {
      "id": "ps2.9:6.4",
      "pali": "nirodhe patiṭṭhāpakaṭṭhena samādhibalaṁ."
    },
    {
      "id": "ps2.9:6.5",
      "pali": "Idaṁ samādhibalaṁ."
    },
    {
      "id": "ps2.9:7.1",
      "pali": "Katamaṁ <b>paññābalaṁ?</b>"
    },
    {
      "id": "ps2.9:7.2",
      "pali": "Avijjāya na kampatīti—paññābalaṁ."
    },
    {
      "id": "ps2.9:7.3",
      "pali": "Sahajātānaṁ dhammānaṁ upatthambhanaṭṭhena paññābalaṁ …pe…"
    },
    {
      "id": "ps2.9:7.4",
      "pali": "nirodhe patiṭṭhāpakaṭṭhena paññābalaṁ."
    },
    {
      "id": "ps2.9:7.5",
      "pali": "Idaṁ paññābalaṁ."
    },
    {
      "id": "ps2.9:8.1",
      "pali": "Katamaṁ <b>hiribalaṁ?</b>"
    },
    {
      "id": "ps2.9:8.2",
      "pali": "Nekkhammena kāmacchandaṁ hirīyatīti—"
    },
    {
      "id": "ps2.9:8.3",
      "pali": "hiribalaṁ."
    },
    {
      "id": "ps2.9:8.4",
      "pali": "Abyāpādena byāpādaṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.5",
      "pali": "Ālokasaññāya thinamiddhaṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.6",
      "pali": "Avikkhepena uddhaccaṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.7",
      "pali": "Dhammavavatthānena vicikicchaṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.8",
      "pali": "Ñāṇena avijjaṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.9",
      "pali": "Pāmojjena aratiṁ hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.10",
      "pali": "Paṭhamena jhānena nīvaraṇe hirīyatīti—hiribalaṁ …pe…"
    },
    {
      "id": "ps2.9:8.11",
      "pali": "arahattamaggena sabbakilese hirīyatīti—hiribalaṁ."
    },
    {
      "id": "ps2.9:8.12",
      "pali": "Idaṁ hiribalaṁ."
    },
    {
      "id": "ps2.9:9.1",
      "pali": "Katamaṁ <b>ottappabalaṁ?</b>"
    },
    {
      "id": "ps2.9:9.2",
      "pali": "Nekkhammena kāmacchandaṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.3",
      "pali": "Abyāpādena byāpādaṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.4",
      "pali": "Ālokasaññāya thinamiddhaṁ ottappatīti— ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.5",
      "pali": "Avikkhepena uddhaccaṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.6",
      "pali": "Dhammavavatthānena vicikicchaṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.7",
      "pali": "Ñāṇena avijjaṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.8",
      "pali": "Pāmojjena aratiṁ ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.9",
      "pali": "Paṭhamena jhānena nīvaraṇe ottappatīti—ottappabalaṁ …pe…"
    },
    {
      "id": "ps2.9:9.10",
      "pali": "arahattamaggena sabbakilese ottappatīti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:9.11",
      "pali": "Idaṁ ottappabalaṁ."
    },
    {
      "id": "ps2.9:10.1",
      "pali": "Katamaṁ <b>paṭisaṅkhānabalaṁ?</b>"
    },
    {
      "id": "ps2.9:10.2",
      "pali": "Nekkhammena kāmacchandaṁ paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.3",
      "pali": "Abyāpādena byāpādaṁ paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.4",
      "pali": "Ālokasaññāya thinamiddhaṁ paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.5",
      "pali": "Avikkhepena uddhaccaṁ paṭisaṅkhātīti— paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.6",
      "pali": "Dhammavavatthānena vicikicchaṁ paṭisaṅkhātīti— paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.7",
      "pali": "Ñāṇena avijjaṁ paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.8",
      "pali": "Pāmojjena aratiṁ paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.9",
      "pali": "Paṭhamena jhānena nīvaraṇe paṭisaṅkhātīti—paṭisaṅkhānabalaṁ …pe…"
    },
    {
      "id": "ps2.9:10.10",
      "pali": "arahattamaggena sabbakilese paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:10.11",
      "pali": "Idaṁ paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:11.1",
      "pali": "Katamaṁ <b>bhāvanābalaṁ?</b>"
    },
    {
      "id": "ps2.9:11.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.3",
      "pali": "Byāpādaṁ pajahanto abyāpādaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.4",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.5",
      "pali": "Uddhaccaṁ pajahanto avikkhepaṁ bhāvetīti— bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.6",
      "pali": "Vicikicchaṁ pajahanto dhammavavatthānaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.7",
      "pali": "Avijjaṁ pajahanto ñāṇaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.8",
      "pali": "Aratiṁ pajahanto pāmojjaṁ bhāvetīti—bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.9",
      "pali": "Nīvaraṇe pajahanto paṭhamaṁ jhānaṁ bhāvetīti— bhāvanābalaṁ …pe…"
    },
    {
      "id": "ps2.9:11.10",
      "pali": "sabbakilese pajahanto arahattamaggaṁ bhāvetīti— bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:11.11",
      "pali": "Idaṁ bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:12.1",
      "pali": "Katamaṁ <b>anavajjabalaṁ?</b>"
    },
    {
      "id": "ps2.9:12.2",
      "pali": "Kāmacchandassa pahīnattā nekkhamme natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.3",
      "pali": "Byāpādassa pahīnattā abyāpāde natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.4",
      "pali": "Thinamiddhassa pahīnattā ālokasaññāya natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.5",
      "pali": "Uddhaccassa pahīnattā avikkhepe natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.6",
      "pali": "Vicikicchāya pahīnattā dhammavavatthāne natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.7",
      "pali": "Avijjāya pahīnattā ñāṇe natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.8",
      "pali": "Aratiyā pahīnattā pāmojje natthi kiñci vajjanti anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.9",
      "pali": "Nīvaraṇānaṁ pahīnattā paṭhamajjhāne natthi kiñci vajjanti—anavajjabalaṁ …pe…"
    },
    {
      "id": "ps2.9:12.10",
      "pali": "sabbakilesānaṁ pahīnattā arahattamagge natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:12.11",
      "pali": "Idaṁ anavajjabalaṁ."
    },
    {
      "id": "ps2.9:13.1",
      "pali": "Katamaṁ <b>saṅgahabalaṁ?</b>"
    },
    {
      "id": "ps2.9:13.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammavasena cittaṁ saṅgaṇhātīti—saṅgahabalaṁ."
    },
    {
      "id": "ps2.9:13.3",
      "pali": "Byāpādaṁ pajahanto abyāpādavasena cittaṁ saṅgaṇhātīti—saṅgahabalaṁ."
    },
    {
      "id": "ps2.9:13.4",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññāvasena cittaṁ saṅgaṇhātīti—saṅgahabalaṁ …pe…"
    },
    {
      "id": "ps2.9:13.5",
      "pali": "sabbakilese pajahanto arahattamaggavasena cittaṁ saṅgaṇhātīti—saṅgahabalaṁ."
    },
    {
      "id": "ps2.9:13.6",
      "pali": "Idaṁ saṅgahabalaṁ."
    },
    {
      "id": "ps2.9:14.1",
      "pali": "Katamaṁ <b>khantibalaṁ?</b>"
    },
    {
      "id": "ps2.9:14.2",
      "pali": "Kāmacchandassa pahīnattā nekkhammaṁ khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.3",
      "pali": "Byāpādassa pahīnattā abyāpādo khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.4",
      "pali": "Thinamiddhassa pahīnattā ālokasaññā khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.5",
      "pali": "Uddhaccassa pahīnattā avikkhepo khamatīti— khantibalaṁ."
    },
    {
      "id": "ps2.9:14.6",
      "pali": "Vicikicchāya pahīnattā dhammavavatthānaṁ khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.7",
      "pali": "Avijjāya pahīnattā ñāṇaṁ khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.8",
      "pali": "Aratiyā pahīnattā pāmojjaṁ khamatīti—khantibalaṁ."
    },
    {
      "id": "ps2.9:14.9",
      "pali": "Nīvaraṇānaṁ pahīnattā paṭhamaṁ jhānaṁ khamatīti— khantibalaṁ …pe…"
    },
    {
      "id": "ps2.9:14.10",
      "pali": "sabbakilesānaṁ pahīnattā arahattamaggo khamatīti— khantibalaṁ."
    },
    {
      "id": "ps2.9:14.11",
      "pali": "Idaṁ khantibalaṁ."
    },
    {
      "id": "ps2.9:15.1",
      "pali": "Katamaṁ <b>paññattibalaṁ?</b>"
    },
    {
      "id": "ps2.9:15.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammavasena cittaṁ paññāpetīti—"
    },
    {
      "id": "ps2.9:15.3",
      "pali": "paññattibalaṁ."
    },
    {
      "id": "ps2.9:15.4",
      "pali": "Byāpādaṁ pajahanto abyāpādavasena cittaṁ paññāpetīti—paññattibalaṁ."
    },
    {
      "id": "ps2.9:15.5",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññāvasena cittaṁ paññāpetīti—paññattibalaṁ …pe…"
    },
    {
      "id": "ps2.9:15.6",
      "pali": "sabbakilese pajahanto arahattamaggavasena cittaṁ paññāpetīti—paññattibalaṁ."
    },
    {
      "id": "ps2.9:15.7",
      "pali": "Idaṁ paññattibalaṁ."
    },
    {
      "id": "ps2.9:16.1",
      "pali": "Katamaṁ <b>nijjhattibalaṁ?</b>"
    },
    {
      "id": "ps2.9:16.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammavasena cittaṁ nijjhāpetīti—nijjhattibalaṁ."
    },
    {
      "id": "ps2.9:16.3",
      "pali": "Byāpādaṁ pajahanto abyāpādavasena cittaṁ nijjhāpetīti—nijjhattibalaṁ."
    },
    {
      "id": "ps2.9:16.4",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññāvasena cittaṁ nijjhāpetīti— nijjhattibalaṁ …pe…"
    },
    {
      "id": "ps2.9:16.5",
      "pali": "sabbakilese pajahanto arahattamaggavasena cittaṁ nijjhāpetīti—nijjhattibalaṁ."
    },
    {
      "id": "ps2.9:16.6",
      "pali": "Idaṁ nijjhattibalaṁ."
    },
    {
      "id": "ps2.9:17.1",
      "pali": "Katamaṁ <b>issariyabalaṁ?</b>"
    },
    {
      "id": "ps2.9:17.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammavasena cittaṁ vasaṁ vattetīti—issariyabalaṁ."
    },
    {
      "id": "ps2.9:17.3",
      "pali": "Byāpādaṁ pajahanto abyāpādavasena cittaṁ vasaṁ vattetīti—issariyabalaṁ."
    },
    {
      "id": "ps2.9:17.4",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññāvasena cittaṁ vasaṁ vattetīti— issariyabalaṁ …pe…"
    },
    {
      "id": "ps2.9:17.5",
      "pali": "sabbakilese pajahanto arahattamaggavasena cittaṁ vasaṁ vattetīti—issariyabalaṁ."
    },
    {
      "id": "ps2.9:17.6",
      "pali": "Idaṁ issariyabalaṁ."
    },
    {
      "id": "ps2.9:18.1",
      "pali": "Katamaṁ <b>adhiṭṭhānabalaṁ?</b>"
    },
    {
      "id": "ps2.9:18.2",
      "pali": "Kāmacchandaṁ pajahanto nekkhammavasena cittaṁ adhiṭṭhātīti—adhiṭṭhānabalaṁ."
    },
    {
      "id": "ps2.9:18.3",
      "pali": "Byāpādaṁ pajahanto abyāpādavasena cittaṁ adhiṭṭhātīti—adhiṭṭhānabalaṁ."
    },
    {
      "id": "ps2.9:18.4",
      "pali": "Thinamiddhaṁ pajahanto ālokasaññāvasena cittaṁ adhiṭṭhātīti— adhiṭṭhānabalaṁ …pe…"
    },
    {
      "id": "ps2.9:18.5",
      "pali": "sabbakilese pajahanto arahattamaggavasena cittaṁ adhiṭṭhātīti—adhiṭṭhānabalaṁ."
    },
    {
      "id": "ps2.9:18.6",
      "pali": "Idaṁ adhiṭṭhānabalaṁ."
    },
    {
      "id": "ps2.9:19.1",
      "pali": "Katamaṁ <b>samathabalaṁ?</b>"
    },
    {
      "id": "ps2.9:19.2",
      "pali": "Nekkhammavasena cittassa ekaggatā avikkhepo samathabalaṁ, abyāpādavasena cittassa ekaggatā avikkhepo samathabalaṁ, ālokasaññāvasena cittassa ekaggatā avikkhepo samathabalaṁ …pe…"
    },
    {
      "id": "ps2.9:19.3",
      "pali": "paṭinissaggānupassī assāsavasena cittassa ekaggatā avikkhepo samathabalaṁ, paṭinissaggānupassī passāsavasena cittassa ekaggatā avikkhepo samathabalaṁ."
    },
    {
      "id": "ps2.9:20.1",
      "pali": "<b>Samathabalan</b>ti kenaṭṭhena samathabalaṁ?"
    },
    {
      "id": "ps2.9:20.2",
      "pali": "Paṭhamena jhānena nīvaraṇe na kampatīti— samathabalaṁ."
    },
    {
      "id": "ps2.9:20.3",
      "pali": "Dutiyena jhānena vitakkavicāre na kampatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.4",
      "pali": "Tatiyena jhānena pītiyā na kampatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.5",
      "pali": "Catutthena jhānena sukhadukkhe na kampatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.6",
      "pali": "Ākāsānañcāyatanasamāpattiyā rūpasaññāya paṭighasaññāya nānattasaññāya na kampatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.7",
      "pali": "Viññāṇañcāyatanasamāpattiyā ākāsānañcāyatanasaññāya na kampatīti— samathabalaṁ."
    },
    {
      "id": "ps2.9:20.8",
      "pali": "Ākiñcaññāyatanasamāpattiyā viññāṇañcāyatanasaññāya na kampatīti— samathabalaṁ."
    },
    {
      "id": "ps2.9:20.9",
      "pali": "Nevasaññānāsaññāyatanasamāpattiyā ākiñcaññāyatanasaññāya na kampatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.10",
      "pali": "Uddhacce ca uddhaccasahagatakilese ca khandhe ca na kampati na calati na vedhatīti—samathabalaṁ."
    },
    {
      "id": "ps2.9:20.11",
      "pali": "Idaṁ samathabalaṁ."
    },
    {
      "id": "ps2.9:21.1",
      "pali": "Katamaṁ <b>vipassanābalaṁ</b>?"
    },
    {
      "id": "ps2.9:21.2",
      "pali": "Aniccānupassanā vipassanābalaṁ, dukkhānupassanā vipassanābalaṁ …pe…"
    },
    {
      "id": "ps2.9:21.3",
      "pali": "paṭinissaggānupassanā vipassanābalaṁ, rūpe aniccānupassanā vipassanābalaṁ, rūpe dukkhānupassanā vipassanābalaṁ …pe…"
    },
    {
      "id": "ps2.9:21.4",
      "pali": "rūpe paṭinissaggānupassanā vipassanābalaṁ, vedanāya …pe…"
    },
    {
      "id": "ps2.9:21.5",
      "pali": "saññāya …"
    },
    {
      "id": "ps2.9:21.6",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "ps2.9:21.7",
      "pali": "viññāṇe …"
    },
    {
      "id": "ps2.9:21.8",
      "pali": "cakkhusmiṁ …pe…"
    },
    {
      "id": "ps2.9:21.9",
      "pali": "jarāmaraṇe aniccānupassanā vipassanābalaṁ, jarāmaraṇe dukkhānupassanā vipassanābalaṁ …pe…"
    },
    {
      "id": "ps2.9:21.10",
      "pali": "jarāmaraṇe paṭinissaggānupassanā vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.11",
      "pali": "<b>Vipassanābalan</b>ti kenaṭṭhena vipassanābalaṁ?"
    },
    {
      "id": "ps2.9:21.12",
      "pali": "Aniccānupassanāya niccasaññāya na kampatīti— vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.13",
      "pali": "Dukkhānupassanāya sukhasaññāya na kampatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.14",
      "pali": "Anattānupassanāya attasaññāya kampatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.15",
      "pali": "Nibbidānupassanāya nandiyā na kampatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.16",
      "pali": "Virāgānupassanāya rāge na kampatīti— vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.17",
      "pali": "Nirodhānupassanāya samudaye na kampatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.18",
      "pali": "Paṭinissaggānupassanāya ādāne na kampatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.19",
      "pali": "Avijjāya ca avijjāsahagatakilese ca khandhe ca na kampati na calati na vedhatīti— vipassanābalaṁ."
    },
    {
      "id": "ps2.9:21.20",
      "pali": "Idaṁ vipassanābalaṁ."
    },
    {
      "id": "ps2.9:22.1",
      "pali": "Katamāni <b>dasa sekhabalāni, dasa asekhabalāni?</b>"
    },
    {
      "id": "ps2.9:22.2",
      "pali": "Sammādiṭṭhiṁ sikkhatīti—sekhabalaṁ."
    },
    {
      "id": "ps2.9:22.3",
      "pali": "Tattha sikkhitattā asekhabalaṁ."
    },
    {
      "id": "ps2.9:22.4",
      "pali": "Sammāsaṅkappaṁ sikkhatīti—sekhabalaṁ."
    },
    {
      "id": "ps2.9:22.5",
      "pali": "Tattha sikkhitattā—"
    },
    {
      "id": "ps2.9:22.6",
      "pali": "asekhabalaṁ."
    },
    {
      "id": "ps2.9:22.7",
      "pali": "Sammāvācaṁ …pe…"
    },
    {
      "id": "ps2.9:22.8",
      "pali": "sammākammantaṁ …"
    },
    {
      "id": "ps2.9:22.9",
      "pali": "sammāājīvaṁ …"
    },
    {
      "id": "ps2.9:22.10",
      "pali": "sammāvāyāmaṁ …"
    },
    {
      "id": "ps2.9:22.11",
      "pali": "sammāsatiṁ …"
    },
    {
      "id": "ps2.9:22.12",
      "pali": "sammāsamādhiṁ …"
    },
    {
      "id": "ps2.9:22.13",
      "pali": "sammāñāṇaṁ …pe…"
    },
    {
      "id": "ps2.9:22.14",
      "pali": "sammāvimuttiṁ sikkhatīti—sekhabalaṁ."
    },
    {
      "id": "ps2.9:22.15",
      "pali": "Tattha sikkhitattā—"
    },
    {
      "id": "ps2.9:22.16",
      "pali": "asekhabalaṁ."
    },
    {
      "id": "ps2.9:22.17",
      "pali": "Imāni dasa sekhabalāni, dasa asekhabalāni."
    },
    {
      "id": "ps2.9:23.1",
      "pali": "Katamāni <b>dasa khīṇāsavabalāni?</b>"
    },
    {
      "id": "ps2.9:23.2",
      "pali": "Idha khīṇāsavassa bhikkhuno aniccato sabbe saṅkhārā yathābhūtaṁ sammappaññāya sudiṭṭhā honti."
    },
    {
      "id": "ps2.9:23.3",
      "pali": "Yampi khīṇāsavassa bhikkhuno aniccato sabbe saṅkhārā yathābhūtaṁ sammappaññāya sudiṭṭhā honti, idampi khīṇāsavassa bhikkhuno balaṁ hoti, yaṁ balaṁ āgamma khīṇāsavo bhikkhu āsavānaṁ khayaṁ paṭijānāti—“khīṇā me āsavā”ti."
    },
    {
      "id": "ps2.9:24.1",
      "pali": "Puna caparaṁ khīṇāsavassa bhikkhuno aṅgārakāsūpamā kāmā yathābhūtaṁ sammappaññāya sudiṭṭhā honti."
    },
    {
      "id": "ps2.9:24.2",
      "pali": "Yampi khīṇāsavassa bhikkhuno aṅgārakāsūpamā kāmā yathābhūtaṁ sammappaññāya sudiṭṭhā honti, idampi khīṇāsavassa bhikkhuno balaṁ hoti, yaṁ balaṁ āgamma khīṇāsavo bhikkhu āsavānaṁ khayaṁ paṭijānāti—“khīṇā me āsavā”ti."
    },
    {
      "id": "ps2.9:25.1",
      "pali": "Puna caparaṁ khīṇāsavassa bhikkhuno vivekaninnaṁ cittaṁ hoti vivekapoṇaṁ vivekapabbhāraṁ vivekaṭṭhaṁ nekkhammābhirataṁ byantībhūtaṁ sabbaso āsavaṭṭhāniyehi dhammehi."
    },
    {
      "id": "ps2.9:25.2",
      "pali": "Yampi khīṇāsavassa bhikkhuno vivekaninnaṁ cittaṁ hoti vivekapoṇaṁ vivekapabbhāraṁ vivekaṭṭhaṁ nekkhammābhirataṁ byantībhūtaṁ sabbaso āsavaṭṭhāniyehi dhammehi, idampi khīṇāsavassa bhikkhuno balaṁ hoti, yaṁ balaṁ āgamma khīṇāsavo bhikkhu āsavānaṁ khayaṁ paṭijānāti—“khīṇā me āsavā”ti."
    },
    {
      "id": "ps2.9:26.1",
      "pali": "Puna caparaṁ khīṇāsavassa bhikkhuno cattāro satipaṭṭhānā bhāvitā honti subhāvitā."
    },
    {
      "id": "ps2.9:26.2",
      "pali": "Yampi khīṇāsavassa bhikkhuno cattāro satipaṭṭhānā bhāvitā honti subhāvitā, idampi khīṇāsavassa bhikkhuno balaṁ hoti, yaṁ balaṁ āgamma khīṇāsavo bhikkhu āsavānaṁ khayaṁ paṭijānāti—“khīṇā me āsavā”ti."
    },
    {
      "id": "ps2.9:27.1",
      "pali": "Puna caparaṁ khīṇāsavassa bhikkhuno cattāro sammappadhānā bhāvitā honti subhāvitā …pe…"
    },
    {
      "id": "ps2.9:27.2",
      "pali": "cattāro iddhipādā bhāvitā honti subhāvitā …"
    },
    {
      "id": "ps2.9:27.3",
      "pali": "pañcindriyāni bhāvitāni honti subhāvitāni …"
    },
    {
      "id": "ps2.9:27.4",
      "pali": "pañca balāni bhāvitāni honti subhāvitāni …"
    },
    {
      "id": "ps2.9:27.5",
      "pali": "satta bojjhaṅgā bhāvitā honti subhāvitā …pe…"
    },
    {
      "id": "ps2.9:27.6",
      "pali": "ariyo aṭṭhaṅgiko maggo bhāvito hoti subhāvito."
    },
    {
      "id": "ps2.9:27.7",
      "pali": "Yampi khīṇāsavassa bhikkhuno aṭṭhaṅgiko maggo bhāvito hoti subhāvito, idampi khīṇāsavassa bhikkhuno balaṁ hoti, yaṁ balaṁ āgamma khīṇāsavo bhikkhu āsavānaṁ khayaṁ paṭijānāti—“khīṇā me āsavā”ti."
    },
    {
      "id": "ps2.9:27.8",
      "pali": "Imāni dasa khīṇāsavabalāni."
    },
    {
      "id": "ps2.9:28.1",
      "pali": "Katamāni <b>dasa iddhibalāni?</b>"
    },
    {
      "id": "ps2.9:28.2",
      "pali": "Adhiṭṭhānā iddhi, vikubbanā iddhi, manomayā iddhi, ñāṇavipphārā iddhi, samādhivipphārā iddhi, ariyā iddhi, kammavipākajā iddhi, puññavato iddhi, vijjāmayā iddhi, tattha tattha sammā payogappaccayā ijjhanaṭṭhena iddhi—"
    },
    {
      "id": "ps2.9:28.3",
      "pali": "imāni dasa iddhibalāni."
    },
    {
      "id": "ps2.9:29.1",
      "pali": "Katamāni <b>dasa tathāgatabalāni?</b>"
    },
    {
      "id": "ps2.9:29.2",
      "pali": "Idha tathāgato ṭhānañca ṭhānato aṭṭhānañca aṭṭhānato yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:29.3",
      "pali": "Yampi tathāgato ṭhānañca ṭhānato aṭṭhānañca aṭṭhānato yathābhūtaṁ pajānāti, idampi tathāgatassa tathāgatabalaṁ hoti, yaṁ balaṁ āgamma tathāgato āsabhaṁ ṭhānaṁ paṭijānāti parisāsu sīhanādaṁ nadati, brahmacakkaṁ pavatteti."
    },
    {
      "id": "ps2.9:30.1",
      "pali": "Puna caparaṁ tathāgato atītānāgatapaccuppannānaṁ kammasamādānānaṁ ṭhānaso hetuso vipākaṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:30.2",
      "pali": "Yampi tathāgato atītānāgatapaccuppannānaṁ kammasamādānānaṁ ṭhānaso hetuso vipākaṁ yathābhūtaṁ pajānāti, idampi tathāgatassa tathāgatabalaṁ hoti, yaṁ balaṁ āgamma tathāgato āsabhaṁ ṭhānaṁ paṭijānāti, parisāsu sīhanādaṁ, nadati, brahmacakkaṁ pavatteti."
    },
    {
      "id": "ps2.9:31.1",
      "pali": "Puna caparaṁ tathāgato sabbatthagāminiṁ paṭipadaṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:31.2",
      "pali": "Yampi tathāgato sabbatthagāminiṁ paṭipadaṁ yathābhūtaṁ pajānāti, idampi tathāgatassa tathāgatabalaṁ hoti, yaṁ balaṁ āgamma tathāgato āsabhaṁ ṭhānaṁ paṭijānāti, parisāsu sīhanādaṁ nadati, brahmacakkaṁ pavatteti."
    },
    {
      "id": "ps2.9:32.1",
      "pali": "Puna caparaṁ tathāgato anekadhātuṁ nānādhātuṁ lokaṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:32.2",
      "pali": "Yampi tathāgato anekadhātuṁ nānādhātuṁ lokaṁ yathābhūtaṁ pajānāti, idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:33.1",
      "pali": "Puna caparaṁ tathāgato sattānaṁ nānādhimuttikataṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:33.2",
      "pali": "Yampi tathāgato sattānaṁ nānādhimuttikataṁ yathābhūtaṁ pajānāti, idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:34.1",
      "pali": "Puna caparaṁ tathāgato parasattānaṁ parapuggalānaṁ indriyaparopariyattaṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:34.2",
      "pali": "Yampi tathāgato parasattānaṁ parapuggalānaṁ indriyaparopariyattaṁ yathābhūtaṁ pajānāti, idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:35.1",
      "pali": "Puna caparaṁ tathāgato jhānavimokkhasamādhisamāpattīnaṁ saṅkilesaṁ vodānaṁ vuṭṭhānaṁ yathābhūtaṁ pajānāti."
    },
    {
      "id": "ps2.9:35.2",
      "pali": "Yampi tathāgato jhānavimokkhasamādhisamāpattīnaṁ saṅkilesaṁ vodānaṁ vuṭṭhānaṁ yathābhūtaṁ pajānāti, idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:36.1",
      "pali": "Puna caparaṁ tathāgato anekavihitaṁ pubbenivāsaṁ anussarati, seyyathidaṁ—"
    },
    {
      "id": "ps2.9:36.2",
      "pali": "ekampi jātiṁ dvepi jātiyo …pe…"
    },
    {
      "id": "ps2.9:36.3",
      "pali": "iti sākāraṁ sauddesaṁ anekavihitaṁ pubbenivāsaṁ anussarati."
    },
    {
      "id": "ps2.9:36.4",
      "pali": "Yampi tathāgato anekavihitaṁ pubbenivāsaṁ anussarati."
    },
    {
      "id": "ps2.9:36.5",
      "pali": "Seyyathidaṁ—"
    },
    {
      "id": "ps2.9:36.6",
      "pali": "ekampi jātiṁ dvepi jātiyo …pe…"
    },
    {
      "id": "ps2.9:36.7",
      "pali": "idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:37.1",
      "pali": "Puna caparaṁ tathāgato dibbena cakkhunā visuddhena atikkantamānusakena satte passati cavamāne upapajjamāne …pe…"
    },
    {
      "id": "ps2.9:37.2",
      "pali": "yampi tathāgato dibbena cakkhunā visuddhena atikkantamānusakena satte passati cavamāne upapajjamāne …pe…"
    },
    {
      "id": "ps2.9:37.3",
      "pali": "idampi tathāgatassa …pe…."
    },
    {
      "id": "ps2.9:38.1",
      "pali": "Puna caparaṁ tathāgato āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati."
    },
    {
      "id": "ps2.9:38.2",
      "pali": "Yampi tathāgato āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati, idampi tathāgatassa tathāgatabalaṁ hoti, yaṁ balaṁ āgamma tathāgato āsabhaṁ ṭhānaṁ paṭijānāti, parisāsu sīhanādaṁ nadati, brahmacakkaṁ pavatteti."
    },
    {
      "id": "ps2.9:38.3",
      "pali": "Imāni dasa tathāgatabalāni."
    },
    {
      "id": "ps2.9:39.1",
      "pali": "Kenaṭṭhena saddhābalaṁ?"
    },
    {
      "id": "ps2.9:39.2",
      "pali": "Kenaṭṭhena vīriyabalaṁ?"
    },
    {
      "id": "ps2.9:39.3",
      "pali": "Kenaṭṭhena satibalaṁ?"
    },
    {
      "id": "ps2.9:39.4",
      "pali": "Kenaṭṭhena samādhibalaṁ?"
    },
    {
      "id": "ps2.9:39.5",
      "pali": "Kenaṭṭhena paññābalaṁ?"
    },
    {
      "id": "ps2.9:39.6",
      "pali": "Kenaṭṭhena hiribalaṁ?"
    },
    {
      "id": "ps2.9:39.7",
      "pali": "Kenaṭṭhena ottappabalaṁ?"
    },
    {
      "id": "ps2.9:39.8",
      "pali": "Kenaṭṭhena paṭisaṅkhānabalaṁ …pe…"
    },
    {
      "id": "ps2.9:39.9",
      "pali": "kenaṭṭhena tathāgatabalaṁ?"
    },
    {
      "id": "ps2.9:40.1",
      "pali": "Assaddhiye akampiyaṭṭhena saddhābalaṁ."
    },
    {
      "id": "ps2.9:40.2",
      "pali": "Kosajje akampiyaṭṭhena vīriyabalaṁ."
    },
    {
      "id": "ps2.9:40.3",
      "pali": "Pamāde akampiyaṭṭhena satibalaṁ."
    },
    {
      "id": "ps2.9:40.4",
      "pali": "Uddhacce akampiyaṭṭhena samādhibalaṁ."
    },
    {
      "id": "ps2.9:40.5",
      "pali": "Avijjāya akampiyaṭṭhena paññābalaṁ."
    },
    {
      "id": "ps2.9:40.6",
      "pali": "Hirīyati pāpake akusale dhammeti—hiribalaṁ."
    },
    {
      "id": "ps2.9:40.7",
      "pali": "Ottappati pāpake akusale dhammeti—ottappabalaṁ."
    },
    {
      "id": "ps2.9:40.8",
      "pali": "Ñāṇena kilese paṭisaṅkhātīti—paṭisaṅkhānabalaṁ."
    },
    {
      "id": "ps2.9:40.9",
      "pali": "Tattha jātā dhammā ekarasā hontīti— bhāvanābalaṁ."
    },
    {
      "id": "ps2.9:40.10",
      "pali": "Tattha natthi kiñci vajjanti—anavajjabalaṁ."
    },
    {
      "id": "ps2.9:40.11",
      "pali": "Tena cittaṁ saṅgaṇhātīti—saṅgahabalaṁ."
    },
    {
      "id": "ps2.9:40.12",
      "pali": "Taṁ tassa khamatīti—"
    },
    {
      "id": "ps2.9:40.13",
      "pali": "khantibalaṁ."
    },
    {
      "id": "ps2.9:40.14",
      "pali": "Tena cittaṁ paññapetīti—paññattibalaṁ."
    },
    {
      "id": "ps2.9:40.15",
      "pali": "Tena cittaṁ nijjhāpetīti—nijjhattibalaṁ."
    },
    {
      "id": "ps2.9:40.16",
      "pali": "Tena cittaṁ vasaṁ vattetīti—issariyabalaṁ."
    },
    {
      "id": "ps2.9:40.17",
      "pali": "Tena cittaṁ adhiṭṭhātīti— adhiṭṭhānabalaṁ."
    },
    {
      "id": "ps2.9:40.18",
      "pali": "Tena cittaṁ ekagganti—samathabalaṁ."
    },
    {
      "id": "ps2.9:40.19",
      "pali": "Tattha jāte dhamme anupassatīti—vipassanābalaṁ."
    },
    {
      "id": "ps2.9:40.20",
      "pali": "Tattha sikkhatīti—sekhabalaṁ."
    },
    {
      "id": "ps2.9:40.21",
      "pali": "Tattha sikkhitattā—"
    },
    {
      "id": "ps2.9:40.22",
      "pali": "asekhabalaṁ."
    },
    {
      "id": "ps2.9:40.23",
      "pali": "Tena āsavā khīṇāti—khīṇāsavabalaṁ."
    },
    {
      "id": "ps2.9:40.24",
      "pali": "Tassa ijjhatīti—iddhibalaṁ."
    },
    {
      "id": "ps2.9:40.25",
      "pali": "Appameyyaṭṭhena tathāgatabalanti."
    },
    {
      "id": "ps2.9:40.26",
      "pali": "Balakathā niṭṭhitā."
    }
  ]
}
