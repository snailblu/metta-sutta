{
  "uid": "thag1.63",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.63:1.1",
      "pali": "“Cutā patanti patitā,"
    },
    {
      "id": "thag1.63:1.2",
      "pali": "giddhā ca punarāgatā;"
    },
    {
      "id": "thag1.63:1.3",
      "pali": "Kataṁ kiccaṁ rataṁ rammaṁ,"
    },
    {
      "id": "thag1.63:1.4",
      "pali": "sukhenanvāgataṁ sukhan”ti."
    },
    {
      "id": "thag1.63:1.5",
      "pali": "… Pakkho thero …."
    }
  ]
}
