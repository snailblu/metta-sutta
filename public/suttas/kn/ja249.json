{
  "uid": "ja249",
  "title": "Siṅgālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja249:1.1",
      "pali": "“Ekaputtako bhavissasi,"
    },
    {
      "id": "ja249:1.2",
      "pali": "Tvañca no hessasi issaro kule;"
    },
    {
      "id": "ja249:1.3",
      "pali": "Oroha dumasmā sālaka,"
    },
    {
      "id": "ja249:1.4",
      "pali": "Ehi dāni gharakaṁ vajemase”."
    },
    {
      "id": "ja249:2.1",
      "pali": "“Nanu maṁ suhadayoti maññasi,"
    },
    {
      "id": "ja249:2.2",
      "pali": "Yañca maṁ hanasi veḷuyaṭṭhiyā;"
    },
    {
      "id": "ja249:2.3",
      "pali": "Pakkambavane ramāmase,"
    },
    {
      "id": "ja249:2.4",
      "pali": "Gaccha tvaṁ gharakaṁ yathāsukhan”ti."
    },
    {
      "id": "ja249:3.1",
      "pali": "Sālakajātakaṁ navamaṁ."
    }
  ]
}
