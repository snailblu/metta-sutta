{
  "uid": "tha-ap143",
  "title": "1 Atichattiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap143:1.1",
      "pali": "“Parinibbute bhagavati,"
    },
    {
      "id": "tha-ap143:1.2",
      "pali": "atthadassīnaruttame;"
    },
    {
      "id": "tha-ap143:1.3",
      "pali": "Chattātichattaṁ kāretvā,"
    },
    {
      "id": "tha-ap143:1.4",
      "pali": "thūpamhi abhiropayiṁ."
    },
    {
      "id": "tha-ap143:2.1",
      "pali": "Kālena kālamāgantvā,"
    },
    {
      "id": "tha-ap143:2.2",
      "pali": "namassiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap143:2.3",
      "pali": "Pupphacchadanaṁ katvāna,"
    },
    {
      "id": "tha-ap143:2.4",
      "pali": "chattamhi abhiropayiṁ."
    },
    {
      "id": "tha-ap143:3.1",
      "pali": "Sattarase kappasate,"
    },
    {
      "id": "tha-ap143:3.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap143:3.3",
      "pali": "Manussattaṁ na gacchāmi,"
    },
    {
      "id": "tha-ap143:3.4",
      "pali": "thūpapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap143:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap143:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap143:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap143:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap143:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā atichattiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap143:6.1",
      "pali": "Atichattiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
