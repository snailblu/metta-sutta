{
  "uid": "thag1.53",
  "title": "Chaṭṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.53:1.1",
      "pali": "“Vassati devo yathā sugītaṁ,"
    },
    {
      "id": "thag1.53:1.2",
      "pali": "Channā me kuṭikā sukhā nivātā;"
    },
    {
      "id": "thag1.53:1.3",
      "pali": "Tassaṁ viharāmi appamatto,"
    },
    {
      "id": "thag1.53:1.4",
      "pali": "Atha ce patthayasi pavassa devā”ti."
    },
    {
      "id": "thag1.53:1.5",
      "pali": "… Valliyo thero …."
    }
  ]
}
