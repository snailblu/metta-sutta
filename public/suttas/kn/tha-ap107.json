{
  "uid": "tha-ap107",
  "title": "Muṭṭhipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap107:1.1",
      "pali": "“Sudassanoti nāmena,"
    },
    {
      "id": "tha-ap107:1.2",
      "pali": "mālākāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap107:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap107:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap107:2.1",
      "pali": "Jātipupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap107:2.2",
      "pali": "pūjayiṁ padumuttaraṁ;"
    },
    {
      "id": "tha-ap107:2.3",
      "pali": "Visuddhacakkhu sumano,"
    },
    {
      "id": "tha-ap107:2.4",
      "pali": "dibbacakkhuṁ samajjhagaṁ."
    },
    {
      "id": "tha-ap107:3.1",
      "pali": "Etissā pupphapūjāya,"
    },
    {
      "id": "tha-ap107:3.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap107:3.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap107:3.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap107:4.1",
      "pali": "Soḷasāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap107:4.2",
      "pali": "devuttarasanāmakā;"
    },
    {
      "id": "tha-ap107:4.3",
      "pali": "Chattiṁsamhi ito kappe,"
    },
    {
      "id": "tha-ap107:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap107:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap107:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap107:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap107:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā muṭṭhipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap107:7.1",
      "pali": "Muṭṭhipupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
