{
  "uid": "ja40",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja40:1.1",
      "pali": "“Kāmaṁ patāmi nirayaṁ,"
    },
    {
      "id": "ja40:1.2",
      "pali": "uddhampādo avaṁsiro;"
    },
    {
      "id": "ja40:1.3",
      "pali": "Nānariyaṁ karissāmi,"
    },
    {
      "id": "ja40:1.4",
      "pali": "handa piṇḍaṁ paṭiggahā”ti."
    },
    {
      "id": "ja40:2.1",
      "pali": "Khadiraṅgārajātakaṁ dasamaṁ."
    },
    {
      "id": "ja40:2.2",
      "pali": "Kulāvakavaggo catuttho."
    },
    {
      "id": "ja40:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja40:4.1",
      "pali": "Sirimātali dhītara pakkhivaro,"
    },
    {
      "id": "ja40:4.2",
      "pali": "Ratiyāgato mātāpitā ca puna;"
    },
    {
      "id": "ja40:4.3",
      "pali": "Jagatīruha vuḍḍha sukakkaṭako,"
    },
    {
      "id": "ja40:4.4",
      "pali": "Tathā nandakapiṇḍavarena dasāti."
    }
  ]
}
