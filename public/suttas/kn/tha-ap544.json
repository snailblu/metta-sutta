{
  "uid": "tha-ap544",
  "title": "Kaṅkhārevatattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap544:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap544:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "tha-ap544:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap544:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "tha-ap544:2.1",
      "pali": "Sīhahanu brahmagiro,"
    },
    {
      "id": "tha-ap544:2.2",
      "pali": "haṁsadundubhinissano;"
    },
    {
      "id": "tha-ap544:2.3",
      "pali": "Nāgavikkantagamano,"
    },
    {
      "id": "tha-ap544:2.4",
      "pali": "candasūrādikappabho."
    },
    {
      "id": "tha-ap544:3.1",
      "pali": "Mahāmatī mahāvīro,"
    },
    {
      "id": "tha-ap544:3.2",
      "pali": "mahājhāyī mahābalo;"
    },
    {
      "id": "tha-ap544:3.3",
      "pali": "Mahākāruṇiko nātho,"
    },
    {
      "id": "tha-ap544:3.4",
      "pali": "mahātamapanūdano."
    },
    {
      "id": "tha-ap544:4.1",
      "pali": "Sa kadāci tilokaggo,"
    },
    {
      "id": "tha-ap544:4.2",
      "pali": "veneyyaṁ vinayaṁ bahuṁ;"
    },
    {
      "id": "tha-ap544:4.3",
      "pali": "Dhammaṁ desesi sambuddho,"
    },
    {
      "id": "tha-ap544:4.4",
      "pali": "sattāsayavidū muni."
    },
    {
      "id": "tha-ap544:5.1",
      "pali": "Jhāyiṁ jhānarataṁ vīraṁ,"
    },
    {
      "id": "tha-ap544:5.2",
      "pali": "upasantaṁ anāvilaṁ;"
    },
    {
      "id": "tha-ap544:5.3",
      "pali": "Vaṇṇayanto parisatiṁ,"
    },
    {
      "id": "tha-ap544:5.4",
      "pali": "tosesi janataṁ jino."
    },
    {
      "id": "tha-ap544:6.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap544:6.2",
      "pali": "brāhmaṇo vedapāragū;"
    },
    {
      "id": "tha-ap544:6.3",
      "pali": "Dhammaṁ sutvāna mudito,"
    },
    {
      "id": "tha-ap544:6.4",
      "pali": "taṁ ṭhānamabhipatthayiṁ."
    },
    {
      "id": "tha-ap544:7.1",
      "pali": "Tadā jino viyākāsi,"
    },
    {
      "id": "tha-ap544:7.2",
      "pali": "saṅghamajjhe vināyako;"
    },
    {
      "id": "tha-ap544:7.3",
      "pali": "‘Mudito hohi tvaṁ brahme,"
    },
    {
      "id": "tha-ap544:7.4",
      "pali": "lacchase taṁ manorathaṁ."
    },
    {
      "id": "tha-ap544:8.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap544:8.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap544:8.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap544:8.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap544:9.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap544:9.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap544:9.3",
      "pali": "Revato nāma nāmena,"
    },
    {
      "id": "tha-ap544:9.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap544:10.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap544:10.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap544:10.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap544:10.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap544:11.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap544:11.2",
      "pali": "jātohaṁ koliye pure;"
    },
    {
      "id": "tha-ap544:11.3",
      "pali": "Khattiye kulasampanne,"
    },
    {
      "id": "tha-ap544:11.4",
      "pali": "iddhe phīte mahaddhane."
    },
    {
      "id": "tha-ap544:12.1",
      "pali": "Yadā kapilavatthusmiṁ,"
    },
    {
      "id": "tha-ap544:12.2",
      "pali": "buddho dhammamadesayi;"
    },
    {
      "id": "tha-ap544:12.3",
      "pali": "Tadā pasanno sugate,"
    },
    {
      "id": "tha-ap544:12.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap544:13.1",
      "pali": "Kaṅkhā me bahulā āsi,"
    },
    {
      "id": "tha-ap544:13.2",
      "pali": "kappākappe tahiṁ tahiṁ;"
    },
    {
      "id": "tha-ap544:13.3",
      "pali": "Sabbaṁ taṁ vinayī buddho,"
    },
    {
      "id": "tha-ap544:13.4",
      "pali": "desetvā dhammamuttamaṁ."
    },
    {
      "id": "tha-ap544:14.1",
      "pali": "Tatohaṁ tiṇṇasaṁsāro,"
    },
    {
      "id": "tha-ap544:14.2",
      "pali": "sadā jhānasukhe rato;"
    },
    {
      "id": "tha-ap544:14.3",
      "pali": "Viharāmi tadā buddho,"
    },
    {
      "id": "tha-ap544:14.4",
      "pali": "maṁ disvā etadabravi."
    },
    {
      "id": "tha-ap544:15.1",
      "pali": "‘Yā kāci kaṅkhā idha vā huraṁ vā,"
    },
    {
      "id": "tha-ap544:15.2",
      "pali": "Sakavediyā vā paravediyā vā;"
    },
    {
      "id": "tha-ap544:15.3",
      "pali": "Ye jhāyino tā pajahanti sabbā,"
    },
    {
      "id": "tha-ap544:15.4",
      "pali": "Ātāpino brahmacariyaṁ carantā’."
    },
    {
      "id": "tha-ap544:16.1",
      "pali": "Satasahasse kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap544:16.2",
      "pali": "phalaṁ dassesi me idha;"
    },
    {
      "id": "tha-ap544:16.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap544:16.4",
      "pali": "kilese jhāpayiṁ mama."
    },
    {
      "id": "tha-ap544:17.1",
      "pali": "Tato jhānarataṁ disvā,"
    },
    {
      "id": "tha-ap544:17.2",
      "pali": "buddho lokantagū muni;"
    },
    {
      "id": "tha-ap544:17.3",
      "pali": "Jhāyīnaṁ bhikkhūnaṁ aggo,"
    },
    {
      "id": "tha-ap544:17.4",
      "pali": "paññāpeti mahāmati."
    },
    {
      "id": "tha-ap544:18.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap544:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap544:18.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap544:19.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap544:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap544:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap544:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap544:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap544:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap544:21.1",
      "pali": "Itthaṁ sudaṁ āyasmā kaṅkhārevato thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap544:22.1",
      "pali": "Kaṅkhārevatattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
