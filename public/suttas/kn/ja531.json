{
  "uid": "ja531",
  "title": "Kusavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja531:1.1",
      "pali": "“Idaṁ te raṭṭhaṁ sadhanaṁ sayoggaṁ,"
    },
    {
      "id": "ja531:1.2",
      "pali": "Sakāyuraṁ sabbakāmūpapannaṁ;"
    },
    {
      "id": "ja531:1.3",
      "pali": "Idaṁ te rajjaṁ anusāsa amma,"
    },
    {
      "id": "ja531:1.4",
      "pali": "Gacchāmahaṁ yattha piyā pabhāvatī”."
    },
    {
      "id": "ja531:2.1",
      "pali": "“Anujjubhūtena haraṁ mahantaṁ,"
    },
    {
      "id": "ja531:2.2",
      "pali": "Divā ca ratto ca nisīthakāle;"
    },
    {
      "id": "ja531:2.3",
      "pali": "Paṭigaccha tvaṁ khippaṁ kusāvatiṁ kusa,"
    },
    {
      "id": "ja531:2.4",
      "pali": "Nicchāmi dubbaṇṇamahaṁ vasantaṁ”."
    },
    {
      "id": "ja531:3.1",
      "pali": "“Nāhaṁ gamissāmi ito kusāvatiṁ,"
    },
    {
      "id": "ja531:3.2",
      "pali": "Pabhāvatī vaṇṇapalobhito tava;"
    },
    {
      "id": "ja531:3.3",
      "pali": "Ramāmi maddassa niketaramme,"
    },
    {
      "id": "ja531:3.4",
      "pali": "Hitvāna raṭṭhaṁ tava dassane rato."
    },
    {
      "id": "ja531:4.1",
      "pali": "Pabhāvatī vaṇṇapalobhito tava,"
    },
    {
      "id": "ja531:4.2",
      "pali": "Sammūḷharūpo vicarāmi mediniṁ;"
    },
    {
      "id": "ja531:4.3",
      "pali": "Disaṁ na jānāmi kutomhi āgato,"
    },
    {
      "id": "ja531:4.4",
      "pali": "Tayamhi matto migamandalocane."
    },
    {
      "id": "ja531:5.1",
      "pali": "Suvaṇṇacīravasane,"
    },
    {
      "id": "ja531:5.2",
      "pali": "jātarūpasumekhale;"
    },
    {
      "id": "ja531:5.3",
      "pali": "Sussoṇi tava kāmā hi,"
    },
    {
      "id": "ja531:5.4",
      "pali": "nāhaṁ rajjena matthiko”."
    },
    {
      "id": "ja531:6.1",
      "pali": "“Abbhūti tassa bho hoti,"
    },
    {
      "id": "ja531:6.2",
      "pali": "yo anicchantamicchati;"
    },
    {
      "id": "ja531:6.3",
      "pali": "Akāmaṁ rāja kāmesi,"
    },
    {
      "id": "ja531:6.4",
      "pali": "akantaṁ kantumicchasi”."
    },
    {
      "id": "ja531:7.1",
      "pali": "“Akāmaṁ vā sakāmaṁ vā,"
    },
    {
      "id": "ja531:7.2",
      "pali": "yo naro labhate piyaṁ;"
    },
    {
      "id": "ja531:7.3",
      "pali": "Lābhamettha pasaṁsāma,"
    },
    {
      "id": "ja531:7.4",
      "pali": "alābho tattha pāpako”."
    },
    {
      "id": "ja531:8.1",
      "pali": "“Pāsāṇasāraṁ khaṇasi,"
    },
    {
      "id": "ja531:8.2",
      "pali": "kaṇikārassa dārunā;"
    },
    {
      "id": "ja531:8.3",
      "pali": "Vātaṁ jālena bādhesi,"
    },
    {
      "id": "ja531:8.4",
      "pali": "yo anicchantamicchasi”."
    },
    {
      "id": "ja531:9.1",
      "pali": "“Pāsāṇo nūna te hadaye,"
    },
    {
      "id": "ja531:9.2",
      "pali": "ohito mudulakkhaṇe;"
    },
    {
      "id": "ja531:9.3",
      "pali": "Yo te sātaṁ na vindāmi,"
    },
    {
      "id": "ja531:9.4",
      "pali": "tirojanapadāgato."
    },
    {
      "id": "ja531:10.1",
      "pali": "Yadā maṁ bhakuṭiṁ katvā,"
    },
    {
      "id": "ja531:10.2",
      "pali": "rājaputtī udikkhati;"
    },
    {
      "id": "ja531:10.3",
      "pali": "Āḷāriko tadā homi,"
    },
    {
      "id": "ja531:10.4",
      "pali": "rañño maddassantepure."
    },
    {
      "id": "ja531:11.1",
      "pali": "Yadā umhayamānā maṁ,"
    },
    {
      "id": "ja531:11.2",
      "pali": "rājaputtī udikkhati;"
    },
    {
      "id": "ja531:11.3",
      "pali": "Nāḷāriko tadā homi,"
    },
    {
      "id": "ja531:11.4",
      "pali": "rājā homi tadā kuso”."
    },
    {
      "id": "ja531:12.1",
      "pali": "“Sace hi vacanaṁ saccaṁ,"
    },
    {
      "id": "ja531:12.2",
      "pali": "nemittānaṁ bhavissati;"
    },
    {
      "id": "ja531:12.3",
      "pali": "Neva me tvaṁ patī assa,"
    },
    {
      "id": "ja531:12.4",
      "pali": "kāmaṁ chindantu sattadhā”."
    },
    {
      "id": "ja531:13.1",
      "pali": "“Sace hi vacanaṁ saccaṁ,"
    },
    {
      "id": "ja531:13.2",
      "pali": "aññesaṁ yadi vā mamaṁ;"
    },
    {
      "id": "ja531:13.3",
      "pali": "Neva tuyhaṁ patī atthi,"
    },
    {
      "id": "ja531:13.4",
      "pali": "añño sīhassarā kusā”."
    },
    {
      "id": "ja531:14.1",
      "pali": "“Nekkhaṁ gīvaṁ te kāressaṁ,"
    },
    {
      "id": "ja531:14.2",
      "pali": "patvā khujje kusāvatiṁ;"
    },
    {
      "id": "ja531:14.3",
      "pali": "Sace maṁ nāganāsūrū,"
    },
    {
      "id": "ja531:14.4",
      "pali": "olokeyya pabhāvatī."
    },
    {
      "id": "ja531:15.1",
      "pali": "Nekkhaṁ gīvaṁ te kāressaṁ,"
    },
    {
      "id": "ja531:15.2",
      "pali": "patvā khujje kusāvatiṁ;"
    },
    {
      "id": "ja531:15.3",
      "pali": "Sace maṁ nāganāsūrū,"
    },
    {
      "id": "ja531:15.4",
      "pali": "ālapeyya pabhāvatī."
    },
    {
      "id": "ja531:16.1",
      "pali": "Nekkhaṁ gīvaṁ te kāressaṁ,"
    },
    {
      "id": "ja531:16.2",
      "pali": "patvā khujje kusāvatiṁ;"
    },
    {
      "id": "ja531:16.3",
      "pali": "Sace maṁ nāganāsūrū,"
    },
    {
      "id": "ja531:16.4",
      "pali": "umhāyeyya pabhāvatī."
    },
    {
      "id": "ja531:17.1",
      "pali": "Nekkhaṁ gīvaṁ te kāressaṁ,"
    },
    {
      "id": "ja531:17.2",
      "pali": "patvā khujje kusāvatiṁ;"
    },
    {
      "id": "ja531:17.3",
      "pali": "Sace maṁ nāganāsūrū,"
    },
    {
      "id": "ja531:17.4",
      "pali": "pamhāyeyya pabhāvatī."
    },
    {
      "id": "ja531:18.1",
      "pali": "Nekkhaṁ gīvaṁ te kāressaṁ,"
    },
    {
      "id": "ja531:18.2",
      "pali": "patvā khujje kusāvatiṁ;"
    },
    {
      "id": "ja531:18.3",
      "pali": "Sace maṁ nāganāsūrū,"
    },
    {
      "id": "ja531:18.4",
      "pali": "pāṇīhi upasamphuse”."
    },
    {
      "id": "ja531:19.1",
      "pali": "“Na hi nūnāyaṁ rājaputtī,"
    },
    {
      "id": "ja531:19.2",
      "pali": "kuse sātampi vindati;"
    },
    {
      "id": "ja531:19.3",
      "pali": "Āḷārike bhate pose,"
    },
    {
      "id": "ja531:19.4",
      "pali": "vetanena anatthike”."
    },
    {
      "id": "ja531:20.1",
      "pali": "“Na hi nūnāyaṁ sā khujjā,"
    },
    {
      "id": "ja531:20.2",
      "pali": "labhati jivhāya chedanaṁ;"
    },
    {
      "id": "ja531:20.3",
      "pali": "Sunisitena satthena,"
    },
    {
      "id": "ja531:20.4",
      "pali": "evaṁ dubbhāsitaṁ bhaṇaṁ”."
    },
    {
      "id": "ja531:21.1",
      "pali": "“Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:21.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:21.3",
      "pali": "Mahāyasoti katvāna,"
    },
    {
      "id": "ja531:21.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:22.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:22.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:22.3",
      "pali": "Mahaddhanoti katvāna,"
    },
    {
      "id": "ja531:22.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:23.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:23.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:23.3",
      "pali": "Mahabbaloti katvāna,"
    },
    {
      "id": "ja531:23.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:24.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:24.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:24.3",
      "pali": "Mahāraṭṭhoti katvāna,"
    },
    {
      "id": "ja531:24.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:25.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:25.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:25.3",
      "pali": "Mahārājāti katvāna,"
    },
    {
      "id": "ja531:25.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:26.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:26.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:26.3",
      "pali": "Sīhassaroti katvāna,"
    },
    {
      "id": "ja531:26.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:27.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:27.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:27.3",
      "pali": "Vaggussaroti katvāna,"
    },
    {
      "id": "ja531:27.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:28.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:28.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:28.3",
      "pali": "Bindussaroti katvāna,"
    },
    {
      "id": "ja531:28.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:29.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:29.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:29.3",
      "pali": "Mañjussaroti katvāna,"
    },
    {
      "id": "ja531:29.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:30.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:30.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:30.3",
      "pali": "Madhussaroti katvāna,"
    },
    {
      "id": "ja531:30.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:31.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:31.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:31.3",
      "pali": "Satasippoti katvāna,"
    },
    {
      "id": "ja531:31.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:32.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:32.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:32.3",
      "pali": "Khattiyotipi katvāna,"
    },
    {
      "id": "ja531:32.4",
      "pali": "karassu rucire piyaṁ."
    },
    {
      "id": "ja531:33.1",
      "pali": "Mā naṁ rūpena pāmesi,"
    },
    {
      "id": "ja531:33.2",
      "pali": "ārohena pabhāvati;"
    },
    {
      "id": "ja531:33.3",
      "pali": "Kusarājāti katvāna,"
    },
    {
      "id": "ja531:33.4",
      "pali": "karassu rucire piyaṁ”."
    },
    {
      "id": "ja531:34.1",
      "pali": "“Ete nāgā upatthaddhā,"
    },
    {
      "id": "ja531:34.2",
      "pali": "sabbe tiṭṭhanti vammitā;"
    },
    {
      "id": "ja531:34.3",
      "pali": "Purā maddanti pākāraṁ,"
    },
    {
      "id": "ja531:34.4",
      "pali": "ānentetaṁ pabhāvatiṁ”."
    },
    {
      "id": "ja531:35.1",
      "pali": "“Satta bile karitvāna,"
    },
    {
      "id": "ja531:35.2",
      "pali": "ahametaṁ pabhāvatiṁ;"
    },
    {
      "id": "ja531:35.3",
      "pali": "Khattiyānaṁ padassāmi,"
    },
    {
      "id": "ja531:35.4",
      "pali": "ye maṁ hantuṁ idhāgatā”."
    },
    {
      "id": "ja531:36.1",
      "pali": "“Avuṭṭhahi rājaputtī,"
    },
    {
      "id": "ja531:36.2",
      "pali": "sāmā koseyyavāsinī;"
    },
    {
      "id": "ja531:36.3",
      "pali": "Assupuṇṇehi nettehi,"
    },
    {
      "id": "ja531:36.4",
      "pali": "dāsīgaṇapurakkhatā”."
    },
    {
      "id": "ja531:37.1",
      "pali": "“Taṁ nūna kakkūpanisevitaṁ mukhaṁ,"
    },
    {
      "id": "ja531:37.2",
      "pali": "Ādāsadantātharupaccavekkhitaṁ;"
    },
    {
      "id": "ja531:37.3",
      "pali": "Subhaṁ sunettaṁ virajaṁ anaṅgaṇaṁ,"
    },
    {
      "id": "ja531:37.4",
      "pali": "Chuddhaṁ vane ṭhassati khattiyehi."
    },
    {
      "id": "ja531:38.1",
      "pali": "Te nūna me asite vellitagge,"
    },
    {
      "id": "ja531:38.2",
      "pali": "Kese mudū candanasāralitte;"
    },
    {
      "id": "ja531:38.3",
      "pali": "Samākule sīvathikāya majjhe,"
    },
    {
      "id": "ja531:38.4",
      "pali": "Pādehi gijjhā parikaḍḍhissanti."
    },
    {
      "id": "ja531:39.1",
      "pali": "Tā nūna me tambanakhā sulomā,"
    },
    {
      "id": "ja531:39.2",
      "pali": "Bāhā mudū candanasāralittā;"
    },
    {
      "id": "ja531:39.3",
      "pali": "Chinnā vane ujjhitā khattiyehi,"
    },
    {
      "id": "ja531:39.4",
      "pali": "Gayha dhaṅko gacchati yenakāmaṁ."
    },
    {
      "id": "ja531:40.1",
      "pali": "Te nūna tālūpanibhe alambe,"
    },
    {
      "id": "ja531:40.2",
      "pali": "Nisevite kāsikacandanena;"
    },
    {
      "id": "ja531:40.3",
      "pali": "Thanesu me lambissati siṅgālo,"
    },
    {
      "id": "ja531:40.4",
      "pali": "Mātūva putto taruṇo tanūjo."
    },
    {
      "id": "ja531:41.1",
      "pali": "Taṁ nūna soṇiṁ puthulaṁ sukoṭṭitaṁ,"
    },
    {
      "id": "ja531:41.2",
      "pali": "Nisevitaṁ kañcanamekhalāhi;"
    },
    {
      "id": "ja531:41.3",
      "pali": "Chinnaṁ vane khattiyehī avatthaṁ,"
    },
    {
      "id": "ja531:41.4",
      "pali": "Siṅgālasaṅghā parikaḍḍhissanti."
    },
    {
      "id": "ja531:42.1",
      "pali": "Soṇā dhaṅkā siṅgālā ca,"
    },
    {
      "id": "ja531:42.2",
      "pali": "ye caññe santi dāṭhino;"
    },
    {
      "id": "ja531:42.3",
      "pali": "Ajarā nūna hessanti,"
    },
    {
      "id": "ja531:42.4",
      "pali": "bhakkhayitvā pabhāvatiṁ."
    },
    {
      "id": "ja531:43.1",
      "pali": "Sace maṁsāni hariṁsu,"
    },
    {
      "id": "ja531:43.2",
      "pali": "khattiyā dūragāmino;"
    },
    {
      "id": "ja531:43.3",
      "pali": "Aṭṭhīni amma yācitvā,"
    },
    {
      "id": "ja531:43.4",
      "pali": "anupathe dahātha naṁ."
    },
    {
      "id": "ja531:44.1",
      "pali": "Khettāni amma kāretvā,"
    },
    {
      "id": "ja531:44.2",
      "pali": "kaṇikārettha ropaya;"
    },
    {
      "id": "ja531:44.3",
      "pali": "Yadā te pupphitā assu,"
    },
    {
      "id": "ja531:44.4",
      "pali": "hemantānaṁ himaccaye;"
    },
    {
      "id": "ja531:44.5",
      "pali": "Sareyyātha mamaṁ amma,"
    },
    {
      "id": "ja531:44.6",
      "pali": "evaṁvaṇṇā pabhāvatī”."
    },
    {
      "id": "ja531:45.1",
      "pali": "“Tassā mātā udaṭṭhāsi,"
    },
    {
      "id": "ja531:45.2",
      "pali": "khattiyā devavaṇṇinī;"
    },
    {
      "id": "ja531:45.3",
      "pali": "Disvā asiñca sūnañca,"
    },
    {
      "id": "ja531:45.4",
      "pali": "rañño maddassantepure”."
    },
    {
      "id": "ja531:46.1",
      "pali": "“Iminā nūna asinā,"
    },
    {
      "id": "ja531:46.2",
      "pali": "susaññaṁ tanumajjhimaṁ;"
    },
    {
      "id": "ja531:46.3",
      "pali": "Dhītaraṁ madda hantvāna,"
    },
    {
      "id": "ja531:46.4",
      "pali": "khattiyānaṁ padassasi."
    },
    {
      "id": "ja531:47.1",
      "pali": "Na me akāsi vacanaṁ,"
    },
    {
      "id": "ja531:47.2",
      "pali": "atthakāmāya puttike;"
    },
    {
      "id": "ja531:47.3",
      "pali": "Sājja lohitasañchannā,"
    },
    {
      "id": "ja531:47.4",
      "pali": "gacchasi yamasādhanaṁ."
    },
    {
      "id": "ja531:48.1",
      "pali": "Evamāpajjatī poso,"
    },
    {
      "id": "ja531:48.2",
      "pali": "pāpiyañca nigacchati;"
    },
    {
      "id": "ja531:48.3",
      "pali": "Yo ve hitānaṁ vacanaṁ,"
    },
    {
      "id": "ja531:48.4",
      "pali": "na karoti atthadassinaṁ."
    },
    {
      "id": "ja531:49.1",
      "pali": "Sace ca ajja dhāresi,"
    },
    {
      "id": "ja531:49.2",
      "pali": "kumāraṁ cārudassanaṁ;"
    },
    {
      "id": "ja531:49.3",
      "pali": "Kusena jātaṁ khattiyaṁ,"
    },
    {
      "id": "ja531:49.4",
      "pali": "suvaṇṇamaṇimekhalaṁ;"
    },
    {
      "id": "ja531:49.5",
      "pali": "Pūjitaṁ ñātisaṅghehi,"
    },
    {
      "id": "ja531:49.6",
      "pali": "na gacchasi yamakkhayaṁ."
    },
    {
      "id": "ja531:50.1",
      "pali": "Yatthassu bherī nadati,"
    },
    {
      "id": "ja531:50.2",
      "pali": "kuñjaro ca nikūjati;"
    },
    {
      "id": "ja531:50.3",
      "pali": "Khattiyānaṁ kule bhadde,"
    },
    {
      "id": "ja531:50.4",
      "pali": "kiṁ nu sukhataraṁ tato."
    },
    {
      "id": "ja531:51.1",
      "pali": "Asso ca sisati dvāre,"
    },
    {
      "id": "ja531:51.2",
      "pali": "kumāro uparodati;"
    },
    {
      "id": "ja531:51.3",
      "pali": "Khattiyānaṁ kule bhadde,"
    },
    {
      "id": "ja531:51.4",
      "pali": "kiṁ nu sukhataraṁ tato."
    },
    {
      "id": "ja531:52.1",
      "pali": "Mayūrakoñcābhirude,"
    },
    {
      "id": "ja531:52.2",
      "pali": "kokilābhinikūjite;"
    },
    {
      "id": "ja531:52.3",
      "pali": "Khattiyānaṁ kule bhadde,"
    },
    {
      "id": "ja531:52.4",
      "pali": "kiṁ nu sukhataraṁ tato”."
    },
    {
      "id": "ja531:53.1",
      "pali": "“Kahaṁ nu so sattumaddano,"
    },
    {
      "id": "ja531:53.2",
      "pali": "pararaṭṭhappamaddano;"
    },
    {
      "id": "ja531:53.3",
      "pali": "Kuso soḷārapaññāṇo,"
    },
    {
      "id": "ja531:53.4",
      "pali": "yo no dukkhā pamocaye”."
    },
    {
      "id": "ja531:54.1",
      "pali": "“Idheva so sattumaddano,"
    },
    {
      "id": "ja531:54.2",
      "pali": "pararaṭṭhappamaddano;"
    },
    {
      "id": "ja531:54.3",
      "pali": "Kuso soḷārapaññāṇo,"
    },
    {
      "id": "ja531:54.4",
      "pali": "yo te sabbe vadhissati”."
    },
    {
      "id": "ja531:55.1",
      "pali": "“Ummattikā nu bhaṇasi,"
    },
    {
      "id": "ja531:55.2",
      "pali": "Andhabālā pabhāsasi;"
    },
    {
      "id": "ja531:55.3",
      "pali": "Kuso ce āgato assa,"
    },
    {
      "id": "ja531:55.4",
      "pali": "Kiṁ na jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja531:56.1",
      "pali": "“Eso āḷāriko poso,"
    },
    {
      "id": "ja531:56.2",
      "pali": "kumārīpuramantare;"
    },
    {
      "id": "ja531:56.3",
      "pali": "Daḷhaṁ katvāna saṁvelliṁ,"
    },
    {
      "id": "ja531:56.4",
      "pali": "kumbhiṁ dhovati oṇato”."
    },
    {
      "id": "ja531:57.1",
      "pali": "“Veṇī tvamasi caṇḍālī,"
    },
    {
      "id": "ja531:57.2",
      "pali": "adūsi kulagandhinī;"
    },
    {
      "id": "ja531:57.3",
      "pali": "Kathaṁ maddakule jātā,"
    },
    {
      "id": "ja531:57.4",
      "pali": "dāsaṁ kayirāsi kāmukaṁ”."
    },
    {
      "id": "ja531:58.1",
      "pali": "“Namhi veṇī na caṇḍālī,"
    },
    {
      "id": "ja531:58.2",
      "pali": "na camhi kulagandhinī;"
    },
    {
      "id": "ja531:58.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:58.4",
      "pali": "tvaṁ nu dāsoti maññasi”."
    },
    {
      "id": "ja531:59.1",
      "pali": "“Yo brāhmaṇasahassāni,"
    },
    {
      "id": "ja531:59.2",
      "pali": "sadā bhojeti vīsatiṁ;"
    },
    {
      "id": "ja531:59.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:59.4",
      "pali": "tvaṁ nu dāsoti maññasi."
    },
    {
      "id": "ja531:60.1",
      "pali": "Yassa nāgasahassāni,"
    },
    {
      "id": "ja531:60.2",
      "pali": "sadā yojenti vīsatiṁ;"
    },
    {
      "id": "ja531:60.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:60.4",
      "pali": "tvaṁ nu dāsoti maññasi."
    },
    {
      "id": "ja531:61.1",
      "pali": "Yassa assasahassāni,"
    },
    {
      "id": "ja531:61.2",
      "pali": "sadā yojenti vīsatiṁ;"
    },
    {
      "id": "ja531:61.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:61.4",
      "pali": "tvaṁ nu dāsoti maññasi."
    },
    {
      "id": "ja531:62.1",
      "pali": "Yassa rathasahassāni,"
    },
    {
      "id": "ja531:62.2",
      "pali": "sadā yojenti vīsatiṁ;"
    },
    {
      "id": "ja531:62.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:62.4",
      "pali": "tvaṁ nu dāsoti maññasi."
    },
    {
      "id": "ja531:63.1",
      "pali": "Yassa usabhasahassāni,"
    },
    {
      "id": "ja531:63.2",
      "pali": "sadā yojenti vīsatiṁ;"
    },
    {
      "id": "ja531:63.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:63.4",
      "pali": "tvaṁ nu dāsoti maññasi."
    },
    {
      "id": "ja531:64.1",
      "pali": "Yassa dhenusahassāni,"
    },
    {
      "id": "ja531:64.2",
      "pali": "sadā duhanti vīsatiṁ;"
    },
    {
      "id": "ja531:64.3",
      "pali": "Okkākaputto bhaddante,"
    },
    {
      "id": "ja531:64.4",
      "pali": "tvaṁ nu dāsoti maññasi”."
    },
    {
      "id": "ja531:65.1",
      "pali": "“Taggha te dukkaṭaṁ bāle,"
    },
    {
      "id": "ja531:65.2",
      "pali": "yaṁ khattiyaṁ mahabbalaṁ;"
    },
    {
      "id": "ja531:65.3",
      "pali": "Nāgaṁ maṇḍūkavaṇṇena,"
    },
    {
      "id": "ja531:65.4",
      "pali": "na naṁ akkhāsidhāgataṁ”."
    },
    {
      "id": "ja531:66.1",
      "pali": "“Aparādhaṁ mahārāja,"
    },
    {
      "id": "ja531:66.2",
      "pali": "tvaṁ no khama rathesabha;"
    },
    {
      "id": "ja531:66.3",
      "pali": "Yaṁ taṁ aññātavesena,"
    },
    {
      "id": "ja531:66.4",
      "pali": "nāññāsimhā idhāgataṁ”."
    },
    {
      "id": "ja531:67.1",
      "pali": "“Mādisassa na taṁ channaṁ,"
    },
    {
      "id": "ja531:67.2",
      "pali": "yohaṁ āḷāriko bhave;"
    },
    {
      "id": "ja531:67.3",
      "pali": "Tvaññeva me pasīdassu,"
    },
    {
      "id": "ja531:67.4",
      "pali": "natthi te deva dukkaṭaṁ”."
    },
    {
      "id": "ja531:68.1",
      "pali": "“Gaccha bāle khamāpehi,"
    },
    {
      "id": "ja531:68.2",
      "pali": "kusarājaṁ mahabbalaṁ;"
    },
    {
      "id": "ja531:68.3",
      "pali": "Khamāpito kuso rājā,"
    },
    {
      "id": "ja531:68.4",
      "pali": "so te dassati jīvitaṁ”."
    },
    {
      "id": "ja531:69.1",
      "pali": "“Pitussa vacanaṁ sutvā,"
    },
    {
      "id": "ja531:69.2",
      "pali": "devavaṇṇī pabhāvatī;"
    },
    {
      "id": "ja531:69.3",
      "pali": "Sirasā aggahī pāde,"
    },
    {
      "id": "ja531:69.4",
      "pali": "kusarājaṁ mahabbalaṁ”."
    },
    {
      "id": "ja531:70.1",
      "pali": "“Yāmā ratyo atikkantā,"
    },
    {
      "id": "ja531:70.2",
      "pali": "tāmā deva tayā vinā;"
    },
    {
      "id": "ja531:70.3",
      "pali": "Vande te sirasā pāde,"
    },
    {
      "id": "ja531:70.4",
      "pali": "mā me kujjha rathesabha."
    },
    {
      "id": "ja531:71.1",
      "pali": "Sabbaṁ te paṭijānāmi,"
    },
    {
      "id": "ja531:71.2",
      "pali": "mahārāja suṇohi me;"
    },
    {
      "id": "ja531:71.3",
      "pali": "Na cāpi appiyaṁ tuyhaṁ,"
    },
    {
      "id": "ja531:71.4",
      "pali": "kareyyāmi ahaṁ puna."
    },
    {
      "id": "ja531:72.1",
      "pali": "Evañce yācamānāya,"
    },
    {
      "id": "ja531:72.2",
      "pali": "vacanaṁ me na kāhasi;"
    },
    {
      "id": "ja531:72.3",
      "pali": "Idāni maṁ tāto hantvā,"
    },
    {
      "id": "ja531:72.4",
      "pali": "khattiyānaṁ padassati”."
    },
    {
      "id": "ja531:73.1",
      "pali": "“Evaṁ te yācamānāya,"
    },
    {
      "id": "ja531:73.2",
      "pali": "kiṁ na kāhāmi te vaco;"
    },
    {
      "id": "ja531:73.3",
      "pali": "Vikuddho tyasmi kalyāṇi,"
    },
    {
      "id": "ja531:73.4",
      "pali": "mā tvaṁ bhāyi pabhāvati."
    },
    {
      "id": "ja531:74.1",
      "pali": "Sabbaṁ te paṭijānāmi,"
    },
    {
      "id": "ja531:74.2",
      "pali": "rājaputti suṇohi me;"
    },
    {
      "id": "ja531:74.3",
      "pali": "Na cāpi appiyaṁ tuyhaṁ,"
    },
    {
      "id": "ja531:74.4",
      "pali": "kareyyāmi ahaṁ puna."
    },
    {
      "id": "ja531:75.1",
      "pali": "Tava kāmā hi sussoṇi,"
    },
    {
      "id": "ja531:75.2",
      "pali": "pahu dukkhaṁ titikkhisaṁ;"
    },
    {
      "id": "ja531:75.3",
      "pali": "Bahuṁ maddakulaṁ hantvā,"
    },
    {
      "id": "ja531:75.4",
      "pali": "nayituṁ taṁ pabhāvati”."
    },
    {
      "id": "ja531:76.1",
      "pali": "“Yojayantu rathe asse,"
    },
    {
      "id": "ja531:76.2",
      "pali": "nānācitte samāhite;"
    },
    {
      "id": "ja531:76.3",
      "pali": "Atha dakkhatha me vegaṁ,"
    },
    {
      "id": "ja531:76.4",
      "pali": "vidhamantassa sattavo”."
    },
    {
      "id": "ja531:77.1",
      "pali": "“Tañca tattha udikkhiṁsu,"
    },
    {
      "id": "ja531:77.2",
      "pali": "rañño maddassantepure;"
    },
    {
      "id": "ja531:77.3",
      "pali": "Vijambhamānaṁ sīhaṁva,"
    },
    {
      "id": "ja531:77.4",
      "pali": "phoṭentaṁ diguṇaṁ bhujaṁ."
    },
    {
      "id": "ja531:78.1",
      "pali": "Hatthikkhandhañca āruyha,"
    },
    {
      "id": "ja531:78.2",
      "pali": "āropetvā pabhāvatiṁ;"
    },
    {
      "id": "ja531:78.3",
      "pali": "Saṅgāmaṁ otaritvāna,"
    },
    {
      "id": "ja531:78.4",
      "pali": "sīhanādaṁ nadī kuso."
    },
    {
      "id": "ja531:79.1",
      "pali": "Tassa taṁ nadato sutvā,"
    },
    {
      "id": "ja531:79.2",
      "pali": "sīhassevitare migā;"
    },
    {
      "id": "ja531:79.3",
      "pali": "Khattiyā vipalāyiṁsu,"
    },
    {
      "id": "ja531:79.4",
      "pali": "kusasaddabhayaṭṭitā."
    },
    {
      "id": "ja531:80.1",
      "pali": "Hatthārohā anīkaṭṭhā,"
    },
    {
      "id": "ja531:80.2",
      "pali": "rathikā pattikārakā;"
    },
    {
      "id": "ja531:80.3",
      "pali": "Aññamaññassa chindanti,"
    },
    {
      "id": "ja531:80.4",
      "pali": "kusasaddabhayaṭṭitā."
    },
    {
      "id": "ja531:81.1",
      "pali": "Tasmiṁ saṅgāmasīsasmiṁ,"
    },
    {
      "id": "ja531:81.2",
      "pali": "passitvā haṭṭhamānaso;"
    },
    {
      "id": "ja531:81.3",
      "pali": "Kusassa rañño devindo,"
    },
    {
      "id": "ja531:81.4",
      "pali": "adā verocanaṁ maṇiṁ."
    },
    {
      "id": "ja531:82.1",
      "pali": "So taṁ vijitvā saṅgāmaṁ,"
    },
    {
      "id": "ja531:82.2",
      "pali": "laddhā verocanaṁ maṇiṁ;"
    },
    {
      "id": "ja531:82.3",
      "pali": "Hatthikkhandhagato rājā,"
    },
    {
      "id": "ja531:82.4",
      "pali": "pāvekkhi nagaraṁ puraṁ."
    },
    {
      "id": "ja531:83.1",
      "pali": "Jīvaggāhaṁ gahetvāna,"
    },
    {
      "id": "ja531:83.2",
      "pali": "bandhitvā satta khattiye;"
    },
    {
      "id": "ja531:83.3",
      "pali": "Sasurassupanāmesi,"
    },
    {
      "id": "ja531:83.4",
      "pali": "ime te deva sattavo."
    },
    {
      "id": "ja531:84.1",
      "pali": "Sabbeva te vasaṁ gatā,"
    },
    {
      "id": "ja531:84.2",
      "pali": "amittā vihatā tava;"
    },
    {
      "id": "ja531:84.3",
      "pali": "Kāmaṁ karohi te tayā,"
    },
    {
      "id": "ja531:84.4",
      "pali": "muñca vā te hanassu vā”."
    },
    {
      "id": "ja531:85.1",
      "pali": "“Tuyheva sattavo ete,"
    },
    {
      "id": "ja531:85.2",
      "pali": "na hi te mayha sattavo;"
    },
    {
      "id": "ja531:85.3",
      "pali": "Tvaññeva no mahārāja,"
    },
    {
      "id": "ja531:85.4",
      "pali": "muñca vā te hanassu vā”."
    },
    {
      "id": "ja531:86.1",
      "pali": "“Imā te dhītaro satta,"
    },
    {
      "id": "ja531:86.2",
      "pali": "devakaññūpamā subhā;"
    },
    {
      "id": "ja531:86.3",
      "pali": "Dadāhi nesaṁ ekekaṁ,"
    },
    {
      "id": "ja531:86.4",
      "pali": "hontu jāmātaro tava”."
    },
    {
      "id": "ja531:87.1",
      "pali": "“Amhākañceva tāsañca,"
    },
    {
      "id": "ja531:87.2",
      "pali": "tvaṁ no sabbesamissaro;"
    },
    {
      "id": "ja531:87.3",
      "pali": "Tvaññeva no mahārāja,"
    },
    {
      "id": "ja531:87.4",
      "pali": "dehi nesaṁ yadicchasi”."
    },
    {
      "id": "ja531:88.1",
      "pali": "Ekamekassa ekekaṁ,"
    },
    {
      "id": "ja531:88.2",
      "pali": "adā sīhassaro kuso;"
    },
    {
      "id": "ja531:88.3",
      "pali": "Khattiyānaṁ tadā tesaṁ,"
    },
    {
      "id": "ja531:88.4",
      "pali": "rañño maddassa dhītaro."
    },
    {
      "id": "ja531:89.1",
      "pali": "Pīṇitā tena lābhena,"
    },
    {
      "id": "ja531:89.2",
      "pali": "tuṭṭhā sīhassare kuse;"
    },
    {
      "id": "ja531:89.3",
      "pali": "Sakaraṭṭhāni pāyiṁsu,"
    },
    {
      "id": "ja531:89.4",
      "pali": "khattiyā satta tāvade."
    },
    {
      "id": "ja531:90.1",
      "pali": "Pabhāvatiñca ādāya,"
    },
    {
      "id": "ja531:90.2",
      "pali": "maṇiṁ verocanaṁ subhaṁ;"
    },
    {
      "id": "ja531:90.3",
      "pali": "Kusāvatiṁ kuso rājā,"
    },
    {
      "id": "ja531:90.4",
      "pali": "agamāsi mahabbalo."
    },
    {
      "id": "ja531:91.1",
      "pali": "Tyassu ekarathe yantā,"
    },
    {
      "id": "ja531:91.2",
      "pali": "pavisantā kusāvatiṁ;"
    },
    {
      "id": "ja531:91.3",
      "pali": "Samānā vaṇṇarūpena,"
    },
    {
      "id": "ja531:91.4",
      "pali": "nāññamaññātirocisuṁ."
    },
    {
      "id": "ja531:92.1",
      "pali": "Mātā puttena saṅgacchi,"
    },
    {
      "id": "ja531:92.2",
      "pali": "ubhayo ca jayampatī;"
    },
    {
      "id": "ja531:92.3",
      "pali": "Samaggā te tadā āsuṁ,"
    },
    {
      "id": "ja531:92.4",
      "pali": "phītaṁ dharaṇimāvasunti."
    },
    {
      "id": "ja531:93.1",
      "pali": "Kusajātakaṁ paṭhamaṁ."
    }
  ]
}
