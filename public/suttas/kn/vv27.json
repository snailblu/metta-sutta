{
  "uid": "vv27",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv27:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv27:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv27:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv27:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv27:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv27:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv27:2.3",
      "pali": "vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv27:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv27:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv27:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv27:4.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv27:4.2",
      "pali": "Purimāya jātiyā manussaloke."
    },
    {
      "id": "vv27:5.1",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "vv27:5.2",
      "pali": "vippasannamanāvilaṁ;"
    },
    {
      "id": "vv27:5.3",
      "pali": "Tassa adāsahaṁ bhikkhaṁ,"
    },
    {
      "id": "vv27:5.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv27:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv27:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv27:6.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv27:7.1",
      "pali": "Paṭhamabhikkhādāyikāvimānaṁ dasamaṁ."
    }
  ]
}
