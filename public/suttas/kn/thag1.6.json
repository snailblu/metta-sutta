{
  "uid": "thag1.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.6:1.1",
      "pali": "“Yo sītavanaṁ upagā bhikkhu,"
    },
    {
      "id": "thag1.6:1.2",
      "pali": "Eko santusito samāhitatto;"
    },
    {
      "id": "thag1.6:1.3",
      "pali": "Vijitāvī apetalomahaṁso,"
    },
    {
      "id": "thag1.6:1.4",
      "pali": "Rakkhaṁ kāyagatāsatiṁ dhitimā”ti."
    },
    {
      "id": "thag1.6:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā sītavaniyo thero gāthaṁ abhāsitthāti."
    }
  ]
}
