{
  "uid": "tha-ap322",
  "title": "Kumudamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap322:1.1",
      "pali": "“Usabhaṁ pavaraṁ vīraṁ,"
    },
    {
      "id": "tha-ap322:1.2",
      "pali": "mahesiṁ vijitāvinaṁ;"
    },
    {
      "id": "tha-ap322:1.3",
      "pali": "Vipassinaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap322:1.4",
      "pali": "abhijātaṁva kesariṁ."
    },
    {
      "id": "tha-ap322:2.1",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap322:2.2",
      "pali": "āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap322:2.3",
      "pali": "Gahetvā kumudaṁ mālaṁ,"
    },
    {
      "id": "tha-ap322:2.4",
      "pali": "buddhaseṭṭhaṁ samokiriṁ."
    },
    {
      "id": "tha-ap322:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap322:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap322:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap322:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap322:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap322:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap322:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap322:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kumudamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap322:6.1",
      "pali": "Kumudamāliyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap322:7.1",
      "pali": "Ārakkhadāyakavaggo bāttiṁsatimo."
    },
    {
      "id": "tha-ap322:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap322:9.1",
      "pali": "Ārakkhado bhojanado,"
    },
    {
      "id": "tha-ap322:9.2",
      "pali": "gatasaññī padumiyo;"
    },
    {
      "id": "tha-ap322:9.3",
      "pali": "Pupphāsanī santhaviko,"
    },
    {
      "id": "tha-ap322:9.4",
      "pali": "saddasaññī tiraṁsiyo;"
    },
    {
      "id": "tha-ap322:9.5",
      "pali": "Kandaliko kumudī ca,"
    },
    {
      "id": "tha-ap322:9.6",
      "pali": "sattapaññāsa gāthakāti."
    }
  ]
}
