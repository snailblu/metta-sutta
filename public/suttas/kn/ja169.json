{
  "uid": "ja169",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja169:1.1",
      "pali": "“Yo ve mettena cittena,"
    },
    {
      "id": "ja169:1.2",
      "pali": "sabbalokānukampati;"
    },
    {
      "id": "ja169:1.3",
      "pali": "Uddhaṁ adho ca tiriyaṁ,"
    },
    {
      "id": "ja169:1.4",
      "pali": "appamāṇena sabbaso."
    },
    {
      "id": "ja169:2.1",
      "pali": "Appamāṇaṁ hitaṁ cittaṁ,"
    },
    {
      "id": "ja169:2.2",
      "pali": "paripuṇṇaṁ subhāvitaṁ;"
    },
    {
      "id": "ja169:2.3",
      "pali": "Yaṁ pamāṇakataṁ kammaṁ,"
    },
    {
      "id": "ja169:2.4",
      "pali": "na taṁ tatrāvasissatī”ti."
    },
    {
      "id": "ja169:3.1",
      "pali": "Arakajātakaṁ navamaṁ."
    }
  ]
}
