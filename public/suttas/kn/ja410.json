{
  "uid": "ja410",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja410:1.1",
      "pali": "“Yo maṁ pure paccuḍḍeti,"
    },
    {
      "id": "ja410:1.2",
      "pali": "araññe dūramāyato;"
    },
    {
      "id": "ja410:1.3",
      "pali": "So na dissati mātaṅgo,"
    },
    {
      "id": "ja410:1.4",
      "pali": "somadatto kuhiṁ gato."
    },
    {
      "id": "ja410:2.1",
      "pali": "Ayaṁ vā so mato seti,"
    },
    {
      "id": "ja410:2.2",
      "pali": "allasiṅgaṁva vacchito;"
    },
    {
      "id": "ja410:2.3",
      "pali": "Bhumyā nipatito seti,"
    },
    {
      "id": "ja410:2.4",
      "pali": "amarā vata kuñjaro”."
    },
    {
      "id": "ja410:3.1",
      "pali": "“Anagāriyupetassa,"
    },
    {
      "id": "ja410:3.2",
      "pali": "vippamuttassa te sato;"
    },
    {
      "id": "ja410:3.3",
      "pali": "Samaṇassa na taṁ sādhu,"
    },
    {
      "id": "ja410:3.4",
      "pali": "yaṁ petamanusocasi”."
    },
    {
      "id": "ja410:4.1",
      "pali": "“Saṁvāsena have sakka,"
    },
    {
      "id": "ja410:4.2",
      "pali": "manussassa migassa vā;"
    },
    {
      "id": "ja410:4.3",
      "pali": "Hadaye jāyate pemaṁ,"
    },
    {
      "id": "ja410:4.4",
      "pali": "taṁ na sakkā asocituṁ”."
    },
    {
      "id": "ja410:5.1",
      "pali": "“Mataṁ marissaṁ rodanti,"
    },
    {
      "id": "ja410:5.2",
      "pali": "ye rudanti lapanti ca;"
    },
    {
      "id": "ja410:5.3",
      "pali": "Tasmā tvaṁ isi mā rodi,"
    },
    {
      "id": "ja410:5.4",
      "pali": "roditaṁ moghamāhu santo."
    },
    {
      "id": "ja410:6.1",
      "pali": "Kanditena have brahme,"
    },
    {
      "id": "ja410:6.2",
      "pali": "mato peto samuṭṭhahe;"
    },
    {
      "id": "ja410:6.3",
      "pali": "Sabbe saṅgamma rodāma,"
    },
    {
      "id": "ja410:6.4",
      "pali": "aññamaññassa ñātake”."
    },
    {
      "id": "ja410:7.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "ja410:7.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "ja410:7.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "ja410:7.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "ja410:8.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "ja410:8.2",
      "pali": "yamāsi hadayassitaṁ;"
    },
    {
      "id": "ja410:8.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "ja410:8.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "ja410:9.1",
      "pali": "Sohaṁ abbūḷhasallosmi,"
    },
    {
      "id": "ja410:9.2",
      "pali": "vītasoko anāvilo;"
    },
    {
      "id": "ja410:9.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "ja410:9.4",
      "pali": "tava sutvāna vāsavā”ti."
    },
    {
      "id": "ja410:10.1",
      "pali": "Somadattajātakaṁ pañcamaṁ."
    }
  ]
}
