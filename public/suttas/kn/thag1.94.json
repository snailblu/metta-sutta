{
  "uid": "thag1.94",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.94:1.1",
      "pali": "“Namo hi tassa bhagavato,"
    },
    {
      "id": "thag1.94:1.2",
      "pali": "sakyaputtassa sirīmato;"
    },
    {
      "id": "thag1.94:1.3",
      "pali": "Tenāyaṁ aggappattena,"
    },
    {
      "id": "thag1.94:1.4",
      "pali": "aggadhammo sudesito”ti."
    },
    {
      "id": "thag1.94:1.5",
      "pali": "… Mettaji thero …."
    }
  ]
}
