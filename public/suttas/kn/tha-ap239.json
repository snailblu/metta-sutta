{
  "uid": "tha-ap239",
  "title": "Piyālapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap239:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap239:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap239:1.3",
      "pali": "Piyālaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap239:1.4",
      "pali": "gatamagge khipiṁ ahaṁ."
    },
    {
      "id": "tha-ap239:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap239:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap239:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap239:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap239:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap239:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap239:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap239:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā piyālapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap239:5.1",
      "pali": "Piyālapupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
