{
  "uid": "thag18.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag18.1:1.1",
      "pali": "“Na gaṇena purakkhato care,"
    },
    {
      "id": "thag18.1:1.2",
      "pali": "Vimano hoti samādhi dullabho;"
    },
    {
      "id": "thag18.1:1.3",
      "pali": "Nānājanasaṅgaho dukho,"
    },
    {
      "id": "thag18.1:1.4",
      "pali": "Iti disvāna gaṇaṁ na rocaye."
    },
    {
      "id": "thag18.1:2.1",
      "pali": "Na kulāni upabbaje muni,"
    },
    {
      "id": "thag18.1:2.2",
      "pali": "Vimano hoti samādhi dullabho;"
    },
    {
      "id": "thag18.1:2.3",
      "pali": "So ussukko rasānugiddho,"
    },
    {
      "id": "thag18.1:2.4",
      "pali": "Atthaṁ riñcati yo sukhāvaho."
    },
    {
      "id": "thag18.1:3.1",
      "pali": "Paṅkoti hi naṁ avedayuṁ,"
    },
    {
      "id": "thag18.1:3.2",
      "pali": "Yāyaṁ vandanapūjanā kulesu;"
    },
    {
      "id": "thag18.1:3.3",
      "pali": "Sukhumaṁ sallaṁ durubbahaṁ,"
    },
    {
      "id": "thag18.1:3.4",
      "pali": "Sakkāro kāpurisena dujjaho."
    },
    {
      "id": "thag18.1:4.1",
      "pali": "Senāsanamhā oruyha,"
    },
    {
      "id": "thag18.1:4.2",
      "pali": "nagaraṁ piṇḍāya pāvisiṁ;"
    },
    {
      "id": "thag18.1:4.3",
      "pali": "Bhuñjantaṁ purisaṁ kuṭṭhiṁ,"
    },
    {
      "id": "thag18.1:4.4",
      "pali": "sakkaccaṁ taṁ upaṭṭhahiṁ."
    },
    {
      "id": "thag18.1:5.1",
      "pali": "So me pakkena hatthena,"
    },
    {
      "id": "thag18.1:5.2",
      "pali": "ālopaṁ upanāmayi;"
    },
    {
      "id": "thag18.1:5.3",
      "pali": "Ālopaṁ pakkhipantassa,"
    },
    {
      "id": "thag18.1:5.4",
      "pali": "aṅguli cettha chijjatha."
    },
    {
      "id": "thag18.1:6.1",
      "pali": "Kuṭṭamūlañca nissāya,"
    },
    {
      "id": "thag18.1:6.2",
      "pali": "ālopaṁ taṁ abhuñjisaṁ;"
    },
    {
      "id": "thag18.1:6.3",
      "pali": "Bhuñjamāne vā bhutte vā,"
    },
    {
      "id": "thag18.1:6.4",
      "pali": "jegucchaṁ me na vijjati."
    },
    {
      "id": "thag18.1:7.1",
      "pali": "Uttiṭṭhapiṇḍo āhāro,"
    },
    {
      "id": "thag18.1:7.2",
      "pali": "pūtimuttañca osadhaṁ;"
    },
    {
      "id": "thag18.1:7.3",
      "pali": "Senāsanaṁ rukkhamūlaṁ,"
    },
    {
      "id": "thag18.1:7.4",
      "pali": "paṁsukūlañca cīvaraṁ;"
    },
    {
      "id": "thag18.1:7.5",
      "pali": "Yassete abhisambhutvā,"
    },
    {
      "id": "thag18.1:7.6",
      "pali": "sa ve cātuddiso naro."
    },
    {
      "id": "thag18.1:8.1",
      "pali": "Yattha eke vihaññanti,"
    },
    {
      "id": "thag18.1:8.2",
      "pali": "āruhantā siluccayaṁ;"
    },
    {
      "id": "thag18.1:8.3",
      "pali": "Tassa buddhassa dāyādo,"
    },
    {
      "id": "thag18.1:8.4",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "thag18.1:8.5",
      "pali": "Iddhibalenupatthaddho,"
    },
    {
      "id": "thag18.1:8.6",
      "pali": "kassapo abhirūhati."
    },
    {
      "id": "thag18.1:9.1",
      "pali": "Piṇḍapātapaṭikkanto,"
    },
    {
      "id": "thag18.1:9.2",
      "pali": "selamāruyha kassapo;"
    },
    {
      "id": "thag18.1:9.3",
      "pali": "Jhāyati anupādāno,"
    },
    {
      "id": "thag18.1:9.4",
      "pali": "pahīnabhayabheravo."
    },
    {
      "id": "thag18.1:10.1",
      "pali": "Piṇḍapātapaṭikkanto,"
    },
    {
      "id": "thag18.1:10.2",
      "pali": "selamāruyha kassapo;"
    },
    {
      "id": "thag18.1:10.3",
      "pali": "Jhāyati anupādāno,"
    },
    {
      "id": "thag18.1:10.4",
      "pali": "ḍayhamānesu nibbuto."
    },
    {
      "id": "thag18.1:11.1",
      "pali": "Piṇḍapātapaṭikkanto,"
    },
    {
      "id": "thag18.1:11.2",
      "pali": "selamāruyha kassapo;"
    },
    {
      "id": "thag18.1:11.3",
      "pali": "Jhāyati anupādāno,"
    },
    {
      "id": "thag18.1:11.4",
      "pali": "katakicco anāsavo."
    },
    {
      "id": "thag18.1:12.1",
      "pali": "Karerimālāvitatā,"
    },
    {
      "id": "thag18.1:12.2",
      "pali": "bhūmibhāgā manoramā;"
    },
    {
      "id": "thag18.1:12.3",
      "pali": "Kuñjarābhirudā rammā,"
    },
    {
      "id": "thag18.1:12.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:13.1",
      "pali": "Nīlabbhavaṇṇā rucirā,"
    },
    {
      "id": "thag18.1:13.2",
      "pali": "vārisītā sucindharā;"
    },
    {
      "id": "thag18.1:13.3",
      "pali": "Indagopakasañchannā,"
    },
    {
      "id": "thag18.1:13.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:14.1",
      "pali": "Nīlabbhakūṭasadisā,"
    },
    {
      "id": "thag18.1:14.2",
      "pali": "kūṭāgāravarūpamā;"
    },
    {
      "id": "thag18.1:14.3",
      "pali": "Vāraṇābhirudā rammā,"
    },
    {
      "id": "thag18.1:14.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:15.1",
      "pali": "Abhivuṭṭhā rammatalā,"
    },
    {
      "id": "thag18.1:15.2",
      "pali": "nagā isibhi sevitā;"
    },
    {
      "id": "thag18.1:15.3",
      "pali": "Abbhunnaditā sikhīhi,"
    },
    {
      "id": "thag18.1:15.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:16.1",
      "pali": "Alaṁ jhāyitukāmassa,"
    },
    {
      "id": "thag18.1:16.2",
      "pali": "pahitattassa me sato;"
    },
    {
      "id": "thag18.1:16.3",
      "pali": "Alaṁ me atthakāmassa,"
    },
    {
      "id": "thag18.1:16.4",
      "pali": "pahitattassa bhikkhuno."
    },
    {
      "id": "thag18.1:17.1",
      "pali": "Alaṁ me phāsukāmassa,"
    },
    {
      "id": "thag18.1:17.2",
      "pali": "pahitattassa bhikkhuno;"
    },
    {
      "id": "thag18.1:17.3",
      "pali": "Alaṁ me yogakāmassa,"
    },
    {
      "id": "thag18.1:17.4",
      "pali": "pahitattassa tādino."
    },
    {
      "id": "thag18.1:18.1",
      "pali": "Umāpupphena samānā,"
    },
    {
      "id": "thag18.1:18.2",
      "pali": "gaganāvabbhachāditā;"
    },
    {
      "id": "thag18.1:18.3",
      "pali": "Nānādijagaṇākiṇṇā,"
    },
    {
      "id": "thag18.1:18.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:19.1",
      "pali": "Anākiṇṇā gahaṭṭhehi,"
    },
    {
      "id": "thag18.1:19.2",
      "pali": "migasaṅghanisevitā;"
    },
    {
      "id": "thag18.1:19.3",
      "pali": "Nānādijagaṇākiṇṇā,"
    },
    {
      "id": "thag18.1:19.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:20.1",
      "pali": "Acchodikā puthusilā,"
    },
    {
      "id": "thag18.1:20.2",
      "pali": "gonaṅgulamigāyutā;"
    },
    {
      "id": "thag18.1:20.3",
      "pali": "Ambusevālasañchannā,"
    },
    {
      "id": "thag18.1:20.4",
      "pali": "te selā ramayanti maṁ."
    },
    {
      "id": "thag18.1:21.1",
      "pali": "Na pañcaṅgikena turiyena,"
    },
    {
      "id": "thag18.1:21.2",
      "pali": "Rati me hoti tādisī;"
    },
    {
      "id": "thag18.1:21.3",
      "pali": "Yathā ekaggacittassa,"
    },
    {
      "id": "thag18.1:21.4",
      "pali": "Sammā dhammaṁ vipassato."
    },
    {
      "id": "thag18.1:22.1",
      "pali": "Kammaṁ bahukaṁ na kāraye,"
    },
    {
      "id": "thag18.1:22.2",
      "pali": "Parivajjeyya janaṁ na uyyame;"
    },
    {
      "id": "thag18.1:22.3",
      "pali": "Ussukko so rasānugiddho,"
    },
    {
      "id": "thag18.1:22.4",
      "pali": "Atthaṁ riñcati yo sukhāvaho."
    },
    {
      "id": "thag18.1:23.1",
      "pali": "Kammaṁ bahukaṁ na kāraye,"
    },
    {
      "id": "thag18.1:23.2",
      "pali": "Parivajjeyya anattaneyyametaṁ;"
    },
    {
      "id": "thag18.1:23.3",
      "pali": "Kicchati kāyo kilamati,"
    },
    {
      "id": "thag18.1:23.4",
      "pali": "Dukkhito so samathaṁ na vindati."
    },
    {
      "id": "thag18.1:24.1",
      "pali": "Oṭṭhappahatamattena,"
    },
    {
      "id": "thag18.1:24.2",
      "pali": "attānampi na passati;"
    },
    {
      "id": "thag18.1:24.3",
      "pali": "Patthaddhagīvo carati,"
    },
    {
      "id": "thag18.1:24.4",
      "pali": "ahaṁ seyyoti maññati."
    },
    {
      "id": "thag18.1:25.1",
      "pali": "Aseyyo seyyasamānaṁ,"
    },
    {
      "id": "thag18.1:25.2",
      "pali": "bālo maññati attānaṁ;"
    },
    {
      "id": "thag18.1:25.3",
      "pali": "Na taṁ viññū pasaṁsanti,"
    },
    {
      "id": "thag18.1:25.4",
      "pali": "patthaddhamānasaṁ naraṁ."
    },
    {
      "id": "thag18.1:26.1",
      "pali": "Yo ca seyyohamasmīti,"
    },
    {
      "id": "thag18.1:26.2",
      "pali": "nāhaṁ seyyoti vā pana;"
    },
    {
      "id": "thag18.1:26.3",
      "pali": "Hīno taṁsadiso vāti,"
    },
    {
      "id": "thag18.1:26.4",
      "pali": "vidhāsu na vikampati."
    },
    {
      "id": "thag18.1:27.1",
      "pali": "Paññavantaṁ tathā tādiṁ,"
    },
    {
      "id": "thag18.1:27.2",
      "pali": "sīlesu susamāhitaṁ;"
    },
    {
      "id": "thag18.1:27.3",
      "pali": "Cetosamathamanuttaṁ,"
    },
    {
      "id": "thag18.1:27.4",
      "pali": "tañce viññū pasaṁsare."
    },
    {
      "id": "thag18.1:28.1",
      "pali": "Yassa sabrahmacārīsu,"
    },
    {
      "id": "thag18.1:28.2",
      "pali": "gāravo nūpalabbhati;"
    },
    {
      "id": "thag18.1:28.3",
      "pali": "Ārakā hoti saddhammā,"
    },
    {
      "id": "thag18.1:28.4",
      "pali": "nabhato puthavī yathā."
    },
    {
      "id": "thag18.1:29.1",
      "pali": "Yesañca hiriottappaṁ,"
    },
    {
      "id": "thag18.1:29.2",
      "pali": "sadā sammā upaṭṭhitaṁ;"
    },
    {
      "id": "thag18.1:29.3",
      "pali": "Virūḷhabrahmacariyā te,"
    },
    {
      "id": "thag18.1:29.4",
      "pali": "tesaṁ khīṇā punabbhavā."
    },
    {
      "id": "thag18.1:30.1",
      "pali": "Uddhato capalo bhikkhu,"
    },
    {
      "id": "thag18.1:30.2",
      "pali": "paṁsukūlena pāruto;"
    },
    {
      "id": "thag18.1:30.3",
      "pali": "Kapīva sīhacammena,"
    },
    {
      "id": "thag18.1:30.4",
      "pali": "na so tenupasobhati."
    },
    {
      "id": "thag18.1:31.1",
      "pali": "Anuddhato acapalo,"
    },
    {
      "id": "thag18.1:31.2",
      "pali": "nipako saṁvutindriyo;"
    },
    {
      "id": "thag18.1:31.3",
      "pali": "Sobhati paṁsukūlena,"
    },
    {
      "id": "thag18.1:31.4",
      "pali": "sīhova girigabbhare."
    },
    {
      "id": "thag18.1:32.1",
      "pali": "Ete sambahulā devā,"
    },
    {
      "id": "thag18.1:32.2",
      "pali": "iddhimanto yasassino;"
    },
    {
      "id": "thag18.1:32.3",
      "pali": "Dasadevasahassāni,"
    },
    {
      "id": "thag18.1:32.4",
      "pali": "sabbe te brahmakāyikā."
    },
    {
      "id": "thag18.1:33.1",
      "pali": "Dhammasenāpatiṁ vīraṁ,"
    },
    {
      "id": "thag18.1:33.2",
      "pali": "mahājhāyiṁ samāhitaṁ;"
    },
    {
      "id": "thag18.1:33.3",
      "pali": "Sāriputtaṁ namassantā,"
    },
    {
      "id": "thag18.1:33.4",
      "pali": "tiṭṭhanti pañjalīkatā."
    },
    {
      "id": "thag18.1:34.1",
      "pali": "‘Namo te purisājañña,"
    },
    {
      "id": "thag18.1:34.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "thag18.1:34.3",
      "pali": "Yassa te nābhijānāma,"
    },
    {
      "id": "thag18.1:34.4",
      "pali": "yampi nissāya jhāyati."
    },
    {
      "id": "thag18.1:35.1",
      "pali": "Accheraṁ vata buddhānaṁ,"
    },
    {
      "id": "thag18.1:35.2",
      "pali": "gambhīro gocaro sako;"
    },
    {
      "id": "thag18.1:35.3",
      "pali": "Ye mayaṁ nābhijānāma,"
    },
    {
      "id": "thag18.1:35.4",
      "pali": "vālavedhisamāgatā’."
    },
    {
      "id": "thag18.1:36.1",
      "pali": "Taṁ tathā devakāyehi,"
    },
    {
      "id": "thag18.1:36.2",
      "pali": "pūjitaṁ pūjanārahaṁ;"
    },
    {
      "id": "thag18.1:36.3",
      "pali": "Sāriputtaṁ tadā disvā,"
    },
    {
      "id": "thag18.1:36.4",
      "pali": "kappinassa sitaṁ ahu."
    },
    {
      "id": "thag18.1:37.1",
      "pali": "Yāvatā buddhakhettamhi,"
    },
    {
      "id": "thag18.1:37.2",
      "pali": "ṭhapayitvā mahāmuniṁ;"
    },
    {
      "id": "thag18.1:37.3",
      "pali": "Dhutaguṇe visiṭṭhohaṁ,"
    },
    {
      "id": "thag18.1:37.4",
      "pali": "sadiso me na vijjati."
    },
    {
      "id": "thag18.1:38.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag18.1:38.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thag18.1:38.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thag18.1:38.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thag18.1:39.1",
      "pali": "Na cīvare na sayane,"
    },
    {
      "id": "thag18.1:39.2",
      "pali": "bhojane nupalimpati;"
    },
    {
      "id": "thag18.1:39.3",
      "pali": "Gotamo anappameyyo,"
    },
    {
      "id": "thag18.1:39.4",
      "pali": "muḷālapupphaṁ vimalaṁva;"
    },
    {
      "id": "thag18.1:39.5",
      "pali": "Ambunā nekkhammaninno,"
    },
    {
      "id": "thag18.1:39.6",
      "pali": "tibhavābhinissaṭo."
    },
    {
      "id": "thag18.1:40.1",
      "pali": "Satipaṭṭhānagīvo so,"
    },
    {
      "id": "thag18.1:40.2",
      "pali": "saddhāhattho mahāmuni;"
    },
    {
      "id": "thag18.1:40.3",
      "pali": "Paññāsīso mahāñāṇī,"
    },
    {
      "id": "thag18.1:40.4",
      "pali": "sadā carati nibbuto”ti."
    },
    {
      "id": "thag18.1:40.5",
      "pali": "… Mahākassapo thero …"
    },
    {
      "id": "thag18.1:40.6",
      "pali": "Cattālīsanipāto niṭṭhito."
    },
    {
      "id": "thag18.1:41.1",
      "pali": "Cattālīsanipātamhi,"
    },
    {
      "id": "thag18.1:41.2",
      "pali": "mahākassapasavhayo;"
    },
    {
      "id": "thag18.1:41.3",
      "pali": "Ekova thero gāthāyo,"
    },
    {
      "id": "thag18.1:41.4",
      "pali": "cattālīsa duvepi cāti."
    }
  ]
}
