{
  "uid": "tha-ap352",
  "title": "Ekañjaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap352:1.1",
      "pali": "“Romaso nāma sambuddho,"
    },
    {
      "id": "tha-ap352:1.2",
      "pali": "nadīkūle vasī tadā;"
    },
    {
      "id": "tha-ap352:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap352:1.4",
      "pali": "pītaraṁsiṁva bhāṇumaṁ."
    },
    {
      "id": "tha-ap352:2.1",
      "pali": "Ukkāmukhapahaṭṭhaṁva,"
    },
    {
      "id": "tha-ap352:2.2",
      "pali": "khadiraṅgārasannibhaṁ;"
    },
    {
      "id": "tha-ap352:2.3",
      "pali": "Osadhiṁva virocantaṁ,"
    },
    {
      "id": "tha-ap352:2.4",
      "pali": "ekañjalimakāsahaṁ."
    },
    {
      "id": "tha-ap352:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap352:3.2",
      "pali": "yaṁ añjalimakāsahaṁ;"
    },
    {
      "id": "tha-ap352:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap352:3.4",
      "pali": "añjaliyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap352:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap352:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap352:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap352:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekañjaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap352:6.1",
      "pali": "Ekañjaliyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap352:7.1",
      "pali": "Ekapadumiyavaggo pañcatiṁsatimo."
    },
    {
      "id": "tha-ap352:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap352:9.1",
      "pali": "Padumī uppalamālī,"
    },
    {
      "id": "tha-ap352:9.2",
      "pali": "dhajo kiṅkaṇikaṁ naḷaṁ;"
    },
    {
      "id": "tha-ap352:9.3",
      "pali": "Campako padumo muṭṭhi,"
    },
    {
      "id": "tha-ap352:9.4",
      "pali": "tindukekañjalī tathā;"
    },
    {
      "id": "tha-ap352:9.5",
      "pali": "Cha ca saṭṭhi ca gāthāyo,"
    },
    {
      "id": "tha-ap352:9.6",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
