{
  "uid": "tha-ap329",
  "title": "Nigguṇḍipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap329:1.1",
      "pali": "“Yadā devo devakāyā,"
    },
    {
      "id": "tha-ap329:1.2",
      "pali": "cavate āyusaṅkhayā;"
    },
    {
      "id": "tha-ap329:1.3",
      "pali": "Tayo saddā niccharanti,"
    },
    {
      "id": "tha-ap329:1.4",
      "pali": "devānaṁ anumodataṁ."
    },
    {
      "id": "tha-ap329:2.1",
      "pali": "‘Ito bho sugatiṁ gaccha,"
    },
    {
      "id": "tha-ap329:2.2",
      "pali": "manussānaṁ sahabyataṁ;"
    },
    {
      "id": "tha-ap329:2.3",
      "pali": "Manussabhūto saddhamme,"
    },
    {
      "id": "tha-ap329:2.4",
      "pali": "labha saddhaṁ anuttaraṁ."
    },
    {
      "id": "tha-ap329:3.1",
      "pali": "Sā te saddhā niviṭṭhāssa,"
    },
    {
      "id": "tha-ap329:3.2",
      "pali": "mūlajātā patiṭṭhitā;"
    },
    {
      "id": "tha-ap329:3.3",
      "pali": "Yāvajīvaṁ asaṁhīrā,"
    },
    {
      "id": "tha-ap329:3.4",
      "pali": "saddhamme suppavedite."
    },
    {
      "id": "tha-ap329:4.1",
      "pali": "Kāyena kusalaṁ katvā,"
    },
    {
      "id": "tha-ap329:4.2",
      "pali": "vācāya kusalaṁ bahuṁ;"
    },
    {
      "id": "tha-ap329:4.3",
      "pali": "Manasā kusalaṁ katvā,"
    },
    {
      "id": "tha-ap329:4.4",
      "pali": "abyāpajjaṁ nirūpadhiṁ."
    },
    {
      "id": "tha-ap329:5.1",
      "pali": "Tato opadhikaṁ puññaṁ,"
    },
    {
      "id": "tha-ap329:5.2",
      "pali": "katvā dānena taṁ bahuṁ;"
    },
    {
      "id": "tha-ap329:5.3",
      "pali": "Aññepi macce saddhamme,"
    },
    {
      "id": "tha-ap329:5.4",
      "pali": "brahmacariye nivesaya’."
    },
    {
      "id": "tha-ap329:6.1",
      "pali": "Imāya anukampāya,"
    },
    {
      "id": "tha-ap329:6.2",
      "pali": "devādevaṁ yadā vidū;"
    },
    {
      "id": "tha-ap329:6.3",
      "pali": "Cavantaṁ anumodanti,"
    },
    {
      "id": "tha-ap329:6.4",
      "pali": "ehi deva punappunaṁ."
    },
    {
      "id": "tha-ap329:7.1",
      "pali": "‘Saṁvego me tadā āsi,"
    },
    {
      "id": "tha-ap329:7.2",
      "pali": "devasaṅghe samāgate;"
    },
    {
      "id": "tha-ap329:7.3",
      "pali": "Kaṁsu nāma ahaṁ yoniṁ,"
    },
    {
      "id": "tha-ap329:7.4",
      "pali": "gamissāmi ito cuto’."
    },
    {
      "id": "tha-ap329:8.1",
      "pali": "Mama saṁvegamaññāya,"
    },
    {
      "id": "tha-ap329:8.2",
      "pali": "samaṇo bhāvitindriyo;"
    },
    {
      "id": "tha-ap329:8.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap329:8.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap329:9.1",
      "pali": "Sumano nāma nāmena,"
    },
    {
      "id": "tha-ap329:9.2",
      "pali": "padumuttarasāvako;"
    },
    {
      "id": "tha-ap329:9.3",
      "pali": "Atthadhammānusāsitvā,"
    },
    {
      "id": "tha-ap329:9.4",
      "pali": "saṁvejesi mamaṁ tadā."
    },
    {
      "id": "tha-ap329:10.1",
      "pali": "Dvādasamaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap329:11.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap329:11.2",
      "pali": "buddhe cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap329:11.3",
      "pali": "Taṁ dhīraṁ abhivādetvā,"
    },
    {
      "id": "tha-ap329:11.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap329:12.1",
      "pali": "Upapajjiṁ sa tattheva,"
    },
    {
      "id": "tha-ap329:12.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap329:12.3",
      "pali": "Vasanto mātukucchimhi,"
    },
    {
      "id": "tha-ap329:12.4",
      "pali": "puna dhāreti mātuyā."
    },
    {
      "id": "tha-ap329:13.1",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap329:13.2",
      "pali": "tidase upapajjahaṁ;"
    },
    {
      "id": "tha-ap329:13.3",
      "pali": "Etthantare na passāmi,"
    },
    {
      "id": "tha-ap329:13.4",
      "pali": "domanassamahaṁ tadā."
    },
    {
      "id": "tha-ap329:14.1",
      "pali": "Tāvatiṁsā cavitvāna,"
    },
    {
      "id": "tha-ap329:14.2",
      "pali": "mātukucchiṁ samokkamiṁ;"
    },
    {
      "id": "tha-ap329:14.3",
      "pali": "Nikkhamitvāna kucchimhā,"
    },
    {
      "id": "tha-ap329:14.4",
      "pali": "kaṇhasukkaṁ ajānahaṁ."
    },
    {
      "id": "tha-ap329:15.1",
      "pali": "Jātiyā sattavassova,"
    },
    {
      "id": "tha-ap329:15.2",
      "pali": "ārāmaṁ pāvisiṁ ahaṁ;"
    },
    {
      "id": "tha-ap329:15.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap329:15.4",
      "pali": "sakyaputtassa tādino."
    },
    {
      "id": "tha-ap329:16.1",
      "pali": "Vitthārike pāvacane,"
    },
    {
      "id": "tha-ap329:16.2",
      "pali": "bāhujaññamhi sāsane;"
    },
    {
      "id": "tha-ap329:16.3",
      "pali": "Addasaṁ sāsanakare,"
    },
    {
      "id": "tha-ap329:16.4",
      "pali": "bhikkhavo tattha satthuno."
    },
    {
      "id": "tha-ap329:17.1",
      "pali": "Sāvatthi nāma nagaraṁ,"
    },
    {
      "id": "tha-ap329:17.2",
      "pali": "rājā tatthāsi kosalo;"
    },
    {
      "id": "tha-ap329:17.3",
      "pali": "Rathena nāgayuttena,"
    },
    {
      "id": "tha-ap329:17.4",
      "pali": "upesi bodhimuttamaṁ."
    },
    {
      "id": "tha-ap329:18.1",
      "pali": "Tassāhaṁ nāgaṁ disvāna,"
    },
    {
      "id": "tha-ap329:18.2",
      "pali": "pubbakammaṁ anussariṁ;"
    },
    {
      "id": "tha-ap329:18.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap329:18.4",
      "pali": "samayaṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap329:19.1",
      "pali": "Jātiyā sattavassova,"
    },
    {
      "id": "tha-ap329:19.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap329:19.3",
      "pali": "Yo so buddhaṁ upaṭṭhāsi,"
    },
    {
      "id": "tha-ap329:19.4",
      "pali": "ānando nāma sāvako."
    },
    {
      "id": "tha-ap329:20.1",
      "pali": "Gatimā dhitimā ceva,"
    },
    {
      "id": "tha-ap329:20.2",
      "pali": "satimā ca bahussuto;"
    },
    {
      "id": "tha-ap329:20.3",
      "pali": "Rañño cittaṁ pasādento,"
    },
    {
      "id": "tha-ap329:20.4",
      "pali": "niyyādesi mahājuti."
    },
    {
      "id": "tha-ap329:21.1",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "tha-ap329:21.2",
      "pali": "pubbakammaṁ anussariṁ;"
    },
    {
      "id": "tha-ap329:21.3",
      "pali": "Tattheva ṭhitako santo,"
    },
    {
      "id": "tha-ap329:21.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap329:22.1",
      "pali": "Ekaṁsaṁ cīvaraṁ katvā,"
    },
    {
      "id": "tha-ap329:22.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap329:22.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap329:22.4",
      "pali": "imaṁ vācaṁ udīrayiṁ."
    },
    {
      "id": "tha-ap329:23.1",
      "pali": "‘Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap329:23.2",
      "pali": "dvipadindassa satthuno;"
    },
    {
      "id": "tha-ap329:23.3",
      "pali": "Nigguṇḍipupphaṁ paggayha,"
    },
    {
      "id": "tha-ap329:23.4",
      "pali": "sīhāsane ṭhapesahaṁ."
    },
    {
      "id": "tha-ap329:24.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap329:24.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap329:24.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap329:24.4",
      "pali": "hitvā jayaparājayaṁ’."
    },
    {
      "id": "tha-ap329:25.1",
      "pali": "Pañcavīsasahassamhi,"
    },
    {
      "id": "tha-ap329:25.2",
      "pali": "kappānaṁ manujādhipā;"
    },
    {
      "id": "tha-ap329:25.3",
      "pali": "Abbudanirabbudāni,"
    },
    {
      "id": "tha-ap329:25.4",
      "pali": "aṭṭhaṭṭhāsiṁsu khattiyā."
    },
    {
      "id": "tha-ap329:26.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap329:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap329:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap329:27.1",
      "pali": "Itthaṁ sudaṁ āyasmā nigguṇḍipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap329:28.1",
      "pali": "Nigguṇḍipupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
