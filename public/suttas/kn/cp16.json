{
  "uid": "cp16",
  "title": "Sīlapāramī 6",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp16:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp16:1.2",
      "pali": "sutattakanakasannibho;"
    },
    {
      "id": "cp16:1.3",
      "pali": "Migarājā ruru nāma,"
    },
    {
      "id": "cp16:1.4",
      "pali": "paramasīlasamāhito."
    },
    {
      "id": "cp16:2.1",
      "pali": "Ramme padese ramaṇīye,"
    },
    {
      "id": "cp16:2.2",
      "pali": "vivitte amanussake;"
    },
    {
      "id": "cp16:2.3",
      "pali": "Tattha vāsaṁ upagañchiṁ,"
    },
    {
      "id": "cp16:2.4",
      "pali": "gaṅgākūle manorame."
    },
    {
      "id": "cp16:3.1",
      "pali": "Atha upari gaṅgāya,"
    },
    {
      "id": "cp16:3.2",
      "pali": "dhanikehi paripīḷito;"
    },
    {
      "id": "cp16:3.3",
      "pali": "Puriso gaṅgāya papati,"
    },
    {
      "id": "cp16:3.4",
      "pali": "‘jīvāmi vā marāmi vā’."
    },
    {
      "id": "cp16:4.1",
      "pali": "Rattindivaṁ so gaṅgāya,"
    },
    {
      "id": "cp16:4.2",
      "pali": "vuyhamāno mahodake;"
    },
    {
      "id": "cp16:4.3",
      "pali": "Ravanto karuṇaṁ ravaṁ,"
    },
    {
      "id": "cp16:4.4",
      "pali": "majjhe gaṅgāya gacchati."
    },
    {
      "id": "cp16:5.1",
      "pali": "Tassāhaṁ saddaṁ sutvāna,"
    },
    {
      "id": "cp16:5.2",
      "pali": "karuṇaṁ paridevato;"
    },
    {
      "id": "cp16:5.3",
      "pali": "Gaṅgāya tīre ṭhatvāna,"
    },
    {
      "id": "cp16:5.4",
      "pali": "apucchiṁ ‘kosi tvaṁ naro’."
    },
    {
      "id": "cp16:6.1",
      "pali": "So me puṭṭho ca byākāsi,"
    },
    {
      "id": "cp16:6.2",
      "pali": "attano karaṇaṁ tadā;"
    },
    {
      "id": "cp16:6.3",
      "pali": "‘Dhanikehi bhīto tasito,"
    },
    {
      "id": "cp16:6.4",
      "pali": "pakkhandohaṁ mahānadiṁ’."
    },
    {
      "id": "cp16:7.1",
      "pali": "Tassa katvāna kāruññaṁ,"
    },
    {
      "id": "cp16:7.2",
      "pali": "cajitvā mama jīvitaṁ;"
    },
    {
      "id": "cp16:7.3",
      "pali": "Pavisitvā nīhariṁ tassa,"
    },
    {
      "id": "cp16:7.4",
      "pali": "andhakāramhi rattiyā."
    },
    {
      "id": "cp16:8.1",
      "pali": "Assatthakālamaññāya,"
    },
    {
      "id": "cp16:8.2",
      "pali": "tassāhaṁ idamabraviṁ;"
    },
    {
      "id": "cp16:8.3",
      "pali": "‘Ekaṁ taṁ varaṁ yācāmi,"
    },
    {
      "id": "cp16:8.4",
      "pali": "mā maṁ kassaci pāvada’."
    },
    {
      "id": "cp16:9.1",
      "pali": "Nagaraṁ gantvāna ācikkhi,"
    },
    {
      "id": "cp16:9.2",
      "pali": "pucchito dhanahetuko;"
    },
    {
      "id": "cp16:9.3",
      "pali": "Rājānaṁ so gahetvāna,"
    },
    {
      "id": "cp16:9.4",
      "pali": "upagañchi mamantikaṁ."
    },
    {
      "id": "cp16:10.1",
      "pali": "Yāvatā karaṇaṁ sabbaṁ,"
    },
    {
      "id": "cp16:10.2",
      "pali": "rañño ārocitaṁ mayā;"
    },
    {
      "id": "cp16:10.3",
      "pali": "Rājā sutvāna vacanaṁ,"
    },
    {
      "id": "cp16:10.4",
      "pali": "usuṁ tassa pakappayi;"
    },
    {
      "id": "cp16:10.5",
      "pali": "‘Idheva ghātayissāmi,"
    },
    {
      "id": "cp16:10.6",
      "pali": "mittadubbhiṁ anāriyaṁ’."
    },
    {
      "id": "cp16:11.1",
      "pali": "Tamahaṁ anurakkhanto,"
    },
    {
      "id": "cp16:11.2",
      "pali": "nimminiṁ mama attanā;"
    },
    {
      "id": "cp16:11.3",
      "pali": "‘Tiṭṭhateso mahārāja,"
    },
    {
      "id": "cp16:11.4",
      "pali": "kāmakāro bhavāmi te’."
    },
    {
      "id": "cp16:12.1",
      "pali": "Anurakkhiṁ mama sīlaṁ,"
    },
    {
      "id": "cp16:12.2",
      "pali": "nārakkhiṁ mama jīvitaṁ;"
    },
    {
      "id": "cp16:12.3",
      "pali": "Sīlavā hi tadā āsiṁ,"
    },
    {
      "id": "cp16:12.4",
      "pali": "bodhiyāyeva kāraṇā”ti."
    },
    {
      "id": "cp16:13.1",
      "pali": "Rurumigarājacariyaṁ chaṭṭhaṁ."
    }
  ]
}
