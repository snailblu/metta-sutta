{
  "uid": "tha-ap476",
  "title": "Sumanabījaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap476:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap476:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap476:1.3",
      "pali": "Sumano bījaniṁ gayha,"
    },
    {
      "id": "tha-ap476:1.4",
      "pali": "abījiṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap476:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap476:2.2",
      "pali": "abījiṁ bodhimuttamaṁ;"
    },
    {
      "id": "tha-ap476:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap476:2.4",
      "pali": "bījanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap476:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap476:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap476:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap476:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap476:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap476:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap476:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap476:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap476:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap476:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumanabījaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap476:7.1",
      "pali": "Sumanabījaniyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
