{
  "uid": "thig2.5",
  "title": "Cittātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.5:1.1",
      "pali": "“Kiñcāpi khomhi kisikā,"
    },
    {
      "id": "thig2.5:1.2",
      "pali": "gilānā bāḷhadubbalā;"
    },
    {
      "id": "thig2.5:1.3",
      "pali": "Daṇḍamolubbha gacchāmi,"
    },
    {
      "id": "thig2.5:1.4",
      "pali": "pabbataṁ abhirūhiya."
    },
    {
      "id": "thig2.5:2.1",
      "pali": "Saṅghāṭiṁ nikkhipitvāna,"
    },
    {
      "id": "thig2.5:2.2",
      "pali": "pattakañca nikujjiya;"
    },
    {
      "id": "thig2.5:2.3",
      "pali": "Sele khambhesimattānaṁ,"
    },
    {
      "id": "thig2.5:2.4",
      "pali": "tamokhandhaṁ padāliyā”ti."
    },
    {
      "id": "thig2.5:3.1",
      "pali": "… Cittā therī …."
    }
  ]
}
