{
  "uid": "ja417",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja417:1.1",
      "pali": "“Odātavatthā suci allakesā,"
    },
    {
      "id": "ja417:1.2",
      "pali": "Kaccāni kiṁ kumbhimadhissayitvā;"
    },
    {
      "id": "ja417:1.3",
      "pali": "Piṭṭhā tilā dhovasi taṇḍulāni,"
    },
    {
      "id": "ja417:1.4",
      "pali": "Tilodano hehiti kissahetu”."
    },
    {
      "id": "ja417:2.1",
      "pali": "“Na kho ayaṁ brāhmaṇa bhojanatthā,"
    },
    {
      "id": "ja417:2.2",
      "pali": "Tilodano hehiti sādhupakko;"
    },
    {
      "id": "ja417:2.3",
      "pali": "Dhammo mato tassa pahuttamajja,"
    },
    {
      "id": "ja417:2.4",
      "pali": "Ahaṁ karissāmi susānamajjhe”."
    },
    {
      "id": "ja417:3.1",
      "pali": "“Anuvicca kaccāni karohi kiccaṁ,"
    },
    {
      "id": "ja417:3.2",
      "pali": "Dhammo mato ko nu taveva saṁsi;"
    },
    {
      "id": "ja417:3.3",
      "pali": "Sahassanetto atulānubhāvo,"
    },
    {
      "id": "ja417:3.4",
      "pali": "Na miyyatī dhammavaro kadāci”."
    },
    {
      "id": "ja417:4.1",
      "pali": "“Daḷhappamāṇaṁ mama ettha brahme,"
    },
    {
      "id": "ja417:4.2",
      "pali": "Dhammo mato natthi mamettha kaṅkhā;"
    },
    {
      "id": "ja417:4.3",
      "pali": "Yeyeva dāni pāpā bhavanti,"
    },
    {
      "id": "ja417:4.4",
      "pali": "Te teva dāni sukhitā bhavanti."
    },
    {
      "id": "ja417:5.1",
      "pali": "Suṇisā hi mayhaṁ vañjhā ahosi,"
    },
    {
      "id": "ja417:5.2",
      "pali": "Sā maṁ vadhitvāna vijāyi puttaṁ;"
    },
    {
      "id": "ja417:5.3",
      "pali": "Sā dāni sabbassa kulassa issarā,"
    },
    {
      "id": "ja417:5.4",
      "pali": "Ahaṁ panamhi apaviddhā ekikā”."
    },
    {
      "id": "ja417:6.1",
      "pali": "“Jīvāmi vohaṁ na matohamasmi,"
    },
    {
      "id": "ja417:6.2",
      "pali": "Taveva atthāya idhāgatosmi;"
    },
    {
      "id": "ja417:6.3",
      "pali": "Yā taṁ vadhitvāna vijāyi puttaṁ,"
    },
    {
      "id": "ja417:6.4",
      "pali": "Sahāva puttena karomi bhasmaṁ”."
    },
    {
      "id": "ja417:7.1",
      "pali": "“Evañca te ruccati devarāja,"
    },
    {
      "id": "ja417:7.2",
      "pali": "Mameva atthāya idhāgatosi;"
    },
    {
      "id": "ja417:7.3",
      "pali": "Ahañca putto suṇisā ca nattā,"
    },
    {
      "id": "ja417:7.4",
      "pali": "Sammodamānā gharamāvasema”."
    },
    {
      "id": "ja417:8.1",
      "pali": "“Evañca te ruccati kātiyāni,"
    },
    {
      "id": "ja417:8.2",
      "pali": "Hatāpi santā na jahāsi dhammaṁ;"
    },
    {
      "id": "ja417:8.3",
      "pali": "Tuvañca putto suṇisā ca nattā,"
    },
    {
      "id": "ja417:8.4",
      "pali": "Sammodamānā gharamāvasetha."
    },
    {
      "id": "ja417:9.1",
      "pali": "Sā kātiyānī suṇisāya saddhiṁ,"
    },
    {
      "id": "ja417:9.2",
      "pali": "Sammodamānā gharamāvasittha;"
    },
    {
      "id": "ja417:9.3",
      "pali": "Putto ca nattā ca upaṭṭhahiṁsu,"
    },
    {
      "id": "ja417:9.4",
      "pali": "Devānamindena adhiggahītā”ti."
    },
    {
      "id": "ja417:10.1",
      "pali": "Kaccānijātakaṁ paṭhamaṁ."
    }
  ]
}
