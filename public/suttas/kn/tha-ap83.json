{
  "uid": "tha-ap83",
  "title": "Timirapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap83:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap83:1.2",
      "pali": "anusotaṁ vajāmahaṁ;"
    },
    {
      "id": "tha-ap83:1.3",
      "pali": "Nisinnaṁ samaṇaṁ disvā,"
    },
    {
      "id": "tha-ap83:1.4",
      "pali": "vippasannamanāvilaṁ."
    },
    {
      "id": "tha-ap83:2.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap83:2.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "tha-ap83:2.3",
      "pali": "Tārayissati tiṇṇoyaṁ,"
    },
    {
      "id": "tha-ap83:2.4",
      "pali": "dantoyaṁ damayissati."
    },
    {
      "id": "tha-ap83:3.1",
      "pali": "Assāsissati assattho,"
    },
    {
      "id": "tha-ap83:3.2",
      "pali": "santo ca samayissati;"
    },
    {
      "id": "tha-ap83:3.3",
      "pali": "Mocayissati mutto ca,"
    },
    {
      "id": "tha-ap83:3.4",
      "pali": "nibbāpessati nibbuto."
    },
    {
      "id": "tha-ap83:4.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "tha-ap83:4.2",
      "pali": "siddhatthassa mahesino;"
    },
    {
      "id": "tha-ap83:4.3",
      "pali": "Gahetvā timirapupphaṁ,"
    },
    {
      "id": "tha-ap83:4.4",
      "pali": "matthake okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap83:5.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap83:5.2",
      "pali": "katvā ca naṁ padakkhiṇaṁ;"
    },
    {
      "id": "tha-ap83:5.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap83:5.4",
      "pali": "pakkāmiṁ aparaṁ disaṁ."
    },
    {
      "id": "tha-ap83:6.1",
      "pali": "Aciraṁ gatamattaṁ maṁ,"
    },
    {
      "id": "tha-ap83:6.2",
      "pali": "migarājā viheṭhayi;"
    },
    {
      "id": "tha-ap83:6.3",
      "pali": "Papātamanugacchanto,"
    },
    {
      "id": "tha-ap83:6.4",
      "pali": "tattheva papatiṁ ahaṁ."
    },
    {
      "id": "tha-ap83:7.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap83:7.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap83:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap83:7.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap83:8.1",
      "pali": "Chappaññāsamhi kappamhi,"
    },
    {
      "id": "tha-ap83:8.2",
      "pali": "sattevāsuṁ mahāyasā;"
    },
    {
      "id": "tha-ap83:8.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap83:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap83:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap83:9.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap83:9.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap83:9.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap83:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā timirapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap83:11.1",
      "pali": "Timirapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
