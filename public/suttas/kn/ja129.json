{
  "uid": "ja129",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja129:1.1",
      "pali": "“Nāyaṁ sikhā puññahetu,"
    },
    {
      "id": "ja129:1.2",
      "pali": "ghāsahetu ayaṁ sikhā;"
    },
    {
      "id": "ja129:1.3",
      "pali": "Nāguṭṭhigaṇanaṁ yāti,"
    },
    {
      "id": "ja129:1.4",
      "pali": "alaṁ te hotu aggikā”ti."
    },
    {
      "id": "ja129:2.1",
      "pali": "Aggikabhāradvājajātakaṁ navamaṁ."
    }
  ]
}
