{
  "uid": "ja458",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja458:1.1",
      "pali": "“Ekā nisinnā suci saññatūrū,"
    },
    {
      "id": "ja458:1.2",
      "pali": "Pāsādamāruyha aninditaṅgī;"
    },
    {
      "id": "ja458:1.3",
      "pali": "Yācāmi taṁ kinnaranettacakkhu,"
    },
    {
      "id": "ja458:1.4",
      "pali": "Imekarattiṁ ubhayo vasema”."
    },
    {
      "id": "ja458:2.1",
      "pali": "“Okiṇṇantaraparikhaṁ,"
    },
    {
      "id": "ja458:2.2",
      "pali": "daḷhamaṭṭālakoṭṭhakaṁ;"
    },
    {
      "id": "ja458:2.3",
      "pali": "Rakkhitaṁ khaggahatthehi,"
    },
    {
      "id": "ja458:2.4",
      "pali": "duppavesamidaṁ puraṁ."
    },
    {
      "id": "ja458:3.1",
      "pali": "Daharassa yuvino cāpi,"
    },
    {
      "id": "ja458:3.2",
      "pali": "āgamo ca na vijjati;"
    },
    {
      "id": "ja458:3.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja458:3.4",
      "pali": "saṅgamaṁ icchase mayā”."
    },
    {
      "id": "ja458:4.1",
      "pali": "“Yakkhohamasmi kalyāṇi,"
    },
    {
      "id": "ja458:4.2",
      "pali": "Āgatosmi tavantike;"
    },
    {
      "id": "ja458:4.3",
      "pali": "Tvaṁ maṁ nandaya bhaddante,"
    },
    {
      "id": "ja458:4.4",
      "pali": "Puṇṇakaṁsaṁ dadāmi te”."
    },
    {
      "id": "ja458:5.1",
      "pali": "“Devaṁ va yakkhaṁ atha vā manussaṁ,"
    },
    {
      "id": "ja458:5.2",
      "pali": "Na patthaye udayamaticca aññaṁ;"
    },
    {
      "id": "ja458:5.3",
      "pali": "Gaccheva tvaṁ yakkha mahānubhāva,"
    },
    {
      "id": "ja458:5.4",
      "pali": "Mā cassu gantvā punarāvajittha”."
    },
    {
      "id": "ja458:6.1",
      "pali": "“Yā sā rati uttamā kāmabhoginaṁ,"
    },
    {
      "id": "ja458:6.2",
      "pali": "Yaṁ hetu sattā visamaṁ caranti;"
    },
    {
      "id": "ja458:6.3",
      "pali": "Mā taṁ ratiṁ jīyi tuvaṁ sucimhite,"
    },
    {
      "id": "ja458:6.4",
      "pali": "Dadāmi te rūpiyaṁ kaṁsapūraṁ”."
    },
    {
      "id": "ja458:7.1",
      "pali": "“Nāriṁ naro nijjhapayaṁ dhanena,"
    },
    {
      "id": "ja458:7.2",
      "pali": "Ukkaṁsatī yattha karoti chandaṁ;"
    },
    {
      "id": "ja458:7.3",
      "pali": "Vipaccanīko tava devadhammo,"
    },
    {
      "id": "ja458:7.4",
      "pali": "Paccakkhato thokatarena esi”."
    },
    {
      "id": "ja458:8.1",
      "pali": "“Āyu ca vaṇṇo ca manussaloke,"
    },
    {
      "id": "ja458:8.2",
      "pali": "Nihīyati manujānaṁ sugatte;"
    },
    {
      "id": "ja458:8.3",
      "pali": "Teneva vaṇṇena dhanampi tuyhaṁ,"
    },
    {
      "id": "ja458:8.4",
      "pali": "Nihīyati jiṇṇatarāsi ajja."
    },
    {
      "id": "ja458:9.1",
      "pali": "Evaṁ me pekkhamānassa,"
    },
    {
      "id": "ja458:9.2",
      "pali": "rājaputti yasassini;"
    },
    {
      "id": "ja458:9.3",
      "pali": "Hāyateva tava vaṇṇo,"
    },
    {
      "id": "ja458:9.4",
      "pali": "ahorattānamaccaye”."
    },
    {
      "id": "ja458:10.1",
      "pali": "“Imināva tvaṁ vayasā,"
    },
    {
      "id": "ja458:10.2",
      "pali": "rājaputti sumedhase;"
    },
    {
      "id": "ja458:10.3",
      "pali": "Brahmacariyaṁ careyyāsi,"
    },
    {
      "id": "ja458:10.4",
      "pali": "bhiyyo vaṇṇavatī siyā”."
    },
    {
      "id": "ja458:11.1",
      "pali": "“Devā na jīranti yathā manussā,"
    },
    {
      "id": "ja458:11.2",
      "pali": "Gattesu tesaṁ valiyo na honti;"
    },
    {
      "id": "ja458:11.3",
      "pali": "Pucchāmi taṁ yakkha mahānubhāva,"
    },
    {
      "id": "ja458:11.4",
      "pali": "Kathaṁ nu devāna sarīradeho”."
    },
    {
      "id": "ja458:12.1",
      "pali": "“Devā na jīranti yathā manussā,"
    },
    {
      "id": "ja458:12.2",
      "pali": "Gattesu tesaṁ valiyo na honti;"
    },
    {
      "id": "ja458:12.3",
      "pali": "Suve suve bhiyyatarova tesaṁ,"
    },
    {
      "id": "ja458:12.4",
      "pali": "Dibbo ca vaṇṇo vipulā ca bhogā”."
    },
    {
      "id": "ja458:13.1",
      "pali": "“Kiṁsūdha bhītā janatā anekā,"
    },
    {
      "id": "ja458:13.2",
      "pali": "Maggo ca nekāyatanaṁ pavutto;"
    },
    {
      "id": "ja458:13.3",
      "pali": "Pucchāmi taṁ yakkha mahānubhāva,"
    },
    {
      "id": "ja458:13.4",
      "pali": "Katthaṭṭhito paralokaṁ na bhāye”."
    },
    {
      "id": "ja458:14.1",
      "pali": "“Vācaṁ manañca paṇidhāya sammā,"
    },
    {
      "id": "ja458:14.2",
      "pali": "Kāyena pāpāni akubbamāno;"
    },
    {
      "id": "ja458:14.3",
      "pali": "Bahunnapānaṁ gharamāvasanto,"
    },
    {
      "id": "ja458:14.4",
      "pali": "Saddho mudū saṁvibhāgī vadaññū;"
    },
    {
      "id": "ja458:14.5",
      "pali": "Saṅgāhako sakhilo saṇhavāco,"
    },
    {
      "id": "ja458:14.6",
      "pali": "Etthaṭṭhito paralokaṁ na bhāye”."
    },
    {
      "id": "ja458:15.1",
      "pali": "“Anusāsasi maṁ yakkha,"
    },
    {
      "id": "ja458:15.2",
      "pali": "yathā mātā yathā pitā;"
    },
    {
      "id": "ja458:15.3",
      "pali": "Uḷāravaṇṇaṁ pucchāmi,"
    },
    {
      "id": "ja458:15.4",
      "pali": "ko nu tvamasi subrahā”."
    },
    {
      "id": "ja458:16.1",
      "pali": "“Udayohamasmi kalyāṇi,"
    },
    {
      "id": "ja458:16.2",
      "pali": "saṅgarattā idhāgato;"
    },
    {
      "id": "ja458:16.3",
      "pali": "Āmanta kho taṁ gacchāmi,"
    },
    {
      "id": "ja458:16.4",
      "pali": "muttosmi tava saṅgarā”."
    },
    {
      "id": "ja458:17.1",
      "pali": "“Sace kho tvaṁ udayosi,"
    },
    {
      "id": "ja458:17.2",
      "pali": "saṅgarattā idhāgato;"
    },
    {
      "id": "ja458:17.3",
      "pali": "Anusāsa maṁ rājaputta,"
    },
    {
      "id": "ja458:17.4",
      "pali": "yathāssa puna saṅgamo”."
    },
    {
      "id": "ja458:18.1",
      "pali": "“Atipatati vayo khaṇo tatheva,"
    },
    {
      "id": "ja458:18.2",
      "pali": "Ṭhānaṁ natthi dhuvaṁ cavanti sattā;"
    },
    {
      "id": "ja458:18.3",
      "pali": "Parijiyyati addhuvaṁ sarīraṁ,"
    },
    {
      "id": "ja458:18.4",
      "pali": "Udaye mā pamāda carassu dhammaṁ."
    },
    {
      "id": "ja458:19.1",
      "pali": "Kasiṇā pathavī dhanassa pūrā,"
    },
    {
      "id": "ja458:19.2",
      "pali": "Ekasseva siyā anaññadheyyā;"
    },
    {
      "id": "ja458:19.3",
      "pali": "Tañcāpi jahati avītarāgo,"
    },
    {
      "id": "ja458:19.4",
      "pali": "Udaye mā pamāda carassu dhammaṁ."
    },
    {
      "id": "ja458:20.1",
      "pali": "Mātā ca pitā ca bhātaro ca,"
    },
    {
      "id": "ja458:20.2",
      "pali": "Bhariyā yāpi dhanena hoti kītā;"
    },
    {
      "id": "ja458:20.3",
      "pali": "Te cāpi jahanti aññamaññaṁ,"
    },
    {
      "id": "ja458:20.4",
      "pali": "Udaye mā pamāda carassu dhammaṁ."
    },
    {
      "id": "ja458:21.1",
      "pali": "Kāyo parabhojananti ñatvā,"
    },
    {
      "id": "ja458:21.2",
      "pali": "Saṁsāre sugatiñca duggatiñca;"
    },
    {
      "id": "ja458:21.3",
      "pali": "Ittaravāsoti jāniyāna,"
    },
    {
      "id": "ja458:21.4",
      "pali": "Udaye mā pamāda carassu dhammaṁ”."
    },
    {
      "id": "ja458:22.1",
      "pali": "“Sādhu bhāsatiyaṁ yakkho,"
    },
    {
      "id": "ja458:22.2",
      "pali": "appaṁ maccāna jīvitaṁ;"
    },
    {
      "id": "ja458:22.3",
      "pali": "Kasirañca parittañca,"
    },
    {
      "id": "ja458:22.4",
      "pali": "tañca dukkhena saṁyutaṁ;"
    },
    {
      "id": "ja458:22.5",
      "pali": "Sāhaṁ ekā pabbajissāmi,"
    },
    {
      "id": "ja458:22.6",
      "pali": "hitvā kāsiṁ surundhanan”ti."
    },
    {
      "id": "ja458:23.1",
      "pali": "Udayajātakaṁ catutthaṁ."
    }
  ]
}
