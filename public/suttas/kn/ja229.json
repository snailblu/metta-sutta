{
  "uid": "ja229",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja229:1.1",
      "pali": "“Gajaggameghehi hayaggamālibhi,"
    },
    {
      "id": "ja229:1.2",
      "pali": "Rathūmijātehi sarābhivassebhi;"
    },
    {
      "id": "ja229:1.3",
      "pali": "Tharuggahāvaṭṭadaḷhappahāribhi,"
    },
    {
      "id": "ja229:1.4",
      "pali": "Parivāritā takkasilā samantato."
    },
    {
      "id": "ja229:2.1",
      "pali": "Abhidhāvatha cūpadhāvatha ca,"
    },
    {
      "id": "ja229:2.2",
      "pali": "Vividhā vināditā vadantibhi;"
    },
    {
      "id": "ja229:2.3",
      "pali": "Vattatajja tumulo ghoso yathā,"
    },
    {
      "id": "ja229:2.4",
      "pali": "Vijjulatā jaladharassa gajjato”ti."
    },
    {
      "id": "ja229:3.1",
      "pali": "Palāyitajātakaṁ navamaṁ."
    }
  ]
}
