{
  "uid": "tha-ap561",
  "title": "Sivakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap561:1.1",
      "pali": "“Esanāya carantassa,"
    },
    {
      "id": "tha-ap561:1.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap561:1.3",
      "pali": "Rittakaṁ pattaṁ disvāna,"
    },
    {
      "id": "tha-ap561:1.4",
      "pali": "kummāsaṁ pūrayiṁ ahaṁ."
    },
    {
      "id": "tha-ap561:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap561:2.2",
      "pali": "yaṁ bhikkhamadadiṁ tadā;"
    },
    {
      "id": "tha-ap561:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap561:2.4",
      "pali": "kummāsassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap561:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap561:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap561:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap561:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap561:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap561:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap561:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap561:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap561:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap561:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sivakatthero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap561:7.1",
      "pali": "Sivakattherassāpadānaṁ navamaṁ."
    }
  ]
}
