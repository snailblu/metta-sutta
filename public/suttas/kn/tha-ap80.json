{
  "uid": "tha-ap80",
  "title": "Pāṭalipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap80:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap80:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap80:1.3",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap80:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap80:2.1",
      "pali": "Seṭṭhiputto tadā āsiṁ,"
    },
    {
      "id": "tha-ap80:2.2",
      "pali": "sukhumālo sukhedhito;"
    },
    {
      "id": "tha-ap80:2.3",
      "pali": "Ucchaṅge pāṭalipupphaṁ,"
    },
    {
      "id": "tha-ap80:2.4",
      "pali": "katvāna abhisaṁhariṁ."
    },
    {
      "id": "tha-ap80:3.1",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap80:3.2",
      "pali": "pupphehi abhipūjayiṁ;"
    },
    {
      "id": "tha-ap80:3.3",
      "pali": "Tissaṁ lokaviduṁ nāthaṁ,"
    },
    {
      "id": "tha-ap80:3.4",
      "pali": "naradevaṁ namassahaṁ."
    },
    {
      "id": "tha-ap80:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap80:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap80:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap80:4.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap80:5.1",
      "pali": "Ito tesaṭṭhikappamhi,"
    },
    {
      "id": "tha-ap80:5.2",
      "pali": "abhisammatanāmako;"
    },
    {
      "id": "tha-ap80:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap80:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap80:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap80:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap80:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap80:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāṭalipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap80:8.1",
      "pali": "Pāṭalipupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
