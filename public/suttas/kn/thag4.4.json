{
  "uid": "thag4.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.4:1.1",
      "pali": "“Dhiratthu pūre duggandhe,"
    },
    {
      "id": "thag4.4:1.2",
      "pali": "mārapakkhe avassute;"
    },
    {
      "id": "thag4.4:1.3",
      "pali": "Navasotāni te kāye,"
    },
    {
      "id": "thag4.4:1.4",
      "pali": "yāni sandanti sabbadā."
    },
    {
      "id": "thag4.4:2.1",
      "pali": "Mā purāṇaṁ amaññittho,"
    },
    {
      "id": "thag4.4:2.2",
      "pali": "māsādesi tathāgate;"
    },
    {
      "id": "thag4.4:2.3",
      "pali": "Saggepi te na rajjanti,"
    },
    {
      "id": "thag4.4:2.4",
      "pali": "kimaṅgaṁ pana mānuse."
    },
    {
      "id": "thag4.4:3.1",
      "pali": "Ye ca kho bālā dummedhā,"
    },
    {
      "id": "thag4.4:3.2",
      "pali": "dummantī mohapārutā;"
    },
    {
      "id": "thag4.4:3.3",
      "pali": "Tādisā tattha rajjanti,"
    },
    {
      "id": "thag4.4:3.4",
      "pali": "mārakhittamhi bandhane."
    },
    {
      "id": "thag4.4:4.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "thag4.4:4.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "thag4.4:4.3",
      "pali": "Tādī tattha na rajjanti,"
    },
    {
      "id": "thag4.4:4.4",
      "pali": "chinnasuttā abandhanā”ti."
    },
    {
      "id": "thag4.4:4.5",
      "pali": "… Nandako thero …."
    }
  ]
}
