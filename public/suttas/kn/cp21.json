{
  "uid": "cp21",
  "title": "Nekkhammapāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp21:1.1",
      "pali": "“Yadāhaṁ amitayaso,"
    },
    {
      "id": "cp21:1.2",
      "pali": "Rājaputto yudhañjayo;"
    },
    {
      "id": "cp21:1.3",
      "pali": "Ussāvabinduṁ sūriyātape,"
    },
    {
      "id": "cp21:1.4",
      "pali": "Patitaṁ disvāna saṁvijiṁ."
    },
    {
      "id": "cp21:2.1",
      "pali": "Taññevādhipatiṁ katvā,"
    },
    {
      "id": "cp21:2.2",
      "pali": "saṁvegamanubrūhayiṁ;"
    },
    {
      "id": "cp21:2.3",
      "pali": "Mātāpitū ca vanditvā,"
    },
    {
      "id": "cp21:2.4",
      "pali": "pabbajjamanuyācahaṁ."
    },
    {
      "id": "cp21:3.1",
      "pali": "Yācanti maṁ pañjalikā,"
    },
    {
      "id": "cp21:3.2",
      "pali": "sanegamā saraṭṭhakā;"
    },
    {
      "id": "cp21:3.3",
      "pali": "‘Ajjeva putta paṭipajja,"
    },
    {
      "id": "cp21:3.4",
      "pali": "iddhaṁ phītaṁ mahāmahiṁ’."
    },
    {
      "id": "cp21:4.1",
      "pali": "Sarājake sahorodhe,"
    },
    {
      "id": "cp21:4.2",
      "pali": "sanegame saraṭṭhake;"
    },
    {
      "id": "cp21:4.3",
      "pali": "Karuṇaṁ paridevante,"
    },
    {
      "id": "cp21:4.4",
      "pali": "anapekkhova pariccajiṁ."
    },
    {
      "id": "cp21:5.1",
      "pali": "Kevalaṁ pathaviṁ rajjaṁ,"
    },
    {
      "id": "cp21:5.2",
      "pali": "ñātiparijanaṁ yasaṁ;"
    },
    {
      "id": "cp21:5.3",
      "pali": "Cajamāno na cintesiṁ,"
    },
    {
      "id": "cp21:5.4",
      "pali": "bodhiyāyeva kāraṇā."
    },
    {
      "id": "cp21:6.1",
      "pali": "Mātāpitā na me dessā,"
    },
    {
      "id": "cp21:6.2",
      "pali": "napi me dessaṁ mahāyasaṁ;"
    },
    {
      "id": "cp21:6.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp21:6.4",
      "pali": "tasmā rajjaṁ pariccajin”ti."
    },
    {
      "id": "cp21:7.1",
      "pali": "Yudhañjayacariyaṁ paṭhamaṁ."
    }
  ]
}
