{
  "uid": "tha-ap264",
  "title": "Telamakkhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap264:1.1",
      "pali": "“Siddhatthamhi bhagavati,"
    },
    {
      "id": "tha-ap264:1.2",
      "pali": "nibbutamhi narāsabhe;"
    },
    {
      "id": "tha-ap264:1.3",
      "pali": "Bodhiyā vedikāyāhaṁ,"
    },
    {
      "id": "tha-ap264:1.4",
      "pali": "telaṁ makkhesi tāvade."
    },
    {
      "id": "tha-ap264:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap264:2.2",
      "pali": "yaṁ telaṁ makkhayiṁ tadā;"
    },
    {
      "id": "tha-ap264:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap264:2.4",
      "pali": "makkhanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap264:3.1",
      "pali": "Catuvīse ito kappe,"
    },
    {
      "id": "tha-ap264:3.2",
      "pali": "succhavi nāma khattiyo;"
    },
    {
      "id": "tha-ap264:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap264:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap264:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap264:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap264:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap264:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā telamakkhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap264:6.1",
      "pali": "Telamakkhiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
