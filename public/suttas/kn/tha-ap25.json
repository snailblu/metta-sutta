{
  "uid": "tha-ap25",
  "title": "3 Tisaraṇagamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap25:1.1",
      "pali": "“Nagare candavatiyā,"
    },
    {
      "id": "tha-ap25:1.2",
      "pali": "mātuupaṭṭhāko ahuṁ;"
    },
    {
      "id": "tha-ap25:1.3",
      "pali": "Andhā mātā pitā mayhaṁ,"
    },
    {
      "id": "tha-ap25:1.4",
      "pali": "te posemi ahaṁ tadā."
    },
    {
      "id": "tha-ap25:2.1",
      "pali": "Rahogato nisīditvā,"
    },
    {
      "id": "tha-ap25:2.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "tha-ap25:2.3",
      "pali": "Posento mātāpitaro,"
    },
    {
      "id": "tha-ap25:2.4",
      "pali": "pabbajjaṁ na labhāmahaṁ."
    },
    {
      "id": "tha-ap25:3.1",
      "pali": "Mahandhakārapihitā,"
    },
    {
      "id": "tha-ap25:3.2",
      "pali": "tividhaggīhi ḍayhare;"
    },
    {
      "id": "tha-ap25:3.3",
      "pali": "Etādise bhave jāte,"
    },
    {
      "id": "tha-ap25:3.4",
      "pali": "natthi koci vināyako."
    },
    {
      "id": "tha-ap25:4.1",
      "pali": "Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap25:4.2",
      "pali": "dippati dāni sāsanaṁ;"
    },
    {
      "id": "tha-ap25:4.3",
      "pali": "Sakkā uddharituṁ attā,"
    },
    {
      "id": "tha-ap25:4.4",
      "pali": "puññakāmena jantunā."
    },
    {
      "id": "tha-ap25:5.1",
      "pali": "Uggayha tīṇi saraṇe,"
    },
    {
      "id": "tha-ap25:5.2",
      "pali": "paripuṇṇāni gopayiṁ;"
    },
    {
      "id": "tha-ap25:5.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap25:5.4",
      "pali": "paṭimokkhāmi duggatiṁ."
    },
    {
      "id": "tha-ap25:6.1",
      "pali": "Nisabho nāma samaṇo,"
    },
    {
      "id": "tha-ap25:6.2",
      "pali": "buddhassa aggasāvako;"
    },
    {
      "id": "tha-ap25:6.3",
      "pali": "Tamahaṁ upagantvāna,"
    },
    {
      "id": "tha-ap25:6.4",
      "pali": "saraṇagamanaṁ gahiṁ."
    },
    {
      "id": "tha-ap25:7.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap25:7.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap25:7.3",
      "pali": "Tāvatā saraṇagamanaṁ,"
    },
    {
      "id": "tha-ap25:7.4",
      "pali": "paripuṇṇaṁ agopayiṁ."
    },
    {
      "id": "tha-ap25:8.1",
      "pali": "Carime vattamānamhi,"
    },
    {
      "id": "tha-ap25:8.2",
      "pali": "saraṇaṁ taṁ anussariṁ;"
    },
    {
      "id": "tha-ap25:8.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap25:8.4",
      "pali": "tāvatiṁsaṁ agacchahaṁ."
    },
    {
      "id": "tha-ap25:9.1",
      "pali": "Devalokagato santo,"
    },
    {
      "id": "tha-ap25:9.2",
      "pali": "puññakammasamāhito;"
    },
    {
      "id": "tha-ap25:9.3",
      "pali": "Yaṁ desaṁ upapajjāmi,"
    },
    {
      "id": "tha-ap25:9.4",
      "pali": "aṭṭha hetū labhāmahaṁ."
    },
    {
      "id": "tha-ap25:10.1",
      "pali": "Disāsu pūjito homi,"
    },
    {
      "id": "tha-ap25:10.2",
      "pali": "tikkhapañño bhavāmahaṁ;"
    },
    {
      "id": "tha-ap25:10.3",
      "pali": "Sabbe devānuvattanti,"
    },
    {
      "id": "tha-ap25:10.4",
      "pali": "amitabhogaṁ labhāmahaṁ."
    },
    {
      "id": "tha-ap25:11.1",
      "pali": "Suvaṇṇavaṇṇo sabbattha,"
    },
    {
      "id": "tha-ap25:11.2",
      "pali": "paṭikanto bhavāmahaṁ;"
    },
    {
      "id": "tha-ap25:11.3",
      "pali": "Mittānaṁ acalo homi,"
    },
    {
      "id": "tha-ap25:11.4",
      "pali": "yaso abbhuggato mamaṁ."
    },
    {
      "id": "tha-ap25:12.1",
      "pali": "Asītikkhattu devindo,"
    },
    {
      "id": "tha-ap25:12.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap25:12.3",
      "pali": "Dibbasukhaṁ anubhaviṁ,"
    },
    {
      "id": "tha-ap25:12.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap25:13.1",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap25:13.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap25:13.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap25:13.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap25:14.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap25:14.2",
      "pali": "puññakammasamāhito;"
    },
    {
      "id": "tha-ap25:14.3",
      "pali": "Pure sāvatthiyaṁ jāto,"
    },
    {
      "id": "tha-ap25:14.4",
      "pali": "mahāsāle suaḍḍhake."
    },
    {
      "id": "tha-ap25:15.1",
      "pali": "Nagarā nikkhamitvāna,"
    },
    {
      "id": "tha-ap25:15.2",
      "pali": "dārakehi purakkhato;"
    },
    {
      "id": "tha-ap25:15.3",
      "pali": "Hasakhiḍḍasamaṅgīhaṁ,"
    },
    {
      "id": "tha-ap25:15.4",
      "pali": "saṅghārāmaṁ upāgamiṁ."
    },
    {
      "id": "tha-ap25:16.1",
      "pali": "Tatthaddasāsiṁ samaṇaṁ,"
    },
    {
      "id": "tha-ap25:16.2",
      "pali": "vippamuttaṁ nirūpadhiṁ;"
    },
    {
      "id": "tha-ap25:16.3",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "tha-ap25:16.4",
      "pali": "saraṇañca adāsi me."
    },
    {
      "id": "tha-ap25:17.1",
      "pali": "Sohaṁ sutvāna saraṇaṁ,"
    },
    {
      "id": "tha-ap25:17.2",
      "pali": "saraṇaṁ me anussariṁ;"
    },
    {
      "id": "tha-ap25:17.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap25:17.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap25:18.1",
      "pali": "Jātiyā sattame vasse,"
    },
    {
      "id": "tha-ap25:18.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap25:18.3",
      "pali": "Upasampādayi buddho,"
    },
    {
      "id": "tha-ap25:18.4",
      "pali": "guṇamaññāya cakkhumā."
    },
    {
      "id": "tha-ap25:19.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap25:19.2",
      "pali": "saraṇāni agacchahaṁ;"
    },
    {
      "id": "tha-ap25:19.3",
      "pali": "Tato me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap25:19.4",
      "pali": "phalaṁ dassesi me idha."
    },
    {
      "id": "tha-ap25:20.1",
      "pali": "Sugopitaṁ me saraṇaṁ,"
    },
    {
      "id": "tha-ap25:20.2",
      "pali": "mānasaṁ suppaṇīhitaṁ;"
    },
    {
      "id": "tha-ap25:20.3",
      "pali": "Anubhotvā yasaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap25:20.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap25:21.1",
      "pali": "Yesaṁ sotāvadhānatthi,"
    },
    {
      "id": "tha-ap25:21.2",
      "pali": "suṇotha mama bhāsato;"
    },
    {
      "id": "tha-ap25:21.3",
      "pali": "Ahaṁ vo kathayissāmi,"
    },
    {
      "id": "tha-ap25:21.4",
      "pali": "sāmaṁ diṭṭhaṁ padaṁ mama."
    },
    {
      "id": "tha-ap25:22.1",
      "pali": "‘Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap25:22.2",
      "pali": "vattate jinasāsanaṁ;"
    },
    {
      "id": "tha-ap25:22.3",
      "pali": "Amatā vāditā bherī,"
    },
    {
      "id": "tha-ap25:22.4",
      "pali": "sokasallavinodanā."
    },
    {
      "id": "tha-ap25:23.1",
      "pali": "Yathāsakena thāmena,"
    },
    {
      "id": "tha-ap25:23.2",
      "pali": "puññakkhette anuttare;"
    },
    {
      "id": "tha-ap25:23.3",
      "pali": "Adhikāraṁ kareyyātha,"
    },
    {
      "id": "tha-ap25:23.4",
      "pali": "passayissatha nibbutiṁ."
    },
    {
      "id": "tha-ap25:24.1",
      "pali": "Paggayha tīṇi saraṇe,"
    },
    {
      "id": "tha-ap25:24.2",
      "pali": "pañcasīlāni gopiya;"
    },
    {
      "id": "tha-ap25:24.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap25:24.4",
      "pali": "dukkhassantaṁ karissatha."
    },
    {
      "id": "tha-ap25:25.1",
      "pali": "Sammā dhammaṁ bhāvetvāna,"
    },
    {
      "id": "tha-ap25:25.2",
      "pali": "Sīlāni parigopiya;"
    },
    {
      "id": "tha-ap25:25.3",
      "pali": "Aciraṁ arahattaṁ vo,"
    },
    {
      "id": "tha-ap25:25.4",
      "pali": "Sabbepi pāpuṇissatha."
    },
    {
      "id": "tha-ap25:26.1",
      "pali": "Tevijjo iddhipattomhi,"
    },
    {
      "id": "tha-ap25:26.2",
      "pali": "cetopariyakovido;"
    },
    {
      "id": "tha-ap25:26.3",
      "pali": "Sāvako te mahāvīra,"
    },
    {
      "id": "tha-ap25:26.4",
      "pali": "saraṇo vandati satthuno’."
    },
    {
      "id": "tha-ap25:27.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap25:27.2",
      "pali": "saraṇaṁ buddhassa gacchahaṁ;"
    },
    {
      "id": "tha-ap25:27.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap25:27.4",
      "pali": "saraṇaṁ gamane phalaṁ."
    },
    {
      "id": "tha-ap25:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap25:28.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap25:28.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap25:28.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap25:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā tisaraṇagamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap25:30.1",
      "pali": "Tisaraṇagamaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
