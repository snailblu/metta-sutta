{
  "uid": "tha-ap192",
  "title": "Tivaṇṭipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap192:1.1",
      "pali": "“Abhibhūtaṁ panijjhanti,"
    },
    {
      "id": "tha-ap192:1.2",
      "pali": "Sabbe saṅgamma te mamaṁ;"
    },
    {
      "id": "tha-ap192:1.3",
      "pali": "Tesaṁ nijjhāyamānānaṁ,"
    },
    {
      "id": "tha-ap192:1.4",
      "pali": "Pariḷāho ajāyatha."
    },
    {
      "id": "tha-ap192:2.1",
      "pali": "Sunando nāma nāmena,"
    },
    {
      "id": "tha-ap192:2.2",
      "pali": "buddhassa sāvako tadā;"
    },
    {
      "id": "tha-ap192:2.3",
      "pali": "Dhammadassissa munino,"
    },
    {
      "id": "tha-ap192:2.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap192:3.1",
      "pali": "Ye me baddhacarā āsuṁ,"
    },
    {
      "id": "tha-ap192:3.2",
      "pali": "te me pupphaṁ aduṁ tadā;"
    },
    {
      "id": "tha-ap192:3.3",
      "pali": "Tāhaṁ pupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap192:3.4",
      "pali": "sāvake abhiropayiṁ."
    },
    {
      "id": "tha-ap192:4.1",
      "pali": "Sohaṁ kālaṅkato tattha,"
    },
    {
      "id": "tha-ap192:4.2",
      "pali": "punāpi upapajjahaṁ;"
    },
    {
      "id": "tha-ap192:4.3",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap192:4.4",
      "pali": "vinipātaṁ na gacchahaṁ."
    },
    {
      "id": "tha-ap192:5.1",
      "pali": "Teraseto kappasate,"
    },
    {
      "id": "tha-ap192:5.2",
      "pali": "aṭṭhāsuṁ dhūmaketuno;"
    },
    {
      "id": "tha-ap192:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap192:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap192:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap192:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap192:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap192:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tivaṇṭipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap192:8.1",
      "pali": "Tivaṇṭipupphiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap192:9.1",
      "pali": "Kuṭajapupphiyavaggo ekūnavīsatimo."
    },
    {
      "id": "tha-ap192:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap192:11.1",
      "pali": "Kuṭajo bandhujīvī ca,"
    },
    {
      "id": "tha-ap192:11.2",
      "pali": "koṭumbarikahatthiyo;"
    },
    {
      "id": "tha-ap192:11.3",
      "pali": "Isimuggo ca bodhi ca,"
    },
    {
      "id": "tha-ap192:11.4",
      "pali": "ekacintī tikaṇṇiko;"
    },
    {
      "id": "tha-ap192:11.5",
      "pali": "Ekacārī tivaṇṭi ca,"
    },
    {
      "id": "tha-ap192:11.6",
      "pali": "gāthā dvāsaṭṭhi kittitāti."
    }
  ]
}
