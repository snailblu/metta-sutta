{
  "uid": "tha-ap241",
  "title": "Jagatikārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap241:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap241:1.2",
      "pali": "atthadassi naruttame;"
    },
    {
      "id": "tha-ap241:1.3",
      "pali": "Jagatī kāritā mayhaṁ,"
    },
    {
      "id": "tha-ap241:1.4",
      "pali": "buddhassa thūpamuttame."
    },
    {
      "id": "tha-ap241:2.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap241:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap241:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap241:2.4",
      "pali": "jagatiyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap241:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap241:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap241:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap241:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā jagatikārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap241:5.1",
      "pali": "Jagatikārakattherassāpadānaṁ navamaṁ."
    }
  ]
}
