{
  "uid": "ja227",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja227:1.1",
      "pali": "“Sūro sūrena saṅgamma,"
    },
    {
      "id": "ja227:1.2",
      "pali": "vikkantena pahārinā;"
    },
    {
      "id": "ja227:1.3",
      "pali": "Ehi nāga nivattassu,"
    },
    {
      "id": "ja227:1.4",
      "pali": "kiṁ nu bhīto palāyasi;"
    },
    {
      "id": "ja227:1.5",
      "pali": "Passantu aṅgamagadhā,"
    },
    {
      "id": "ja227:1.6",
      "pali": "mama tuyhañca vikkamaṁ”."
    },
    {
      "id": "ja227:2.1",
      "pali": "“Na taṁ pādā vadhissāmi,"
    },
    {
      "id": "ja227:2.2",
      "pali": "na dantehi na soṇḍiyā;"
    },
    {
      "id": "ja227:2.3",
      "pali": "Mīḷhena taṁ vadhissāmi,"
    },
    {
      "id": "ja227:2.4",
      "pali": "pūti haññatu pūtinā”ti."
    },
    {
      "id": "ja227:3.1",
      "pali": "Gūthapāṇajātakaṁ sattamaṁ."
    }
  ]
}
