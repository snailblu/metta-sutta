{
  "uid": "vv64",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv64:1.1",
      "pali": "“Sahassayuttaṁ hayavāhanaṁ subhaṁ,"
    },
    {
      "id": "vv64:1.2",
      "pali": "Āruyhimaṁ sandanaṁ nekacittaṁ;"
    },
    {
      "id": "vv64:1.3",
      "pali": "Uyyānabhūmiṁ abhito anukkamaṁ,"
    },
    {
      "id": "vv64:1.4",
      "pali": "Purindado bhūtapatīva vāsavo."
    },
    {
      "id": "vv64:2.1",
      "pali": "Sovaṇṇamayā te rathakubbarā ubho,"
    },
    {
      "id": "vv64:2.2",
      "pali": "Phalehi aṁsehi atīva saṅgatā;"
    },
    {
      "id": "vv64:2.3",
      "pali": "Sujātagumbā naravīraniṭṭhitā,"
    },
    {
      "id": "vv64:2.4",
      "pali": "Virocatī pannaraseva cando."
    },
    {
      "id": "vv64:3.1",
      "pali": "Suvaṇṇajālāvatato ratho ayaṁ,"
    },
    {
      "id": "vv64:3.2",
      "pali": "Bahūhi nānāratanehi cittito;"
    },
    {
      "id": "vv64:3.3",
      "pali": "Sunandighoso ca subhassaro ca,"
    },
    {
      "id": "vv64:3.4",
      "pali": "Virocatī cāmarahatthabāhubhi."
    },
    {
      "id": "vv64:4.1",
      "pali": "Imā ca nābhyo manasābhinimmitā,"
    },
    {
      "id": "vv64:4.2",
      "pali": "Rathassa pādantaramajjhabhūsitā;"
    },
    {
      "id": "vv64:4.3",
      "pali": "Imā ca nābhyo satarājicittitā,"
    },
    {
      "id": "vv64:4.4",
      "pali": "Sateratā vijjurivappabhāsare."
    },
    {
      "id": "vv64:5.1",
      "pali": "Anekacittāvatato ratho ayaṁ,"
    },
    {
      "id": "vv64:5.2",
      "pali": "Puthū ca nemī ca sahassaraṁsiko;"
    },
    {
      "id": "vv64:5.3",
      "pali": "Tesaṁ saro suyyati vaggurūpo,"
    },
    {
      "id": "vv64:5.4",
      "pali": "Pañcaṅgikaṁ tūriyamivappavāditaṁ."
    },
    {
      "id": "vv64:6.1",
      "pali": "Sirasmiṁ cittaṁ maṇicandakappitaṁ,"
    },
    {
      "id": "vv64:6.2",
      "pali": "Sadā visuddhaṁ ruciraṁ pabhassaraṁ;"
    },
    {
      "id": "vv64:6.3",
      "pali": "Suvaṇṇarājīhi atīva saṅgataṁ,"
    },
    {
      "id": "vv64:6.4",
      "pali": "Veḷuriyarājīva atīva sobhati."
    },
    {
      "id": "vv64:7.1",
      "pali": "Ime ca vāḷī maṇicandakappitā,"
    },
    {
      "id": "vv64:7.2",
      "pali": "Ārohakambū sujavā brahūpamā;"
    },
    {
      "id": "vv64:7.3",
      "pali": "Brahā mahantā balino mahājavā,"
    },
    {
      "id": "vv64:7.4",
      "pali": "Mano tavaññāya tatheva siṁsare."
    },
    {
      "id": "vv64:8.1",
      "pali": "Ime ca sabbe sahitā catukkamā,"
    },
    {
      "id": "vv64:8.2",
      "pali": "Mano tavaññāya tatheva siṁsare;"
    },
    {
      "id": "vv64:8.3",
      "pali": "Samaṁ vahantī mudukā anuddhatā,"
    },
    {
      "id": "vv64:8.4",
      "pali": "Āmodamānā turagānamuttama."
    },
    {
      "id": "vv64:9.1",
      "pali": "Dhunanti vagganti patanti cambare,"
    },
    {
      "id": "vv64:9.2",
      "pali": "Abbhuddhunantā sukate piḷandhane;"
    },
    {
      "id": "vv64:9.3",
      "pali": "Tesaṁ saro suyyati vaggurūpo,"
    },
    {
      "id": "vv64:9.4",
      "pali": "Pañcaṅgikaṁ tūriyamivappavāditaṁ."
    },
    {
      "id": "vv64:10.1",
      "pali": "Rathassa ghoso apiḷandhanāna ca,"
    },
    {
      "id": "vv64:10.2",
      "pali": "Khurassa nādo abhihiṁsanāya ca;"
    },
    {
      "id": "vv64:10.3",
      "pali": "Ghoso suvaggū samitassa suyyati,"
    },
    {
      "id": "vv64:10.4",
      "pali": "Gandhabbatūriyāni vicitrasaṁvane."
    },
    {
      "id": "vv64:11.1",
      "pali": "Rathe ṭhitā tā migamandalocanā,"
    },
    {
      "id": "vv64:11.2",
      "pali": "Āḷārapamhā hasitā piyaṁvadā;"
    },
    {
      "id": "vv64:11.3",
      "pali": "Veḷuriyajālāvatatā tanucchavā,"
    },
    {
      "id": "vv64:11.4",
      "pali": "Sadeva gandhabbasūraggapūjitā."
    },
    {
      "id": "vv64:12.1",
      "pali": "Tā rattarattambarapītavāsasā,"
    },
    {
      "id": "vv64:12.2",
      "pali": "Visālanettā abhirattalocanā;"
    },
    {
      "id": "vv64:12.3",
      "pali": "Kule sujātā sutanū sucimhitā,"
    },
    {
      "id": "vv64:12.4",
      "pali": "Rathe ṭhitā pañjalikā upaṭṭhitā."
    },
    {
      "id": "vv64:13.1",
      "pali": "Tā kambukeyūradharā suvāsasā,"
    },
    {
      "id": "vv64:13.2",
      "pali": "Sumajjhimā ūruthanūpapannā;"
    },
    {
      "id": "vv64:13.3",
      "pali": "Vaṭṭaṅguliyo sumukhā sudassanā,"
    },
    {
      "id": "vv64:13.4",
      "pali": "Rathe ṭhitā pañjalikā upaṭṭhitā."
    },
    {
      "id": "vv64:14.1",
      "pali": "Aññā suveṇī susu missakesiyo,"
    },
    {
      "id": "vv64:14.2",
      "pali": "Samaṁ vibhattāhi pabhassarāhi ca;"
    },
    {
      "id": "vv64:14.3",
      "pali": "Anubbatā tā tava mānase ratā,"
    },
    {
      "id": "vv64:14.4",
      "pali": "Rathe ṭhitā pañjalikā upaṭṭhitā."
    },
    {
      "id": "vv64:15.1",
      "pali": "Āveḷiniyo padumuppalacchadā,"
    },
    {
      "id": "vv64:15.2",
      "pali": "Alaṅkatā candanasāravāsitā;"
    },
    {
      "id": "vv64:15.3",
      "pali": "Anubbatā tā tava mānase ratā,"
    },
    {
      "id": "vv64:15.4",
      "pali": "Rathe ṭhitā pañjalikā upaṭṭhitā."
    },
    {
      "id": "vv64:16.1",
      "pali": "Tā māliniyo padumuppalacchadā,"
    },
    {
      "id": "vv64:16.2",
      "pali": "Alaṅkatā candanasāravāsitā;"
    },
    {
      "id": "vv64:16.3",
      "pali": "Anubbatā tā tava mānase ratā,"
    },
    {
      "id": "vv64:16.4",
      "pali": "Rathe ṭhitā pañjalikā upaṭṭhitā."
    },
    {
      "id": "vv64:17.1",
      "pali": "Kaṇṭhesu te yāni piḷandhanāni,"
    },
    {
      "id": "vv64:17.2",
      "pali": "Hatthesu pādesu tatheva sīse;"
    },
    {
      "id": "vv64:17.3",
      "pali": "Obhāsayantī dasa sabbaso disā,"
    },
    {
      "id": "vv64:17.4",
      "pali": "Abbhuddayaṁ sāradikova bhāṇumā."
    },
    {
      "id": "vv64:18.1",
      "pali": "Vātassa vegena ca sampakampitā,"
    },
    {
      "id": "vv64:18.2",
      "pali": "Bhujesu mālā apiḷandhanāni ca;"
    },
    {
      "id": "vv64:18.3",
      "pali": "Muñcanti ghosaṁ ruciraṁ suciṁ subhaṁ,"
    },
    {
      "id": "vv64:18.4",
      "pali": "Sabbehi viññūhi sutabbarūpaṁ."
    },
    {
      "id": "vv64:19.1",
      "pali": "Uyyānabhūmyā ca duvaddhato ṭhitā,"
    },
    {
      "id": "vv64:19.2",
      "pali": "Rathā ca nāgā tūriyāni ca saro;"
    },
    {
      "id": "vv64:19.3",
      "pali": "Tameva devinda pamodayanti,"
    },
    {
      "id": "vv64:19.4",
      "pali": "Vīṇā yathā pokkharapattabāhubhi."
    },
    {
      "id": "vv64:20.1",
      "pali": "Imāsu vīṇāsu bahūsu vaggūsu,"
    },
    {
      "id": "vv64:20.2",
      "pali": "Manuññarūpāsu hadayeritaṁ pītiṁ;"
    },
    {
      "id": "vv64:20.3",
      "pali": "Pavajjamānāsu atīva accharā,"
    },
    {
      "id": "vv64:20.4",
      "pali": "Bhamanti kaññā padumesu sikkhitā."
    },
    {
      "id": "vv64:21.1",
      "pali": "Yadā ca gītāni ca vāditāni ca,"
    },
    {
      "id": "vv64:21.2",
      "pali": "Naccāni cimāni samenti ekato;"
    },
    {
      "id": "vv64:21.3",
      "pali": "Athettha naccanti athettha accharā,"
    },
    {
      "id": "vv64:21.4",
      "pali": "Obhāsayantī ubhato varitthiyo."
    },
    {
      "id": "vv64:22.1",
      "pali": "So modasi tūriyagaṇappabodhano,"
    },
    {
      "id": "vv64:22.2",
      "pali": "Mahīyamāno vajirāvudhoriva;"
    },
    {
      "id": "vv64:22.3",
      "pali": "Imāsu vīṇāsu bahūsu vaggūsu,"
    },
    {
      "id": "vv64:22.4",
      "pali": "Manuññarūpāsu hadayeritaṁ pītiṁ."
    },
    {
      "id": "vv64:23.1",
      "pali": "Kiṁ tvaṁ pure kammamakāsi attanā,"
    },
    {
      "id": "vv64:23.2",
      "pali": "Manussabhūto purimāya jātiyā;"
    },
    {
      "id": "vv64:23.3",
      "pali": "Uposathaṁ kaṁ vā tuvaṁ upāvasi,"
    },
    {
      "id": "vv64:23.4",
      "pali": "Kaṁ dhammacariyaṁ vatamābhirocayi."
    },
    {
      "id": "vv64:24.1",
      "pali": "Nayīdamappassa katassa kammuno,"
    },
    {
      "id": "vv64:24.2",
      "pali": "Pubbe suciṇṇassa uposathassa vā;"
    },
    {
      "id": "vv64:24.3",
      "pali": "Iddhānubhāvo vipulo ayaṁ tava,"
    },
    {
      "id": "vv64:24.4",
      "pali": "Yaṁ devasaṅghaṁ abhirocase bhusaṁ."
    },
    {
      "id": "vv64:25.1",
      "pali": "Dānassa te idaṁ phalaṁ,"
    },
    {
      "id": "vv64:25.2",
      "pali": "atho sīlassa vā pana;"
    },
    {
      "id": "vv64:25.3",
      "pali": "Atho añjalikammassa,"
    },
    {
      "id": "vv64:25.4",
      "pali": "taṁ me akkhāhi pucchito”ti."
    },
    {
      "id": "vv64:26.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv64:26.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv64:26.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv64:26.4",
      "pali": "yassa kammassidaṁ phalanti."
    },
    {
      "id": "vv64:27.1",
      "pali": "“Jitindriyaṁ buddhamanomanikkamaṁ,"
    },
    {
      "id": "vv64:27.2",
      "pali": "Naruttamaṁ kassapamaggapuggalaṁ;"
    },
    {
      "id": "vv64:27.3",
      "pali": "Avāpurantaṁ amatassa dvāraṁ,"
    },
    {
      "id": "vv64:27.4",
      "pali": "Devātidevaṁ satapuññalakkhaṇaṁ."
    },
    {
      "id": "vv64:28.1",
      "pali": "Tamaddasaṁ kuñjaramoghatiṇṇaṁ,"
    },
    {
      "id": "vv64:28.2",
      "pali": "Suvaṇṇasiṅgīnadabimbasādisaṁ;"
    },
    {
      "id": "vv64:28.3",
      "pali": "Disvāna taṁ khippamahuṁ sucīmano,"
    },
    {
      "id": "vv64:28.4",
      "pali": "Tameva disvāna subhāsitaddhajaṁ."
    },
    {
      "id": "vv64:29.1",
      "pali": "Tamannapānaṁ athavāpi cīvaraṁ,"
    },
    {
      "id": "vv64:29.2",
      "pali": "Suciṁ paṇītaṁ rasasā upetaṁ;"
    },
    {
      "id": "vv64:29.3",
      "pali": "Pupphābhikkiṇamhi sake nivesane,"
    },
    {
      "id": "vv64:29.4",
      "pali": "Patiṭṭhapesiṁ sa asaṅgamānaso."
    },
    {
      "id": "vv64:30.1",
      "pali": "Tamannapānena ca cīvarena ca,"
    },
    {
      "id": "vv64:30.2",
      "pali": "Khajjena bhojjena ca sāyanena ca;"
    },
    {
      "id": "vv64:30.3",
      "pali": "Santappayitvā dvipadānamuttamaṁ,"
    },
    {
      "id": "vv64:30.4",
      "pali": "So saggaso devapure ramāmahaṁ."
    },
    {
      "id": "vv64:31.1",
      "pali": "Etenupāyena imaṁ niraggaḷaṁ,"
    },
    {
      "id": "vv64:31.2",
      "pali": "Yaññaṁ yajitvā tividhaṁ visuddhaṁ;"
    },
    {
      "id": "vv64:31.3",
      "pali": "Pahāyahaṁ mānusakaṁ samussayaṁ,"
    },
    {
      "id": "vv64:31.4",
      "pali": "Indūpamo devapure ramāmahaṁ."
    },
    {
      "id": "vv64:32.1",
      "pali": "Āyuñca vaṇṇañca sukhaṁ balañca,"
    },
    {
      "id": "vv64:32.2",
      "pali": "Paṇītarūpaṁ abhikaṅkhatā muni;"
    },
    {
      "id": "vv64:32.3",
      "pali": "Annañca pānañca bahuṁ susaṅkhataṁ,"
    },
    {
      "id": "vv64:32.4",
      "pali": "Patiṭṭhapetabbamasaṅgamānase."
    },
    {
      "id": "vv64:33.1",
      "pali": "Nayimasmiṁ loke parasmiṁ vā pana,"
    },
    {
      "id": "vv64:33.2",
      "pali": "Buddhena seṭṭho va samo va vijjati;"
    },
    {
      "id": "vv64:33.3",
      "pali": "Āhuneyyānaṁ paramāhutiṁ gato,"
    },
    {
      "id": "vv64:33.4",
      "pali": "Puññatthikānaṁ vipulapphalesinan”ti."
    },
    {
      "id": "vv64:34.1",
      "pali": "Mahārathavimānaṁ cuddasamaṁ."
    },
    {
      "id": "vv64:34.2",
      "pali": "Mahārathavaggo pañcamo."
    },
    {
      "id": "vv64:35.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv64:36.1",
      "pali": "Maṇḍūko revatī chatto,"
    },
    {
      "id": "vv64:36.2",
      "pali": "Kakkaṭo dvārapālako;"
    },
    {
      "id": "vv64:36.3",
      "pali": "Dve karaṇīyā dve sūci,"
    },
    {
      "id": "vv64:36.4",
      "pali": "Tayo nāgā ca dve rathā;"
    },
    {
      "id": "vv64:36.5",
      "pali": "Purisānaṁ paṭhamo vaggo pavuccatīti."
    },
    {
      "id": "vv64:37.1",
      "pali": "Bhāṇavāraṁ tatiyaṁ."
    }
  ]
}
