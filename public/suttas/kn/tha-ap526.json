{
  "uid": "tha-ap526",
  "title": "Abbhañjanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap526:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap526:1.2",
      "pali": "rājuyyāne vasāmahaṁ;"
    },
    {
      "id": "tha-ap526:1.3",
      "pali": "Cammavāsī tadā āsiṁ,"
    },
    {
      "id": "tha-ap526:1.4",
      "pali": "kamaṇḍaludharo ahaṁ."
    },
    {
      "id": "tha-ap526:2.1",
      "pali": "Addasaṁ vimalaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap526:2.2",
      "pali": "sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap526:2.3",
      "pali": "Padhānaṁ pahitattaṁ taṁ,"
    },
    {
      "id": "tha-ap526:2.4",
      "pali": "jhāyiṁ jhānarataṁ vasiṁ."
    },
    {
      "id": "tha-ap526:3.1",
      "pali": "Sabbakāmasamiddhiñca,"
    },
    {
      "id": "tha-ap526:3.2",
      "pali": "oghatiṇṇamanāsavaṁ;"
    },
    {
      "id": "tha-ap526:3.3",
      "pali": "Disvā pasanno sumano,"
    },
    {
      "id": "tha-ap526:3.4",
      "pali": "abbhañjanamadāsahaṁ."
    },
    {
      "id": "tha-ap526:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap526:4.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap526:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap526:4.4",
      "pali": "abbhañjanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap526:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap526:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap526:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap526:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap526:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap526:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap526:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap526:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap526:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap526:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā abbhañjanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap526:9.1",
      "pali": "Abbhañjanadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
