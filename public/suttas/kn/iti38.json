{
  "uid": "iti38",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti38:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti38:2.1",
      "pali": "“Tathāgataṁ, bhikkhave, arahantaṁ sammāsambuddhaṁ dve vitakkā bahulaṁ samudācaranti—"
    },
    {
      "id": "iti38:2.2",
      "pali": "khemo ca vitakko, paviveko ca."
    },
    {
      "id": "iti38:2.3",
      "pali": "Abyāpajjhārāmo, bhikkhave, tathāgato abyāpajjharato."
    },
    {
      "id": "iti38:2.4",
      "pali": "Tamenaṁ, bhikkhave, tathāgataṁ abyāpajjhārāmaṁ abyāpajjharataṁ eseva vitakko bahulaṁ samudācarati:"
    },
    {
      "id": "iti38:2.5",
      "pali": "‘imāyāhaṁ iriyāya na kañci byābādhemi tasaṁ vā thāvaraṁ vā’ti."
    },
    {
      "id": "iti38:3.1",
      "pali": "Pavivekārāmo, bhikkhave, tathāgato pavivekarato."
    },
    {
      "id": "iti38:3.2",
      "pali": "Tamenaṁ, bhikkhave, tathāgataṁ pavivekārāmaṁ pavivekarataṁ eseva vitakko bahulaṁ samudācarati:"
    },
    {
      "id": "iti38:3.3",
      "pali": "‘yaṁ akusalaṁ taṁ pahīnan’ti."
    },
    {
      "id": "iti38:4.1",
      "pali": "Tasmātiha, bhikkhave, tumhepi abyāpajjhārāmā viharatha abyāpajjharatā."
    },
    {
      "id": "iti38:4.2",
      "pali": "Tesaṁ vo, bhikkhave, tumhākaṁ abyāpajjhārāmānaṁ viharataṁ abyāpajjharatānaṁ eseva vitakko bahulaṁ samudācarissati:"
    },
    {
      "id": "iti38:4.3",
      "pali": "‘imāya mayaṁ iriyāya na kañci byābādhema tasaṁ vā thāvaraṁ vā’ti."
    },
    {
      "id": "iti38:5.1",
      "pali": "Pavivekārāmā, bhikkhave, viharatha pavivekaratā."
    },
    {
      "id": "iti38:5.2",
      "pali": "Tesaṁ vo, bhikkhave, tumhākaṁ pavivekārāmānaṁ viharataṁ pavivekaratānaṁ eseva vitakko bahulaṁ samudācarissati:"
    },
    {
      "id": "iti38:5.3",
      "pali": "‘kiṁ akusalaṁ, kiṁ appahīnaṁ, kiṁ pajahāmā’”ti."
    },
    {
      "id": "iti38:5.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti38:5.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti38:6.1",
      "pali": "“Tathāgataṁ buddhamasayhasāhinaṁ,"
    },
    {
      "id": "iti38:6.2",
      "pali": "Duve vitakkā samudācaranti naṁ;"
    },
    {
      "id": "iti38:6.3",
      "pali": "Khemo vitakko paṭhamo udīrito,"
    },
    {
      "id": "iti38:6.4",
      "pali": "Tato viveko dutiyo pakāsito."
    },
    {
      "id": "iti38:7.1",
      "pali": "Tamonudaṁ pāragataṁ mahesiṁ,"
    },
    {
      "id": "iti38:7.2",
      "pali": "Taṁ pattipattaṁ vasimaṁ anāsavaṁ;"
    },
    {
      "id": "iti38:7.3",
      "pali": "Visantaraṁ taṇhakkhaye vimuttaṁ,"
    },
    {
      "id": "iti38:7.4",
      "pali": "Taṁ ve muniṁ antimadehadhāriṁ;"
    },
    {
      "id": "iti38:7.5",
      "pali": "Mārañjahaṁ brūmi jarāya pāraguṁ."
    },
    {
      "id": "iti38:8.1",
      "pali": "Sele yathā pabbatamuddhaniṭṭhito,"
    },
    {
      "id": "iti38:8.2",
      "pali": "Yathāpi passe janataṁ samantato;"
    },
    {
      "id": "iti38:8.3",
      "pali": "Tathūpamaṁ dhammamayaṁ sumedho,"
    },
    {
      "id": "iti38:8.4",
      "pali": "Pāsādamāruyha samantacakkhu;"
    },
    {
      "id": "iti38:8.5",
      "pali": "Sokāvatiṇṇaṁ janatamapetasoko,"
    },
    {
      "id": "iti38:8.6",
      "pali": "Avekkhati jātijarābhibhūtan”ti."
    },
    {
      "id": "iti38:9.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti38:9.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
