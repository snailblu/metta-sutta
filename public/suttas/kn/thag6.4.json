{
  "uid": "thag6.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.4:1.1",
      "pali": "“Kullo sivathikaṁ gantvā,"
    },
    {
      "id": "thag6.4:1.2",
      "pali": "addasa itthimujjhitaṁ;"
    },
    {
      "id": "thag6.4:1.3",
      "pali": "Apaviddhaṁ susānasmiṁ,"
    },
    {
      "id": "thag6.4:1.4",
      "pali": "khajjantiṁ kimihī phuṭaṁ."
    },
    {
      "id": "thag6.4:2.1",
      "pali": "Āturaṁ asuciṁ pūtiṁ,"
    },
    {
      "id": "thag6.4:2.2",
      "pali": "passa kulla samussayaṁ;"
    },
    {
      "id": "thag6.4:2.3",
      "pali": "Uggharantaṁ paggharantaṁ,"
    },
    {
      "id": "thag6.4:2.4",
      "pali": "bālānaṁ abhinanditaṁ."
    },
    {
      "id": "thag6.4:3.1",
      "pali": "Dhammādāsaṁ gahetvāna,"
    },
    {
      "id": "thag6.4:3.2",
      "pali": "ñāṇadassanapattiyā;"
    },
    {
      "id": "thag6.4:3.3",
      "pali": "Paccavekkhiṁ imaṁ kāyaṁ,"
    },
    {
      "id": "thag6.4:3.4",
      "pali": "tucchaṁ santarabāhiraṁ."
    },
    {
      "id": "thag6.4:4.1",
      "pali": "Yathā idaṁ tathā etaṁ,"
    },
    {
      "id": "thag6.4:4.2",
      "pali": "yathā etaṁ tathā idaṁ;"
    },
    {
      "id": "thag6.4:4.3",
      "pali": "Yathā adho tathā uddhaṁ,"
    },
    {
      "id": "thag6.4:4.4",
      "pali": "yathā uddhaṁ tathā adho."
    },
    {
      "id": "thag6.4:5.1",
      "pali": "Yathā divā tathā rattiṁ,"
    },
    {
      "id": "thag6.4:5.2",
      "pali": "yathā rattiṁ tathā divā;"
    },
    {
      "id": "thag6.4:5.3",
      "pali": "Yathā pure tathā pacchā,"
    },
    {
      "id": "thag6.4:5.4",
      "pali": "yathā pacchā tathā pure."
    },
    {
      "id": "thag6.4:6.1",
      "pali": "Pañcaṅgikena turiyena,"
    },
    {
      "id": "thag6.4:6.2",
      "pali": "Na ratī hoti tādisī;"
    },
    {
      "id": "thag6.4:6.3",
      "pali": "Yathā ekaggacittassa,"
    },
    {
      "id": "thag6.4:6.4",
      "pali": "Sammā dhammaṁ vipassato”ti."
    },
    {
      "id": "thag6.4:6.5",
      "pali": "… Kullo thero …."
    }
  ]
}
