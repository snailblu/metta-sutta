{
  "uid": "ja324",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja324:1.1",
      "pali": "“Kalyāṇarūpo vatayaṁ catuppado,"
    },
    {
      "id": "ja324:1.2",
      "pali": "Subhaddako ceva supesalo ca;"
    },
    {
      "id": "ja324:1.3",
      "pali": "Yo brāhmaṇaṁ jātimantūpapannaṁ,"
    },
    {
      "id": "ja324:1.4",
      "pali": "Apacāyati meṇḍavaro yasassī”."
    },
    {
      "id": "ja324:2.1",
      "pali": "“Mā brāhmaṇa ittaradassanena,"
    },
    {
      "id": "ja324:2.2",
      "pali": "Vissāsamāpajji catuppadassa;"
    },
    {
      "id": "ja324:2.3",
      "pali": "Daḷhappahāraṁ abhikaṅkhamāno,"
    },
    {
      "id": "ja324:2.4",
      "pali": "Avasakkatī dassati suppahāraṁ”."
    },
    {
      "id": "ja324:3.1",
      "pali": "Ūruṭṭhi bhaggaṁ pavaṭṭito khāribhāro,"
    },
    {
      "id": "ja324:3.2",
      "pali": "Sabbañca bhaṇḍaṁ brāhmaṇassa bhinnaṁ;"
    },
    {
      "id": "ja324:3.3",
      "pali": "Ubhopi bāhā paggayha kandati,"
    },
    {
      "id": "ja324:3.4",
      "pali": "“Abhidhāvatha haññate brahmacārī."
    },
    {
      "id": "ja324:4.1",
      "pali": "Evaṁ so nihato seti,"
    },
    {
      "id": "ja324:4.2",
      "pali": "yo apūjaṁ pasaṁsati;"
    },
    {
      "id": "ja324:4.3",
      "pali": "Yathāhamajja pahato,"
    },
    {
      "id": "ja324:4.4",
      "pali": "hato meṇḍena dummatī”ti."
    },
    {
      "id": "ja324:5.1",
      "pali": "Cammasāṭakajātakaṁ catutthaṁ."
    }
  ]
}
