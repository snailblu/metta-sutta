{
  "uid": "pv7",
  "title": "7. Sattaputtakhādapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv7:1.1",
      "pali": "“Naggā dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv7:1.2",
      "pali": "duggandhā pūti vāyasi;"
    },
    {
      "id": "pv7:1.3",
      "pali": "Makkhikāhi parikiṇṇā,"
    },
    {
      "id": "pv7:1.4",
      "pali": "kā nu tvaṁ idha tiṭṭhasī”ti."
    },
    {
      "id": "pv7:2.1",
      "pali": "“Ahaṁ bhadante petīmhi,"
    },
    {
      "id": "pv7:2.2",
      "pali": "duggatā yamalokikā;"
    },
    {
      "id": "pv7:2.3",
      "pali": "Pāpakammaṁ karitvāna,"
    },
    {
      "id": "pv7:2.4",
      "pali": "petalokaṁ ito gatā."
    },
    {
      "id": "pv7:3.1",
      "pali": "Kālena satta puttāni,"
    },
    {
      "id": "pv7:3.2",
      "pali": "sāyaṁ satta punāpare;"
    },
    {
      "id": "pv7:3.3",
      "pali": "Vijāyitvāna khādāmi,"
    },
    {
      "id": "pv7:3.4",
      "pali": "tepi nā honti me alaṁ."
    },
    {
      "id": "pv7:4.1",
      "pali": "Pariḍayhati dhūmāyati,"
    },
    {
      "id": "pv7:4.2",
      "pali": "khudāya hadayaṁ mama;"
    },
    {
      "id": "pv7:4.3",
      "pali": "Nibbutiṁ nādhigacchāmi,"
    },
    {
      "id": "pv7:4.4",
      "pali": "aggidaḍḍhāva ātape”ti."
    },
    {
      "id": "pv7:5.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv7:5.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv7:5.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv7:5.4",
      "pali": "puttamaṁsāni khādasī”ti."
    },
    {
      "id": "pv7:6.1",
      "pali": "“Ahū mayhaṁ duve puttā,"
    },
    {
      "id": "pv7:6.2",
      "pali": "ubho sampattayobbanā;"
    },
    {
      "id": "pv7:6.3",
      "pali": "Sāhaṁ puttabalūpetā,"
    },
    {
      "id": "pv7:6.4",
      "pali": "sāmikaṁ atimaññisaṁ."
    },
    {
      "id": "pv7:7.1",
      "pali": "Tato me sāmiko kuddho,"
    },
    {
      "id": "pv7:7.2",
      "pali": "sapatiṁ mayhamānayi;"
    },
    {
      "id": "pv7:7.3",
      "pali": "Sā ca gabbhaṁ alabhittha,"
    },
    {
      "id": "pv7:7.4",
      "pali": "tassā pāpaṁ acetayiṁ."
    },
    {
      "id": "pv7:8.1",
      "pali": "Sāhaṁ paduṭṭhamanasā,"
    },
    {
      "id": "pv7:8.2",
      "pali": "akariṁ gabbhapātanaṁ;"
    },
    {
      "id": "pv7:8.3",
      "pali": "Tassā temāsiko gabbho,"
    },
    {
      "id": "pv7:8.4",
      "pali": "pūtilohitako pati."
    },
    {
      "id": "pv7:9.1",
      "pali": "Tadassā mātā kupitā,"
    },
    {
      "id": "pv7:9.2",
      "pali": "mayhaṁ ñātī samānayi;"
    },
    {
      "id": "pv7:9.3",
      "pali": "Sapathañca maṁ kāresi,"
    },
    {
      "id": "pv7:9.4",
      "pali": "paribhāsāpayī ca maṁ."
    },
    {
      "id": "pv7:10.1",
      "pali": "Sāhaṁ ghorañca sapathaṁ,"
    },
    {
      "id": "pv7:10.2",
      "pali": "musāvādaṁ abhāsisaṁ;"
    },
    {
      "id": "pv7:10.3",
      "pali": "‘Puttamaṁsāni khādāmi,"
    },
    {
      "id": "pv7:10.4",
      "pali": "sace taṁ pakataṁ mayā’."
    },
    {
      "id": "pv7:11.1",
      "pali": "Tassa kammassa vipākena,"
    },
    {
      "id": "pv7:11.2",
      "pali": "musāvādassa cūbhayaṁ;"
    },
    {
      "id": "pv7:11.3",
      "pali": "Puttamaṁsāni khādāmi,"
    },
    {
      "id": "pv7:11.4",
      "pali": "pubbalohitamakkhitā”ti."
    },
    {
      "id": "pv7:12.1",
      "pali": "Sattaputtakhādapetivatthu sattamaṁ."
    }
  ]
}
