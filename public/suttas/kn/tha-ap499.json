{
  "uid": "tha-ap499",
  "title": "Udakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap499:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap499:1.2",
      "pali": "bhikkhusaṅghe anuttare;"
    },
    {
      "id": "tha-ap499:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap499:1.4",
      "pali": "pānīghaṭamapūrayiṁ."
    },
    {
      "id": "tha-ap499:2.1",
      "pali": "Pabbatagge dumagge vā,"
    },
    {
      "id": "tha-ap499:2.2",
      "pali": "ākāse vātha bhūmiyaṁ;"
    },
    {
      "id": "tha-ap499:2.3",
      "pali": "Yadā pānīyamicchāmi,"
    },
    {
      "id": "tha-ap499:2.4",
      "pali": "khippaṁ nibbattate mama."
    },
    {
      "id": "tha-ap499:3.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap499:3.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap499:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap499:3.4",
      "pali": "dakadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap499:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap499:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap499:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap499:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap499:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap499:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap499:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap499:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap499:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap499:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā udakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap499:8.1",
      "pali": "Udakadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
