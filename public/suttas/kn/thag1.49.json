{
  "uid": "thag1.49",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.49:1.1",
      "pali": "“Cihacihābhinadite,"
    },
    {
      "id": "thag1.49:1.2",
      "pali": "sippikābhirutehi ca;"
    },
    {
      "id": "thag1.49:1.3",
      "pali": "Na me taṁ phandati cittaṁ,"
    },
    {
      "id": "thag1.49:1.4",
      "pali": "ekattanirataṁ hi me”ti."
    },
    {
      "id": "thag1.49:1.5",
      "pali": "… Rāmaṇeyyako thero …."
    }
  ]
}
