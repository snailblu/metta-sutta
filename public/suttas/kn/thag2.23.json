{
  "uid": "thag2.23",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.23:1.1",
      "pali": "“Satimā paññavā bhikkhu,"
    },
    {
      "id": "thag2.23:1.2",
      "pali": "āraddhabalavīriyo;"
    },
    {
      "id": "thag2.23:1.3",
      "pali": "Pañca kappasatānāhaṁ,"
    },
    {
      "id": "thag2.23:1.4",
      "pali": "ekarattiṁ anussariṁ."
    },
    {
      "id": "thag2.23:2.1",
      "pali": "Cattāro satipaṭṭhāne,"
    },
    {
      "id": "thag2.23:2.2",
      "pali": "satta aṭṭha ca bhāvayaṁ;"
    },
    {
      "id": "thag2.23:2.3",
      "pali": "Pañca kappasatānāhaṁ,"
    },
    {
      "id": "thag2.23:2.4",
      "pali": "ekarattiṁ anussarin”ti."
    },
    {
      "id": "thag2.23:2.5",
      "pali": "… Sobhito thero …."
    }
  ]
}
