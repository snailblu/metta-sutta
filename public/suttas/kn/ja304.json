{
  "uid": "ja304",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja304:1.1",
      "pali": "“Imāni maṁ daddara tāpayanti,"
    },
    {
      "id": "ja304:1.2",
      "pali": "Vācāduruttāni manussaloke;"
    },
    {
      "id": "ja304:1.3",
      "pali": "Maṇḍūkabhakkhā udakantasevī,"
    },
    {
      "id": "ja304:1.4",
      "pali": "Āsīvisaṁ maṁ avisā sapanti”."
    },
    {
      "id": "ja304:2.1",
      "pali": "“Sakā raṭṭhā pabbājito,"
    },
    {
      "id": "ja304:2.2",
      "pali": "aññaṁ janapadaṁ gato;"
    },
    {
      "id": "ja304:2.3",
      "pali": "Mahantaṁ koṭṭhaṁ kayirātha,"
    },
    {
      "id": "ja304:2.4",
      "pali": "duruttānaṁ nidhetave."
    },
    {
      "id": "ja304:3.1",
      "pali": "Yattha posaṁ na jānanti,"
    },
    {
      "id": "ja304:3.2",
      "pali": "jātiyā vinayena vā;"
    },
    {
      "id": "ja304:3.3",
      "pali": "Na tattha mānaṁ kayirātha,"
    },
    {
      "id": "ja304:3.4",
      "pali": "vasamaññātake jane."
    },
    {
      "id": "ja304:4.1",
      "pali": "Videsavāsaṁ vasato,"
    },
    {
      "id": "ja304:4.2",
      "pali": "jātavedasamenapi;"
    },
    {
      "id": "ja304:4.3",
      "pali": "Khamitabbaṁ sapaññena,"
    },
    {
      "id": "ja304:4.4",
      "pali": "api dāsassa tajjitan”ti."
    },
    {
      "id": "ja304:5.1",
      "pali": "Daddarajātakaṁ catutthaṁ."
    }
  ]
}
