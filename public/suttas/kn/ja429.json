{
  "uid": "ja429",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja429:1.1",
      "pali": "“Dumo yadā hoti phalūpapanno,"
    },
    {
      "id": "ja429:1.2",
      "pali": "Bhuñjanti naṁ vihaṅgamā sampatantā;"
    },
    {
      "id": "ja429:1.3",
      "pali": "Khīṇanti ñatvāna dumaṁ phalaccaye,"
    },
    {
      "id": "ja429:1.4",
      "pali": "Disodisaṁ yanti tato vihaṅgamā."
    },
    {
      "id": "ja429:2.1",
      "pali": "Cara cārikaṁ lohitatuṇḍa māmari,"
    },
    {
      "id": "ja429:2.2",
      "pali": "Kiṁ tvaṁ suva sukkhadumamhi jhāyasi;"
    },
    {
      "id": "ja429:2.3",
      "pali": "Tadiṅgha maṁ brūhi vasantasannibha,"
    },
    {
      "id": "ja429:2.4",
      "pali": "Kasmā suva sukkhadumaṁ na riñcasi”."
    },
    {
      "id": "ja429:3.1",
      "pali": "“Ye ve sakhīnaṁ sakhāro bhavanti,"
    },
    {
      "id": "ja429:3.2",
      "pali": "Pāṇaccaye dukkhasukhesu haṁsa;"
    },
    {
      "id": "ja429:3.3",
      "pali": "Khīṇaṁ akhīṇampi na taṁ jahanti,"
    },
    {
      "id": "ja429:3.4",
      "pali": "Santo sataṁ dhammamanussarantā."
    },
    {
      "id": "ja429:4.1",
      "pali": "Sohaṁ sataṁ aññatarosmi haṁsa,"
    },
    {
      "id": "ja429:4.2",
      "pali": "Ñātī ca me hoti sakhā ca rukkho;"
    },
    {
      "id": "ja429:4.3",
      "pali": "Taṁ nussahe jīvikattho pahātuṁ,"
    },
    {
      "id": "ja429:4.4",
      "pali": "Khīṇanti ñatvāna na hesa dhammo”."
    },
    {
      "id": "ja429:5.1",
      "pali": "“Sādhu sakkhi kataṁ hoti,"
    },
    {
      "id": "ja429:5.2",
      "pali": "metti saṁsati santhavo;"
    },
    {
      "id": "ja429:5.3",
      "pali": "Sacetaṁ dhammaṁ rocesi,"
    },
    {
      "id": "ja429:5.4",
      "pali": "pāsaṁsosi vijānataṁ."
    },
    {
      "id": "ja429:6.1",
      "pali": "So te suva varaṁ dammi,"
    },
    {
      "id": "ja429:6.2",
      "pali": "pattayāna vihaṅgama;"
    },
    {
      "id": "ja429:6.3",
      "pali": "Varaṁ varassu vakkaṅga,"
    },
    {
      "id": "ja429:6.4",
      "pali": "yaṁ kiñci manasicchasi”."
    },
    {
      "id": "ja429:7.1",
      "pali": "“Varañca me haṁsa bhavaṁ dadeyya,"
    },
    {
      "id": "ja429:7.2",
      "pali": "Ayañca rukkho punarāyuṁ labhetha;"
    },
    {
      "id": "ja429:7.3",
      "pali": "So sākhavā phalimā saṁvirūḷho,"
    },
    {
      "id": "ja429:7.4",
      "pali": "Madhutthiko tiṭṭhatu sobhamāno”."
    },
    {
      "id": "ja429:8.1",
      "pali": "“Taṁ passa samma phalimaṁ uḷāraṁ,"
    },
    {
      "id": "ja429:8.2",
      "pali": "Sahāva te hotu udumbarena;"
    },
    {
      "id": "ja429:8.3",
      "pali": "So sākhavā phalimā saṁvirūḷho,"
    },
    {
      "id": "ja429:8.4",
      "pali": "Madhutthiko tiṭṭhatu sobhamāno”."
    },
    {
      "id": "ja429:9.1",
      "pali": "“Evaṁ sakka sukhī hohi,"
    },
    {
      "id": "ja429:9.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja429:9.3",
      "pali": "Yathāhamajja sukhito,"
    },
    {
      "id": "ja429:9.4",
      "pali": "disvāna saphalaṁ dumaṁ”."
    },
    {
      "id": "ja429:10.1",
      "pali": "“Suvassa ca varaṁ datvā,"
    },
    {
      "id": "ja429:10.2",
      "pali": "katvāna saphalaṁ dumaṁ;"
    },
    {
      "id": "ja429:10.3",
      "pali": "Pakkāmi saha bhariyāya,"
    },
    {
      "id": "ja429:10.4",
      "pali": "devānaṁ nandanaṁ vanan”ti."
    },
    {
      "id": "ja429:11.1",
      "pali": "Mahāsuvajātakaṁ tatiyaṁ."
    }
  ]
}
