{
  "uid": "cnd2",
  "title": "Pucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cnd2:1.1",
      "pali": "“Kenassu nivuto loko,"
    },
    {
      "id": "cnd2:1.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "cnd2:1.3",
      "pali": "Kenassu nappakāsati;"
    },
    {
      "id": "cnd2:1.4",
      "pali": "Kissābhilepanaṁ brūsi,"
    },
    {
      "id": "cnd2:1.5",
      "pali": "Kiṁsu tassa mahabbhayaṁ”."
    },
    {
      "id": "cnd2:2.1",
      "pali": "“Avijjāya nivuto loko,"
    },
    {
      "id": "cnd2:2.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "cnd2:2.3",
      "pali": "Vevicchā pamādā nappakāsati;"
    },
    {
      "id": "cnd2:2.4",
      "pali": "Jappābhilepanaṁ brūmi,"
    },
    {
      "id": "cnd2:2.5",
      "pali": "Dukkhamassa mahabbhayaṁ”."
    },
    {
      "id": "cnd2:3.1",
      "pali": "“Savanti sabbadhi sotā,"
    },
    {
      "id": "cnd2:3.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "cnd2:3.3",
      "pali": "Sotānaṁ kiṁ nivāraṇaṁ;"
    },
    {
      "id": "cnd2:3.4",
      "pali": "Sotānaṁ saṁvaraṁ brūhi,"
    },
    {
      "id": "cnd2:3.5",
      "pali": "Kena sotā pidhiyyare”."
    },
    {
      "id": "cnd2:4.1",
      "pali": "“Yāni sotāni lokasmiṁ,"
    },
    {
      "id": "cnd2:4.2",
      "pali": "(ajitāti bhagavā)"
    },
    {
      "id": "cnd2:4.3",
      "pali": "Sati tesaṁ nivāraṇaṁ;"
    },
    {
      "id": "cnd2:4.4",
      "pali": "Sotānaṁ saṁvaraṁ brūmi,"
    },
    {
      "id": "cnd2:4.5",
      "pali": "Paññāyete pidhiyyare”."
    },
    {
      "id": "cnd2:5.1",
      "pali": "“Paññā ceva sati cāpi,"
    },
    {
      "id": "cnd2:5.2",
      "pali": "(iccāyasmā ajito)"
    },
    {
      "id": "cnd2:5.3",
      "pali": "Nāmarūpañca mārisa;"
    },
    {
      "id": "cnd2:5.4",
      "pali": "Etaṁ me puṭṭho pabrūhi,"
    },
    {
      "id": "cnd2:5.5",
      "pali": "Katthetaṁ uparujjhati”."
    },
    {
      "id": "cnd2:6.1",
      "pali": "“Yametaṁ pañhaṁ apucchi,"
    },
    {
      "id": "cnd2:6.2",
      "pali": "ajita taṁ vadāmi te;"
    },
    {
      "id": "cnd2:6.3",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "cnd2:6.4",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "cnd2:6.5",
      "pali": "Viññāṇassa nirodhena,"
    },
    {
      "id": "cnd2:6.6",
      "pali": "etthetaṁ uparujjhati”."
    },
    {
      "id": "cnd2:7.1",
      "pali": "“Ye ca saṅkhātadhammāse,"
    },
    {
      "id": "cnd2:7.2",
      "pali": "ye ca sekhā puthū idha;"
    },
    {
      "id": "cnd2:7.3",
      "pali": "Tesaṁ me nipako iriyaṁ,"
    },
    {
      "id": "cnd2:7.4",
      "pali": "puṭṭho pabrūhi mārisa”."
    },
    {
      "id": "cnd2:8.1",
      "pali": "“Kāmesu nābhigijjheyya,"
    },
    {
      "id": "cnd2:8.2",
      "pali": "Manasānāvilo siyā;"
    },
    {
      "id": "cnd2:8.3",
      "pali": "Kusalo sabbadhammānaṁ,"
    },
    {
      "id": "cnd2:8.4",
      "pali": "Sato bhikkhu paribbaje”ti."
    },
    {
      "id": "cnd2:8.5",
      "pali": "Ajitamāṇavapucchā paṭhamā."
    },
    {
      "id": "cnd2:9.1",
      "pali": "“Kodha santusito loke,"
    },
    {
      "id": "cnd2:9.2",
      "pali": "(iccāyasmā tissametteyyo)"
    },
    {
      "id": "cnd2:9.3",
      "pali": "Kassa no santi iñjitā;"
    },
    {
      "id": "cnd2:9.4",
      "pali": "Ko ubhantamabhiññāya,"
    },
    {
      "id": "cnd2:9.5",
      "pali": "Majjhe mantā na lippati;"
    },
    {
      "id": "cnd2:9.6",
      "pali": "Kaṁ brūsi mahāpurisoti,"
    },
    {
      "id": "cnd2:9.7",
      "pali": "Ko idha sibbinimaccagā”."
    },
    {
      "id": "cnd2:10.1",
      "pali": "“Kāmesu brahmacariyavā,"
    },
    {
      "id": "cnd2:10.2",
      "pali": "(metteyyāti bhagavā)"
    },
    {
      "id": "cnd2:10.3",
      "pali": "Vītataṇho sadā sato;"
    },
    {
      "id": "cnd2:10.4",
      "pali": "Saṅkhāya nibbuto bhikkhu,"
    },
    {
      "id": "cnd2:10.5",
      "pali": "Tassa no santi iñjitā."
    },
    {
      "id": "cnd2:11.1",
      "pali": "So ubhantamabhiññāya,"
    },
    {
      "id": "cnd2:11.2",
      "pali": "Majjhe mantā na lippati;"
    },
    {
      "id": "cnd2:11.3",
      "pali": "Taṁ brūmi mahāpurisoti,"
    },
    {
      "id": "cnd2:11.4",
      "pali": "So idha sibbinimaccagā”ti."
    },
    {
      "id": "cnd2:11.5",
      "pali": "Tissametteyyamāṇavapucchā dutiyā."
    },
    {
      "id": "cnd2:12.1",
      "pali": "“Anejaṁ mūladassāviṁ,"
    },
    {
      "id": "cnd2:12.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "cnd2:12.3",
      "pali": "Atthi pañhena āgamaṁ;"
    },
    {
      "id": "cnd2:12.4",
      "pali": "Kiṁ nissitā isayo manujā,"
    },
    {
      "id": "cnd2:12.5",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "cnd2:12.6",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "cnd2:12.7",
      "pali": "Pucchāmi taṁ bhagavā brūhi metaṁ”."
    },
    {
      "id": "cnd2:13.1",
      "pali": "“Ye kecime isayo manujā,"
    },
    {
      "id": "cnd2:13.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "cnd2:13.3",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "cnd2:13.4",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "cnd2:13.5",
      "pali": "Āsīsamānā puṇṇaka itthattaṁ;"
    },
    {
      "id": "cnd2:13.6",
      "pali": "Jaraṁ sitā yaññamakappayiṁsu”."
    },
    {
      "id": "cnd2:14.1",
      "pali": "“Ye kecime isayo manujā,"
    },
    {
      "id": "cnd2:14.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "cnd2:14.3",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "cnd2:14.4",
      "pali": "Yaññamakappayiṁsu puthūdha loke,"
    },
    {
      "id": "cnd2:14.5",
      "pali": "Kaccisu te bhagavā yaññapathe appamattā;"
    },
    {
      "id": "cnd2:14.6",
      "pali": "Atāruṁ jātiñca jarañca mārisa,"
    },
    {
      "id": "cnd2:14.7",
      "pali": "Pucchāmi taṁ bhagavā brūhi metaṁ”."
    },
    {
      "id": "cnd2:15.1",
      "pali": "“Āsīsanti thomayanti abhijappanti juhanti,"
    },
    {
      "id": "cnd2:15.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "cnd2:15.3",
      "pali": "Kāmābhijappanti paṭicca lābhaṁ;"
    },
    {
      "id": "cnd2:15.4",
      "pali": "Te yājayogā bhavarāgarattā,"
    },
    {
      "id": "cnd2:15.5",
      "pali": "Nātariṁsu jātijaranti brūmi”."
    },
    {
      "id": "cnd2:16.1",
      "pali": "“Te ce nātariṁsu yājayogā,"
    },
    {
      "id": "cnd2:16.2",
      "pali": "(iccāyasmā puṇṇako)"
    },
    {
      "id": "cnd2:16.3",
      "pali": "Yaññehi jātiñca jarañca mārisa;"
    },
    {
      "id": "cnd2:16.4",
      "pali": "Atha ko carahi devamanussaloke,"
    },
    {
      "id": "cnd2:16.5",
      "pali": "Atāri jātiñca jarañca mārisa;"
    },
    {
      "id": "cnd2:16.6",
      "pali": "Pucchāmi taṁ bhagavā brūhi metaṁ”."
    },
    {
      "id": "cnd2:17.1",
      "pali": "“Saṅkhāya lokasmi paroparāni,"
    },
    {
      "id": "cnd2:17.2",
      "pali": "(puṇṇakāti bhagavā)"
    },
    {
      "id": "cnd2:17.3",
      "pali": "Yassiñjitaṁ natthi kuhiñci loke;"
    },
    {
      "id": "cnd2:17.4",
      "pali": "Santo vidhūmo anīgho nirāso,"
    },
    {
      "id": "cnd2:17.5",
      "pali": "Atāri so jātijaranti brūmī”ti."
    },
    {
      "id": "cnd2:17.6",
      "pali": "Puṇṇakamāṇavapucchā tatiyā."
    },
    {
      "id": "cnd2:18.1",
      "pali": "“Pucchāmi taṁ bhagavā brūhi metaṁ,"
    },
    {
      "id": "cnd2:18.2",
      "pali": "(iccāyasmā mettagū)"
    },
    {
      "id": "cnd2:18.3",
      "pali": "Maññāmi taṁ vedaguṁ bhāvitattaṁ;"
    },
    {
      "id": "cnd2:18.4",
      "pali": "Kuto nu dukkhā samudāgatā ime,"
    },
    {
      "id": "cnd2:18.5",
      "pali": "Ye keci lokasmimanekarūpā”."
    },
    {
      "id": "cnd2:19.1",
      "pali": "“Dukkhassa ve maṁ pabhavaṁ apucchasi,"
    },
    {
      "id": "cnd2:19.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "cnd2:19.3",
      "pali": "Taṁ te pavakkhāmi yathā pajānaṁ;"
    },
    {
      "id": "cnd2:19.4",
      "pali": "Upadhinidānā pabhavanti dukkhā,"
    },
    {
      "id": "cnd2:19.5",
      "pali": "Ye keci lokasmimanekarūpā."
    },
    {
      "id": "cnd2:20.1",
      "pali": "Yo ve avidvā upadhiṁ karoti,"
    },
    {
      "id": "cnd2:20.2",
      "pali": "Punappunaṁ dukkhamupeti mando;"
    },
    {
      "id": "cnd2:20.3",
      "pali": "Tasmā pajānaṁ upadhiṁ na kayirā,"
    },
    {
      "id": "cnd2:20.4",
      "pali": "Dukkhassa jātippabhavānupassī”."
    },
    {
      "id": "cnd2:21.1",
      "pali": "“Yaṁ taṁ apucchimha akittayī no,"
    },
    {
      "id": "cnd2:21.2",
      "pali": "Aññaṁ taṁ pucchāma tadiṅgha brūhi;"
    },
    {
      "id": "cnd2:21.3",
      "pali": "‘Kathaṁ nu dhīrā vitaranti oghaṁ,"
    },
    {
      "id": "cnd2:21.4",
      "pali": "Jātiṁ jaraṁ sokapariddavañca’;"
    },
    {
      "id": "cnd2:21.5",
      "pali": "Taṁ me muni sādhu viyākarohi,"
    },
    {
      "id": "cnd2:21.6",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "cnd2:22.1",
      "pali": "“Kittayissāmi te dhammaṁ,"
    },
    {
      "id": "cnd2:22.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "cnd2:22.3",
      "pali": "Diṭṭhe dhamme anītihaṁ;"
    },
    {
      "id": "cnd2:22.4",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "cnd2:22.5",
      "pali": "Tare loke visattikaṁ”."
    },
    {
      "id": "cnd2:23.1",
      "pali": "“Tañcāhaṁ abhinandāmi,"
    },
    {
      "id": "cnd2:23.2",
      "pali": "mahesi dhammamuttamaṁ;"
    },
    {
      "id": "cnd2:23.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "cnd2:23.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "cnd2:24.1",
      "pali": "“Yaṁ kiñci sampajānāsi,"
    },
    {
      "id": "cnd2:24.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "cnd2:24.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "cnd2:24.4",
      "pali": "Etesu nandiñca nivesanañca,"
    },
    {
      "id": "cnd2:24.5",
      "pali": "Panujja viññāṇaṁ bhave na tiṭṭhe."
    },
    {
      "id": "cnd2:25.1",
      "pali": "Evaṁvihārī sato appamatto,"
    },
    {
      "id": "cnd2:25.2",
      "pali": "Bhikkhu caraṁ hitvā mamāyitāni;"
    },
    {
      "id": "cnd2:25.3",
      "pali": "Jātiṁ jaraṁ sokapariddavañca,"
    },
    {
      "id": "cnd2:25.4",
      "pali": "Idheva vidvā pajaheyya dukkhaṁ”."
    },
    {
      "id": "cnd2:26.1",
      "pali": "“Etābhinandāmi vaco mahesino,"
    },
    {
      "id": "cnd2:26.2",
      "pali": "Sukittitaṁ gotamanūpadhīkaṁ;"
    },
    {
      "id": "cnd2:26.3",
      "pali": "Addhā hi bhagavā pahāsi dukkhaṁ,"
    },
    {
      "id": "cnd2:26.4",
      "pali": "Tathā hi te vidito esa dhammo."
    },
    {
      "id": "cnd2:27.1",
      "pali": "Te cāpi nūnappajaheyyu dukkhaṁ,"
    },
    {
      "id": "cnd2:27.2",
      "pali": "Ye tvaṁ muni aṭṭhitaṁ ovadeyya;"
    },
    {
      "id": "cnd2:27.3",
      "pali": "Taṁ taṁ namassāmi samecca nāga,"
    },
    {
      "id": "cnd2:27.4",
      "pali": "Appeva maṁ bhagavā aṭṭhitaṁ ovadeyya”."
    },
    {
      "id": "cnd2:28.1",
      "pali": "“Yaṁ brāhmaṇaṁ vedagumābhijaññā,"
    },
    {
      "id": "cnd2:28.2",
      "pali": "Akiñcanaṁ kāmabhave asattaṁ;"
    },
    {
      "id": "cnd2:28.3",
      "pali": "Addhā hi so oghamimaṁ atāri,"
    },
    {
      "id": "cnd2:28.4",
      "pali": "Tiṇṇo ca pāraṁ akhilo akaṅkho."
    },
    {
      "id": "cnd2:29.1",
      "pali": "Vidvā ca yo vedagū naro idha,"
    },
    {
      "id": "cnd2:29.2",
      "pali": "Bhavābhave saṅgamimaṁ visajja;"
    },
    {
      "id": "cnd2:29.3",
      "pali": "So vītataṇho anīgho nirāso,"
    },
    {
      "id": "cnd2:29.4",
      "pali": "Atāri so jātijaranti brūmī”ti."
    },
    {
      "id": "cnd2:29.5",
      "pali": "Mettagūmāṇavapucchā catutthī."
    },
    {
      "id": "cnd2:30.1",
      "pali": "“Pucchāmi taṁ bhagavā brūhi metaṁ,"
    },
    {
      "id": "cnd2:30.2",
      "pali": "(iccāyasmā dhotako)"
    },
    {
      "id": "cnd2:30.3",
      "pali": "Vācābhikaṅkhāmi mahesi tuyhaṁ;"
    },
    {
      "id": "cnd2:30.4",
      "pali": "Tava sutvāna nigghosaṁ,"
    },
    {
      "id": "cnd2:30.5",
      "pali": "Sikkhe nibbānamattano”."
    },
    {
      "id": "cnd2:31.1",
      "pali": "“Tenahātappaṁ karohi,"
    },
    {
      "id": "cnd2:31.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "cnd2:31.3",
      "pali": "Idheva nipako sato;"
    },
    {
      "id": "cnd2:31.4",
      "pali": "Ito sutvāna nigghosaṁ,"
    },
    {
      "id": "cnd2:31.5",
      "pali": "Sikkhe nibbānamattano”."
    },
    {
      "id": "cnd2:32.1",
      "pali": "“Passāmahaṁ devamanussaloke,"
    },
    {
      "id": "cnd2:32.2",
      "pali": "Akiñcanaṁ brāhmaṇamiriyamānaṁ;"
    },
    {
      "id": "cnd2:32.3",
      "pali": "Taṁ taṁ namassāmi samantacakkhu,"
    },
    {
      "id": "cnd2:32.4",
      "pali": "Pamuñca maṁ sakka kathaṅkathāhi”."
    },
    {
      "id": "cnd2:33.1",
      "pali": "“Nāhaṁ sahissāmi pamocanāya,"
    },
    {
      "id": "cnd2:33.2",
      "pali": "Kathaṅkathiṁ dhotaka kañci loke;"
    },
    {
      "id": "cnd2:33.3",
      "pali": "Dhammañca seṭṭhaṁ abhijānamāno,"
    },
    {
      "id": "cnd2:33.4",
      "pali": "Evaṁ tuvaṁ oghamimaṁ taresi”."
    },
    {
      "id": "cnd2:34.1",
      "pali": "“Anusāsa brahme karuṇāyamāno,"
    },
    {
      "id": "cnd2:34.2",
      "pali": "Vivekadhammaṁ yamahaṁ vijaññaṁ;"
    },
    {
      "id": "cnd2:34.3",
      "pali": "Yathāhaṁ ākāsova abyāpajjamāno,"
    },
    {
      "id": "cnd2:34.4",
      "pali": "Idheva santo asito careyyaṁ”."
    },
    {
      "id": "cnd2:35.1",
      "pali": "“Kittayissāmi te santiṁ,"
    },
    {
      "id": "cnd2:35.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "cnd2:35.3",
      "pali": "Diṭṭhe dhamme anītihaṁ;"
    },
    {
      "id": "cnd2:35.4",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "cnd2:35.5",
      "pali": "Tare loke visattikaṁ”."
    },
    {
      "id": "cnd2:36.1",
      "pali": "“Tañcāhaṁ abhinandāmi,"
    },
    {
      "id": "cnd2:36.2",
      "pali": "mahesi santimuttamaṁ;"
    },
    {
      "id": "cnd2:36.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "cnd2:36.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "cnd2:37.1",
      "pali": "“Yaṁ kiñci sampajānāsi,"
    },
    {
      "id": "cnd2:37.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "cnd2:37.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "cnd2:37.4",
      "pali": "Etaṁ viditvā saṅgoti loke,"
    },
    {
      "id": "cnd2:37.5",
      "pali": "Bhavābhavāya mākāsi taṇhan”ti."
    },
    {
      "id": "cnd2:37.6",
      "pali": "Dhotakamāṇavapucchā pañcamī."
    },
    {
      "id": "cnd2:38.1",
      "pali": "“Eko ahaṁ sakka mahantamoghaṁ,"
    },
    {
      "id": "cnd2:38.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd2:38.3",
      "pali": "Anissito no visahāmi tārituṁ;"
    },
    {
      "id": "cnd2:38.4",
      "pali": "Ārammaṇaṁ brūhi samantacakkhu,"
    },
    {
      "id": "cnd2:38.5",
      "pali": "Yaṁ nissito oghamimaṁ tareyyaṁ”."
    },
    {
      "id": "cnd2:39.1",
      "pali": "“Ākiñcaññaṁ pekkhamāno satimā,"
    },
    {
      "id": "cnd2:39.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd2:39.3",
      "pali": "Natthīti nissāya tarassu oghaṁ;"
    },
    {
      "id": "cnd2:39.4",
      "pali": "Kāme pahāya virato kathāhi,"
    },
    {
      "id": "cnd2:39.5",
      "pali": "Taṇhakkhayaṁ nattamahābhipassa”."
    },
    {
      "id": "cnd2:40.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "cnd2:40.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd2:40.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "cnd2:40.4",
      "pali": "Saññāvimokkhe paramedhimutto,"
    },
    {
      "id": "cnd2:40.5",
      "pali": "Tiṭṭhe nu so tattha anānuyāyī”."
    },
    {
      "id": "cnd2:41.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "cnd2:41.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd2:41.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "cnd2:41.4",
      "pali": "Saññāvimokkhe paramedhimutto,"
    },
    {
      "id": "cnd2:41.5",
      "pali": "Tiṭṭheyya so tattha anānuyāyī”."
    },
    {
      "id": "cnd2:42.1",
      "pali": "“Tiṭṭhe ce so tattha anānuyāyī,"
    },
    {
      "id": "cnd2:42.2",
      "pali": "Pūgampi vassānaṁ samantacakkhu;"
    },
    {
      "id": "cnd2:42.3",
      "pali": "Tattheva so sītisiyā vimutto,"
    },
    {
      "id": "cnd2:42.4",
      "pali": "Cavetha viññāṇaṁ tathāvidhassa”."
    },
    {
      "id": "cnd2:43.1",
      "pali": "“Acci yathā vātavegena khittā,"
    },
    {
      "id": "cnd2:43.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd2:43.3",
      "pali": "Atthaṁ paleti na upeti saṅkhaṁ;"
    },
    {
      "id": "cnd2:43.4",
      "pali": "Evaṁ munī nāmakāyā vimutto,"
    },
    {
      "id": "cnd2:43.5",
      "pali": "Atthaṁ paleti na upeti saṅkhaṁ”."
    },
    {
      "id": "cnd2:44.1",
      "pali": "“Atthaṅgato so uda vā so natthi,"
    },
    {
      "id": "cnd2:44.2",
      "pali": "Udāhu ve sassatiyā arogo;"
    },
    {
      "id": "cnd2:44.3",
      "pali": "Taṁ me munī sādhu viyākarohi,"
    },
    {
      "id": "cnd2:44.4",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "cnd2:45.1",
      "pali": "“Atthaṅgatassa na pamāṇamatthi,"
    },
    {
      "id": "cnd2:45.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd2:45.3",
      "pali": "Yena naṁ vajjuṁ taṁ tassa natthi;"
    },
    {
      "id": "cnd2:45.4",
      "pali": "Sabbesu dhammesu samūhatesu,"
    },
    {
      "id": "cnd2:45.5",
      "pali": "Samūhatā vādapathāpi sabbe”ti."
    },
    {
      "id": "cnd2:45.6",
      "pali": "Upasīvamāṇavapucchā chaṭṭhī."
    },
    {
      "id": "cnd2:46.1",
      "pali": "“Santi loke munayo,"
    },
    {
      "id": "cnd2:46.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "cnd2:46.3",
      "pali": "Janā vadanti tayidaṁ kathaṁsu;"
    },
    {
      "id": "cnd2:46.4",
      "pali": "Ñāṇūpapannaṁ muni no vadanti,"
    },
    {
      "id": "cnd2:46.5",
      "pali": "Udāhu ve jīvitenūpapannaṁ”."
    },
    {
      "id": "cnd2:47.1",
      "pali": "“Na diṭṭhiyā na sutiyā na ñāṇena,"
    },
    {
      "id": "cnd2:47.2",
      "pali": "Munīdha nanda kusalā vadanti;"
    },
    {
      "id": "cnd2:47.3",
      "pali": "Visenikatvā anīghā nirāsā,"
    },
    {
      "id": "cnd2:47.4",
      "pali": "Caranti ye te munayoti brūmi”."
    },
    {
      "id": "cnd2:48.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "cnd2:48.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "cnd2:48.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:48.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "cnd2:48.5",
      "pali": "Anekarūpena vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:48.6",
      "pali": "Kaccissu te bhagavā tattha yatā carantā,"
    },
    {
      "id": "cnd2:48.7",
      "pali": "Atāru jātiñca jarañca mārisa;"
    },
    {
      "id": "cnd2:48.8",
      "pali": "Pucchāmi taṁ bhagavā brūhi metaṁ”."
    },
    {
      "id": "cnd2:49.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "cnd2:49.2",
      "pali": "(nandāti bhagavā)"
    },
    {
      "id": "cnd2:49.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:49.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "cnd2:49.5",
      "pali": "Anekarūpena vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:49.6",
      "pali": "Kiñcāpi te tattha yatā caranti,"
    },
    {
      "id": "cnd2:49.7",
      "pali": "Nātariṁsu jātijaranti brūmi”."
    },
    {
      "id": "cnd2:50.1",
      "pali": "“Ye kecime samaṇabrāhmaṇāse,"
    },
    {
      "id": "cnd2:50.2",
      "pali": "(iccāyasmā nando)"
    },
    {
      "id": "cnd2:50.3",
      "pali": "Diṭṭhassutenāpi vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:50.4",
      "pali": "Sīlabbatenāpi vadanti suddhiṁ,"
    },
    {
      "id": "cnd2:50.5",
      "pali": "Anekarūpena vadanti suddhiṁ;"
    },
    {
      "id": "cnd2:50.6",
      "pali": "Te ce muni brūsi anoghatiṇṇe,"
    },
    {
      "id": "cnd2:50.7",
      "pali": "Atha ko carahi devamanussaloke;"
    },
    {
      "id": "cnd2:50.8",
      "pali": "Atāri jātiñca jarañca mārisa,"
    },
    {
      "id": "cnd2:50.9",
      "pali": "Pucchāmi taṁ bhagavā brūhi metaṁ”."
    },
    {
      "id": "cnd2:51.1",
      "pali": "“Nāhaṁ sabbe samaṇabrāhmaṇāse,"
    },
    {
      "id": "cnd2:51.2",
      "pali": "(nandāti bhagavā)"
    },
    {
      "id": "cnd2:51.3",
      "pali": "Jātijarāya nivutāti brūmi;"
    },
    {
      "id": "cnd2:51.4",
      "pali": "Ye sīdha diṭṭhaṁ va sutaṁ mutaṁ vā,"
    },
    {
      "id": "cnd2:51.5",
      "pali": "Sīlabbataṁ vāpi pahāya sabbaṁ;"
    },
    {
      "id": "cnd2:51.6",
      "pali": "Anekarūpampi pahāya sabbaṁ,"
    },
    {
      "id": "cnd2:51.7",
      "pali": "Taṇhaṁ pariññāya anāsavāse;"
    },
    {
      "id": "cnd2:51.8",
      "pali": "Te ve narā oghatiṇṇāti brūmi”."
    },
    {
      "id": "cnd2:52.1",
      "pali": "“Etābhinandāmi vaco mahesino,"
    },
    {
      "id": "cnd2:52.2",
      "pali": "Sukittitaṁ gotamanūpadhīkaṁ;"
    },
    {
      "id": "cnd2:52.3",
      "pali": "Ye sīdha diṭṭhaṁ va sutaṁ mutaṁ vā,"
    },
    {
      "id": "cnd2:52.4",
      "pali": "Sīlabbataṁ vāpi pahāya sabbaṁ;"
    },
    {
      "id": "cnd2:52.5",
      "pali": "Anekarūpampi pahāya sabbaṁ,"
    },
    {
      "id": "cnd2:52.6",
      "pali": "Taṇhaṁ pariññāya anāsavāse;"
    },
    {
      "id": "cnd2:52.7",
      "pali": "Ahampi te oghatiṇṇāti brūmī”ti."
    },
    {
      "id": "cnd2:52.8",
      "pali": "Nandamāṇavapucchā sattamā."
    },
    {
      "id": "cnd2:53.1",
      "pali": "“Ye me pubbe viyākaṁsu,"
    },
    {
      "id": "cnd2:53.2",
      "pali": "(iccāyasmā hemako)"
    },
    {
      "id": "cnd2:53.3",
      "pali": "Huraṁ gotamasāsanā;"
    },
    {
      "id": "cnd2:53.4",
      "pali": "Iccāsi iti bhavissati,"
    },
    {
      "id": "cnd2:53.5",
      "pali": "Sabbaṁ taṁ itihītihaṁ;"
    },
    {
      "id": "cnd2:53.6",
      "pali": "Sabbaṁ taṁ takkavaḍḍhanaṁ,"
    },
    {
      "id": "cnd2:53.7",
      "pali": "Nāhaṁ tattha abhiramiṁ."
    },
    {
      "id": "cnd2:54.1",
      "pali": "Tvañca me dhammamakkhāhi,"
    },
    {
      "id": "cnd2:54.2",
      "pali": "taṇhānigghātanaṁ muni;"
    },
    {
      "id": "cnd2:54.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "cnd2:54.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "cnd2:55.1",
      "pali": "“Idha diṭṭhasutamutaviññātesu,"
    },
    {
      "id": "cnd2:55.2",
      "pali": "Piyarūpesu hemaka;"
    },
    {
      "id": "cnd2:55.3",
      "pali": "Chandarāgavinodanaṁ,"
    },
    {
      "id": "cnd2:55.4",
      "pali": "Nibbānapadamaccutaṁ."
    },
    {
      "id": "cnd2:56.1",
      "pali": "Etadaññāya ye satā,"
    },
    {
      "id": "cnd2:56.2",
      "pali": "Diṭṭhadhammābhinibbutā;"
    },
    {
      "id": "cnd2:56.3",
      "pali": "Upasantā ca te sadā,"
    },
    {
      "id": "cnd2:56.4",
      "pali": "Tiṇṇā loke visattikan”ti."
    },
    {
      "id": "cnd2:56.5",
      "pali": "Hemakamāṇavapucchā aṭṭhamā."
    },
    {
      "id": "cnd2:57.1",
      "pali": "“Yasmiṁ kāmā na vasanti,"
    },
    {
      "id": "cnd2:57.2",
      "pali": "(iccāyasmā todeyyo)"
    },
    {
      "id": "cnd2:57.3",
      "pali": "Taṇhā yassa na vijjati;"
    },
    {
      "id": "cnd2:57.4",
      "pali": "Kathaṅkathā ca yo tiṇṇo,"
    },
    {
      "id": "cnd2:57.5",
      "pali": "Vimokkho tassa kīdiso”."
    },
    {
      "id": "cnd2:58.1",
      "pali": "“Yasmiṁ kāmā na vasanti,"
    },
    {
      "id": "cnd2:58.2",
      "pali": "(todeyyāti bhagavā)"
    },
    {
      "id": "cnd2:58.3",
      "pali": "Taṇhā yassa na vijjati;"
    },
    {
      "id": "cnd2:58.4",
      "pali": "Kathaṅkathā ca yo tiṇṇo,"
    },
    {
      "id": "cnd2:58.5",
      "pali": "Vimokkho tassa nāparo”."
    },
    {
      "id": "cnd2:59.1",
      "pali": "“Nirāsaso so uda āsasāno,"
    },
    {
      "id": "cnd2:59.2",
      "pali": "Paññāṇavā so uda paññakappī;"
    },
    {
      "id": "cnd2:59.3",
      "pali": "Muniṁ ahaṁ sakka yathā vijaññaṁ,"
    },
    {
      "id": "cnd2:59.4",
      "pali": "Taṁ me viyācikkha samantacakkhu”."
    },
    {
      "id": "cnd2:60.1",
      "pali": "“Nirāsaso so na ca āsasāno,"
    },
    {
      "id": "cnd2:60.2",
      "pali": "Paññāṇavā so na ca paññakappī;"
    },
    {
      "id": "cnd2:60.3",
      "pali": "Evampi todeyya muniṁ vijāna,"
    },
    {
      "id": "cnd2:60.4",
      "pali": "Akiñcanaṁ kāmabhave asattan”ti."
    },
    {
      "id": "cnd2:60.5",
      "pali": "Todeyyamāṇavapucchā navamā."
    },
    {
      "id": "cnd2:61.1",
      "pali": "“Majjhe sarasmiṁ tiṭṭhataṁ,"
    },
    {
      "id": "cnd2:61.2",
      "pali": "(iccāyasmā kappo)"
    },
    {
      "id": "cnd2:61.3",
      "pali": "Oghe jāte mahabbhaye;"
    },
    {
      "id": "cnd2:61.4",
      "pali": "Jarāmaccuparetānaṁ,"
    },
    {
      "id": "cnd2:61.5",
      "pali": "Dīpaṁ pabrūhi mārisa;"
    },
    {
      "id": "cnd2:61.6",
      "pali": "Tvañca me dīpamakkhāhi,"
    },
    {
      "id": "cnd2:61.7",
      "pali": "Yathāyidaṁ nāparaṁ siyā”."
    },
    {
      "id": "cnd2:62.1",
      "pali": "“Majjhe sarasmiṁ tiṭṭhataṁ,"
    },
    {
      "id": "cnd2:62.2",
      "pali": "(kappāti bhagavā)"
    },
    {
      "id": "cnd2:62.3",
      "pali": "Oghe jāte mahabbhaye;"
    },
    {
      "id": "cnd2:62.4",
      "pali": "Jarāmaccuparetānaṁ,"
    },
    {
      "id": "cnd2:62.5",
      "pali": "Dīpaṁ pabrūmi kappa te."
    },
    {
      "id": "cnd2:63.1",
      "pali": "Akiñcanaṁ anādānaṁ,"
    },
    {
      "id": "cnd2:63.2",
      "pali": "etaṁ dīpaṁ anāparaṁ;"
    },
    {
      "id": "cnd2:63.3",
      "pali": "Nibbānaṁ iti naṁ brūmi,"
    },
    {
      "id": "cnd2:63.4",
      "pali": "jarāmaccuparikkhayaṁ."
    },
    {
      "id": "cnd2:64.1",
      "pali": "Etadaññāya ye satā,"
    },
    {
      "id": "cnd2:64.2",
      "pali": "Diṭṭhadhammābhinibbutā;"
    },
    {
      "id": "cnd2:64.3",
      "pali": "Na te māravasānugā,"
    },
    {
      "id": "cnd2:64.4",
      "pali": "Na te mārassa paddhagū”ti."
    },
    {
      "id": "cnd2:64.5",
      "pali": "Kappamāṇavapucchā dasamā."
    },
    {
      "id": "cnd2:65.1",
      "pali": "“Sutvānahaṁ vīramakāmakāmiṁ,"
    },
    {
      "id": "cnd2:65.2",
      "pali": "(iccāyasmā jatukaṇṇi)"
    },
    {
      "id": "cnd2:65.3",
      "pali": "Oghātigaṁ puṭṭhumakāmamāgamaṁ;"
    },
    {
      "id": "cnd2:65.4",
      "pali": "Santipadaṁ brūhi sahajanetta,"
    },
    {
      "id": "cnd2:65.5",
      "pali": "Yathātacchaṁ bhagavā brūhi metaṁ."
    },
    {
      "id": "cnd2:66.1",
      "pali": "Bhagavā hi kāme abhibhuyya iriyati,"
    },
    {
      "id": "cnd2:66.2",
      "pali": "Ādiccova pathaviṁ tejī tejasā;"
    },
    {
      "id": "cnd2:66.3",
      "pali": "Parittapaññassa me bhūripañña,"
    },
    {
      "id": "cnd2:66.4",
      "pali": "Ācikkha dhammaṁ yamahaṁ vijaññaṁ;"
    },
    {
      "id": "cnd2:66.5",
      "pali": "Jātijarāya idha vippahānaṁ”."
    },
    {
      "id": "cnd2:67.1",
      "pali": "“Kāmesu vinaya gedhaṁ,"
    },
    {
      "id": "cnd2:67.2",
      "pali": "(jatukaṇṇīti bhagavā)"
    },
    {
      "id": "cnd2:67.3",
      "pali": "Nekkhammaṁ daṭṭhu khemato;"
    },
    {
      "id": "cnd2:67.4",
      "pali": "Uggahitaṁ nirattaṁ vā,"
    },
    {
      "id": "cnd2:67.5",
      "pali": "Mā te vijjittha kiñcanaṁ."
    },
    {
      "id": "cnd2:68.1",
      "pali": "Yaṁ pubbe taṁ visosehi,"
    },
    {
      "id": "cnd2:68.2",
      "pali": "pacchā te māhu kiñcanaṁ;"
    },
    {
      "id": "cnd2:68.3",
      "pali": "Majjhe ce no gahessasi,"
    },
    {
      "id": "cnd2:68.4",
      "pali": "upasanto carissasi."
    },
    {
      "id": "cnd2:69.1",
      "pali": "Sabbaso nāmarūpasmiṁ,"
    },
    {
      "id": "cnd2:69.2",
      "pali": "Vītagedhassa brāhmaṇa;"
    },
    {
      "id": "cnd2:69.3",
      "pali": "Āsavāssa na vijjanti,"
    },
    {
      "id": "cnd2:69.4",
      "pali": "Yehi maccuvasaṁ vaje”ti."
    },
    {
      "id": "cnd2:69.5",
      "pali": "Jatukaṇṇimāṇavapucchā ekādasamā."
    },
    {
      "id": "cnd2:70.1",
      "pali": "“Okañjahaṁ taṇhacchidaṁ anejaṁ,"
    },
    {
      "id": "cnd2:70.2",
      "pali": "(iccāyasmā bhadrāvudho)"
    },
    {
      "id": "cnd2:70.3",
      "pali": "Nandiñjahaṁ oghatiṇṇaṁ vimuttaṁ;"
    },
    {
      "id": "cnd2:70.4",
      "pali": "Kappañjahaṁ abhiyāce sumedhaṁ,"
    },
    {
      "id": "cnd2:70.5",
      "pali": "Sutvāna nāgassa apanamissanti ito."
    },
    {
      "id": "cnd2:71.1",
      "pali": "Nānājanā janapadehi saṅgatā,"
    },
    {
      "id": "cnd2:71.2",
      "pali": "Tava vīra vākyaṁ abhikaṅkhamānā;"
    },
    {
      "id": "cnd2:71.3",
      "pali": "Tesaṁ tuvaṁ sādhu viyākarohi,"
    },
    {
      "id": "cnd2:71.4",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "cnd2:72.1",
      "pali": "“Ādānataṇhaṁ vinayetha sabbaṁ,"
    },
    {
      "id": "cnd2:72.2",
      "pali": "(bhadrāvudhāti bhagavā)"
    },
    {
      "id": "cnd2:72.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "cnd2:72.4",
      "pali": "Yaṁ yañhi lokasmimupādiyanti,"
    },
    {
      "id": "cnd2:72.5",
      "pali": "Teneva māro anveti jantuṁ."
    },
    {
      "id": "cnd2:73.1",
      "pali": "Tasmā pajānaṁ na upādiyetha,"
    },
    {
      "id": "cnd2:73.2",
      "pali": "Bhikkhu sato kiñcanaṁ sabbaloke;"
    },
    {
      "id": "cnd2:73.3",
      "pali": "Ādānasatte iti pekkhamāno,"
    },
    {
      "id": "cnd2:73.4",
      "pali": "Pajaṁ imaṁ maccudheyye visattan”ti."
    },
    {
      "id": "cnd2:73.5",
      "pali": "Bhadrāvudhamāṇavapucchā dvādasamā."
    },
    {
      "id": "cnd2:74.1",
      "pali": "“Jhāyiṁ virajamāsīnaṁ,"
    },
    {
      "id": "cnd2:74.2",
      "pali": "(iccāyasmā udayo)"
    },
    {
      "id": "cnd2:74.3",
      "pali": "Katakiccaṁ anāsavaṁ;"
    },
    {
      "id": "cnd2:74.4",
      "pali": "Pāraguṁ sabbadhammānaṁ,"
    },
    {
      "id": "cnd2:74.5",
      "pali": "Atthi pañhena āgamaṁ;"
    },
    {
      "id": "cnd2:74.6",
      "pali": "Aññāvimokkhaṁ pabrūhi,"
    },
    {
      "id": "cnd2:74.7",
      "pali": "Avijjāya pabhedanaṁ”."
    },
    {
      "id": "cnd2:75.1",
      "pali": "“Pahānaṁ kāmacchandānaṁ,"
    },
    {
      "id": "cnd2:75.2",
      "pali": "(udayāti bhagavā)"
    },
    {
      "id": "cnd2:75.3",
      "pali": "Domanassāna cūbhayaṁ;"
    },
    {
      "id": "cnd2:75.4",
      "pali": "Thinassa ca panūdanaṁ,"
    },
    {
      "id": "cnd2:75.5",
      "pali": "Kukkuccānaṁ nivāraṇaṁ."
    },
    {
      "id": "cnd2:76.1",
      "pali": "Upekkhāsatisaṁsuddhaṁ,"
    },
    {
      "id": "cnd2:76.2",
      "pali": "dhammatakkapurejavaṁ;"
    },
    {
      "id": "cnd2:76.3",
      "pali": "Aññāvimokkhaṁ pabrūmi,"
    },
    {
      "id": "cnd2:76.4",
      "pali": "avijjāya pabhedanaṁ”."
    },
    {
      "id": "cnd2:77.1",
      "pali": "“Kiṁsu saṁyojano loko,"
    },
    {
      "id": "cnd2:77.2",
      "pali": "kiṁsu tassa vicāraṇaṁ;"
    },
    {
      "id": "cnd2:77.3",
      "pali": "Kissassa vippahānena,"
    },
    {
      "id": "cnd2:77.4",
      "pali": "nibbānaṁ iti vuccati”."
    },
    {
      "id": "cnd2:78.1",
      "pali": "“Nandisaṁyojano loko,"
    },
    {
      "id": "cnd2:78.2",
      "pali": "vitakkassa vicāraṇaṁ;"
    },
    {
      "id": "cnd2:78.3",
      "pali": "Taṇhāya vippahānena,"
    },
    {
      "id": "cnd2:78.4",
      "pali": "nibbānaṁ iti vuccati”."
    },
    {
      "id": "cnd2:79.1",
      "pali": "“Kathaṁ satassa carato,"
    },
    {
      "id": "cnd2:79.2",
      "pali": "viññāṇaṁ uparujjhati;"
    },
    {
      "id": "cnd2:79.3",
      "pali": "Bhagavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "cnd2:79.4",
      "pali": "taṁ suṇoma vaco tava”."
    },
    {
      "id": "cnd2:80.1",
      "pali": "“Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "cnd2:80.2",
      "pali": "Vedanaṁ nābhinandato;"
    },
    {
      "id": "cnd2:80.3",
      "pali": "Evaṁ satassa carato,"
    },
    {
      "id": "cnd2:80.4",
      "pali": "Viññāṇaṁ uparujjhatī”ti."
    },
    {
      "id": "cnd2:80.5",
      "pali": "Udayamāṇavapucchā terasamā."
    },
    {
      "id": "cnd2:81.1",
      "pali": "“Yo atītaṁ ādisati,"
    },
    {
      "id": "cnd2:81.2",
      "pali": "(iccāyasmā posālo)"
    },
    {
      "id": "cnd2:81.3",
      "pali": "Anejo chinnasaṁsayo;"
    },
    {
      "id": "cnd2:81.4",
      "pali": "Pāraguṁ sabbadhammānaṁ,"
    },
    {
      "id": "cnd2:81.5",
      "pali": "Atthi pañhena āgamaṁ."
    },
    {
      "id": "cnd2:82.1",
      "pali": "Vibhūtarūpasaññissa,"
    },
    {
      "id": "cnd2:82.2",
      "pali": "sabbakāyappahāyino;"
    },
    {
      "id": "cnd2:82.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "cnd2:82.4",
      "pali": "natthi kiñcīti passato;"
    },
    {
      "id": "cnd2:82.5",
      "pali": "Ñāṇaṁ sakkānupucchāmi,"
    },
    {
      "id": "cnd2:82.6",
      "pali": "kathaṁ neyyo tathāvidho”."
    },
    {
      "id": "cnd2:83.1",
      "pali": "“Viññāṇaṭṭhitiyo sabbā,"
    },
    {
      "id": "cnd2:83.2",
      "pali": "(posālāti bhagavā)"
    },
    {
      "id": "cnd2:83.3",
      "pali": "Abhijānaṁ tathāgato;"
    },
    {
      "id": "cnd2:83.4",
      "pali": "Tiṭṭhantamenaṁ jānāti,"
    },
    {
      "id": "cnd2:83.5",
      "pali": "Vimuttaṁ tapparāyaṇaṁ."
    },
    {
      "id": "cnd2:84.1",
      "pali": "Ākiñcaññasambhavaṁ ñatvā,"
    },
    {
      "id": "cnd2:84.2",
      "pali": "Nandī saṁyojanaṁ iti;"
    },
    {
      "id": "cnd2:84.3",
      "pali": "Evametaṁ abhiññāya,"
    },
    {
      "id": "cnd2:84.4",
      "pali": "Tato tattha vipassati;"
    },
    {
      "id": "cnd2:84.5",
      "pali": "Etaṁ ñāṇaṁ tathaṁ tassa,"
    },
    {
      "id": "cnd2:84.6",
      "pali": "Brāhmaṇassa vusīmato”ti."
    },
    {
      "id": "cnd2:84.7",
      "pali": "Posālamāṇavapucchā cuddasamā."
    },
    {
      "id": "cnd2:85.1",
      "pali": "“Dvāhaṁ sakkaṁ apucchissaṁ,"
    },
    {
      "id": "cnd2:85.2",
      "pali": "(iccāyasmā mogharājā)"
    },
    {
      "id": "cnd2:85.3",
      "pali": "Na me byākāsi cakkhumā;"
    },
    {
      "id": "cnd2:85.4",
      "pali": "Yāvatatiyañca devīsi,"
    },
    {
      "id": "cnd2:85.5",
      "pali": "Byākarotīti me sutaṁ."
    },
    {
      "id": "cnd2:86.1",
      "pali": "Ayaṁ loko paro loko,"
    },
    {
      "id": "cnd2:86.2",
      "pali": "brahmaloko sadevako;"
    },
    {
      "id": "cnd2:86.3",
      "pali": "Diṭṭhiṁ te nābhijānāti,"
    },
    {
      "id": "cnd2:86.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "cnd2:87.1",
      "pali": "Evaṁ abhikkantadassāviṁ,"
    },
    {
      "id": "cnd2:87.2",
      "pali": "atthi pañhena āgamaṁ;"
    },
    {
      "id": "cnd2:87.3",
      "pali": "Kathaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "cnd2:87.4",
      "pali": "maccurājā na passati”."
    },
    {
      "id": "cnd2:88.1",
      "pali": "“Suññato lokaṁ avekkhassu,"
    },
    {
      "id": "cnd2:88.2",
      "pali": "Mogharāja sadā sato;"
    },
    {
      "id": "cnd2:88.3",
      "pali": "Attānudiṭṭhiṁ ūhacca,"
    },
    {
      "id": "cnd2:88.4",
      "pali": "Evaṁ maccutaro siyā;"
    },
    {
      "id": "cnd2:88.5",
      "pali": "Evaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "cnd2:88.6",
      "pali": "Maccurājā na passatī”ti."
    },
    {
      "id": "cnd2:88.7",
      "pali": "Mogharājamāṇavapucchā pannarasamā."
    },
    {
      "id": "cnd2:89.1",
      "pali": "“Jiṇṇohamasmi abalo vītavaṇṇo,"
    },
    {
      "id": "cnd2:89.2",
      "pali": "(iccāyasmā piṅgiyo)"
    },
    {
      "id": "cnd2:89.3",
      "pali": "Nettā na suddhā savanaṁ na phāsu;"
    },
    {
      "id": "cnd2:89.4",
      "pali": "Māhaṁ nassaṁ momuho antarāva,"
    },
    {
      "id": "cnd2:89.5",
      "pali": "Ācikkha dhammaṁ yamahaṁ vijaññaṁ;"
    },
    {
      "id": "cnd2:89.6",
      "pali": "Jātijarāya idha vippahānaṁ”."
    },
    {
      "id": "cnd2:90.1",
      "pali": "“Disvāna rūpesu vihaññamāne,"
    },
    {
      "id": "cnd2:90.2",
      "pali": "(piṅgiyāti bhagavā)"
    },
    {
      "id": "cnd2:90.3",
      "pali": "Ruppanti rūpesu janā pamattā;"
    },
    {
      "id": "cnd2:90.4",
      "pali": "Tasmā tuvaṁ piṅgiya appamatto,"
    },
    {
      "id": "cnd2:90.5",
      "pali": "Jahassu rūpaṁ apunabbhavāya”."
    },
    {
      "id": "cnd2:91.1",
      "pali": "“Disā catasso vidisā catasso,"
    },
    {
      "id": "cnd2:91.2",
      "pali": "Uddhaṁ adho dasa disā imāyo;"
    },
    {
      "id": "cnd2:91.3",
      "pali": "Na tuyhaṁ adiṭṭhaṁ asutaṁ amutaṁ,"
    },
    {
      "id": "cnd2:91.4",
      "pali": "Atho aviññātaṁ kiñcanamatthi loke;"
    },
    {
      "id": "cnd2:91.5",
      "pali": "Ācikkha dhammaṁ yamahaṁ vijaññaṁ,"
    },
    {
      "id": "cnd2:91.6",
      "pali": "Jātijarāya idha vippahānaṁ”."
    },
    {
      "id": "cnd2:92.1",
      "pali": "“Taṇhādhipanne manuje pekkhamāno,"
    },
    {
      "id": "cnd2:92.2",
      "pali": "(piṅgiyāti bhagavā)"
    },
    {
      "id": "cnd2:92.3",
      "pali": "Santāpajāte jarasā parete;"
    },
    {
      "id": "cnd2:92.4",
      "pali": "Tasmā tuvaṁ piṅgiya appamatto,"
    },
    {
      "id": "cnd2:92.5",
      "pali": "Jahassu taṇhaṁ apunabbhavāyā”ti."
    },
    {
      "id": "cnd2:92.6",
      "pali": "Piṅgiyamāṇavapucchā soḷasamā."
    }
  ]
}
