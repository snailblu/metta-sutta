{
  "uid": "tha-ap471",
  "title": "9 Sayampaṭibhāniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap471:1.1",
      "pali": "“Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap471:1.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap471:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap471:1.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:2.1",
      "pali": "Tamandhakāraṁ nāsetvā,"
    },
    {
      "id": "tha-ap471:2.2",
      "pali": "santāretvā bahuṁ janaṁ;"
    },
    {
      "id": "tha-ap471:2.3",
      "pali": "Ñāṇālokena jotantaṁ,"
    },
    {
      "id": "tha-ap471:2.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:3.1",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap471:3.2",
      "pali": "nīyantaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap471:3.3",
      "pali": "Uddharantaṁ bahū satte,"
    },
    {
      "id": "tha-ap471:3.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:4.1",
      "pali": "Āhanantaṁ dhammabheriṁ,"
    },
    {
      "id": "tha-ap471:4.2",
      "pali": "maddantaṁ titthiye gaṇe;"
    },
    {
      "id": "tha-ap471:4.3",
      "pali": "Sīhanādaṁ vinadantaṁ,"
    },
    {
      "id": "tha-ap471:4.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:5.1",
      "pali": "Yāvatā brahmalokato,"
    },
    {
      "id": "tha-ap471:5.2",
      "pali": "āgantvāna sabrahmakā;"
    },
    {
      "id": "tha-ap471:5.3",
      "pali": "Pucchanti nipuṇe pañhe,"
    },
    {
      "id": "tha-ap471:5.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:6.1",
      "pali": "Yassañjaliṁ karitvāna,"
    },
    {
      "id": "tha-ap471:6.2",
      "pali": "āyācanti sadevakā;"
    },
    {
      "id": "tha-ap471:6.3",
      "pali": "Tena puññaṁ anubhonti,"
    },
    {
      "id": "tha-ap471:6.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:7.1",
      "pali": "Sabbe janā samāgantvā,"
    },
    {
      "id": "tha-ap471:7.2",
      "pali": "sampavārenti cakkhumaṁ;"
    },
    {
      "id": "tha-ap471:7.3",
      "pali": "Na vikampati ajjhiṭṭho,"
    },
    {
      "id": "tha-ap471:7.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:8.1",
      "pali": "Nagaraṁ pavisato yassa,"
    },
    {
      "id": "tha-ap471:8.2",
      "pali": "ravanti bheriyo bahū;"
    },
    {
      "id": "tha-ap471:8.3",
      "pali": "Vinadanti gajā mattā,"
    },
    {
      "id": "tha-ap471:8.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:9.1",
      "pali": "Vīthiyā gacchato yassa,"
    },
    {
      "id": "tha-ap471:9.2",
      "pali": "sabbābhā jotate sadā;"
    },
    {
      "id": "tha-ap471:9.3",
      "pali": "Abbhunnatā samā honti,"
    },
    {
      "id": "tha-ap471:9.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:10.1",
      "pali": "Byāharantassa buddhassa,"
    },
    {
      "id": "tha-ap471:10.2",
      "pali": "cakkavāḷampi suyyati;"
    },
    {
      "id": "tha-ap471:10.3",
      "pali": "Sabbe satte viññāpeti,"
    },
    {
      "id": "tha-ap471:10.4",
      "pali": "ko disvā na pasīdati."
    },
    {
      "id": "tha-ap471:11.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap471:11.2",
      "pali": "yaṁ buddhamabhikittayiṁ;"
    },
    {
      "id": "tha-ap471:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap471:11.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap471:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap471:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap471:12.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap471:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap471:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap471:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap471:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap471:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap471:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap471:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā sayampaṭibhāniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap471:16.1",
      "pali": "Sayampaṭibhāniyattherassāpadānaṁ navamaṁ."
    }
  ]
}
