{
  "uid": "thi-ap2",
  "title": "2 Mekhalādāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap2:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "thi-ap2:1.2",
      "pali": "thūpakārāpikā ahuṁ;"
    },
    {
      "id": "thi-ap2:1.3",
      "pali": "Mekhalikā mayā dinnā,"
    },
    {
      "id": "thi-ap2:1.4",
      "pali": "navakammāya satthuno."
    },
    {
      "id": "thi-ap2:2.1",
      "pali": "Niṭṭhite ca mahāthūpe,"
    },
    {
      "id": "thi-ap2:2.2",
      "pali": "mekhalaṁ punadāsahaṁ;"
    },
    {
      "id": "thi-ap2:2.3",
      "pali": "Lokanāthassa munino,"
    },
    {
      "id": "thi-ap2:2.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "thi-ap2:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "thi-ap2:3.2",
      "pali": "yaṁ mekhalamadaṁ tadā;"
    },
    {
      "id": "thi-ap2:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap2:3.4",
      "pali": "thūpakārassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap2:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap2:4.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap2:4.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap2:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap2:5.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap2:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap2:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap2:6.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap2:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap2:7.1",
      "pali": "Itthaṁ sudaṁ mekhalādāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap2:8.1",
      "pali": "Mekhalādāyikātheriyāpadānaṁ dutiyaṁ."
    }
  ]
}
