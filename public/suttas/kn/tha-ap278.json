{
  "uid": "tha-ap278",
  "title": "6 Potthakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap278:1.1",
      "pali": "“Satthāraṁ dhammamārabbha,"
    },
    {
      "id": "tha-ap278:1.2",
      "pali": "saṅghañcāpi mahesinaṁ;"
    },
    {
      "id": "tha-ap278:1.3",
      "pali": "Potthadānaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap278:1.4",
      "pali": "dakkhiṇeyye anuttare."
    },
    {
      "id": "tha-ap278:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap278:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap278:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap278:2.4",
      "pali": "potthadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap278:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap278:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap278:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap278:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā potthakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap278:5.1",
      "pali": "Potthakadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
