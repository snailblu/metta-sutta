{
  "uid": "tha-ap334",
  "title": "Udakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap334:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap334:1.2",
      "pali": "Gacchantaṁ anilañjase;"
    },
    {
      "id": "tha-ap334:1.3",
      "pali": "Ghatāsanaṁva jalitaṁ,"
    },
    {
      "id": "tha-ap334:1.4",
      "pali": "Ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap334:2.1",
      "pali": "Pāṇinā udakaṁ gayha,"
    },
    {
      "id": "tha-ap334:2.2",
      "pali": "ākāse ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap334:2.3",
      "pali": "Sampaṭicchi mahāvīro,"
    },
    {
      "id": "tha-ap334:2.4",
      "pali": "buddho kāruṇiko isi."
    },
    {
      "id": "tha-ap334:3.1",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap334:3.2",
      "pali": "padumuttaranāmako;"
    },
    {
      "id": "tha-ap334:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap334:3.4",
      "pali": "imaṁ gāthamabhāsatha."
    },
    {
      "id": "tha-ap334:4.1",
      "pali": "‘Iminā dakadānena,"
    },
    {
      "id": "tha-ap334:4.2",
      "pali": "pītiuppādanena ca;"
    },
    {
      "id": "tha-ap334:4.3",
      "pali": "Kappasatasahassampi,"
    },
    {
      "id": "tha-ap334:4.4",
      "pali": "duggatiṁ nupapajjati’."
    },
    {
      "id": "tha-ap334:5.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap334:5.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap334:5.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap334:5.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap334:6.1",
      "pali": "Sahassarājanāmena,"
    },
    {
      "id": "tha-ap334:6.2",
      "pali": "tayo ca cakkavattino;"
    },
    {
      "id": "tha-ap334:6.3",
      "pali": "Pañcasaṭṭhikappasate,"
    },
    {
      "id": "tha-ap334:6.4",
      "pali": "cāturantā janādhipā."
    },
    {
      "id": "tha-ap334:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap334:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap334:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap334:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā udakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap334:9.1",
      "pali": "Udakapūjakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
