{
  "uid": "iti98",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti98:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti98:2.1",
      "pali": "“Dvemāni, bhikkhave, dānāni—"
    },
    {
      "id": "iti98:2.2",
      "pali": "āmisadānañca dhammadānañca."
    },
    {
      "id": "iti98:2.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ dānānaṁ yadidaṁ dhammadānaṁ."
    },
    {
      "id": "iti98:3.1",
      "pali": "Dveme, bhikkhave, saṁvibhāgā—"
    },
    {
      "id": "iti98:3.2",
      "pali": "āmisasaṁvibhāgo ca dhammasaṁvibhāgo ca."
    },
    {
      "id": "iti98:3.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ saṁvibhāgānaṁ yadidaṁ dhammasaṁvibhāgo."
    },
    {
      "id": "iti98:4.1",
      "pali": "Dveme, bhikkhave, anuggahā—"
    },
    {
      "id": "iti98:4.2",
      "pali": "āmisānuggaho ca dhammānuggaho ca."
    },
    {
      "id": "iti98:4.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ anuggahānaṁ yadidaṁ dhammānuggaho”ti."
    },
    {
      "id": "iti98:4.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti98:4.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti98:5.1",
      "pali": "“Yamāhu dānaṁ paramaṁ anuttaraṁ,"
    },
    {
      "id": "iti98:5.2",
      "pali": "Yaṁ saṁvibhāgaṁ bhagavā avaṇṇayi;"
    },
    {
      "id": "iti98:5.3",
      "pali": "Aggamhi khettamhi pasannacitto,"
    },
    {
      "id": "iti98:5.4",
      "pali": "Viññū pajānaṁ ko na yajetha kāle."
    },
    {
      "id": "iti98:6.1",
      "pali": "Ye ceva bhāsanti suṇanti cūbhayaṁ,"
    },
    {
      "id": "iti98:6.2",
      "pali": "Pasannacittā sugatassa sāsane;"
    },
    {
      "id": "iti98:6.3",
      "pali": "Tesaṁ so attho paramo visujjhati,"
    },
    {
      "id": "iti98:6.4",
      "pali": "Ye appamattā sugatassa sāsane”ti."
    },
    {
      "id": "iti98:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti98:7.2",
      "pali": "Navamaṁ."
    }
  ]
}
