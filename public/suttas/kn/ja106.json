{
  "uid": "ja106",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja106:1.1",
      "pali": "“Sukhaṁ vata maṁ jīvantaṁ,"
    },
    {
      "id": "ja106:1.2",
      "pali": "Pacamānā udañcanī;"
    },
    {
      "id": "ja106:1.3",
      "pali": "Corī jāyappavādena,"
    },
    {
      "id": "ja106:1.4",
      "pali": "Telaṁ loṇañca yācatī”ti."
    },
    {
      "id": "ja106:2.1",
      "pali": "Udañcanījātakaṁ chaṭṭhaṁ."
    }
  ]
}
