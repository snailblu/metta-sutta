{
  "uid": "vv11",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv11:1.1",
      "pali": "“Koñcā mayūrā diviyā ca haṁsā,"
    },
    {
      "id": "vv11:1.2",
      "pali": "Vaggussarā kokilā sampatanti;"
    },
    {
      "id": "vv11:1.3",
      "pali": "Pupphābhikiṇṇaṁ rammamidaṁ vimānaṁ,"
    },
    {
      "id": "vv11:1.4",
      "pali": "Anekacittaṁ naranārisevitaṁ."
    },
    {
      "id": "vv11:2.1",
      "pali": "Tatthacchasi devi mahānubhāve,"
    },
    {
      "id": "vv11:2.2",
      "pali": "Iddhī vikubbanti anekarūpā;"
    },
    {
      "id": "vv11:2.3",
      "pali": "Imā ca te accharāyo samantato,"
    },
    {
      "id": "vv11:2.4",
      "pali": "Naccanti gāyanti pamodayanti ca."
    },
    {
      "id": "vv11:3.1",
      "pali": "Deviddhipattāsi mahānubhāve,"
    },
    {
      "id": "vv11:3.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv11:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv11:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv11:4.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv11:4.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv11:4.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv11:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv11:5.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv11:5.2",
      "pali": "Patibbatānaññamanā ahosiṁ;"
    },
    {
      "id": "vv11:5.3",
      "pali": "Mātāva puttaṁ anurakkhamānā,"
    },
    {
      "id": "vv11:5.4",
      "pali": "Kuddhāpihaṁ nappharusaṁ avocaṁ."
    },
    {
      "id": "vv11:6.1",
      "pali": "Sacce ṭhitā mosavajjaṁ pahāya,"
    },
    {
      "id": "vv11:6.2",
      "pali": "Dāne ratā saṅgahitattabhāvā;"
    },
    {
      "id": "vv11:6.3",
      "pali": "Annañca pānañca pasannacittā,"
    },
    {
      "id": "vv11:6.4",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv11:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv11:7.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv11:7.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv11:7.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv11:8.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv11:8.2",
      "pali": "Manussabhūtā yamakāsi puññaṁ;"
    },
    {
      "id": "vv11:8.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv11:8.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv11:9.1",
      "pali": "Paṭhamapatibbatāvimānaṁ ekādasamaṁ."
    }
  ]
}
