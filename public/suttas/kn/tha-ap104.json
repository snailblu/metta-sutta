{
  "uid": "tha-ap104",
  "title": "2 Ñāṇasaññikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap104:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap104:1.2",
      "pali": "Nisabhājāniyaṁ yathā;"
    },
    {
      "id": "tha-ap104:1.3",
      "pali": "Tidhāpabhinnaṁ mātaṅgaṁ,"
    },
    {
      "id": "tha-ap104:1.4",
      "pali": "Kuñjaraṁva mahesinaṁ."
    },
    {
      "id": "tha-ap104:2.1",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap104:2.2",
      "pali": "uḷurājaṁva pūritaṁ;"
    },
    {
      "id": "tha-ap104:2.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap104:2.4",
      "pali": "lokajeṭṭhaṁ apassahaṁ."
    },
    {
      "id": "tha-ap104:3.1",
      "pali": "Ñāṇe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap104:3.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap104:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap104:3.4",
      "pali": "siddhatthamabhivādayiṁ."
    },
    {
      "id": "tha-ap104:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap104:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap104:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap104:4.4",
      "pali": "ñāṇasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap104:5.1",
      "pali": "Tesattatimhito kappe,"
    },
    {
      "id": "tha-ap104:5.2",
      "pali": "soḷasāsuṁ naruttamā;"
    },
    {
      "id": "tha-ap104:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap104:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap104:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap104:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap104:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap104:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ñāṇasaññiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap104:8.1",
      "pali": "Ñāṇasaññikattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
