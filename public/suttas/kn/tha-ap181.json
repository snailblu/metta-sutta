{
  "uid": "tha-ap181",
  "title": "Tikicchakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap181:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap181:1.2",
      "pali": "vejjo āsiṁ susikkhito;"
    },
    {
      "id": "tha-ap181:1.3",
      "pali": "Āturānaṁ sadukkhānaṁ,"
    },
    {
      "id": "tha-ap181:1.4",
      "pali": "mahājanasukhāvaho."
    },
    {
      "id": "tha-ap181:2.1",
      "pali": "Byādhitaṁ samaṇaṁ disvā,"
    },
    {
      "id": "tha-ap181:2.2",
      "pali": "sīlavantaṁ mahājutiṁ;"
    },
    {
      "id": "tha-ap181:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap181:2.4",
      "pali": "bhesajjamadadiṁ tadā."
    },
    {
      "id": "tha-ap181:3.1",
      "pali": "Arogo āsi teneva,"
    },
    {
      "id": "tha-ap181:3.2",
      "pali": "samaṇo saṁvutindriyo;"
    },
    {
      "id": "tha-ap181:3.3",
      "pali": "Asoko nāma nāmena,"
    },
    {
      "id": "tha-ap181:3.4",
      "pali": "upaṭṭhāko vipassino."
    },
    {
      "id": "tha-ap181:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap181:4.2",
      "pali": "yaṁ osadhamadāsahaṁ;"
    },
    {
      "id": "tha-ap181:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap181:4.4",
      "pali": "bhesajjassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap181:5.1",
      "pali": "Ito ca aṭṭhame kappe,"
    },
    {
      "id": "tha-ap181:5.2",
      "pali": "sabbosadhasanāmako;"
    },
    {
      "id": "tha-ap181:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap181:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap181:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap181:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap181:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap181:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā tikicchako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap181:8.1",
      "pali": "Tikicchakattherassāpadānaṁ navamaṁ."
    }
  ]
}
