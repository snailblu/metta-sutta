{
  "uid": "tha-ap46",
  "title": "Sanniṭṭhāpakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap46:1.1",
      "pali": "“Araññe kuṭikaṁ katvā,"
    },
    {
      "id": "tha-ap46:1.2",
      "pali": "vasāmi pabbatantare;"
    },
    {
      "id": "tha-ap46:1.3",
      "pali": "Lābhālābhena santuṭṭho,"
    },
    {
      "id": "tha-ap46:1.4",
      "pali": "yasena ayasena ca."
    },
    {
      "id": "tha-ap46:2.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap46:2.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap46:2.3",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap46:2.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap46:3.1",
      "pali": "Upāgataṁ mahānāgaṁ,"
    },
    {
      "id": "tha-ap46:3.2",
      "pali": "jalajuttamanāmakaṁ;"
    },
    {
      "id": "tha-ap46:3.3",
      "pali": "Tiṇasantharaṁ paññāpetvā,"
    },
    {
      "id": "tha-ap46:3.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap46:4.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap46:4.2",
      "pali": "āmaṇḍaṁ pānīyañcahaṁ;"
    },
    {
      "id": "tha-ap46:4.3",
      "pali": "Adāsiṁ ujubhūtassa,"
    },
    {
      "id": "tha-ap46:4.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap46:5.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap46:5.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap46:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap46:5.4",
      "pali": "āmaṇḍassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap46:6.1",
      "pali": "Ekatālīsakappamhi,"
    },
    {
      "id": "tha-ap46:6.2",
      "pali": "eko āsiṁ arindamo;"
    },
    {
      "id": "tha-ap46:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap46:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap46:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap46:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap46:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap46:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā sanniṭṭhāpako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap46:9.1",
      "pali": "Sanniṭṭhāpakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
