{
  "uid": "ne27",
  "title": "Sampāta 8",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne27:1.1",
      "pali": "Tattha katamo vibhattihārasampāto?"
    },
    {
      "id": "ne27:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne27:2.2",
      "pali": "Kusalapakkho kusalapakkhena niddisitabbo."
    },
    {
      "id": "ne27:2.3",
      "pali": "Akusalapakkho akusalapakkhena niddisitabbo."
    },
    {
      "id": "ne27:2.4",
      "pali": "Niyutto vibhattihārasampāto."
    }
  ]
}
