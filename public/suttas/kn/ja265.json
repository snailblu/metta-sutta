{
  "uid": "ja265",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja265:1.1",
      "pali": "“Disvā khurappe dhanuveganunne,"
    },
    {
      "id": "ja265:1.2",
      "pali": "Khagge gahīte tikhiṇe teladhote;"
    },
    {
      "id": "ja265:1.3",
      "pali": "Tasmiṁ bhayasmiṁ maraṇe viyūḷhe,"
    },
    {
      "id": "ja265:1.4",
      "pali": "Kasmā nu te nāhu chambhitattaṁ”."
    },
    {
      "id": "ja265:2.1",
      "pali": "“Disvā khurappe dhanuveganunne,"
    },
    {
      "id": "ja265:2.2",
      "pali": "Khagge gahīte tikhiṇe teladhote;"
    },
    {
      "id": "ja265:2.3",
      "pali": "Tasmiṁ bhayasmiṁ maraṇe viyūḷhe,"
    },
    {
      "id": "ja265:2.4",
      "pali": "Vedaṁ alatthaṁ vipulaṁ uḷāraṁ."
    },
    {
      "id": "ja265:3.1",
      "pali": "So vedajāto ajjhabhaviṁ amitte,"
    },
    {
      "id": "ja265:3.2",
      "pali": "Pubbeva me jīvitamāsi cattaṁ;"
    },
    {
      "id": "ja265:3.3",
      "pali": "Na hi jīvite ālayaṁ kubbamāno,"
    },
    {
      "id": "ja265:3.4",
      "pali": "Sūro kayirā sūrakiccaṁ kadācī”ti."
    },
    {
      "id": "ja265:4.1",
      "pali": "Khurappajātakaṁ pañcamaṁ."
    }
  ]
}
