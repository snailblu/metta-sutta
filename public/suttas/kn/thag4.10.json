{
  "uid": "thag4.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.10:1.1",
      "pali": "“Dhammo have rakkhati dhammacāriṁ,"
    },
    {
      "id": "thag4.10:1.2",
      "pali": "Dhammo suciṇṇo sukhamāvahati;"
    },
    {
      "id": "thag4.10:1.3",
      "pali": "Esānisaṁso dhamme suciṇṇe,"
    },
    {
      "id": "thag4.10:1.4",
      "pali": "Na duggatiṁ gacchati dhammacārī."
    },
    {
      "id": "thag4.10:2.1",
      "pali": "Na hi dhammo adhammo ca,"
    },
    {
      "id": "thag4.10:2.2",
      "pali": "ubho samavipākino;"
    },
    {
      "id": "thag4.10:2.3",
      "pali": "Adhammo nirayaṁ neti,"
    },
    {
      "id": "thag4.10:2.4",
      "pali": "dhammo pāpeti suggatiṁ."
    },
    {
      "id": "thag4.10:3.1",
      "pali": "Tasmā hi dhammesu kareyya chandaṁ,"
    },
    {
      "id": "thag4.10:3.2",
      "pali": "Iti modamāno sugatena tādinā;"
    },
    {
      "id": "thag4.10:3.3",
      "pali": "Dhamme ṭhitā sugatavarassa sāvakā,"
    },
    {
      "id": "thag4.10:3.4",
      "pali": "Nīyanti dhīrā saraṇavaraggagāmino”."
    },
    {
      "id": "thag4.10:4.1",
      "pali": "“Vipphoṭito gaṇḍamūlo,"
    },
    {
      "id": "thag4.10:4.2",
      "pali": "Taṇhājālo samūhato;"
    },
    {
      "id": "thag4.10:4.3",
      "pali": "So khīṇasaṁsāro na catthi kiñcanaṁ,"
    },
    {
      "id": "thag4.10:4.4",
      "pali": "Cando yathā dosinā puṇṇamāsiyan”ti."
    },
    {
      "id": "thag4.10:4.5",
      "pali": "… Dhammiko thero …."
    }
  ]
}
