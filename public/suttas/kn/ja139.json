{
  "uid": "ja139",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja139:1.1",
      "pali": "“Akkhī bhinnā paṭo naṭṭho,"
    },
    {
      "id": "ja139:1.2",
      "pali": "sakhigehe ca bhaṇḍanaṁ;"
    },
    {
      "id": "ja139:1.3",
      "pali": "Ubhato paduṭṭhā kammantā,"
    },
    {
      "id": "ja139:1.4",
      "pali": "udakamhi thalamhi cā”ti."
    },
    {
      "id": "ja139:2.1",
      "pali": "Ubhatobhaṭṭhajātakaṁ navamaṁ."
    }
  ]
}
