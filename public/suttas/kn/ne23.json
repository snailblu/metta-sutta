{
  "uid": "ne23",
  "title": "Sampāta 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne23:1.1",
      "pali": "Tattha katamo padaṭṭhāno hārasampāto?"
    },
    {
      "id": "ne23:2.1",
      "pali": "“Tasmā rakkhitacittassa, sammāsaṅkappagocaro”ti gāthā."
    },
    {
      "id": "ne23:2.2",
      "pali": "“Tasmā rakkhitacittassā”ti tiṇṇaṁ sucaritānaṁ padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.3",
      "pali": "“Sammāsaṅkappagocaro”ti samathassa padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.4",
      "pali": "“Sammādiṭṭhipurekkhāro”ti vipassanāya padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.5",
      "pali": "“Ñatvāna udayabbayan”ti dassanabhūmiyā padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.6",
      "pali": "“Thinamiddhābhibhū bhikkhū”ti vīriyassa padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.7",
      "pali": "“Sabbā duggatiyo jahe”ti bhāvanāya padaṭṭhānaṁ."
    },
    {
      "id": "ne23:2.8",
      "pali": "Niyutto padaṭṭhāno hārasampāto."
    }
  ]
}
