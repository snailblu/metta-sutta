{
  "uid": "ja77",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja77:1.1",
      "pali": "“Usabhā rukkhā gāviyo gavā ca,"
    },
    {
      "id": "ja77:1.2",
      "pali": "Asso kaṁso siṅgālī ca kumbho;"
    },
    {
      "id": "ja77:1.3",
      "pali": "Pokkharaṇī ca apākacandanaṁ,"
    },
    {
      "id": "ja77:1.4",
      "pali": "Lābūni sīdanti silā plavan”ti."
    },
    {
      "id": "ja77:2.1",
      "pali": "Maṇḍūkiyo kaṇhasappe gilanti,"
    },
    {
      "id": "ja77:2.2",
      "pali": "Kākaṁ supaṇṇā parivārayanti;"
    },
    {
      "id": "ja77:2.3",
      "pali": "Tasā vakā eḷakānaṁ bhayāhi,"
    },
    {
      "id": "ja77:2.4",
      "pali": "Vipariyāso vattati nayidha matthīti."
    },
    {
      "id": "ja77:3.1",
      "pali": "Mahāsupinajātakaṁ sattamaṁ."
    }
  ]
}
