{
  "uid": "ja442",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja442:1.1",
      "pali": "“Bahussuto sutadhammosi saṅkha,"
    },
    {
      "id": "ja442:1.2",
      "pali": "Diṭṭhā tayā samaṇabrāhmaṇā ca;"
    },
    {
      "id": "ja442:1.3",
      "pali": "Athakkhaṇe dassayase vilāpaṁ,"
    },
    {
      "id": "ja442:1.4",
      "pali": "Añño nu ko te paṭimantako mayā”."
    },
    {
      "id": "ja442:2.1",
      "pali": "“Subbhū subhā suppaṭimukkakambu,"
    },
    {
      "id": "ja442:2.2",
      "pali": "Paggayha sovaṇṇamayāya pātiyā;"
    },
    {
      "id": "ja442:2.3",
      "pali": "‘Bhuñjassu bhattaṁ’ iti maṁ vadeti,"
    },
    {
      "id": "ja442:2.4",
      "pali": "Saddhāvittā"
    },
    {
      "id": "ja442:2.5",
      "pali": "Tamahaṁ noti brūmi”."
    },
    {
      "id": "ja442:3.1",
      "pali": "“Etādisaṁ brāhmaṇa disvāna yakkhaṁ,"
    },
    {
      "id": "ja442:3.2",
      "pali": "Puccheyya poso sukhamāsisāno;"
    },
    {
      "id": "ja442:3.3",
      "pali": "Uṭṭhehi naṁ pañjalikābhipuccha,"
    },
    {
      "id": "ja442:3.4",
      "pali": "Devī nusi tvaṁ uda mānusī nu”."
    },
    {
      "id": "ja442:4.1",
      "pali": "“Yaṁ tvaṁ sukhenābhisamekkhase maṁ,"
    },
    {
      "id": "ja442:4.2",
      "pali": "Bhuñjassu bhattaṁ iti maṁ vadesi;"
    },
    {
      "id": "ja442:4.3",
      "pali": "Pucchāmi taṁ nāri mahānubhāve,"
    },
    {
      "id": "ja442:4.4",
      "pali": "Devī nusi tvaṁ uda mānusī nu”."
    },
    {
      "id": "ja442:5.1",
      "pali": "“Devī ahaṁ saṅkha mahānubhāvā,"
    },
    {
      "id": "ja442:5.2",
      "pali": "Idhāgatā sāgaravārimajjhe;"
    },
    {
      "id": "ja442:5.3",
      "pali": "Anukampikā no ca paduṭṭhacittā,"
    },
    {
      "id": "ja442:5.4",
      "pali": "Taveva atthāya idhāgatāsmi."
    },
    {
      "id": "ja442:6.1",
      "pali": "Idhannapānaṁ sayanāsanañca,"
    },
    {
      "id": "ja442:6.2",
      "pali": "Yānāni nānāvividhāni saṅkha;"
    },
    {
      "id": "ja442:6.3",
      "pali": "Sabbassa tyāhaṁ paṭipādayāmi,"
    },
    {
      "id": "ja442:6.4",
      "pali": "Yaṁ kiñci tuyhaṁ manasābhipatthitaṁ”."
    },
    {
      "id": "ja442:7.1",
      "pali": "“Yaṁ kiñci yiṭṭhañca hutañca mayhaṁ,"
    },
    {
      "id": "ja442:7.2",
      "pali": "Sabbassa no issarā tvaṁ sugatte;"
    },
    {
      "id": "ja442:7.3",
      "pali": "Susoṇi subbhamu suvilaggamajjhe,"
    },
    {
      "id": "ja442:7.4",
      "pali": "Kissa me kammassa ayaṁ vipāko”."
    },
    {
      "id": "ja442:8.1",
      "pali": "“Ghamme pathe brāhmaṇa ekabhikkhuṁ,"
    },
    {
      "id": "ja442:8.2",
      "pali": "Ugghaṭṭapādaṁ tasitaṁ kilantaṁ;"
    },
    {
      "id": "ja442:8.3",
      "pali": "Paṭipādayī saṅkha upāhanāni,"
    },
    {
      "id": "ja442:8.4",
      "pali": "Sā dakkhiṇā kāmaduhā tavajja”."
    },
    {
      "id": "ja442:9.1",
      "pali": "“Sā hotu nāvā phalakūpapannā,"
    },
    {
      "id": "ja442:9.2",
      "pali": "Anavassutā erakavātayuttā;"
    },
    {
      "id": "ja442:9.3",
      "pali": "Aññassa yānassa na hettha bhūmi,"
    },
    {
      "id": "ja442:9.4",
      "pali": "Ajjeva maṁ moḷiniṁ pāpayassu”."
    },
    {
      "id": "ja442:10.1",
      "pali": "“Sā tattha vittā sumanā patītā,"
    },
    {
      "id": "ja442:10.2",
      "pali": "Nāvaṁ sucittaṁ abhinimminitvā;"
    },
    {
      "id": "ja442:10.3",
      "pali": "Ādāya saṅkhaṁ purisena saddhiṁ,"
    },
    {
      "id": "ja442:10.4",
      "pali": "Upānayī nagaraṁ sādhuramman”ti."
    },
    {
      "id": "ja442:11.1",
      "pali": "Saṅkhajātakaṁ catutthaṁ."
    }
  ]
}
