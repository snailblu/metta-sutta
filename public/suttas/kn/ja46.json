{
  "uid": "ja46",
  "title": "Atthakāmavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja46:1.1",
      "pali": "“Na ve anatthakusalena,"
    },
    {
      "id": "ja46:1.2",
      "pali": "atthacariyā sukhāvahā;"
    },
    {
      "id": "ja46:1.3",
      "pali": "Hāpeti atthaṁ dummedho,"
    },
    {
      "id": "ja46:1.4",
      "pali": "kapi ārāmiko yathā”ti."
    },
    {
      "id": "ja46:2.1",
      "pali": "Ārāmadūsakajātakaṁ chaṭṭhaṁ."
    }
  ]
}
