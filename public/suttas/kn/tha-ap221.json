{
  "uid": "tha-ap221",
  "title": "Sappidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap221:1.1",
      "pali": "“Nisinno pāsādavare,"
    },
    {
      "id": "tha-ap221:1.2",
      "pali": "nārīgaṇapurakkhato;"
    },
    {
      "id": "tha-ap221:1.3",
      "pali": "Byādhitaṁ samaṇaṁ disvā,"
    },
    {
      "id": "tha-ap221:1.4",
      "pali": "abhināmesahaṁ gharaṁ."
    },
    {
      "id": "tha-ap221:2.1",
      "pali": "Upaviṭṭhaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap221:2.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap221:2.3",
      "pali": "Sappitelaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap221:2.4",
      "pali": "siddhatthassa mahesino."
    },
    {
      "id": "tha-ap221:3.1",
      "pali": "Passaddhadarathaṁ disvā,"
    },
    {
      "id": "tha-ap221:3.2",
      "pali": "vippasannamukhindriyaṁ;"
    },
    {
      "id": "tha-ap221:3.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap221:3.4",
      "pali": "anusaṁsāvayiṁ pure."
    },
    {
      "id": "tha-ap221:4.1",
      "pali": "Disvā maṁ suppasannattaṁ,"
    },
    {
      "id": "tha-ap221:4.2",
      "pali": "iddhiyā pāramiṅgato;"
    },
    {
      "id": "tha-ap221:4.3",
      "pali": "Nabhaṁ abbhuggamī dhīro,"
    },
    {
      "id": "tha-ap221:4.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap221:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap221:5.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap221:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap221:5.4",
      "pali": "sappitelassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap221:6.1",
      "pali": "Ito sattarase kappe,"
    },
    {
      "id": "tha-ap221:6.2",
      "pali": "jutideva sanāmako;"
    },
    {
      "id": "tha-ap221:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap221:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap221:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap221:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap221:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap221:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā sappidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap221:9.1",
      "pali": "Sappidāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
