{
  "uid": "tha-ap112",
  "title": "Reṇupūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap112:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap112:1.2",
      "pali": "Sataraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap112:1.3",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap112:1.4",
      "pali": "Uḷurājaṁva pūritaṁ."
    },
    {
      "id": "tha-ap112:2.1",
      "pali": "Purakkhataṁ sāvakehi,"
    },
    {
      "id": "tha-ap112:2.2",
      "pali": "sāgareheva medaniṁ;"
    },
    {
      "id": "tha-ap112:2.3",
      "pali": "Nāgaṁ paggayha reṇūhi,"
    },
    {
      "id": "tha-ap112:2.4",
      "pali": "vipassissābhiropayiṁ."
    },
    {
      "id": "tha-ap112:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap112:3.2",
      "pali": "yaṁ reṇumabhiropayiṁ;"
    },
    {
      "id": "tha-ap112:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap112:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap112:4.1",
      "pali": "Paṇṇatālīsito kappe,"
    },
    {
      "id": "tha-ap112:4.2",
      "pali": "reṇu nāmāsi khattiyo;"
    },
    {
      "id": "tha-ap112:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap112:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap112:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap112:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap112:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap112:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā reṇupūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap112:7.1",
      "pali": "Reṇupūjakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap112:8.1",
      "pali": "Bhikkhadāyivaggo ekādasamo."
    },
    {
      "id": "tha-ap112:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap112:10.1",
      "pali": "Bhikkhadāyī ñāṇasaññī,"
    },
    {
      "id": "tha-ap112:10.2",
      "pali": "hatthiyo padapūjako;"
    },
    {
      "id": "tha-ap112:10.3",
      "pali": "Muṭṭhipupphī udakado,"
    },
    {
      "id": "tha-ap112:10.4",
      "pali": "naḷamāli upaṭṭhako;"
    },
    {
      "id": "tha-ap112:10.5",
      "pali": "Biḷālidāyī reṇu ca,"
    },
    {
      "id": "tha-ap112:10.6",
      "pali": "gāthāyo cha ca saṭṭhi ca."
    }
  ]
}
