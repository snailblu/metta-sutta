{
  "uid": "thag2.32",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.32:1.1",
      "pali": "“Aniccāni gahakāni,"
    },
    {
      "id": "thag2.32:1.2",
      "pali": "tattha tattha punappunaṁ;"
    },
    {
      "id": "thag2.32:1.3",
      "pali": "Gahakāraṁ gavesanto,"
    },
    {
      "id": "thag2.32:1.4",
      "pali": "dukkhā jāti punappunaṁ."
    },
    {
      "id": "thag2.32:2.1",
      "pali": "Gahakāraka diṭṭhosi,"
    },
    {
      "id": "thag2.32:2.2",
      "pali": "puna gehaṁ na kāhasi;"
    },
    {
      "id": "thag2.32:2.3",
      "pali": "Sabbā te phāsukā bhaggā,"
    },
    {
      "id": "thag2.32:2.4",
      "pali": "thūṇikā ca vidālitā;"
    },
    {
      "id": "thag2.32:2.5",
      "pali": "Vimariyādikataṁ cittaṁ,"
    },
    {
      "id": "thag2.32:2.6",
      "pali": "idheva vidhamissatī”ti."
    },
    {
      "id": "thag2.32:2.7",
      "pali": "… Sivako thero …."
    }
  ]
}
