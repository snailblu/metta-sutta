{
  "uid": "vv71",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv71:1.1",
      "pali": "“Uccamidaṁ maṇithūṇaṁ vimānaṁ,"
    },
    {
      "id": "vv71:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv71:1.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv71:2.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv71:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv71:2.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv71:3.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv71:3.2",
      "pali": "Ahosiṁ yavapālako;"
    },
    {
      "id": "vv71:3.3",
      "pali": "Addasaṁ virajaṁ bhikkhuṁ,"
    },
    {
      "id": "vv71:3.4",
      "pali": "Vippasannamanāvilaṁ."
    },
    {
      "id": "vv71:4.1",
      "pali": "Tassa adāsahaṁ bhāgaṁ,"
    },
    {
      "id": "vv71:4.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "vv71:4.3",
      "pali": "Kummāsapiṇḍaṁ datvāna,"
    },
    {
      "id": "vv71:4.4",
      "pali": "modāmi nandane vane."
    },
    {
      "id": "vv71:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv71:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv71:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv71:6.1",
      "pali": "Yavapālakavimānaṁ sattamaṁ."
    }
  ]
}
