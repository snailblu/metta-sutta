{
  "uid": "thag4.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.9:1.1",
      "pali": "“Jātarūpena sañchannā,"
    },
    {
      "id": "thag4.9:1.2",
      "pali": "dāsīgaṇapurakkhatā;"
    },
    {
      "id": "thag4.9:1.3",
      "pali": "Aṅkena puttamādāya,"
    },
    {
      "id": "thag4.9:1.4",
      "pali": "bhariyā maṁ upāgami."
    },
    {
      "id": "thag4.9:2.1",
      "pali": "Tañca disvāna āyantiṁ,"
    },
    {
      "id": "thag4.9:2.2",
      "pali": "sakaputtassa mātaraṁ;"
    },
    {
      "id": "thag4.9:2.3",
      "pali": "Alaṅkataṁ suvasanaṁ,"
    },
    {
      "id": "thag4.9:2.4",
      "pali": "maccupāsaṁva oḍḍitaṁ."
    },
    {
      "id": "thag4.9:3.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag4.9:3.2",
      "pali": "yoniso udapajjatha;"
    },
    {
      "id": "thag4.9:3.3",
      "pali": "Ādīnavo pāturahu,"
    },
    {
      "id": "thag4.9:3.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag4.9:4.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag4.9:4.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag4.9:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag4.9:4.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag4.9:4.5",
      "pali": "… Candano thero …."
    }
  ]
}
