{
  "uid": "thag2.37",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.37:1.1",
      "pali": "“Na tāva supituṁ hoti,"
    },
    {
      "id": "thag2.37:1.2",
      "pali": "ratti nakkhattamālinī;"
    },
    {
      "id": "thag2.37:1.3",
      "pali": "Paṭijaggitumevesā,"
    },
    {
      "id": "thag2.37:1.4",
      "pali": "ratti hoti vijānatā”."
    },
    {
      "id": "thag2.37:2.1",
      "pali": "“Hatthikkhandhāvapatitaṁ,"
    },
    {
      "id": "thag2.37:2.2",
      "pali": "kuñjaro ce anukkame;"
    },
    {
      "id": "thag2.37:2.3",
      "pali": "Saṅgāme me mataṁ seyyo,"
    },
    {
      "id": "thag2.37:2.4",
      "pali": "yañce jīve parājito”ti."
    },
    {
      "id": "thag2.37:2.5",
      "pali": "… Soṇo poṭiriyo thero …."
    }
  ]
}
