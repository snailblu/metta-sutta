{
  "uid": "vv17",
  "title": "Pīṭhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv17:1.1",
      "pali": "“Idaṁ vimānaṁ ruciraṁ pabhassaraṁ,"
    },
    {
      "id": "vv17:1.2",
      "pali": "Veḷuriyathambhaṁ satataṁ sunimmitaṁ;"
    },
    {
      "id": "vv17:1.3",
      "pali": "Suvaṇṇarukkhehi samantamotthataṁ,"
    },
    {
      "id": "vv17:1.4",
      "pali": "Ṭhānaṁ mamaṁ kammavipākasambhavaṁ."
    },
    {
      "id": "vv17:2.1",
      "pali": "Tatrūpapannā purimaccharā imā,"
    },
    {
      "id": "vv17:2.2",
      "pali": "Sataṁ sahassāni sakena kammunā;"
    },
    {
      "id": "vv17:2.3",
      "pali": "Tuvaṁsi ajjhupagatā yasassinī,"
    },
    {
      "id": "vv17:2.4",
      "pali": "Obhāsayaṁ tiṭṭhasi pubbadevatā."
    },
    {
      "id": "vv17:3.1",
      "pali": "Sasī adhiggayha yathā virocati,"
    },
    {
      "id": "vv17:3.2",
      "pali": "Nakkhattarājāriva tārakāgaṇaṁ;"
    },
    {
      "id": "vv17:3.3",
      "pali": "Tatheva tvaṁ accharāsaṅgaṇaṁ imaṁ,"
    },
    {
      "id": "vv17:3.4",
      "pali": "Daddallamānā yasasā virocasi."
    },
    {
      "id": "vv17:4.1",
      "pali": "Kuto nu āgamma anomadassane,"
    },
    {
      "id": "vv17:4.2",
      "pali": "Upapannā tvaṁ bhavanaṁ mamaṁ idaṁ;"
    },
    {
      "id": "vv17:4.3",
      "pali": "Brahmaṁva devā tidasā sahindakā,"
    },
    {
      "id": "vv17:4.4",
      "pali": "Sabbe na tappāmase dassanena tan”ti."
    },
    {
      "id": "vv17:5.1",
      "pali": "“Yametaṁ sakka anupucchase mamaṁ,"
    },
    {
      "id": "vv17:5.2",
      "pali": "‘Kuto cutā tvaṁ idha āgatā’ti;"
    },
    {
      "id": "vv17:5.3",
      "pali": "Bārāṇasī nāma puratthi kāsinaṁ,"
    },
    {
      "id": "vv17:5.4",
      "pali": "Tattha ahosiṁ pure kesakārikā."
    },
    {
      "id": "vv17:6.1",
      "pali": "Buddhe ca dhamme ca pasannamānasā,"
    },
    {
      "id": "vv17:6.2",
      "pali": "Saṅghe ca ekantagatā asaṁsayā;"
    },
    {
      "id": "vv17:6.3",
      "pali": "Akhaṇḍasikkhāpadā āgatapphalā,"
    },
    {
      "id": "vv17:6.4",
      "pali": "Sambodhidhamme niyatā anāmayā”ti."
    },
    {
      "id": "vv17:7.1",
      "pali": "“Tantyābhinandāmase svāgatañca te,"
    },
    {
      "id": "vv17:7.2",
      "pali": "Dhammena ca tvaṁ yasasā virocasi;"
    },
    {
      "id": "vv17:7.3",
      "pali": "Buddhe ca dhamme ca pasannamānase,"
    },
    {
      "id": "vv17:7.4",
      "pali": "Saṅghe ca ekantagate asaṁsaye;"
    },
    {
      "id": "vv17:7.5",
      "pali": "Akhaṇḍasikkhāpade āgatapphale,"
    },
    {
      "id": "vv17:7.6",
      "pali": "Sambodhidhamme niyate anāmaye”ti."
    },
    {
      "id": "vv17:8.1",
      "pali": "Kesakārīvimānaṁ sattarasamaṁ."
    },
    {
      "id": "vv17:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv17:10.1",
      "pali": "Pañca pīṭhā tayo nāvā,"
    },
    {
      "id": "vv17:10.2",
      "pali": "dīpatiladakkhiṇā dve;"
    },
    {
      "id": "vv17:10.3",
      "pali": "Pati dve suṇisā uttarā,"
    },
    {
      "id": "vv17:10.4",
      "pali": "sirimā kesakārikā;"
    },
    {
      "id": "vv17:10.5",
      "pali": "Vaggo tena pavuccatīti."
    },
    {
      "id": "vv17:11.1",
      "pali": "Itthivimāne paṭhamo vaggo."
    }
  ]
}
