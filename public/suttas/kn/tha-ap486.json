{
  "uid": "tha-ap486",
  "title": "4 Ñāṇathavikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap486:1.1",
      "pali": "“Dakkhiṇe himavantassa,"
    },
    {
      "id": "tha-ap486:1.2",
      "pali": "sukato assamo mama;"
    },
    {
      "id": "tha-ap486:1.3",
      "pali": "Uttamatthaṁ gavesanto,"
    },
    {
      "id": "tha-ap486:1.4",
      "pali": "vasāmi vipine tadā."
    },
    {
      "id": "tha-ap486:2.1",
      "pali": "Lābhālābhena santuṭṭho,"
    },
    {
      "id": "tha-ap486:2.2",
      "pali": "mūlena ca phalena ca;"
    },
    {
      "id": "tha-ap486:2.3",
      "pali": "Anvesanto ācariyaṁ,"
    },
    {
      "id": "tha-ap486:2.4",
      "pali": "vasāmi ekako ahaṁ."
    },
    {
      "id": "tha-ap486:3.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap486:3.2",
      "pali": "loke uppajji tāvade;"
    },
    {
      "id": "tha-ap486:3.3",
      "pali": "Catusaccaṁ pakāseti,"
    },
    {
      "id": "tha-ap486:3.4",
      "pali": "uddharanto mahājanaṁ."
    },
    {
      "id": "tha-ap486:4.1",
      "pali": "Nāhaṁ suṇomi sambuddhaṁ,"
    },
    {
      "id": "tha-ap486:4.2",
      "pali": "napi me koci saṁsati;"
    },
    {
      "id": "tha-ap486:4.3",
      "pali": "Aṭṭhavasse atikkante,"
    },
    {
      "id": "tha-ap486:4.4",
      "pali": "assosiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap486:5.1",
      "pali": "Aggidāruṁ nīharitvā,"
    },
    {
      "id": "tha-ap486:5.2",
      "pali": "sammajjitvāna assamaṁ;"
    },
    {
      "id": "tha-ap486:5.3",
      "pali": "Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap486:5.4",
      "pali": "nikkhamiṁ vipinā ahaṁ."
    },
    {
      "id": "tha-ap486:6.1",
      "pali": "Ekarattiṁ vasantohaṁ,"
    },
    {
      "id": "tha-ap486:6.2",
      "pali": "gāmesu nigamesu ca;"
    },
    {
      "id": "tha-ap486:6.3",
      "pali": "Anupubbena candavatiṁ,"
    },
    {
      "id": "tha-ap486:6.4",
      "pali": "tadāhaṁ upasaṅkamiṁ."
    },
    {
      "id": "tha-ap486:7.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "tha-ap486:7.2",
      "pali": "sumedho lokanāyako;"
    },
    {
      "id": "tha-ap486:7.3",
      "pali": "Uddharanto bahū satte,"
    },
    {
      "id": "tha-ap486:7.4",
      "pali": "deseti amataṁ padaṁ."
    },
    {
      "id": "tha-ap486:8.1",
      "pali": "Janakāyamatikkamma,"
    },
    {
      "id": "tha-ap486:8.2",
      "pali": "vanditvā jinasāgaraṁ;"
    },
    {
      "id": "tha-ap486:8.3",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "tha-ap486:8.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap486:9.1",
      "pali": "‘Tuvaṁ satthā ca ketu ca,"
    },
    {
      "id": "tha-ap486:9.2",
      "pali": "dhajo yūpo ca pāṇinaṁ;"
    },
    {
      "id": "tha-ap486:9.3",
      "pali": "Parāyaṇo patiṭṭhā ca,"
    },
    {
      "id": "tha-ap486:9.4",
      "pali": "dīpo ca dvipaduttamo."
    },
    {
      "id": "tha-ap486:10.1",
      "pali": "Ekavīsatimaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap486:11.1",
      "pali": "Nepuñño dassane vīro,"
    },
    {
      "id": "tha-ap486:11.2",
      "pali": "tāresi janataṁ tuvaṁ;"
    },
    {
      "id": "tha-ap486:11.3",
      "pali": "Natthañño tārako loke,"
    },
    {
      "id": "tha-ap486:11.4",
      "pali": "tavuttaritaro mune."
    },
    {
      "id": "tha-ap486:12.1",
      "pali": "Sakkā theve kusaggena,"
    },
    {
      "id": "tha-ap486:12.2",
      "pali": "pametuṁ sāgaruttame;"
    },
    {
      "id": "tha-ap486:12.3",
      "pali": "Na tveva tava sabbaññu,"
    },
    {
      "id": "tha-ap486:12.4",
      "pali": "ñāṇaṁ sakkā pametave."
    },
    {
      "id": "tha-ap486:13.1",
      "pali": "Tuladaṇḍe ṭhapetvāna,"
    },
    {
      "id": "tha-ap486:13.2",
      "pali": "mahiṁ sakkā dharetave;"
    },
    {
      "id": "tha-ap486:13.3",
      "pali": "Na tveva tava paññāya,"
    },
    {
      "id": "tha-ap486:13.4",
      "pali": "pamāṇamatthi cakkhuma."
    },
    {
      "id": "tha-ap486:14.1",
      "pali": "Ākāso minituṁ sakkā,"
    },
    {
      "id": "tha-ap486:14.2",
      "pali": "rajjuyā aṅgulena vā;"
    },
    {
      "id": "tha-ap486:14.3",
      "pali": "Na tveva tava sabbaññu,"
    },
    {
      "id": "tha-ap486:14.4",
      "pali": "sīlaṁ sakkā pametave."
    },
    {
      "id": "tha-ap486:15.1",
      "pali": "Mahāsamudde udakaṁ,"
    },
    {
      "id": "tha-ap486:15.2",
      "pali": "ākāso ca vasundharā;"
    },
    {
      "id": "tha-ap486:15.3",
      "pali": "Parimeyyāni etāni,"
    },
    {
      "id": "tha-ap486:15.4",
      "pali": "appameyyosi cakkhuma’."
    },
    {
      "id": "tha-ap486:16.1",
      "pali": "Chahi gāthāhi sabbaññuṁ,"
    },
    {
      "id": "tha-ap486:16.2",
      "pali": "kittayitvā mahāyasaṁ;"
    },
    {
      "id": "tha-ap486:16.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap486:16.4",
      "pali": "tuṇhī aṭṭhāsahaṁ tadā."
    },
    {
      "id": "tha-ap486:17.1",
      "pali": "Yaṁ vadanti sumedhoti,"
    },
    {
      "id": "tha-ap486:17.2",
      "pali": "bhūripaññaṁ sumedhasaṁ;"
    },
    {
      "id": "tha-ap486:17.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap486:17.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap486:18.1",
      "pali": "‘Yo me ñāṇaṁ pakittesi,"
    },
    {
      "id": "tha-ap486:18.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap486:18.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap486:18.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap486:19.1",
      "pali": "Sattasattati kappāni,"
    },
    {
      "id": "tha-ap486:19.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap486:19.3",
      "pali": "Sahassakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap486:19.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap486:20.1",
      "pali": "Anekasatakkhattuñca,"
    },
    {
      "id": "tha-ap486:20.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap486:20.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap486:20.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap486:21.1",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap486:21.2",
      "pali": "puññakammasamāhito;"
    },
    {
      "id": "tha-ap486:21.3",
      "pali": "Anūnamanasaṅkappo,"
    },
    {
      "id": "tha-ap486:21.4",
      "pali": "tikkhapañño bhavissati’."
    },
    {
      "id": "tha-ap486:22.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap486:22.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap486:22.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap486:22.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap486:23.1",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap486:23.2",
      "pali": "pabbajissatikiñcano;"
    },
    {
      "id": "tha-ap486:23.3",
      "pali": "Jātiyā sattavassena,"
    },
    {
      "id": "tha-ap486:23.4",
      "pali": "arahattaṁ phusissati."
    },
    {
      "id": "tha-ap486:24.1",
      "pali": "Yato sarāmi attānaṁ,"
    },
    {
      "id": "tha-ap486:24.2",
      "pali": "yato pattosmi sāsanaṁ;"
    },
    {
      "id": "tha-ap486:24.3",
      "pali": "Etthantare na jānāmi,"
    },
    {
      "id": "tha-ap486:24.4",
      "pali": "cetanaṁ amanoramaṁ."
    },
    {
      "id": "tha-ap486:25.1",
      "pali": "Saṁsaritvā bhave sabbe,"
    },
    {
      "id": "tha-ap486:25.2",
      "pali": "sampattānubhaviṁ ahaṁ;"
    },
    {
      "id": "tha-ap486:25.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap486:25.4",
      "pali": "phalaṁ ñāṇassa thomane."
    },
    {
      "id": "tha-ap486:26.1",
      "pali": "Tiyaggī nibbutā mayhaṁ,"
    },
    {
      "id": "tha-ap486:26.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap486:26.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap486:26.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap486:27.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap486:27.2",
      "pali": "yaṁ ñāṇamathaviṁ ahaṁ;"
    },
    {
      "id": "tha-ap486:27.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap486:27.4",
      "pali": "phalaṁ ñāṇassa thomane."
    },
    {
      "id": "tha-ap486:28.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap486:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap486:28.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap486:29.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap486:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap486:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap486:30.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap486:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap486:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap486:31.1",
      "pali": "Itthaṁ sudaṁ āyasmā ñāṇathaviko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap486:32.1",
      "pali": "Ñāṇathavikattherassāpadānaṁ catutthaṁ."
    }
  ]
}
