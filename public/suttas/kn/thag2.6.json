{
  "uid": "thag2.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.6:1.1",
      "pali": "“Yadāhaṁ dhammamassosiṁ,"
    },
    {
      "id": "thag2.6:1.2",
      "pali": "bhāsamānassa satthuno;"
    },
    {
      "id": "thag2.6:1.3",
      "pali": "Na kaṅkhamabhijānāmi,"
    },
    {
      "id": "thag2.6:1.4",
      "pali": "sabbaññūaparājite."
    },
    {
      "id": "thag2.6:2.1",
      "pali": "Satthavāhe mahāvīre,"
    },
    {
      "id": "thag2.6:2.2",
      "pali": "sārathīnaṁ varuttame;"
    },
    {
      "id": "thag2.6:2.3",
      "pali": "Magge paṭipadāyaṁ vā,"
    },
    {
      "id": "thag2.6:2.4",
      "pali": "kaṅkhā mayhaṁ na vijjatī”ti."
    },
    {
      "id": "thag2.6:2.5",
      "pali": "… Meḷajino thero …."
    }
  ]
}
