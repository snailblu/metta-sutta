{
  "uid": "tha-ap404",
  "title": "Puṇṇakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap404:1.1",
      "pali": "“Pabbhārakūṭaṁ nissāya,"
    },
    {
      "id": "tha-ap404:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap404:1.3",
      "pali": "Ābādhiko ca so buddho,"
    },
    {
      "id": "tha-ap404:1.4",
      "pali": "vasati pabbatantare."
    },
    {
      "id": "tha-ap404:2.1",
      "pali": "Mama assamasāmantā,"
    },
    {
      "id": "tha-ap404:2.2",
      "pali": "panādo āsi tāvade;"
    },
    {
      "id": "tha-ap404:2.3",
      "pali": "Buddhe nibbāyamānamhi,"
    },
    {
      "id": "tha-ap404:2.4",
      "pali": "āloko udapajjatha."
    },
    {
      "id": "tha-ap404:3.1",
      "pali": "Yāvatā vanasaṇḍasmiṁ,"
    },
    {
      "id": "tha-ap404:3.2",
      "pali": "acchakokataracchakā;"
    },
    {
      "id": "tha-ap404:3.3",
      "pali": "Vāḷā ca kesarī sabbe,"
    },
    {
      "id": "tha-ap404:3.4",
      "pali": "abhigajjiṁsu tāvade."
    },
    {
      "id": "tha-ap404:4.1",
      "pali": "Uppātaṁ tamahaṁ disvā,"
    },
    {
      "id": "tha-ap404:4.2",
      "pali": "pabbhāraṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap404:4.3",
      "pali": "Tatthaddassāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap404:4.4",
      "pali": "nibbutaṁ aparājitaṁ."
    },
    {
      "id": "tha-ap404:5.1",
      "pali": "Suphullaṁ sālarājaṁva,"
    },
    {
      "id": "tha-ap404:5.2",
      "pali": "sataraṁsiṁva uggataṁ;"
    },
    {
      "id": "tha-ap404:5.3",
      "pali": "Vītaccikaṁva aṅgāraṁ,"
    },
    {
      "id": "tha-ap404:5.4",
      "pali": "nibbutaṁ aparājitaṁ."
    },
    {
      "id": "tha-ap404:6.1",
      "pali": "Tiṇaṁ kaṭṭhañca pūretvā,"
    },
    {
      "id": "tha-ap404:6.2",
      "pali": "citakaṁ tatthakāsahaṁ;"
    },
    {
      "id": "tha-ap404:6.3",
      "pali": "Citakaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap404:6.4",
      "pali": "sarīraṁ jhāpayiṁ ahaṁ."
    },
    {
      "id": "tha-ap404:7.1",
      "pali": "Sarīraṁ jhāpayitvāna,"
    },
    {
      "id": "tha-ap404:7.2",
      "pali": "gandhatoyaṁ samokiriṁ;"
    },
    {
      "id": "tha-ap404:7.3",
      "pali": "Antalikkhe ṭhito yakkho,"
    },
    {
      "id": "tha-ap404:7.4",
      "pali": "nāmamaggahi tāvade."
    },
    {
      "id": "tha-ap404:8.1",
      "pali": "‘Yaṁ pūritaṁ tayā kiccaṁ,"
    },
    {
      "id": "tha-ap404:8.2",
      "pali": "sayambhussa mahesino;"
    },
    {
      "id": "tha-ap404:8.3",
      "pali": "Puṇṇako nāma nāmena,"
    },
    {
      "id": "tha-ap404:8.4",
      "pali": "sadā hohi tuvaṁ mune’."
    },
    {
      "id": "tha-ap404:9.1",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap404:9.2",
      "pali": "devalokaṁ agacchahaṁ;"
    },
    {
      "id": "tha-ap404:9.3",
      "pali": "Tattha dibbamayo gandho,"
    },
    {
      "id": "tha-ap404:9.4",
      "pali": "antalikkhā pavassati."
    },
    {
      "id": "tha-ap404:10.1",
      "pali": "Tatrāpi nāmadheyyaṁ me,"
    },
    {
      "id": "tha-ap404:10.2",
      "pali": "puṇṇakoti ahū tadā;"
    },
    {
      "id": "tha-ap404:10.3",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap404:10.4",
      "pali": "saṅkappaṁ pūrayāmahaṁ."
    },
    {
      "id": "tha-ap404:11.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap404:11.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap404:11.3",
      "pali": "Idhāpi puṇṇako nāma,"
    },
    {
      "id": "tha-ap404:11.4",
      "pali": "nāmadheyyaṁ pakāsati."
    },
    {
      "id": "tha-ap404:12.1",
      "pali": "Tosayitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap404:12.2",
      "pali": "gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap404:12.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap404:12.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap404:13.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap404:13.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap404:13.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap404:13.4",
      "pali": "tanukiccassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap404:14.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap404:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap404:14.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap404:15.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap404:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap404:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap404:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap404:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap404:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap404:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā puṇṇako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap404:18.1",
      "pali": "Puṇṇakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
