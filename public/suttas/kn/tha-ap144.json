{
  "uid": "tha-ap144",
  "title": "Thambhāropakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap144:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap144:1.2",
      "pali": "dhammadassīnarāsabhe;"
    },
    {
      "id": "tha-ap144:1.3",
      "pali": "Āropesiṁ dhajatthambhaṁ,"
    },
    {
      "id": "tha-ap144:1.4",
      "pali": "buddhaseṭṭhassa cetiye."
    },
    {
      "id": "tha-ap144:2.1",
      "pali": "Nisseṇiṁ māpayitvāna,"
    },
    {
      "id": "tha-ap144:2.2",
      "pali": "thūpaseṭṭhaṁ samāruhiṁ;"
    },
    {
      "id": "tha-ap144:2.3",
      "pali": "Jātipupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap144:2.4",
      "pali": "thūpamhi abhiropayiṁ."
    },
    {
      "id": "tha-ap144:3.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap144:3.2",
      "pali": "aho no satthu sampadā;"
    },
    {
      "id": "tha-ap144:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap144:3.4",
      "pali": "thūpapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap144:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap144:4.2",
      "pali": "thūpasīkhasanāmakā;"
    },
    {
      "id": "tha-ap144:4.3",
      "pali": "Soḷasāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap144:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap144:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap144:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap144:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap144:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā thambhāropako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap144:7.1",
      "pali": "Thambhāropakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
