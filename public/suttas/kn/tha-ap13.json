{
  "uid": "tha-ap13",
  "title": "Sīhāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap13:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap13:1.2",
      "pali": "siddhatthe dvipaduttame;"
    },
    {
      "id": "tha-ap13:1.3",
      "pali": "Vitthārike pāvacane,"
    },
    {
      "id": "tha-ap13:1.4",
      "pali": "bāhujaññamhi sāsane."
    },
    {
      "id": "tha-ap13:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap13:2.2",
      "pali": "sīhāsanamakāsahaṁ;"
    },
    {
      "id": "tha-ap13:2.3",
      "pali": "Sīhāsanaṁ karitvāna,"
    },
    {
      "id": "tha-ap13:2.4",
      "pali": "pādapīṭhamakāsahaṁ."
    },
    {
      "id": "tha-ap13:3.1",
      "pali": "Sīhāsane ca vassante,"
    },
    {
      "id": "tha-ap13:3.2",
      "pali": "gharaṁ tattha akāsahaṁ;"
    },
    {
      "id": "tha-ap13:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap13:3.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap13:4.1",
      "pali": "Āyāmena catubbīsa-"
    },
    {
      "id": "tha-ap13:4.2",
      "pali": "yojanaṁ āsi tāvade;"
    },
    {
      "id": "tha-ap13:4.3",
      "pali": "Vimānaṁ sukataṁ mayhaṁ,"
    },
    {
      "id": "tha-ap13:4.4",
      "pali": "vitthārena catuddasa."
    },
    {
      "id": "tha-ap13:5.1",
      "pali": "Sataṁ kaññāsahassāni,"
    },
    {
      "id": "tha-ap13:5.2",
      "pali": "parivārenti maṁ sadā;"
    },
    {
      "id": "tha-ap13:5.3",
      "pali": "Soṇṇamayañca pallaṅkaṁ,"
    },
    {
      "id": "tha-ap13:5.4",
      "pali": "byamhe āsi sunimmitaṁ."
    },
    {
      "id": "tha-ap13:6.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap13:6.2",
      "pali": "dibbayānaṁ upaṭṭhitaṁ;"
    },
    {
      "id": "tha-ap13:6.3",
      "pali": "Pāsādā sivikā ceva,"
    },
    {
      "id": "tha-ap13:6.4",
      "pali": "nibbattanti yadicchakaṁ."
    },
    {
      "id": "tha-ap13:7.1",
      "pali": "Maṇimayā ca pallaṅkā,"
    },
    {
      "id": "tha-ap13:7.2",
      "pali": "aññe sāramayā bahū;"
    },
    {
      "id": "tha-ap13:7.3",
      "pali": "Nibbattanti mamaṁ sabbe,"
    },
    {
      "id": "tha-ap13:7.4",
      "pali": "sīhāsanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap13:8.1",
      "pali": "Soṇṇamayā rūpimayā,"
    },
    {
      "id": "tha-ap13:8.2",
      "pali": "phalikāveḷuriyāmayā;"
    },
    {
      "id": "tha-ap13:8.3",
      "pali": "Pādukā abhirūhāmi,"
    },
    {
      "id": "tha-ap13:8.4",
      "pali": "pādapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap13:9.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap13:9.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap13:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap13:9.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap13:10.1",
      "pali": "Tesattatimhito kappe,"
    },
    {
      "id": "tha-ap13:10.2",
      "pali": "indanāmā tayo janā;"
    },
    {
      "id": "tha-ap13:10.3",
      "pali": "Dvesattatimhito kappe,"
    },
    {
      "id": "tha-ap13:10.4",
      "pali": "tayo sumananāmakā."
    },
    {
      "id": "tha-ap13:11.1",
      "pali": "Samasattatito kappe,"
    },
    {
      "id": "tha-ap13:11.2",
      "pali": "tayo varuṇanāmakā;"
    },
    {
      "id": "tha-ap13:11.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap13:11.4",
      "pali": "catudīpamhi issarā."
    },
    {
      "id": "tha-ap13:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap13:12.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap13:12.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap13:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap13:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā sīhāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap13:14.1",
      "pali": "Sīhāsanadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
