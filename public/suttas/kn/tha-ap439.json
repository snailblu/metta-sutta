{
  "uid": "tha-ap439",
  "title": "Ambāṭakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap439:1.1",
      "pali": "“Vipine buddhaṁ disvāna,"
    },
    {
      "id": "tha-ap439:1.2",
      "pali": "sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap439:1.3",
      "pali": "Ambāṭakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap439:1.4",
      "pali": "sayambhussa adāsahaṁ."
    },
    {
      "id": "tha-ap439:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap439:2.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap439:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap439:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap439:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap439:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap439:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap439:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap439:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap439:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap439:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap439:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap439:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap439:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambāṭakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap439:7.1",
      "pali": "Ambāṭakadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
