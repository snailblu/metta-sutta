{
  "uid": "iti76",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti76:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti76:2.1",
      "pali": "“Tīṇimāni, bhikkhave, sukhāni patthayamāno sīlaṁ rakkheyya paṇḍito."
    },
    {
      "id": "iti76:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti76:2.3",
      "pali": "Pasaṁsā me āgacchatūti sīlaṁ rakkheyya paṇḍito, bhogā me uppajjantūti sīlaṁ rakkheyya paṇḍito, kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjissāmīti sīlaṁ rakkheyya paṇḍito."
    },
    {
      "id": "iti76:2.4",
      "pali": "Imāni kho, bhikkhave, tīṇi sukhāni patthayamāno sīlaṁ rakkheyya paṇḍito”ti."
    },
    {
      "id": "iti76:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti76:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti76:3.1",
      "pali": "“Sīlaṁ rakkheyya medhāvī,"
    },
    {
      "id": "iti76:3.2",
      "pali": "patthayāno tayo sukhe;"
    },
    {
      "id": "iti76:3.3",
      "pali": "Pasaṁsaṁ vittalābhañca,"
    },
    {
      "id": "iti76:3.4",
      "pali": "pecca sagge pamodanaṁ."
    },
    {
      "id": "iti76:4.1",
      "pali": "Akarontopi ce pāpaṁ,"
    },
    {
      "id": "iti76:4.2",
      "pali": "karontamupasevati;"
    },
    {
      "id": "iti76:4.3",
      "pali": "Saṅkiyo hoti pāpasmiṁ,"
    },
    {
      "id": "iti76:4.4",
      "pali": "avaṇṇo cassa rūhati."
    },
    {
      "id": "iti76:5.1",
      "pali": "Yādisaṁ kurute mittaṁ,"
    },
    {
      "id": "iti76:5.2",
      "pali": "yādisaṁ cūpasevati;"
    },
    {
      "id": "iti76:5.3",
      "pali": "Sa ve tādisako hoti,"
    },
    {
      "id": "iti76:5.4",
      "pali": "sahavāso hi tādiso."
    },
    {
      "id": "iti76:6.1",
      "pali": "Sevamāno sevamānaṁ,"
    },
    {
      "id": "iti76:6.2",
      "pali": "samphuṭṭho samphusaṁ paraṁ;"
    },
    {
      "id": "iti76:6.3",
      "pali": "Saro diddho kalāpaṁva,"
    },
    {
      "id": "iti76:6.4",
      "pali": "alittamupalimpati;"
    },
    {
      "id": "iti76:6.5",
      "pali": "Upalepabhayā dhīro,"
    },
    {
      "id": "iti76:6.6",
      "pali": "neva pāpasakhā siyā."
    },
    {
      "id": "iti76:7.1",
      "pali": "Pūtimacchaṁ kusaggena,"
    },
    {
      "id": "iti76:7.2",
      "pali": "yo naro upanayhati;"
    },
    {
      "id": "iti76:7.3",
      "pali": "Kusāpi pūti vāyanti,"
    },
    {
      "id": "iti76:7.4",
      "pali": "evaṁ bālūpasevanā."
    },
    {
      "id": "iti76:8.1",
      "pali": "Tagarañca palāsena,"
    },
    {
      "id": "iti76:8.2",
      "pali": "yo naro upanayhati;"
    },
    {
      "id": "iti76:8.3",
      "pali": "Pattāpi surabhi vāyanti,"
    },
    {
      "id": "iti76:8.4",
      "pali": "evaṁ dhīrūpasevanā."
    },
    {
      "id": "iti76:9.1",
      "pali": "Tasmā pattapuṭasseva,"
    },
    {
      "id": "iti76:9.2",
      "pali": "ñatvā sampākamattano;"
    },
    {
      "id": "iti76:9.3",
      "pali": "Asante nupaseveyya,"
    },
    {
      "id": "iti76:9.4",
      "pali": "sante seveyya paṇḍito;"
    },
    {
      "id": "iti76:9.5",
      "pali": "Asanto nirayaṁ nenti,"
    },
    {
      "id": "iti76:9.6",
      "pali": "santo pāpenti suggatin”ti."
    },
    {
      "id": "iti76:10.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti76:10.2",
      "pali": "Sattamaṁ."
    }
  ]
}
