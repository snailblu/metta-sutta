{
  "uid": "iti61",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti61:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti61:2.1",
      "pali": "“Tīṇimāni, bhikkhave, cakkhūni."
    },
    {
      "id": "iti61:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti61:2.3",
      "pali": "Maṁsacakkhu, dibbacakkhu, paññācakkhu—"
    },
    {
      "id": "iti61:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi cakkhūnī”ti."
    },
    {
      "id": "iti61:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti61:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti61:3.1",
      "pali": "“Maṁsacakkhu dibbacakkhu,"
    },
    {
      "id": "iti61:3.2",
      "pali": "paññācakkhu anuttaraṁ;"
    },
    {
      "id": "iti61:3.3",
      "pali": "Etāni tīṇi cakkhūni,"
    },
    {
      "id": "iti61:3.4",
      "pali": "akkhāsi purisuttamo."
    },
    {
      "id": "iti61:4.1",
      "pali": "Maṁsacakkhussa uppādo,"
    },
    {
      "id": "iti61:4.2",
      "pali": "maggo dibbassa cakkhuno;"
    },
    {
      "id": "iti61:4.3",
      "pali": "Yato ñāṇaṁ udapādi,"
    },
    {
      "id": "iti61:4.4",
      "pali": "paññācakkhu anuttaraṁ;"
    },
    {
      "id": "iti61:4.5",
      "pali": "Yassa cakkhussa paṭilābhā,"
    },
    {
      "id": "iti61:4.6",
      "pali": "sabbadukkhā pamuccatī”ti."
    },
    {
      "id": "iti61:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti61:5.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
