{
  "uid": "tha-ap323",
  "title": "1 Umāpupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap323:1.1",
      "pali": "“Samāhitaṁ samāpannaṁ,"
    },
    {
      "id": "tha-ap323:1.2",
      "pali": "siddhatthamaparājitaṁ;"
    },
    {
      "id": "tha-ap323:1.3",
      "pali": "Samādhinā upaviṭṭhaṁ,"
    },
    {
      "id": "tha-ap323:1.4",
      "pali": "addasāhaṁ naruttamaṁ."
    },
    {
      "id": "tha-ap323:2.1",
      "pali": "Umāpupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap323:2.2",
      "pali": "buddhassa abhiropayiṁ;"
    },
    {
      "id": "tha-ap323:2.3",
      "pali": "Sabbapupphā ekasīsā,"
    },
    {
      "id": "tha-ap323:2.4",
      "pali": "uddhaṁvaṇṭā adhomukhā."
    },
    {
      "id": "tha-ap323:3.1",
      "pali": "Sucittā viya tiṭṭhante,"
    },
    {
      "id": "tha-ap323:3.2",
      "pali": "ākāse pupphasantharā;"
    },
    {
      "id": "tha-ap323:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap323:3.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap323:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap323:4.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap323:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap323:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap323:5.1",
      "pali": "Pañcapaññāsito kappe,"
    },
    {
      "id": "tha-ap323:5.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap323:5.3",
      "pali": "Samantachadano nāma,"
    },
    {
      "id": "tha-ap323:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap323:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap323:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap323:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap323:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap323:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā umāpupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap323:8.1",
      "pali": "Umāpupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
