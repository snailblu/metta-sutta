{
  "uid": "tha-ap263",
  "title": "Ākāsukkhipiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap263:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ siddhatthaṁ,"
    },
    {
      "id": "tha-ap263:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap263:1.3",
      "pali": "Jalajagge duve gayha,"
    },
    {
      "id": "tha-ap263:1.4",
      "pali": "Upāgacchiṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap263:2.1",
      "pali": "Ekañca pupphaṁ pādesu,"
    },
    {
      "id": "tha-ap263:2.2",
      "pali": "buddhaseṭṭhassa nikkhipiṁ;"
    },
    {
      "id": "tha-ap263:2.3",
      "pali": "Ekañca pupphaṁ paggayha,"
    },
    {
      "id": "tha-ap263:2.4",
      "pali": "ākāse ukkhipiṁ ahaṁ."
    },
    {
      "id": "tha-ap263:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap263:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap263:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap263:3.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap263:4.1",
      "pali": "Ito chattiṁsakappamhi,"
    },
    {
      "id": "tha-ap263:4.2",
      "pali": "eko āsiṁ mahīpati;"
    },
    {
      "id": "tha-ap263:4.3",
      "pali": "Antalikkhakaro nāma,"
    },
    {
      "id": "tha-ap263:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap263:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap263:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap263:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap263:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap263:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ākāsukkhipiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap263:7.1",
      "pali": "Ākāsukkhipiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
