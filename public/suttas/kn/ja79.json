{
  "uid": "ja79",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja79:1.1",
      "pali": "“Yato viluttā ca hatā ca gāvo,"
    },
    {
      "id": "ja79:1.2",
      "pali": "Daḍḍhāni gehāni jano ca nīto;"
    },
    {
      "id": "ja79:1.3",
      "pali": "Athāgamā puttahatāya putto,"
    },
    {
      "id": "ja79:1.4",
      "pali": "Kharassaraṁ ḍiṇḍimaṁ vādayanto”ti."
    },
    {
      "id": "ja79:2.1",
      "pali": "Kharassarajātakaṁ navamaṁ."
    }
  ]
}
