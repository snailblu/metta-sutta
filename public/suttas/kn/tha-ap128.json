{
  "uid": "tha-ap128",
  "title": "Kusumāsaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap128:1.1",
      "pali": "“Nagare dhaññavatiyā,"
    },
    {
      "id": "tha-ap128:1.2",
      "pali": "ahosiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap128:1.3",
      "pali": "Lakkhaṇe itihāse ca,"
    },
    {
      "id": "tha-ap128:1.4",
      "pali": "sanighaṇḍusakeṭubhe."
    },
    {
      "id": "tha-ap128:2.1",
      "pali": "Padako veyyākaraṇo,"
    },
    {
      "id": "tha-ap128:2.2",
      "pali": "nimittakovido ahaṁ;"
    },
    {
      "id": "tha-ap128:2.3",
      "pali": "Mante ca sisse vācesiṁ,"
    },
    {
      "id": "tha-ap128:2.4",
      "pali": "tiṇṇaṁ vedāna pāragū."
    },
    {
      "id": "tha-ap128:3.1",
      "pali": "Pañca uppalahatthāni,"
    },
    {
      "id": "tha-ap128:3.2",
      "pali": "piṭṭhiyaṁ ṭhapitāni me;"
    },
    {
      "id": "tha-ap128:3.3",
      "pali": "Āhutiṁ yiṭṭhukāmohaṁ,"
    },
    {
      "id": "tha-ap128:3.4",
      "pali": "pitumātusamāgame."
    },
    {
      "id": "tha-ap128:4.1",
      "pali": "Tadā vipassī bhagavā,"
    },
    {
      "id": "tha-ap128:4.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap128:4.3",
      "pali": "Obhāsento disā sabbā,"
    },
    {
      "id": "tha-ap128:4.4",
      "pali": "āgacchati narāsabho."
    },
    {
      "id": "tha-ap128:5.1",
      "pali": "Āsanaṁ paññapetvāna,"
    },
    {
      "id": "tha-ap128:5.2",
      "pali": "nimantetvā mahāmuniṁ;"
    },
    {
      "id": "tha-ap128:5.3",
      "pali": "Santharitvāna taṁ pupphaṁ,"
    },
    {
      "id": "tha-ap128:5.4",
      "pali": "abhinesiṁ sakaṁ gharaṁ."
    },
    {
      "id": "tha-ap128:6.1",
      "pali": "Yaṁ me atthi sake gehe,"
    },
    {
      "id": "tha-ap128:6.2",
      "pali": "āmisaṁ paccupaṭṭhitaṁ;"
    },
    {
      "id": "tha-ap128:6.3",
      "pali": "Tāhaṁ buddhassa pādāsiṁ,"
    },
    {
      "id": "tha-ap128:6.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap128:7.1",
      "pali": "Bhuttāviṁ kālamaññāya,"
    },
    {
      "id": "tha-ap128:7.2",
      "pali": "pupphahatthamadāsahaṁ;"
    },
    {
      "id": "tha-ap128:7.3",
      "pali": "Anumoditvāna sabbaññū,"
    },
    {
      "id": "tha-ap128:7.4",
      "pali": "pakkāmi uttarāmukho."
    },
    {
      "id": "tha-ap128:8.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap128:8.2",
      "pali": "yaṁ pupphamadadiṁ tadā;"
    },
    {
      "id": "tha-ap128:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap128:8.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap128:9.1",
      "pali": "Anantaraṁ ito kappe,"
    },
    {
      "id": "tha-ap128:9.2",
      "pali": "rājāhuṁ varadassano;"
    },
    {
      "id": "tha-ap128:9.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap128:9.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap128:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap128:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap128:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap128:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā kusumāsaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap128:12.1",
      "pali": "Kusumāsaniyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
