{
  "uid": "mil7.3.4",
  "title": "Samuddavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.3.4:1.1",
      "pali": "“Bhante nāgasena, ‘sālakalyāṇikāya ekaṁ aṅgaṁ gahetabban’ti yaṁ vadesi, katamaṁ taṁ ekaṁ aṅgaṁ gahetabban”ti?"
    },
    {
      "id": "mil7.3.4:1.2",
      "pali": "“Yathā, mahārāja, sālakalyāṇikā nāma antopathaviyaṁyeva abhivaḍḍhati hatthasatampi bhiyyopi;"
    },
    {
      "id": "mil7.3.4:1.3",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena cattāri sāmaññaphalāni catasso paṭisambhidā chaḷabhiññāyo kevalañca samaṇadhammaṁ suññāgāreyeva paripūrayitabbaṁ."
    },
    {
      "id": "mil7.3.4:1.4",
      "pali": "Idaṁ, mahārāja, sālakalyāṇikāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.3.4:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, therena rāhulena—"
    },
    {
      "id": "mil7.3.4:2.1",
      "pali": "‘Sālakalyāṇikā nāma,"
    },
    {
      "id": "mil7.3.4:2.2",
      "pali": "pādapo dharaṇīruho;"
    },
    {
      "id": "mil7.3.4:2.3",
      "pali": "Antopathaviyaṁyeva,"
    },
    {
      "id": "mil7.3.4:2.4",
      "pali": "satahatthopi vaḍḍhati."
    },
    {
      "id": "mil7.3.4:3.1",
      "pali": "Yathā kālamhi sampatte,"
    },
    {
      "id": "mil7.3.4:3.2",
      "pali": "paripākena so dumo;"
    },
    {
      "id": "mil7.3.4:3.3",
      "pali": "Uggañchitvāna ekāhaṁ,"
    },
    {
      "id": "mil7.3.4:3.4",
      "pali": "satahatthopi vaḍḍhati."
    },
    {
      "id": "mil7.3.4:4.1",
      "pali": "Evamevāhaṁ mahāvīra,"
    },
    {
      "id": "mil7.3.4:4.2",
      "pali": "sālakalyāṇikā viya;"
    },
    {
      "id": "mil7.3.4:4.3",
      "pali": "Abbhantare suññāgāre,"
    },
    {
      "id": "mil7.3.4:4.4",
      "pali": "dhammato abhivaḍḍhayin’”ti."
    },
    {
      "id": "mil7.3.4:5.1",
      "pali": "Sālakalyāṇikaṅgapañho catuttho."
    }
  ]
}
