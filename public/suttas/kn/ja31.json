{
  "uid": "ja31",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja31:1.1",
      "pali": "“Kulāvakā mātali simbalismiṁ,"
    },
    {
      "id": "ja31:1.2",
      "pali": "Īsāmukhena parivajjayassu;"
    },
    {
      "id": "ja31:1.3",
      "pali": "Kāmaṁ cajāma asuresu pāṇaṁ,"
    },
    {
      "id": "ja31:1.4",
      "pali": "Māme dijā vikkulāvā ahesun”ti."
    },
    {
      "id": "ja31:2.1",
      "pali": "Kulāvakajātakaṁ paṭhamaṁ."
    }
  ]
}
