{
  "uid": "tha-ap433",
  "title": "1 Ekavihārikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap433:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap433:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap433:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap433:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap433:2.1",
      "pali": "Nippapañco nirālambo,"
    },
    {
      "id": "tha-ap433:2.2",
      "pali": "ākāsasamamānaso;"
    },
    {
      "id": "tha-ap433:2.3",
      "pali": "Suññatābahulo tādī,"
    },
    {
      "id": "tha-ap433:2.4",
      "pali": "animittarato vasī."
    },
    {
      "id": "tha-ap433:3.1",
      "pali": "Asaṅgacitto nikleso,"
    },
    {
      "id": "tha-ap433:3.2",
      "pali": "asaṁsaṭṭho kule gaṇe;"
    },
    {
      "id": "tha-ap433:3.3",
      "pali": "Mahākāruṇiko vīro,"
    },
    {
      "id": "tha-ap433:3.4",
      "pali": "vinayopāyakovido."
    },
    {
      "id": "tha-ap433:4.1",
      "pali": "Uyyutto parakiccesu,"
    },
    {
      "id": "tha-ap433:4.2",
      "pali": "vinayanto sadevake;"
    },
    {
      "id": "tha-ap433:4.3",
      "pali": "Nibbānagamanaṁ maggaṁ,"
    },
    {
      "id": "tha-ap433:4.4",
      "pali": "gatiṁ paṅkavisosanaṁ."
    },
    {
      "id": "tha-ap433:5.1",
      "pali": "Amataṁ paramassādaṁ,"
    },
    {
      "id": "tha-ap433:5.2",
      "pali": "jarāmaccunivāraṇaṁ;"
    },
    {
      "id": "tha-ap433:5.3",
      "pali": "Mahāparisamajjhe so,"
    },
    {
      "id": "tha-ap433:5.4",
      "pali": "nisinno lokatārako."
    },
    {
      "id": "tha-ap433:6.1",
      "pali": "Karavīkaruto nātho,"
    },
    {
      "id": "tha-ap433:6.2",
      "pali": "brahmaghoso tathāgato;"
    },
    {
      "id": "tha-ap433:6.3",
      "pali": "Uddharanto mahāduggā,"
    },
    {
      "id": "tha-ap433:6.4",
      "pali": "vippanaṭṭhe anāyake."
    },
    {
      "id": "tha-ap433:7.1",
      "pali": "Desento virajaṁ dhammaṁ,"
    },
    {
      "id": "tha-ap433:7.2",
      "pali": "diṭṭho me lokanāyako;"
    },
    {
      "id": "tha-ap433:7.3",
      "pali": "Tassa dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap433:7.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap433:8.1",
      "pali": "Pabbajitvā tadāpāhaṁ,"
    },
    {
      "id": "tha-ap433:8.2",
      "pali": "cintento jinasāsanaṁ;"
    },
    {
      "id": "tha-ap433:8.3",
      "pali": "Ekakova vane ramme,"
    },
    {
      "id": "tha-ap433:8.4",
      "pali": "vasiṁ saṁsaggapīḷito."
    },
    {
      "id": "tha-ap433:9.1",
      "pali": "Sakkāyavūpakāso me,"
    },
    {
      "id": "tha-ap433:9.2",
      "pali": "hetubhūto mamābhavī;"
    },
    {
      "id": "tha-ap433:9.3",
      "pali": "Manaso vūpakāsassa,"
    },
    {
      "id": "tha-ap433:9.4",
      "pali": "saṁsaggabhayadassino."
    },
    {
      "id": "tha-ap433:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap433:10.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap433:10.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap433:10.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap433:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap433:11.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap433:11.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap433:11.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap433:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap433:12.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap433:12.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap433:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap433:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekavihāriko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap433:14.1",
      "pali": "Ekavihārikattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
