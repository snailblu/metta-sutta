{
  "uid": "tha-ap281",
  "title": "9 Ekapuṇḍarīkattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap281:1.1",
      "pali": "“Romaso nāma nāmena,"
    },
    {
      "id": "tha-ap281:1.2",
      "pali": "sayambhū subbato tadā;"
    },
    {
      "id": "tha-ap281:1.3",
      "pali": "Puṇḍarīkaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap281:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap281:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap281:2.2",
      "pali": "puṇḍarīkamadaṁ tadā;"
    },
    {
      "id": "tha-ap281:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap281:2.4",
      "pali": "puṇḍarīkassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap281:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap281:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap281:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap281:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekapuṇḍarīko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap281:5.1",
      "pali": "Ekapuṇḍarīkattherassāpadānaṁ navamaṁ."
    }
  ]
}
