{
  "uid": "ja399",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja399:1.1",
      "pali": "“Te kathaṁ nu karissanti,"
    },
    {
      "id": "ja399:1.2",
      "pali": "vuddhā giridarīsayā;"
    },
    {
      "id": "ja399:1.3",
      "pali": "Ahaṁ baddhosmi pāsena,"
    },
    {
      "id": "ja399:1.4",
      "pali": "nilīyassa vasaṁ gato”."
    },
    {
      "id": "ja399:2.1",
      "pali": "“Kiṁ gijjha paridevasi,"
    },
    {
      "id": "ja399:2.2",
      "pali": "kā nu te paridevanā;"
    },
    {
      "id": "ja399:2.3",
      "pali": "Na me suto vā diṭṭho vā,"
    },
    {
      "id": "ja399:2.4",
      "pali": "bhāsanto mānusiṁ dijo”."
    },
    {
      "id": "ja399:3.1",
      "pali": "“Bharāmi mātāpitaro,"
    },
    {
      "id": "ja399:3.2",
      "pali": "vuddhe giridarīsaye;"
    },
    {
      "id": "ja399:3.3",
      "pali": "Te kathaṁ nu karissanti,"
    },
    {
      "id": "ja399:3.4",
      "pali": "ahaṁ vasaṁ gato tava”."
    },
    {
      "id": "ja399:4.1",
      "pali": "“Yannu gijjho yojanasataṁ,"
    },
    {
      "id": "ja399:4.2",
      "pali": "kuṇapāni avekkhati;"
    },
    {
      "id": "ja399:4.3",
      "pali": "Kasmā jālañca pāsañca,"
    },
    {
      "id": "ja399:4.4",
      "pali": "āsajjāpi na bujjhasi”."
    },
    {
      "id": "ja399:5.1",
      "pali": "“Yadā parābhavo hoti,"
    },
    {
      "id": "ja399:5.2",
      "pali": "poso jīvitasaṅkhaye;"
    },
    {
      "id": "ja399:5.3",
      "pali": "Atha jālañca pāsañca,"
    },
    {
      "id": "ja399:5.4",
      "pali": "āsajjāpi na bujjhati”."
    },
    {
      "id": "ja399:6.1",
      "pali": "“Bharassu mātāpitaro,"
    },
    {
      "id": "ja399:6.2",
      "pali": "vuddhe giridarīsaye;"
    },
    {
      "id": "ja399:6.3",
      "pali": "Mayā tvaṁ samanuññāto,"
    },
    {
      "id": "ja399:6.4",
      "pali": "sotthiṁ passāhi ñātake”."
    },
    {
      "id": "ja399:7.1",
      "pali": "“Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja399:7.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja399:7.3",
      "pali": "Bharissaṁ mātāpitaro,"
    },
    {
      "id": "ja399:7.4",
      "pali": "vuddhe giridarīsaye”ti."
    },
    {
      "id": "ja399:8.1",
      "pali": "Mātuposakagijjhajātakaṁ catutthaṁ."
    }
  ]
}
