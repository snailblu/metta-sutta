{
  "uid": "tha-ap461",
  "title": "9 Paṭṭipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap461:1.1",
      "pali": "“Nīharante sarīramhi,"
    },
    {
      "id": "tha-ap461:1.2",
      "pali": "vajjamānāsu bherisu;"
    },
    {
      "id": "tha-ap461:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap461:1.4",
      "pali": "paṭṭipupphamapūjayiṁ."
    },
    {
      "id": "tha-ap461:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap461:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap461:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap461:2.4",
      "pali": "dehapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap461:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap461:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap461:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap461:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap461:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap461:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap461:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap461:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap461:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap461:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṭṭipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap461:7.1",
      "pali": "Paṭṭipupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
