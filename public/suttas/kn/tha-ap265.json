{
  "uid": "tha-ap265",
  "title": "Aḍḍhacandiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap265:1.1",
      "pali": "“Tissassa kho bhagavato,"
    },
    {
      "id": "tha-ap265:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap265:1.3",
      "pali": "Aḍḍhacandaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap265:1.4",
      "pali": "dharaṇīruhapādape."
    },
    {
      "id": "tha-ap265:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap265:2.2",
      "pali": "yaṁ candamabhiropayiṁ;"
    },
    {
      "id": "tha-ap265:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap265:2.4",
      "pali": "bodhipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap265:3.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap265:3.2",
      "pali": "devalo nāma khattiyo;"
    },
    {
      "id": "tha-ap265:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap265:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap265:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap265:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap265:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap265:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā aḍḍhacandiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap265:6.1",
      "pali": "Aḍḍhacandiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
