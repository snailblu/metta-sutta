{
  "uid": "ja55",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja55:1.1",
      "pali": "“Yo alīnena cittena,"
    },
    {
      "id": "ja55:1.2",
      "pali": "alīnamanaso naro;"
    },
    {
      "id": "ja55:1.3",
      "pali": "Bhāveti kusalaṁ dhammaṁ,"
    },
    {
      "id": "ja55:1.4",
      "pali": "yogakkhemassa pattiyā;"
    },
    {
      "id": "ja55:1.5",
      "pali": "Pāpuṇe anupubbena,"
    },
    {
      "id": "ja55:1.6",
      "pali": "sabbasaṁyojanakkhayan”ti."
    },
    {
      "id": "ja55:2.1",
      "pali": "Pañcāvudhajātakaṁ pañcamaṁ."
    }
  ]
}
