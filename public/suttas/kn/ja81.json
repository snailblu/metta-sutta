{
  "uid": "ja81",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja81:1.1",
      "pali": "“Apāyimha anaccimha,"
    },
    {
      "id": "ja81:1.2",
      "pali": "agāyimha rudimha ca;"
    },
    {
      "id": "ja81:1.3",
      "pali": "Visaññikaraṇiṁ pitvā,"
    },
    {
      "id": "ja81:1.4",
      "pali": "diṭṭhā nāhumha vānarā”ti."
    },
    {
      "id": "ja81:2.1",
      "pali": "Surāpānajātakaṁ paṭhamaṁ."
    }
  ]
}
