{
  "uid": "ja135",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja135:1.1",
      "pali": "“Candābhaṁ sūriyābhañca,"
    },
    {
      "id": "ja135:1.2",
      "pali": "yodha paññāya gādha”ti."
    },
    {
      "id": "ja135:1.3",
      "pali": "Avitakkena jhānena,"
    },
    {
      "id": "ja135:1.4",
      "pali": "hoti ābhassarūpagoti."
    },
    {
      "id": "ja135:2.1",
      "pali": "Candābhajātakaṁ pañcamaṁ."
    }
  ]
}
