{
  "uid": "thag1.23",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.23:1.1",
      "pali": "“Ahaṁ kho veḷugumbasmiṁ,"
    },
    {
      "id": "thag1.23:1.2",
      "pali": "bhutvāna madhupāyasaṁ;"
    },
    {
      "id": "thag1.23:1.3",
      "pali": "Padakkhiṇaṁ sammasanto,"
    },
    {
      "id": "thag1.23:1.4",
      "pali": "khandhānaṁ udayabbayaṁ;"
    },
    {
      "id": "thag1.23:1.5",
      "pali": "Sānuṁ paṭigamissāmi,"
    },
    {
      "id": "thag1.23:1.6",
      "pali": "vivekamanubrūhayan”ti."
    },
    {
      "id": "thag1.23:1.7",
      "pali": "… Gosālo thero …."
    }
  ]
}
