{
  "uid": "thag14.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag14.2:1.1",
      "pali": "“Yathāpi bhaddo ājañño,"
    },
    {
      "id": "thag14.2:1.2",
      "pali": "dhure yutto dhurassaho;"
    },
    {
      "id": "thag14.2:1.3",
      "pali": "Mathito atibhārena,"
    },
    {
      "id": "thag14.2:1.4",
      "pali": "saṁyugaṁ nātivattati."
    },
    {
      "id": "thag14.2:2.1",
      "pali": "Evaṁ paññāya ye tittā,"
    },
    {
      "id": "thag14.2:2.2",
      "pali": "samuddo vārinā yathā;"
    },
    {
      "id": "thag14.2:2.3",
      "pali": "Na pare atimaññanti,"
    },
    {
      "id": "thag14.2:2.4",
      "pali": "ariyadhammova pāṇinaṁ."
    },
    {
      "id": "thag14.2:3.1",
      "pali": "Kāle kālavasaṁ pattā,"
    },
    {
      "id": "thag14.2:3.2",
      "pali": "bhavābhavavasaṁ gatā;"
    },
    {
      "id": "thag14.2:3.3",
      "pali": "Narā dukkhaṁ nigacchanti,"
    },
    {
      "id": "thag14.2:3.4",
      "pali": "tedha socanti māṇavā."
    },
    {
      "id": "thag14.2:4.1",
      "pali": "Unnatā sukhadhammena,"
    },
    {
      "id": "thag14.2:4.2",
      "pali": "dukkhadhammena conatā;"
    },
    {
      "id": "thag14.2:4.3",
      "pali": "Dvayena bālā haññanti,"
    },
    {
      "id": "thag14.2:4.4",
      "pali": "yathābhūtaṁ adassino."
    },
    {
      "id": "thag14.2:5.1",
      "pali": "Ye ca dukkhe sukhasmiñca,"
    },
    {
      "id": "thag14.2:5.2",
      "pali": "majjhe sibbinimaccagū;"
    },
    {
      "id": "thag14.2:5.3",
      "pali": "Ṭhitā te indakhīlova,"
    },
    {
      "id": "thag14.2:5.4",
      "pali": "na te unnataonatā."
    },
    {
      "id": "thag14.2:6.1",
      "pali": "Na heva lābhe nālābhe,"
    },
    {
      "id": "thag14.2:6.2",
      "pali": "na yase na ca kittiyā;"
    },
    {
      "id": "thag14.2:6.3",
      "pali": "Na nindāyaṁ pasaṁsāya,"
    },
    {
      "id": "thag14.2:6.4",
      "pali": "na te dukkhe sukhamhi ca."
    },
    {
      "id": "thag14.2:7.1",
      "pali": "Sabbattha te na limpanti,"
    },
    {
      "id": "thag14.2:7.2",
      "pali": "udabinduva pokkhare;"
    },
    {
      "id": "thag14.2:7.3",
      "pali": "Sabbattha sukhitā dhīrā,"
    },
    {
      "id": "thag14.2:7.4",
      "pali": "sabbattha aparājitā."
    },
    {
      "id": "thag14.2:8.1",
      "pali": "Dhammena ca alābho yo,"
    },
    {
      "id": "thag14.2:8.2",
      "pali": "yo ca lābho adhammiko;"
    },
    {
      "id": "thag14.2:8.3",
      "pali": "Alābho dhammiko seyyo,"
    },
    {
      "id": "thag14.2:8.4",
      "pali": "yañce lābho adhammiko."
    },
    {
      "id": "thag14.2:9.1",
      "pali": "Yaso ca appabuddhīnaṁ,"
    },
    {
      "id": "thag14.2:9.2",
      "pali": "viññūnaṁ ayaso ca yo;"
    },
    {
      "id": "thag14.2:9.3",
      "pali": "Ayasova seyyo viññūnaṁ,"
    },
    {
      "id": "thag14.2:9.4",
      "pali": "na yaso appabuddhinaṁ."
    },
    {
      "id": "thag14.2:10.1",
      "pali": "Dummedhehi pasaṁsā ca,"
    },
    {
      "id": "thag14.2:10.2",
      "pali": "viññūhi garahā ca yā;"
    },
    {
      "id": "thag14.2:10.3",
      "pali": "Garahāva seyyo viññūhi,"
    },
    {
      "id": "thag14.2:10.4",
      "pali": "yañce bālappasaṁsanā."
    },
    {
      "id": "thag14.2:11.1",
      "pali": "Sukhañca kāmamayikaṁ,"
    },
    {
      "id": "thag14.2:11.2",
      "pali": "dukkhañca pavivekiyaṁ;"
    },
    {
      "id": "thag14.2:11.3",
      "pali": "Pavivekadukkhaṁ seyyo,"
    },
    {
      "id": "thag14.2:11.4",
      "pali": "yañce kāmamayaṁ sukhaṁ."
    },
    {
      "id": "thag14.2:12.1",
      "pali": "Jīvitañca adhammena,"
    },
    {
      "id": "thag14.2:12.2",
      "pali": "dhammena maraṇañca yaṁ;"
    },
    {
      "id": "thag14.2:12.3",
      "pali": "Maraṇaṁ dhammikaṁ seyyo,"
    },
    {
      "id": "thag14.2:12.4",
      "pali": "yañce jīve adhammikaṁ."
    },
    {
      "id": "thag14.2:13.1",
      "pali": "Kāmakopappahīnā ye,"
    },
    {
      "id": "thag14.2:13.2",
      "pali": "santacittā bhavābhave;"
    },
    {
      "id": "thag14.2:13.3",
      "pali": "Caranti loke asitā,"
    },
    {
      "id": "thag14.2:13.4",
      "pali": "natthi tesaṁ piyāpiyaṁ."
    },
    {
      "id": "thag14.2:14.1",
      "pali": "Bhāvayitvāna bojjhaṅge,"
    },
    {
      "id": "thag14.2:14.2",
      "pali": "indriyāni balāni ca;"
    },
    {
      "id": "thag14.2:14.3",
      "pali": "Pappuyya paramaṁ santiṁ,"
    },
    {
      "id": "thag14.2:14.4",
      "pali": "parinibbantināsavā”ti."
    },
    {
      "id": "thag14.2:14.5",
      "pali": "… Godatto thero …"
    },
    {
      "id": "thag14.2:14.6",
      "pali": "Cuddasakanipāto niṭṭhito."
    },
    {
      "id": "thag14.2:15.1",
      "pali": "Revato ceva godatto,"
    },
    {
      "id": "thag14.2:15.2",
      "pali": "therā dve te mahiddhikā;"
    },
    {
      "id": "thag14.2:15.3",
      "pali": "Cuddasamhi nipātamhi,"
    },
    {
      "id": "thag14.2:15.4",
      "pali": "gāthāyo aṭṭhavīsatīti."
    }
  ]
}
