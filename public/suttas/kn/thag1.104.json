{
  "uid": "thag1.104",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.104:1.1",
      "pali": "“Lahuko vata me kāyo,"
    },
    {
      "id": "thag1.104:1.2",
      "pali": "Phuṭṭho ca pītisukhena vipulena;"
    },
    {
      "id": "thag1.104:1.3",
      "pali": "Tūlamiva eritaṁ mālutena,"
    },
    {
      "id": "thag1.104:1.4",
      "pali": "Pilavatīva me kāyo”ti."
    },
    {
      "id": "thag1.104:1.5",
      "pali": "… Khitako thero …."
    }
  ]
}
