{
  "uid": "ja114",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja114:1.1",
      "pali": "“Bahucintī appacintī,"
    },
    {
      "id": "ja114:1.2",
      "pali": "ubho jāle abajjhare;"
    },
    {
      "id": "ja114:1.3",
      "pali": "Mitacintī pamocesī,"
    },
    {
      "id": "ja114:1.4",
      "pali": "ubho tattha samāgatā”ti."
    },
    {
      "id": "ja114:2.1",
      "pali": "Mitacintijātakaṁ catutthaṁ."
    }
  ]
}
