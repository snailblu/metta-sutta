{
  "uid": "thag6.10",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.10:1.1",
      "pali": "“Yadā navo pabbajito,"
    },
    {
      "id": "thag6.10:1.2",
      "pali": "jātiyā sattavassiko;"
    },
    {
      "id": "thag6.10:1.3",
      "pali": "Iddhiyā abhibhotvāna,"
    },
    {
      "id": "thag6.10:1.4",
      "pali": "pannagindaṁ mahiddhikaṁ."
    },
    {
      "id": "thag6.10:2.1",
      "pali": "Upajjhāyassa udakaṁ,"
    },
    {
      "id": "thag6.10:2.2",
      "pali": "anotattā mahāsarā;"
    },
    {
      "id": "thag6.10:2.3",
      "pali": "Āharāmi tato disvā,"
    },
    {
      "id": "thag6.10:2.4",
      "pali": "maṁ satthā etadabravi”."
    },
    {
      "id": "thag6.10:3.1",
      "pali": "“Sāriputta imaṁ passa,"
    },
    {
      "id": "thag6.10:3.2",
      "pali": "āgacchantaṁ kumārakaṁ;"
    },
    {
      "id": "thag6.10:3.3",
      "pali": "Udakakumbhamādāya,"
    },
    {
      "id": "thag6.10:3.4",
      "pali": "ajjhattaṁ susamāhitaṁ."
    },
    {
      "id": "thag6.10:4.1",
      "pali": "Pāsādikena vattena,"
    },
    {
      "id": "thag6.10:4.2",
      "pali": "kalyāṇairiyāpatho;"
    },
    {
      "id": "thag6.10:4.3",
      "pali": "Sāmaṇeronuruddhassa,"
    },
    {
      "id": "thag6.10:4.4",
      "pali": "iddhiyā ca visārado."
    },
    {
      "id": "thag6.10:5.1",
      "pali": "Ājānīyena ājañño,"
    },
    {
      "id": "thag6.10:5.2",
      "pali": "sādhunā sādhukārito;"
    },
    {
      "id": "thag6.10:5.3",
      "pali": "Vinīto anuruddhena,"
    },
    {
      "id": "thag6.10:5.4",
      "pali": "katakiccena sikkhito."
    },
    {
      "id": "thag6.10:6.1",
      "pali": "So patvā paramaṁ santiṁ,"
    },
    {
      "id": "thag6.10:6.2",
      "pali": "sacchikatvā akuppataṁ;"
    },
    {
      "id": "thag6.10:6.3",
      "pali": "Sāmaṇero sa sumano,"
    },
    {
      "id": "thag6.10:6.4",
      "pali": "mā maṁ jaññāti icchatī”ti."
    },
    {
      "id": "thag6.10:6.5",
      "pali": "… Sumano thero …."
    }
  ]
}
