{
  "uid": "ja366",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja366:1.1",
      "pali": "“Madhuvaṇṇaṁ madhurasaṁ,"
    },
    {
      "id": "ja366:1.2",
      "pali": "madhugandhaṁ visaṁ ahu;"
    },
    {
      "id": "ja366:1.3",
      "pali": "Gumbiyo ghāsamesāno,"
    },
    {
      "id": "ja366:1.4",
      "pali": "araññe odahī visaṁ."
    },
    {
      "id": "ja366:2.1",
      "pali": "Madhu iti maññamānā,"
    },
    {
      "id": "ja366:2.2",
      "pali": "ye taṁ visamakhādisuṁ;"
    },
    {
      "id": "ja366:2.3",
      "pali": "Tesaṁ taṁ kaṭukaṁ āsi,"
    },
    {
      "id": "ja366:2.4",
      "pali": "maraṇaṁ tenupāgamuṁ."
    },
    {
      "id": "ja366:3.1",
      "pali": "Ye ca kho paṭisaṅkhāya,"
    },
    {
      "id": "ja366:3.2",
      "pali": "visaṁ taṁ parivajjayuṁ;"
    },
    {
      "id": "ja366:3.3",
      "pali": "Te āturesu sukhitā,"
    },
    {
      "id": "ja366:3.4",
      "pali": "ḍayhamānesu nibbutā."
    },
    {
      "id": "ja366:4.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja366:4.2",
      "pali": "visaṁ kāmā samohitā;"
    },
    {
      "id": "ja366:4.3",
      "pali": "Āmisaṁ bandhanañcetaṁ,"
    },
    {
      "id": "ja366:4.4",
      "pali": "maccuveso guhāsayo."
    },
    {
      "id": "ja366:5.1",
      "pali": "Evameva ime kāme,"
    },
    {
      "id": "ja366:5.2",
      "pali": "āturā paricārike;"
    },
    {
      "id": "ja366:5.3",
      "pali": "Ye sadā parivajjenti,"
    },
    {
      "id": "ja366:5.4",
      "pali": "saṅgaṁ loke upaccagun”ti."
    },
    {
      "id": "ja366:6.1",
      "pali": "Gumbiyajātakaṁ chaṭṭhaṁ."
    }
  ]
}
