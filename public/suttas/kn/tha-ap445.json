{
  "uid": "tha-ap445",
  "title": "3 Billiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap445:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap445:1.2",
      "pali": "assamo sukato mama;"
    },
    {
      "id": "tha-ap445:1.3",
      "pali": "Billarukkhehi ākiṇṇo,"
    },
    {
      "id": "tha-ap445:1.4",
      "pali": "nānādumanisevito."
    },
    {
      "id": "tha-ap445:2.1",
      "pali": "Sugandhaṁ beluvaṁ disvā,"
    },
    {
      "id": "tha-ap445:2.2",
      "pali": "buddhaseṭṭhamanussariṁ;"
    },
    {
      "id": "tha-ap445:2.3",
      "pali": "Khāribhāraṁ pūrayitvā,"
    },
    {
      "id": "tha-ap445:2.4",
      "pali": "tuṭṭho saṁviggamānaso."
    },
    {
      "id": "tha-ap445:3.1",
      "pali": "Kakusandhaṁ upāgamma,"
    },
    {
      "id": "tha-ap445:3.2",
      "pali": "billapakkamadāsahaṁ;"
    },
    {
      "id": "tha-ap445:3.3",
      "pali": "Puññakkhettassa vīrassa,"
    },
    {
      "id": "tha-ap445:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap445:4.1",
      "pali": "Imasmiṁyeva kappasmiṁ,"
    },
    {
      "id": "tha-ap445:4.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap445:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap445:4.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap445:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap445:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap445:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap445:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap445:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap445:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap445:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap445:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap445:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap445:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā billiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap445:9.1",
      "pali": "Billiyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
