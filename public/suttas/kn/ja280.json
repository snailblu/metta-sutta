{
  "uid": "ja280",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja280:1.1",
      "pali": "“Addhā hi nūna migarājā,"
    },
    {
      "id": "ja280:1.2",
      "pali": "puṭakammassa kovido;"
    },
    {
      "id": "ja280:1.3",
      "pali": "Tathā hi puṭaṁ dūseti,"
    },
    {
      "id": "ja280:1.4",
      "pali": "aññaṁ nūna karissati”."
    },
    {
      "id": "ja280:2.1",
      "pali": "“Na me mātā vā pitā vā,"
    },
    {
      "id": "ja280:2.2",
      "pali": "puṭakammassa kovido;"
    },
    {
      "id": "ja280:2.3",
      "pali": "Kataṁ kataṁ kho dūsema,"
    },
    {
      "id": "ja280:2.4",
      "pali": "evaṁ dhammamidaṁ kulaṁ”."
    },
    {
      "id": "ja280:3.1",
      "pali": "“Yesaṁ vo ediso dhammo,"
    },
    {
      "id": "ja280:3.2",
      "pali": "Adhammo pana kīdiso;"
    },
    {
      "id": "ja280:3.3",
      "pali": "Mā vo dhammaṁ adhammaṁ vā,"
    },
    {
      "id": "ja280:3.4",
      "pali": "Addasāma kudācanan”ti."
    },
    {
      "id": "ja280:4.1",
      "pali": "Puṭadūsakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja280:4.2",
      "pali": "Udapānavaggo tatiyo."
    },
    {
      "id": "ja280:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja280:6.1",
      "pali": "Udapānavaraṁ vanabyaggha kapi,"
    },
    {
      "id": "ja280:6.2",
      "pali": "Sikhinī ca balāka ruciravaro;"
    },
    {
      "id": "ja280:6.3",
      "pali": "Sujanādhiparomakadūsa puna,"
    },
    {
      "id": "ja280:6.4",
      "pali": "Satapattavaro puṭakamma dasāti."
    }
  ]
}
