{
  "uid": "tha-ap272",
  "title": "Taraṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap272:1.1",
      "pali": "“Suvaṇṇavaṇṇo sambuddho,"
    },
    {
      "id": "tha-ap272:1.2",
      "pali": "vipassī dakkhiṇāraho;"
    },
    {
      "id": "tha-ap272:1.3",
      "pali": "Nadītīre ṭhito satthā,"
    },
    {
      "id": "tha-ap272:1.4",
      "pali": "bhikkhusaṅghapurakkhato."
    },
    {
      "id": "tha-ap272:2.1",
      "pali": "Nāvā na vijjate tattha,"
    },
    {
      "id": "tha-ap272:2.2",
      "pali": "santāraṇī mahaṇṇave;"
    },
    {
      "id": "tha-ap272:2.3",
      "pali": "Nadiyā abhinikkhamma,"
    },
    {
      "id": "tha-ap272:2.4",
      "pali": "tāresiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap272:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap272:3.2",
      "pali": "yaṁ tāresiṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap272:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap272:3.4",
      "pali": "taraṇāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap272:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap272:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap272:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap272:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā taraṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap272:6.1",
      "pali": "Taraṇiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap272:7.1",
      "pali": "Padumukkhipavaggo sattavīsatimo."
    },
    {
      "id": "tha-ap272:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap272:9.1",
      "pali": "Ukkhipī telacandī ca,"
    },
    {
      "id": "tha-ap272:9.2",
      "pali": "dīpado ca biḷālido;"
    },
    {
      "id": "tha-ap272:9.3",
      "pali": "Maccho javo saḷalado,"
    },
    {
      "id": "tha-ap272:9.4",
      "pali": "rakkhaso taraṇo dasa;"
    },
    {
      "id": "tha-ap272:9.5",
      "pali": "Gāthāyo cettha saṅkhātā,"
    },
    {
      "id": "tha-ap272:9.6",
      "pali": "tālīsaṁ cekameva cāti."
    }
  ]
}
