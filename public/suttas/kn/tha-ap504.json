{
  "uid": "tha-ap504",
  "title": "Ekapattadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap504:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap504:1.2",
      "pali": "kumbhakāro ahosahaṁ;"
    },
    {
      "id": "tha-ap504:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap504:1.4",
      "pali": "oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap504:2.1",
      "pali": "Sukataṁ mattikāpattaṁ,"
    },
    {
      "id": "tha-ap504:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap504:2.3",
      "pali": "Pattaṁ datvā bhagavato,"
    },
    {
      "id": "tha-ap504:2.4",
      "pali": "ujubhūtassa tādino."
    },
    {
      "id": "tha-ap504:3.1",
      "pali": "Bhave nibbattamānohaṁ,"
    },
    {
      "id": "tha-ap504:3.2",
      "pali": "soṇṇathāle labhāmahaṁ;"
    },
    {
      "id": "tha-ap504:3.3",
      "pali": "Rūpimaye ca sovaṇṇe,"
    },
    {
      "id": "tha-ap504:3.4",
      "pali": "taṭṭike ca maṇīmaye."
    },
    {
      "id": "tha-ap504:4.1",
      "pali": "Pātiyo paribhuñjāmi,"
    },
    {
      "id": "tha-ap504:4.2",
      "pali": "puññakammassidaṁ phalaṁ;"
    },
    {
      "id": "tha-ap504:4.3",
      "pali": "Yasānañca dhanānañca,"
    },
    {
      "id": "tha-ap504:4.4",
      "pali": "aggabhūto ca homahaṁ."
    },
    {
      "id": "tha-ap504:5.1",
      "pali": "Yathāpi bhaddake khette,"
    },
    {
      "id": "tha-ap504:5.2",
      "pali": "bījaṁ appampi ropitaṁ;"
    },
    {
      "id": "tha-ap504:5.3",
      "pali": "Sammādhāraṁ pavecchante,"
    },
    {
      "id": "tha-ap504:5.4",
      "pali": "phalaṁ toseti kassakaṁ."
    },
    {
      "id": "tha-ap504:6.1",
      "pali": "Tathevidaṁ pattadānaṁ,"
    },
    {
      "id": "tha-ap504:6.2",
      "pali": "buddhakhettamhi ropitaṁ;"
    },
    {
      "id": "tha-ap504:6.3",
      "pali": "Pītidhāre pavassante,"
    },
    {
      "id": "tha-ap504:6.4",
      "pali": "phalaṁ maṁ tosayissati."
    },
    {
      "id": "tha-ap504:7.1",
      "pali": "Yāvatā khettā vijjanti,"
    },
    {
      "id": "tha-ap504:7.2",
      "pali": "saṅghāpi ca gaṇāpi ca;"
    },
    {
      "id": "tha-ap504:7.3",
      "pali": "Buddhakhettasamo natthi,"
    },
    {
      "id": "tha-ap504:7.4",
      "pali": "sukhado sabbapāṇinaṁ."
    },
    {
      "id": "tha-ap504:8.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap504:8.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap504:8.3",
      "pali": "Ekapattaṁ daditvāna,"
    },
    {
      "id": "tha-ap504:8.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap504:9.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap504:9.2",
      "pali": "yaṁ pattamadadiṁ tadā;"
    },
    {
      "id": "tha-ap504:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap504:9.4",
      "pali": "pattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap504:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap504:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap504:10.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap504:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap504:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap504:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap504:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap504:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap504:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap504:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekapattadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap504:14.1",
      "pali": "Ekapattadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
