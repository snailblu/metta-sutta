{
  "uid": "ja413",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja413:1.1",
      "pali": "“Rājā apucchi vidhuraṁ,"
    },
    {
      "id": "ja413:1.2",
      "pali": "dhammakāmo yudhiṭṭhilo;"
    },
    {
      "id": "ja413:1.3",
      "pali": "Api brāhmaṇa jānāsi,"
    },
    {
      "id": "ja413:1.4",
      "pali": "ko eko bahu socati”."
    },
    {
      "id": "ja413:2.1",
      "pali": "“Brāhmaṇo ajayūthena,"
    },
    {
      "id": "ja413:2.2",
      "pali": "pahūtedho vane vasaṁ;"
    },
    {
      "id": "ja413:2.3",
      "pali": "Dhūmaṁ akāsi vāseṭṭho,"
    },
    {
      "id": "ja413:2.4",
      "pali": "rattindivamatandito."
    },
    {
      "id": "ja413:3.1",
      "pali": "Tassa taṁ dhūmagandhena,"
    },
    {
      "id": "ja413:3.2",
      "pali": "sarabhā makasaḍḍitā;"
    },
    {
      "id": "ja413:3.3",
      "pali": "Vassāvāsaṁ upāgacchuṁ,"
    },
    {
      "id": "ja413:3.4",
      "pali": "dhūmakārissa santike."
    },
    {
      "id": "ja413:4.1",
      "pali": "Sarabhesu manaṁ katvā,"
    },
    {
      "id": "ja413:4.2",
      "pali": "ajā so nāvabujjhatha;"
    },
    {
      "id": "ja413:4.3",
      "pali": "Āgacchantī vajantī vā,"
    },
    {
      "id": "ja413:4.4",
      "pali": "tassa tā vinasuṁ ajā."
    },
    {
      "id": "ja413:5.1",
      "pali": "Sarabhā sarade kāle,"
    },
    {
      "id": "ja413:5.2",
      "pali": "pahīnamakase vane;"
    },
    {
      "id": "ja413:5.3",
      "pali": "Pāvisuṁ giriduggāni,"
    },
    {
      "id": "ja413:5.4",
      "pali": "nadīnaṁ pabhavāni ca."
    },
    {
      "id": "ja413:6.1",
      "pali": "Sarabhe ca gate disvā,"
    },
    {
      "id": "ja413:6.2",
      "pali": "ajā ca vibhavaṁ gatā;"
    },
    {
      "id": "ja413:6.3",
      "pali": "Kiso ca vivaṇṇo cāsi,"
    },
    {
      "id": "ja413:6.4",
      "pali": "paṇḍurogī ca brāhmaṇo."
    },
    {
      "id": "ja413:7.1",
      "pali": "Evaṁ yo saṁ niraṅkatvā,"
    },
    {
      "id": "ja413:7.2",
      "pali": "āgantuṁ kurute piyaṁ;"
    },
    {
      "id": "ja413:7.3",
      "pali": "So eko bahu socati,"
    },
    {
      "id": "ja413:7.4",
      "pali": "dhūmakārīva brāhmaṇo”ti."
    },
    {
      "id": "ja413:8.1",
      "pali": "Dhūmakārijātakaṁ aṭṭhamaṁ."
    }
  ]
}
