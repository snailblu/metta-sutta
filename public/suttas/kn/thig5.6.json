{
  "uid": "thig5.6",
  "title": "Mittākāḷītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.6:1.1",
      "pali": "“Saddhāya pabbajitvāna,"
    },
    {
      "id": "thig5.6:1.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thig5.6:1.3",
      "pali": "Vicariṁhaṁ tena tena,"
    },
    {
      "id": "thig5.6:1.4",
      "pali": "lābhasakkāraussukā."
    },
    {
      "id": "thig5.6:2.1",
      "pali": "Riñcitvā paramaṁ atthaṁ,"
    },
    {
      "id": "thig5.6:2.2",
      "pali": "hīnamatthaṁ asevihaṁ;"
    },
    {
      "id": "thig5.6:2.3",
      "pali": "Kilesānaṁ vasaṁ gantvā,"
    },
    {
      "id": "thig5.6:2.4",
      "pali": "sāmaññatthaṁ na bujjhihaṁ."
    },
    {
      "id": "thig5.6:3.1",
      "pali": "Tassā me ahu saṁvego,"
    },
    {
      "id": "thig5.6:3.2",
      "pali": "nisinnāya vihārake;"
    },
    {
      "id": "thig5.6:3.3",
      "pali": "Ummaggapaṭipannāmhi,"
    },
    {
      "id": "thig5.6:3.4",
      "pali": "taṇhāya vasamāgatā."
    },
    {
      "id": "thig5.6:4.1",
      "pali": "Appakaṁ jīvitaṁ mayhaṁ,"
    },
    {
      "id": "thig5.6:4.2",
      "pali": "jarā byādhi ca maddati;"
    },
    {
      "id": "thig5.6:4.3",
      "pali": "Purāyaṁ bhijjati kāyo,"
    },
    {
      "id": "thig5.6:4.4",
      "pali": "na me kālo pamajjituṁ."
    },
    {
      "id": "thig5.6:5.1",
      "pali": "Yathābhūtamavekkhantī,"
    },
    {
      "id": "thig5.6:5.2",
      "pali": "khandhānaṁ udayabbayaṁ;"
    },
    {
      "id": "thig5.6:5.3",
      "pali": "Vimuttacittā uṭṭhāsiṁ,"
    },
    {
      "id": "thig5.6:5.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig5.6:6.1",
      "pali": "… Mittā kāḷī therī …."
    }
  ]
}
