{
  "uid": "vv63",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv63:1.1",
      "pali": "“Daḷhadhammā nisārassa,"
    },
    {
      "id": "vv63:1.2",
      "pali": "dhanuṁ olubbha tiṭṭhasi;"
    },
    {
      "id": "vv63:1.3",
      "pali": "Khattiyo nusi rājañño,"
    },
    {
      "id": "vv63:1.4",
      "pali": "adu luddo vanecaro”ti."
    },
    {
      "id": "vv63:2.1",
      "pali": "“Assakādhipatissāhaṁ,"
    },
    {
      "id": "vv63:2.2",
      "pali": "bhante putto vanecaro;"
    },
    {
      "id": "vv63:2.3",
      "pali": "Nāmaṁ me bhikkhu te brūmi,"
    },
    {
      "id": "vv63:2.4",
      "pali": "sujāto iti maṁ vidū."
    },
    {
      "id": "vv63:3.1",
      "pali": "Mige gavesamānohaṁ,"
    },
    {
      "id": "vv63:3.2",
      "pali": "Ogāhanto brahāvanaṁ;"
    },
    {
      "id": "vv63:3.3",
      "pali": "Migaṁ tañceva nāddakkhiṁ,"
    },
    {
      "id": "vv63:3.4",
      "pali": "Tañca disvā ṭhito ahan”ti."
    },
    {
      "id": "vv63:4.1",
      "pali": "“Svāgataṁ te mahāpuñña,"
    },
    {
      "id": "vv63:4.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "vv63:4.3",
      "pali": "Etto udakamādāya,"
    },
    {
      "id": "vv63:4.4",
      "pali": "pāde pakkhālayassu te."
    },
    {
      "id": "vv63:5.1",
      "pali": "Idampi pānīyaṁ sītaṁ,"
    },
    {
      "id": "vv63:5.2",
      "pali": "ābhataṁ girigabbharā;"
    },
    {
      "id": "vv63:5.3",
      "pali": "Rājaputta tato pitvā,"
    },
    {
      "id": "vv63:5.4",
      "pali": "santhatasmiṁ upāvisā”ti."
    },
    {
      "id": "vv63:6.1",
      "pali": "“Kalyāṇī vata te vācā,"
    },
    {
      "id": "vv63:6.2",
      "pali": "Savanīyā mahāmuni;"
    },
    {
      "id": "vv63:6.3",
      "pali": "Nelā atthavatī vaggu,"
    },
    {
      "id": "vv63:6.4",
      "pali": "Mantvā atthañca bhāsasi."
    },
    {
      "id": "vv63:7.1",
      "pali": "Kā te rati vane viharato,"
    },
    {
      "id": "vv63:7.2",
      "pali": "Isinisabha vadehi puṭṭho;"
    },
    {
      "id": "vv63:7.3",
      "pali": "Tava vacanapathaṁ nisāmayitvā,"
    },
    {
      "id": "vv63:7.4",
      "pali": "Atthadhammapadaṁ samācaremase”ti."
    },
    {
      "id": "vv63:8.1",
      "pali": "“Ahiṁsā sabbapāṇīnaṁ,"
    },
    {
      "id": "vv63:8.2",
      "pali": "kumāramhāka ruccati;"
    },
    {
      "id": "vv63:8.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv63:8.4",
      "pali": "majjapānā ca ārati."
    },
    {
      "id": "vv63:9.1",
      "pali": "Ārati samacariyā ca,"
    },
    {
      "id": "vv63:9.2",
      "pali": "bāhusaccaṁ kataññutā;"
    },
    {
      "id": "vv63:9.3",
      "pali": "Diṭṭheva dhamme pāsaṁsā,"
    },
    {
      "id": "vv63:9.4",
      "pali": "dhammā ete pasaṁsiyāti."
    },
    {
      "id": "vv63:10.1",
      "pali": "Santike maraṇaṁ tuyhaṁ,"
    },
    {
      "id": "vv63:10.2",
      "pali": "oraṁ māsehi pañcahi;"
    },
    {
      "id": "vv63:10.3",
      "pali": "Rājaputta vijānāhi,"
    },
    {
      "id": "vv63:10.4",
      "pali": "attānaṁ parimocayā”ti."
    },
    {
      "id": "vv63:11.1",
      "pali": "“Katamaṁ svāhaṁ janapadaṁ gantvā,"
    },
    {
      "id": "vv63:11.2",
      "pali": "Kiṁ kammaṁ kiñca porisaṁ;"
    },
    {
      "id": "vv63:11.3",
      "pali": "Kāya vā pana vijjāya,"
    },
    {
      "id": "vv63:11.4",
      "pali": "Bhaveyyaṁ ajarāmaro”ti."
    },
    {
      "id": "vv63:12.1",
      "pali": "“Na vijjate so padeso,"
    },
    {
      "id": "vv63:12.2",
      "pali": "kammaṁ vijjā ca porisaṁ;"
    },
    {
      "id": "vv63:12.3",
      "pali": "Yattha gantvā bhave macco,"
    },
    {
      "id": "vv63:12.4",
      "pali": "rājaputtājarāmaro."
    },
    {
      "id": "vv63:13.1",
      "pali": "Mahaddhanā mahābhogā,"
    },
    {
      "id": "vv63:13.2",
      "pali": "raṭṭhavantopi khattiyā;"
    },
    {
      "id": "vv63:13.3",
      "pali": "Pahūtadhanadhaññāse,"
    },
    {
      "id": "vv63:13.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "vv63:14.1",
      "pali": "Yadi te sutā andhakaveṇḍuputtā,"
    },
    {
      "id": "vv63:14.2",
      "pali": "Sūrā vīrā vikkantappahārino;"
    },
    {
      "id": "vv63:14.3",
      "pali": "Tepi āyukkhayaṁ pattā,"
    },
    {
      "id": "vv63:14.4",
      "pali": "Viddhastā sassatīsamā."
    },
    {
      "id": "vv63:15.1",
      "pali": "Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "vv63:15.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "vv63:15.3",
      "pali": "Ete caññe ca jātiyā,"
    },
    {
      "id": "vv63:15.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "vv63:16.1",
      "pali": "Ye mantaṁ parivattenti,"
    },
    {
      "id": "vv63:16.2",
      "pali": "chaḷaṅgaṁ brahmacintitaṁ;"
    },
    {
      "id": "vv63:16.3",
      "pali": "Ete caññe ca vijjāya,"
    },
    {
      "id": "vv63:16.4",
      "pali": "tepi no ajarāmarā."
    },
    {
      "id": "vv63:17.1",
      "pali": "Isayo cāpi ye santā,"
    },
    {
      "id": "vv63:17.2",
      "pali": "saññatattā tapassino;"
    },
    {
      "id": "vv63:17.3",
      "pali": "Sarīraṁ tepi kālena,"
    },
    {
      "id": "vv63:17.4",
      "pali": "vijahanti tapassino."
    },
    {
      "id": "vv63:18.1",
      "pali": "Bhāvitattāpi arahanto,"
    },
    {
      "id": "vv63:18.2",
      "pali": "katakiccā anāsavā;"
    },
    {
      "id": "vv63:18.3",
      "pali": "Nikkhipanti imaṁ dehaṁ,"
    },
    {
      "id": "vv63:18.4",
      "pali": "puññapāpaparikkhayā”ti."
    },
    {
      "id": "vv63:19.1",
      "pali": "“Subhāsitā atthavatī,"
    },
    {
      "id": "vv63:19.2",
      "pali": "gāthāyo te mahāmuni;"
    },
    {
      "id": "vv63:19.3",
      "pali": "Nijjhattomhi subhaṭṭhena,"
    },
    {
      "id": "vv63:19.4",
      "pali": "tvañca me saraṇaṁ bhavā”ti."
    },
    {
      "id": "vv63:20.1",
      "pali": "“Mā maṁ tvaṁ saraṇaṁ gaccha,"
    },
    {
      "id": "vv63:20.2",
      "pali": "tameva saraṇaṁ vaja;"
    },
    {
      "id": "vv63:20.3",
      "pali": "Sakyaputtaṁ mahāvīraṁ,"
    },
    {
      "id": "vv63:20.4",
      "pali": "yamahaṁ saraṇaṁ gato”ti."
    },
    {
      "id": "vv63:21.1",
      "pali": "“Katarasmiṁ so janapade,"
    },
    {
      "id": "vv63:21.2",
      "pali": "satthā tumhāka mārisa;"
    },
    {
      "id": "vv63:21.3",
      "pali": "Ahampi daṭṭhuṁ gacchissaṁ,"
    },
    {
      "id": "vv63:21.4",
      "pali": "jinaṁ appaṭipuggalan”ti."
    },
    {
      "id": "vv63:22.1",
      "pali": "“Puratthimasmiṁ janapade,"
    },
    {
      "id": "vv63:22.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "vv63:22.3",
      "pali": "Tatthāsi purisājañño,"
    },
    {
      "id": "vv63:22.4",
      "pali": "so ca kho parinibbuto”ti."
    },
    {
      "id": "vv63:23.1",
      "pali": "“Sace hi buddho tiṭṭheyya,"
    },
    {
      "id": "vv63:23.2",
      "pali": "Satthā tumhāka mārisa;"
    },
    {
      "id": "vv63:23.3",
      "pali": "Yojanāni sahassāni,"
    },
    {
      "id": "vv63:23.4",
      "pali": "Gaccheyyaṁ payirupāsituṁ."
    },
    {
      "id": "vv63:24.1",
      "pali": "Yato ca kho parinibbuto,"
    },
    {
      "id": "vv63:24.2",
      "pali": "satthā tumhāka mārisa;"
    },
    {
      "id": "vv63:24.3",
      "pali": "Nibbutampi mahāvīraṁ,"
    },
    {
      "id": "vv63:24.4",
      "pali": "gacchāmi saraṇaṁ ahaṁ."
    },
    {
      "id": "vv63:25.1",
      "pali": "Upemi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "vv63:25.2",
      "pali": "dhammañcāpi anuttaraṁ;"
    },
    {
      "id": "vv63:25.3",
      "pali": "Saṅghañca naradevassa,"
    },
    {
      "id": "vv63:25.4",
      "pali": "gacchāmi saraṇaṁ ahaṁ."
    },
    {
      "id": "vv63:26.1",
      "pali": "Pāṇātipātā viramāmi khippaṁ,"
    },
    {
      "id": "vv63:26.2",
      "pali": "Loke adinnaṁ parivajjayāmi;"
    },
    {
      "id": "vv63:26.3",
      "pali": "Amajjapo no ca musā bhaṇāmi,"
    },
    {
      "id": "vv63:26.4",
      "pali": "Sakena dārena ca homi tuṭṭho”ti."
    },
    {
      "id": "vv63:27.1",
      "pali": "“Sahassaraṁsīva yathā mahappabho,"
    },
    {
      "id": "vv63:27.2",
      "pali": "Disaṁ yathā bhāti nabhe anukkamaṁ;"
    },
    {
      "id": "vv63:27.3",
      "pali": "Tathāpakāro tavāyaṁ mahāratho,"
    },
    {
      "id": "vv63:27.4",
      "pali": "Samantato yojanasattamāyato."
    },
    {
      "id": "vv63:28.1",
      "pali": "Suvaṇṇapaṭṭehi samantamotthaṭo,"
    },
    {
      "id": "vv63:28.2",
      "pali": "Urassa muttāhi maṇīhi cittito;"
    },
    {
      "id": "vv63:28.3",
      "pali": "Lekhā suvaṇṇassa ca rūpiyassa ca,"
    },
    {
      "id": "vv63:28.4",
      "pali": "Sobhenti veḷuriyamayā sunimmitā."
    },
    {
      "id": "vv63:29.1",
      "pali": "Sīsañcidaṁ veḷuriyassa nimmitaṁ,"
    },
    {
      "id": "vv63:29.2",
      "pali": "Yugañcidaṁ lohitakāya cittitaṁ;"
    },
    {
      "id": "vv63:29.3",
      "pali": "Yuttā suvaṇṇassa ca rūpiyassa ca,"
    },
    {
      "id": "vv63:29.4",
      "pali": "Sobhanti assā ca ime manojavā."
    },
    {
      "id": "vv63:30.1",
      "pali": "So tiṭṭhasi hemarathe adhiṭṭhito,"
    },
    {
      "id": "vv63:30.2",
      "pali": "Devānamindova sahassavāhano;"
    },
    {
      "id": "vv63:30.3",
      "pali": "Pucchāmi tāhaṁ yasavanta kovidaṁ,"
    },
    {
      "id": "vv63:30.4",
      "pali": "Kathaṁ tayā laddho ayaṁ uḷāro”ti."
    },
    {
      "id": "vv63:31.1",
      "pali": "“Sujāto nāmahaṁ bhante,"
    },
    {
      "id": "vv63:31.2",
      "pali": "rājaputto pure ahuṁ;"
    },
    {
      "id": "vv63:31.3",
      "pali": "Tvañca maṁ anukampāya,"
    },
    {
      "id": "vv63:31.4",
      "pali": "saññamasmiṁ nivesayi."
    },
    {
      "id": "vv63:32.1",
      "pali": "Khīṇāyukañca maṁ ñatvā,"
    },
    {
      "id": "vv63:32.2",
      "pali": "sarīraṁ pādāsi satthuno;"
    },
    {
      "id": "vv63:32.3",
      "pali": "Imaṁ sujāta pūjehi,"
    },
    {
      "id": "vv63:32.4",
      "pali": "taṁ te atthāya hehiti."
    },
    {
      "id": "vv63:33.1",
      "pali": "Tāhaṁ gandhehi mālehi,"
    },
    {
      "id": "vv63:33.2",
      "pali": "pūjayitvā samuyyuto;"
    },
    {
      "id": "vv63:33.3",
      "pali": "Pahāya mānusaṁ dehaṁ,"
    },
    {
      "id": "vv63:33.4",
      "pali": "upapannomhi nandanaṁ."
    },
    {
      "id": "vv63:34.1",
      "pali": "Nandane ca vane ramme,"
    },
    {
      "id": "vv63:34.2",
      "pali": "nānādijagaṇāyute;"
    },
    {
      "id": "vv63:34.3",
      "pali": "Ramāmi naccagītehi,"
    },
    {
      "id": "vv63:34.4",
      "pali": "accharāhi purakkhato”ti."
    },
    {
      "id": "vv63:35.1",
      "pali": "Cūḷarathavimānaṁ terasamaṁ."
    }
  ]
}
