{
  "uid": "thag2.11",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.11:1.1",
      "pali": "“Sussūsā sutavaddhanī,"
    },
    {
      "id": "thag2.11:1.2",
      "pali": "sutaṁ paññāya vaddhanaṁ;"
    },
    {
      "id": "thag2.11:1.3",
      "pali": "Paññāya atthaṁ jānāti,"
    },
    {
      "id": "thag2.11:1.4",
      "pali": "ñāto attho sukhāvaho."
    },
    {
      "id": "thag2.11:2.1",
      "pali": "Sevetha pantāni senāsanāni,"
    },
    {
      "id": "thag2.11:2.2",
      "pali": "Careyya saṁyojanavippamokkhaṁ;"
    },
    {
      "id": "thag2.11:2.3",
      "pali": "Sace ratiṁ nādhigaccheyya tattha,"
    },
    {
      "id": "thag2.11:2.4",
      "pali": "Saṅghe vase rakkhitatto satimā”ti."
    },
    {
      "id": "thag2.11:2.5",
      "pali": "… Mahācundo thero …."
    }
  ]
}
