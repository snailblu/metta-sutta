{
  "uid": "tha-ap516",
  "title": "Ketakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap516:1.1",
      "pali": "“Vinatānadiyā tīre,"
    },
    {
      "id": "tha-ap516:1.2",
      "pali": "vihāsi purisuttamo;"
    },
    {
      "id": "tha-ap516:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap516:1.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "tha-ap516:2.1",
      "pali": "Madhugandhassa pupphena,"
    },
    {
      "id": "tha-ap516:2.2",
      "pali": "ketakassa ahaṁ tadā;"
    },
    {
      "id": "tha-ap516:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap516:2.4",
      "pali": "buddhaseṭṭhamapūjayiṁ."
    },
    {
      "id": "tha-ap516:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap516:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap516:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap516:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap516:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap516:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap516:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap516:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap516:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap516:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap516:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap516:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap516:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap516:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā ketakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap516:8.1",
      "pali": "Ketakapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
