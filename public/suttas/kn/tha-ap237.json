{
  "uid": "tha-ap237",
  "title": "5 Vedikārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap237:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap237:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap237:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap237:1.4",
      "pali": "kāresiṁ vedikaṁ ahaṁ."
    },
    {
      "id": "tha-ap237:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap237:2.2",
      "pali": "kāresiṁ vedikaṁ ahaṁ;"
    },
    {
      "id": "tha-ap237:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap237:2.4",
      "pali": "vedikāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap237:3.1",
      "pali": "Ito ekādase kappe,"
    },
    {
      "id": "tha-ap237:3.2",
      "pali": "ahosiṁ sūriyassamo;"
    },
    {
      "id": "tha-ap237:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap237:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap237:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap237:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap237:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap237:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā vedikārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap237:6.1",
      "pali": "Vedikārakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
