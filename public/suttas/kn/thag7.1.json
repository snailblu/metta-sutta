{
  "uid": "thag7.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag7.1:1.1",
      "pali": "“Alaṅkatā suvasanā,"
    },
    {
      "id": "thag7.1:1.2",
      "pali": "māladhārī vibhūsitā;"
    },
    {
      "id": "thag7.1:1.3",
      "pali": "Alattakakatāpādā,"
    },
    {
      "id": "thag7.1:1.4",
      "pali": "pādukāruyha vesikā."
    },
    {
      "id": "thag7.1:2.1",
      "pali": "Pādukā oruhitvāna,"
    },
    {
      "id": "thag7.1:2.2",
      "pali": "purato pañjalīkatā;"
    },
    {
      "id": "thag7.1:2.3",
      "pali": "Sā maṁ saṇhena mudunā,"
    },
    {
      "id": "thag7.1:2.4",
      "pali": "mhitapubbaṁ abhāsatha."
    },
    {
      "id": "thag7.1:3.1",
      "pali": "Yuvāsi tvaṁ pabbajito,"
    },
    {
      "id": "thag7.1:3.2",
      "pali": "tiṭṭhāhi mama sāsane;"
    },
    {
      "id": "thag7.1:3.3",
      "pali": "Bhuñja mānusake kāme,"
    },
    {
      "id": "thag7.1:3.4",
      "pali": "ahaṁ vittaṁ dadāmi te;"
    },
    {
      "id": "thag7.1:3.5",
      "pali": "Saccaṁ te paṭijānāmi,"
    },
    {
      "id": "thag7.1:3.6",
      "pali": "aggiṁ vā te harāmahaṁ."
    },
    {
      "id": "thag7.1:4.1",
      "pali": "Yadā jiṇṇā bhavissāma,"
    },
    {
      "id": "thag7.1:4.2",
      "pali": "ubho daṇḍaparāyanā;"
    },
    {
      "id": "thag7.1:4.3",
      "pali": "Ubhopi pabbajissāma,"
    },
    {
      "id": "thag7.1:4.4",
      "pali": "ubhayattha kaṭaggaho."
    },
    {
      "id": "thag7.1:5.1",
      "pali": "Tañca disvāna yācantiṁ,"
    },
    {
      "id": "thag7.1:5.2",
      "pali": "vesikaṁ pañjalīkataṁ;"
    },
    {
      "id": "thag7.1:5.3",
      "pali": "Alaṅkataṁ suvasanaṁ,"
    },
    {
      "id": "thag7.1:5.4",
      "pali": "maccupāsaṁva oḍḍitaṁ."
    },
    {
      "id": "thag7.1:6.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag7.1:6.2",
      "pali": "… pe"
    },
    {
      "id": "thag7.1:6.3",
      "pali": "…"
    },
    {
      "id": "thag7.1:6.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag7.1:7.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag7.1:7.2",
      "pali": "… pe"
    },
    {
      "id": "thag7.1:7.3",
      "pali": "…"
    },
    {
      "id": "thag7.1:7.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag7.1:7.5",
      "pali": "… Sundarasamuddo thero …."
    }
  ]
}
