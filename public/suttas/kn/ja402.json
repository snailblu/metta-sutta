{
  "uid": "ja402",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja402:1.1",
      "pali": "“Vibbhantacitto kupitindriyosi,"
    },
    {
      "id": "ja402:1.2",
      "pali": "Nettehi te vārigaṇā savanti;"
    },
    {
      "id": "ja402:1.3",
      "pali": "Kiṁ te naṭṭhaṁ kiṁ pana patthayāno,"
    },
    {
      "id": "ja402:1.4",
      "pali": "Idhāgamā brahme tadiṅgha brūhi”."
    },
    {
      "id": "ja402:2.1",
      "pali": "“Miyyetha bhariyā vajato mamajja,"
    },
    {
      "id": "ja402:2.2",
      "pali": "Agacchato maraṇamāha yakkho;"
    },
    {
      "id": "ja402:2.3",
      "pali": "Etena dukkhena pavedhitosmi,"
    },
    {
      "id": "ja402:2.4",
      "pali": "Akkhāhi me senaka etamatthaṁ”."
    },
    {
      "id": "ja402:3.1",
      "pali": "“Bahūni ṭhānāni vicintayitvā,"
    },
    {
      "id": "ja402:3.2",
      "pali": "Yamettha vakkhāmi tadeva saccaṁ;"
    },
    {
      "id": "ja402:3.3",
      "pali": "Maññāmi te brāhmaṇa sattubhastaṁ,"
    },
    {
      "id": "ja402:3.4",
      "pali": "Ajānato kaṇhasappo paviṭṭho."
    },
    {
      "id": "ja402:4.1",
      "pali": "Ādāya daṇḍaṁ parisumbha bhastaṁ,"
    },
    {
      "id": "ja402:4.2",
      "pali": "Passeḷamūgaṁ uragaṁ dujivhaṁ;"
    },
    {
      "id": "ja402:4.3",
      "pali": "Chindajja kaṅkhaṁ vicikicchitāni,"
    },
    {
      "id": "ja402:4.4",
      "pali": "Bhujaṅgamaṁ passa pamuñca bhastaṁ”."
    },
    {
      "id": "ja402:5.1",
      "pali": "Saṁviggarūpo parisāya majjhe,"
    },
    {
      "id": "ja402:5.2",
      "pali": "So brāhmaṇo sattubhastaṁ pamuñci;"
    },
    {
      "id": "ja402:5.3",
      "pali": "Atha nikkhami urago uggatejo,"
    },
    {
      "id": "ja402:5.4",
      "pali": "Āsīviso sappo phaṇaṁ karitvā."
    },
    {
      "id": "ja402:6.1",
      "pali": "“Suladdhalābhā janakassa rañño,"
    },
    {
      "id": "ja402:6.2",
      "pali": "Yo passatī senakaṁ sādhupaññaṁ;"
    },
    {
      "id": "ja402:6.3",
      "pali": "Vivaṭṭachaddo nusi sabbadassī,"
    },
    {
      "id": "ja402:6.4",
      "pali": "Ñāṇaṁ nu te brāhmaṇa bhiṁsarūpaṁ”."
    },
    {
      "id": "ja402:7.1",
      "pali": "“Imāni me sattasatāni atthi,"
    },
    {
      "id": "ja402:7.2",
      "pali": "Gaṇhāhi sabbāni dadāmi tuyhaṁ;"
    },
    {
      "id": "ja402:7.3",
      "pali": "Tayā hi me jīvitamajja laddhaṁ,"
    },
    {
      "id": "ja402:7.4",
      "pali": "Athopi bhariyāya makāsi sotthiṁ”."
    },
    {
      "id": "ja402:8.1",
      "pali": "“Na paṇḍitā vetanamādiyanti,"
    },
    {
      "id": "ja402:8.2",
      "pali": "Citrāhi gāthāhi subhāsitāhi;"
    },
    {
      "id": "ja402:8.3",
      "pali": "Itopi te brahme dadantu vittaṁ,"
    },
    {
      "id": "ja402:8.4",
      "pali": "Ādāya tvaṁ gaccha sakaṁ niketan”ti."
    },
    {
      "id": "ja402:9.1",
      "pali": "Sattubhastajātakaṁ sattamaṁ."
    }
  ]
}
