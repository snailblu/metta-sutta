{
  "uid": "ja494",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja494:1.1",
      "pali": "“Abbhuto vata lokasmiṁ,"
    },
    {
      "id": "ja494:1.2",
      "pali": "uppajji lomahaṁsano;"
    },
    {
      "id": "ja494:1.3",
      "pali": "Dibbo ratho pāturahu,"
    },
    {
      "id": "ja494:1.4",
      "pali": "vedehassa yasassino”."
    },
    {
      "id": "ja494:2.1",
      "pali": "Devaputto mahiddhiko,"
    },
    {
      "id": "ja494:2.2",
      "pali": "mātali devasārathi;"
    },
    {
      "id": "ja494:2.3",
      "pali": "Nimantayittha rājānaṁ,"
    },
    {
      "id": "ja494:2.4",
      "pali": "vedehaṁ mithilaggahaṁ."
    },
    {
      "id": "ja494:3.1",
      "pali": "“Ehimaṁ rathamāruyha,"
    },
    {
      "id": "ja494:3.2",
      "pali": "rājaseṭṭha disampati;"
    },
    {
      "id": "ja494:3.3",
      "pali": "Devā dassanakāmā te,"
    },
    {
      "id": "ja494:3.4",
      "pali": "tāvatiṁsā saindakā;"
    },
    {
      "id": "ja494:3.5",
      "pali": "Saramānā hi te devā,"
    },
    {
      "id": "ja494:3.6",
      "pali": "sudhammāyaṁ samacchare”."
    },
    {
      "id": "ja494:4.1",
      "pali": "Tato ca rājā sādhino,"
    },
    {
      "id": "ja494:4.2",
      "pali": "vedeho mithilaggaho;"
    },
    {
      "id": "ja494:4.3",
      "pali": "Sahassayuttamāruyha,"
    },
    {
      "id": "ja494:4.4",
      "pali": "agā devāna santike;"
    },
    {
      "id": "ja494:4.5",
      "pali": "Taṁ devā paṭinandiṁsu,"
    },
    {
      "id": "ja494:4.6",
      "pali": "disvā rājānamāgataṁ."
    },
    {
      "id": "ja494:5.1",
      "pali": "“Svāgataṁ te mahārāja,"
    },
    {
      "id": "ja494:5.2",
      "pali": "atho te adurāgataṁ;"
    },
    {
      "id": "ja494:5.3",
      "pali": "Nisīda dāni rājīsi,"
    },
    {
      "id": "ja494:5.4",
      "pali": "devarājassa santike”."
    },
    {
      "id": "ja494:6.1",
      "pali": "Sakkopi paṭinandittha,"
    },
    {
      "id": "ja494:6.2",
      "pali": "vedehaṁ mithilaggahaṁ;"
    },
    {
      "id": "ja494:6.3",
      "pali": "Nimantayittha kāmehi,"
    },
    {
      "id": "ja494:6.4",
      "pali": "āsanena ca vāsavo."
    },
    {
      "id": "ja494:7.1",
      "pali": "“Sādhu khosi anuppatto,"
    },
    {
      "id": "ja494:7.2",
      "pali": "āvāsaṁ vasavattinaṁ;"
    },
    {
      "id": "ja494:7.3",
      "pali": "Vasa devesu rājīsi,"
    },
    {
      "id": "ja494:7.4",
      "pali": "sabbakāmasamiddhisu;"
    },
    {
      "id": "ja494:7.5",
      "pali": "Tāvatiṁsesu devesu,"
    },
    {
      "id": "ja494:7.6",
      "pali": "bhuñja kāme amānuse”."
    },
    {
      "id": "ja494:8.1",
      "pali": "“Ahaṁ pure saggagato ramāmi,"
    },
    {
      "id": "ja494:8.2",
      "pali": "Naccehi gītehi ca vāditehi;"
    },
    {
      "id": "ja494:8.3",
      "pali": "So dāni ajja na ramāmi sagge,"
    },
    {
      "id": "ja494:8.4",
      "pali": "Āyuṁ nu khīṇo maraṇaṁ nu santike;"
    },
    {
      "id": "ja494:8.5",
      "pali": "Udāhu mūḷhosmi janindaseṭṭha”."
    },
    {
      "id": "ja494:9.1",
      "pali": "“Na tāyu khīṇaṁ maraṇañca dūre,"
    },
    {
      "id": "ja494:9.2",
      "pali": "Na cāpi mūḷho naravīraseṭṭha;"
    },
    {
      "id": "ja494:9.3",
      "pali": "Tuyhañca puññāni parittakāni,"
    },
    {
      "id": "ja494:9.4",
      "pali": "Yesaṁ vipākaṁ idha vedayittho."
    },
    {
      "id": "ja494:10.1",
      "pali": "Vasa devānubhāvena,"
    },
    {
      "id": "ja494:10.2",
      "pali": "rājaseṭṭha disampati;"
    },
    {
      "id": "ja494:10.3",
      "pali": "Tāvatiṁsesu devesu,"
    },
    {
      "id": "ja494:10.4",
      "pali": "bhuñja kāme amānuse”."
    },
    {
      "id": "ja494:11.1",
      "pali": "“Yathā yācitakaṁ yānaṁ,"
    },
    {
      "id": "ja494:11.2",
      "pali": "yathā yācitakaṁ dhanaṁ;"
    },
    {
      "id": "ja494:11.3",
      "pali": "Evaṁsampadamevetaṁ,"
    },
    {
      "id": "ja494:11.4",
      "pali": "yaṁ parato dānapaccayā."
    },
    {
      "id": "ja494:12.1",
      "pali": "Na cāhametamicchāmi,"
    },
    {
      "id": "ja494:12.2",
      "pali": "yaṁ parato dānapaccayā;"
    },
    {
      "id": "ja494:12.3",
      "pali": "Sayaṅkatāni puññāni,"
    },
    {
      "id": "ja494:12.4",
      "pali": "taṁ me āveṇikaṁ dhanaṁ."
    },
    {
      "id": "ja494:13.1",
      "pali": "Sohaṁ gantvā manussesu,"
    },
    {
      "id": "ja494:13.2",
      "pali": "kāhāmi kusalaṁ bahuṁ;"
    },
    {
      "id": "ja494:13.3",
      "pali": "Dānena samacariyāya,"
    },
    {
      "id": "ja494:13.4",
      "pali": "saṁyamena damena ca;"
    },
    {
      "id": "ja494:13.5",
      "pali": "Yaṁ katvā sukhito hoti,"
    },
    {
      "id": "ja494:13.6",
      "pali": "na ca pacchānutappati."
    },
    {
      "id": "ja494:14.1",
      "pali": "Imāni tāni khettāni,"
    },
    {
      "id": "ja494:14.2",
      "pali": "imaṁ nikkhaṁ sukuṇḍalaṁ;"
    },
    {
      "id": "ja494:14.3",
      "pali": "Imā tā haritānūpā,"
    },
    {
      "id": "ja494:14.4",
      "pali": "imā najjo savantiyo."
    },
    {
      "id": "ja494:15.1",
      "pali": "Imā tā pokkharaṇī rammā,"
    },
    {
      "id": "ja494:15.2",
      "pali": "cakkavākapakūjitā;"
    },
    {
      "id": "ja494:15.3",
      "pali": "Mandālakehi sañchannā,"
    },
    {
      "id": "ja494:15.4",
      "pali": "padumuppalakehi ca;"
    },
    {
      "id": "ja494:15.5",
      "pali": "Yassimāni mamāyiṁsu,"
    },
    {
      "id": "ja494:15.6",
      "pali": "kiṁ nu te disataṁ gatā."
    },
    {
      "id": "ja494:16.1",
      "pali": "Tānīdha khettāni so bhūmibhāgo,"
    },
    {
      "id": "ja494:16.2",
      "pali": "Teyeva ārāmavanūpacārā;"
    },
    {
      "id": "ja494:16.3",
      "pali": "Tameva mayhaṁ janataṁ apassato,"
    },
    {
      "id": "ja494:16.4",
      "pali": "Suññaṁva me nārada khāyate disā”."
    },
    {
      "id": "ja494:17.1",
      "pali": "“Diṭṭhā mayā vimānāni,"
    },
    {
      "id": "ja494:17.2",
      "pali": "obhāsentā catuddisā;"
    },
    {
      "id": "ja494:17.3",
      "pali": "Sammukhā devarājassa,"
    },
    {
      "id": "ja494:17.4",
      "pali": "tidasānañca sammukhā."
    },
    {
      "id": "ja494:18.1",
      "pali": "Vutthaṁ me bhavanaṁ dibyaṁ,"
    },
    {
      "id": "ja494:18.2",
      "pali": "Bhuttā kāmā amānusā;"
    },
    {
      "id": "ja494:18.3",
      "pali": "Tāvatiṁsesu devesu,"
    },
    {
      "id": "ja494:18.4",
      "pali": "Sabbakāmasamiddhisu."
    },
    {
      "id": "ja494:19.1",
      "pali": "Sohaṁ etādisaṁ hitvā,"
    },
    {
      "id": "ja494:19.2",
      "pali": "puññāyamhi idhāgato;"
    },
    {
      "id": "ja494:19.3",
      "pali": "Dhammameva carissāmi,"
    },
    {
      "id": "ja494:19.4",
      "pali": "nāhaṁ rajjena atthiko."
    },
    {
      "id": "ja494:20.1",
      "pali": "Adaṇḍāvacaraṁ maggaṁ,"
    },
    {
      "id": "ja494:20.2",
      "pali": "sammāsambuddhadesitaṁ;"
    },
    {
      "id": "ja494:20.3",
      "pali": "Taṁ maggaṁ paṭipajjissaṁ,"
    },
    {
      "id": "ja494:20.4",
      "pali": "yena gacchanti subbatā”ti."
    },
    {
      "id": "ja494:21.1",
      "pali": "Sādhinajātakaṁ ekādasamaṁ."
    }
  ]
}
