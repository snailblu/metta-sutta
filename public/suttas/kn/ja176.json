{
  "uid": "ja176",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja176:1.1",
      "pali": "“Bālo vatāyaṁ dumasākhagocaro,"
    },
    {
      "id": "ja176:1.2",
      "pali": "Paññā janinda nayimassa vijjati;"
    },
    {
      "id": "ja176:1.3",
      "pali": "Kaḷāyamuṭṭhiṁ avakiriya kevalaṁ,"
    },
    {
      "id": "ja176:1.4",
      "pali": "Ekaṁ kaḷāyaṁ patitaṁ gavesati”."
    },
    {
      "id": "ja176:2.1",
      "pali": "“Evameva mayaṁ rāja,"
    },
    {
      "id": "ja176:2.2",
      "pali": "ye caññe atilobhino;"
    },
    {
      "id": "ja176:2.3",
      "pali": "Appena bahuṁ jiyyāma,"
    },
    {
      "id": "ja176:2.4",
      "pali": "kaḷāyeneva vānaro”ti."
    },
    {
      "id": "ja176:3.1",
      "pali": "Kaḷāyamuṭṭhijātakaṁ chaṭṭhaṁ."
    }
  ]
}
