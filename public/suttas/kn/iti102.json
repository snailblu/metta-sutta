{
  "uid": "iti102",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti102:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti102:2.1",
      "pali": "“Jānatohaṁ, bhikkhave, passato āsavānaṁ khayaṁ vadāmi, no ajānato no apassato."
    },
    {
      "id": "iti102:2.2",
      "pali": "Kiñca, bhikkhave, jānato, kiṁ passato āsavānaṁ khayo hoti?"
    },
    {
      "id": "iti102:2.3",
      "pali": "Idaṁ dukkhanti, bhikkhave, jānato passato āsavānaṁ khayo hoti. Ayaṁ dukkhasamudayoti, bhikkhave, jānato passato āsavānaṁ khayo hoti. Ayaṁ dukkhanirodhoti, bhikkhave, jānato passato āsavānaṁ khayo hoti. Ayaṁ dukkhanirodhagāminī paṭipadāti, bhikkhave, jānato passato āsavānaṁ khayo hoti."
    },
    {
      "id": "iti102:2.4",
      "pali": "Evaṁ kho, bhikkhave, jānato evaṁ passato āsavānaṁ khayo hotī”ti."
    },
    {
      "id": "iti102:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti102:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti102:3.1",
      "pali": "“Sekhassa sikkhamānassa,"
    },
    {
      "id": "iti102:3.2",
      "pali": "ujumaggānusārino;"
    },
    {
      "id": "iti102:3.3",
      "pali": "Khayasmiṁ paṭhamaṁ ñāṇaṁ,"
    },
    {
      "id": "iti102:3.4",
      "pali": "tato aññā anantarā."
    },
    {
      "id": "iti102:4.1",
      "pali": "Tato aññāvimuttassa,"
    },
    {
      "id": "iti102:4.2",
      "pali": "vimuttiñāṇamuttamaṁ;"
    },
    {
      "id": "iti102:4.3",
      "pali": "Uppajjati khaye ñāṇaṁ,"
    },
    {
      "id": "iti102:4.4",
      "pali": "khīṇā saṁyojanā iti."
    },
    {
      "id": "iti102:5.1",
      "pali": "Na tvevidaṁ kusītena,"
    },
    {
      "id": "iti102:5.2",
      "pali": "bālenamavijānatā;"
    },
    {
      "id": "iti102:5.3",
      "pali": "Nibbānaṁ adhigantabbaṁ,"
    },
    {
      "id": "iti102:5.4",
      "pali": "sabbaganthappamocanan”ti."
    },
    {
      "id": "iti102:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti102:6.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
