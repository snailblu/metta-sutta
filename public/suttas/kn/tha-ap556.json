{
  "uid": "tha-ap556",
  "title": "4 Kimilattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap556:1.1",
      "pali": "“Nibbute kakusandhamhi,"
    },
    {
      "id": "tha-ap556:1.2",
      "pali": "brāhmaṇamhi vusīmati;"
    },
    {
      "id": "tha-ap556:1.3",
      "pali": "Gahetvā salalaṁ mālaṁ,"
    },
    {
      "id": "tha-ap556:1.4",
      "pali": "maṇḍapaṁ kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap556:2.1",
      "pali": "Tāvatiṁsaṁ gato santo,"
    },
    {
      "id": "tha-ap556:2.2",
      "pali": "labhimha byamhamuttamaṁ;"
    },
    {
      "id": "tha-ap556:2.3",
      "pali": "Aññe devetirocāmi,"
    },
    {
      "id": "tha-ap556:2.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap556:3.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "tha-ap556:3.2",
      "pali": "caṅkamanto ṭhito cahaṁ;"
    },
    {
      "id": "tha-ap556:3.3",
      "pali": "Channo salalapupphehi,"
    },
    {
      "id": "tha-ap556:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap556:4.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "tha-ap556:4.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap556:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap556:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap556:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap556:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap556:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap556:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap556:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap556:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap556:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap556:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap556:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap556:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā kimilo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap556:9.1",
      "pali": "Kimilattherassāpadānaṁ catutthaṁ."
    }
  ]
}
