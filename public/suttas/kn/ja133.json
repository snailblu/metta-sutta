{
  "uid": "ja133",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja133:1.1",
      "pali": "“Khemaṁ yahiṁ tattha arī udīrito,"
    },
    {
      "id": "ja133:1.2",
      "pali": "Dakassa majjhe jalate ghatāsano;"
    },
    {
      "id": "ja133:1.3",
      "pali": "Na ajja vāso mahiyā mahīruhe,"
    },
    {
      "id": "ja133:1.4",
      "pali": "Disā bhajavho saraṇājja no bhayan”ti."
    },
    {
      "id": "ja133:2.1",
      "pali": "Ghatāsanajātakaṁ tatiyaṁ."
    }
  ]
}
