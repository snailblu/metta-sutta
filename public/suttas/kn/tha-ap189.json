{
  "uid": "tha-ap189",
  "title": "Ekacintikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap189:1.1",
      "pali": "“Yadā devo devakāyā,"
    },
    {
      "id": "tha-ap189:1.2",
      "pali": "cavate āyusaṅkhayā;"
    },
    {
      "id": "tha-ap189:1.3",
      "pali": "Tayo saddā niccharanti,"
    },
    {
      "id": "tha-ap189:1.4",
      "pali": "devānaṁ anumodataṁ."
    },
    {
      "id": "tha-ap189:2.1",
      "pali": "‘Ito bho sugatiṁ gaccha,"
    },
    {
      "id": "tha-ap189:2.2",
      "pali": "manussānaṁ sahabyataṁ;"
    },
    {
      "id": "tha-ap189:2.3",
      "pali": "Manussabhūto saddhamme,"
    },
    {
      "id": "tha-ap189:2.4",
      "pali": "labha saddhaṁ anuttaraṁ."
    },
    {
      "id": "tha-ap189:3.1",
      "pali": "Sā te saddhā niviṭṭhāssa,"
    },
    {
      "id": "tha-ap189:3.2",
      "pali": "mūlajātā patiṭṭhitā;"
    },
    {
      "id": "tha-ap189:3.3",
      "pali": "Yāvajīvaṁ asaṁhīrā,"
    },
    {
      "id": "tha-ap189:3.4",
      "pali": "saddhamme suppavedite."
    },
    {
      "id": "tha-ap189:4.1",
      "pali": "Kāyena kusalaṁ katvā,"
    },
    {
      "id": "tha-ap189:4.2",
      "pali": "vācāya kusalaṁ bahuṁ;"
    },
    {
      "id": "tha-ap189:4.3",
      "pali": "Manasā kusalaṁ katvā,"
    },
    {
      "id": "tha-ap189:4.4",
      "pali": "abyāpajjaṁ nirūpadhiṁ."
    },
    {
      "id": "tha-ap189:5.1",
      "pali": "Tato opadhikaṁ puññaṁ,"
    },
    {
      "id": "tha-ap189:5.2",
      "pali": "katvā dānena taṁ bahuṁ;"
    },
    {
      "id": "tha-ap189:5.3",
      "pali": "Aññepi macce saddhamme,"
    },
    {
      "id": "tha-ap189:5.4",
      "pali": "brahmacariye nivesaya’."
    },
    {
      "id": "tha-ap189:6.1",
      "pali": "Imāya anukampāya,"
    },
    {
      "id": "tha-ap189:6.2",
      "pali": "devā devaṁ yadā vidū;"
    },
    {
      "id": "tha-ap189:6.3",
      "pali": "Cavantaṁ anumodanti,"
    },
    {
      "id": "tha-ap189:6.4",
      "pali": "ehi deva punappunaṁ."
    },
    {
      "id": "tha-ap189:7.1",
      "pali": "Saṁvego me tadā āsi,"
    },
    {
      "id": "tha-ap189:7.2",
      "pali": "devasaṅghe samāgate;"
    },
    {
      "id": "tha-ap189:7.3",
      "pali": "Kaṁ su nāma ahaṁ yoniṁ,"
    },
    {
      "id": "tha-ap189:7.4",
      "pali": "gamissāmi ito cuto."
    },
    {
      "id": "tha-ap189:8.1",
      "pali": "Mama saṁvegamaññāya,"
    },
    {
      "id": "tha-ap189:8.2",
      "pali": "samaṇo bhāvitindriyo;"
    },
    {
      "id": "tha-ap189:8.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap189:8.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap189:9.1",
      "pali": "Sumano nāma nāmena,"
    },
    {
      "id": "tha-ap189:9.2",
      "pali": "padumuttarasāvako;"
    },
    {
      "id": "tha-ap189:9.3",
      "pali": "Atthadhammānusāsitvā,"
    },
    {
      "id": "tha-ap189:9.4",
      "pali": "saṁvejesi mamaṁ tadā."
    },
    {
      "id": "tha-ap189:10.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "tha-ap189:10.2",
      "pali": "buddhe cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap189:10.3",
      "pali": "Taṁ dhīraṁ abhivādetvā,"
    },
    {
      "id": "tha-ap189:10.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap189:11.1",
      "pali": "Upapajjiṁ sa tattheva,"
    },
    {
      "id": "tha-ap189:11.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap189:11.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap189:11.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap189:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap189:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap189:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap189:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekacintiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap189:14.1",
      "pali": "Ekacintikattherassāpadānaṁ sattamaṁ."
    }
  ]
}
