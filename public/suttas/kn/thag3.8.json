{
  "uid": "thag3.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.8:1.1",
      "pali": "“Ekopi saddho medhāvī,"
    },
    {
      "id": "thag3.8:1.2",
      "pali": "assaddhānīdha ñātinaṁ;"
    },
    {
      "id": "thag3.8:1.3",
      "pali": "Dhammaṭṭho sīlasampanno,"
    },
    {
      "id": "thag3.8:1.4",
      "pali": "hoti atthāya bandhunaṁ."
    },
    {
      "id": "thag3.8:2.1",
      "pali": "Niggayha anukampāya,"
    },
    {
      "id": "thag3.8:2.2",
      "pali": "coditā ñātayo mayā;"
    },
    {
      "id": "thag3.8:2.3",
      "pali": "Ñātibandhavapemena,"
    },
    {
      "id": "thag3.8:2.4",
      "pali": "kāraṁ katvāna bhikkhusu."
    },
    {
      "id": "thag3.8:3.1",
      "pali": "Te abbhatītā kālaṅkatā,"
    },
    {
      "id": "thag3.8:3.2",
      "pali": "pattā te tidivaṁ sukhaṁ;"
    },
    {
      "id": "thag3.8:3.3",
      "pali": "Bhātaro mayhaṁ mātā ca,"
    },
    {
      "id": "thag3.8:3.4",
      "pali": "modanti kāmakāmino”ti."
    },
    {
      "id": "thag3.8:3.5",
      "pali": "… Vassiko thero …."
    }
  ]
}
