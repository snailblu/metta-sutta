{
  "uid": "cnd10",
  "title": "Pucchāniddesa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cnd10:1.1",
      "pali": "<b>Eko ahaṁ sakka mahantamoghaṁ,</b>"
    },
    {
      "id": "cnd10:1.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd10:1.3",
      "pali": "<b>Anissito no visahāmi tārituṁ;</b>"
    },
    {
      "id": "cnd10:1.4",
      "pali": "<b>Ārammaṇaṁ brūhi samantacakkhu,</b>"
    },
    {
      "id": "cnd10:1.5",
      "pali": "<b>Yaṁ nissito oghamimaṁ tareyyaṁ.</b>"
    },
    {
      "id": "cnd10:2.1",
      "pali": "<b>Eko ahaṁ sakka mahantamoghan</b>ti."
    },
    {
      "id": "cnd10:2.2",
      "pali": "<b>Eko</b>ti puggalo vā me dutiyo natthi, dhammo vā me dutiyo natthi, yaṁ vā puggalaṁ nissāya dhammaṁ vā nissāya mahantaṁ kāmoghaṁ bhavoghaṁ diṭṭhoghaṁ avijjoghaṁ tareyyaṁ uttareyyaṁ patareyyaṁ samatikkameyyaṁ vītivatteyyanti."
    },
    {
      "id": "cnd10:2.3",
      "pali": "<b>Sakkā</b>ti sakko."
    },
    {
      "id": "cnd10:2.4",
      "pali": "Bhagavā sakyakulā pabbajitotipi sakko."
    },
    {
      "id": "cnd10:2.5",
      "pali": "Atha vā aḍḍho mahaddhano dhanavātipi sakko."
    },
    {
      "id": "cnd10:2.6",
      "pali": "Tassimāni dhanāni, seyyathidaṁ—"
    },
    {
      "id": "cnd10:2.7",
      "pali": "saddhādhanaṁ sīladhanaṁ hiridhanaṁ ottappadhanaṁ sutadhanaṁ cāgadhanaṁ paññādhanaṁ satipaṭṭhānadhanaṁ …pe…"
    },
    {
      "id": "cnd10:2.8",
      "pali": "nibbānadhanaṁ."
    },
    {
      "id": "cnd10:2.9",
      "pali": "Imehi anekehi dhanaratanehi aḍḍho mahaddhano dhanavātipi sakko."
    },
    {
      "id": "cnd10:2.10",
      "pali": "Atha vā sakko pahu visavī alamatto sūro vīro vikkanto abhīrū achambhī anutrāsī apalāyī pahīnabhayabheravo vigatalomahaṁsotipi sakkoti—"
    },
    {
      "id": "cnd10:2.11",
      "pali": "eko ahaṁ sakka mahantamoghaṁ."
    },
    {
      "id": "cnd10:3.1",
      "pali": "<b>Iccāyasmā upasīvo</b>ti."
    },
    {
      "id": "cnd10:3.2",
      "pali": "<b>Iccā</b>ti padasandhi …pe…."
    },
    {
      "id": "cnd10:3.3",
      "pali": "<b>Āyasmā</b>ti piyavacanaṁ …pe…."
    },
    {
      "id": "cnd10:3.4",
      "pali": "<b>Upasīvo</b>ti tassa brāhmaṇassa nāmaṁ …pe… abhilāpoti—"
    },
    {
      "id": "cnd10:3.5",
      "pali": "iccāyasmā upasīvo."
    },
    {
      "id": "cnd10:4.1",
      "pali": "<b>Anissito no visahāmi tāritun</b>ti."
    },
    {
      "id": "cnd10:4.2",
      "pali": "<b>Anissito</b>ti puggalaṁ vā anissito dhammaṁ vā anissito no visahāmi na ussahāmi na sakkomi na paṭibalo mahantaṁ kāmoghaṁ bhavoghaṁ diṭṭhoghaṁ avijjoghaṁ tarituṁ uttarituṁ patarituṁ samatikkamituṁ vītivattitunti—"
    },
    {
      "id": "cnd10:4.3",
      "pali": "anissito no visahāmi tārituṁ."
    },
    {
      "id": "cnd10:5.1",
      "pali": "<b>Ārammaṇaṁ brūhi samantacakkhū</b>ti ārammaṇaṁ ālambaṇaṁ nissayaṁ upanissayaṁ brūhi ācikkhāhi desehi paññapehi paṭṭhapehi vivarāhi vibhajāhi uttānīkarohi pakāsehi."
    },
    {
      "id": "cnd10:5.2",
      "pali": "<b>Samantacakkhū</b>ti samantacakkhu vuccati sabbaññutañāṇaṁ."
    },
    {
      "id": "cnd10:5.3",
      "pali": "Bhagavā tena sabbaññutañāṇena upeto samupeto upāgato samupāgato upapanno samupapanno samannāgato."
    },
    {
      "id": "cnd10:6.1",
      "pali": "Na tassa adiṭṭhamidhatthi kiñci,"
    },
    {
      "id": "cnd10:6.2",
      "pali": "Atho aviññātamajānitabbaṁ;"
    },
    {
      "id": "cnd10:6.3",
      "pali": "Sabbaṁ abhiññāsi yadatthi neyyaṁ,"
    },
    {
      "id": "cnd10:6.4",
      "pali": "Tathāgato tena samantacakkhūti."
    },
    {
      "id": "cnd10:7.1",
      "pali": "Ārammaṇaṁ brūhi samantacakkhu."
    },
    {
      "id": "cnd10:8.1",
      "pali": "<b>Yaṁ nissito oghamimaṁ tareyyan</b>ti."
    },
    {
      "id": "cnd10:8.2",
      "pali": "<b>Yaṁ nissito</b>ti yaṁ puggalaṁ vā nissito dhammaṁ vā nissito mahantaṁ kāmoghaṁ bhavoghaṁ diṭṭhoghaṁ avijjoghaṁ tareyyaṁ uttareyyaṁ patareyyaṁ samatikkameyyaṁ vītivatteyyanti—"
    },
    {
      "id": "cnd10:8.3",
      "pali": "yaṁ nissito oghamimaṁ tareyyaṁ."
    },
    {
      "id": "cnd10:8.4",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd10:9.1",
      "pali": "“Eko ahaṁ sakka mahantamoghaṁ,"
    },
    {
      "id": "cnd10:9.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd10:9.3",
      "pali": "Anissito no visahāmi tārituṁ;"
    },
    {
      "id": "cnd10:9.4",
      "pali": "Ārammaṇaṁ brūhi samantacakkhu,"
    },
    {
      "id": "cnd10:9.5",
      "pali": "Yaṁ nissito oghamimaṁ tareyyan”ti."
    },
    {
      "id": "cnd10:10.1",
      "pali": "<b>Ākiñcaññaṁ pekkhamāno satimā,</b>"
    },
    {
      "id": "cnd10:10.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:10.3",
      "pali": "<b>Natthīti nissāya tarassu oghaṁ;</b>"
    },
    {
      "id": "cnd10:10.4",
      "pali": "<b>Kāme pahāya virato kathāhi,</b>"
    },
    {
      "id": "cnd10:10.5",
      "pali": "<b>Taṇhakkhayaṁ nattamahābhipassa.</b>"
    },
    {
      "id": "cnd10:11.1",
      "pali": "<b>Ākiñcaññaṁ pekkhamāno satimā</b>ti so brāhmaṇo pakatiyā ākiñcaññāyatanasamāpattiṁ lābhīyeva nissayaṁ na jānāti—"
    },
    {
      "id": "cnd10:11.2",
      "pali": "“ayaṁ me nissayo”ti."
    },
    {
      "id": "cnd10:11.3",
      "pali": "Tassa bhagavā nissayañca ācikkhati uttariñca niyyānapathaṁ."
    },
    {
      "id": "cnd10:11.4",
      "pali": "Ākiñcaññāyatanasamāpattiṁ sato samāpajjitvā tato vuṭṭhahitvā tattha jāte cittacetasike dhamme aniccato pekkhamāno, dukkhato …pe…"
    },
