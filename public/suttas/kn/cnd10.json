    },
    {
      "id": "cnd10:11.45",
      "pali": "nissaraṇato pekkhamāno dakkhamāno olokayamāno nijjhāyamāno upaparikkhamāno."
    },
    {
      "id": "cnd10:12.1",
      "pali": "<b>Satimā</b>ti yā sati anussati paṭissati …pe… sammāsati—"
    },
    {
      "id": "cnd10:12.2",
      "pali": "ayaṁ vuccati sati."
    },
    {
      "id": "cnd10:12.3",
      "pali": "Imāya satiyā upeto hoti …pe… samannāgato, so vuccati satimāti—"
    },
    {
      "id": "cnd10:12.4",
      "pali": "ākiñcaññaṁ pekkhamāno satimā."
    },
    {
      "id": "cnd10:13.1",
      "pali": "<b>Upasīvāti bhagavā</b>ti."
    },
    {
      "id": "cnd10:13.2",
      "pali": "<b>Upasīvā</b>ti bhagavā taṁ brāhmaṇaṁ nāmena ālapati."
    },
    {
      "id": "cnd10:13.3",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd10:13.4",
      "pali": "upasīvāti bhagavā."
    },
    {
      "id": "cnd10:14.1",
      "pali": "<b>Natthīti nissāya tarassu oghan</b>ti natthi kiñcīti ākiñcaññāyatanasamāpatti."
    },
    {
      "id": "cnd10:14.2",
      "pali": "Kiṅkāraṇā natthi kiñcīti ākiñcaññāyatanasamāpatti?"
    },
    {
      "id": "cnd10:14.3",
      "pali": "Viññāṇañcāyatanasamāpattiṁ sato samāpajjitvā tato vuṭṭhahitvā taññeva viññāṇaṁ abhāveti, vibhāveti, antaradhāpeti, natthi kiñcīti passati."
    },
    {
      "id": "cnd10:14.4",
      "pali": "Taṅkāraṇā natthi kiñcīti ākiñcaññāyatanasamāpattiṁ nissāya upanissāya ālambaṇaṁ karitvā kāmoghaṁ bhavoghaṁ diṭṭhoghaṁ avijjoghaṁ tarassu uttarassu patarassu samatikkamassu vītivattassūti—"
    },
    {
      "id": "cnd10:14.5",
      "pali": "natthīti nissāya tarassu oghaṁ."
    },
    {
      "id": "cnd10:15.1",
      "pali": "<b>Kāme pahāya virato kathāhī</b>ti."
    },
    {
      "id": "cnd10:15.2",
      "pali": "<b>Kāmā</b>ti uddānato dve kāmā—"
    },
    {
      "id": "cnd10:15.3",
      "pali": "vatthukāmā ca kilesakāmā ca …pe…"
    },
    {
      "id": "cnd10:15.4",
      "pali": "ime vuccanti vatthukāmā …pe…"
    },
    {
      "id": "cnd10:15.5",
      "pali": "ime vuccanti kilesakāmā."
    },
    {
      "id": "cnd10:15.6",
      "pali": "<b>Kāme pahāyā</b>ti vatthukāme parijānitvā kilesakāme pahāya pajahitvā vinodetvā byantīkaritvā anabhāvaṁ gametvāti—"
    },
    {
      "id": "cnd10:15.7",
      "pali": "kāme pahāya."
    },
    {
      "id": "cnd10:15.8",
      "pali": "<b>Virato kathāhī</b>ti kathaṅkathā vuccati vicikicchā."
    },
    {
      "id": "cnd10:15.9",
      "pali": "Dukkhe kaṅkhā …pe… chambhitattaṁ cittassa manovilekho kathaṅkathāya ārato virato paṭivirato nikkhanto nissaṭo vippamutto visaññutto vimariyādikatena cetasā viharatīti—"
    },
    {
      "id": "cnd10:15.10",
      "pali": "evampi virato kathāhi …pe…"
    },
    {
      "id": "cnd10:15.11",
      "pali": "atha vā dvattiṁsāya tiracchānakathāya ārato virato paṭivirato nikkhanto nissaṭo vippamutto visaññutto vimariyādikatena cetasā viharatīti evampi virato kathāhīti—"
    },
    {
      "id": "cnd10:15.12",
      "pali": "kāme pahāya virato kathāhi."
    },
    {
      "id": "cnd10:16.1",
      "pali": "<b>Taṇhakkhayaṁ nattamahābhipassā</b>ti."
    },
    {
      "id": "cnd10:16.2",
      "pali": "<b>Taṇhā</b>ti rūpataṇhā …pe… dhammataṇhā."
    },
    {
      "id": "cnd10:16.3",
      "pali": "<b>Nattaṁ</b> vuccati ratti."
    },
    {
      "id": "cnd10:16.4",
      "pali": "<b>Aho</b>ti divaso."
    },
    {
      "id": "cnd10:16.5",
      "pali": "Rattiñca divā ca taṇhakkhayaṁ rāgakkhayaṁ dosakkhayaṁ mohakkhayaṁ gatikkhayaṁ upapattikkhayaṁ paṭisandhikkhayaṁ bhavakkhayaṁ saṁsārakkhayaṁ vaṭṭakkhayaṁ passa abhipassa dakkha olokaya nijjhāya upaparikkhāti—"
    },
    {
      "id": "cnd10:16.6",
      "pali": "taṇhakkhayaṁ nattamahābhipassa."
    },
    {
      "id": "cnd10:16.7",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd10:17.1",
      "pali": "“Ākiñcaññaṁ pekkhamāno satimā,"
    },
    {
      "id": "cnd10:17.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:17.3",
      "pali": "Natthīti nissāya tarassu oghaṁ;"
    },
    {
      "id": "cnd10:17.4",
      "pali": "Kāme pahāya virato kathāhi,"
    },
    {
      "id": "cnd10:17.5",
      "pali": "Taṇhakkhayaṁ nattamahābhipassā”ti."
    },
    {
      "id": "cnd10:18.1",
      "pali": "<b>Sabbesu kāmesu yo vītarāgo,</b>"
    },
    {
      "id": "cnd10:18.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd10:18.3",
      "pali": "<b>Ākiñcaññaṁ nissito hitvā maññaṁ;</b>"
    },
    {
      "id": "cnd10:18.4",
      "pali": "<b>Saññāvimokkhe paramedhimutto,</b>"
    },
    {
      "id": "cnd10:18.5",
      "pali": "<b>Tiṭṭhe nu so tattha anānuyāyī.</b>"
    },
    {
      "id": "cnd10:19.1",
      "pali": "<b>Sabbesu kāmesu yo vītarāgo</b>ti."
    },
    {
      "id": "cnd10:19.2",
      "pali": "<b>Sabbesū</b>ti sabbena sabbaṁ sabbathā sabbaṁ asesaṁ nissesaṁ pariyādiyanavacanametaṁ sabbesūti."
    },
    {
      "id": "cnd10:19.3",
      "pali": "<b>Kāmesū</b>ti <b>kāmā</b>ti uddānato dve kāmā—"
    },
    {
      "id": "cnd10:19.4",
      "pali": "vatthukāmā ca kilesakāmā ca …pe…"
    },
    {
      "id": "cnd10:19.5",
      "pali": "ime vuccanti vatthukāmā …pe…"
    },
    {
      "id": "cnd10:19.6",
      "pali": "ime vuccanti kilesakāmā."
    },
    {
      "id": "cnd10:19.7",
      "pali": "Sabbesu kāmesu yo vītarāgoti."
    },
    {
      "id": "cnd10:19.8",
      "pali": "Sabbesu kāmesu yo vītarāgo vigatarāgo cattarāgo vantarāgo muttarāgo pahīnarāgo paṭinissaṭṭharāgo vikkhambhanatoti—"
    },
    {
      "id": "cnd10:19.9",
      "pali": "sabbesu kāmesu yo vītarāgo."
    },
    {
      "id": "cnd10:20.1",
      "pali": "<b>Iccāyasmā upasīvo</b>ti."
    },
    {
      "id": "cnd10:20.2",
      "pali": "<b>Iccā</b>ti padasandhi …pe…."
    },
    {
      "id": "cnd10:20.3",
      "pali": "<b>Āyasmā</b>ti piyavacanaṁ …pe…."
    },
    {
      "id": "cnd10:20.4",
      "pali": "<b>Upasīvo</b>ti tassa brāhmaṇassa nāmaṁ …pe… abhilāpoti—"
    },
    {
      "id": "cnd10:20.5",
      "pali": "iccāyasmā upasīvo."
    },
    {
      "id": "cnd10:21.1",
      "pali": "<b>Ākiñcaññaṁ nissito hitvā maññan</b>ti."
    },
    {
      "id": "cnd10:21.2",
      "pali": "Heṭṭhimā cha samāpattiyo hitvā cajitvā pariccajitvā atikkamitvā samatikkamitvā vītivattitvā ākiñcaññāyatanasamāpattiṁ nissito allīno upagato samupagato ajjhosito adhimuttoti—"
    },
    {
      "id": "cnd10:21.3",
      "pali": "ākiñcaññaṁ nissito hitvā maññaṁ."
    },
    {
      "id": "cnd10:22.1",
      "pali": "<b>Saññāvimokkhe paramedhimutto</b>ti saññāvimokkhā vuccanti satta saññāsamāpattiyo."
    },
    {
      "id": "cnd10:22.2",
      "pali": "Tāsaṁ saññāsamāpattīnaṁ ākiñcaññāyatanasamāpattivimokkho aggo ca seṭṭho ca viseṭṭho ca pāmokkho ca uttamo ca pavaro ca, parame agge seṭṭhe viseṭṭhe pāmokkhe uttame pavare adhimuttivimokkhena adhimutto tatrādhimutto tadadhimutto taccarito tabbahulo taggaruko tanninno tappoṇo tappabbhāro tadadhimutto tadadhipateyyoti—"
    },
    {
      "id": "cnd10:22.3",
      "pali": "saññāvimokkhe paramedhimutto."
    },
    {
      "id": "cnd10:23.1",
      "pali": "<b>Tiṭṭhe nu so tattha anānuyāyī</b>ti."
    },
    {
      "id": "cnd10:23.2",
      "pali": "<b>Tiṭṭhe nū</b>ti saṁsayapucchā vimatipucchā dveḷhakapucchā anekaṁsapucchā, “evaṁ nu kho, nanu kho, kiṁ nu kho, kathaṁ nu kho”ti—"
    },
    {
      "id": "cnd10:23.3",
      "pali": "tiṭṭhe nu."
    },
    {
      "id": "cnd10:23.4",
      "pali": "<b>Tatthā</b>ti ākiñcaññāyatane."
    },
    {
      "id": "cnd10:23.5",
      "pali": "<b>Anānuyāyī</b>ti anānuyāyī aviccamāno avigacchamāno anantaradhāyamāno aparihāyamāno …pe…."
    },
    {
      "id": "cnd10:23.6",
      "pali": "Atha vā arajjamāno adussamāno amuyhamāno akilissamānoti—"
    },
    {
      "id": "cnd10:23.7",
      "pali": "tiṭṭhe nu so tattha anānuyāyī."
    },
    {
      "id": "cnd10:23.8",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd10:24.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "cnd10:24.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "cnd10:24.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "cnd10:24.4",
      "pali": "Saññāvimokkhe paramedhimutto,"
    },
    {
      "id": "cnd10:24.5",
      "pali": "Tiṭṭhe nu so tattha anānuyāyī”ti."
    },
    {
      "id": "cnd10:25.1",
      "pali": "<b>Sabbesu kāmesu yo vītarāgo,</b>"
    },
    {
      "id": "cnd10:25.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:25.3",
      "pali": "<b>Ākiñcaññaṁ nissito hitvā maññaṁ;</b>"
    },
    {
      "id": "cnd10:25.4",
      "pali": "<b>Saññāvimokkhe paramedhimutto,</b>"
    },
    {
      "id": "cnd10:25.5",
      "pali": "<b>Tiṭṭheyya so tattha anānuyāyī.</b>"
    },
    {
      "id": "cnd10:26.1",
      "pali": "<b>Sabbesu kāmesu yo vītarāgo</b>ti."
    },
    {
      "id": "cnd10:26.2",
      "pali": "<b>Sabbesū</b>ti sabbena sabbaṁ sabbathā sabbaṁ asesaṁ nissesaṁ pariyādiyanavacanametaṁ sabbesūti."
    },
    {
      "id": "cnd10:26.3",
      "pali": "<b>Kāmesū</b>ti <b>kāmā</b>ti uddānato dve kāmā—"
    },
    {
      "id": "cnd10:26.4",
      "pali": "vatthukāmā ca kilesakāmā ca …pe…"
    },
    {
      "id": "cnd10:26.5",
      "pali": "ime vuccanti vatthukāmā …pe…"
    },
    {
      "id": "cnd10:26.6",
      "pali": "ime vuccanti kilesakāmā."
    },
    {
      "id": "cnd10:26.7",
      "pali": "<b>Sabbesu kāmesu yo vītarāgo</b>ti sabbesu kāmesu yo vītarāgo …pe…"
    },
    {
      "id": "cnd10:26.8",
      "pali": "paṭinissaṭṭharāgo vikkhambhanatoti—"
    },
    {
      "id": "cnd10:26.9",
      "pali": "sabbesu kāmesu yo vītarāgo."
    },
    {
      "id": "cnd10:27.1",
      "pali": "<b>Upasīvāti bhagavā</b>ti."
    },
    {
      "id": "cnd10:27.2",
      "pali": "<b>Upasīvā</b>ti bhagavā taṁ brāhmaṇaṁ nāmena ālapati."
    },
    {
      "id": "cnd10:27.3",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd10:27.4",
      "pali": "upasīvāti bhagavā."
    },
    {
      "id": "cnd10:28.1",
      "pali": "<b>Ākiñcaññaṁ nissito hitvā maññan</b>ti."
    },
    {
      "id": "cnd10:28.2",
      "pali": "Heṭṭhimā cha samāpattiyo hitvā cajitvā pariccajitvā atikkamitvā samatikkamitvā vītivattitvā ākiñcaññāyatanasamāpattiṁ nissito allīno upagato samupagato ajjhosito adhimuttoti—"
    },
    {
      "id": "cnd10:28.3",
      "pali": "ākiñcaññaṁ nissito hitvā maññaṁ."
    },
    {
      "id": "cnd10:29.1",
      "pali": "<b>Saññāvimokkhe paramedhimutto</b>ti saññāvimokkhā vuccanti satta saññāsamāpattiyo."
    },
    {
      "id": "cnd10:29.2",
      "pali": "Tāsaṁ saññāsamāpattīnaṁ ākiñcaññāyatanasamāpattivimokkho aggo ca seṭṭho ca viseṭṭho ca pāmokkho ca uttamo ca pavaro ca, parame agge seṭṭhe viseṭṭhe pāmokkhe uttame pavare adhimuttivimokkhena adhimutto tatrādhimutto tadadhimutto …pe…"
    },
    {
      "id": "cnd10:29.3",
      "pali": "tadadhipateyyoti—"
    },
    {
      "id": "cnd10:29.4",
      "pali": "saññāvimokkhe paramedhimutto."
    },
    {
      "id": "cnd10:30.1",
      "pali": "<b>Tiṭṭheyya so tattha anānuyāyī</b>ti."
    },
    {
      "id": "cnd10:30.2",
      "pali": "<b>Tiṭṭheyyā</b>ti tiṭṭheyya saṭṭhikappasahassāni."
    },
    {
      "id": "cnd10:30.3",
      "pali": "<b>Tatthā</b>ti ākiñcaññāyatane."
    },
    {
      "id": "cnd10:30.4",
      "pali": "<b>Anānuyāyī</b>ti anānuyāyī aviccamāno avigacchamāno anantaradhāyamāno aparihāyamāno."
    },
    {
      "id": "cnd10:30.5",
      "pali": "Atha vā arajjamāno adussamāno amuyhamāno akilissamānoti—"
    },
    {
      "id": "cnd10:30.6",
      "pali": "tiṭṭheyya so tattha anānuyāyī."
    },
    {
      "id": "cnd10:30.7",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd10:31.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "cnd10:31.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:31.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "cnd10:31.4",
      "pali": "Saññāvimokkhe paramedhimutto,"
    },
    {
      "id": "cnd10:31.5",
      "pali": "Tiṭṭheyya so tattha anānuyāyī”ti."
    },
    {
      "id": "cnd10:32.1",
      "pali": "<b>Tiṭṭhe ce so tattha anānuyāyī,</b>"
    },
    {
      "id": "cnd10:32.2",
      "pali": "<b>Pūgampi vassāni samantacakkhu;</b>"
    },
    {
      "id": "cnd10:32.3",
      "pali": "<b>Tattheva so sītisiyā vimutto,</b>"
    },
    {
      "id": "cnd10:32.4",
      "pali": "<b>Cavetha viññāṇaṁ tathāvidhassa.</b>"
    },
    {
      "id": "cnd10:33.1",
      "pali": "<b>Tiṭṭhe ce so tattha anānuyāyī</b>ti sace so tiṭṭheyya saṭṭhikappasahassāni."
    },
    {
      "id": "cnd10:33.2",
      "pali": "<b>Tatthā</b>ti ākiñcaññāyatane."
    },
    {
      "id": "cnd10:33.3",
      "pali": "<b>Anānuyāyī</b>ti anānuyāyī aviccamāno avigacchamāno anantaradhāyamāno aparihāyamāno."
    },
    {
      "id": "cnd10:33.4",
      "pali": "Atha vā arajjamāno adussamāno amuyhamāno akilissamānoti—"
    },
    {
      "id": "cnd10:33.5",
      "pali": "tiṭṭhe ce so tattha anānuyāyī."
    },
    {
      "id": "cnd10:34.1",
      "pali": "<b>Pūgampi vassāni samantacakkhū</b>ti."
    },
    {
      "id": "cnd10:34.2",
      "pali": "<b>Pūgampi vassānī</b>ti pūgampi vassāni bahūni vassāni bahūni vassasatāni bahūni vassasahassāni bahūni vassasatasahassāni bahūni kappāni bahūni kappasatāni bahūni kappasahassāni bahūni kappasatasahassāni."
    },
    {
      "id": "cnd10:34.3",
      "pali": "<b>Samantacakkhū</b>ti samantacakkhu vuccati sabbaññutañāṇaṁ …pe…"
    },
    {
      "id": "cnd10:34.4",
      "pali": "tathāgato tena samantacakkhūti—"
    },
    {
      "id": "cnd10:34.5",
      "pali": "pūgampi vassāni samantacakkhu."
    },
    {
      "id": "cnd10:35.1",
      "pali": "<b>Tattheva so sītisiyā vimutto, cavetha viññāṇaṁ tathāvidhassā</b>ti tattheva so sītibhāvamanuppatto nicco dhuvo sassato avipariṇāmadhammo sassatisamaṁ tatheva tiṭṭheyya."
    },
    {
      "id": "cnd10:35.2",
      "pali": "Atha vā tassa viññāṇaṁ caveyya ucchijjeyya nasseyya vinasseyya na bhaveyyāti punabbhavapaṭisandhiviññāṇaṁ nibbatteyya kāmadhātuyā vā rūpadhātuyā vā arūpadhātuyā vāti ākiñcaññāyatanaṁ samāpannassa sassatañca ucchedañca pucchati."
    },
    {
      "id": "cnd10:35.3",
      "pali": "Udāhu tattheva anupādisesāya nibbānadhātuyā parinibbāyeyya."
    },
    {
      "id": "cnd10:35.4",
      "pali": "Atha vā tassa viññāṇaṁ caveyya puna paṭisandhiviññāṇaṁ nibbatteyya kāmadhātuyā vā rūpadhātuyā vā arūpadhātuyā vāti, ākiñcaññāyatanaṁ upapannassa parinibbānañca paṭisandhiñca pucchati."
    },
    {
      "id": "cnd10:35.5",
      "pali": "<b>Tathāvidhassā</b>ti tathāvidhassa tādisassa tassaṇṭhitassa tappakārassa tappaṭibhāgassa ākiñcaññāyatanaṁ upapannassāti—"
    },
    {
      "id": "cnd10:35.6",
      "pali": "tattheva so sītisiyā vimutto, cavetha viññāṇaṁ tathāvidhassa."
    },
    {
      "id": "cnd10:35.7",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd10:36.1",
      "pali": "“Tiṭṭhe ce so tattha anānuyāyī,"
    },
    {
      "id": "cnd10:36.2",
      "pali": "Pūgampi vassāni samantacakkhu;"
    },
    {
      "id": "cnd10:36.3",
      "pali": "Tattheva so sītisiyā vimutto,"
    },
    {
      "id": "cnd10:36.4",
      "pali": "Cavetha viññāṇaṁ tathāvidhassā”ti."
    },
    {
      "id": "cnd10:37.1",
      "pali": "<b>Acci yathā vātavegena khittā,</b>"
    },
    {
      "id": "cnd10:37.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:37.3",
      "pali": "<b>Atthaṁ paleti na upeti saṅkhaṁ;</b>"
    },
    {
      "id": "cnd10:37.4",
      "pali": "<b>Evaṁ munī nāmakāyā vimutto,</b>"
    },
    {
      "id": "cnd10:37.5",
      "pali": "<b>Atthaṁ paleti na upeti saṅkhaṁ.</b>"
    },
    {
      "id": "cnd10:38.1",
      "pali": "<b>Acci yathā vātavegena khittā</b>ti acci vuccati jālasikhā."
    },
    {
      "id": "cnd10:38.2",
      "pali": "<b>Vātā</b>ti puratthimā vātā pacchimā vātā uttarā vātā dakkhiṇā vātā sarajā vātā arajā vātā sītā vātā uṇhā vātā parittā vātā adhimattā vātā verambhavātā pakkhavātā supaṇṇavātā tālapaṇṇavātā vidhūpanavātā."
    },
    {
      "id": "cnd10:38.3",
      "pali": "<b>Vātavegena khittā</b>ti vātavegena khittā ukkhittā nunnā paṇunnā khambhitā vikkhambhitāti—"
    },
    {
      "id": "cnd10:38.4",
      "pali": "acci yathā vātavegena khittā."
    },
    {
      "id": "cnd10:38.5",
      "pali": "<b>Upasīvāti bhagavā</b>ti."
    },
    {
      "id": "cnd10:38.6",
      "pali": "<b>Upasīvā</b>ti bhagavā taṁ brāhmaṇaṁ nāmena ālapati."
    },
    {
      "id": "cnd10:38.7",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd10:38.8",
      "pali": "upasīvāti bhagavā."
    },
    {
      "id": "cnd10:39.1",
      "pali": "<b>Atthaṁ paleti na upeti saṅkhan</b>ti."
    },
    {
      "id": "cnd10:39.2",
      "pali": "<b>Atthaṁ paletī</b>ti atthaṁ paleti, atthaṁ gameti, atthaṁ gacchati nirujjhati vūpasamati paṭippassambhati."
    },
    {
      "id": "cnd10:39.3",
      "pali": "<b>Na upeti saṅkhan</b>ti saṅkhaṁ na upeti, uddesaṁ na upeti, gaṇanaṁ na upeti, paṇṇattiṁ na upeti, “puratthimaṁ vā disaṁ gatā, pacchimaṁ vā disaṁ gatā, uttaraṁ vā disaṁ gatā, dakkhiṇaṁ vā disaṁ gatā uddhaṁ vā gatā, adho vā gatā, tiriyaṁ vā gatā, vidisaṁ vā gatā”ti, so hetu natthi, paccayo natthi, kāraṇaṁ natthi, yena saṅkhaṁ gaccheyyāti—"
    },
    {
      "id": "cnd10:39.4",
      "pali": "atthaṁ paleti na upeti saṅkhaṁ."
    },
    {
      "id": "cnd10:40.1",
      "pali": "<b>Evaṁ munī nāmakāyā vimutto</b>ti."
    },
    {
      "id": "cnd10:40.2",
      "pali": "<b>Evan</b>ti opammasampaṭipādanaṁ."
    },
    {
      "id": "cnd10:40.3",
      "pali": "<b>Munī</b>ti monaṁ vuccati ñāṇaṁ …pe… saṅgajālamaticca so muni."
    },
    {
      "id": "cnd10:40.4",
      "pali": "<b>Nāmakāyā vimutto</b>ti so muni pakatiyā pubbeva rūpakāyā vimutto."
    },
    {
      "id": "cnd10:40.5",
      "pali": "Tadaṅgaṁ samatikkamā vikkhambhanappahānena pahīno."
    },
    {
      "id": "cnd10:40.6",
      "pali": "Tassa munino bhavantaṁ āgamma cattāro ariyamaggā paṭiladdhā honti."
    },
    {
      "id": "cnd10:40.7",
      "pali": "Catunnaṁ ariyamaggānaṁ paṭiladdhattā nāmakāyo ca rūpakāyo ca pariññātā honti."
    },
    {
      "id": "cnd10:40.8",
      "pali": "Nāmakāyassa ca rūpakāyassa ca pariññātattā nāmakāyā ca rūpakāyā ca mutto vimutto suvimutto accantaanupādāvimokkhenāti—"
    },
    {
      "id": "cnd10:40.9",
      "pali": "evaṁ munī nāmakāyā vimutto."
    },
    {
      "id": "cnd10:41.1",
      "pali": "<b>Atthaṁ paleti na upeti saṅkhan</b>ti."
    },
    {
      "id": "cnd10:41.2",
      "pali": "<b>Atthaṁ paletī</b>ti anupādisesāya nibbānadhātuyā parinibbāyati."
    },
    {
      "id": "cnd10:41.3",
      "pali": "<b>Na upeti saṅkhan</b>ti anupādisesāya nibbānadhātuyā parinibbuto saṅkhaṁ na upeti, uddesaṁ na upeti, gaṇanaṁ na upeti, paṇṇattiṁ na upeti—"
    },
    {
      "id": "cnd10:41.4",
      "pali": "khattiyoti vā brāhmaṇoti vā vessoti vā suddoti vā gahaṭṭhoti vā pabbajitoti vā devoti vā manussoti vā rūpīti vā arūpīti vā saññīti vā asaññīti vā nevasaññīnāsaññīti vā."
    },
    {
      "id": "cnd10:41.5",
      "pali": "So hetu natthi paccayo natthi kāraṇaṁ natthi yena saṅkhaṁ gaccheyyāti—"
    },
    {
      "id": "cnd10:41.6",
      "pali": "atthaṁ paleti na upeti saṅkhaṁ."
    },
    {
      "id": "cnd10:41.7",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd10:42.1",
      "pali": "“Acci yathā vātavegena khittā,"
    },
    {
      "id": "cnd10:42.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:42.3",
      "pali": "Atthaṁ paleti na upeti saṅkhaṁ;"
    },
    {
      "id": "cnd10:42.4",
      "pali": "Evaṁ munī nāmakāyā vimutto,"
    },
    {
      "id": "cnd10:42.5",
      "pali": "Atthaṁ paleti na upeti saṅkhan”ti."
    },
    {
      "id": "cnd10:43.1",
      "pali": "<b>Atthaṅgato so uda vā so natthi,</b>"
    },
    {
      "id": "cnd10:43.2",
      "pali": "<b>Udāhu ve sassatiyā arogo;</b>"
    },
    {
      "id": "cnd10:43.3",
      "pali": "<b>Taṁ me munī sādhu viyākarohi,</b>"
    },
    {
      "id": "cnd10:43.4",
      "pali": "<b>Tathā hi te vidito esa dhammo.</b>"
    },
    {
      "id": "cnd10:44.1",
      "pali": "<b>Atthaṅgato so uda vā so natthī</b>ti so atthaṅgato udāhu natthi so niruddho ucchinno vinaṭṭhoti—"
    },
    {
      "id": "cnd10:44.2",
      "pali": "atthaṅgato so uda vā so natthi."
    },
    {
      "id": "cnd10:45.1",
      "pali": "<b>Udāhu ve sassatiyā arogo</b>ti udāhu nicco dhuvo sassato avipariṇāmadhammo sassatisamaṁ tatheva tiṭṭheyyāti—"
    },
    {
      "id": "cnd10:45.2",
      "pali": "udāhu ve sassatiyā arogo."
    },
    {
      "id": "cnd10:46.1",
      "pali": "<b>Taṁ me munī sādhu viyākarohī</b>ti."
    },
    {
      "id": "cnd10:46.2",
      "pali": "<b>Tan</b>ti yaṁ pucchāmi yaṁ yācāmi yaṁ ajjhesāmi yaṁ pasādemi."
    },
    {
      "id": "cnd10:46.3",
      "pali": "<b>Munī</b>ti monaṁ vuccati ñāṇaṁ …pe… saṅgajālamaticca so muni."
    },
    {
      "id": "cnd10:46.4",
      "pali": "<b>Sādhu viyākarohī</b>ti sādhu ācikkhāhi desehi paññapehi paṭṭhapehi vivarāhi vibhajāhi uttānīkarohi pakāsehīti—"
    },
    {
      "id": "cnd10:46.5",
      "pali": "taṁ me munī sādhu viyākarohi."
    },
    {
      "id": "cnd10:47.1",
      "pali": "<b>Tathā hi te vidito esa dhammo</b>ti tathā hi te vidito tulito tīrito vibhūto vibhāvito esa dhammoti—"
    },
    {
      "id": "cnd10:47.2",
      "pali": "tathā hi te vidito esa dhammo."
    },
    {
      "id": "cnd10:47.3",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd10:48.1",
      "pali": "“Atthaṅgato so uda vā so natthi,"
    },
    {
      "id": "cnd10:48.2",
      "pali": "Udāhu ve sassatiyā arogo;"
    },
    {
      "id": "cnd10:48.3",
      "pali": "Taṁ me munī sādhu viyākarohi,"
    },
    {
      "id": "cnd10:48.4",
      "pali": "Tathā hi te vidito esa dhammo”ti."
    },
    {
      "id": "cnd10:49.1",
      "pali": "<b>Atthaṅgatassa na pamāṇamatthi,</b>"
    },
    {
      "id": "cnd10:49.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:49.3",
      "pali": "<b>Yena naṁ vajjuṁ taṁ tassa natthi;</b>"
    },
    {
      "id": "cnd10:49.4",
      "pali": "<b>Sabbesu dhammesu samūhatesu,</b>"
    },
    {
      "id": "cnd10:49.5",
      "pali": "<b>Samūhatā vādapathāpi sabbe.</b>"
    },
    {
      "id": "cnd10:50.1",
      "pali": "<b>Atthaṅgatassa na pamāṇamatthī</b>ti atthaṅgatassa anupādisesāya nibbānadhātuyā parinibbutassa rūpapamāṇaṁ natthi, vedanāpamāṇaṁ natthi, saññāpamāṇaṁ natthi, saṅkhārapamāṇaṁ natthi, viññāṇapamāṇaṁ natthi, na atthi na saṁvijjati nupalabbhati pahīnaṁ samucchinnaṁ vūpasantaṁ paṭippassaddhaṁ abhabbuppattikaṁ ñāṇagginā daḍḍhanti—"
    },
    {
      "id": "cnd10:50.2",
      "pali": "atthaṅgatassa na pamāṇamatthi."
    },
    {
      "id": "cnd10:50.3",
      "pali": "<b>Upasīvāti bhagavā</b>ti <b>upasīvā</b>ti bhagavā taṁ brāhmaṇaṁ nāmena ālapati."
    },
    {
      "id": "cnd10:50.4",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd10:50.5",
      "pali": "upasīvāti bhagavā."
    },
    {
      "id": "cnd10:51.1",
      "pali": "<b>Yena naṁ vajjuṁ taṁ tassa natthī</b>ti yena taṁ rāgena vadeyyuṁ, yena dosena vadeyyuṁ, yena mohena vadeyyuṁ, yena mānena vadeyyuṁ, yāya diṭṭhiyā vadeyyuṁ, yena uddhaccena vadeyyuṁ, yāya vicikicchāya vadeyyuṁ, yehi anusayehi vadeyyuṁ—"
    },
    {
      "id": "cnd10:51.2",
      "pali": "rattoti vā duṭṭhoti vā mūḷhoti vā vinibaddhoti vā parāmaṭṭhoti vā vikkhepagatoti vā aniṭṭhaṅgatoti vā thāmagatoti vā, te abhisaṅkhārā pahīnā."
    },
    {
      "id": "cnd10:51.3",
      "pali": "Abhisaṅkhārānaṁ pahīnattā gatiyā yena taṁ vadeyyuṁ—"
    },
    {
      "id": "cnd10:51.4",
      "pali": "nerayikoti vā tiracchānayonikoti vā pettivisayikoti vā manussoti vā devoti vā rūpīti vā arūpīti vā saññīti vā asaññīti vā nevasaññīnāsaññīti vā, so hetu natthi paccayo natthi kāraṇaṁ natthi yena vadeyyuṁ katheyyuṁ bhaṇeyyuṁ dīpeyyuṁ vohareyyunti—"
    },
    {
      "id": "cnd10:51.5",
      "pali": "yena naṁ vajjuṁ taṁ tassa natthi."
    },
    {
      "id": "cnd10:52.1",
      "pali": "<b>Sabbesu dhammesu samūhatesū</b>ti sabbesu dhammesu sabbesu khandhesu sabbesu āyatanesu sabbāsu dhātūsu sabbāsu gatīsu sabbāsu upapattīsu sabbāsu paṭisandhīsu sabbesu bhavesu sabbesu saṁsāresu sabbesu vaṭṭesu ūhatesu samūhatesu uddhatesu samuddhatesu uppāṭitesu samuppāṭitesu pahīnesu samucchinnesu vūpasantesu paṭippassaddhesu abhabbuppattikesu ñāṇagginā daḍḍhesūti—"
    },
    {
      "id": "cnd10:52.2",
      "pali": "sabbesu dhammesu samūhatesu."
    },
    {
      "id": "cnd10:53.1",
      "pali": "<b>Samūhatā vādapathāpi sabbe</b>ti vādapathā vuccanti kilesā ca khandhā ca abhisaṅkhārā ca."
    },
    {
      "id": "cnd10:53.2",
      "pali": "Tassa vādā ca vādapathā ca adhivacanāni ca adhivacanapathā ca nirutti ca niruttipathā ca paññatti ca paññattipathā ca ūhatā samūhatā uddhatā samuddhatā uppāṭitā samuppāṭitā pahīnā samucchinnā vūpasantā paṭippassaddhā abhabbuppattikā ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "cnd10:53.3",
      "pali": "samūhatā vādapathāpi sabbe."
    },
    {
      "id": "cnd10:53.4",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd10:54.1",
      "pali": "“Atthaṅgatassa na pamāṇamatthi,"
    },
    {
      "id": "cnd10:54.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "cnd10:54.3",
      "pali": "Yena naṁ vajjuṁ taṁ tassa natthi;"
    },
    {
      "id": "cnd10:54.4",
      "pali": "Sabbesu dhammesu samūhatesu,"
    },
    {
      "id": "cnd10:54.5",
      "pali": "Samūhatā vādapathāpi sabbe”ti."
    },
    {
      "id": "cnd10:55.1",
      "pali": "Saha gāthāpariyosānā ye te brāhmaṇena saddhiṁ …pe…"
    },
    {
      "id": "cnd10:55.2",
      "pali": "pañjaliko namassamāno nisinno hoti—"
    },
    {
      "id": "cnd10:55.3",
      "pali": "satthā me, bhante bhagavā, sāvakohamasmīti."
    },
    {
      "id": "cnd10:55.4",
      "pali": "Upasīvamāṇavapucchāniddeso chaṭṭho."
    }
  ]
}
