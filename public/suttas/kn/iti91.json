{
  "uid": "iti91",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti91:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti91:2.1",
      "pali": "“Antamidaṁ, bhikkhave, jīvikānaṁ yadidaṁ piṇḍolyaṁ."
    },
    {
      "id": "iti91:2.2",
      "pali": "Abhisāpoyaṁ, bhikkhave, lokasmiṁ: ‘piṇḍolo vicarasi pattapāṇī’ti."
    },
    {
      "id": "iti91:2.3",
      "pali": "Tañca kho etaṁ, bhikkhave, kulaputtā upenti atthavasikā, atthavasaṁ paṭicca;"
    },
    {
      "id": "iti91:2.4",
      "pali": "neva rājābhinītā, na corābhinītā, na iṇaṭṭā, na bhayaṭṭā, na ājīvikāpakatā."
    },
    {
      "id": "iti91:2.5",
      "pali": "Api ca kho ‘otiṇṇamhā jātiyā jarāya maraṇena sokehi paridevehi dukkhehi domanassehi upāyāsehi dukkhotiṇṇā dukkhaparetā,"
    },
    {
      "id": "iti91:2.6",
      "pali": "appeva nāma imassa kevalassa dukkhakkhandhassa antakiriyā paññāyethā’ti."
    },
    {
      "id": "iti91:2.7",
      "pali": "Evaṁ pabbajito cāyaṁ, bhikkhave, kulaputto."
    },
    {
      "id": "iti91:2.8",
      "pali": "So ca hoti abhijjhālu kāmesu tibbasārāgo, byāpannacitto paduṭṭhamanasaṅkappo, muṭṭhassati asampajāno asamāhito vibbhantacitto pākatindriyo."
    },
    {
      "id": "iti91:2.9",
      "pali": "Seyyathāpi, bhikkhave, chavālātaṁ ubhatopadittaṁ majjhe gūthagataṁ neva gāme kaṭṭhatthaṁ pharati na araññe;"
    },
    {
      "id": "iti91:2.10",
      "pali": "tathūpamāhaṁ, bhikkhave, imaṁ puggalaṁ vadāmi gihibhogā parihīno sāmaññatthañca na paripūretī”ti."
    },
    {
      "id": "iti91:2.11",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti91:2.12",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti91:3.1",
      "pali": "“Gihibhogā parihīno,"
    },
    {
      "id": "iti91:3.2",
      "pali": "Sāmaññatthañca dubbhago;"
    },
    {
      "id": "iti91:3.3",
      "pali": "Paridhaṁsamāno pakireti,"
    },
    {
      "id": "iti91:3.4",
      "pali": "Chavālātaṁva nassati."
    },
    {
      "id": "iti91:4.1",
      "pali": "Kāsāvakaṇṭhā bahavo,"
    },
    {
      "id": "iti91:4.2",
      "pali": "pāpadhammā asaññatā;"
    },
    {
      "id": "iti91:4.3",
      "pali": "Pāpā pāpehi kammehi,"
    },
    {
      "id": "iti91:4.4",
      "pali": "nirayaṁ te upapajjare."
    },
    {
      "id": "iti91:5.1",
      "pali": "Seyyo ayoguḷo bhutto,"
    },
    {
      "id": "iti91:5.2",
      "pali": "tatto aggisikhūpamo;"
    },
    {
      "id": "iti91:5.3",
      "pali": "Yañce bhuñjeyya dussīlo,"
    },
    {
      "id": "iti91:5.4",
      "pali": "raṭṭhapiṇḍamasaññato”ti."
    },
    {
      "id": "iti91:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti91:6.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
