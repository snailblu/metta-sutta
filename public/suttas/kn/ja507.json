{
  "uid": "ja507",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja507:1.1",
      "pali": "Brahmalokā cavitvāna,"
    },
    {
      "id": "ja507:1.2",
      "pali": "devaputto mahiddhiko;"
    },
    {
      "id": "ja507:1.3",
      "pali": "Rañño putto udapādi,"
    },
    {
      "id": "ja507:1.4",
      "pali": "sabbakāmasamiddhisu."
    },
    {
      "id": "ja507:2.1",
      "pali": "Kāmā vā kāmasaññā vā,"
    },
    {
      "id": "ja507:2.2",
      "pali": "brahmaloke na vijjati;"
    },
    {
      "id": "ja507:2.3",
      "pali": "Svāssu tāyeva saññāya,"
    },
    {
      "id": "ja507:2.4",
      "pali": "kāmehi vijigucchatha."
    },
    {
      "id": "ja507:3.1",
      "pali": "Tassa cantepure āsi,"
    },
    {
      "id": "ja507:3.2",
      "pali": "jhānāgāraṁ sumāpitaṁ;"
    },
    {
      "id": "ja507:3.3",
      "pali": "So tattha paṭisallīno,"
    },
    {
      "id": "ja507:3.4",
      "pali": "eko rahasi jhāyatha."
    },
    {
      "id": "ja507:4.1",
      "pali": "Sa rājā paridevesi,"
    },
    {
      "id": "ja507:4.2",
      "pali": "puttasokena aṭṭito;"
    },
    {
      "id": "ja507:4.3",
      "pali": "“Ekaputto cayaṁ mayhaṁ,"
    },
    {
      "id": "ja507:4.4",
      "pali": "na ca kāmāni bhuñjati."
    },
    {
      "id": "ja507:5.1",
      "pali": "Ko nu khvettha upāyo so,"
    },
    {
      "id": "ja507:5.2",
      "pali": "ko vā jānāti kiñcanaṁ;"
    },
    {
      "id": "ja507:5.3",
      "pali": "Yo me puttaṁ palobheyya,"
    },
    {
      "id": "ja507:5.4",
      "pali": "yathā kāmāni patthaye”."
    },
    {
      "id": "ja507:6.1",
      "pali": "Ahu kumārī tattheva,"
    },
    {
      "id": "ja507:6.2",
      "pali": "vaṇṇarūpasamāhitā;"
    },
    {
      "id": "ja507:6.3",
      "pali": "Kusalā naccagītassa,"
    },
    {
      "id": "ja507:6.4",
      "pali": "vādite ca padakkhiṇā."
    },
    {
      "id": "ja507:7.1",
      "pali": "Sā tattha upasaṅkamma,"
    },
    {
      "id": "ja507:7.2",
      "pali": "rājānaṁ etadabravi;"
    },
    {
      "id": "ja507:7.3",
      "pali": "“Ahaṁ kho naṁ palobheyyaṁ,"
    },
    {
      "id": "ja507:7.4",
      "pali": "sace bhattā bhavissati”."
    },
    {
      "id": "ja507:8.1",
      "pali": "Taṁ tathāvādiniṁ rājā,"
    },
    {
      "id": "ja507:8.2",
      "pali": "kumāriṁ etadabravi;"
    },
    {
      "id": "ja507:8.3",
      "pali": "“Tvaññeva naṁ palobhehi,"
    },
    {
      "id": "ja507:8.4",
      "pali": "tava bhattā bhavissati”."
    },
    {
      "id": "ja507:9.1",
      "pali": "Sā ca antepuraṁ gantvā,"
    },
    {
      "id": "ja507:9.2",
      "pali": "bahuṁ kāmupasaṁhitaṁ;"
    },
    {
      "id": "ja507:9.3",
      "pali": "Hadayaṅgamā pemanīyā,"
    },
    {
      "id": "ja507:9.4",
      "pali": "citrā gāthā abhāsatha."
    },
    {
      "id": "ja507:10.1",
      "pali": "Tassā ca gāyamānāya,"
    },
    {
      "id": "ja507:10.2",
      "pali": "saddaṁ sutvāna nāriyā;"
    },
    {
      "id": "ja507:10.3",
      "pali": "Kāmacchandassa uppajji,"
    },
    {
      "id": "ja507:10.4",
      "pali": "janaṁ so paripucchatha."
    },
    {
      "id": "ja507:11.1",
      "pali": "“Kasseso saddo ko vā so,"
    },
    {
      "id": "ja507:11.2",
      "pali": "bhaṇati uccāvacaṁ bahuṁ;"
    },
    {
      "id": "ja507:11.3",
      "pali": "Hadayaṅgamaṁ pemanīyaṁ,"
    },
    {
      "id": "ja507:11.4",
      "pali": "aho kaṇṇasukhaṁ mama”."
    },
    {
      "id": "ja507:12.1",
      "pali": "“Esā kho pamadā deva,"
    },
    {
      "id": "ja507:12.2",
      "pali": "khiḍḍā esā anappikā;"
    },
    {
      "id": "ja507:12.3",
      "pali": "Sace tvaṁ kāme bhuñjeyya,"
    },
    {
      "id": "ja507:12.4",
      "pali": "bhiyyo bhiyyo chādeyyu taṁ”."
    },
    {
      "id": "ja507:13.1",
      "pali": "“Iṅgha āgacchatorena,"
    },
    {
      "id": "ja507:13.2",
      "pali": "avidūramhi gāyatu;"
    },
    {
      "id": "ja507:13.3",
      "pali": "Assamassa samīpamhi,"
    },
    {
      "id": "ja507:13.4",
      "pali": "santike mayhaṁ gāyatu”."
    },
    {
      "id": "ja507:14.1",
      "pali": "Tirokuṭṭamhi gāyitvā,"
    },
    {
      "id": "ja507:14.2",
      "pali": "jhānāgāramhi pāvisi;"
    },
    {
      "id": "ja507:14.3",
      "pali": "Bandhi naṁ anupubbena,"
    },
    {
      "id": "ja507:14.4",
      "pali": "āraññamiva kuñjaraṁ."
    },
    {
      "id": "ja507:15.1",
      "pali": "Tassa kāmarasaṁ ñatvā,"
    },
    {
      "id": "ja507:15.2",
      "pali": "issādhammo ajāyatha;"
    },
    {
      "id": "ja507:15.3",
      "pali": "“Ahameva kāme bhuñjeyyaṁ,"
    },
    {
      "id": "ja507:15.4",
      "pali": "mā añño puriso ahu”."
    },
    {
      "id": "ja507:16.1",
      "pali": "Tato asiṁ gahetvāna,"
    },
    {
      "id": "ja507:16.2",
      "pali": "purise hantuṁ upakkami;"
    },
    {
      "id": "ja507:16.3",
      "pali": "“Ahameveko bhuñjissaṁ,"
    },
    {
      "id": "ja507:16.4",
      "pali": "mā añño puriso siyā”."
    },
    {
      "id": "ja507:17.1",
      "pali": "Tato jānapadā sabbe,"
    },
    {
      "id": "ja507:17.2",
      "pali": "vikkandiṁsu samāgatā;"
    },
    {
      "id": "ja507:17.3",
      "pali": "“Putto tyāyaṁ mahārāja,"
    },
    {
      "id": "ja507:17.4",
      "pali": "janaṁ heṭhetyadūsakaṁ”."
    },
    {
      "id": "ja507:18.1",
      "pali": "Tañca rājā vivāhesi,"
    },
    {
      "id": "ja507:18.2",
      "pali": "samhā raṭṭhā ca khattiyo;"
    },
    {
      "id": "ja507:18.3",
      "pali": "“Yāvatā vijitaṁ mayhaṁ,"
    },
    {
      "id": "ja507:18.4",
      "pali": "na te vatthabba tāvade”."
    },
    {
      "id": "ja507:19.1",
      "pali": "Tato so bhariyamādāya,"
    },
    {
      "id": "ja507:19.2",
      "pali": "samuddaṁ upasaṅkami;"
    },
    {
      "id": "ja507:19.3",
      "pali": "Paṇṇasālaṁ karitvāna,"
    },
    {
      "id": "ja507:19.4",
      "pali": "vanamuñchāya pāvisi."
    },
    {
      "id": "ja507:20.1",
      "pali": "Athettha isi māgacchi,"
    },
    {
      "id": "ja507:20.2",
      "pali": "samuddaṁ uparūpari;"
    },
    {
      "id": "ja507:20.3",
      "pali": "So tassa gehaṁ pāvekkhi,"
    },
    {
      "id": "ja507:20.4",
      "pali": "bhattakāle upaṭṭhite."
    },
    {
      "id": "ja507:21.1",
      "pali": "Tañca bhariyā palobhesi,"
    },
    {
      "id": "ja507:21.2",
      "pali": "passa yāva sudāruṇaṁ;"
    },
    {
      "id": "ja507:21.3",
      "pali": "Cuto so brahmacariyamhā,"
    },
    {
      "id": "ja507:21.4",
      "pali": "iddhiyā parihāyatha."
    },
    {
      "id": "ja507:22.1",
      "pali": "Rājaputto ca uñchāto,"
    },
    {
      "id": "ja507:22.2",
      "pali": "vanamūlaphalaṁ bahuṁ;"
    },
    {
      "id": "ja507:22.3",
      "pali": "Sāyaṁ kājena ādāya,"
    },
    {
      "id": "ja507:22.4",
      "pali": "assamaṁ upasaṅkami."
    },
    {
      "id": "ja507:23.1",
      "pali": "Isī ca khattiyaṁ disvā,"
    },
    {
      "id": "ja507:23.2",
      "pali": "samuddaṁ upasaṅkami;"
    },
    {
      "id": "ja507:23.3",
      "pali": "“Vehāyasaṁ gamissan”ti,"
    },
    {
      "id": "ja507:23.4",
      "pali": "sīdate so mahaṇṇave."
    },
    {
      "id": "ja507:24.1",
      "pali": "Khattiyo ca isiṁ disvā,"
    },
    {
      "id": "ja507:24.2",
      "pali": "sīdamānaṁ mahaṇṇave;"
    },
    {
      "id": "ja507:24.3",
      "pali": "Tasseva anukampāya,"
    },
    {
      "id": "ja507:24.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "ja507:25.1",
      "pali": "“Abhijjamāne vārismiṁ,"
    },
    {
      "id": "ja507:25.2",
      "pali": "sayaṁ āgamma iddhiyā;"
    },
    {
      "id": "ja507:25.3",
      "pali": "Missībhāvitthiyā gantvā,"
    },
    {
      "id": "ja507:25.4",
      "pali": "saṁsīdasi mahaṇṇave."
    },
    {
      "id": "ja507:26.1",
      "pali": "Āvaṭṭanī mahāmāyā,"
    },
    {
      "id": "ja507:26.2",
      "pali": "brahmacariyavikopanā;"
    },
    {
      "id": "ja507:26.3",
      "pali": "Sīdanti naṁ viditvāna,"
    },
    {
      "id": "ja507:26.4",
      "pali": "ārakā parivajjaye."
    },
    {
      "id": "ja507:27.1",
      "pali": "Analā mudusambhāsā,"
    },
    {
      "id": "ja507:27.2",
      "pali": "duppūrā tā nadīsamā;"
    },
    {
      "id": "ja507:27.3",
      "pali": "Sīdanti naṁ viditvāna,"
    },
    {
      "id": "ja507:27.4",
      "pali": "ārakā parivajjaye."
    },
    {
      "id": "ja507:28.1",
      "pali": "Yaṁ etā upasevanti,"
    },
    {
      "id": "ja507:28.2",
      "pali": "chandasā vā dhanena vā;"
    },
    {
      "id": "ja507:28.3",
      "pali": "Jātavedova saṁ ṭhānaṁ,"
    },
    {
      "id": "ja507:28.4",
      "pali": "khippaṁ anudahanti naṁ”."
    },
    {
      "id": "ja507:29.1",
      "pali": "Khattiyassa vaco sutvā,"
    },
    {
      "id": "ja507:29.2",
      "pali": "isissa nibbidā ahu;"
    },
    {
      "id": "ja507:29.3",
      "pali": "Laddhā porāṇakaṁ maggaṁ,"
    },
    {
      "id": "ja507:29.4",
      "pali": "gacchate so vihāyasaṁ."
    },
    {
      "id": "ja507:30.1",
      "pali": "Khattiyo ca isiṁ disvā,"
    },
    {
      "id": "ja507:30.2",
      "pali": "gacchamānaṁ vihāyasaṁ;"
    },
    {
      "id": "ja507:30.3",
      "pali": "Saṁvegaṁ alabhī dhīro,"
    },
    {
      "id": "ja507:30.4",
      "pali": "pabbajjaṁ samarocayi."
    },
    {
      "id": "ja507:31.1",
      "pali": "Tato so pabbajitvāna,"
    },
    {
      "id": "ja507:31.2",
      "pali": "kāmarāgaṁ virājayi;"
    },
    {
      "id": "ja507:31.3",
      "pali": "Kāmarāgaṁ virājetvā,"
    },
    {
      "id": "ja507:31.4",
      "pali": "brahmalokūpago ahūti."
    },
    {
      "id": "ja507:32.1",
      "pali": "Mahāpalobhanajātakaṁ ekādasamaṁ."
    }
  ]
}
