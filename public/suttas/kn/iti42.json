{
  "uid": "iti42",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti42:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti42:2.1",
      "pali": "“Dveme, bhikkhave, sukkā dhammā lokaṁ pālenti."
    },
    {
      "id": "iti42:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "iti42:2.3",
      "pali": "Hirī ca, ottappañca."
    },
    {
      "id": "iti42:2.4",
      "pali": "Ime ce, bhikkhave, dve sukkā dhammā lokaṁ na pāleyyuṁ, nayidha paññāyetha mātāti vā mātucchāti vā mātulānīti vā ācariyabhariyāti vā garūnaṁ dārāti vā."
    },
    {
      "id": "iti42:2.5",
      "pali": "Sambhedaṁ loko agamissa yathā ajeḷakā kukkuṭasūkarā soṇasiṅgālā."
    },
    {
      "id": "iti42:2.6",
      "pali": "Yasmā ca kho, bhikkhave, ime dve sukkā dhammā lokaṁ pālenti tasmā paññāyati mātāti vā mātucchāti vā mātulānīti vā ācariyabhariyāti vā garūnaṁ dārāti vā”ti."
    },
    {
      "id": "iti42:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti42:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti42:3.1",
      "pali": "“Yesañce hiriottappaṁ,"
    },
    {
      "id": "iti42:3.2",
      "pali": "sabbadā ca na vijjati;"
    },
    {
      "id": "iti42:3.3",
      "pali": "Vokkantā sukkamūlā te,"
    },
    {
      "id": "iti42:3.4",
      "pali": "jātimaraṇagāmino."
    },
    {
      "id": "iti42:4.1",
      "pali": "Yesañca hiriottappaṁ,"
    },
    {
      "id": "iti42:4.2",
      "pali": "sadā sammā upaṭṭhitā;"
    },
    {
      "id": "iti42:4.3",
      "pali": "Virūḷhabrahmacariyā te,"
    },
    {
      "id": "iti42:4.4",
      "pali": "santo khīṇapunabbhavā”ti."
    },
    {
      "id": "iti42:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti42:5.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
