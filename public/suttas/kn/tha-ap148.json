{
  "uid": "tha-ap148",
  "title": "6 Anulepadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap148:1.1",
      "pali": "“Anomadassīmunino,"
    },
    {
      "id": "tha-ap148:1.2",
      "pali": "bodhivedimakāsahaṁ;"
    },
    {
      "id": "tha-ap148:1.3",
      "pali": "Sudhāya piṇḍaṁ datvāna,"
    },
    {
      "id": "tha-ap148:1.4",
      "pali": "pāṇikammaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap148:2.1",
      "pali": "Disvā taṁ sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap148:2.2",
      "pali": "anomadassī naruttamo;"
    },
    {
      "id": "tha-ap148:2.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap148:2.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap148:3.1",
      "pali": "‘Iminā sudhakammena,"
    },
    {
      "id": "tha-ap148:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap148:3.3",
      "pali": "Sampattiṁ anubhotvāna,"
    },
    {
      "id": "tha-ap148:3.4",
      "pali": "dukkhassantaṁ karissati’."
    },
    {
      "id": "tha-ap148:4.1",
      "pali": "Pasannamukhavaṇṇomhi,"
    },
    {
      "id": "tha-ap148:4.2",
      "pali": "ekaggo susamāhito;"
    },
    {
      "id": "tha-ap148:4.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap148:4.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap148:5.1",
      "pali": "Ito kappasate āsiṁ,"
    },
    {
      "id": "tha-ap148:5.2",
      "pali": "paripuṇṇe anūnake;"
    },
    {
      "id": "tha-ap148:5.3",
      "pali": "Rājā sabbaghano nāma,"
    },
    {
      "id": "tha-ap148:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap148:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap148:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap148:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap148:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā anulepadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap148:8.1",
      "pali": "Anulepadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
