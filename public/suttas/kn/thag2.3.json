{
  "uid": "thag2.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.3:1.1",
      "pali": "“Makkaṭo pañcadvārāyaṁ,"
    },
    {
      "id": "thag2.3:1.2",
      "pali": "kuṭikāyaṁ pasakkiya;"
    },
    {
      "id": "thag2.3:1.3",
      "pali": "Dvārena anupariyeti,"
    },
    {
      "id": "thag2.3:1.4",
      "pali": "ghaṭṭayanto muhuṁ muhuṁ."
    },
    {
      "id": "thag2.3:2.1",
      "pali": "Tiṭṭha makkaṭa mā dhāvi,"
    },
    {
      "id": "thag2.3:2.2",
      "pali": "na hi te taṁ yathā pure;"
    },
    {
      "id": "thag2.3:2.3",
      "pali": "Niggahītosi paññāya,"
    },
    {
      "id": "thag2.3:2.4",
      "pali": "neva dūraṁ gamissatī”ti."
    },
    {
      "id": "thag2.3:2.5",
      "pali": "… Valliyo thero …."
    }
  ]
}
