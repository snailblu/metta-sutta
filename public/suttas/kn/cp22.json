{
  "uid": "cp22",
  "title": "Nekkhammapāramī 2",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp22:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp22:1.2",
      "pali": "indapatthe puruttame;"
    },
    {
      "id": "cp22:1.3",
      "pali": "Kāmito dayito putto,"
    },
    {
      "id": "cp22:1.4",
      "pali": "somanassoti vissuto."
    },
    {
      "id": "cp22:2.1",
      "pali": "Sīlavā guṇasampanno,"
    },
    {
      "id": "cp22:2.2",
      "pali": "kalyāṇapaṭibhānavā;"
    },
    {
      "id": "cp22:2.3",
      "pali": "Vuḍḍhāpacāyī hirīmā,"
    },
    {
      "id": "cp22:2.4",
      "pali": "saṅgahesu ca kovido."
    },
    {
      "id": "cp22:3.1",
      "pali": "Tassa rañño patikaro,"
    },
    {
      "id": "cp22:3.2",
      "pali": "ahosi kuhakatāpaso;"
    },
    {
      "id": "cp22:3.3",
      "pali": "Ārāmaṁ mālāvacchañca,"
    },
    {
      "id": "cp22:3.4",
      "pali": "ropayitvāna jīvati."
    },
    {
      "id": "cp22:4.1",
      "pali": "Tamahaṁ disvāna kuhakaṁ,"
    },
    {
      "id": "cp22:4.2",
      "pali": "thusarāsiṁva ataṇḍulaṁ;"
    },
    {
      "id": "cp22:4.3",
      "pali": "Dumaṁva anto susiraṁ,"
    },
    {
      "id": "cp22:4.4",
      "pali": "kadaliṁva asārakaṁ."
    },
    {
      "id": "cp22:5.1",
      "pali": "Natthimassa sataṁ dhammo,"
    },
    {
      "id": "cp22:5.2",
      "pali": "sāmaññāpagato ayaṁ;"
    },
    {
      "id": "cp22:5.3",
      "pali": "Hirīsukkadhammajahito,"
    },
    {
      "id": "cp22:5.4",
      "pali": "jīvitavuttikāraṇā."
    },
    {
      "id": "cp22:6.1",
      "pali": "Kupito ahu paccanto,"
    },
    {
      "id": "cp22:6.2",
      "pali": "aṭavīhi parantihi;"
    },
    {
      "id": "cp22:6.3",
      "pali": "Taṁ nisedhetuṁ gacchanto,"
    },
    {
      "id": "cp22:6.4",
      "pali": "anusāsi pitā mamaṁ."
    },
    {
      "id": "cp22:7.1",
      "pali": "‘Mā pamajji tuvaṁ tāta,"
    },
    {
      "id": "cp22:7.2",
      "pali": "jaṭilaṁ uggatāpanaṁ;"
    },
    {
      "id": "cp22:7.3",
      "pali": "Yadicchakaṁ pavattehi,"
    },
    {
      "id": "cp22:7.4",
      "pali": "sabbakāmadado hi so’."
    },
    {
      "id": "cp22:8.1",
      "pali": "Tamahaṁ gantvānupaṭṭhānaṁ,"
    },
    {
      "id": "cp22:8.2",
      "pali": "Idaṁ vacanamabraviṁ;"
    },
    {
      "id": "cp22:8.3",
      "pali": "‘Kacci te gahapati kusalaṁ,"
    },
    {
      "id": "cp22:8.4",
      "pali": "Kiṁ vā te āharīyatu’."
    },
    {
      "id": "cp22:9.1",
      "pali": "Tena so kupito āsi,"
    },
    {
      "id": "cp22:9.2",
      "pali": "kuhako mānanissito;"
    },
    {
      "id": "cp22:9.3",
      "pali": "‘Ghātāpemi tuvaṁ ajja,"
    },
    {
      "id": "cp22:9.4",
      "pali": "raṭṭhā pabbājayāmi vā’."
    },
    {
      "id": "cp22:10.1",
      "pali": "Nisedhayitvā paccantaṁ,"
    },
    {
      "id": "cp22:10.2",
      "pali": "rājā kuhakamabravi;"
    },
    {
      "id": "cp22:10.3",
      "pali": "‘Kacci te bhante khamanīyaṁ,"
    },
    {
      "id": "cp22:10.4",
      "pali": "sammāno te pavattito’."
    },
    {
      "id": "cp22:11.1",
      "pali": "Tassa ācikkhatī pāpo,"
    },
    {
      "id": "cp22:11.2",
      "pali": "kumāro yathā nāsiyo;"
    },
    {
      "id": "cp22:11.3",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "cp22:11.4",
      "pali": "āṇāpesi mahīpati."
    },
    {
      "id": "cp22:12.1",
      "pali": "‘Sīsaṁ tattheva chinditvā,"
    },
    {
      "id": "cp22:12.2",
      "pali": "katvāna catukhaṇḍikaṁ;"
    },
    {
      "id": "cp22:12.3",
      "pali": "Rathiyā rathiyaṁ dassetha,"
    },
    {
      "id": "cp22:12.4",
      "pali": "sā gati jaṭilahīḷitā’."
    },
    {
      "id": "cp22:13.1",
      "pali": "Tattha kāraṇikā gantvā,"
    },
    {
      "id": "cp22:13.2",
      "pali": "caṇḍā luddā akāruṇā;"
    },
    {
      "id": "cp22:13.3",
      "pali": "Mātu aṅke nisinnassa,"
    },
    {
      "id": "cp22:13.4",
      "pali": "ākaḍḍhitvā nayanti maṁ."
    },
    {
      "id": "cp22:14.1",
      "pali": "Tesāhaṁ evamavacaṁ,"
    },
    {
      "id": "cp22:14.2",
      "pali": "bandhataṁ gāḷhabandhanaṁ;"
    },
    {
      "id": "cp22:14.3",
      "pali": "‘Rañño dassetha maṁ khippaṁ,"
    },
    {
      "id": "cp22:14.4",
      "pali": "rājakiriyāni atthi me’."
    },
    {
      "id": "cp22:15.1",
      "pali": "Te maṁ rañño dassayiṁsu,"
    },
    {
      "id": "cp22:15.2",
      "pali": "pāpassa pāpasevino;"
    },
    {
      "id": "cp22:15.3",
      "pali": "Disvāna taṁ saññāpesiṁ,"
    },
    {
      "id": "cp22:15.4",
      "pali": "mamañca vasamānayiṁ."
    },
    {
      "id": "cp22:16.1",
      "pali": "So maṁ tattha khamāpesi,"
    },
    {
      "id": "cp22:16.2",
      "pali": "mahārajjamadāsi me;"
    },
    {
      "id": "cp22:16.3",
      "pali": "Sohaṁ tamaṁ dālayitvā,"
    },
    {
      "id": "cp22:16.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "cp22:17.1",
      "pali": "Na me dessaṁ mahārajjaṁ,"
    },
    {
      "id": "cp22:17.2",
      "pali": "kāmabhogo na dessiyo;"
    },
    {
      "id": "cp22:17.3",
      "pali": "Sabbaññutaṁ piyaṁ mayhaṁ,"
    },
    {
      "id": "cp22:17.4",
      "pali": "tasmā rajjaṁ pariccajin”ti."
    },
    {
      "id": "cp22:18.1",
      "pali": "Somanassacariyaṁ dutiyaṁ."
    }
  ]
}
