{
  "uid": "thag3.16",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.16:1.1",
      "pali": "“Pāpamitte vivajjetvā,"
    },
    {
      "id": "thag3.16:1.2",
      "pali": "bhajeyyuttamapuggalaṁ;"
    },
    {
      "id": "thag3.16:1.3",
      "pali": "Ovāde cassa tiṭṭheyya,"
    },
    {
      "id": "thag3.16:1.4",
      "pali": "patthento acalaṁ sukhaṁ."
    },
    {
      "id": "thag3.16:2.1",
      "pali": "Parittaṁ dārumāruyha,"
    },
    {
      "id": "thag3.16:2.2",
      "pali": "yathā sīde mahaṇṇave;"
    },
    {
      "id": "thag3.16:2.3",
      "pali": "Evaṁ kusītamāgamma,"
    },
    {
      "id": "thag3.16:2.4",
      "pali": "sādhujīvīpi sīdati;"
    },
    {
      "id": "thag3.16:2.5",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "thag3.16:2.6",
      "pali": "kusītaṁ hīnavīriyaṁ."
    },
    {
      "id": "thag3.16:3.1",
      "pali": "Pavivittehi ariyehi,"
    },
    {
      "id": "thag3.16:3.2",
      "pali": "pahitattehi jhāyibhi;"
    },
    {
      "id": "thag3.16:3.3",
      "pali": "Niccaṁ āraddhavīriyehi,"
    },
    {
      "id": "thag3.16:3.4",
      "pali": "paṇḍitehi sahāvase”ti."
    },
    {
      "id": "thag3.16:3.5",
      "pali": "… Vimalo thero …"
    },
    {
      "id": "thag3.16:3.6",
      "pali": "Tikanipāto niṭṭhito."
    },
    {
      "id": "thag3.16:4.1",
      "pali": "Aṅgaṇiko bhāradvājo,"
    },
    {
      "id": "thag3.16:4.2",
      "pali": "paccayo bākulo isi;"
    },
    {
      "id": "thag3.16:4.3",
      "pali": "Dhaniyo mātaṅgaputto,"
    },
    {
      "id": "thag3.16:4.4",
      "pali": "sobhito vāraṇo isi."
    },
    {
      "id": "thag3.16:5.1",
      "pali": "Vassiko ca yasojo ca,"
    },
    {
      "id": "thag3.16:5.2",
      "pali": "sāṭimattiyupāli ca;"
    },
    {
      "id": "thag3.16:5.3",
      "pali": "Uttarapālo abhibhūto,"
    },
    {
      "id": "thag3.16:5.4",
      "pali": "gotamo hāritopi ca."
    },
    {
      "id": "thag3.16:6.1",
      "pali": "Thero tikanipātamhi,"
    },
    {
      "id": "thag3.16:6.2",
      "pali": "nibbāne vimalo kato;"
    },
    {
      "id": "thag3.16:6.3",
      "pali": "Aṭṭhatālīsa gāthāyo,"
    },
    {
      "id": "thag3.16:6.4",
      "pali": "therā soḷasa kittitāti."
    }
  ]
}
