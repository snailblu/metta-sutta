{
  "uid": "cp28",
  "title": "Saccapāramī 2",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp28:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp28:1.2",
      "pali": "Tāpaso saccasavhayo;"
    },
    {
      "id": "cp28:1.3",
      "pali": "Saccena lokaṁ pālesiṁ,"
    },
    {
      "id": "cp28:1.4",
      "pali": "Samaggaṁ janamakāsahan”ti."
    },
    {
      "id": "cp28:2.1",
      "pali": "Saccatāpasacariyaṁ aṭṭhamaṁ."
    }
  ]
}
