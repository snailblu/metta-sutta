{
  "uid": "thig12.1",
  "title": "Puṇṇātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig12.1:1.1",
      "pali": "“Udahārī ahaṁ sīte,"
    },
    {
      "id": "thig12.1:1.2",
      "pali": "sadā udakamotariṁ;"
    },
    {
      "id": "thig12.1:1.3",
      "pali": "Ayyānaṁ daṇḍabhayabhītā,"
    },
    {
      "id": "thig12.1:1.4",
      "pali": "vācādosabhayaṭṭitā."
    },
    {
      "id": "thig12.1:2.1",
      "pali": "Kassa brāhmaṇa tvaṁ bhīto,"
    },
    {
      "id": "thig12.1:2.2",
      "pali": "sadā udakamotari;"
    },
    {
      "id": "thig12.1:2.3",
      "pali": "Vedhamānehi gattehi,"
    },
    {
      "id": "thig12.1:2.4",
      "pali": "sītaṁ vedayase bhusaṁ”."
    },
    {
      "id": "thig12.1:3.1",
      "pali": "“Jānantī vata maṁ bhoti,"
    },
    {
      "id": "thig12.1:3.2",
      "pali": "puṇṇike paripucchasi;"
    },
    {
      "id": "thig12.1:3.3",
      "pali": "Karontaṁ kusalaṁ kammaṁ,"
    },
    {
      "id": "thig12.1:3.4",
      "pali": "rundhantaṁ katapāpakaṁ."
    },
    {
      "id": "thig12.1:4.1",
      "pali": "Yo ca vuḍḍho daharo vā,"
    },
    {
      "id": "thig12.1:4.2",
      "pali": "pāpakammaṁ pakubbati;"
    },
    {
      "id": "thig12.1:4.3",
      "pali": "Dakābhisecanā sopi,"
    },
    {
      "id": "thig12.1:4.4",
      "pali": "pāpakammā pamuccati”."
    },
    {
      "id": "thig12.1:5.1",
      "pali": "“Ko nu te idamakkhāsi,"
    },
    {
      "id": "thig12.1:5.2",
      "pali": "ajānantassa ajānako;"
    },
    {
      "id": "thig12.1:5.3",
      "pali": "Dakābhisecanā nāma,"
    },
    {
      "id": "thig12.1:5.4",
      "pali": "pāpakammā pamuccati."
    },
    {
      "id": "thig12.1:6.1",
      "pali": "Saggaṁ nūna gamissanti,"
    },
    {
      "id": "thig12.1:6.2",
      "pali": "sabbe maṇḍūkakacchapā;"
    },
    {
      "id": "thig12.1:6.3",
      "pali": "Nāgā ca susumārā ca,"
    },
    {
      "id": "thig12.1:6.4",
      "pali": "ye caññe udake carā."
    },
    {
      "id": "thig12.1:7.1",
      "pali": "Orabbhikā sūkarikā,"
    },
    {
      "id": "thig12.1:7.2",
      "pali": "macchikā migabandhakā;"
    },
    {
      "id": "thig12.1:7.3",
      "pali": "Corā ca vajjhaghātā ca,"
    },
    {
      "id": "thig12.1:7.4",
      "pali": "ye caññe pāpakammino;"
    },
    {
      "id": "thig12.1:7.5",
      "pali": "Dakābhisecanā tepi,"
    },
    {
      "id": "thig12.1:7.6",
      "pali": "pāpakammā pamuccare."
    },
    {
      "id": "thig12.1:8.1",
      "pali": "Sace imā nadiyo te,"
    },
    {
      "id": "thig12.1:8.2",
      "pali": "pāpaṁ pubbe kataṁ vahuṁ;"
    },
    {
      "id": "thig12.1:8.3",
      "pali": "Puññampimā vaheyyuṁ te,"
    },
    {
      "id": "thig12.1:8.4",
      "pali": "tena tvaṁ paribāhiro."
    },
    {
      "id": "thig12.1:9.1",
      "pali": "Yassa brāhmaṇa tvaṁ bhīto,"
    },
    {
      "id": "thig12.1:9.2",
      "pali": "sadā udakamotari;"
    },
    {
      "id": "thig12.1:9.3",
      "pali": "Tameva brahme mā kāsi,"
    },
    {
      "id": "thig12.1:9.4",
      "pali": "mā te sītaṁ chaviṁ hane”."
    },
    {
      "id": "thig12.1:10.1",
      "pali": "“Kummaggapaṭipannaṁ maṁ,"
    },
    {
      "id": "thig12.1:10.2",
      "pali": "ariyamaggaṁ samānayi;"
    },
    {
      "id": "thig12.1:10.3",
      "pali": "Dakābhisecanā bhoti,"
    },
    {
      "id": "thig12.1:10.4",
      "pali": "imaṁ sāṭaṁ dadāmi te”."
    },
    {
      "id": "thig12.1:11.1",
      "pali": "“Tuyheva sāṭako hotu,"
    },
    {
      "id": "thig12.1:11.2",
      "pali": "nāhamicchāmi sāṭakaṁ;"
    },
    {
      "id": "thig12.1:11.3",
      "pali": "Sace bhāyasi dukkhassa,"
    },
    {
      "id": "thig12.1:11.4",
      "pali": "sace te dukkhamappiyaṁ."
    },
    {
      "id": "thig12.1:12.1",
      "pali": "Mākāsi pāpakaṁ kammaṁ,"
    },
    {
      "id": "thig12.1:12.2",
      "pali": "āvi vā yadi vā raho;"
    },
    {
      "id": "thig12.1:12.3",
      "pali": "Sace ca pāpakaṁ kammaṁ,"
    },
    {
      "id": "thig12.1:12.4",
      "pali": "karissasi karosi vā."
    },
    {
      "id": "thig12.1:13.1",
      "pali": "Na te dukkhā pamutyatthi,"
    },
    {
      "id": "thig12.1:13.2",
      "pali": "upeccāpi palāyato;"
    },
    {
      "id": "thig12.1:13.3",
      "pali": "Sace bhāyasi dukkhassa,"
    },
    {
      "id": "thig12.1:13.4",
      "pali": "sace te dukkhamappiyaṁ."
    },
    {
      "id": "thig12.1:14.1",
      "pali": "Upehi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "thig12.1:14.2",
      "pali": "dhammaṁ saṅghañca tādinaṁ;"
    },
    {
      "id": "thig12.1:14.3",
      "pali": "Samādiyāhi sīlāni,"
    },
    {
      "id": "thig12.1:14.4",
      "pali": "taṁ te atthāya hehiti”."
    },
    {
      "id": "thig12.1:15.1",
      "pali": "“Upemi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "thig12.1:15.2",
      "pali": "dhammaṁ saṅghañca tādinaṁ;"
    },
    {
      "id": "thig12.1:15.3",
      "pali": "Samādiyāmi sīlāni,"
    },
    {
      "id": "thig12.1:15.4",
      "pali": "taṁ me atthāya hehiti."
    },
    {
      "id": "thig12.1:16.1",
      "pali": "Brahmabandhu pure āsiṁ,"
    },
    {
      "id": "thig12.1:16.2",
      "pali": "ajjamhi saccabrāhmaṇo;"
    },
    {
      "id": "thig12.1:16.3",
      "pali": "Tevijjo vedasampanno,"
    },
    {
      "id": "thig12.1:16.4",
      "pali": "sottiyo camhi nhātako”ti."
    },
    {
      "id": "thig12.1:17.1",
      "pali": "… Puṇṇā therī …."
    },
    {
      "id": "thig12.1:18.1",
      "pali": "Soḷasakanipāto niṭṭhito."
    }
  ]
}
