{
  "uid": "thig1.9",
  "title": "Bhadrātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.9:1.1",
      "pali": "“Saddhāya pabbajitvāna,"
    },
    {
      "id": "thig1.9:1.2",
      "pali": "bhadre bhadraratā bhava;"
    },
    {
      "id": "thig1.9:1.3",
      "pali": "Bhāvehi kusale dhamme,"
    },
    {
      "id": "thig1.9:1.4",
      "pali": "yogakkhemamanuttaran”ti."
    },
    {
      "id": "thig1.9:2.1",
      "pali": "… Bhadrā therī …."
    }
  ]
}
