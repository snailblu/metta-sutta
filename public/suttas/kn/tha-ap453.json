{
  "uid": "tha-ap453",
  "title": "Jagatidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap453:1.1",
      "pali": "“Dhammadassissa munino,"
    },
    {
      "id": "tha-ap453:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap453:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap453:1.4",
      "pali": "jagatiṁ kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap453:2.1",
      "pali": "Darito pabbatato vā,"
    },
    {
      "id": "tha-ap453:2.2",
      "pali": "rukkhato patito ahaṁ;"
    },
    {
      "id": "tha-ap453:2.3",
      "pali": "Cuto patiṭṭhaṁ vindāmi,"
    },
    {
      "id": "tha-ap453:2.4",
      "pali": "jagatiyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap453:3.1",
      "pali": "Na me corā vihesanti,"
    },
    {
      "id": "tha-ap453:3.2",
      "pali": "nātimaññanti khattiyā;"
    },
    {
      "id": "tha-ap453:3.3",
      "pali": "Sabbāmittetikkamāmi,"
    },
    {
      "id": "tha-ap453:3.4",
      "pali": "jagatiyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap453:4.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap453:4.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap453:4.3",
      "pali": "Sabbattha pūjito homi,"
    },
    {
      "id": "tha-ap453:4.4",
      "pali": "jagatiyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap453:5.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap453:5.2",
      "pali": "jagatiṁ kārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap453:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap453:5.4",
      "pali": "jagatidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap453:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap453:6.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap453:6.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap453:6.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap453:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap453:7.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap453:7.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap453:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap453:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap453:8.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap453:8.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap453:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap453:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā jagatidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap453:10.1",
      "pali": "Jagatidāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
