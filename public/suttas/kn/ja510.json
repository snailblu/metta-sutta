{
  "uid": "ja510",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja510:1.1",
      "pali": "“Yamekarattiṁ paṭhamaṁ,"
    },
    {
      "id": "ja510:1.2",
      "pali": "gabbhe vasati māṇavo;"
    },
    {
      "id": "ja510:1.3",
      "pali": "Abbhuṭṭhitova so yāti,"
    },
    {
      "id": "ja510:1.4",
      "pali": "sagacchaṁ na nivattati."
    },
    {
      "id": "ja510:2.1",
      "pali": "Na yujjhamānā na balenavassitā,"
    },
    {
      "id": "ja510:2.2",
      "pali": "Narā na jīranti na cāpi miyyare;"
    },
    {
      "id": "ja510:2.3",
      "pali": "Sabbaṁ hidaṁ jātijarāyupaddutaṁ,"
    },
    {
      "id": "ja510:2.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:3.1",
      "pali": "Caturaṅginiṁ senaṁ subhiṁsarūpaṁ,"
    },
    {
      "id": "ja510:3.2",
      "pali": "Jayanti raṭṭhādhipatī pasayha;"
    },
    {
      "id": "ja510:3.3",
      "pali": "Na maccuno jayitumussahanti,"
    },
    {
      "id": "ja510:3.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:4.1",
      "pali": "Hatthīhi assehi rathehi pattibhi,"
    },
    {
      "id": "ja510:4.2",
      "pali": "Parivāritā muccare ekacceyyā;"
    },
    {
      "id": "ja510:4.3",
      "pali": "Na maccuno muccitumussahanti,"
    },
    {
      "id": "ja510:4.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:5.1",
      "pali": "Hatthīhi assehi rathehi pattibhi,"
    },
    {
      "id": "ja510:5.2",
      "pali": "Sūrā pabhañjanti padhaṁsayanti;"
    },
    {
      "id": "ja510:5.3",
      "pali": "Na maccuno bhañjitumussahanti,"
    },
    {
      "id": "ja510:5.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:6.1",
      "pali": "Mattā gajā bhinnagaḷā pabhinnā,"
    },
    {
      "id": "ja510:6.2",
      "pali": "Nagarāni maddanti janaṁ hananti;"
    },
    {
      "id": "ja510:6.3",
      "pali": "Na maccuno madditumussahanti,"
    },
    {
      "id": "ja510:6.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:7.1",
      "pali": "Issāsino katahatthāpi vīrā,"
    },
    {
      "id": "ja510:7.2",
      "pali": "Dūrepātī akkhaṇavedhinopi;"
    },
    {
      "id": "ja510:7.3",
      "pali": "Na maccuno vijjhitumussahanti,"
    },
    {
      "id": "ja510:7.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:8.1",
      "pali": "Sarāni khīyanti saselakānanā,"
    },
    {
      "id": "ja510:8.2",
      "pali": "Sabbaṁ hidaṁ khīyati dīghamantaraṁ;"
    },
    {
      "id": "ja510:8.3",
      "pali": "Sabbaṁ hidaṁ bhañjare kālapariyāyaṁ,"
    },
    {
      "id": "ja510:8.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:9.1",
      "pali": "Sabbesa mevaṁ hi narāna nārinaṁ,"
    },
    {
      "id": "ja510:9.2",
      "pali": "Calācalaṁ pāṇabhunodha jīvitaṁ;"
    },
    {
      "id": "ja510:9.3",
      "pali": "Paṭova dhuttassa dumova kūlajo,"
    },
    {
      "id": "ja510:9.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:10.1",
      "pali": "Dumapphalāneva patanti māṇavā,"
    },
    {
      "id": "ja510:10.2",
      "pali": "Daharā ca vuddhā ca sarīrabhedā;"
    },
    {
      "id": "ja510:10.3",
      "pali": "Nāriyo narā majjhimaporisā ca,"
    },
    {
      "id": "ja510:10.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:11.1",
      "pali": "Nāyaṁ vayo tārakarājasannibho,"
    },
    {
      "id": "ja510:11.2",
      "pali": "Yadabbhatītaṁ gatameva dāni taṁ;"
    },
    {
      "id": "ja510:11.3",
      "pali": "Jiṇṇassa hī natthi ratī kuto sukhaṁ,"
    },
    {
      "id": "ja510:11.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:12.1",
      "pali": "Yakkhā pisācā athavāpi petā,"
    },
    {
      "id": "ja510:12.2",
      "pali": "Kupitā te assasanti manusse;"
    },
    {
      "id": "ja510:12.3",
      "pali": "Na maccuno assasitussahanti,"
    },
    {
      "id": "ja510:12.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:13.1",
      "pali": "Yakkhe pisāce athavāpi pete,"
    },
    {
      "id": "ja510:13.2",
      "pali": "Kupitepi te nijjhapanaṁ karonti;"
    },
    {
      "id": "ja510:13.3",
      "pali": "Na maccuno nijjhapanaṁ karonti,"
    },
    {
      "id": "ja510:13.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:14.1",
      "pali": "Aparādhake dūsake heṭhake ca,"
    },
    {
      "id": "ja510:14.2",
      "pali": "Rājāno daṇḍenti viditvāna dosaṁ;"
    },
    {
      "id": "ja510:14.3",
      "pali": "Na maccuno daṇḍayitussahanti,"
    },
    {
      "id": "ja510:14.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:15.1",
      "pali": "Aparādhakā dūsakā heṭhakā ca,"
    },
    {
      "id": "ja510:15.2",
      "pali": "Labhanti te rājino nijjhapetuṁ;"
    },
    {
      "id": "ja510:15.3",
      "pali": "Na maccuno nijjhapanaṁ karonti,"
    },
    {
      "id": "ja510:15.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:16.1",
      "pali": "Na khattiyoti na ca brāhmaṇoti,"
    },
    {
      "id": "ja510:16.2",
      "pali": "Na aḍḍhakā balavā tejavāpi;"
    },
    {
      "id": "ja510:16.3",
      "pali": "Na maccurājassa apekkhamatthi,"
    },
    {
      "id": "ja510:16.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:17.1",
      "pali": "Sīhā ca byagghā ca athopi dīpiyo,"
    },
    {
      "id": "ja510:17.2",
      "pali": "Pasayha khādanti vipphandamānaṁ;"
    },
    {
      "id": "ja510:17.3",
      "pali": "Na maccuno khāditumussahanti,"
    },
    {
      "id": "ja510:17.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:18.1",
      "pali": "Māyākārā raṅgamajjhe karontā,"
    },
    {
      "id": "ja510:18.2",
      "pali": "Mohenti cakkhūni janassa tāvade;"
    },
    {
      "id": "ja510:18.3",
      "pali": "Na maccuno mohayitussahanti,"
    },
    {
      "id": "ja510:18.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:19.1",
      "pali": "Āsīvisā kupitā uggatejā,"
    },
    {
      "id": "ja510:19.2",
      "pali": "Ḍaṁsanti mārentipi te manusse;"
    },
    {
      "id": "ja510:19.3",
      "pali": "Na maccuno ḍaṁsitumussahanti,"
    },
    {
      "id": "ja510:19.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:20.1",
      "pali": "Āsīvisā kupitā yaṁ ḍaṁsanti,"
    },
    {
      "id": "ja510:20.2",
      "pali": "Tikicchakā tesa visaṁ hananti;"
    },
    {
      "id": "ja510:20.3",
      "pali": "Na maccuno daṭṭhavisaṁ hananti,"
    },
    {
      "id": "ja510:20.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:21.1",
      "pali": "Dhammantarī vettaraṇī ca bhojo,"
    },
    {
      "id": "ja510:21.2",
      "pali": "Visāni hantvāna bhujaṅgamānaṁ;"
    },
    {
      "id": "ja510:21.3",
      "pali": "Suyyanti te kālakatā tatheva,"
    },
    {
      "id": "ja510:21.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:22.1",
      "pali": "Vijjādharā ghoramadhīyamānā,"
    },
    {
      "id": "ja510:22.2",
      "pali": "Adassanaṁ osadhehi vajanti;"
    },
    {
      "id": "ja510:22.3",
      "pali": "Na maccurājassa vajantadassanaṁ,"
    },
    {
      "id": "ja510:22.4",
      "pali": "Taṁ me matī hoti carāmi dhammaṁ."
    },
    {
      "id": "ja510:23.1",
      "pali": "Dhammo have rakkhati dhammacāriṁ,"
    },
    {
      "id": "ja510:23.2",
      "pali": "Dhammo suciṇṇo sukhamāvahāti;"
    },
    {
      "id": "ja510:23.3",
      "pali": "Esānisaṁso dhamme suciṇṇe,"
    },
    {
      "id": "ja510:23.4",
      "pali": "Na duggatiṁ gacchati dhammacārī."
    },
    {
      "id": "ja510:24.1",
      "pali": "Na hi dhammo adhammo ca,"
    },
    {
      "id": "ja510:24.2",
      "pali": "Ubho samavipākino;"
    },
    {
      "id": "ja510:24.3",
      "pali": "Adhammo nirayaṁ neti,"
    },
    {
      "id": "ja510:24.4",
      "pali": "Dhammo pāpeti suggatin”ti."
    },
    {
      "id": "ja510:25.1",
      "pali": "Ayogharajātakaṁ cuddasamaṁ."
    },
    {
      "id": "ja510:26.1",
      "pali": "Vīsatinipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja510:27.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja510:28.1",
      "pali": "Mātaṅga sambhūta sivi sirimanto,"
    },
    {
      "id": "ja510:28.2",
      "pali": "Rohaṇa haṁsa sattigumbo bhallātiya;"
    },
    {
      "id": "ja510:28.3",
      "pali": "Somanassa campeyya brahma pañca-"
    },
    {
      "id": "ja510:28.4",
      "pali": "Paṇḍita cirassaṁvata ayogharāti."
    }
  ]
}
