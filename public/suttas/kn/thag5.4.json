{
  "uid": "thag5.4",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.4:1.1",
      "pali": "“Yaṁ patthayāno dhammesu,"
    },
    {
      "id": "thag5.4:1.2",
      "pali": "upajjhāyo anuggahi;"
    },
    {
      "id": "thag5.4:1.3",
      "pali": "Amataṁ abhikaṅkhantaṁ,"
    },
    {
      "id": "thag5.4:1.4",
      "pali": "kataṁ kattabbakaṁ mayā."
    },
    {
      "id": "thag5.4:2.1",
      "pali": "Anuppatto sacchikato,"
    },
    {
      "id": "thag5.4:2.2",
      "pali": "sayaṁ dhammo anītiho;"
    },
    {
      "id": "thag5.4:2.3",
      "pali": "Visuddhañāṇo nikkaṅkho,"
    },
    {
      "id": "thag5.4:2.4",
      "pali": "byākaromi tavantike."
    },
    {
      "id": "thag5.4:3.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thag5.4:3.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thag5.4:3.3",
      "pali": "Sadattho me anuppatto,"
    },
    {
      "id": "thag5.4:3.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thag5.4:4.1",
      "pali": "Appamattassa me sikkhā,"
    },
    {
      "id": "thag5.4:4.2",
      "pali": "sussutā tava sāsane;"
    },
    {
      "id": "thag5.4:4.3",
      "pali": "Sabbe me āsavā khīṇā,"
    },
    {
      "id": "thag5.4:4.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thag5.4:5.1",
      "pali": "Anusāsi maṁ ariyavatā,"
    },
    {
      "id": "thag5.4:5.2",
      "pali": "Anukampi anuggahi;"
    },
    {
      "id": "thag5.4:5.3",
      "pali": "Amogho tuyhamovādo,"
    },
    {
      "id": "thag5.4:5.4",
      "pali": "Antevāsimhi sikkhito”ti."
    },
    {
      "id": "thag5.4:5.5",
      "pali": "… Sumano thero …."
    }
  ]
}
