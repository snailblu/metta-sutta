{
  "uid": "tha-ap45",
  "title": "3 Kāḷigodhāputtabhaddiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap45:1.1",
      "pali": "“Padumuttarasambuddhaṁ,"
    },
    {
      "id": "tha-ap45:1.2",
      "pali": "mettacittaṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap45:1.3",
      "pali": "Upeti janatā sabbā,"
    },
    {
      "id": "tha-ap45:1.4",
      "pali": "sabbalokagganāyakaṁ."
    },
    {
      "id": "tha-ap45:2.1",
      "pali": "Sattukañca baddhakañca,"
    },
    {
      "id": "tha-ap45:2.2",
      "pali": "āmisaṁ pānabhojanaṁ;"
    },
    {
      "id": "tha-ap45:2.3",
      "pali": "Dadanti satthuno sabbe,"
    },
    {
      "id": "tha-ap45:2.4",
      "pali": "puññakkhette anuttare."
    },
    {
      "id": "tha-ap45:3.1",
      "pali": "Ahampi dānaṁ dassāmi,"
    },
    {
      "id": "tha-ap45:3.2",
      "pali": "devadevassa tādino;"
    },
    {
      "id": "tha-ap45:3.3",
      "pali": "Buddhaseṭṭhaṁ nimantetvā,"
    },
    {
      "id": "tha-ap45:3.4",
      "pali": "saṅghampi ca anuttaraṁ."
    },
    {
      "id": "tha-ap45:4.1",
      "pali": "Uyyojitā mayā cete,"
    },
    {
      "id": "tha-ap45:4.2",
      "pali": "nimantesuṁ tathāgataṁ;"
    },
    {
      "id": "tha-ap45:4.3",
      "pali": "Kevalaṁ bhikkhusaṅghañca,"
    },
    {
      "id": "tha-ap45:4.4",
      "pali": "puññakkhettaṁ anuttaraṁ."
    },
    {
      "id": "tha-ap45:5.1",
      "pali": "Satasahassapallaṅkaṁ,"
    },
    {
      "id": "tha-ap45:5.2",
      "pali": "sovaṇṇaṁ gonakatthataṁ;"
    },
    {
      "id": "tha-ap45:5.3",
      "pali": "Tūlikāpaṭalikāya,"
    },
    {
      "id": "tha-ap45:5.4",
      "pali": "khomakappāsikehi ca;"
    },
    {
      "id": "tha-ap45:5.5",
      "pali": "Mahārahaṁ paññāpayiṁ,"
    },
    {
      "id": "tha-ap45:5.6",
      "pali": "āsanaṁ buddhayuttakaṁ."
    },
    {
      "id": "tha-ap45:6.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap45:6.2",
      "pali": "devadevo narāsabho;"
    },
    {
      "id": "tha-ap45:6.3",
      "pali": "Bhikkhusaṅghaparibyūḷho,"
    },
    {
      "id": "tha-ap45:6.4",
      "pali": "mama dvāramupāgami."
    },
    {
      "id": "tha-ap45:7.1",
      "pali": "Paccuggantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap45:7.2",
      "pali": "lokanāthaṁ yasassinaṁ;"
    },
    {
      "id": "tha-ap45:7.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap45:7.4",
      "pali": "abhināmayiṁ saṅgharaṁ."
    },
    {
      "id": "tha-ap45:8.1",
      "pali": "Bhikkhūnaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap45:8.2",
      "pali": "buddhañca lokanāyakaṁ;"
    },
    {
      "id": "tha-ap45:8.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap45:8.4",
      "pali": "paramannena tappayiṁ."
    },
    {
      "id": "tha-ap45:9.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap45:9.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap45:9.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap45:9.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap45:10.1",
      "pali": "‘Yenidaṁ āsanaṁ dinnaṁ,"
    },
    {
      "id": "tha-ap45:10.2",
      "pali": "sovaṇṇaṁ gonakatthataṁ;"
    },
    {
      "id": "tha-ap45:10.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap45:10.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap45:11.1",
      "pali": "Catusattatikkhattuṁ so,"
    },
    {
      "id": "tha-ap45:11.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap45:11.3",
      "pali": "Anubhossati sampattiṁ,"
    },
    {
      "id": "tha-ap45:11.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap45:12.1",
      "pali": "Padesarajjaṁ sahassaṁ,"
    },
    {
      "id": "tha-ap45:12.2",
      "pali": "vasudhaṁ āvasissati;"
    },
    {
      "id": "tha-ap45:12.3",
      "pali": "Ekapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap45:12.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap45:13.1",
      "pali": "Sabbāsu bhavayonīsu,"
    },
    {
      "id": "tha-ap45:13.2",
      "pali": "uccākulī bhavissati;"
    },
    {
      "id": "tha-ap45:13.3",
      "pali": "So ca pacchā pabbajitvā,"
    },
    {
      "id": "tha-ap45:13.4",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap45:13.5",
      "pali": "Bhaddiyo nāma nāmena,"
    },
    {
      "id": "tha-ap45:13.6",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap45:14.1",
      "pali": "Vivekamanuyuttomhi,"
    },
    {
      "id": "tha-ap45:14.2",
      "pali": "pantasenanivāsahaṁ;"
    },
    {
      "id": "tha-ap45:14.3",
      "pali": "Phalañcādhigataṁ sabbaṁ,"
    },
    {
      "id": "tha-ap45:14.4",
      "pali": "cattaklesomhi ajjahaṁ."
    },
    {
      "id": "tha-ap45:15.1",
      "pali": "Mama sabbaṁ abhiññāya,"
    },
    {
      "id": "tha-ap45:15.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap45:15.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap45:15.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap45:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap45:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap45:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap45:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhaddiyo kāḷigodhāya putto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap45:18.1",
      "pali": "Bhaddiyassa kāḷigodhāya puttattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
