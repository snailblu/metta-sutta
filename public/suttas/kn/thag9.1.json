{
  "uid": "thag9.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag9.1:1.1",
      "pali": "“Yadā dukkhaṁ jarāmaraṇanti paṇḍito,"
    },
    {
      "id": "thag9.1:1.2",
      "pali": "Aviddasū yattha sitā puthujjanā;"
    },
    {
      "id": "thag9.1:1.3",
      "pali": "Dukkhaṁ pariññāya satova jhāyati,"
    },
    {
      "id": "thag9.1:1.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:2.1",
      "pali": "Yadā dukkhassāvahaniṁ visattikaṁ,"
    },
    {
      "id": "thag9.1:2.2",
      "pali": "Papañcasaṅghātadukhādhivāhiniṁ;"
    },
    {
      "id": "thag9.1:2.3",
      "pali": "Taṇhaṁ pahantvāna satova jhāyati,"
    },
    {
      "id": "thag9.1:2.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:3.1",
      "pali": "Yadā sivaṁ dvecaturaṅgagāminaṁ,"
    },
    {
      "id": "thag9.1:3.2",
      "pali": "Magguttamaṁ sabbakilesasodhanaṁ;"
    },
    {
      "id": "thag9.1:3.3",
      "pali": "Paññāya passitva satova jhāyati,"
    },
    {
      "id": "thag9.1:3.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:4.1",
      "pali": "Yadā asokaṁ virajaṁ asaṅkhataṁ,"
    },
    {
      "id": "thag9.1:4.2",
      "pali": "Santaṁ padaṁ sabbakilesasodhanaṁ;"
    },
    {
      "id": "thag9.1:4.3",
      "pali": "Bhāveti saṁyojanabandhanacchidaṁ,"
    },
    {
      "id": "thag9.1:4.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:5.1",
      "pali": "Yadā nabhe gajjati meghadundubhi,"
    },
    {
      "id": "thag9.1:5.2",
      "pali": "Dhārākulā vihagapathe samantato;"
    },
    {
      "id": "thag9.1:5.3",
      "pali": "Bhikkhū ca pabbhāragatova jhāyati,"
    },
    {
      "id": "thag9.1:5.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:6.1",
      "pali": "Yadā nadīnaṁ kusumākulānaṁ,"
    },
    {
      "id": "thag9.1:6.2",
      "pali": "Vicitta-vāneyya-vaṭaṁsakānaṁ;"
    },
    {
      "id": "thag9.1:6.3",
      "pali": "Tīre nisinno sumanova jhāyati,"
    },
    {
      "id": "thag9.1:6.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:7.1",
      "pali": "Yadā nisīthe rahitamhi kānane,"
    },
    {
      "id": "thag9.1:7.2",
      "pali": "Deve gaḷantamhi nadanti dāṭhino;"
    },
    {
      "id": "thag9.1:7.3",
      "pali": "Bhikkhū ca pabbhāragatova jhāyati,"
    },
    {
      "id": "thag9.1:7.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:8.1",
      "pali": "Yadā vitakke uparundhiyattano,"
    },
    {
      "id": "thag9.1:8.2",
      "pali": "Nagantare nagavivaraṁ samassito;"
    },
    {
      "id": "thag9.1:8.3",
      "pali": "Vītaddaro vītakhilova jhāyati,"
    },
    {
      "id": "thag9.1:8.4",
      "pali": "Tato ratiṁ paramataraṁ na vindati."
    },
    {
      "id": "thag9.1:9.1",
      "pali": "Yadā sukhī malakhilasokanāsano,"
    },
    {
      "id": "thag9.1:9.2",
      "pali": "Niraggaḷo nibbanatho visallo;"
    },
    {
      "id": "thag9.1:9.3",
      "pali": "Sabbāsave byantikatova jhāyati,"
    },
    {
      "id": "thag9.1:9.4",
      "pali": "Tato ratiṁ paramataraṁ na vindatī”ti."
    },
    {
      "id": "thag9.1:9.5",
      "pali": "… Bhūto thero …"
    },
    {
      "id": "thag9.1:9.6",
      "pali": "Navakanipāto niṭṭhito."
    },
    {
      "id": "thag9.1:10.1",
      "pali": "Bhūto tathaddaso thero,"
    },
    {
      "id": "thag9.1:10.2",
      "pali": "eko khaggavisāṇavā;"
    },
    {
      "id": "thag9.1:10.3",
      "pali": "Navakamhi nipātamhi,"
    },
    {
      "id": "thag9.1:10.4",
      "pali": "gāthāyopi imā navāti."
    }
  ]
}
