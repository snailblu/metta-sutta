{
  "uid": "ps3.8",
  "title": "3.8. Satipaṭṭhānakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps3.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "ps3.8:1.2",
      "pali": "“Cattārome, bhikkhave, satipaṭṭhānā."
    },
    {
      "id": "ps3.8:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "ps3.8:1.4",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "ps3.8:1.5",
      "pali": "Vedanāsu …"
    },
    {
      "id": "ps3.8:1.6",
      "pali": "citte …"
    },
    {
      "id": "ps3.8:1.7",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "ps3.8:1.8",
      "pali": "Ime kho, bhikkhave, cattāro satipaṭṭhānā”ti."
    },
    {
      "id": "ps3.8:2.1",
      "pali": "Kathaṁ <b>kāye kāyānupassī viharati?</b>"
    },
    {
      "id": "ps3.8:2.2",
      "pali": "Idhekacco pathavīkāyaṁ aniccato anupassati, no niccato;"
    },
    {
      "id": "ps3.8:2.3",
      "pali": "dukkhato anupassati, no sukhato;"
    },
    {
      "id": "ps3.8:2.4",
      "pali": "anattato anupassati, no attato;"
    },
    {
      "id": "ps3.8:2.5",
      "pali": "nibbindati, no nandati;"
    },
    {
      "id": "ps3.8:2.6",
      "pali": "virajjati, no rajjati;"
    },
    {
      "id": "ps3.8:2.7",
      "pali": "nirodheti, no samudeti, paṭinissajjati, no ādiyati."
    },
    {
      "id": "ps3.8:2.8",
      "pali": "Aniccato anupassanto niccasaññaṁ pajahati, dukkhato anupassanto sukhasaññaṁ pajahati, anattato anupassanto attasaññaṁ pajahati, nibbindanto nandiṁ pajahati, virajjanto rāgaṁ pajahati, nirodhento samudayaṁ pajahati, paṭinissajjanto ādānaṁ pajahati."
    },
    {
      "id": "ps3.8:2.9",
      "pali": "Imehi sattahi ākārehi kāyaṁ anupassati."
    },
    {
      "id": "ps3.8:2.10",
      "pali": "Kāyo upaṭṭhānaṁ, no sati."
    },
    {
      "id": "ps3.8:2.11",
      "pali": "Sati upaṭṭhānañceva sati ca."
    },
    {
      "id": "ps3.8:2.12",
      "pali": "Tāya satiyā tena ñāṇena taṁ kāyaṁ anupassati."
    },
    {
      "id": "ps3.8:2.13",
      "pali": "Tena vuccati—"
    },
    {
      "id": "ps3.8:2.14",
      "pali": "“kāye kāyānupassanāsatipaṭṭhānā”."
    },
    {
      "id": "ps3.8:3.1",
      "pali": "<b>Bhāvanā</b>ti catasso bhāvanā—"
    },
