{
  "uid": "thag1.15",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.15:1.1",
      "pali": "“Pañca chinde pañca jahe,"
    },
    {
      "id": "thag1.15:1.2",
      "pali": "pañca cuttari bhāvaye;"
    },
    {
      "id": "thag1.15:1.3",
      "pali": "Pañca saṅgātigo bhikkhu,"
    },
    {
      "id": "thag1.15:1.4",
      "pali": "oghatiṇṇoti vuccatī”ti."
    },
    {
      "id": "thag1.15:1.5",
      "pali": "… Kuṇḍadhāno thero …."
    }
  ]
}
