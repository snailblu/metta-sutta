{
  "uid": "bv15",
  "title": "15 Piyadassībuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv15:1.1",
      "pali": "“Sujātassa aparena,"
    },
    {
      "id": "bv15:1.2",
      "pali": "sayambhū lokanāyako;"
    },
    {
      "id": "bv15:1.3",
      "pali": "Durāsado asamasamo,"
    },
    {
      "id": "bv15:1.4",
      "pali": "piyadassī mahāyaso."
    },
    {
      "id": "bv15:2.1",
      "pali": "Sopi buddho amitayaso,"
    },
    {
      "id": "bv15:2.2",
      "pali": "ādiccova virocati;"
    },
    {
      "id": "bv15:2.3",
      "pali": "Sabbaṁ tamaṁ nihantvāna,"
    },
    {
      "id": "bv15:2.4",
      "pali": "dhammacakkaṁ pavattayi."
    },
    {
      "id": "bv15:3.1",
      "pali": "Tassāpi atulatejassa,"
    },
    {
      "id": "bv15:3.2",
      "pali": "Ahesuṁ abhisamayā tayo;"
    },
    {
      "id": "bv15:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv15:3.4",
      "pali": "Paṭhamābhisamayo ahu."
    },
    {
      "id": "bv15:4.1",
      "pali": "Sudassano devarājā,"
    },
    {
      "id": "bv15:4.2",
      "pali": "micchādiṭṭhimarocayi;"
    },
    {
      "id": "bv15:4.3",
      "pali": "Tassa diṭṭhiṁ vinodento,"
    },
    {
      "id": "bv15:4.4",
      "pali": "satthā dhammamadesayi."
    },
    {
      "id": "bv15:5.1",
      "pali": "Janasannipāto atulo,"
    },
    {
      "id": "bv15:5.2",
      "pali": "mahāsannipatī tadā;"
    },
    {
      "id": "bv15:5.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv15:5.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv15:6.1",
      "pali": "Yadā doṇamukhaṁ hatthiṁ,"
    },
    {
      "id": "bv15:6.2",
      "pali": "vinesi narasārathi;"
    },
    {
      "id": "bv15:6.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv15:6.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv15:7.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv15:7.2",
      "pali": "tassāpi piyadassino;"
    },
    {
      "id": "bv15:7.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv15:7.4",
      "pali": "paṭhamo āsi samāgamo."
    },
    {
      "id": "bv15:8.1",
      "pali": "Tato paraṁ navutikoṭī,"
    },
    {
      "id": "bv15:8.2",
      "pali": "samiṁsu ekato munī;"
    },
    {
      "id": "bv15:8.3",
      "pali": "Tatiye sannipātamhi,"
    },
    {
      "id": "bv15:8.4",
      "pali": "asītikoṭiyo ahū."
    },
    {
      "id": "bv15:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv15:9.2",
      "pali": "kassapo nāma brāhmaṇo;"
    },
    {
      "id": "bv15:9.3",
      "pali": "Ajjhāyako mantadharo,"
    },
    {
      "id": "bv15:9.4",
      "pali": "tiṇṇaṁ vedāna pāragū."
    },
    {
      "id": "bv15:10.1",
      "pali": "Tassa dhammaṁ suṇitvāna,"
    },
    {
      "id": "bv15:10.2",
      "pali": "pasādaṁ janayiṁ ahaṁ;"
    },
    {
      "id": "bv15:10.3",
      "pali": "Koṭisatasahassehi,"
    },
    {
      "id": "bv15:10.4",
      "pali": "saṅghārāmaṁ amāpayiṁ."
    },
    {
      "id": "bv15:11.1",
      "pali": "Tassa datvāna ārāmaṁ,"
    },
    {
      "id": "bv15:11.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "bv15:11.3",
      "pali": "Saraṇe pañca sīle ca,"
    },
    {
      "id": "bv15:11.4",
      "pali": "daḷhaṁ katvā samādiyiṁ."
    },
    {
      "id": "bv15:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv15:12.2",
      "pali": "saṅghamajjhe nisīdiya;"
    },
    {
      "id": "bv15:12.3",
      "pali": "‘Aṭṭhārase kappasate,"
    },
    {
      "id": "bv15:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv15:13.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv15:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv15:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv15:14.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv15:14.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv15:14.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv15:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv15:15.1",
      "pali": "Sudhaññaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv15:15.2",
      "pali": "sudatto nāma khattiyo;"
    },
    {
      "id": "bv15:15.3",
      "pali": "Candā nāmāsi janikā,"
    },
    {
      "id": "bv15:15.4",
      "pali": "piyadassissa satthuno."
    },
    {
      "id": "bv15:16.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv15:16.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv15:16.3",
      "pali": "Sunimmalavimalagiriguhā,"
    },
    {
      "id": "bv15:16.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv15:17.1",
      "pali": "Tettiṁsasahassāni ca,"
    },
    {
      "id": "bv15:17.2",
      "pali": "Nāriyo samalaṅkatā;"
    },
    {
      "id": "bv15:17.3",
      "pali": "Vimalā nāma nārī ca,"
    },
    {
      "id": "bv15:17.4",
      "pali": "Kañcanāveḷo nāma atrajo."
    },
    {
      "id": "bv15:18.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv15:18.2",
      "pali": "rathayānena nikkhami;"
    },
    {
      "id": "bv15:18.3",
      "pali": "Chamāsaṁ padhānacāraṁ,"
    },
    {
      "id": "bv15:18.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv15:19.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv15:19.2",
      "pali": "piyadassī mahāmuni;"
    },
    {
      "id": "bv15:19.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv15:19.4",
      "pali": "usabhuyyāne manorame."
    },
    {
      "id": "bv15:20.1",
      "pali": "Pālito sabbadassī ca,"
    },
    {
      "id": "bv15:20.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv15:20.3",
      "pali": "Sobhito nāmupaṭṭhāko,"
    },
    {
      "id": "bv15:20.4",
      "pali": "piyadassissa satthuno."
    },
    {
      "id": "bv15:21.1",
      "pali": "Sujātā dhammadinnā ca,"
    },
    {
      "id": "bv15:21.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv15:21.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv15:21.4",
      "pali": "kakudhoti pavuccati."
    },
    {
      "id": "bv15:22.1",
      "pali": "Sandhako dhammako ceva,"
    },
    {
      "id": "bv15:22.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv15:22.3",
      "pali": "Visākhā dhammadinnā ca,"
    },
    {
      "id": "bv15:22.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv15:23.1",
      "pali": "Sopi buddho amitayaso,"
    },
    {
      "id": "bv15:23.2",
      "pali": "dvattiṁsavaralakkhaṇo;"
    },
    {
      "id": "bv15:23.3",
      "pali": "Asītihatthamubbedho,"
    },
    {
      "id": "bv15:23.4",
      "pali": "sālarājāva dissati."
    },
    {
      "id": "bv15:24.1",
      "pali": "Aggicandasūriyānaṁ,"
    },
    {
      "id": "bv15:24.2",
      "pali": "natthi tādisikā pabhā;"
    },
    {
      "id": "bv15:24.3",
      "pali": "Yathā ahu pabhā tassa,"
    },
    {
      "id": "bv15:24.4",
      "pali": "asamassa mahesino."
    },
    {
      "id": "bv15:25.1",
      "pali": "Tassāpi devadevassa,"
    },
    {
      "id": "bv15:25.2",
      "pali": "āyu tāvatakaṁ ahu;"
    },
    {
      "id": "bv15:25.3",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv15:25.4",
      "pali": "loke aṭṭhāsi cakkhumā."
    },
    {
      "id": "bv15:26.1",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv15:26.2",
      "pali": "Yugānipi tāni atuliyāni;"
    },
    {
      "id": "bv15:26.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv15:26.4",
      "pali": "Nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv15:27.1",
      "pali": "Piyadassī munivaro,"
    },
    {
      "id": "bv15:27.2",
      "pali": "Assatthārāmamhi nibbuto;"
    },
    {
      "id": "bv15:27.3",
      "pali": "Tatthevassa jinathūpo,"
    },
    {
      "id": "bv15:27.4",
      "pali": "Tīṇiyojanamuggato”ti."
    },
    {
      "id": "bv15:28.1",
      "pali": "Piyadassissa bhagavato vaṁso terasamo."
    }
  ]
}
