{
  "uid": "snp1.11",
  "title": "Vijayasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp1.11:1.1",
      "pali": "Caraṁ vā yadi vā tiṭṭhaṁ,"
    },
    {
      "id": "snp1.11:1.2",
      "pali": "nisinno uda vā sayaṁ;"
    },
    {
      "id": "snp1.11:1.3",
      "pali": "Samiñjeti pasāreti,"
    },
    {
      "id": "snp1.11:1.4",
      "pali": "esā kāyassa iñjanā."
    },
    {
      "id": "snp1.11:2.1",
      "pali": "Aṭṭhinahārusaṁyutto,"
    },
    {
      "id": "snp1.11:2.2",
      "pali": "tacamaṁsāvalepano;"
    },
    {
      "id": "snp1.11:2.3",
      "pali": "Chaviyā kāyo paṭicchanno,"
    },
    {
      "id": "snp1.11:2.4",
      "pali": "yathābhūtaṁ na dissati."
    },
    {
      "id": "snp1.11:3.1",
      "pali": "Antapūro udarapūro,"
    },
    {
      "id": "snp1.11:3.2",
      "pali": "yakanapeḷassa vatthino;"
    },
    {
      "id": "snp1.11:3.3",
      "pali": "Hadayassa papphāsassa,"
    },
    {
      "id": "snp1.11:3.4",
      "pali": "vakkassa pihakassa ca."
    },
    {
      "id": "snp1.11:4.1",
      "pali": "Siṅghāṇikāya kheḷassa,"
    },
    {
      "id": "snp1.11:4.2",
      "pali": "sedassa ca medassa ca;"
    },
    {
      "id": "snp1.11:4.3",
      "pali": "Lohitassa lasikāya,"
    },
    {
      "id": "snp1.11:4.4",
      "pali": "pittassa ca vasāya ca."
    },
    {
      "id": "snp1.11:5.1",
      "pali": "Athassa navahi sotehi,"
    },
    {
      "id": "snp1.11:5.2",
      "pali": "asucī savati sabbadā;"
    },
    {
      "id": "snp1.11:5.3",
      "pali": "Akkhimhā akkhigūthako,"
    },
    {
      "id": "snp1.11:5.4",
      "pali": "kaṇṇamhā kaṇṇagūthako."
    },
    {
      "id": "snp1.11:6.1",
      "pali": "Siṅghāṇikā ca nāsato,"
    },
    {
      "id": "snp1.11:6.2",
      "pali": "mukhena vamatekadā;"
    },
    {
      "id": "snp1.11:6.3",
      "pali": "Pittaṁ semhañca vamati,"
    },
    {
      "id": "snp1.11:6.4",
      "pali": "kāyamhā sedajallikā."
    },
    {
      "id": "snp1.11:7.1",
      "pali": "Athassa susiraṁ sīsaṁ,"
    },
    {
      "id": "snp1.11:7.2",
      "pali": "matthaluṅgassa pūritaṁ;"
    },
    {
      "id": "snp1.11:7.3",
      "pali": "Subhato naṁ maññati bālo,"
    },
    {
      "id": "snp1.11:7.4",
      "pali": "avijjāya purakkhato."
    },
    {
      "id": "snp1.11:8.1",
      "pali": "Yadā ca so mato seti,"
    },
    {
      "id": "snp1.11:8.2",
      "pali": "Uddhumāto vinīlako;"
    },
    {
      "id": "snp1.11:8.3",
      "pali": "Apaviddho susānasmiṁ,"
    },
    {
      "id": "snp1.11:8.4",
      "pali": "Anapekkhā honti ñātayo."
    },
    {
      "id": "snp1.11:9.1",
      "pali": "Khādanti naṁ suvānā ca,"
    },
    {
      "id": "snp1.11:9.2",
      "pali": "siṅgālā ca vakā kimī;"
    },
    {
      "id": "snp1.11:9.3",
      "pali": "Kākā gijjhā ca khādanti,"
    },
    {
      "id": "snp1.11:9.4",
      "pali": "ye caññe santi pāṇino."
    },
    {
      "id": "snp1.11:10.1",
      "pali": "Sutvāna buddhavacanaṁ,"
    },
    {
      "id": "snp1.11:10.2",
      "pali": "Bhikkhu paññāṇavā idha;"
    },
    {
      "id": "snp1.11:10.3",
      "pali": "So kho naṁ parijānāti,"
    },
    {
      "id": "snp1.11:10.4",
      "pali": "Yathābhūtañhi passati."
    },
    {
      "id": "snp1.11:11.1",
      "pali": "Yathā idaṁ tathā etaṁ,"
    },
    {
      "id": "snp1.11:11.2",
      "pali": "Yathā etaṁ tathā idaṁ;"
    },
    {
      "id": "snp1.11:11.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "snp1.11:11.4",
      "pali": "Kāye chandaṁ virājaye."
    },
    {
      "id": "snp1.11:12.1",
      "pali": "Chandarāgaviratto so,"
    },
    {
      "id": "snp1.11:12.2",
      "pali": "Bhikkhu paññāṇavā idha;"
    },
    {
      "id": "snp1.11:12.3",
      "pali": "Ajjhagā amataṁ santiṁ,"
    },
    {
      "id": "snp1.11:12.4",
      "pali": "Nibbānaṁ padamaccutaṁ."
    },
    {
      "id": "snp1.11:13.1",
      "pali": "Dvipādakoyaṁ asuci,"
    },
    {
      "id": "snp1.11:13.2",
      "pali": "Duggandho parihīrati;"
    },
    {
      "id": "snp1.11:13.3",
      "pali": "Nānākuṇapaparipūro,"
    },
    {
      "id": "snp1.11:13.4",
      "pali": "Vissavanto tato tato."
    },
    {
      "id": "snp1.11:14.1",
      "pali": "Etādisena kāyena,"
    },
    {
      "id": "snp1.11:14.2",
      "pali": "Yo maññe uṇṇametave;"
    },
    {
      "id": "snp1.11:14.3",
      "pali": "Paraṁ vā avajāneyya,"
    },
    {
      "id": "snp1.11:14.4",
      "pali": "Kimaññatra adassanāti."
    },
    {
      "id": "snp1.11:14.5",
      "pali": "Vijayasuttaṁ ekādasamaṁ."
    }
  ]
}
