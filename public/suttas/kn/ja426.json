{
  "uid": "ja426",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja426:1.1",
      "pali": "“Khamanīyaṁ yāpanīyaṁ,"
    },
    {
      "id": "ja426:1.2",
      "pali": "kacci mātula te sukhaṁ;"
    },
    {
      "id": "ja426:1.3",
      "pali": "Sukhaṁ te ammā avaca,"
    },
    {
      "id": "ja426:1.4",
      "pali": "sukhakāmāva te mayaṁ”."
    },
    {
      "id": "ja426:2.1",
      "pali": "“Naṅguṭṭhaṁ me avakkamma,"
    },
    {
      "id": "ja426:2.2",
      "pali": "Heṭhayitvāna eḷike;"
    },
    {
      "id": "ja426:2.3",
      "pali": "Sājja mātulavādena,"
    },
    {
      "id": "ja426:2.4",
      "pali": "Muñcitabbā nu maññasi”."
    },
    {
      "id": "ja426:3.1",
      "pali": "“Puratthāmukho nisinnosi,"
    },
    {
      "id": "ja426:3.2",
      "pali": "Ahaṁ te mukhamāgatā;"
    },
    {
      "id": "ja426:3.3",
      "pali": "Pacchato tuyhaṁ naṅguṭṭhaṁ,"
    },
    {
      "id": "ja426:3.4",
      "pali": "Kathaṁ khvāhaṁ avakkamiṁ”."
    },
    {
      "id": "ja426:4.1",
      "pali": "“Yāvatā caturo dīpā,"
    },
    {
      "id": "ja426:4.2",
      "pali": "sasamuddā sapabbatā;"
    },
    {
      "id": "ja426:4.3",
      "pali": "Tāvatā mayhaṁ naṅguṭṭhaṁ,"
    },
    {
      "id": "ja426:4.4",
      "pali": "kathaṁ kho tvaṁ vivajjayi”."
    },
    {
      "id": "ja426:5.1",
      "pali": "“Pubbeva metamakkhiṁsu,"
    },
    {
      "id": "ja426:5.2",
      "pali": "mātā pitā ca bhātaro;"
    },
    {
      "id": "ja426:5.3",
      "pali": "Dīghaṁ duṭṭhassa naṅguṭṭhaṁ,"
    },
    {
      "id": "ja426:5.4",
      "pali": "sāmhi vehāyasāgatā”."
    },
    {
      "id": "ja426:6.1",
      "pali": "“Tañca disvāna āyantiṁ,"
    },
    {
      "id": "ja426:6.2",
      "pali": "antalikkhasmi eḷike;"
    },
    {
      "id": "ja426:6.3",
      "pali": "Migasaṅgho palāyittha,"
    },
    {
      "id": "ja426:6.4",
      "pali": "bhakkho me nāsito tayā”."
    },
    {
      "id": "ja426:7.1",
      "pali": "“Iccevaṁ vilapantiyā,"
    },
    {
      "id": "ja426:7.2",
      "pali": "eḷakiyā ruhagghaso;"
    },
    {
      "id": "ja426:7.3",
      "pali": "Galakaṁ anvāvamaddi,"
    },
    {
      "id": "ja426:7.4",
      "pali": "natthi duṭṭhe subhāsitaṁ."
    },
    {
      "id": "ja426:8.1",
      "pali": "Neva duṭṭhe nayo atthi,"
    },
    {
      "id": "ja426:8.2",
      "pali": "Na dhammo na subhāsitaṁ;"
    },
    {
      "id": "ja426:8.3",
      "pali": "Nikkamaṁ duṭṭhe yuñjetha,"
    },
    {
      "id": "ja426:8.4",
      "pali": "So ca sabbhiṁ na rañjatī”ti."
    },
    {
      "id": "ja426:9.1",
      "pali": "Dīpijātakaṁ dasamaṁ."
    },
    {
      "id": "ja426:10.1",
      "pali": "Aṭṭhakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja426:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja426:12.1",
      "pali": "Parisuddhā manāvilā vatthadharā,"
    },
    {
      "id": "ja426:12.2",
      "pali": "Bakarājassa kāyuraṁ daṇḍavaro;"
    },
    {
      "id": "ja426:12.3",
      "pali": "Atha aṅgāra cetiya devilinā,"
    },
    {
      "id": "ja426:12.4",
      "pali": "Atha āditta gaṅgā daseḷakināti."
    }
  ]
}
