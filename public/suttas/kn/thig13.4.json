{
  "uid": "thig13.4",
  "title": "Sundarītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig13.4:1.1",
      "pali": "“Petāni bhoti puttāni,"
    },
    {
      "id": "thig13.4:1.2",
      "pali": "khādamānā tuvaṁ pure;"
    },
    {
      "id": "thig13.4:1.3",
      "pali": "Tuvaṁ divā ca ratto ca,"
    },
    {
      "id": "thig13.4:1.4",
      "pali": "atīva paritappasi."
    },
    {
      "id": "thig13.4:2.1",
      "pali": "Sājja sabbāni khāditvā,"
    },
    {
      "id": "thig13.4:2.2",
      "pali": "sataputtāni brāhmaṇī;"
    },
    {
      "id": "thig13.4:2.3",
      "pali": "Vāseṭṭhi kena vaṇṇena,"
    },
    {
      "id": "thig13.4:2.4",
      "pali": "na bāḷhaṁ paritappasi”."
    },
    {
      "id": "thig13.4:3.1",
      "pali": "“Bahūni puttasatāni,"
    },
    {
      "id": "thig13.4:3.2",
      "pali": "ñātisaṅghasatāni ca;"
    },
    {
      "id": "thig13.4:3.3",
      "pali": "Khāditāni atītaṁse,"
    },
    {
      "id": "thig13.4:3.4",
      "pali": "mama tuyhañca brāhmaṇa."
    },
    {
      "id": "thig13.4:4.1",
      "pali": "Sāhaṁ nissaraṇaṁ ñatvā,"
    },
    {
      "id": "thig13.4:4.2",
      "pali": "jātiyā maraṇassa ca;"
    },
    {
      "id": "thig13.4:4.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "thig13.4:4.4",
      "pali": "na cāpi paritappayiṁ”."
    },
    {
      "id": "thig13.4:5.1",
      "pali": "“Abbhutaṁ vata vāseṭṭhi,"
    },
    {
      "id": "thig13.4:5.2",
      "pali": "vācaṁ bhāsasi edisiṁ;"
    },
    {
      "id": "thig13.4:5.3",
      "pali": "Kassa tvaṁ dhammamaññāya,"
    },
    {
      "id": "thig13.4:5.4",
      "pali": "giraṁ bhāsasi edisiṁ”."
    },
    {
      "id": "thig13.4:6.1",
      "pali": "“Esa brāhmaṇa sambuddho,"
    },
    {
      "id": "thig13.4:6.2",
      "pali": "nagaraṁ mithilaṁ pati;"
    },
    {
      "id": "thig13.4:6.3",
      "pali": "Sabbadukkhappahānāya,"
    },
    {
      "id": "thig13.4:6.4",
      "pali": "dhammaṁ desesi pāṇinaṁ."
    },
    {
      "id": "thig13.4:7.1",
      "pali": "Tassa brahme arahato,"
    },
    {
      "id": "thig13.4:7.2",
      "pali": "dhammaṁ sutvā nirūpadhiṁ;"
    },
    {
      "id": "thig13.4:7.3",
      "pali": "Tattha viññātasaddhammā,"
    },
    {
      "id": "thig13.4:7.4",
      "pali": "puttasokaṁ byapānudiṁ”."
    },
    {
      "id": "thig13.4:8.1",
      "pali": "“So ahampi gamissāmi,"
    },
    {
      "id": "thig13.4:8.2",
      "pali": "nagaraṁ mithilaṁ pati;"
    },
    {
      "id": "thig13.4:8.3",
      "pali": "Appeva maṁ so bhagavā,"
    },
    {
      "id": "thig13.4:8.4",
      "pali": "sabbadukkhā pamocaye”."
    },
    {
      "id": "thig13.4:9.1",
      "pali": "Addasa brāhmaṇo buddhaṁ,"
    },
    {
      "id": "thig13.4:9.2",
      "pali": "vippamuttaṁ nirūpadhiṁ;"
    },
    {
      "id": "thig13.4:9.3",
      "pali": "Svassa dhammamadesesi,"
    },
    {
      "id": "thig13.4:9.4",
      "pali": "muni dukkhassa pāragū."
    },
    {
      "id": "thig13.4:10.1",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "thig13.4:10.2",
      "pali": "dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "thig13.4:10.3",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "thig13.4:10.4",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "thig13.4:11.1",
      "pali": "Tattha viññātasaddhammo,"
    },
    {
      "id": "thig13.4:11.2",
      "pali": "pabbajjaṁ samarocayi;"
    },
    {
      "id": "thig13.4:11.3",
      "pali": "Sujāto tīhi rattīhi,"
    },
    {
      "id": "thig13.4:11.4",
      "pali": "tisso vijjā aphassayi."
    },
    {
      "id": "thig13.4:12.1",
      "pali": "“Ehi sārathi gacchāhi,"
    },
    {
      "id": "thig13.4:12.2",
      "pali": "rathaṁ niyyādayāhimaṁ;"
    },
    {
      "id": "thig13.4:12.3",
      "pali": "Ārogyaṁ brāhmaṇiṁ vajja,"
    },
    {
      "id": "thig13.4:12.4",
      "pali": "‘pabbaji dāni brāhmaṇo;"
    },
    {
      "id": "thig13.4:12.5",
      "pali": "Sujāto tīhi rattīhi,"
    },
    {
      "id": "thig13.4:12.6",
      "pali": "tisso vijjā aphassayi’”."
    },
    {
      "id": "thig13.4:13.1",
      "pali": "Tato ca rathamādāya,"
    },
    {
      "id": "thig13.4:13.2",
      "pali": "sahassañcāpi sārathi;"
    },
    {
      "id": "thig13.4:13.3",
      "pali": "Ārogyaṁ brāhmaṇiṁvoca,"
    },
    {
      "id": "thig13.4:13.4",
      "pali": "“pabbaji dāni brāhmaṇo;"
    },
    {
      "id": "thig13.4:13.5",
      "pali": "Sujāto tīhi rattīhi,"
    },
    {
      "id": "thig13.4:13.6",
      "pali": "tisso vijjā aphassayi”."
    },
    {
      "id": "thig13.4:14.1",
      "pali": "“Etañcāhaṁ assarathaṁ,"
    },
    {
      "id": "thig13.4:14.2",
      "pali": "sahassañcāpi sārathi;"
    },
    {
      "id": "thig13.4:14.3",
      "pali": "Tevijjaṁ brāhmaṇaṁ sutvā,"
    },
    {
      "id": "thig13.4:14.4",
      "pali": "puṇṇapattaṁ dadāmi te”."
    },
    {
      "id": "thig13.4:15.1",
      "pali": "“Tuyheva hotvassaratho,"
    },
    {
      "id": "thig13.4:15.2",
      "pali": "sahassañcāpi brāhmaṇi;"
    },
    {
      "id": "thig13.4:15.3",
      "pali": "Ahampi pabbajissāmi,"
    },
    {
      "id": "thig13.4:15.4",
      "pali": "varapaññassa santike”."
    },
    {
      "id": "thig13.4:16.1",
      "pali": "“Hatthī gavassaṁ maṇikuṇḍalañca,"
    },
    {
      "id": "thig13.4:16.2",
      "pali": "Phītañcimaṁ gahavibhavaṁ pahāya;"
    },
    {
      "id": "thig13.4:16.3",
      "pali": "Pitā pabbajito tuyhaṁ,"
    },
    {
      "id": "thig13.4:16.4",
      "pali": "Bhuñja bhogāni sundarī;"
    },
    {
      "id": "thig13.4:16.5",
      "pali": "Tuvaṁ dāyādikā kule”."
    },
    {
      "id": "thig13.4:17.1",
      "pali": "“Hatthī gavassaṁ maṇikuṇḍalañca,"
    },
    {
      "id": "thig13.4:17.2",
      "pali": "Rammaṁ cimaṁ gahavibhavaṁ pahāya;"
    },
    {
      "id": "thig13.4:17.3",
      "pali": "Pitā pabbajito mayhaṁ,"
    },
    {
      "id": "thig13.4:17.4",
      "pali": "Puttasokena aṭṭito;"
    },
    {
      "id": "thig13.4:17.5",
      "pali": "Ahampi pabbajissāmi,"
    },
    {
      "id": "thig13.4:17.6",
      "pali": "Bhātusokena aṭṭitā”."
    },
    {
      "id": "thig13.4:18.1",
      "pali": "“So te ijjhatu saṅkappo,"
    },
    {
      "id": "thig13.4:18.2",
      "pali": "yaṁ tvaṁ patthesi sundarī;"
    },
    {
      "id": "thig13.4:18.3",
      "pali": "Uttiṭṭhapiṇḍo uñcho ca,"
    },
    {
      "id": "thig13.4:18.4",
      "pali": "paṁsukūlañca cīvaraṁ;"
    },
    {
      "id": "thig13.4:18.5",
      "pali": "Etāni abhisambhontī,"
    },
    {
      "id": "thig13.4:18.6",
      "pali": "paraloke anāsavā”."
    },
    {
      "id": "thig13.4:19.1",
      "pali": "“Sikkhamānāya me ayye,"
    },
    {
      "id": "thig13.4:19.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thig13.4:19.3",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thig13.4:19.4",
      "pali": "yattha me vusitaṁ pure."
    },
    {
      "id": "thig13.4:20.1",
      "pali": "Tuvaṁ nissāya kalyāṇi,"
    },
    {
      "id": "thig13.4:20.2",
      "pali": "theri saṅghassa sobhane;"
    },
    {
      "id": "thig13.4:20.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig13.4:20.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig13.4:21.1",
      "pali": "Anujānāhi me ayye,"
    },
    {
      "id": "thig13.4:21.2",
      "pali": "icche sāvatthi gantave;"
    },
    {
      "id": "thig13.4:21.3",
      "pali": "Sīhanādaṁ nadissāmi,"
    },
    {
      "id": "thig13.4:21.4",
      "pali": "buddhaseṭṭhassa santike”."
    },
    {
      "id": "thig13.4:22.1",
      "pali": "“Passa sundari satthāraṁ,"
    },
    {
      "id": "thig13.4:22.2",
      "pali": "hemavaṇṇaṁ harittacaṁ;"
    },
    {
      "id": "thig13.4:22.3",
      "pali": "Adantānaṁ dametāraṁ,"
    },
    {
      "id": "thig13.4:22.4",
      "pali": "sambuddhamakutobhayaṁ”."
    },
    {
      "id": "thig13.4:23.1",
      "pali": "“Passa sundarimāyantiṁ,"
    },
    {
      "id": "thig13.4:23.2",
      "pali": "vippamuttaṁ nirūpadhiṁ;"
    },
    {
      "id": "thig13.4:23.3",
      "pali": "Vītarāgaṁ visaṁyuttaṁ,"
    },
    {
      "id": "thig13.4:23.4",
      "pali": "katakiccamanāsavaṁ."
    },
    {
      "id": "thig13.4:24.1",
      "pali": "Bārāṇasito nikkhamma,"
    },
    {
      "id": "thig13.4:24.2",
      "pali": "tava santikamāgatā;"
    },
    {
      "id": "thig13.4:24.3",
      "pali": "Sāvikā te mahāvīra,"
    },
    {
      "id": "thig13.4:24.4",
      "pali": "pāde vandati sundarī."
    },
    {
      "id": "thig13.4:25.1",
      "pali": "Tuvaṁ buddho tuvaṁ satthā,"
    },
    {
      "id": "thig13.4:25.2",
      "pali": "tuyhaṁ dhītāmhi brāhmaṇa;"
    },
    {
      "id": "thig13.4:25.3",
      "pali": "Orasā mukhato jātā,"
    },
    {
      "id": "thig13.4:25.4",
      "pali": "katakiccā anāsavā”."
    },
    {
      "id": "thig13.4:26.1",
      "pali": "“Tassā te svāgataṁ bhadde,"
    },
    {
      "id": "thig13.4:26.2",
      "pali": "tato te adurāgataṁ;"
    },
    {
      "id": "thig13.4:26.3",
      "pali": "Evañhi dantā āyanti,"
    },
    {
      "id": "thig13.4:26.4",
      "pali": "satthu pādāni vandikā;"
    },
    {
      "id": "thig13.4:26.5",
      "pali": "Vītarāgā visaṁyuttā,"
    },
    {
      "id": "thig13.4:26.6",
      "pali": "katakiccā anāsavā”."
    },
    {
      "id": "thig13.4:27.1",
      "pali": "… Sundarī therī …."
    }
  ]
}
