{
  "uid": "thag1.80",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.80:1.1",
      "pali": "“Yaṁ mayā pakataṁ kammaṁ,"
    },
    {
      "id": "thag1.80:1.2",
      "pali": "appaṁ vā yadi vā bahuṁ;"
    },
    {
      "id": "thag1.80:1.3",
      "pali": "Sabbametaṁ parikkhīṇaṁ,"
    },
    {
      "id": "thag1.80:1.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag1.80:1.5",
      "pali": "… Uggo thero …"
    },
    {
      "id": "thag1.80:1.6",
      "pali": "vaggo aṭṭhamo."
    },
    {
      "id": "thag1.80:2.1",
      "pali": "Vacchapālo ca yo thero,"
    },
    {
      "id": "thag1.80:2.2",
      "pali": "ātumo māṇavo isi;"
    },
    {
      "id": "thag1.80:2.3",
      "pali": "Suyāmano susārado,"
    },
    {
      "id": "thag1.80:2.4",
      "pali": "thero yo ca piyañjaho;"
    },
    {
      "id": "thag1.80:2.5",
      "pali": "Ārohaputto meṇḍasiro,"
    },
    {
      "id": "thag1.80:2.6",
      "pali": "rakkhito uggasavhayoti."
    }
  ]
}
