{
  "uid": "thag7.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag7.5:1.1",
      "pali": "“Sare hatthehi bhañjitvā,"
    },
    {
      "id": "thag7.5:1.2",
      "pali": "katvāna kuṭimacchisaṁ;"
    },
    {
      "id": "thag7.5:1.3",
      "pali": "Tena me sarabhaṅgoti,"
    },
    {
      "id": "thag7.5:1.4",
      "pali": "nāmaṁ sammutiyā ahu."
    },
    {
      "id": "thag7.5:2.1",
      "pali": "Na mayhaṁ kappate ajja,"
    },
    {
      "id": "thag7.5:2.2",
      "pali": "sare hatthehi bhañjituṁ;"
    },
    {
      "id": "thag7.5:2.3",
      "pali": "Sikkhāpadā no paññattā,"
    },
    {
      "id": "thag7.5:2.4",
      "pali": "gotamena yasassinā."
    },
    {
      "id": "thag7.5:3.1",
      "pali": "Sakalaṁ samattaṁ rogaṁ,"
    },
    {
      "id": "thag7.5:3.2",
      "pali": "Sarabhaṅgo nāddasaṁ pubbe;"
    },
    {
      "id": "thag7.5:3.3",
      "pali": "Soyaṁ rogo diṭṭho,"
    },
    {
      "id": "thag7.5:3.4",
      "pali": "Vacanakarenātidevassa."
    },
    {
      "id": "thag7.5:4.1",
      "pali": "Yeneva maggena gato vipassī,"
    },
    {
      "id": "thag7.5:4.2",
      "pali": "Yeneva maggena sikhī ca vessabhū;"
    },
    {
      "id": "thag7.5:4.3",
      "pali": "Kakusandhakoṇāgamano ca kassapo,"
    },
    {
      "id": "thag7.5:4.4",
      "pali": "Tenañjasena agamāsi gotamo."
    },
    {
      "id": "thag7.5:5.1",
      "pali": "Vītataṇhā anādānā,"
    },
    {
      "id": "thag7.5:5.2",
      "pali": "satta buddhā khayogadhā;"
    },
    {
      "id": "thag7.5:5.3",
      "pali": "Yehāyaṁ desito dhammo,"
    },
    {
      "id": "thag7.5:5.4",
      "pali": "dhammabhūtehi tādibhi."
    },
    {
      "id": "thag7.5:6.1",
      "pali": "Cattāri ariyasaccāni,"
    },
    {
      "id": "thag7.5:6.2",
      "pali": "anukampāya pāṇinaṁ;"
    },
    {
      "id": "thag7.5:6.3",
      "pali": "Dukkhaṁ samudayo maggo,"
    },
    {
      "id": "thag7.5:6.4",
      "pali": "nirodho dukkhasaṅkhayo."
    },
    {
      "id": "thag7.5:7.1",
      "pali": "Yasmiṁ nivattate dukkhaṁ,"
    },
    {
      "id": "thag7.5:7.2",
      "pali": "saṁsārasmiṁ anantakaṁ;"
    },
    {
      "id": "thag7.5:7.3",
      "pali": "Bhedā imassa kāyassa,"
    },
    {
      "id": "thag7.5:7.4",
      "pali": "jīvitassa ca saṅkhayā;"
    },
    {
      "id": "thag7.5:7.5",
      "pali": "Añño punabbhavo natthi,"
    },
    {
      "id": "thag7.5:7.6",
      "pali": "suvimuttomhi sabbadhī”ti."
    },
    {
      "id": "thag7.5:7.7",
      "pali": "… Sarabhaṅgo thero …"
    },
    {
      "id": "thag7.5:7.8",
      "pali": "Sattakanipāto niṭṭhito."
    },
    {
      "id": "thag7.5:8.1",
      "pali": "Sundarasamuddo thero,"
    },
    {
      "id": "thag7.5:8.2",
      "pali": "thero lakuṇḍabhaddiyo;"
    },
    {
      "id": "thag7.5:8.3",
      "pali": "Bhaddo thero ca sopāko,"
    },
    {
      "id": "thag7.5:8.4",
      "pali": "sarabhaṅgo mahāisi;"
    },
    {
      "id": "thag7.5:8.5",
      "pali": "Sattake pañcakā therā,"
    },
    {
      "id": "thag7.5:8.6",
      "pali": "gāthāyo pañcatiṁsatīti."
    }
  ]
}
