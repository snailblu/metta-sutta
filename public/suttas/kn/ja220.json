{
  "uid": "ja220",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja220:1.1",
      "pali": "“Sukhaṁ jīvitarūposi,"
    },
    {
      "id": "ja220:1.2",
      "pali": "raṭṭhā vivanamāgato;"
    },
    {
      "id": "ja220:1.3",
      "pali": "So ekako rukkhamūle,"
    },
    {
      "id": "ja220:1.4",
      "pali": "kapaṇo viya jhāyasi”."
    },
    {
      "id": "ja220:2.1",
      "pali": "“Sukhaṁ jīvitarūposmi,"
    },
    {
      "id": "ja220:2.2",
      "pali": "raṭṭhā vivanamāgato;"
    },
    {
      "id": "ja220:2.3",
      "pali": "So ekako rukkhamūle,"
    },
    {
      "id": "ja220:2.4",
      "pali": "kapaṇo viya jhāyāmi;"
    },
    {
      "id": "ja220:2.5",
      "pali": "Sataṁ dhammaṁ anussaran”ti."
    },
    {
      "id": "ja220:3.1",
      "pali": "Dhammadhajajātakaṁ dasamaṁ."
    },
    {
      "id": "ja220:3.2",
      "pali": "Bīraṇathambhavaggo sattamo."
    },
    {
      "id": "ja220:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja220:5.1",
      "pali": "Atha bīraṇathambhavaro ca naṭo,"
    },
    {
      "id": "ja220:5.2",
      "pali": "Bharurājavaruttamapuṇṇanadī;"
    },
    {
      "id": "ja220:5.3",
      "pali": "Bahubhāṇi aggipavane mūsikā,"
    },
    {
      "id": "ja220:5.4",
      "pali": "Sahalambatthano kapaṇena dasāti."
    }
  ]
}
