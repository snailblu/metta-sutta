{
  "uid": "ja85",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja85:1.1",
      "pali": "“Āyatiṁ dosaṁ nāññāya,"
    },
    {
      "id": "ja85:1.2",
      "pali": "yo kāme paṭisevati;"
    },
    {
      "id": "ja85:1.3",
      "pali": "Vipākante hananti naṁ,"
    },
    {
      "id": "ja85:1.4",
      "pali": "kiṁpakkamiva bhakkhitan”ti."
    },
    {
      "id": "ja85:2.1",
      "pali": "Kiṁpakkajātakaṁ pañcamaṁ."
    }
  ]
}
