{
  "uid": "thag6.5",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.5:1.1",
      "pali": "“Manujassa pamattacārino,"
    },
    {
      "id": "thag6.5:1.2",
      "pali": "Taṇhā vaḍḍhati māluvā viya;"
    },
    {
      "id": "thag6.5:1.3",
      "pali": "So plavatī hurā huraṁ,"
    },
    {
      "id": "thag6.5:1.4",
      "pali": "Phalamicchaṁva vanasmi vānaro."
    },
    {
      "id": "thag6.5:2.1",
      "pali": "Yaṁ esā sahate jammī,"
    },
    {
      "id": "thag6.5:2.2",
      "pali": "taṇhā loke visattikā;"
    },
    {
      "id": "thag6.5:2.3",
      "pali": "Sokā tassa pavaḍḍhanti,"
    },
    {
      "id": "thag6.5:2.4",
      "pali": "abhivaṭṭhaṁva bīraṇaṁ."
    },
    {
      "id": "thag6.5:3.1",
      "pali": "Yo cetaṁ sahate jammiṁ,"
    },
    {
      "id": "thag6.5:3.2",
      "pali": "taṇhaṁ loke duraccayaṁ;"
    },
    {
      "id": "thag6.5:3.3",
      "pali": "Sokā tamhā papatanti,"
    },
    {
      "id": "thag6.5:3.4",
      "pali": "udabindūva pokkharā."
    },
    {
      "id": "thag6.5:4.1",
      "pali": "Taṁ vo vadāmi bhaddaṁ vo,"
    },
    {
      "id": "thag6.5:4.2",
      "pali": "yāvantettha samāgatā;"
    },
    {
      "id": "thag6.5:4.3",
      "pali": "Taṇhāya mūlaṁ khaṇatha,"
    },
    {
      "id": "thag6.5:4.4",
      "pali": "usīratthova bīraṇaṁ;"
    },
    {
      "id": "thag6.5:4.5",
      "pali": "Mā vo naḷaṁva sotova,"
    },
    {
      "id": "thag6.5:4.6",
      "pali": "māro bhañji punappunaṁ."
    },
    {
      "id": "thag6.5:5.1",
      "pali": "Karotha buddhavacanaṁ,"
    },
    {
      "id": "thag6.5:5.2",
      "pali": "khaṇo vo mā upaccagā;"
    },
    {
      "id": "thag6.5:5.3",
      "pali": "Khaṇātītā hi socanti,"
    },
    {
      "id": "thag6.5:5.4",
      "pali": "nirayamhi samappitā."
    },
    {
      "id": "thag6.5:6.1",
      "pali": "Pamādo rajo pamādo,"
    },
    {
      "id": "thag6.5:6.2",
      "pali": "pamādānupatito rajo;"
    },
    {
      "id": "thag6.5:6.3",
      "pali": "Appamādena vijjāya,"
    },
    {
      "id": "thag6.5:6.4",
      "pali": "abbahe sallamattano”ti."
    },
    {
      "id": "thag6.5:6.5",
      "pali": "… Mālukyaputto thero …."
    }
  ]
}
