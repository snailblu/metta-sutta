{
  "uid": "tha-ap494",
  "title": "Paṁsukūlapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap494:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap494:1.2",
      "pali": "udaṅgaṇo nāma pabbato;"
    },
    {
      "id": "tha-ap494:1.3",
      "pali": "Tatthaddasaṁ paṁsukūlaṁ,"
    },
    {
      "id": "tha-ap494:1.4",
      "pali": "dumaggamhi vilambitaṁ."
    },
    {
      "id": "tha-ap494:2.1",
      "pali": "Tīṇi kiṅkaṇipupphāni,"
    },
    {
      "id": "tha-ap494:2.2",
      "pali": "ocinitvānahaṁ tadā;"
    },
    {
      "id": "tha-ap494:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap494:2.4",
      "pali": "paṁsukūlamapūjayiṁ."
    },
    {
      "id": "tha-ap494:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap494:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap494:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap494:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap494:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap494:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap494:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap494:4.4",
      "pali": "pūjitvā arahaddhajaṁ."
    },
    {
      "id": "tha-ap494:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap494:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap494:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap494:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap494:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap494:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap494:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap494:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap494:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap494:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṁsukūlapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap494:9.1",
      "pali": "Paṁsukūlapūjakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
