{
  "uid": "cp15",
  "title": "Sīlapāramī 5",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp15:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp15:1.2",
      "pali": "mahiṁso pavanacārako;"
    },
    {
      "id": "cp15:1.3",
      "pali": "Pavaḍḍhakāyo balavā,"
    },
    {
      "id": "cp15:1.4",
      "pali": "mahanto bhīmadassano."
    },
    {
      "id": "cp15:2.1",
      "pali": "Pabbhāre giridugge ca,"
    },
    {
      "id": "cp15:2.2",
      "pali": "rukkhamūle dakāsaye;"
    },
    {
      "id": "cp15:2.3",
      "pali": "Hotettha ṭhānaṁ mahiṁsānaṁ,"
    },
    {
      "id": "cp15:2.4",
      "pali": "koci koci tahiṁ tahiṁ."
    },
    {
      "id": "cp15:3.1",
      "pali": "Vicaranto brahāraññe,"
    },
    {
      "id": "cp15:3.2",
      "pali": "ṭhānaṁ addasa bhaddakaṁ;"
    },
    {
      "id": "cp15:3.3",
      "pali": "Taṁ ṭhānaṁ upagantvāna,"
    },
    {
      "id": "cp15:3.4",
      "pali": "tiṭṭhāmi ca sayāmi ca."
    },
    {
      "id": "cp15:4.1",
      "pali": "Athettha kapimāgantvā,"
    },
    {
      "id": "cp15:4.2",
      "pali": "pāpo anariyo lahu;"
    },
    {
      "id": "cp15:4.3",
      "pali": "Khandhe nalāṭe bhamuke,"
    },
    {
      "id": "cp15:4.4",
      "pali": "mutteti ohadeti taṁ."
    },
    {
      "id": "cp15:5.1",
      "pali": "Sakimpi divasaṁ dutiyaṁ,"
    },
    {
      "id": "cp15:5.2",
      "pali": "tatiyaṁ catutthampi ca;"
    },
    {
      "id": "cp15:5.3",
      "pali": "Dūseti maṁ sabbakālaṁ,"
    },
    {
      "id": "cp15:5.4",
      "pali": "tena homi upadduto."
    },
    {
      "id": "cp15:6.1",
      "pali": "Mamaṁ upaddutaṁ disvā,"
    },
    {
      "id": "cp15:6.2",
      "pali": "yakkho maṁ idamabravi;"
    },
    {
      "id": "cp15:6.3",
      "pali": "‘Nāsehetaṁ chavaṁ pāpaṁ,"
    },
    {
      "id": "cp15:6.4",
      "pali": "siṅgehi ca khurehi ca’."
    },
    {
      "id": "cp15:7.1",
      "pali": "Evaṁ vutte, tadā yakkhe,"
    },
    {
      "id": "cp15:7.2",
      "pali": "ahaṁ taṁ idamabraviṁ;"
    },
    {
      "id": "cp15:7.3",
      "pali": "‘Kiṁ tvaṁ makkhesi kuṇapena,"
    },
    {
      "id": "cp15:7.4",
      "pali": "pāpena anariyena maṁ."
    },
    {
      "id": "cp15:8.1",
      "pali": "Yadihaṁ tassa pakuppeyyaṁ,"
    },
    {
      "id": "cp15:8.2",
      "pali": "tato hīnataro bhave;"
    },
    {
      "id": "cp15:8.3",
      "pali": "Sīlañca me pabhijjeyya,"
    },
    {
      "id": "cp15:8.4",
      "pali": "viññū ca garaheyyu maṁ."
    },
    {
      "id": "cp15:9.1",
      "pali": "Hīḷitā jīvitā vāpi,"
    },
    {
      "id": "cp15:9.2",
      "pali": "parisuddhena mataṁ varaṁ;"
    },
    {
      "id": "cp15:9.3",
      "pali": "Kyāhaṁ jīvitahetūpi,"
    },
    {
      "id": "cp15:9.4",
      "pali": "kāhāmi paraheṭhanaṁ’."
    },
    {
      "id": "cp15:10.1",
      "pali": "Mamevāyaṁ maññamāno,"
    },
    {
      "id": "cp15:10.2",
      "pali": "aññepevaṁ karissati;"
    },
    {
      "id": "cp15:10.3",
      "pali": "Teva tassa vadhissanti,"
    },
    {
      "id": "cp15:10.4",
      "pali": "sā me mutti bhavissati."
    },
    {
      "id": "cp15:11.1",
      "pali": "Hīnamajjhimaukkaṭṭhe,"
    },
    {
      "id": "cp15:11.2",
      "pali": "sahanto avamānitaṁ;"
    },
    {
      "id": "cp15:11.3",
      "pali": "Evaṁ labhati sappañño,"
    },
    {
      "id": "cp15:11.4",
      "pali": "manasā yathāpatthitan”ti."
    },
    {
      "id": "cp15:12.1",
      "pali": "Mahiṁsarājacariyaṁ pañcamaṁ."
    }
  ]
}
