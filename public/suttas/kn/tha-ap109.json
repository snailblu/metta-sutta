{
  "uid": "tha-ap109",
  "title": "Naḷamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap109:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap109:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap109:1.3",
      "pali": "Tiṇatthare nisinnassa,"
    },
    {
      "id": "tha-ap109:1.4",
      "pali": "upasantassa tādino."
    },
    {
      "id": "tha-ap109:2.1",
      "pali": "Naḷamālaṁ gahetvāna,"
    },
    {
      "id": "tha-ap109:2.2",
      "pali": "bandhitvā bījaniṁ ahaṁ;"
    },
    {
      "id": "tha-ap109:2.3",
      "pali": "Buddhassa upanāmesiṁ,"
    },
    {
      "id": "tha-ap109:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap109:3.1",
      "pali": "Paṭiggahetvā sabbaññū,"
    },
    {
      "id": "tha-ap109:3.2",
      "pali": "bījaniṁ lokanāyako;"
    },
    {
      "id": "tha-ap109:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap109:3.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "tha-ap109:4.1",
      "pali": "‘Yathā me kāyo nibbāti,"
    },
    {
      "id": "tha-ap109:4.2",
      "pali": "pariḷāho na vijjati;"
    },
    {
      "id": "tha-ap109:4.3",
      "pali": "Tatheva tividhaggīhi,"
    },
    {
      "id": "tha-ap109:4.4",
      "pali": "cittaṁ tava vimuccatu’."
    },
    {
      "id": "tha-ap109:5.1",
      "pali": "Sabbe devā samāgacchuṁ,"
    },
    {
      "id": "tha-ap109:5.2",
      "pali": "ye keci vananissitā;"
    },
    {
      "id": "tha-ap109:5.3",
      "pali": "Sossāma buddhavacanaṁ,"
    },
    {
      "id": "tha-ap109:5.4",
      "pali": "hāsayantañca dāyakaṁ."
    },
    {
      "id": "tha-ap109:6.1",
      "pali": "Nisinno bhagavā tattha,"
    },
    {
      "id": "tha-ap109:6.2",
      "pali": "devasaṅghapurakkhato;"
    },
    {
      "id": "tha-ap109:6.3",
      "pali": "Dāyakaṁ sampahaṁsento,"
    },
    {
      "id": "tha-ap109:6.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap109:7.1",
      "pali": "‘Iminā bījanidānena,"
    },
    {
      "id": "tha-ap109:7.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap109:7.3",
      "pali": "Subbato nāma nāmena,"
    },
    {
      "id": "tha-ap109:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap109:8.1",
      "pali": "Tena kammāvasesena,"
    },
    {
      "id": "tha-ap109:8.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap109:8.3",
      "pali": "Māluto nāma nāmena,"
    },
    {
      "id": "tha-ap109:8.4",
      "pali": "cakkavattī bhavissati’."
    },
    {
      "id": "tha-ap109:9.1",
      "pali": "Iminā bījanidānena,"
    },
    {
      "id": "tha-ap109:9.2",
      "pali": "sammānavipulena ca;"
    },
    {
      "id": "tha-ap109:9.3",
      "pali": "Kappasatasahassampi,"
    },
    {
      "id": "tha-ap109:9.4",
      "pali": "duggatiṁ nupapajjati."
    },
    {
      "id": "tha-ap109:10.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap109:10.2",
      "pali": "subbatā aṭṭhatiṁsa te;"
    },
    {
      "id": "tha-ap109:10.3",
      "pali": "Ekūnatiṁsasahasse,"
    },
    {
      "id": "tha-ap109:10.4",
      "pali": "aṭṭha mālutanāmakā."
    },
    {
      "id": "tha-ap109:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap109:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap109:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap109:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā naḷamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap109:13.1",
      "pali": "Naḷamāliyattherassāpadānaṁ sattamaṁ."
    },
    {
      "id": "tha-ap109:13.2",
      "pali": "Sattamabhāṇavāraṁ."
    }
  ]
}
