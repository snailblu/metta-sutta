{
  "uid": "vv22",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv22:1.1",
      "pali": "“Nīlā pītā ca kāḷā ca,"
    },
    {
      "id": "vv22:1.2",
      "pali": "mañjiṭṭhā atha lohitā;"
    },
    {
      "id": "vv22:1.3",
      "pali": "Uccāvacānaṁ vaṇṇānaṁ,"
    },
    {
      "id": "vv22:1.4",
      "pali": "kiñjakkhaparivāritā."
    },
    {
      "id": "vv22:2.1",
      "pali": "Mandāravānaṁ pupphānaṁ,"
    },
    {
      "id": "vv22:2.2",
      "pali": "mālaṁ dhāresi muddhani;"
    },
    {
      "id": "vv22:2.3",
      "pali": "Nayime aññesu kāyesu,"
    },
    {
      "id": "vv22:2.4",
      "pali": "rukkhā santi sumedhase."
    },
    {
      "id": "vv22:3.1",
      "pali": "Kena kāyaṁ upapannā,"
    },
    {
      "id": "vv22:3.2",
      "pali": "tāvatiṁsaṁ yasassinī;"
    },
    {
      "id": "vv22:3.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv22:3.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv22:4.1",
      "pali": "“Bhadditthikāti maṁ aññaṁsu,"
    },
    {
      "id": "vv22:4.2",
      "pali": "Kimilāyaṁ upāsikā;"
    },
    {
      "id": "vv22:4.3",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "vv22:4.4",
      "pali": "Saṁvibhāgaratā sadā."
    },
    {
      "id": "vv22:5.1",
      "pali": "Acchādanañca bhattañca,"
    },
    {
      "id": "vv22:5.2",
      "pali": "senāsanaṁ padīpiyaṁ;"
    },
    {
      "id": "vv22:5.3",
      "pali": "Adāsiṁ ujubhūtesu,"
    },
    {
      "id": "vv22:5.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "vv22:6.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv22:6.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv22:6.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv22:6.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "vv22:7.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "vv22:7.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "vv22:7.3",
      "pali": "Saññamā saṁvibhāgā ca,"
    },
    {
      "id": "vv22:7.4",
      "pali": "vimānaṁ āvasāmahaṁ."
    },
    {
      "id": "vv22:8.1",
      "pali": "Pāṇātipātā viratā,"
    },
    {
      "id": "vv22:8.2",
      "pali": "musāvādā ca saññatā;"
    },
    {
      "id": "vv22:8.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv22:8.4",
      "pali": "majjapānā ca ārakā."
    },
    {
      "id": "vv22:9.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv22:9.2",
      "pali": "Ariyasaccāna kovidā;"
    },
    {
      "id": "vv22:9.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv22:9.4",
      "pali": "Appamādavihārinī;"
    },
    {
      "id": "vv22:9.5",
      "pali": "Katāvāsā katakusalā tato cutā,"
    },
    {
      "id": "vv22:9.6",
      "pali": "Sayaṁpabhā anuvicarāmi nandanaṁ."
    },
    {
      "id": "vv22:10.1",
      "pali": "Bhikkhū cāhaṁ paramahitānukampake,"
    },
    {
      "id": "vv22:10.2",
      "pali": "Abhojayiṁ tapassiyugaṁ mahāmuniṁ;"
    },
    {
      "id": "vv22:10.3",
      "pali": "Katāvāsā katakusalā tato cutā,"
    },
    {
      "id": "vv22:10.4",
      "pali": "Sayaṁpabhā anuvicarāmi nandanaṁ."
    },
    {
      "id": "vv22:11.1",
      "pali": "Aṭṭhaṅgikaṁ aparimitaṁ sukhāvahaṁ,"
    },
    {
      "id": "vv22:11.2",
      "pali": "Uposathaṁ satatamupāvasiṁ ahaṁ;"
    },
    {
      "id": "vv22:11.3",
      "pali": "Katāvāsā katakusalā tato cutā,"
    },
    {
      "id": "vv22:11.4",
      "pali": "Sayaṁpabhā anuvicarāmi nandanan”ti."
    },
    {
      "id": "vv22:12.1",
      "pali": "Bhadditthivimānaṁ pañcamaṁ."
    }
  ]
}
