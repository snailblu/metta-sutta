{
  "uid": "ja527",
  "title": "Niḷinikāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja527:1.1",
      "pali": "“Nivesanaṁ kassa nudaṁ sunanda,"
    },
    {
      "id": "ja527:1.2",
      "pali": "Pākārena paṇḍumayena guttaṁ;"
    },
    {
      "id": "ja527:1.3",
      "pali": "Kā dissati aggisikhāva dūre,"
    },
    {
      "id": "ja527:1.4",
      "pali": "Vehāyasaṁ pabbataggeva acci."
    },
    {
      "id": "ja527:2.1",
      "pali": "Dhītā nvayaṁ kassa sunanda hoti,"
    },
    {
      "id": "ja527:2.2",
      "pali": "Suṇisā nvayaṁ kassa athopi bhariyā;"
    },
    {
      "id": "ja527:2.3",
      "pali": "Akkhāhi me khippamidheva puṭṭho,"
    },
    {
      "id": "ja527:2.4",
      "pali": "Avāvaṭā yadi vā atthi bhattā”."
    },
    {
      "id": "ja527:3.1",
      "pali": "“Ahañhi jānāmi janinda etaṁ,"
    },
    {
      "id": "ja527:3.2",
      "pali": "Matyā ca petyā ca athopi assā;"
    },
    {
      "id": "ja527:3.3",
      "pali": "Taveva so puriso bhūmipāla,"
    },
    {
      "id": "ja527:3.4",
      "pali": "Rattindivaṁ appamatto tavatthe."
    },
    {
      "id": "ja527:4.1",
      "pali": "Iddho ca phīto ca suvaḍḍhito ca,"
    },
    {
      "id": "ja527:4.2",
      "pali": "Amacco ca te aññataro janinda;"
    },
    {
      "id": "ja527:4.3",
      "pali": "Tassesā bhariyābhipārakassa,"
    },
    {
      "id": "ja527:4.4",
      "pali": "Ummādantī nāmadheyyena rāja”."
    },
    {
      "id": "ja527:5.1",
      "pali": "“Ambho ambho nāmamidaṁ imissā,"
    },
    {
      "id": "ja527:5.2",
      "pali": "Matyā ca petyā ca kataṁ susādhu;"
    },
    {
      "id": "ja527:5.3",
      "pali": "Tadā hi mayhaṁ avalokayantī,"
    },
    {
      "id": "ja527:5.4",
      "pali": "Ummattakaṁ ummadantī akāsi."
    },
    {
      "id": "ja527:6.1",
      "pali": "Yā puṇṇamāse migamandalocanā,"
    },
    {
      "id": "ja527:6.2",
      "pali": "Upāvisi puṇḍarīkattacaṅgī;"
    },
    {
      "id": "ja527:6.3",
      "pali": "Dve puṇṇamāyo tadahū amaññahaṁ,"
    },
    {
      "id": "ja527:6.4",
      "pali": "Disvāna pārāvatarattavāsiniṁ."
    },
    {
      "id": "ja527:7.1",
      "pali": "Aḷārapamhehi subhehi vaggubhi,"
    },
    {
      "id": "ja527:7.2",
      "pali": "Palobhayantī maṁ yadā udikkhati;"
    },
    {
      "id": "ja527:7.3",
      "pali": "Vijambhamānā harateva me mano,"
    },
    {
      "id": "ja527:7.4",
      "pali": "Jātā vane kimpurisīva pabbate."
    },
    {
      "id": "ja527:8.1",
      "pali": "Tadā hi brahatī sāmā,"
    },
    {
      "id": "ja527:8.2",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "ja527:8.3",
      "pali": "Ekaccavasanā nārī,"
    },
    {
      "id": "ja527:8.4",
      "pali": "migī bhantāvudikkhati."
    },
    {
      "id": "ja527:9.1",
      "pali": "Kadāssu maṁ tambanakhā sulomā,"
    },
    {
      "id": "ja527:9.2",
      "pali": "Bāhāmudū candanasāralittā;"
    },
    {
      "id": "ja527:9.3",
      "pali": "Vaṭṭaṅgulī sannatadhīrakuttiyā,"
    },
    {
      "id": "ja527:9.4",
      "pali": "Nārī upaññissati sīsato subhā."
    },
    {
      "id": "ja527:10.1",
      "pali": "Kadāssu maṁ kañcanajāluracchadā,"
    },
    {
      "id": "ja527:10.2",
      "pali": "Dhītā tirīṭissa vilaggamajjhā;"
    },
    {
      "id": "ja527:10.3",
      "pali": "Mudūhi bāhāhi palissajissati,"
    },
    {
      "id": "ja527:10.4",
      "pali": "Brahāvane jātadumaṁva māluvā."
    },
    {
      "id": "ja527:11.1",
      "pali": "Kadāssu lākhārasarattasucchavī,"
    },
    {
      "id": "ja527:11.2",
      "pali": "Bindutthanī puṇḍarīkattacaṅgī;"
    },
    {
      "id": "ja527:11.3",
      "pali": "Mukhaṁ mukhena upanāmayissati,"
    },
    {
      "id": "ja527:11.4",
      "pali": "Soṇḍova soṇḍassa surāya thālaṁ."
    },
    {
      "id": "ja527:12.1",
      "pali": "Yadāddasaṁ taṁ tiṭṭhantiṁ,"
    },
    {
      "id": "ja527:12.2",
      "pali": "Sabbabhaddaṁ manoramaṁ;"
    },
    {
      "id": "ja527:12.3",
      "pali": "Tato sakassa cittassa,"
    },
    {
      "id": "ja527:12.4",
      "pali": "Nāvabodhāmi kañcinaṁ."
    },
    {
      "id": "ja527:13.1",
      "pali": "Ummādantimahaṁ daṭṭhā,"
    },
    {
      "id": "ja527:13.2",
      "pali": "āmuttamaṇikuṇḍalaṁ;"
    },
    {
      "id": "ja527:13.3",
      "pali": "Na supāmi divārattiṁ,"
    },
    {
      "id": "ja527:13.4",
      "pali": "sahassaṁva parājito."
    },
    {
      "id": "ja527:14.1",
      "pali": "Sakko ce me varaṁ dajjā,"
    },
    {
      "id": "ja527:14.2",
      "pali": "so ca labbhetha me varo;"
    },
    {
      "id": "ja527:14.3",
      "pali": "Ekarattaṁ dvirattaṁ vā,"
    },
    {
      "id": "ja527:14.4",
      "pali": "bhaveyyaṁ abhipārako;"
    },
    {
      "id": "ja527:14.5",
      "pali": "Ummādantyā ramitvāna,"
    },
    {
      "id": "ja527:14.6",
      "pali": "sivirājā tato siyaṁ”."
    },
    {
      "id": "ja527:15.1",
      "pali": "“Bhūtāni me bhūtapatī namassato,"
    },
    {
      "id": "ja527:15.2",
      "pali": "Āgamma yakkho idametadabravi;"
    },
    {
      "id": "ja527:15.3",
      "pali": "Rañño mano ummadantyā niviṭṭho,"
    },
    {
      "id": "ja527:15.4",
      "pali": "Dadāmi te taṁ paricārayassu”."
    },
    {
      "id": "ja527:16.1",
      "pali": "“Puññā ca dhaṁse amaro na camhi,"
    },
    {
      "id": "ja527:16.2",
      "pali": "Jano ca me pāpamidañca jaññā;"
    },
    {
      "id": "ja527:16.3",
      "pali": "Bhuso ca tyassa manaso vighāto,"
    },
    {
      "id": "ja527:16.4",
      "pali": "Datvā piyaṁ ummadantiṁ adaṭṭhā”."
    },
    {
      "id": "ja527:17.1",
      "pali": "“Janinda nāññatra tayā mayā vā,"
    },
    {
      "id": "ja527:17.2",
      "pali": "Sabbāpi kammassa katassa jaññā;"
    },
    {
      "id": "ja527:17.3",
      "pali": "Yaṁ te mayā ummadantī padinnā,"
    },
    {
      "id": "ja527:17.4",
      "pali": "Bhusehi rājā vanathaṁ sajāhi”."
    },
    {
      "id": "ja527:18.1",
      "pali": "“Yo pāpakaṁ kamma karaṁ manusso,"
    },
    {
      "id": "ja527:18.2",
      "pali": "So maññati māyida maññiṁsu aññe;"
    },
    {
      "id": "ja527:18.3",
      "pali": "Passanti bhūtāni karontametaṁ,"
    },
    {
      "id": "ja527:18.4",
      "pali": "Yuttā ca ye honti narā pathabyā."
    },
    {
      "id": "ja527:19.1",
      "pali": "Añño nu te koci naro pathabyā,"
    },
    {
      "id": "ja527:19.2",
      "pali": "Saddheyya lokasmi na me piyāti;"
    },
    {
      "id": "ja527:19.3",
      "pali": "Bhuso ca tyassa manaso vighāto,"
    },
    {
      "id": "ja527:19.4",
      "pali": "Datvā piyaṁ ummadantiṁ adaṭṭhā”."
    },
    {
      "id": "ja527:20.1",
      "pali": "“Addhā piyā mayha janinda esā,"
    },
    {
      "id": "ja527:20.2",
      "pali": "Na sā mamaṁ appiyā bhūmipāla;"
    },
    {
      "id": "ja527:20.3",
      "pali": "Gaccheva tvaṁ ummadantiṁ bhadante,"
    },
    {
      "id": "ja527:20.4",
      "pali": "Sīhova selassa guhaṁ upeti”."
    },
    {
      "id": "ja527:21.1",
      "pali": "“Na pīḷitā attadukhena dhīrā,"
    },
    {
      "id": "ja527:21.2",
      "pali": "Sukhapphalaṁ kamma pariccajanti;"
    },
    {
      "id": "ja527:21.3",
      "pali": "Sammohitā vāpi sukhena mattā,"
    },
    {
      "id": "ja527:21.4",
      "pali": "Na pāpakammañca samācaranti”."
    },
    {
      "id": "ja527:22.1",
      "pali": "“Tuvañhi mātā ca pitā ca mayhaṁ,"
    },
    {
      "id": "ja527:22.2",
      "pali": "Bhattā patī posako devatā ca;"
    },
    {
      "id": "ja527:22.3",
      "pali": "Dāso ahaṁ tuyha saputtadāro,"
    },
    {
      "id": "ja527:22.4",
      "pali": "Yathāsukhaṁ sāmi karohi kāmaṁ”."
    },
    {
      "id": "ja527:23.1",
      "pali": "“Yo issaromhīti karoti pāpaṁ,"
    },
    {
      "id": "ja527:23.2",
      "pali": "Katvā ca so nuttasate paresaṁ;"
    },
    {
      "id": "ja527:23.3",
      "pali": "Na tena so jīvati dīghamāyu,"
    },
    {
      "id": "ja527:23.4",
      "pali": "Devāpi pāpena samekkhare naṁ."
    },
    {
      "id": "ja527:24.1",
      "pali": "Aññātakaṁ sāmikehī padinnaṁ,"
    },
    {
      "id": "ja527:24.2",
      "pali": "Dhamme ṭhitā ye paṭicchanti dānaṁ;"
    },
    {
      "id": "ja527:24.3",
      "pali": "Paṭicchakā dāyakā cāpi tattha,"
    },
    {
      "id": "ja527:24.4",
      "pali": "Sukhapphalaññeva karonti kammaṁ."
    },
    {
      "id": "ja527:25.1",
      "pali": "Añño nu te koci naro pathabyā,"
    },
    {
      "id": "ja527:25.2",
      "pali": "Saddheyya lokasmi na me piyāti;"
    },
    {
      "id": "ja527:25.3",
      "pali": "Bhuso ca tyassa manaso vighāto,"
    },
    {
      "id": "ja527:25.4",
      "pali": "Datvā piyaṁ ummadantiṁ adaṭṭhā”."
    },
    {
      "id": "ja527:26.1",
      "pali": "“Addhā piyā mayha janinda esā,"
    },
    {
      "id": "ja527:26.2",
      "pali": "Na sā mamaṁ appiyā bhūmipāla;"
    },
    {
      "id": "ja527:26.3",
      "pali": "Yaṁ te mayā ummadantī padinnā,"
    },
    {
      "id": "ja527:26.4",
      "pali": "Bhusehi rājā vanathaṁ sajāhi”."
    },
    {
      "id": "ja527:27.1",
      "pali": "“Yo attadukkhena parassa dukkhaṁ,"
    },
    {
      "id": "ja527:27.2",
      "pali": "Sukhena vā attasukhaṁ dahāti;"
    },
    {
      "id": "ja527:27.3",
      "pali": "Yathevidaṁ mayha tathā paresaṁ,"
    },
    {
      "id": "ja527:27.4",
      "pali": "Yo evaṁ jānāti sa vedi dhammaṁ."
    },
    {
      "id": "ja527:28.1",
      "pali": "Añño nu te koci naro pathabyā,"
    },
    {
      "id": "ja527:28.2",
      "pali": "Saddheyya lokasmi na me piyāti;"
    },
    {
      "id": "ja527:28.3",
      "pali": "Bhuso ca tyassa manaso vighāto,"
    },
    {
      "id": "ja527:28.4",
      "pali": "Datvā piyaṁ ummadantiṁ adaṭṭhā”."
    },
    {
      "id": "ja527:29.1",
      "pali": "“Janinda jānāsi piyā mamesā,"
    },
    {
      "id": "ja527:29.2",
      "pali": "Na sā mamaṁ appiyā bhūmipāla;"
    },
    {
      "id": "ja527:29.3",
      "pali": "Piyena te dammi piyaṁ janinda,"
    },
    {
      "id": "ja527:29.4",
      "pali": "Piyadāyino deva piyaṁ labhanti”."
    },
    {
      "id": "ja527:30.1",
      "pali": "“So nūnāhaṁ vadhissāmi,"
    },
    {
      "id": "ja527:30.2",
      "pali": "attānaṁ kāmahetukaṁ;"
    },
    {
      "id": "ja527:30.3",
      "pali": "Na hi dhammaṁ adhammena,"
    },
    {
      "id": "ja527:30.4",
      "pali": "ahaṁ vadhitumussahe”."
    },
    {
      "id": "ja527:31.1",
      "pali": "“Sace tuvaṁ mayha satiṁ janinda,"
    },
    {
      "id": "ja527:31.2",
      "pali": "Na kāmayāsi naravīra seṭṭha;"
    },
    {
      "id": "ja527:31.3",
      "pali": "Cajāmi naṁ sabbajanassa sibyā,"
    },
    {
      "id": "ja527:31.4",
      "pali": "Mayā pamuttaṁ tato avhayesi naṁ”."
    },
    {
      "id": "ja527:32.1",
      "pali": "“Adūsiyañce abhipāraka tvaṁ,"
    },
    {
      "id": "ja527:32.2",
      "pali": "Cajāsi katte ahitāya tyassa;"
    },
    {
      "id": "ja527:32.3",
      "pali": "Mahā ca te upavādopi assa,"
    },
    {
      "id": "ja527:32.4",
      "pali": "Na cāpi tyassa nagaramhi pakkho”."
    },
    {
      "id": "ja527:33.1",
      "pali": "“Ahaṁ sahissaṁ upavādametaṁ,"
    },
    {
      "id": "ja527:33.2",
      "pali": "Nindaṁ pasaṁsaṁ garahañca sabbaṁ;"
    },
    {
      "id": "ja527:33.3",
      "pali": "Mametamāgacchatu bhūmipāla,"
    },
    {
      "id": "ja527:33.4",
      "pali": "Yathāsukhaṁ sivi karohi kāmaṁ”."
    },
    {
      "id": "ja527:34.1",
      "pali": "“Yo neva nindaṁ na panappasaṁsaṁ,"
    },
    {
      "id": "ja527:34.2",
      "pali": "Ādiyati garahaṁ nopi pūjaṁ;"
    },
    {
      "id": "ja527:34.3",
      "pali": "Sirī ca lakkhī ca apeti tamhā,"
    },
    {
      "id": "ja527:34.4",
      "pali": "Āpo suvuṭṭhīva yathā thalamhā”."
    },
    {
      "id": "ja527:35.1",
      "pali": "“Yaṁ kiñci dukkhañca sukhañca etto,"
    },
    {
      "id": "ja527:35.2",
      "pali": "Dhammātisārañca manovighātaṁ;"
    },
    {
      "id": "ja527:35.3",
      "pali": "Urasā ahaṁ paccuttarissāmi sabbaṁ,"
    },
    {
      "id": "ja527:35.4",
      "pali": "Pathavī yathā thāvarānaṁ tasānaṁ”."
    },
    {
      "id": "ja527:36.1",
      "pali": "“Dhammātisārañca manovighātaṁ,"
    },
    {
      "id": "ja527:36.2",
      "pali": "Dukkhañca nicchāmi ahaṁ paresaṁ;"
    },
    {
      "id": "ja527:36.3",
      "pali": "Ekovimaṁ hārayissāmi bhāraṁ,"
    },
    {
      "id": "ja527:36.4",
      "pali": "Dhamme ṭhito kiñci ahāpayanto”."
    },
    {
      "id": "ja527:37.1",
      "pali": "“Saggūpagaṁ puññakammaṁ janinda,"
    },
    {
      "id": "ja527:37.2",
      "pali": "Mā me tuvaṁ antarāyaṁ akāsi;"
    },
    {
      "id": "ja527:37.3",
      "pali": "Dadāmi te ummadantiṁ pasanno,"
    },
    {
      "id": "ja527:37.4",
      "pali": "Rājāva yaññe dhanaṁ brāhmaṇānaṁ”."
    },
    {
      "id": "ja527:38.1",
      "pali": "“Addhā tuvaṁ katte hitesi mayhaṁ,"
    },
    {
      "id": "ja527:38.2",
      "pali": "Sakhā mamaṁ ummadantī tuvañca;"
    },
    {
      "id": "ja527:38.3",
      "pali": "Nindeyyu devā pitaro ca sabbe,"
    },
    {
      "id": "ja527:38.4",
      "pali": "Pāpañca passaṁ abhisamparāyaṁ”."
    },
    {
      "id": "ja527:39.1",
      "pali": "“Na hetadhammaṁ sivirāja vajjuṁ,"
    },
    {
      "id": "ja527:39.2",
      "pali": "Sanegamā jānapadā ca sabbe;"
    },
    {
      "id": "ja527:39.3",
      "pali": "Yaṁ te mayā ummadantī padinnā,"
    },
    {
      "id": "ja527:39.4",
      "pali": "Bhusehi rājā vanathaṁ sajāhi”."
    },
    {
      "id": "ja527:40.1",
      "pali": "“Addhā tuvaṁ katte hitesi mayhaṁ,"
    },
    {
      "id": "ja527:40.2",
      "pali": "Sakhā mamaṁ ummadantī tuvañca;"
    },
    {
      "id": "ja527:40.3",
      "pali": "Satañca dhammāni sukittitāni,"
    },
    {
      "id": "ja527:40.4",
      "pali": "Samuddavelāva duraccayāni”."
    },
    {
      "id": "ja527:41.1",
      "pali": "“Āhuneyyo mesi hitānukampī,"
    },
    {
      "id": "ja527:41.2",
      "pali": "Dhātā vidhātā casi kāmapālo;"
    },
    {
      "id": "ja527:41.3",
      "pali": "Tayī hutā rāja mahapphalā hi,"
    },
    {
      "id": "ja527:41.4",
      "pali": "Kāmena me ummadantiṁ paṭiccha”."
    },
    {
      "id": "ja527:42.1",
      "pali": "“Addhā hi sabbaṁ abhipāraka tvaṁ,"
    },
    {
      "id": "ja527:42.2",
      "pali": "Dhammaṁ acārī mama kattuputta;"
    },
    {
      "id": "ja527:42.3",
      "pali": "Añño nu te ko idha sotthikattā,"
    },
    {
      "id": "ja527:42.4",
      "pali": "Dvipado naro aruṇe jīvaloke”."
    },
    {
      "id": "ja527:43.1",
      "pali": "“Tuvaṁ nu seṭṭho tvamanuttarosi,"
    },
    {
      "id": "ja527:43.2",
      "pali": "Tvaṁ dhammagutto dhammavidū sumedho;"
    },
    {
      "id": "ja527:43.3",
      "pali": "So dhammagutto cirameva jīva,"
    },
    {
      "id": "ja527:43.4",
      "pali": "Dhammañca me desaya dhammapāla”."
    },
    {
      "id": "ja527:44.1",
      "pali": "“Tadiṅgha abhipāraka,"
    },
    {
      "id": "ja527:44.2",
      "pali": "suṇohi vacanaṁ mama;"
    },
    {
      "id": "ja527:44.3",
      "pali": "Dhammaṁ te desayissāmi,"
    },
    {
      "id": "ja527:44.4",
      "pali": "sataṁ āsevitaṁ ahaṁ."
    },
    {
      "id": "ja527:45.1",
      "pali": "Sādhu dhammaruci rājā,"
    },
    {
      "id": "ja527:45.2",
      "pali": "sādhu paññāṇavā naro;"
    },
    {
      "id": "ja527:45.3",
      "pali": "Sādhu mittānamaddubbho,"
    },
    {
      "id": "ja527:45.4",
      "pali": "pāpassākaraṇaṁ sukhaṁ."
    },
    {
      "id": "ja527:46.1",
      "pali": "Akkodhanassa vijite,"
    },
    {
      "id": "ja527:46.2",
      "pali": "ṭhitadhammassa rājino;"
    },
    {
      "id": "ja527:46.3",
      "pali": "Sukhaṁ manussā āsetha,"
    },
    {
      "id": "ja527:46.4",
      "pali": "sītacchāyāya saṅghare."
    },
    {
      "id": "ja527:47.1",
      "pali": "Na cāhametaṁ abhirocayāmi,"
    },
    {
      "id": "ja527:47.2",
      "pali": "Kammaṁ asamekkhakataṁ asādhu;"
    },
    {
      "id": "ja527:47.3",
      "pali": "Ye vāpi ñatvāna sayaṁ karonti,"
    },
    {
      "id": "ja527:47.4",
      "pali": "Upamā imā mayhaṁ tuvaṁ suṇohi."
    },
    {
      "id": "ja527:48.1",
      "pali": "Gavañce taramānānaṁ,"
    },
    {
      "id": "ja527:48.2",
      "pali": "jimhaṁ gacchati puṅgavo;"
    },
    {
      "id": "ja527:48.3",
      "pali": "Sabbā tā jimhaṁ gacchanti,"
    },
    {
      "id": "ja527:48.4",
      "pali": "nette jimhaṁ gate sati."
    },
    {
      "id": "ja527:49.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja527:49.2",
      "pali": "yo hoti seṭṭhasammato;"
    },
    {
      "id": "ja527:49.3",
      "pali": "So ce adhammaṁ carati,"
    },
    {
      "id": "ja527:49.4",
      "pali": "pageva itarā pajā;"
    },
    {
      "id": "ja527:49.5",
      "pali": "Sabbaṁ raṭṭhaṁ dukhaṁ seti,"
    },
    {
      "id": "ja527:49.6",
      "pali": "rājā ce hoti adhammiko."
    },
    {
      "id": "ja527:50.1",
      "pali": "Gavañce taramānānaṁ,"
    },
    {
      "id": "ja527:50.2",
      "pali": "ujuṁ gacchati puṅgavo;"
    },
    {
      "id": "ja527:50.3",
      "pali": "Sabbā gāvī ujuṁ yanti,"
    },
    {
      "id": "ja527:50.4",
      "pali": "nette ujuṁ gate sati."
    },
    {
      "id": "ja527:51.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja527:51.2",
      "pali": "yo hoti seṭṭhasammato;"
    },
    {
      "id": "ja527:51.3",
      "pali": "So sace dhammaṁ carati,"
    },
    {
      "id": "ja527:51.4",
      "pali": "pageva itarā pajā;"
    },
    {
      "id": "ja527:51.5",
      "pali": "Sabbaṁ raṭṭhaṁ sukhaṁ seti,"
    },
    {
      "id": "ja527:51.6",
      "pali": "rājā ce hoti dhammiko."
    },
    {
      "id": "ja527:52.1",
      "pali": "Na cāpāhaṁ adhammena,"
    },
    {
      "id": "ja527:52.2",
      "pali": "amarattamabhipatthaye;"
    },
    {
      "id": "ja527:52.3",
      "pali": "Imaṁ vā pathaviṁ sabbaṁ,"
    },
    {
      "id": "ja527:52.4",
      "pali": "vijetuṁ abhipāraka."
    },
    {
      "id": "ja527:53.1",
      "pali": "Yañhi kiñci manussesu,"
    },
    {
      "id": "ja527:53.2",
      "pali": "ratanaṁ idha vijjati;"
    },
    {
      "id": "ja527:53.3",
      "pali": "Gāvo dāso hiraññañca,"
    },
    {
      "id": "ja527:53.4",
      "pali": "vatthiyaṁ haricandanaṁ."
    },
    {
      "id": "ja527:54.1",
      "pali": "Assitthiyo ratanaṁ maṇikañca,"
    },
    {
      "id": "ja527:54.2",
      "pali": "Yañcāpi me candasūriyā abhipālayanti;"
    },
    {
      "id": "ja527:54.3",
      "pali": "Na tassa hetu visamaṁ careyyaṁ,"
    },
    {
      "id": "ja527:54.4",
      "pali": "Majjhe sivīnaṁ usabhomhi jāto."
    },
    {
      "id": "ja527:55.1",
      "pali": "Netā hitā uggato raṭṭhapālo,"
    },
    {
      "id": "ja527:55.2",
      "pali": "Dhammaṁ sivīnaṁ apacāyamāno;"
    },
    {
      "id": "ja527:55.3",
      "pali": "So dhammamevānuvicintayanto,"
    },
    {
      "id": "ja527:55.4",
      "pali": "Tasmā sake cittavase na vatto”."
    },
    {
      "id": "ja527:56.1",
      "pali": "“Addhā tuvaṁ mahārāja,"
    },
    {
      "id": "ja527:56.2",
      "pali": "niccaṁ abyasanaṁ sivaṁ;"
    },
    {
      "id": "ja527:56.3",
      "pali": "Karissasi ciraṁ rajjaṁ,"
    },
    {
      "id": "ja527:56.4",
      "pali": "paññā hi tava tādisī."
    },
    {
      "id": "ja527:57.1",
      "pali": "Etaṁ te anumodāma,"
    },
    {
      "id": "ja527:57.2",
      "pali": "yaṁ dhammaṁ nappamajjasi;"
    },
    {
      "id": "ja527:57.3",
      "pali": "Dhammaṁ pamajja khattiyo,"
    },
    {
      "id": "ja527:57.4",
      "pali": "raṭṭhā cavati issaro."
    },
    {
      "id": "ja527:58.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:58.2",
      "pali": "mātāpitūsu khattiya;"
    },
    {
      "id": "ja527:58.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja527:58.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja527:59.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:59.2",
      "pali": "puttadāresu khattiya;"
    },
    {
      "id": "ja527:59.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:60.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:60.2",
      "pali": "mittāmaccesu khattiya;"
    },
    {
      "id": "ja527:60.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:61.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:61.2",
      "pali": "vāhanesu balesu ca;"
    },
    {
      "id": "ja527:61.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:62.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:62.2",
      "pali": "gāmesu nigamesu ca;"
    },
    {
      "id": "ja527:62.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:63.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:63.2",
      "pali": "raṭṭhesu janapadesu ca;"
    },
    {
      "id": "ja527:63.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:64.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:64.2",
      "pali": "samaṇabrāhmaṇesu ca;"
    },
    {
      "id": "ja527:64.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:65.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:65.2",
      "pali": "migapakkhīsu khattiya;"
    },
    {
      "id": "ja527:65.3",
      "pali": "…pe…"
    },
    {
      "id": "ja527:66.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:66.2",
      "pali": "dhammo ciṇṇo sukhāvaho;"
    },
    {
      "id": "ja527:66.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja527:66.4",
      "pali": "rāja saggaṁ gamissasi."
    },
    {
      "id": "ja527:67.1",
      "pali": "Dhammaṁ cara mahārāja,"
    },
    {
      "id": "ja527:67.2",
      "pali": "saindā devā sabrahmakā;"
    },
    {
      "id": "ja527:67.3",
      "pali": "Suciṇṇena divaṁ pattā,"
    },
    {
      "id": "ja527:67.4",
      "pali": "mā dhammaṁ rāja pāmado”ti."
    },
    {
      "id": "ja527:68.1",
      "pali": "Ummādantījātakaṁ dutiyaṁ."
    }
  ]
}
