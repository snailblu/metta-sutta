{
  "uid": "ja57",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja57:1.1",
      "pali": "“Yassete caturo dhammā,"
    },
    {
      "id": "ja57:1.2",
      "pali": "vānarinda yathā tava;"
    },
    {
      "id": "ja57:1.3",
      "pali": "Saccaṁ dhammo dhiti cāgo,"
    },
    {
      "id": "ja57:1.4",
      "pali": "diṭṭhaṁ so ativattatī”ti."
    },
    {
      "id": "ja57:2.1",
      "pali": "Vānarindajātakaṁ sattamaṁ."
    }
  ]
}
