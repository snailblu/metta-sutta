{
  "uid": "thag1.43",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.43:1.1",
      "pali": "“Sumuttiko sumuttiko,"
    },
    {
      "id": "thag1.43:1.2",
      "pali": "Sāhu sumuttikomhi tīhi khujjakehi;"
    },
    {
      "id": "thag1.43:1.3",
      "pali": "Asitāsu mayā naṅgalāsu mayā,"
    },
    {
      "id": "thag1.43:1.4",
      "pali": "Khuddakuddālāsu mayā."
    },
    {
      "id": "thag1.43:1.5",
      "pali": "Yadipi idhameva idhameva,"
    },
    {
      "id": "thag1.43:1.6",
      "pali": "Atha vāpi alameva alameva;"
    },
    {
      "id": "thag1.43:1.7",
      "pali": "Jhāya sumaṅgala jhāya sumaṅgala,"
    },
    {
      "id": "thag1.43:1.8",
      "pali": "Appamatto vihara sumaṅgalā”ti."
    },
    {
      "id": "thag1.43:1.9",
      "pali": "… Sumaṅgalo thero …."
    }
  ]
}
