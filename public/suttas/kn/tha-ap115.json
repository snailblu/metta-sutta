{
  "uid": "tha-ap115",
  "title": "3 Saraṇagamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap115:1.1",
      "pali": "“Ubhinnaṁ devarājūnaṁ,"
    },
    {
      "id": "tha-ap115:1.2",
      "pali": "saṅgāmo samupaṭṭhito;"
    },
    {
      "id": "tha-ap115:1.3",
      "pali": "Ahosi samupabyūḷho,"
    },
    {
      "id": "tha-ap115:1.4",
      "pali": "mahāghoso avattatha."
    },
    {
      "id": "tha-ap115:2.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap115:2.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap115:2.3",
      "pali": "Antalikkhe ṭhito satthā,"
    },
    {
      "id": "tha-ap115:2.4",
      "pali": "saṁvejesi mahājanaṁ."
    },
    {
      "id": "tha-ap115:3.1",
      "pali": "Sabbe devā attamanā,"
    },
    {
      "id": "tha-ap115:3.2",
      "pali": "nikkhittakavacāvudhā;"
    },
    {
      "id": "tha-ap115:3.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap115:3.4",
      "pali": "ekaggāsiṁsu tāvade."
    },
    {
      "id": "tha-ap115:4.1",
      "pali": "Mayhaṁ saṅkappamaññāya,"
    },
    {
      "id": "tha-ap115:4.2",
      "pali": "vācāsabhimudīrayi;"
    },
    {
      "id": "tha-ap115:4.3",
      "pali": "Anukampako lokavidū,"
    },
    {
      "id": "tha-ap115:4.4",
      "pali": "nibbāpesi mahājanaṁ."
    },
    {
      "id": "tha-ap115:5.1",
      "pali": "Paduṭṭhacitto manujo,"
    },
    {
      "id": "tha-ap115:5.2",
      "pali": "ekapāṇaṁ viheṭhayaṁ;"
    },
    {
      "id": "tha-ap115:5.3",
      "pali": "Tena cittappadosena,"
    },
    {
      "id": "tha-ap115:5.4",
      "pali": "apāyaṁ upapajjati."
    },
    {
      "id": "tha-ap115:6.1",
      "pali": "Saṅgāmasīse nāgova,"
    },
    {
      "id": "tha-ap115:6.2",
      "pali": "bahū pāṇe viheṭhayaṁ;"
    },
    {
      "id": "tha-ap115:6.3",
      "pali": "Nibbāpetha sakaṁ cittaṁ,"
    },
    {
      "id": "tha-ap115:6.4",
      "pali": "mā haññittho punappunaṁ."
    },
    {
      "id": "tha-ap115:7.1",
      "pali": "Dvinnampi yakkharājūnaṁ,"
    },
    {
      "id": "tha-ap115:7.2",
      "pali": "senā sā vimhitā ahu;"
    },
    {
      "id": "tha-ap115:7.3",
      "pali": "Saraṇañca upāgacchuṁ,"
    },
    {
      "id": "tha-ap115:7.4",
      "pali": "lokajeṭṭhaṁ sutādinaṁ."
    },
    {
      "id": "tha-ap115:8.1",
      "pali": "Saññāpetvāna janataṁ,"
    },
    {
      "id": "tha-ap115:8.2",
      "pali": "padamuddhari cakkhumā;"
    },
    {
      "id": "tha-ap115:8.3",
      "pali": "Pekkhamānova devehi,"
    },
    {
      "id": "tha-ap115:8.4",
      "pali": "pakkāmi uttarāmukho."
    },
    {
      "id": "tha-ap115:9.1",
      "pali": "Paṭhamaṁ saraṇaṁ gacchiṁ,"
    },
    {
      "id": "tha-ap115:9.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap115:9.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap115:9.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap115:10.1",
      "pali": "Mahādundubhināmā ca,"
    },
    {
      "id": "tha-ap115:10.2",
      "pali": "soḷasāsuṁ rathesabhā;"
    },
    {
      "id": "tha-ap115:10.3",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap115:10.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap115:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap115:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap115:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap115:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā saraṇagamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap115:13.1",
      "pali": "Saraṇagamaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
