{
  "uid": "thag1.102",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.102:1.1",
      "pali": "“Mānena vañcitāse,"
    },
    {
      "id": "thag1.102:1.2",
      "pali": "Saṅkhāresu saṅkilissamānāse;"
    },
    {
      "id": "thag1.102:1.3",
      "pali": "Lābhālābhena mathitā,"
    },
    {
      "id": "thag1.102:1.4",
      "pali": "Samādhiṁ nādhigacchantī”ti."
    },
    {
      "id": "thag1.102:1.5",
      "pali": "… Setuccho thero …."
    }
  ]
}
