{
  "uid": "vv20",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv20:1.1",
      "pali": "“Piṇḍāya te carantassa,"
    },
    {
      "id": "vv20:1.2",
      "pali": "tuṇhībhūtassa tiṭṭhato;"
    },
    {
      "id": "vv20:1.3",
      "pali": "Daliddā kapaṇā nārī,"
    },
    {
      "id": "vv20:1.4",
      "pali": "parāgāraṁ apassitā."
    },
    {
      "id": "vv20:2.1",
      "pali": "Yā te adāsi ācāmaṁ,"
    },
    {
      "id": "vv20:2.2",
      "pali": "pasannā sehi pāṇibhi;"
    },
    {
      "id": "vv20:2.3",
      "pali": "Sā hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "vv20:2.4",
      "pali": "kaṁ nu sā disataṁ gatā”ti."
    },
    {
      "id": "vv20:3.1",
      "pali": "“Piṇḍāya me carantassa,"
    },
    {
      "id": "vv20:3.2",
      "pali": "tuṇhībhūtassa tiṭṭhato;"
    },
    {
      "id": "vv20:3.3",
      "pali": "Daliddā kapaṇā nārī,"
    },
    {
      "id": "vv20:3.4",
      "pali": "parāgāraṁ apassitā."
    },
    {
      "id": "vv20:4.1",
      "pali": "Yā me adāsi ācāmaṁ,"
    },
    {
      "id": "vv20:4.2",
      "pali": "pasannā sehi pāṇibhi;"
    },
    {
      "id": "vv20:4.3",
      "pali": "Sā hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "vv20:4.4",
      "pali": "vippamuttā ito cutā."
    },
    {
      "id": "vv20:5.1",
      "pali": "Nimmānaratino nāma,"
    },
    {
      "id": "vv20:5.2",
      "pali": "santi devā mahiddhikā;"
    },
    {
      "id": "vv20:5.3",
      "pali": "Tattha sā sukhitā nārī,"
    },
    {
      "id": "vv20:5.4",
      "pali": "modatācāmadāyikā”ti."
    },
    {
      "id": "vv20:6.1",
      "pali": "“Aho dānaṁ varākiyā,"
    },
    {
      "id": "vv20:6.2",
      "pali": "kassape suppatiṭṭhitaṁ;"
    },
    {
      "id": "vv20:6.3",
      "pali": "Parābhatena dānena,"
    },
    {
      "id": "vv20:6.4",
      "pali": "ijjhittha vata dakkhiṇā."
    },
    {
      "id": "vv20:7.1",
      "pali": "Yā mahesittaṁ kāreyya,"
    },
    {
      "id": "vv20:7.2",
      "pali": "cakkavattissa rājino;"
    },
    {
      "id": "vv20:7.3",
      "pali": "Nārī sabbaṅgakalyāṇī,"
    },
    {
      "id": "vv20:7.4",
      "pali": "bhattu cānomadassikā;"
    },
    {
      "id": "vv20:7.5",
      "pali": "Etassācāmadānassa,"
    },
    {
      "id": "vv20:7.6",
      "pali": "kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "vv20:8.1",
      "pali": "Sataṁ nikkhā sataṁ assā,"
    },
    {
      "id": "vv20:8.2",
      "pali": "sataṁ assatarīrathā;"
    },
    {
      "id": "vv20:8.3",
      "pali": "Sataṁ kaññāsahassāni,"
    },
    {
      "id": "vv20:8.4",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "vv20:8.5",
      "pali": "Etassācāmadānassa,"
    },
    {
      "id": "vv20:8.6",
      "pali": "kalaṁ nāgghanti soḷasiṁ."
    },
    {
      "id": "vv20:9.1",
      "pali": "Sataṁ hemavatā nāgā,"
    },
    {
      "id": "vv20:9.2",
      "pali": "īsādantā urūḷhavā;"
    },
    {
      "id": "vv20:9.3",
      "pali": "Suvaṇṇakacchā mātaṅgā,"
    },
    {
      "id": "vv20:9.4",
      "pali": "hemakappanavāsasā;"
    },
    {
      "id": "vv20:9.5",
      "pali": "Etassācāmadānassa,"
    },
    {
      "id": "vv20:9.6",
      "pali": "kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "vv20:10.1",
      "pali": "Catunnamapi dīpānaṁ,"
    },
    {
      "id": "vv20:10.2",
      "pali": "issaraṁ yodha kāraye;"
    },
    {
      "id": "vv20:10.3",
      "pali": "Etassācāmadānassa,"
    },
    {
      "id": "vv20:10.4",
      "pali": "kalaṁ nāgghati soḷasin”ti."
    },
    {
      "id": "vv20:11.1",
      "pali": "Ācāmadāyikāvimānaṁ tatiyaṁ."
    }
  ]
}
