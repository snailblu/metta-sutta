{
  "uid": "ja69",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja69:1.1",
      "pali": "“Dhiratthu taṁ visaṁ vantaṁ,"
    },
    {
      "id": "ja69:1.2",
      "pali": "yamahaṁ jīvitakāraṇā;"
    },
    {
      "id": "ja69:1.3",
      "pali": "Vantaṁ paccāvamissāmi,"
    },
    {
      "id": "ja69:1.4",
      "pali": "mataṁ me jīvitā varan”ti."
    },
    {
      "id": "ja69:2.1",
      "pali": "Visavantajātakaṁ navamaṁ."
    }
  ]
}
