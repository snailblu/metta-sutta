{
  "uid": "tha-ap279",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap279:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap279:1.2",
      "pali": "anusotaṁ vajāmahaṁ;"
    },
    {
      "id": "tha-ap279:1.3",
      "pali": "Satta māluvapupphāni,"
    },
    {
      "id": "tha-ap279:1.4",
      "pali": "citamāropayiṁ ahaṁ."
    },
    {
      "id": "tha-ap279:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap279:2.2",
      "pali": "citakaṁ yamapūjayiṁ;"
    },
    {
      "id": "tha-ap279:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap279:2.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap279:3.1",
      "pali": "Sattasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap279:3.2",
      "pali": "paṭijaggasanāmakā;"
    },
    {
      "id": "tha-ap279:3.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap279:3.4",
      "pali": "sattāsuṁ cakkavattino."
    },
    {
      "id": "tha-ap279:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap279:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap279:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap279:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap279:6.1",
      "pali": "Citakapūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
