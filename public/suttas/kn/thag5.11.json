{
  "uid": "thag5.11",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.11:1.1",
      "pali": "“Upasampadā ca me laddhā,"
    },
    {
      "id": "thag5.11:1.2",
      "pali": "vimutto camhi anāsavo;"
    },
    {
      "id": "thag5.11:1.3",
      "pali": "So ca me bhagavā diṭṭho,"
    },
    {
      "id": "thag5.11:1.4",
      "pali": "vihāre ca sahāvasiṁ."
    },
    {
      "id": "thag5.11:2.1",
      "pali": "Bahudeva rattiṁ bhagavā,"
    },
    {
      "id": "thag5.11:2.2",
      "pali": "abbhokāsetināmayi;"
    },
    {
      "id": "thag5.11:2.3",
      "pali": "Vihārakusalo satthā,"
    },
    {
      "id": "thag5.11:2.4",
      "pali": "vihāraṁ pāvisī tadā."
    },
    {
      "id": "thag5.11:3.1",
      "pali": "Santharitvāna saṅghāṭiṁ,"
    },
    {
      "id": "thag5.11:3.2",
      "pali": "seyyaṁ kappesi gotamo;"
    },
    {
      "id": "thag5.11:3.3",
      "pali": "Sīho selaguhāyaṁva,"
    },
    {
      "id": "thag5.11:3.4",
      "pali": "pahīnabhayabheravo."
    },
    {
      "id": "thag5.11:4.1",
      "pali": "Tato kalyāṇavākkaraṇo,"
    },
    {
      "id": "thag5.11:4.2",
      "pali": "sammāsambuddhasāvako;"
    },
    {
      "id": "thag5.11:4.3",
      "pali": "Soṇo abhāsi saddhammaṁ,"
    },
    {
      "id": "thag5.11:4.4",
      "pali": "buddhaseṭṭhassa sammukhā."
    },
    {
      "id": "thag5.11:5.1",
      "pali": "Pañcakkhandhe pariññāya,"
    },
    {
      "id": "thag5.11:5.2",
      "pali": "Bhāvayitvāna añjasaṁ;"
    },
    {
      "id": "thag5.11:5.3",
      "pali": "Pappuyya paramaṁ santiṁ,"
    },
    {
      "id": "thag5.11:5.4",
      "pali": "Parinibbissatyanāsavo”ti."
    },
    {
      "id": "thag5.11:5.5",
      "pali": "… Soṇo kuṭikaṇṇatthero …."
    }
  ]
}
