{
  "uid": "tha-ap177",
  "title": "Sīhāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap177:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap177:1.2",
      "pali": "padumuttaranāyake;"
    },
    {
      "id": "tha-ap177:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap177:1.4",
      "pali": "sīhāsanamadāsahaṁ."
    },
    {
      "id": "tha-ap177:2.1",
      "pali": "Bahūhi gandhamālehi,"
    },
    {
      "id": "tha-ap177:2.2",
      "pali": "diṭṭhadhammasukhāvahe;"
    },
    {
      "id": "tha-ap177:2.3",
      "pali": "Tattha pūjañca katvāna,"
    },
    {
      "id": "tha-ap177:2.4",
      "pali": "nibbāyati bahujjano."
    },
    {
      "id": "tha-ap177:3.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap177:3.2",
      "pali": "vanditvā bodhimuttamaṁ;"
    },
    {
      "id": "tha-ap177:3.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap177:3.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap177:4.1",
      "pali": "Pannarasasahassamhi,"
    },
    {
      "id": "tha-ap177:4.2",
      "pali": "kappānaṁ aṭṭha āsu te;"
    },
    {
      "id": "tha-ap177:4.3",
      "pali": "Siluccayasanāmā ca,"
    },
    {
      "id": "tha-ap177:4.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap177:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap177:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap177:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap177:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sīhāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap177:7.1",
      "pali": "Sīhāsanadāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
