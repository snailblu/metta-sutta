{
  "uid": "ja487",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja487:1.1",
      "pali": "“Kharājinā jaṭilā paṅkadantā,"
    },
    {
      "id": "ja487:1.2",
      "pali": "Dummakkharūpā ye mantaṁ jappanti;"
    },
    {
      "id": "ja487:1.3",
      "pali": "Kaccinnu te mānusake payoge,"
    },
    {
      "id": "ja487:1.4",
      "pali": "Idaṁ vidū parimuttā apāyā”."
    },
    {
      "id": "ja487:2.1",
      "pali": "“Pāpāni kammāni karetha rāja,"
    },
    {
      "id": "ja487:2.2",
      "pali": "Bahussuto ce na careyya dhammaṁ;"
    },
    {
      "id": "ja487:2.3",
      "pali": "Sahassavedopi na taṁ paṭicca,"
    },
    {
      "id": "ja487:2.4",
      "pali": "Dukkhā pamucce caraṇaṁ apatvā”."
    },
    {
      "id": "ja487:3.1",
      "pali": "“Sahassavedopi na taṁ paṭicca,"
    },
    {
      "id": "ja487:3.2",
      "pali": "Dukkhā pamucce caraṇaṁ apatvā;"
    },
    {
      "id": "ja487:3.3",
      "pali": "Maññāmi vedā aphalā bhavanti,"
    },
    {
      "id": "ja487:3.4",
      "pali": "Sasaṁyamaṁ caraṇaññeva saccaṁ”."
    },
    {
      "id": "ja487:4.1",
      "pali": "“Na heva vedā aphalā bhavanti,"
    },
    {
      "id": "ja487:4.2",
      "pali": "Sasaṁyamaṁ caraṇaññeva saccaṁ;"
    },
    {
      "id": "ja487:4.3",
      "pali": "Kittiñhi pappoti adhicca vede,"
    },
    {
      "id": "ja487:4.4",
      "pali": "Santiṁ puṇāti caraṇena danto”."
    },
    {
      "id": "ja487:5.1",
      "pali": "“Bhaccā mātā pitā bandhū,"
    },
    {
      "id": "ja487:5.2",
      "pali": "yena jāto sayeva so;"
    },
    {
      "id": "ja487:5.3",
      "pali": "Uddālako ahaṁ bhoto,"
    },
    {
      "id": "ja487:5.4",
      "pali": "sottiyākulavaṁsako”."
    },
    {
      "id": "ja487:6.1",
      "pali": "“Kathaṁ bho brāhmaṇo hoti,"
    },
    {
      "id": "ja487:6.2",
      "pali": "kathaṁ bhavati kevalī;"
    },
    {
      "id": "ja487:6.3",
      "pali": "Kathañca parinibbānaṁ,"
    },
    {
      "id": "ja487:6.4",
      "pali": "dhammaṭṭho kinti vuccati”."
    },
    {
      "id": "ja487:7.1",
      "pali": "“Niraṅkatvā aggimādāya brāhmaṇo,"
    },
    {
      "id": "ja487:7.2",
      "pali": "Āpo siñcaṁ yajaṁ usseti yūpaṁ;"
    },
    {
      "id": "ja487:7.3",
      "pali": "Evaṅkaro brāhmaṇo hoti khemī,"
    },
    {
      "id": "ja487:7.4",
      "pali": "Dhamme ṭhitaṁ tena amāpayiṁsu”."
    },
    {
      "id": "ja487:8.1",
      "pali": "“Na suddhi secanenatthi,"
    },
    {
      "id": "ja487:8.2",
      "pali": "nāpi kevalī brāhmaṇo;"
    },
    {
      "id": "ja487:8.3",
      "pali": "Na khantī nāpi soraccaṁ,"
    },
    {
      "id": "ja487:8.4",
      "pali": "nāpi so parinibbuto”."
    },
    {
      "id": "ja487:9.1",
      "pali": "“Kathaṁ so brāhmaṇo hoti,"
    },
    {
      "id": "ja487:9.2",
      "pali": "kathaṁ bhavati kevalī;"
    },
    {
      "id": "ja487:9.3",
      "pali": "Kathañca parinibbānaṁ,"
    },
    {
      "id": "ja487:9.4",
      "pali": "dhammaṭṭho kinti vuccati”."
    },
    {
      "id": "ja487:10.1",
      "pali": "“Akhettabandhū amamo nirāso,"
    },
    {
      "id": "ja487:10.2",
      "pali": "Nillobhapāpo bhavalobhakhīṇo;"
    },
    {
      "id": "ja487:10.3",
      "pali": "Evaṅkaro brāhmaṇo hoti khemī,"
    },
    {
      "id": "ja487:10.4",
      "pali": "Dhamme ṭhitaṁ tena amāpayiṁsu”."
    },
    {
      "id": "ja487:11.1",
      "pali": "“Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "ja487:11.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "ja487:11.3",
      "pali": "Sabbeva soratā dantā,"
    },
    {
      "id": "ja487:11.4",
      "pali": "sabbeva parinibbutā;"
    },
    {
      "id": "ja487:11.5",
      "pali": "Sabbesaṁ sītibhūtānaṁ,"
    },
    {
      "id": "ja487:11.6",
      "pali": "atthi seyyotha pāpiyo”."
    },
    {
      "id": "ja487:12.1",
      "pali": "“Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "ja487:12.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "ja487:12.3",
      "pali": "Sabbeva soratā dantā,"
    },
    {
      "id": "ja487:12.4",
      "pali": "sabbeva parinibbutā;"
    },
    {
      "id": "ja487:12.5",
      "pali": "Sabbesaṁ sītibhūtānaṁ,"
    },
    {
      "id": "ja487:12.6",
      "pali": "natthi seyyotha pāpiyo”."
    },
    {
      "id": "ja487:13.1",
      "pali": "“Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "ja487:13.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "ja487:13.3",
      "pali": "Sabbeva soratā dantā,"
    },
    {
      "id": "ja487:13.4",
      "pali": "sabbeva parinibbutā."
    },
    {
      "id": "ja487:14.1",
      "pali": "Sabbesaṁ sītibhūtānaṁ,"
    },
    {
      "id": "ja487:14.2",
      "pali": "Natthi seyyotha pāpiyo;"
    },
    {
      "id": "ja487:14.3",
      "pali": "Panatthaṁ carasi brahmaññaṁ,"
    },
    {
      "id": "ja487:14.4",
      "pali": "Sottiyākulavaṁsataṁ”."
    },
    {
      "id": "ja487:15.1",
      "pali": "“Nānārattehi vatthehi,"
    },
    {
      "id": "ja487:15.2",
      "pali": "vimānaṁ bhavati chāditaṁ;"
    },
    {
      "id": "ja487:15.3",
      "pali": "Na tesaṁ chāyā vatthānaṁ,"
    },
    {
      "id": "ja487:15.4",
      "pali": "so rāgo anupajjatha."
    },
    {
      "id": "ja487:16.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "ja487:16.2",
      "pali": "yadā sujjhanti māṇavā;"
    },
    {
      "id": "ja487:16.3",
      "pali": "Te sajātiṁ pamuñcanti,"
    },
    {
      "id": "ja487:16.4",
      "pali": "dhammamaññāya subbatā”ti."
    },
    {
      "id": "ja487:17.1",
      "pali": "Uddālakajātakaṁ catutthaṁ."
    }
  ]
}
