{
  "uid": "tha-ap539",
  "title": "7 Mahākoṭṭhikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap539:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap539:1.2",
      "pali": "sabbalokavidū muni;"
    },
    {
      "id": "tha-ap539:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap539:1.4",
      "pali": "kappe uppajji cakkhumā."
    },
    {
      "id": "tha-ap539:2.1",
      "pali": "Ovādako viññāpako,"
    },
    {
      "id": "tha-ap539:2.2",
      "pali": "tārako sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap539:2.3",
      "pali": "Desanākusalo buddho,"
    },
    {
      "id": "tha-ap539:2.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap539:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap539:3.2",
      "pali": "hitesī sabbapāṇinaṁ;"
    },
    {
      "id": "tha-ap539:3.3",
      "pali": "Sampatte titthiye sabbe,"
    },
    {
      "id": "tha-ap539:3.4",
      "pali": "pañcasīle patiṭṭhapi."
    },
    {
      "id": "tha-ap539:4.1",
      "pali": "Evaṁ nirākulaṁ āsi,"
    },
    {
      "id": "tha-ap539:4.2",
      "pali": "suññataṁ titthiyehi ca;"
    },
    {
      "id": "tha-ap539:4.3",
      "pali": "Vicittaṁ arahantehi,"
    },
    {
      "id": "tha-ap539:4.4",
      "pali": "vasībhūtehi tādibhi."
    },
    {
      "id": "tha-ap539:5.1",
      "pali": "Ratanānaṭṭhapaññāsaṁ,"
    },
    {
      "id": "tha-ap539:5.2",
      "pali": "uggato so mahāmuni;"
    },
    {
      "id": "tha-ap539:5.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "tha-ap539:5.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap539:6.1",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "tha-ap539:6.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "tha-ap539:6.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "tha-ap539:6.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "tha-ap539:7.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap539:7.2",
      "pali": "brāhmaṇo vedapāragū;"
    },
    {
      "id": "tha-ap539:7.3",
      "pali": "Upecca sabbalokaggaṁ,"
    },
    {
      "id": "tha-ap539:7.4",
      "pali": "assosiṁ dhammadesanaṁ."
    },
    {
      "id": "tha-ap539:8.1",
      "pali": "Tadā so sāvakaṁ vīro,"
    },
    {
      "id": "tha-ap539:8.2",
      "pali": "pabhinnamatigocaraṁ;"
    },
    {
      "id": "tha-ap539:8.3",
      "pali": "Atthe dhamme nirutte ca,"
    },
    {
      "id": "tha-ap539:8.4",
      "pali": "paṭibhāne ca kovidaṁ."
    },
    {
      "id": "tha-ap539:9.1",
      "pali": "Ṭhapesi etadaggamhi,"
    },
    {
      "id": "tha-ap539:9.2",
      "pali": "taṁ sutvā mudito ahaṁ;"
    },
    {
      "id": "tha-ap539:9.3",
      "pali": "Sasāvakaṁ jinavaraṁ,"
    },
    {
      "id": "tha-ap539:9.4",
      "pali": "sattāhaṁ bhojayiṁ tadā."
    },
    {
      "id": "tha-ap539:10.1",
      "pali": "Dussehacchādayitvāna,"
    },
    {
      "id": "tha-ap539:10.2",
      "pali": "sasissaṁ buddhisāgaraṁ;"
    },
    {
      "id": "tha-ap539:10.3",
      "pali": "Nipacca pādamūlamhi,"
    },
    {
      "id": "tha-ap539:10.4",
      "pali": "taṁ ṭhānaṁ patthayiṁ ahaṁ."
    },
    {
      "id": "tha-ap539:11.1",
      "pali": "Tato avoca lokaggo,"
    },
    {
      "id": "tha-ap539:11.2",
      "pali": "‘passathetaṁ dijuttamaṁ;"
    },
    {
      "id": "tha-ap539:11.3",
      "pali": "Vinataṁ pādamūle me,"
    },
    {
      "id": "tha-ap539:11.4",
      "pali": "kamalodarasappabhaṁ."
    },
    {
      "id": "tha-ap539:12.1",
      "pali": "Buddhaseṭṭhassa bhikkhussa,"
    },
    {
      "id": "tha-ap539:12.2",
      "pali": "Ṭhānaṁ patthayate ayaṁ;"
    },
    {
      "id": "tha-ap539:12.3",
      "pali": "Tāya saddhāya cāgena,"
    },
    {
      "id": "tha-ap539:12.4",
      "pali": "Saddhammassavanena ca."
    },
    {
      "id": "tha-ap539:13.1",
      "pali": "Sabbattha sukhito hutvā,"
    },
    {
      "id": "tha-ap539:13.2",
      "pali": "saṁsaritvā bhavābhave;"
    },
    {
      "id": "tha-ap539:13.3",
      "pali": "Anāgatamhi addhāne,"
    },
    {
      "id": "tha-ap539:13.4",
      "pali": "lacchase taṁ manorathaṁ."
    },
    {
      "id": "tha-ap539:14.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap539:14.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap539:14.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap539:14.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap539:15.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap539:15.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap539:15.3",
      "pali": "Koṭṭhiko nāma nāmena,"
    },
    {
      "id": "tha-ap539:15.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap539:16.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "tha-ap539:16.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "tha-ap539:16.3",
      "pali": "Mettacitto paricariṁ,"
    },
    {
      "id": "tha-ap539:16.4",
      "pali": "sato paññāsamāhito."
    },
    {
      "id": "tha-ap539:17.1",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "tha-ap539:17.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap539:17.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap539:17.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap539:18.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap539:18.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap539:18.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap539:18.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap539:19.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap539:19.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap539:19.3",
      "pali": "Sabbattha sukhito āsiṁ,"
    },
    {
      "id": "tha-ap539:19.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap539:20.1",
      "pali": "Duve bhave saṁsarāmi,"
    },
    {
      "id": "tha-ap539:20.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap539:20.3",
      "pali": "Aññaṁ gatiṁ na gacchāmi,"
    },
    {
      "id": "tha-ap539:20.4",
      "pali": "suciṇṇassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap539:21.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap539:21.2",
      "pali": "khattiye atha brāhmaṇe;"
    },
    {
      "id": "tha-ap539:21.3",
      "pali": "Nīce kule na jāyāmi,"
    },
    {
      "id": "tha-ap539:21.4",
      "pali": "suciṇṇassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap539:22.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap539:22.2",
      "pali": "brahmabandhu ahosahaṁ;"
    },
    {
      "id": "tha-ap539:22.3",
      "pali": "Sāvatthiyaṁ vippakule,"
    },
    {
      "id": "tha-ap539:22.4",
      "pali": "paccājāto mahaddhane."
    },
    {
      "id": "tha-ap539:23.1",
      "pali": "Mātā candavatī nāma,"
    },
    {
      "id": "tha-ap539:23.2",
      "pali": "pitā me assalāyano;"
    },
    {
      "id": "tha-ap539:23.3",
      "pali": "Yadā me pitaraṁ buddho,"
    },
    {
      "id": "tha-ap539:23.4",
      "pali": "vinayī sabbasuddhiyā."
    },
    {
      "id": "tha-ap539:24.1",
      "pali": "Tadā pasanno sugate,"
    },
    {
      "id": "tha-ap539:24.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap539:24.3",
      "pali": "Moggallāno ācariyo,"
    },
    {
      "id": "tha-ap539:24.4",
      "pali": "upajjhā sārisambhavo."
    },
    {
      "id": "tha-ap539:25.1",
      "pali": "Kesesu chijjamānesu,"
    },
    {
      "id": "tha-ap539:25.2",
      "pali": "diṭṭhi chinnā samūlikā;"
    },
    {
      "id": "tha-ap539:25.3",
      "pali": "Nivāsento ca kāsāvaṁ,"
    },
    {
      "id": "tha-ap539:25.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap539:26.1",
      "pali": "Atthadhammaniruttīsu,"
    },
    {
      "id": "tha-ap539:26.2",
      "pali": "paṭibhāne ca me mati;"
    },
    {
      "id": "tha-ap539:26.3",
      "pali": "Pabhinnā tena lokaggo,"
    },
    {
      "id": "tha-ap539:26.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap539:27.1",
      "pali": "Asandiṭṭhaṁ viyākāsiṁ,"
    },
    {
      "id": "tha-ap539:27.2",
      "pali": "upatissena pucchito;"
    },
    {
      "id": "tha-ap539:27.3",
      "pali": "Paṭisambhidāsu tenāhaṁ,"
    },
    {
      "id": "tha-ap539:27.4",
      "pali": "aggo sambuddhasāsane."
    },
    {
      "id": "tha-ap539:28.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap539:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap539:28.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap539:29.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap539:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap539:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap539:30.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap539:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap539:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap539:31.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahākoṭṭhiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap539:32.1",
      "pali": "Mahākoṭṭhikattherassāpadānaṁ sattamaṁ."
    }
  ]
}
