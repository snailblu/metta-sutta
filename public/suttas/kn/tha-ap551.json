{
  "uid": "tha-ap551",
  "title": "Vanavacchattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap551:1.1",
      "pali": "“Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap551:1.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap551:1.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap551:1.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap551:2.1",
      "pali": "Tadāhaṁ pabbajitvāna,"
    },
    {
      "id": "tha-ap551:2.2",
      "pali": "tassa buddhassa sāsane;"
    },
    {
      "id": "tha-ap551:2.3",
      "pali": "Yāvajīvaṁ caritvāna,"
    },
    {
      "id": "tha-ap551:2.4",
      "pali": "brahmacāraṁ tato cuto."
    },
    {
      "id": "tha-ap551:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap551:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap551:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap551:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap551:4.1",
      "pali": "Tato cuto araññamhi,"
    },
    {
      "id": "tha-ap551:4.2",
      "pali": "kapoto āsahaṁ tahiṁ;"
    },
    {
      "id": "tha-ap551:4.3",
      "pali": "Vasate guṇasampanno,"
    },
    {
      "id": "tha-ap551:4.4",
      "pali": "bhikkhu jhānarato sadā."
    },
    {
      "id": "tha-ap551:5.1",
      "pali": "Mettacitto kāruṇiko,"
    },
    {
      "id": "tha-ap551:5.2",
      "pali": "sadā pamuditānano;"
    },
    {
      "id": "tha-ap551:5.3",
      "pali": "Upekkhako mahāvīro,"
    },
    {
      "id": "tha-ap551:5.4",
      "pali": "appamaññāsu kovido."
    },
    {
      "id": "tha-ap551:6.1",
      "pali": "Vinīvaraṇasaṅkappe,"
    },
    {
      "id": "tha-ap551:6.2",
      "pali": "sabbasattahitāsaye;"
    },
    {
      "id": "tha-ap551:6.3",
      "pali": "Visaṭṭho nacirenāsiṁ,"
    },
    {
      "id": "tha-ap551:6.4",
      "pali": "tasmiṁ sugatasāvake."
    },
    {
      "id": "tha-ap551:7.1",
      "pali": "Upecca pādamūlamhi,"
    },
    {
      "id": "tha-ap551:7.2",
      "pali": "nisinnassa tadāssame;"
    },
    {
      "id": "tha-ap551:7.3",
      "pali": "Kadāci sāmisaṁ deti,"
    },
    {
      "id": "tha-ap551:7.4",
      "pali": "dhammaṁ desesi cekadā."
    },
    {
      "id": "tha-ap551:8.1",
      "pali": "Tadā vipulapemena,"
    },
    {
      "id": "tha-ap551:8.2",
      "pali": "upāsitvā jinatrajaṁ;"
    },
    {
      "id": "tha-ap551:8.3",
      "pali": "Tato cuto gato saggaṁ,"
    },
    {
      "id": "tha-ap551:8.4",
      "pali": "pavāso sagharaṁ yathā."
    },
    {
      "id": "tha-ap551:9.1",
      "pali": "Saggā cuto manussesu,"
    },
    {
      "id": "tha-ap551:9.2",
      "pali": "nibbatto puññakammunā;"
    },
    {
      "id": "tha-ap551:9.3",
      "pali": "Agāraṁ chaḍḍayitvāna,"
    },
    {
      "id": "tha-ap551:9.4",
      "pali": "pabbajiṁ bahuso ahaṁ."
    },
    {
      "id": "tha-ap551:10.1",
      "pali": "Samaṇo tāpaso vippo,"
    },
    {
      "id": "tha-ap551:10.2",
      "pali": "paribbajo tathevahaṁ;"
    },
    {
      "id": "tha-ap551:10.3",
      "pali": "Hutvā vasiṁ araññamhi,"
    },
    {
      "id": "tha-ap551:10.4",
      "pali": "anekasataso ahaṁ."
    },
    {
      "id": "tha-ap551:11.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap551:11.2",
      "pali": "ramme kapilavatthave;"
    },
    {
      "id": "tha-ap551:11.3",
      "pali": "Vacchagotto dijo tassa,"
    },
    {
      "id": "tha-ap551:11.4",
      "pali": "jāyāya ahamokkamiṁ."
    },
    {
      "id": "tha-ap551:12.1",
      "pali": "Mātu me dohaḷo āsi,"
    },
    {
      "id": "tha-ap551:12.2",
      "pali": "tirokucchigatassa me;"
    },
    {
      "id": "tha-ap551:12.3",
      "pali": "Jāyamānasamīpamhi,"
    },
    {
      "id": "tha-ap551:12.4",
      "pali": "vanavāsāya nicchayo."
    },
    {
      "id": "tha-ap551:13.1",
      "pali": "Tato me ajanī mātā,"
    },
    {
      "id": "tha-ap551:13.2",
      "pali": "ramaṇīye vanantare;"
    },
    {
      "id": "tha-ap551:13.3",
      "pali": "Gabbhato nikkhamantaṁ maṁ,"
    },
    {
      "id": "tha-ap551:13.4",
      "pali": "kāsāyena paṭiggahuṁ."
    },
    {
      "id": "tha-ap551:14.1",
      "pali": "Tato kumāro siddhattho,"
    },
    {
      "id": "tha-ap551:14.2",
      "pali": "jāto sakyakuladdhajo;"
    },
    {
      "id": "tha-ap551:14.3",
      "pali": "Tassa mitto piyo āsiṁ,"
    },
    {
      "id": "tha-ap551:14.4",
      "pali": "saṁvisaṭṭho sumāniyo."
    },
    {
      "id": "tha-ap551:15.1",
      "pali": "Sattasārebhinikkhante,"
    },
    {
      "id": "tha-ap551:15.2",
      "pali": "ohāya vipulaṁ yasaṁ;"
    },
    {
      "id": "tha-ap551:15.3",
      "pali": "Ahampi pabbajitvāna,"
    },
    {
      "id": "tha-ap551:15.4",
      "pali": "himavantamupāgamiṁ."
    },
    {
      "id": "tha-ap551:16.1",
      "pali": "Vanālayaṁ bhāvanīyaṁ,"
    },
    {
      "id": "tha-ap551:16.2",
      "pali": "kassapaṁ dhutavādikaṁ;"
    },
    {
      "id": "tha-ap551:16.3",
      "pali": "Disvā sutvā jinuppādaṁ,"
    },
    {
      "id": "tha-ap551:16.4",
      "pali": "upesiṁ narasārathiṁ."
    },
    {
      "id": "tha-ap551:17.1",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "tha-ap551:17.2",
      "pali": "sabbatthaṁ sampakāsayaṁ;"
    },
    {
      "id": "tha-ap551:17.3",
      "pali": "Tatohaṁ pabbajitvāna,"
    },
    {
      "id": "tha-ap551:17.4",
      "pali": "vanameva punāgamaṁ."
    },
    {
      "id": "tha-ap551:18.1",
      "pali": "Tatthāppamatto viharaṁ,"
    },
    {
      "id": "tha-ap551:18.2",
      "pali": "chaḷabhiññā aphassayiṁ;"
    },
    {
      "id": "tha-ap551:18.3",
      "pali": "Aho suladdhalābhomhi,"
    },
    {
      "id": "tha-ap551:18.4",
      "pali": "sumittenānukampito."
    },
    {
      "id": "tha-ap551:19.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap551:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap551:19.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap551:20.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap551:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap551:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap551:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap551:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap551:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap551:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā vanavaccho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap551:23.1",
      "pali": "Vanavacchattherassāpadānaṁ navamaṁ."
    }
  ]
}
