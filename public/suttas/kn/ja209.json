{
  "uid": "ja209",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja209:1.1",
      "pali": "“Diṭṭhā mayā vane rukkhā,"
    },
    {
      "id": "ja209:1.2",
      "pali": "assakaṇṇā vibhīṭakā;"
    },
    {
      "id": "ja209:1.3",
      "pali": "Na tāni evaṁ sakkanti,"
    },
    {
      "id": "ja209:1.4",
      "pali": "yathā tvaṁ rukkha sakkasi”."
    },
    {
      "id": "ja209:2.1",
      "pali": "“Purāṇakukkuṭo ayaṁ,"
    },
    {
      "id": "ja209:2.2",
      "pali": "bhetvā pañjaramāgato;"
    },
    {
      "id": "ja209:2.3",
      "pali": "Kusalo vāḷapāsānaṁ,"
    },
    {
      "id": "ja209:2.4",
      "pali": "apakkamati bhāsatī”ti."
    },
    {
      "id": "ja209:3.1",
      "pali": "Kukkuṭajātakaṁ navamaṁ."
    }
  ]
}
