{
  "uid": "iti68",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti68:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti68:2.1",
      "pali": "“Yassa kassaci, bhikkhave, rāgo appahīno, doso appahīno, moho appahīno—"
    },
    {
      "id": "iti68:2.2",
      "pali": "ayaṁ vuccati, bhikkhave, ‘baddho mārassa paṭimukkassa mārapāso yathākāmakaraṇīyo pāpimato’."
    },
    {
      "id": "iti68:2.3",
      "pali": "Yassa kassaci, bhikkhave, rāgo pahīno, doso pahīno, moho pahīno—"
    },
    {
      "id": "iti68:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, ‘abaddho mārassa omukkassa mārapāso na yathākāmakaraṇīyo pāpimato’”ti."
    },
    {
      "id": "iti68:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti68:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti68:3.1",
      "pali": "“Yassa rāgo ca doso ca,"
    },
    {
      "id": "iti68:3.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "iti68:3.3",
      "pali": "Taṁ bhāvitattaññataraṁ,"
    },
    {
      "id": "iti68:3.4",
      "pali": "brahmabhūtaṁ tathāgataṁ;"
    },
    {
      "id": "iti68:3.5",
      "pali": "Buddhaṁ verabhayātītaṁ,"
    },
    {
      "id": "iti68:3.6",
      "pali": "āhu sabbappahāyinan”ti."
    },
    {
      "id": "iti68:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti68:4.2",
      "pali": "Navamaṁ."
    }
  ]
}
