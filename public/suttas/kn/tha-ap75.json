{
  "uid": "tha-ap75",
  "title": "3 Buddhasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap75:1.1",
      "pali": "“Dumagge paṁsukūlikaṁ,"
    },
    {
      "id": "tha-ap75:1.2",
      "pali": "laggaṁ disvāna satthuno;"
    },
    {
      "id": "tha-ap75:1.3",
      "pali": "Tato tamañjaliṁ katvā,"
    },
    {
      "id": "tha-ap75:1.4",
      "pali": "paṁsukūlaṁ avandahaṁ."
    },
    {
      "id": "tha-ap75:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap75:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap75:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap75:2.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap75:3.1",
      "pali": "Ito catutthake kappe,"
    },
    {
      "id": "tha-ap75:3.2",
      "pali": "dumasārosi khattiyo;"
    },
    {
      "id": "tha-ap75:3.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap75:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap75:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap75:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap75:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap75:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā buddhasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap75:6.1",
      "pali": "Buddhasaññakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
