{
  "uid": "thag16.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.1:1.1",
      "pali": "“Yaññatthaṁ vā dhanatthaṁ vā,"
    },
    {
      "id": "thag16.1:1.2",
      "pali": "ye hanāma mayaṁ pure;"
    },
    {
      "id": "thag16.1:1.3",
      "pali": "Avasesaṁ bhayaṁ hoti,"
    },
    {
      "id": "thag16.1:1.4",
      "pali": "vedhanti vilapanti ca."
    },
    {
      "id": "thag16.1:2.1",
      "pali": "Tassa te natthi bhītattaṁ,"
    },
    {
      "id": "thag16.1:2.2",
      "pali": "bhiyyo vaṇṇo pasīdati;"
    },
    {
      "id": "thag16.1:2.3",
      "pali": "Kasmā na paridevesi,"
    },
    {
      "id": "thag16.1:2.4",
      "pali": "evarūpe mahabbhaye”."
    },
    {
      "id": "thag16.1:3.1",
      "pali": "“Natthi cetasikaṁ dukkhaṁ,"
    },
    {
      "id": "thag16.1:3.2",
      "pali": "anapekkhassa gāmaṇi;"
    },
    {
      "id": "thag16.1:3.3",
      "pali": "Atikkantā bhayā sabbe,"
    },
    {
      "id": "thag16.1:3.4",
      "pali": "khīṇasaṁyojanassa ve."
    },
    {
      "id": "thag16.1:4.1",
      "pali": "Khīṇāya bhavanettiyā,"
    },
    {
      "id": "thag16.1:4.2",
      "pali": "diṭṭhe dhamme yathātathe;"
    },
    {
      "id": "thag16.1:4.3",
      "pali": "Na bhayaṁ maraṇe hoti,"
    },
    {
      "id": "thag16.1:4.4",
      "pali": "bhāranikkhepane yathā."
    },
    {
      "id": "thag16.1:5.1",
      "pali": "Suciṇṇaṁ brahmacariyaṁ me,"
    },
    {
      "id": "thag16.1:5.2",
      "pali": "maggo cāpi subhāvito;"
    },
    {
      "id": "thag16.1:5.3",
      "pali": "Maraṇe me bhayaṁ natthi,"
    },
    {
      "id": "thag16.1:5.4",
      "pali": "rogānamiva saṅkhaye."
    },
    {
      "id": "thag16.1:6.1",
      "pali": "Suciṇṇaṁ brahmacariyaṁ me,"
    },
    {
      "id": "thag16.1:6.2",
      "pali": "maggo cāpi subhāvito;"
    },
    {
      "id": "thag16.1:6.3",
      "pali": "Nirassādā bhavā diṭṭhā,"
    },
    {
      "id": "thag16.1:6.4",
      "pali": "visaṁ pitvāva chaḍḍitaṁ."
    },
    {
      "id": "thag16.1:7.1",
      "pali": "Pāragū anupādāno,"
    },
    {
      "id": "thag16.1:7.2",
      "pali": "katakicco anāsavo;"
    },
    {
      "id": "thag16.1:7.3",
      "pali": "Tuṭṭho āyukkhayā hoti,"
    },
    {
      "id": "thag16.1:7.4",
      "pali": "mutto āghātanā yathā."
    },
    {
      "id": "thag16.1:8.1",
      "pali": "Uttamaṁ dhammataṁ patto,"
    },
    {
      "id": "thag16.1:8.2",
      "pali": "sabbaloke anatthiko;"
    },
    {
      "id": "thag16.1:8.3",
      "pali": "Ādittāva gharā mutto,"
    },
    {
      "id": "thag16.1:8.4",
      "pali": "maraṇasmiṁ na socati."
    },
    {
      "id": "thag16.1:9.1",
      "pali": "Yadatthi saṅgataṁ kiñci,"
    },
    {
      "id": "thag16.1:9.2",
      "pali": "bhavo vā yattha labbhati;"
    },
    {
      "id": "thag16.1:9.3",
      "pali": "Sabbaṁ anissaraṁ etaṁ,"
    },
    {
      "id": "thag16.1:9.4",
      "pali": "iti vuttaṁ mahesinā."
    },
    {
      "id": "thag16.1:10.1",
      "pali": "Yo taṁ tathā pajānāti,"
    },
    {
      "id": "thag16.1:10.2",
      "pali": "yathā buddhena desitaṁ;"
    },
    {
      "id": "thag16.1:10.3",
      "pali": "Na gaṇhāti bhavaṁ kiñci,"
    },
    {
      "id": "thag16.1:10.4",
      "pali": "sutattaṁva ayoguḷaṁ."
    },
    {
      "id": "thag16.1:11.1",
      "pali": "Na me hoti ‘ahosin’ti,"
    },
    {
      "id": "thag16.1:11.2",
      "pali": "‘bhavissan’ti na hoti me;"
    },
    {
      "id": "thag16.1:11.3",
      "pali": "Saṅkhārā vigamissanti,"
    },
    {
      "id": "thag16.1:11.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "thag16.1:12.1",
      "pali": "Suddhaṁ dhammasamuppādaṁ,"
    },
    {
      "id": "thag16.1:12.2",
      "pali": "Suddhaṁ saṅkhārasantatiṁ;"
    },
    {
      "id": "thag16.1:12.3",
      "pali": "Passantassa yathābhūtaṁ,"
    },
    {
      "id": "thag16.1:12.4",
      "pali": "Na bhayaṁ hoti gāmaṇi."
    },
    {
      "id": "thag16.1:13.1",
      "pali": "Tiṇakaṭṭhasamaṁ lokaṁ,"
    },
    {
      "id": "thag16.1:13.2",
      "pali": "yadā paññāya passati;"
    },
    {
      "id": "thag16.1:13.3",
      "pali": "Mamattaṁ so asaṁvindaṁ,"
    },
    {
      "id": "thag16.1:13.4",
      "pali": "‘natthi me’ti na socati."
    },
    {
      "id": "thag16.1:14.1",
      "pali": "Ukkaṇṭhāmi sarīrena,"
    },
    {
      "id": "thag16.1:14.2",
      "pali": "bhavenamhi anatthiko;"
    },
    {
      "id": "thag16.1:14.3",
      "pali": "Soyaṁ bhijjissati kāyo,"
    },
    {
      "id": "thag16.1:14.4",
      "pali": "añño ca na bhavissati."
    },
    {
      "id": "thag16.1:15.1",
      "pali": "Yaṁ vo kiccaṁ sarīrena,"
    },
    {
      "id": "thag16.1:15.2",
      "pali": "taṁ karotha yadicchatha;"
    },
    {
      "id": "thag16.1:15.3",
      "pali": "Na me tappaccayā tattha,"
    },
    {
      "id": "thag16.1:15.4",
      "pali": "doso pemañca hehiti”."
    },
    {
      "id": "thag16.1:16.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "thag16.1:16.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "thag16.1:16.3",
      "pali": "Satthāni nikkhipitvāna,"
    },
    {
      "id": "thag16.1:16.4",
      "pali": "māṇavā etadabravuṁ."
    },
    {
      "id": "thag16.1:17.1",
      "pali": "“Kiṁ bhadante karitvāna,"
    },
    {
      "id": "thag16.1:17.2",
      "pali": "ko vā ācariyo tava;"
    },
    {
      "id": "thag16.1:17.3",
      "pali": "Kassa sāsanamāgamma,"
    },
    {
      "id": "thag16.1:17.4",
      "pali": "labbhate taṁ asokatā”."
    },
    {
      "id": "thag16.1:18.1",
      "pali": "“Sabbaññū sabbadassāvī,"
    },
    {
      "id": "thag16.1:18.2",
      "pali": "jino ācariyo mama;"
    },
    {
      "id": "thag16.1:18.3",
      "pali": "Mahākāruṇiko satthā,"
    },
    {
      "id": "thag16.1:18.4",
      "pali": "sabbalokatikicchako."
    },
    {
      "id": "thag16.1:19.1",
      "pali": "Tenāyaṁ desito dhammo,"
    },
    {
      "id": "thag16.1:19.2",
      "pali": "khayagāmī anuttaro;"
    },
    {
      "id": "thag16.1:19.3",
      "pali": "Tassa sāsanamāgamma,"
    },
    {
      "id": "thag16.1:19.4",
      "pali": "labbhate taṁ asokatā”."
    },
    {
      "id": "thag16.1:20.1",
      "pali": "Sutvāna corā isino subhāsitaṁ,"
    },
    {
      "id": "thag16.1:20.2",
      "pali": "Nikkhippa satthāni ca āvudhāni ca;"
    },
    {
      "id": "thag16.1:20.3",
      "pali": "Tamhā ca kammā viramiṁsu eke,"
    },
    {
      "id": "thag16.1:20.4",
      "pali": "Eke ca pabbajjamarocayiṁsu."
    },
    {
      "id": "thag16.1:21.1",
      "pali": "Te pabbajitvā sugatassa sāsane,"
    },
    {
      "id": "thag16.1:21.2",
      "pali": "Bhāvetva bojjhaṅgabalāni paṇḍitā;"
    },
    {
      "id": "thag16.1:21.3",
      "pali": "Udaggacittā sumanā katindriyā,"
    },
    {
      "id": "thag16.1:21.4",
      "pali": "Phusiṁsu nibbānapadaṁ asaṅkhatanti."
    },
    {
      "id": "thag16.1:21.5",
      "pali": "… Adhimutto thero …."
    }
  ]
}
