{
  "uid": "ja191",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja191:1.1",
      "pali": "“Api ruhaka chinnāpi,"
    },
    {
      "id": "ja191:1.2",
      "pali": "jiyā sandhīyate puna;"
    },
    {
      "id": "ja191:1.3",
      "pali": "Sandhīyassu purāṇiyā,"
    },
    {
      "id": "ja191:1.4",
      "pali": "mā kodhassa vasaṁ gami”."
    },
    {
      "id": "ja191:2.1",
      "pali": "“Vijjamānesu vākesu,"
    },
    {
      "id": "ja191:2.2",
      "pali": "vijjamānesu kārisu;"
    },
    {
      "id": "ja191:2.3",
      "pali": "Aññaṁ jiyaṁ karissāmi,"
    },
    {
      "id": "ja191:2.4",
      "pali": "alaññeva purāṇiyā”ti."
    },
    {
      "id": "ja191:3.1",
      "pali": "Ruhakajātakaṁ paṭhamaṁ."
    }
  ]
}
