{
  "uid": "ja126",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja126:1.1",
      "pali": "“Tadevekassa kalyāṇaṁ,"
    },
    {
      "id": "ja126:1.2",
      "pali": "tadevekassa pāpakaṁ;"
    },
    {
      "id": "ja126:1.3",
      "pali": "Tasmā sabbaṁ na kalyāṇaṁ,"
    },
    {
      "id": "ja126:1.4",
      "pali": "sabbaṁ vāpi na pāpakan”ti."
    },
    {
      "id": "ja126:2.1",
      "pali": "Asilakkhaṇajātakaṁ chaṭṭhaṁ."
    }
  ]
}
