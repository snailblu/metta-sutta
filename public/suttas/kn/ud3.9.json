{
  "uid": "ud3.9",
  "title": "Sippasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud3.9:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud3.9:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud3.9:1.3",
      "pali": "Tena kho pana samayena sambahulānaṁ bhikkhūnaṁ pacchābhattaṁ piṇḍapātapaṭikkantānaṁ maṇḍalamāḷe sannisinnānaṁ sannipatitānaṁ ayamantarākathā udapādi:"
    },
    {
      "id": "ud3.9:1.4",
      "pali": "“ko nu kho, āvuso, sippaṁ jānāti?"
    },
    {
      "id": "ud3.9:1.5",
      "pali": "Ko kiṁ sippaṁ sikkhi?"
    },
    {
      "id": "ud3.9:1.6",
      "pali": "Kataraṁ sippaṁ sippānaṁ aggan”ti?"
    },
    {
      "id": "ud3.9:2.1",
      "pali": "Tatthekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.2",
      "pali": "“hatthisippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.3",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.4",
      "pali": "“assasippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.5",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.6",
      "pali": "“rathasippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.7",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.8",
      "pali": "“dhanusippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.9",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.10",
      "pali": "“tharusippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.11",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.12",
      "pali": "“muddāsippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.13",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.14",
      "pali": "“gaṇanāsippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.15",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.16",
      "pali": "“saṅkhānasippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.17",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.18",
      "pali": "“lekhāsippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.19",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.20",
      "pali": "“kāveyyasippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.21",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.22",
      "pali": "“lokāyatasippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.23",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:2.24",
      "pali": "“khattavijjāsippaṁ sippānaṁ aggan”ti."
    },
    {
      "id": "ud3.9:2.25",
      "pali": "Ayañcarahi tesaṁ bhikkhūnaṁ antarākathā hoti vippakatā."
    },
    {
      "id": "ud3.9:3.1",
      "pali": "Atha kho bhagavā sāyanhasamayaṁ paṭisallānā vuṭṭhito yena maṇḍalamāḷo tenupasaṅkami; upasaṅkamitvā paññatte āsane nisīdi."
    },
    {
      "id": "ud3.9:3.2",
      "pali": "Nisajja kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "ud3.9:3.3",
      "pali": "“kāya nuttha, bhikkhave, etarahi kathāya sannisinnā, kā ca pana vo antarākathā vippakatā”ti?"
    },
    {
      "id": "ud3.9:4.1",
      "pali": "“Idha, bhante, amhākaṁ pacchābhattaṁ piṇḍapātapaṭikkantānaṁ maṇḍalamāḷe sannisinnānaṁ ayamantarākathā udapādi:"
    },
    {
      "id": "ud3.9:4.2",
      "pali": "‘ko nu kho, āvuso, sippaṁ jānāti?"
    },
    {
      "id": "ud3.9:4.3",
      "pali": "Ko kiṁ sippaṁ sikkhi?"
    },
    {
      "id": "ud3.9:4.4",
      "pali": "Kataraṁ sippaṁ sippānaṁ aggan’ti?"
    },
    {
      "id": "ud3.9:5.1",
      "pali": "Tatthekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.2",
      "pali": "‘hatthisippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.3",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.4",
      "pali": "‘assasippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.5",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.6",
      "pali": "‘rathasippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.7",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.8",
      "pali": "‘dhanusippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.9",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.10",
      "pali": "‘tharusippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.11",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.12",
      "pali": "‘muddāsippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.13",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.14",
      "pali": "‘gaṇanāsippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.15",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.16",
      "pali": "‘saṅkhānasippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.17",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.18",
      "pali": "‘lekhāsippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.19",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.20",
      "pali": "‘kāveyyasippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.21",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.22",
      "pali": "‘lokāyatasippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.23",
      "pali": "Ekacce evamāhaṁsu:"
    },
    {
      "id": "ud3.9:5.24",
      "pali": "‘khattavijjāsippaṁ sippānaṁ aggan’ti."
    },
    {
      "id": "ud3.9:5.25",
      "pali": "Ayaṁ kho no, bhante, antarākathā hoti vippakatā, atha bhagavā anuppatto”ti."
    },
    {
      "id": "ud3.9:6.1",
      "pali": "“Na khvetaṁ, bhikkhave, tumhākaṁ patirūpaṁ kulaputtānaṁ saddhā agārasmā anagāriyaṁ pabbajitānaṁ yaṁ tumhe evarūpiṁ kathaṁ katheyyātha."
    },
    {
      "id": "ud3.9:6.2",
      "pali": "Sannipatitānaṁ vo, bhikkhave, dvayaṁ karaṇīyaṁ—"
    },
    {
      "id": "ud3.9:6.3",
      "pali": "dhammī vā kathā ariyo vā tuṇhībhāvo”ti."
    },
    {
      "id": "ud3.9:7.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud3.9:8.1",
      "pali": "“Asippajīvī lahu atthakāmo,"
    },
    {
      "id": "ud3.9:8.2",
      "pali": "Yatindriyo sabbadhi vippamutto;"
    },
    {
      "id": "ud3.9:8.3",
      "pali": "Anokasārī amamo nirāso,"
    },
    {
      "id": "ud3.9:8.4",
      "pali": "Hitvā mānaṁ ekacaro sa bhikkhū”ti."
    },
    {
      "id": "ud3.9:8.5",
      "pali": "Navamaṁ."
    }
  ]
}
