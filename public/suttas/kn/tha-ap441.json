{
  "uid": "tha-ap441",
  "title": "Ambapiṇḍiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap441:1.1",
      "pali": "“Hatthirājā tadā āsiṁ,"
    },
    {
      "id": "tha-ap441:1.2",
      "pali": "īsādanto uruḷhavā;"
    },
    {
      "id": "tha-ap441:1.3",
      "pali": "Vicaranto brahāraññe,"
    },
    {
      "id": "tha-ap441:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap441:2.1",
      "pali": "Ambapiṇḍaṁ gahetvāna,"
    },
    {
      "id": "tha-ap441:2.2",
      "pali": "adāsiṁ satthuno ahaṁ;"
    },
    {
      "id": "tha-ap441:2.3",
      "pali": "Paṭiggaṇhi mahāvīro,"
    },
    {
      "id": "tha-ap441:2.4",
      "pali": "siddhattho lokanāyako."
    },
    {
      "id": "tha-ap441:3.1",
      "pali": "Mama nijjhāyamānassa,"
    },
    {
      "id": "tha-ap441:3.2",
      "pali": "paribhuñji tadā jino;"
    },
    {
      "id": "tha-ap441:3.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap441:3.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap441:4.1",
      "pali": "Tato ahaṁ cavitvāna,"
    },
    {
      "id": "tha-ap441:4.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap441:4.3",
      "pali": "Eteneva upāyena,"
    },
    {
      "id": "tha-ap441:4.4",
      "pali": "anubhutvāna sampadā."
    },
    {
      "id": "tha-ap441:5.1",
      "pali": "Padhānapahitattohaṁ,"
    },
    {
      "id": "tha-ap441:5.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap441:5.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap441:5.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap441:6.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap441:6.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap441:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap441:6.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap441:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap441:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap441:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap441:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap441:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap441:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap441:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap441:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap441:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap441:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambapiṇḍiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap441:11.1",
      "pali": "Ambapiṇḍiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
