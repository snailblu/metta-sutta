{
  "uid": "tha-ap285",
  "title": "Paccuggamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap285:1.1",
      "pali": "“Sīhaṁ yathā vanacaraṁ,"
    },
    {
      "id": "tha-ap285:1.2",
      "pali": "nisabhājāniyaṁ yathā;"
    },
    {
      "id": "tha-ap285:1.3",
      "pali": "Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap285:1.4",
      "pali": "āgacchantaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap285:2.1",
      "pali": "Siddhatthaṁ lokapajjotaṁ,"
    },
    {
      "id": "tha-ap285:2.2",
      "pali": "sabbalokatikicchakaṁ;"
    },
    {
      "id": "tha-ap285:2.3",
      "pali": "Akāsiṁ paccuggamanaṁ,"
    },
    {
      "id": "tha-ap285:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap285:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap285:3.2",
      "pali": "paccuggacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap285:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap285:3.4",
      "pali": "paccuggamane idaṁ phalaṁ."
    },
    {
      "id": "tha-ap285:4.1",
      "pali": "Sattatiṁse ito kappe,"
    },
    {
      "id": "tha-ap285:4.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap285:4.3",
      "pali": "Saparivāroti nāmena,"
    },
    {
      "id": "tha-ap285:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap285:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap285:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap285:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap285:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā paccuggamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap285:7.1",
      "pali": "Paccuggamaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
