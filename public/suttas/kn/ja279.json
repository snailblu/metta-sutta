{
  "uid": "ja279",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja279:1.1",
      "pali": "“Yathā māṇavako panthe,"
    },
    {
      "id": "ja279:1.2",
      "pali": "siṅgāliṁ vanagocariṁ;"
    },
    {
      "id": "ja279:1.3",
      "pali": "Atthakāmaṁ pavedentiṁ,"
    },
    {
      "id": "ja279:1.4",
      "pali": "anatthakāmāti maññati;"
    },
    {
      "id": "ja279:1.5",
      "pali": "Anatthakāmaṁ satapattaṁ,"
    },
    {
      "id": "ja279:1.6",
      "pali": "atthakāmoti maññati."
    },
    {
      "id": "ja279:2.1",
      "pali": "Evameva idhekacco,"
    },
    {
      "id": "ja279:2.2",
      "pali": "puggalo hoti tādiso;"
    },
    {
      "id": "ja279:2.3",
      "pali": "Hitehi vacanaṁ vutto,"
    },
    {
      "id": "ja279:2.4",
      "pali": "paṭigaṇhāti vāmato."
    },
    {
      "id": "ja279:3.1",
      "pali": "Ye ca kho naṁ pasaṁsanti,"
    },
    {
      "id": "ja279:3.2",
      "pali": "bhayā ukkaṁsayanti vā;"
    },
    {
      "id": "ja279:3.3",
      "pali": "Tañhi so maññate mittaṁ,"
    },
    {
      "id": "ja279:3.4",
      "pali": "satapattaṁva māṇavo”ti."
    },
    {
      "id": "ja279:4.1",
      "pali": "Satapattajātakaṁ navamaṁ."
    }
  ]
}
