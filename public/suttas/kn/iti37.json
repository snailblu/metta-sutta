{
  "uid": "iti37",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti37:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti37:2.1",
      "pali": "“Dvīhi, bhikkhave, dhammehi samannāgato bhikkhu diṭṭheva dhamme sukhasomanassabahulo viharati, yoni cassa āraddhā hoti āsavānaṁ khayāya."
    },
    {
      "id": "iti37:2.2",
      "pali": "Katamehi dvīhi?"
    },
    {
      "id": "iti37:2.3",
      "pali": "Saṁvejanīyesu ṭhānesu saṁvejanena, saṁviggassa ca yoniso padhānena."
    },
    {
      "id": "iti37:2.4",
      "pali": "Imehi kho, bhikkhave, dvīhi dhammehi samannāgato bhikkhu diṭṭheva dhamme sukhasomanassabahulo viharati, yoni cassa āraddhā hoti āsavānaṁ khayāyā”ti."
    },
    {
      "id": "iti37:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti37:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti37:3.1",
      "pali": "“Saṁvejanīyaṭṭhānesu,"
    },
    {
      "id": "iti37:3.2",
      "pali": "saṁvijjetheva paṇḍito;"
    },
    {
      "id": "iti37:3.3",
      "pali": "Ātāpī nipako bhikkhu,"
    },
    {
      "id": "iti37:3.4",
      "pali": "paññāya samavekkhiya."
    },
    {
      "id": "iti37:4.1",
      "pali": "Evaṁ vihārī ātāpī,"
    },
    {
      "id": "iti37:4.2",
      "pali": "santavutti anuddhato;"
    },
    {
      "id": "iti37:4.3",
      "pali": "Cetosamathamanuyutto,"
    },
    {
      "id": "iti37:4.4",
      "pali": "khayaṁ dukkhassa pāpuṇe”ti."
    },
    {
      "id": "iti37:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti37:5.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti37:5.3",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "iti37:6.1",
      "pali": "Dve ca bhikkhū tapanīyā,"
    },
    {
      "id": "iti37:6.2",
      "pali": "tapanīyā paratthehi;"
    },
    {
      "id": "iti37:6.3",
      "pali": "Ātāpī nakuhanā dve,"
    },
    {
      "id": "iti37:6.4",
      "pali": "somanassena te dasāti."
    }
  ]
}
