{
  "uid": "tha-ap293",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap293:1.1",
      "pali": "“Ajito nāma nāmena,"
    },
    {
      "id": "tha-ap293:1.2",
      "pali": "ahosiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap293:1.3",
      "pali": "Āhutiṁ yiṭṭhukāmohaṁ,"
    },
    {
      "id": "tha-ap293:1.4",
      "pali": "nānāpupphaṁ samānayiṁ."
    },
    {
      "id": "tha-ap293:2.1",
      "pali": "Jalantaṁ citakaṁ disvā,"
    },
    {
      "id": "tha-ap293:2.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap293:2.3",
      "pali": "Tañca pupphaṁ samānetvā,"
    },
    {
      "id": "tha-ap293:2.4",
      "pali": "citake okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap293:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap293:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap293:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap293:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap293:4.1",
      "pali": "Sattavīse ito kappe,"
    },
    {
      "id": "tha-ap293:4.2",
      "pali": "sattāsuṁ manujādhipā;"
    },
    {
      "id": "tha-ap293:4.3",
      "pali": "Supajjalitanāmā te,"
    },
    {
      "id": "tha-ap293:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap293:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap293:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap293:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap293:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap293:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap293:7.1",
      "pali": "Citakapūjakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
