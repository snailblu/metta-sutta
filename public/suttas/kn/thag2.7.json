{
  "uid": "thag2.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.7:1.1",
      "pali": "“Yathā agāraṁ ducchannaṁ,"
    },
    {
      "id": "thag2.7:1.2",
      "pali": "vuṭṭhī samativijjhati;"
    },
    {
      "id": "thag2.7:1.3",
      "pali": "Evaṁ abhāvitaṁ cittaṁ,"
    },
    {
      "id": "thag2.7:1.4",
      "pali": "rāgo samativijjhati."
    },
    {
      "id": "thag2.7:2.1",
      "pali": "Yathā agāraṁ succhannaṁ,"
    },
    {
      "id": "thag2.7:2.2",
      "pali": "Vuṭṭhī na samativijjhati;"
    },
    {
      "id": "thag2.7:2.3",
      "pali": "Evaṁ subhāvitaṁ cittaṁ,"
    },
    {
      "id": "thag2.7:2.4",
      "pali": "Rāgo na samativijjhatī”ti."
    },
    {
      "id": "thag2.7:2.5",
      "pali": "… Rādho thero …."
    }
  ]
}
