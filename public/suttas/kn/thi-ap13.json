{
  "uid": "thi-ap13",
  "title": "Modakadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap13:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "thi-ap13:1.2",
      "pali": "kumbhadāsī ahosahaṁ;"
    },
    {
      "id": "thi-ap13:1.3",
      "pali": "Mama bhāgaṁ gahetvāna,"
    },
    {
      "id": "thi-ap13:1.4",
      "pali": "gacchaṁ udakahārikā."
    },
    {
      "id": "thi-ap13:2.1",
      "pali": "Panthamhi samaṇaṁ disvā,"
    },
    {
      "id": "thi-ap13:2.2",
      "pali": "santacittaṁ samāhitaṁ;"
    },
    {
      "id": "thi-ap13:2.3",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "thi-ap13:2.4",
      "pali": "modake tīṇidāsahaṁ."
    },
    {
      "id": "thi-ap13:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap13:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap13:3.3",
      "pali": "Ekanavutikappāni,"
    },
    {
      "id": "thi-ap13:3.4",
      "pali": "vinipātaṁ nagacchahaṁ."
    },
    {
      "id": "thi-ap13:4.1",
      "pali": "Sampatti taṁ karitvāna,"
    },
    {
      "id": "thi-ap13:4.2",
      "pali": "sabbaṁ anubhaviṁ ahaṁ;"
    },
    {
      "id": "thi-ap13:4.3",
      "pali": "Modake tīṇi datvāna,"
    },
    {
      "id": "thi-ap13:4.4",
      "pali": "pattāhaṁ acalaṁ padaṁ."
    },
    {
      "id": "thi-ap13:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap13:5.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap13:5.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap13:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap13:6.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap13:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap13:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap13:7.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap13:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap13:8.1",
      "pali": "Itthaṁ sudaṁ modakadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap13:9.1",
      "pali": "Modakadāyikātheriyāpadānaṁ tatiyaṁ."
    }
  ]
}
