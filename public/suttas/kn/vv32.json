{
  "uid": "vv32",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv32:1.1",
      "pali": "Latā ca sajjā pavarā ca devatā,"
    },
    {
      "id": "vv32:1.2",
      "pali": "Accimatī rājavarassa sirīmato;"
    },
    {
      "id": "vv32:1.3",
      "pali": "Sutā ca rañño vessavaṇassa dhītā,"
    },
    {
      "id": "vv32:1.4",
      "pali": "Rājīmatī dhammaguṇehi sobhatha."
    },
    {
      "id": "vv32:2.1",
      "pali": "Pañcettha nāriyo āgamaṁsu nhāyituṁ,"
    },
    {
      "id": "vv32:2.2",
      "pali": "Sītodakaṁ uppaliniṁ sivaṁ nadiṁ;"
    },
    {
      "id": "vv32:2.3",
      "pali": "Tā tattha nhāyitvā rametvā devatā,"
    },
    {
      "id": "vv32:2.4",
      "pali": "Naccitvā gāyitvā sutā lataṁ bravi."
    },
    {
      "id": "vv32:3.1",
      "pali": "“Pucchāmi taṁ uppalamāladhārini,"
    },
    {
      "id": "vv32:3.2",
      "pali": "Āveḷini kañcanasannibhattace;"
    },
    {
      "id": "vv32:3.3",
      "pali": "Timiratambakkhi nabheva sobhane,"
    },
    {
      "id": "vv32:3.4",
      "pali": "Dīghāyukī kena kato yaso tava."
    },
    {
      "id": "vv32:4.1",
      "pali": "Kenāsi bhadde patino piyatarā,"
    },
    {
      "id": "vv32:4.2",
      "pali": "Visiṭṭhakalyāṇitarassu rūpato;"
    },
    {
      "id": "vv32:4.3",
      "pali": "Padakkhiṇā naccanagītavādite,"
    },
    {
      "id": "vv32:4.4",
      "pali": "Ācikkha no tvaṁ naranāripucchitā”ti."
    },
    {
      "id": "vv32:5.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv32:5.2",
      "pali": "Uḷārabhoge kule suṇisā ahosiṁ;"
    },
    {
      "id": "vv32:5.3",
      "pali": "Akkodhanā bhattuvasānuvattinī,"
    },
    {
      "id": "vv32:5.4",
      "pali": "Uposathe appamattā ahosiṁ."
    },
    {
      "id": "vv32:6.1",
      "pali": "Manussabhūtā daharā apāpikā,"
    },
    {
      "id": "vv32:6.2",
      "pali": "Pasannacittā patimābhirādhayiṁ;"
    },
    {
      "id": "vv32:6.3",
      "pali": "Sadevaraṁ sassasuraṁ sadāsakaṁ,"
    },
    {
      "id": "vv32:6.4",
      "pali": "Abhirādhayiṁ tamhi kato yaso mama."
    },
    {
      "id": "vv32:7.1",
      "pali": "Sāhaṁ tena kusalena kammunā,"
    },
    {
      "id": "vv32:7.2",
      "pali": "Catubbhi ṭhānehi visesamajjhagā;"
    },
    {
      "id": "vv32:7.3",
      "pali": "Āyuñca vaṇṇañca sukhaṁ balañca,"
    },
    {
      "id": "vv32:7.4",
      "pali": "Khiḍḍāratiṁ paccanubhomanappakaṁ”."
    },
    {
      "id": "vv32:8.1",
      "pali": "“Sutaṁ nu taṁ bhāsati yaṁ ayaṁ latā,"
    },
    {
      "id": "vv32:8.2",
      "pali": "Yaṁ no apucchimha akittayī no;"
    },
    {
      "id": "vv32:8.3",
      "pali": "Patino kiramhākaṁ visiṭṭha nārīnaṁ,"
    },
    {
      "id": "vv32:8.4",
      "pali": "Gatī ca tāsaṁ pavarā ca devatā."
    },
    {
      "id": "vv32:9.1",
      "pali": "Patīsu dhammaṁ pacarāma sabbā,"
    },
    {
      "id": "vv32:9.2",
      "pali": "Patibbatā yattha bhavanti itthiyo;"
    },
    {
      "id": "vv32:9.3",
      "pali": "Patīsu dhammaṁ pacaritva sabbā,"
    },
    {
      "id": "vv32:9.4",
      "pali": "Lacchāmase bhāsati yaṁ ayaṁ latā."
    },
    {
      "id": "vv32:10.1",
      "pali": "Sīho yathā pabbatasānugocaro,"
    },
    {
      "id": "vv32:10.2",
      "pali": "Mahindharaṁ pabbatamāvasitvā;"
    },
    {
      "id": "vv32:10.3",
      "pali": "Pasayha hantvā itare catuppade,"
    },
    {
      "id": "vv32:10.4",
      "pali": "Khudde mige khādati maṁsabhojano."
    },
    {
      "id": "vv32:11.1",
      "pali": "Tatheva saddhā idha ariyasāvikā,"
    },
    {
      "id": "vv32:11.2",
      "pali": "Bhattāraṁ nissāya patiṁ anubbatā;"
    },
    {
      "id": "vv32:11.3",
      "pali": "Kodhaṁ vadhitvā abhibhuyya maccharaṁ,"
    },
    {
      "id": "vv32:11.4",
      "pali": "Saggamhi sā modati dhammacārinī”ti."
    },
    {
      "id": "vv32:12.1",
      "pali": "Latāvimānaṁ catutthaṁ."
    }
  ]
}
