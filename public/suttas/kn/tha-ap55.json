{
  "uid": "tha-ap55",
  "title": "Sayanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap55:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap55:1.2",
      "pali": "sabbalokānukampino;"
    },
    {
      "id": "tha-ap55:1.3",
      "pali": "Sayanaṁ tassa pādāsiṁ,"
    },
    {
      "id": "tha-ap55:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap55:2.1",
      "pali": "Tena sayanadānena,"
    },
    {
      "id": "tha-ap55:2.2",
      "pali": "sukhette bījasampadā;"
    },
    {
      "id": "tha-ap55:2.3",
      "pali": "Bhogā nibbattare tassa,"
    },
    {
      "id": "tha-ap55:2.4",
      "pali": "sayanassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap55:3.1",
      "pali": "Ākāse seyyaṁ kappemi,"
    },
    {
      "id": "tha-ap55:3.2",
      "pali": "dhāremi pathaviṁ imaṁ;"
    },
    {
      "id": "tha-ap55:3.3",
      "pali": "Pāṇesu me issariyaṁ,"
    },
    {
      "id": "tha-ap55:3.4",
      "pali": "sayanassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap55:4.1",
      "pali": "Pañcakappasahassamhi,"
    },
    {
      "id": "tha-ap55:4.2",
      "pali": "aṭṭha āsuṁ mahātejā;"
    },
    {
      "id": "tha-ap55:4.3",
      "pali": "Catuttiṁse kappasate,"
    },
    {
      "id": "tha-ap55:4.4",
      "pali": "caturo ca mahabbalā."
    },
    {
      "id": "tha-ap55:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap55:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap55:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap55:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sayanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap55:7.1",
      "pali": "Sayanadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
