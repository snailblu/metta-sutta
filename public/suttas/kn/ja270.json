{
  "uid": "ja270",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja270:1.1",
      "pali": "“Sabbehi kira ñātīhi,"
    },
    {
      "id": "ja270:1.2",
      "pali": "kosiyo issaro kato;"
    },
    {
      "id": "ja270:1.3",
      "pali": "Sace ñātīhi anuññāto,"
    },
    {
      "id": "ja270:1.4",
      "pali": "bhaṇeyyāhaṁ ekavācikaṁ”."
    },
    {
      "id": "ja270:2.1",
      "pali": "“Bhaṇa samma anuññāto,"
    },
    {
      "id": "ja270:2.2",
      "pali": "atthaṁ dhammañca kevalaṁ;"
    },
    {
      "id": "ja270:2.3",
      "pali": "Santi hi daharā pakkhī,"
    },
    {
      "id": "ja270:2.4",
      "pali": "paññavanto jutindharā”."
    },
    {
      "id": "ja270:3.1",
      "pali": "“Na me ruccati bhaddaṁ vo,"
    },
    {
      "id": "ja270:3.2",
      "pali": "ulūkassābhisecanaṁ;"
    },
    {
      "id": "ja270:3.3",
      "pali": "Akkuddhassa mukhaṁ passa,"
    },
    {
      "id": "ja270:3.4",
      "pali": "kathaṁ kuddho karissatī”ti."
    },
    {
      "id": "ja270:4.1",
      "pali": "Ulūkajātakaṁ dasamaṁ."
    },
    {
      "id": "ja270:4.2",
      "pali": "Padumavaggo dutiyo."
    },
    {
      "id": "ja270:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja270:6.1",
      "pali": "Padumuttama nāgasirivhayano,"
    },
    {
      "id": "ja270:6.2",
      "pali": "Sa-mahaṇṇava yūpa khurappavaro;"
    },
    {
      "id": "ja270:6.3",
      "pali": "Atha bhaddalī kuñjara rukkha puna,"
    },
    {
      "id": "ja270:6.4",
      "pali": "Kharavāca ulūkavarena dasāti."
    }
  ]
}
