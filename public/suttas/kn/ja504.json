{
  "uid": "ja504",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja504:1.1",
      "pali": "Bhallātiyo nāma ahosi rājā,"
    },
    {
      "id": "ja504:1.2",
      "pali": "Raṭṭhaṁ pahāya migavaṁ acāri so;"
    },
    {
      "id": "ja504:1.3",
      "pali": "Agamā girivaraṁ gandhamādanaṁ,"
    },
    {
      "id": "ja504:1.4",
      "pali": "Supupphitaṁ kimpurisānuciṇṇaṁ."
    },
    {
      "id": "ja504:2.1",
      "pali": "Sāḷūrasaṅghañca nisedhayitvā,"
    },
    {
      "id": "ja504:2.2",
      "pali": "Dhanuṁ kalāpañca so nikkhipitvā;"
    },
    {
      "id": "ja504:2.3",
      "pali": "Upāgami vacanaṁ vattukāmo,"
    },
    {
      "id": "ja504:2.4",
      "pali": "Yatthaṭṭhitā kimpurisā ahesuṁ."
    },
    {
      "id": "ja504:3.1",
      "pali": "“Himaccaye hemavatāya tīre,"
    },
    {
      "id": "ja504:3.2",
      "pali": "Kimidhaṭṭhitā mantayavho abhiṇhaṁ;"
    },
    {
      "id": "ja504:3.3",
      "pali": "Pucchāmi vo mānusadehavaṇṇe,"
    },
    {
      "id": "ja504:3.4",
      "pali": "Kathaṁ vo jānanti manussaloke”."
    },
    {
      "id": "ja504:4.1",
      "pali": "“Mallaṁ giriṁ paṇḍarakaṁ tikūṭaṁ,"
    },
    {
      "id": "ja504:4.2",
      "pali": "Sītodakā anuvicarāma najjo;"
    },
    {
      "id": "ja504:4.3",
      "pali": "Migā manussāva nibhāsavaṇṇā,"
    },
    {
      "id": "ja504:4.4",
      "pali": "Jānanti no kimpurisāti ludda”."
    },
    {
      "id": "ja504:5.1",
      "pali": "“Sukiccharūpaṁ paridevayavho,"
    },
    {
      "id": "ja504:5.2",
      "pali": "Āliṅgito cāsi piyo piyāya;"
    },
    {
      "id": "ja504:5.3",
      "pali": "Pucchāmi vo mānusadehavaṇṇe,"
    },
    {
      "id": "ja504:5.4",
      "pali": "Kimidha vane rodatha appatītā."
    },
    {
      "id": "ja504:6.1",
      "pali": "Sukiccharūpaṁ paridevayavho,"
    },
    {
      "id": "ja504:6.2",
      "pali": "Āliṅgito cāsi piyo piyāya;"
    },
    {
      "id": "ja504:6.3",
      "pali": "Pucchāmi vo mānusadehavaṇṇe,"
    },
    {
      "id": "ja504:6.4",
      "pali": "Kimidha vane vilapatha appatītā."
    },
    {
      "id": "ja504:7.1",
      "pali": "Sukiccharūpaṁ paridevayavho,"
    },
    {
      "id": "ja504:7.2",
      "pali": "Āliṅgito cāsi piyo piyāya;"
    },
    {
      "id": "ja504:7.3",
      "pali": "Pucchāmi vo mānusadehavaṇṇe,"
    },
    {
      "id": "ja504:7.4",
      "pali": "Kimidha vane socatha appatītā”."
    },
    {
      "id": "ja504:8.1",
      "pali": "“Mayekarattaṁ vippavasimha ludda,"
    },
    {
      "id": "ja504:8.2",
      "pali": "Akāmakā aññamaññaṁ sarantā;"
    },
    {
      "id": "ja504:8.3",
      "pali": "Tamekarattaṁ anutappamānā,"
    },
    {
      "id": "ja504:8.4",
      "pali": "Socāma ‘sā ratti punaṁ na hessati’”."
    },
    {
      "id": "ja504:9.1",
      "pali": "“Yamekarattaṁ anutappathetaṁ,"
    },
    {
      "id": "ja504:9.2",
      "pali": "Dhanaṁ va naṭṭhaṁ pitaraṁ va petaṁ;"
    },
    {
      "id": "ja504:9.3",
      "pali": "Pucchāmi vo mānusadehavaṇṇe,"
    },
    {
      "id": "ja504:9.4",
      "pali": "Kathaṁ vinā vāsamakappayittha”."
    },
    {
      "id": "ja504:10.1",
      "pali": "“Yamimaṁ nadiṁ passasi sīghasotaṁ,"
    },
    {
      "id": "ja504:10.2",
      "pali": "Nānādumacchādanaṁ selakūlaṁ;"
    },
    {
      "id": "ja504:10.3",
      "pali": "Taṁ me piyo uttari vassakāle,"
    },
    {
      "id": "ja504:10.4",
      "pali": "Mamañca maññaṁ anubandhatīti."
    },
    {
      "id": "ja504:11.1",
      "pali": "Ahañca aṅkolakamocināmi,"
    },
    {
      "id": "ja504:11.2",
      "pali": "Atimuttakaṁ sattaliyothikañca;"
    },
    {
      "id": "ja504:11.3",
      "pali": "‘Piyo ca me hehiti mālabhārī,"
    },
    {
      "id": "ja504:11.4",
      "pali": "Ahañca naṁ mālinī ajjhupessaṁ’."
    },
    {
      "id": "ja504:12.1",
      "pali": "Ahañcidaṁ kuravakamocināmi,"
    },
    {
      "id": "ja504:12.2",
      "pali": "Uddālakā pāṭalisindhuvārakā;"
    },
    {
      "id": "ja504:12.3",
      "pali": "‘Piyo ca me hehiti mālabhārī,"
    },
    {
      "id": "ja504:12.4",
      "pali": "Ahañca naṁ mālinī ajjhupessaṁ’."
    },
    {
      "id": "ja504:13.1",
      "pali": "Ahañca sālassa supupphitassa,"
    },
    {
      "id": "ja504:13.2",
      "pali": "Oceyya pupphāni karomi mālaṁ;"
    },
    {
      "id": "ja504:13.3",
      "pali": "‘Piyo ca me hehiti mālabhārī,"
    },
    {
      "id": "ja504:13.4",
      "pali": "Ahañca naṁ mālinī ajjhupessaṁ’."
    },
    {
      "id": "ja504:14.1",
      "pali": "Ahañca sālassa supupphitassa,"
    },
    {
      "id": "ja504:14.2",
      "pali": "Oceyya pupphāni karomi bhāraṁ;"
    },
    {
      "id": "ja504:14.3",
      "pali": "Idañca no hehiti santharatthaṁ,"
    },
    {
      "id": "ja504:14.4",
      "pali": "Yatthajjimaṁ viharissāma rattiṁ."
    },
    {
      "id": "ja504:15.1",
      "pali": "Ahañca kho agaḷuṁ candanañca,"
    },
    {
      "id": "ja504:15.2",
      "pali": "Silāya piṁsāmi pamattarūpā;"
    },
    {
      "id": "ja504:15.3",
      "pali": "‘Piyo ca me hehiti rositaṅgo,"
    },
    {
      "id": "ja504:15.4",
      "pali": "Ahañca naṁ rositā ajjhupessaṁ’."
    },
    {
      "id": "ja504:16.1",
      "pali": "Athāgamā salilaṁ sīghasotaṁ,"
    },
    {
      "id": "ja504:16.2",
      "pali": "Nudaṁ sāle salaḷe kaṇṇikāre;"
    },
    {
      "id": "ja504:16.3",
      "pali": "Āpūratha tena muhuttakena,"
    },
    {
      "id": "ja504:16.4",
      "pali": "Sāyaṁ nadī āsi mayā suduttarā."
    },
    {
      "id": "ja504:17.1",
      "pali": "Ubhosu tīresu mayaṁ tadā ṭhitā,"
    },
    {
      "id": "ja504:17.2",
      "pali": "Sampassantā ubhayo aññamaññaṁ;"
    },
    {
      "id": "ja504:17.3",
      "pali": "Sakimpi rodāma sakiṁ hasāma,"
    },
    {
      "id": "ja504:17.4",
      "pali": "Kicchena no āgamā saṁvarī sā."
    },
    {
      "id": "ja504:18.1",
      "pali": "Pātova kho uggate sūriyamhi,"
    },
    {
      "id": "ja504:18.2",
      "pali": "Catukkaṁ nadiṁ uttariyāna ludda;"
    },
    {
      "id": "ja504:18.3",
      "pali": "Āliṅgiyā aññamaññaṁ mayaṁ ubho,"
    },
    {
      "id": "ja504:18.4",
      "pali": "Sakimpi rodāma sakiṁ hasāma."
    },
    {
      "id": "ja504:19.1",
      "pali": "Tīhūnakaṁ sattasatāni ludda,"
    },
    {
      "id": "ja504:19.2",
      "pali": "Yamidha mayaṁ vippavasimha pubbe;"
    },
    {
      "id": "ja504:19.3",
      "pali": "Vassekimaṁ jīvitaṁ bhūmipāla,"
    },
    {
      "id": "ja504:19.4",
      "pali": "Ko nīdha kantāya vinā vaseyya”."
    },
    {
      "id": "ja504:20.1",
      "pali": "“Āyuñca vo kīvatako nu samma,"
    },
    {
      "id": "ja504:20.2",
      "pali": "Sacepi jānātha vadetha āyuṁ;"
    },
    {
      "id": "ja504:20.3",
      "pali": "Anussavā vuḍḍhato āgamā vā,"
    },
    {
      "id": "ja504:20.4",
      "pali": "Akkhātha me taṁ avikampamānā”."
    },
    {
      "id": "ja504:21.1",
      "pali": "“Āyuñca no vassasahassaṁ ludda,"
    },
    {
      "id": "ja504:21.2",
      "pali": "Na cantarā pāpako atthi rogo;"
    },
    {
      "id": "ja504:21.3",
      "pali": "Appañca dukkhaṁ sukhameva bhiyyo,"
    },
    {
      "id": "ja504:21.4",
      "pali": "Avītarāgā vijahāma jīvitaṁ”."
    },
    {
      "id": "ja504:22.1",
      "pali": "“Idañca sutvāna amānusānaṁ,"
    },
    {
      "id": "ja504:22.2",
      "pali": "Bhallātiyo ittara jīvitanti;"
    },
    {
      "id": "ja504:22.3",
      "pali": "Nivattatha na migavaṁ acari,"
    },
    {
      "id": "ja504:22.4",
      "pali": "Adāsi dānāni abhuñji bhoge."
    },
    {
      "id": "ja504:23.1",
      "pali": "Idañca sutvāna amānusānaṁ,"
    },
    {
      "id": "ja504:23.2",
      "pali": "Sammodatha mā kalahaṁ akattha;"
    },
    {
      "id": "ja504:23.3",
      "pali": "Mā vo tapī attakammāparādho,"
    },
    {
      "id": "ja504:23.4",
      "pali": "Yathāpi te kimpurisekarattaṁ."
    },
    {
      "id": "ja504:24.1",
      "pali": "Idañca sutvāna amānusānaṁ,"
    },
    {
      "id": "ja504:24.2",
      "pali": "Sammodatha mā vivādaṁ akattha;"
    },
    {
      "id": "ja504:24.3",
      "pali": "Mā vo tapī attakammāparādho,"
    },
    {
      "id": "ja504:24.4",
      "pali": "Yathāpi te kimpurisekarattaṁ”."
    },
    {
      "id": "ja504:25.1",
      "pali": "“Vividhaṁ adhimanā suṇomahaṁ,"
    },
    {
      "id": "ja504:25.2",
      "pali": "Vacanapathaṁ tava atthasaṁhitaṁ;"
    },
    {
      "id": "ja504:25.3",
      "pali": "Muñcaṁ giraṁ nudaseva me daraṁ,"
    },
    {
      "id": "ja504:25.4",
      "pali": "Samaṇa sukhāvaha jīva me ciran”ti."
    },
    {
      "id": "ja504:26.1",
      "pali": "Bhallātiyajātakaṁ aṭṭhamaṁ."
    }
  ]
}
