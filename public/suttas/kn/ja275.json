{
  "uid": "ja275",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja275:1.1",
      "pali": "“Kāyaṁ balākā rucirā,"
    },
    {
      "id": "ja275:1.2",
      "pali": "kākanīḷasmimacchati;"
    },
    {
      "id": "ja275:1.3",
      "pali": "Caṇḍo kāko sakhā mayhaṁ,"
    },
    {
      "id": "ja275:1.4",
      "pali": "yassa cetaṁ kulāvakaṁ”."
    },
    {
      "id": "ja275:2.1",
      "pali": "“Nanu maṁ samma jānāsi,"
    },
    {
      "id": "ja275:2.2",
      "pali": "dija sāmākabhojana;"
    },
    {
      "id": "ja275:2.3",
      "pali": "Akatvā vacanaṁ tuyhaṁ,"
    },
    {
      "id": "ja275:2.4",
      "pali": "passa lūnosmi āgato”."
    },
    {
      "id": "ja275:3.1",
      "pali": "“Punapāpajjasī samma,"
    },
    {
      "id": "ja275:3.2",
      "pali": "sīlañhi tava tādisaṁ;"
    },
    {
      "id": "ja275:3.3",
      "pali": "Na hi mānusakā bhogā,"
    },
    {
      "id": "ja275:3.4",
      "pali": "subhuñjā honti pakkhinā”ti."
    },
    {
      "id": "ja275:4.1",
      "pali": "Rucirajātakaṁ pañcamaṁ."
    }
  ]
}
