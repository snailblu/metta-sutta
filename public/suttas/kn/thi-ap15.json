{
  "uid": "thi-ap15",
  "title": "Pañcadīpadāyikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap15:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "thi-ap15:1.2",
      "pali": "cārikī āsahaṁ tadā;"
    },
    {
      "id": "thi-ap15:1.3",
      "pali": "Ārāmena ca ārāmaṁ,"
    },
    {
      "id": "thi-ap15:1.4",
      "pali": "carāmi kusalatthikā."
    },
    {
      "id": "thi-ap15:2.1",
      "pali": "Kāḷapakkhamhi divase,"
    },
    {
      "id": "thi-ap15:2.2",
      "pali": "addasaṁ bodhimuttamaṁ;"
    },
    {
      "id": "thi-ap15:2.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "thi-ap15:2.4",
      "pali": "bodhimūle nisīdahaṁ."
    },
    {
      "id": "thi-ap15:3.1",
      "pali": "Garucittaṁ upaṭṭhetvā,"
    },
    {
      "id": "thi-ap15:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "thi-ap15:3.3",
      "pali": "Somanassaṁ pavedetvā,"
    },
    {
      "id": "thi-ap15:3.4",
      "pali": "evaṁ cintesi tāvade."
    },
    {
      "id": "thi-ap15:4.1",
      "pali": "‘Yadi buddho amitaguṇo,"
    },
    {
      "id": "thi-ap15:4.2",
      "pali": "asamappaṭipuggalo;"
    },
    {
      "id": "thi-ap15:4.3",
      "pali": "Dassetu pāṭihīraṁ me,"
    },
    {
      "id": "thi-ap15:4.4",
      "pali": "bodhi obhāsatu ayaṁ’."
    },
    {
      "id": "thi-ap15:5.1",
      "pali": "Saha āvajjite mayhaṁ,"
    },
    {
      "id": "thi-ap15:5.2",
      "pali": "bodhi pajjali tāvade;"
    },
    {
      "id": "thi-ap15:5.3",
      "pali": "Sabbasoṇṇamayā āsi,"
    },
    {
      "id": "thi-ap15:5.4",
      "pali": "disā sabbā virocati."
    },
    {
      "id": "thi-ap15:6.1",
      "pali": "Sattarattindivaṁ tattha,"
    },
    {
      "id": "thi-ap15:6.2",
      "pali": "bodhimūle nisīdahaṁ;"
    },
    {
      "id": "thi-ap15:6.3",
      "pali": "Sattame divase patte,"
    },
    {
      "id": "thi-ap15:6.4",
      "pali": "dīpapūjaṁ akāsahaṁ."
    },
    {
      "id": "thi-ap15:7.1",
      "pali": "Āsanaṁ parivāretvā,"
    },
    {
      "id": "thi-ap15:7.2",
      "pali": "pañca dīpāni pajjaluṁ;"
    },
    {
      "id": "thi-ap15:7.3",
      "pali": "Yāva udeti sūriyo,"
    },
    {
      "id": "thi-ap15:7.4",
      "pali": "dīpā me pajjaluṁ tadā."
    },
    {
      "id": "thi-ap15:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap15:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap15:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap15:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap15:9.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "thi-ap15:9.2",
      "pali": "pañcadīpāti vuccati;"
    },
    {
      "id": "thi-ap15:9.3",
      "pali": "Saṭṭhiyojanamubbedhaṁ,"
    },
    {
      "id": "thi-ap15:9.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "thi-ap15:10.1",
      "pali": "Asaṅkhiyāni dīpāni,"
    },
    {
      "id": "thi-ap15:10.2",
      "pali": "parivāre jaliṁsu me;"
    },
    {
      "id": "thi-ap15:10.3",
      "pali": "Yāvatā devabhavanaṁ,"
    },
    {
      "id": "thi-ap15:10.4",
      "pali": "dīpālokena jotati."
    },
    {
      "id": "thi-ap15:11.1",
      "pali": "Parammukhā nisīditvā,"
    },
    {
      "id": "thi-ap15:11.2",
      "pali": "yadi icchāmi passituṁ;"
    },
    {
      "id": "thi-ap15:11.3",
      "pali": "Uddhaṁ adho ca tiriyaṁ,"
    },
    {
      "id": "thi-ap15:11.4",
      "pali": "sabbaṁ passāmi cakkhunā."
    },
    {
      "id": "thi-ap15:12.1",
      "pali": "Yāvatā abhikaṅkhāmi,"
    },
    {
      "id": "thi-ap15:12.2",
      "pali": "daṭṭhuṁ sugataduggate;"
    },
    {
      "id": "thi-ap15:12.3",
      "pali": "Tattha āvaraṇaṁ natthi,"
    },
    {
      "id": "thi-ap15:12.4",
      "pali": "rukkhesu pabbatesu vā."
    },
    {
      "id": "thi-ap15:13.1",
      "pali": "Asīti devarājūnaṁ,"
    },
    {
      "id": "thi-ap15:13.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap15:13.3",
      "pali": "Satānaṁ cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap15:13.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap15:14.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "thi-ap15:14.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "thi-ap15:14.3",
      "pali": "Dīpasatasahassāni,"
    },
    {
      "id": "thi-ap15:14.4",
      "pali": "parivāre jalanti me."
    },
    {
      "id": "thi-ap15:15.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "thi-ap15:15.2",
      "pali": "uppajjiṁ mātukucchiyaṁ;"
    },
    {
      "id": "thi-ap15:15.3",
      "pali": "Mātukucchigatā santī,"
    },
    {
      "id": "thi-ap15:15.4",
      "pali": "akkhi me na nimīlati."
    },
    {
      "id": "thi-ap15:16.1",
      "pali": "Dīpasatasahassāni,"
    },
    {
      "id": "thi-ap15:16.2",
      "pali": "puññakammasamaṅgitā;"
    },
    {
      "id": "thi-ap15:16.3",
      "pali": "Jalanti sūtikāgehe,"
    },
    {
      "id": "thi-ap15:16.4",
      "pali": "pañcadīpānidaṁ phalaṁ."
    },
    {
      "id": "thi-ap15:17.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap15:17.2",
      "pali": "mānasaṁ vinivattayiṁ;"
    },
    {
      "id": "thi-ap15:17.3",
      "pali": "Ajarāmataṁ sītibhāvaṁ,"
    },
    {
      "id": "thi-ap15:17.4",
      "pali": "nibbānaṁ phassayiṁ ahaṁ."
    },
    {
      "id": "thi-ap15:18.1",
      "pali": "Jātiyā sattavassāhaṁ,"
    },
    {
      "id": "thi-ap15:18.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "thi-ap15:18.3",
      "pali": "Upasampādayī buddho,"
    },
    {
      "id": "thi-ap15:18.4",
      "pali": "guṇamaññāya gotamo."
    },
    {
      "id": "thi-ap15:19.1",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "thi-ap15:19.2",
      "pali": "suññāgāre vasantiyā;"
    },
    {
      "id": "thi-ap15:19.3",
      "pali": "Sadā pajjalate dīpaṁ,"
    },
    {
      "id": "thi-ap15:19.4",
      "pali": "pañcadīpānidaṁ phalaṁ."
    },
    {
      "id": "thi-ap15:20.1",
      "pali": "Dibbacakkhuvisuddhaṁ me,"
    },
    {
      "id": "thi-ap15:20.2",
      "pali": "samādhikusalā ahaṁ;"
    },
    {
      "id": "thi-ap15:20.3",
      "pali": "Abhiññāpāramippattā,"
    },
    {
      "id": "thi-ap15:20.4",
      "pali": "pañcadīpānidaṁ phalaṁ."
    },
    {
      "id": "thi-ap15:21.1",
      "pali": "Sabbavositavosānā,"
    },
    {
      "id": "thi-ap15:21.2",
      "pali": "katakiccā anāsavā;"
    },
    {
      "id": "thi-ap15:21.3",
      "pali": "Pañcadīpā mahāvīra,"
    },
    {
      "id": "thi-ap15:21.4",
      "pali": "pāde vandāmi cakkhuma."
    },
    {
      "id": "thi-ap15:22.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap15:22.2",
      "pali": "yaṁ dīpamadadiṁ tadā;"
    },
    {
      "id": "thi-ap15:22.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap15:22.4",
      "pali": "pañcadīpānidaṁ phalaṁ."
    },
    {
      "id": "thi-ap15:23.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap15:23.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap15:23.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap15:24.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap15:24.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap15:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap15:25.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap15:25.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap15:25.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap15:26.1",
      "pali": "Itthaṁ sudaṁ pañcadīpadāyikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap15:27.1",
      "pali": "Pañcadīpadāyikātheriyāpadānaṁ pañcamaṁ."
    }
  ]
}
