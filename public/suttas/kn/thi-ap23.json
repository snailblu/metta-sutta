{
  "uid": "thi-ap23",
  "title": "Dhammadinnātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap23:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap23:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap23:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap23:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap23:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "thi-ap23:2.2",
      "pali": "kule aññatare ahuṁ;"
    },
    {
      "id": "thi-ap23:2.3",
      "pali": "Parakammakārī āsiṁ,"
    },
    {
      "id": "thi-ap23:2.4",
      "pali": "nipakā sīlasaṁvutā."
    },
    {
      "id": "thi-ap23:3.1",
      "pali": "Padumuttarabuddhassa,"
    },
    {
      "id": "thi-ap23:3.2",
      "pali": "sujāto aggasāvako;"
    },
    {
      "id": "thi-ap23:3.3",
      "pali": "Vihārā abhinikkhamma,"
    },
    {
      "id": "thi-ap23:3.4",
      "pali": "piṇḍapātāya gacchati."
    },
    {
      "id": "thi-ap23:4.1",
      "pali": "Ghaṭaṁ gahetvā gacchantī,"
    },
    {
      "id": "thi-ap23:4.2",
      "pali": "tadā udakahārikā;"
    },
    {
      "id": "thi-ap23:4.3",
      "pali": "Taṁ disvā adadaṁ pūpaṁ,"
    },
    {
      "id": "thi-ap23:4.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "thi-ap23:5.1",
      "pali": "Paṭiggahetvā tattheva,"
    },
    {
      "id": "thi-ap23:5.2",
      "pali": "nisinno paribhuñji so;"
    },
    {
      "id": "thi-ap23:5.3",
      "pali": "Tato netvāna taṁ gehaṁ,"
    },
    {
      "id": "thi-ap23:5.4",
      "pali": "adāsiṁ tassa bhojanaṁ."
    },
    {
      "id": "thi-ap23:6.1",
      "pali": "Tato me ayyako tuṭṭho,"
    },
    {
      "id": "thi-ap23:6.2",
      "pali": "akarī suṇisaṁ sakaṁ;"
    },
    {
      "id": "thi-ap23:6.3",
      "pali": "Sassuyā saha gantvāna,"
    },
    {
      "id": "thi-ap23:6.4",
      "pali": "sambuddhaṁ abhivādayiṁ."
    },
    {
      "id": "thi-ap23:7.1",
      "pali": "Tadā so dhammakathikaṁ,"
    },
    {
      "id": "thi-ap23:7.2",
      "pali": "bhikkhuniṁ parikittayaṁ;"
    },
    {
      "id": "thi-ap23:7.3",
      "pali": "Ṭhapesi etadaggamhi,"
    },
    {
      "id": "thi-ap23:7.4",
      "pali": "taṁ sutvā muditā ahaṁ."
    },
    {
      "id": "thi-ap23:8.1",
      "pali": "Nimantayitvā sugataṁ,"
    },
    {
      "id": "thi-ap23:8.2",
      "pali": "sasaṅghaṁ lokanāyakaṁ;"
    },
    {
      "id": "thi-ap23:8.3",
      "pali": "Mahādānaṁ daditvāna,"
    },
    {
      "id": "thi-ap23:8.4",
      "pali": "taṁ ṭhānamabhipatthayiṁ."
    },
    {
      "id": "thi-ap23:9.1",
      "pali": "Tato maṁ sugato āha,"
    },
    {
      "id": "thi-ap23:9.2",
      "pali": "ghananinnādasussaro;"
    },
    {
      "id": "thi-ap23:9.3",
      "pali": "‘Mamupaṭṭhānanirate,"
    },
    {
      "id": "thi-ap23:9.4",
      "pali": "sasaṅghaparivesike."
    },
    {
      "id": "thi-ap23:10.1",
      "pali": "Saddhammassavane yutte,"
    },
    {
      "id": "thi-ap23:10.2",
      "pali": "guṇavaddhitamānase;"
    },
    {
      "id": "thi-ap23:10.3",
      "pali": "Bhadde bhavassu muditā,"
    },
    {
      "id": "thi-ap23:10.4",
      "pali": "lacchase paṇidhīphalaṁ."
    },
    {
      "id": "thi-ap23:11.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap23:11.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap23:11.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap23:11.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap23:12.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap23:12.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap23:12.3",
      "pali": "Dhammadinnāti nāmena,"
    },
    {
      "id": "thi-ap23:12.4",
      "pali": "hessati satthu sāvikā’."
    },
    {
      "id": "thi-ap23:13.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap23:13.2",
      "pali": "yāvajīvaṁ mahāmuniṁ;"
    },
    {
      "id": "thi-ap23:13.3",
      "pali": "Mettacittā paricariṁ,"
    },
    {
      "id": "thi-ap23:13.4",
      "pali": "paccayehi vināyakaṁ."
    },
    {
      "id": "thi-ap23:14.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap23:14.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap23:14.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap23:14.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap23:15.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "thi-ap23:15.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "thi-ap23:15.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "thi-ap23:15.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "thi-ap23:16.1",
      "pali": "Upaṭṭhāko mahesissa,"
    },
    {
      "id": "thi-ap23:16.2",
      "pali": "tadā āsi narissaro;"
    },
    {
      "id": "thi-ap23:16.3",
      "pali": "Kāsirājā kikī nāma,"
    },
    {
      "id": "thi-ap23:16.4",
      "pali": "bārāṇasipuruttame."
    },
    {
      "id": "thi-ap23:17.1",
      "pali": "Chaṭṭhā tassāsahaṁ dhītā,"
    },
    {
      "id": "thi-ap23:17.2",
      "pali": "sudhammā iti vissutā;"
    },
    {
      "id": "thi-ap23:17.3",
      "pali": "Dhammaṁ sutvā jinaggassa,"
    },
    {
      "id": "thi-ap23:17.4",
      "pali": "pabbajjaṁ samarocayiṁ."
    },
    {
      "id": "thi-ap23:18.1",
      "pali": "Anujāni na no tāto,"
    },
    {
      "id": "thi-ap23:18.2",
      "pali": "agāreva tadā mayaṁ;"
    },
    {
      "id": "thi-ap23:18.3",
      "pali": "Vīsavassasahassāni,"
    },
    {
      "id": "thi-ap23:18.4",
      "pali": "vicarimha atanditā."
    },
    {
      "id": "thi-ap23:19.1",
      "pali": "Tatiyaṁ bhāṇavāraṁ."
    },
    {
      "id": "thi-ap23:20.1",
      "pali": "Komāribrahmacariyaṁ,"
    },
    {
      "id": "thi-ap23:20.2",
      "pali": "rājakaññā sukhedhitā;"
    },
    {
      "id": "thi-ap23:20.3",
      "pali": "Buddhopaṭṭhānaniratā,"
    },
    {
      "id": "thi-ap23:20.4",
      "pali": "muditā satta dhītaro."
    },
    {
      "id": "thi-ap23:21.1",
      "pali": "Samaṇī samaṇaguttā ca,"
    },
    {
      "id": "thi-ap23:21.2",
      "pali": "bhikkhunī bhikkhudāyikā;"
    },
    {
      "id": "thi-ap23:21.3",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "thi-ap23:21.4",
      "pali": "sattamī saṅghadāyikā."
    },
    {
      "id": "thi-ap23:22.1",
      "pali": "Khemā uppalavaṇṇā ca,"
    },
    {
      "id": "thi-ap23:22.2",
      "pali": "paṭācārā ca kuṇḍalā;"
    },
    {
      "id": "thi-ap23:22.3",
      "pali": "Gotamī ca ahañceva,"
    },
    {
      "id": "thi-ap23:22.4",
      "pali": "visākhā hoti sattamī."
    },
    {
      "id": "thi-ap23:23.1",
      "pali": "Tehi kammehi sukatehi,"
    },
    {
      "id": "thi-ap23:23.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap23:23.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap23:23.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap23:24.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap23:24.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "thi-ap23:24.3",
      "pali": "Jātā seṭṭhikule phīte,"
    },
    {
      "id": "thi-ap23:24.4",
      "pali": "sabbakāmasamiddhine."
    },
    {
      "id": "thi-ap23:25.1",
      "pali": "Yadā rūpaguṇūpetā,"
    },
    {
      "id": "thi-ap23:25.2",
      "pali": "paṭhame yobbane ṭhitā;"
    },
    {
      "id": "thi-ap23:25.3",
      "pali": "Tadā parakulaṁ gantvā,"
    },
    {
      "id": "thi-ap23:25.4",
      "pali": "vasiṁ sukhasamappitā."
    },
    {
      "id": "thi-ap23:26.1",
      "pali": "Upetvā lokasaraṇaṁ,"
    },
    {
      "id": "thi-ap23:26.2",
      "pali": "suṇitvā dhammadesanaṁ;"
    },
    {
      "id": "thi-ap23:26.3",
      "pali": "Anāgāmiphalaṁ patto,"
    },
    {
      "id": "thi-ap23:26.4",
      "pali": "sāmiko me subuddhimā."
    },
    {
      "id": "thi-ap23:27.1",
      "pali": "Tadāhaṁ anujānetvā,"
    },
    {
      "id": "thi-ap23:27.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap23:27.3",
      "pali": "Na cireneva kālena,"
    },
    {
      "id": "thi-ap23:27.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap23:28.1",
      "pali": "Tadā upāsako so maṁ,"
    },
    {
      "id": "thi-ap23:28.2",
      "pali": "upagantvā apucchatha;"
    },
    {
      "id": "thi-ap23:28.3",
      "pali": "Gambhīre nipuṇe pañhe,"
    },
    {
      "id": "thi-ap23:28.4",
      "pali": "te sabbe byākariṁ ahaṁ."
    },
    {
      "id": "thi-ap23:29.1",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "thi-ap23:29.2",
      "pali": "etadagge ṭhapesi maṁ;"
    },
    {
      "id": "thi-ap23:29.3",
      "pali": "‘Bhikkhuniṁ dhammakathikaṁ,"
    },
    {
      "id": "thi-ap23:29.4",
      "pali": "nāññaṁ passāmi edisiṁ."
    },
    {
      "id": "thi-ap23:30.1",
      "pali": "Dhammadinnā yathā dhīrā,"
    },
    {
      "id": "thi-ap23:30.2",
      "pali": "evaṁ dhāretha bhikkhavo’;"
    },
    {
      "id": "thi-ap23:30.3",
      "pali": "Evāhaṁ paṇḍitā homi,"
    },
    {
      "id": "thi-ap23:30.4",
      "pali": "nāyakenānukampitā."
    },
    {
      "id": "thi-ap23:31.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thi-ap23:31.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thi-ap23:31.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thi-ap23:31.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thi-ap23:32.1",
      "pali": "Yassatthāya pabbajitā,"
    },
    {
      "id": "thi-ap23:32.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thi-ap23:32.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thi-ap23:32.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thi-ap23:33.1",
      "pali": "Iddhīsu ca vasī homi,"
    },
    {
      "id": "thi-ap23:33.2",
      "pali": "dibbāya sotadhātuyā;"
    },
    {
      "id": "thi-ap23:33.3",
      "pali": "Paracittāni jānāmi,"
    },
    {
      "id": "thi-ap23:33.4",
      "pali": "satthusāsanakārikā."
    },
    {
      "id": "thi-ap23:34.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thi-ap23:34.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thi-ap23:34.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thi-ap23:34.4",
      "pali": "visuddhāsiṁ sunimmalā."
    },
    {
      "id": "thi-ap23:35.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap23:35.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap23:35.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap23:36.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap23:36.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap23:36.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap23:37.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap23:37.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap23:37.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap23:38.1",
      "pali": "Itthaṁ sudaṁ dhammadinnā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap23:39.1",
      "pali": "Dhammadinnātheriyāpadānaṁ tatiyaṁ."
    }
  ]
}
