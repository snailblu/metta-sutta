{
  "uid": "tha-ap70",
  "title": "Ambadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap70:1.1",
      "pali": "“Anomadassī bhagavā,"
    },
    {
      "id": "tha-ap70:1.2",
      "pali": "nisinno pabbatantare;"
    },
    {
      "id": "tha-ap70:1.3",
      "pali": "Mettāya aphari loke,"
    },
    {
      "id": "tha-ap70:1.4",
      "pali": "appamāṇe nirūpadhi."
    },
    {
      "id": "tha-ap70:2.1",
      "pali": "Kapi ahaṁ tadā āsiṁ,"
    },
    {
      "id": "tha-ap70:2.2",
      "pali": "himavante naguttame;"
    },
    {
      "id": "tha-ap70:2.3",
      "pali": "Disvā anomadassiṁ taṁ,"
    },
    {
      "id": "tha-ap70:2.4",
      "pali": "buddhe cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap70:3.1",
      "pali": "Avidūre himavantassa,"
    },
    {
      "id": "tha-ap70:3.2",
      "pali": "ambāsuṁ phalino tadā;"
    },
    {
      "id": "tha-ap70:3.3",
      "pali": "Tato pakkaṁ gahetvāna,"
    },
    {
      "id": "tha-ap70:3.4",
      "pali": "ambaṁ samadhukaṁ adaṁ."
    },
    {
      "id": "tha-ap70:4.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "tha-ap70:4.2",
      "pali": "anomadassī mahāmuni;"
    },
    {
      "id": "tha-ap70:4.3",
      "pali": "Iminā madhudānena,"
    },
    {
      "id": "tha-ap70:4.4",
      "pali": "ambadānena cūbhayaṁ."
    },
    {
      "id": "tha-ap70:5.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap70:5.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap70:5.3",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap70:5.4",
      "pali": "vokiṇṇaṁ saṁsarissati."
    },
    {
      "id": "tha-ap70:6.1",
      "pali": "Khepetvā pāpakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap70:6.2",
      "pali": "paripakkāya buddhiyā;"
    },
    {
      "id": "tha-ap70:6.3",
      "pali": "Vinipātamagantvāna,"
    },
    {
      "id": "tha-ap70:6.4",
      "pali": "kilese jhāpayissati."
    },
    {
      "id": "tha-ap70:7.1",
      "pali": "Damena uttamenāhaṁ,"
    },
    {
      "id": "tha-ap70:7.2",
      "pali": "damitomhi mahesinā;"
    },
    {
      "id": "tha-ap70:7.3",
      "pali": "Pattomhi acalaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap70:7.4",
      "pali": "hitvā jayaparājayaṁ."
    },
    {
      "id": "tha-ap70:8.1",
      "pali": "Sattasattatikappasate,"
    },
    {
      "id": "tha-ap70:8.2",
      "pali": "ambaṭṭhajasanāmakā;"
    },
    {
      "id": "tha-ap70:8.3",
      "pali": "Catuddasa te rājāno,"
    },
    {
      "id": "tha-ap70:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap70:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap70:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap70:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap70:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap70:11.1",
      "pali": "Ambadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
