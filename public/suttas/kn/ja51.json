{
  "uid": "ja51",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja51:1.1",
      "pali": "“Āsīsetheva puriso,"
    },
    {
      "id": "ja51:1.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja51:1.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja51:1.4",
      "pali": "yathā icchiṁ tathā ahū”ti."
    },
    {
      "id": "ja51:2.1",
      "pali": "Mahāsīlavajātakaṁ paṭhamaṁ."
    }
  ]
}
