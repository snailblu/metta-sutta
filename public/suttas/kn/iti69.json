{
  "uid": "iti69",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti69:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti69:2.1",
      "pali": "“Yassa kassaci, bhikkhave, bhikkhussa vā bhikkhuniyā vā rāgo appahīno, doso appahīno, moho appahīno—"
    },
    {
      "id": "iti69:2.2",
      "pali": "ayaṁ vuccati, bhikkhave, ‘atiṇṇo samuddaṁ saūmiṁ savīciṁ sāvaṭṭaṁ sagahaṁ sarakkhasaṁ’."
    },
    {
      "id": "iti69:2.3",
      "pali": "Yassa kassaci, bhikkhave, bhikkhussa vā bhikkhuniyā vā rāgo pahīno, doso pahīno, moho pahīno—"
    },
    {
      "id": "iti69:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, ‘atari samuddaṁ saūmiṁ savīciṁ sāvaṭṭaṁ sagahaṁ sarakkhasaṁ, tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo’”ti."
    },
    {
      "id": "iti69:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti69:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti69:3.1",
      "pali": "“Yassa rāgo ca doso ca,"
    },
    {
      "id": "iti69:3.2",
      "pali": "Avijjā ca virājitā;"
    },
    {
      "id": "iti69:3.3",
      "pali": "Somaṁ samuddaṁ sagahaṁ sarakkhasaṁ,"
    },
    {
      "id": "iti69:3.4",
      "pali": "Saūmibhayaṁ duttaraṁ accatāri."
    },
    {
      "id": "iti69:4.1",
      "pali": "Saṅgātigo maccujaho nirūpadhi,"
    },
    {
      "id": "iti69:4.2",
      "pali": "Pahāsi dukkhaṁ apunabbhavāya;"
    },
    {
      "id": "iti69:4.3",
      "pali": "Atthaṅgato so na pamāṇameti,"
    },
    {
      "id": "iti69:4.4",
      "pali": "Amohayi maccurājanti brūmī”ti."
    },
    {
      "id": "iti69:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti69:5.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti69:5.3",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "iti69:6.1",
      "pali": "Puññaṁ cakkhu atha indriyāni,"
    },
    {
      "id": "iti69:6.2",
      "pali": "Addhā ca caritaṁ duve soci;"
    },
    {
      "id": "iti69:6.3",
      "pali": "Muno atha rāgaduve,"
    },
    {
      "id": "iti69:6.4",
      "pali": "Puna vaggamāhu dutiyamuttamanti."
    }
  ]
}
