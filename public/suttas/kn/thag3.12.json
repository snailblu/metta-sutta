{
  "uid": "thag3.12",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.12:1.1",
      "pali": "“Paṇḍitaṁ vata maṁ santaṁ,"
    },
    {
      "id": "thag3.12:1.2",
      "pali": "alamatthavicintakaṁ;"
    },
    {
      "id": "thag3.12:1.3",
      "pali": "Pañca kāmaguṇā loke,"
    },
    {
      "id": "thag3.12:1.4",
      "pali": "sammohā pātayiṁsu maṁ."
    },
    {
      "id": "thag3.12:2.1",
      "pali": "Pakkhando māravisaye,"
    },
    {
      "id": "thag3.12:2.2",
      "pali": "daḷhasallasamappito;"
    },
    {
      "id": "thag3.12:2.3",
      "pali": "Asakkhiṁ maccurājassa,"
    },
    {
      "id": "thag3.12:2.4",
      "pali": "ahaṁ pāsā pamuccituṁ."
    },
    {
      "id": "thag3.12:3.1",
      "pali": "Sabbe kāmā pahīnā me,"
    },
    {
      "id": "thag3.12:3.2",
      "pali": "bhavā sabbe padālitā;"
    },
    {
      "id": "thag3.12:3.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag3.12:3.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag3.12:3.5",
      "pali": "… Uttarapālo thero …."
    }
  ]
}
