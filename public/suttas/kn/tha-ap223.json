{
  "uid": "tha-ap223",
  "title": "1 Ālambaṇadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap223:1.1",
      "pali": "“Atthadassissa bhagavato,"
    },
    {
      "id": "tha-ap223:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap223:1.3",
      "pali": "Ālambaṇaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap223:1.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap223:2.1",
      "pali": "Dharaṇiṁ paṭipajjāmi,"
    },
    {
      "id": "tha-ap223:2.2",
      "pali": "vipulaṁ sāgarapparaṁ;"
    },
    {
      "id": "tha-ap223:2.3",
      "pali": "Pāṇesu ca issariyaṁ,"
    },
    {
      "id": "tha-ap223:2.4",
      "pali": "vattemi vasudhāya ca."
    },
    {
      "id": "tha-ap223:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap223:3.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap223:3.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap223:3.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap223:4.1",
      "pali": "Ito dvesaṭṭhikappamhi,"
    },
    {
      "id": "tha-ap223:4.2",
      "pali": "tayo āsiṁsu khattiyā;"
    },
    {
      "id": "tha-ap223:4.3",
      "pali": "Ekāpassitanāmā te,"
    },
    {
      "id": "tha-ap223:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap223:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap223:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap223:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap223:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap223:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ālambaṇadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap223:7.1",
      "pali": "Ālambaṇadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
