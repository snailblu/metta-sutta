{
  "uid": "tha-ap557",
  "title": "Vajjīputtattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap557:1.1",
      "pali": "“Sahassaraṁsī bhagavā,"
    },
    {
      "id": "tha-ap557:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap557:1.3",
      "pali": "Vivekā vuṭṭhahitvāna,"
    },
    {
      "id": "tha-ap557:1.4",
      "pali": "gocarāyābhinikkhami."
    },
    {
      "id": "tha-ap557:2.1",
      "pali": "Phalahattho ahaṁ disvā,"
    },
    {
      "id": "tha-ap557:2.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap557:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap557:2.4",
      "pali": "savaṇṭaṁ adadiṁ phalaṁ."
    },
    {
      "id": "tha-ap557:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap557:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap557:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap557:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap557:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap557:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap557:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap557:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap557:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap557:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap557:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap557:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap557:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap557:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā vajjīputto thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap557:8.1",
      "pali": "Vajjīputtattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
