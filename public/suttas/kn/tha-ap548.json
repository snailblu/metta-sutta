{
  "uid": "tha-ap548",
  "title": "Kāḷudāyittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap548:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap548:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "tha-ap548:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap548:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "tha-ap548:2.1",
      "pali": "Nāyakānaṁ varo satthā,"
    },
    {
      "id": "tha-ap548:2.2",
      "pali": "guṇāguṇavidū jino;"
    },
    {
      "id": "tha-ap548:2.3",
      "pali": "Kataññū katavedī ca,"
    },
    {
      "id": "tha-ap548:2.4",
      "pali": "titthe yojeti pāṇine."
    },
    {
      "id": "tha-ap548:3.1",
      "pali": "Sabbaññutena ñāṇena,"
    },
    {
      "id": "tha-ap548:3.2",
      "pali": "tulayitvā dayāsayo;"
    },
    {
      "id": "tha-ap548:3.3",
      "pali": "Deseti pavaraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap548:3.4",
      "pali": "anantaguṇasañcayo."
    },
    {
      "id": "tha-ap548:4.1",
      "pali": "Sa kadāci mahāvīro,"
    },
    {
      "id": "tha-ap548:4.2",
      "pali": "anantajinasaṁsari;"
    },
    {
      "id": "tha-ap548:4.3",
      "pali": "Deseti madhuraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap548:4.4",
      "pali": "catusaccūpasañhitaṁ."
    },
    {
      "id": "tha-ap548:5.1",
      "pali": "Sutvāna taṁ dhammavaraṁ,"
    },
    {
      "id": "tha-ap548:5.2",
      "pali": "ādimajjhantasobhanaṁ;"
    },
    {
      "id": "tha-ap548:5.3",
      "pali": "Pāṇasatasahassānaṁ,"
    },
    {
      "id": "tha-ap548:5.4",
      "pali": "dhammābhisamayo ahu."
    },
    {
      "id": "tha-ap548:6.1",
      "pali": "Ninnāditā tadā bhūmi,"
    },
    {
      "id": "tha-ap548:6.2",
      "pali": "gajjiṁsu ca payodharā;"
    },
    {
      "id": "tha-ap548:6.3",
      "pali": "Sādhukāraṁ pavattiṁsu,"
    },
    {
      "id": "tha-ap548:6.4",
      "pali": "devabrahmanarāsurā."
    },
    {
      "id": "tha-ap548:7.1",
      "pali": "‘Aho kāruṇiko satthā,"
    },
    {
      "id": "tha-ap548:7.2",
      "pali": "aho saddhammadesanā;"
    },
    {
      "id": "tha-ap548:7.3",
      "pali": "Aho bhavasamuddamhi,"
    },
    {
      "id": "tha-ap548:7.4",
      "pali": "nimugge uddharī jino’."
    },
    {
      "id": "tha-ap548:8.1",
      "pali": "Evaṁ pavedajātesu,"
    },
    {
      "id": "tha-ap548:8.2",
      "pali": "sanarāmarabrahmasu;"
    },
    {
      "id": "tha-ap548:8.3",
      "pali": "Kulappasādakānaggaṁ,"
    },
    {
      "id": "tha-ap548:8.4",
      "pali": "sāvakaṁ vaṇṇayī jino."
    },
    {
      "id": "tha-ap548:9.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap548:9.2",
      "pali": "jātomaccakule ahuṁ;"
    },
    {
      "id": "tha-ap548:9.3",
      "pali": "Pāsādiko dassaniyo,"
    },
    {
      "id": "tha-ap548:9.4",
      "pali": "pahūtadhanadhaññavā."
    },
    {
      "id": "tha-ap548:10.1",
      "pali": "Haṁsārāmamupeccāhaṁ,"
    },
    {
      "id": "tha-ap548:10.2",
      "pali": "vanditvā taṁ tathāgataṁ;"
    },
    {
      "id": "tha-ap548:10.3",
      "pali": "Suṇitvā madhuraṁ dhammaṁ,"
    },
    {
      "id": "tha-ap548:10.4",
      "pali": "kāraṁ katvā ca tādino."
    },
    {
      "id": "tha-ap548:11.1",
      "pali": "Nipacca pādamūlehaṁ,"
    },
    {
      "id": "tha-ap548:11.2",
      "pali": "imaṁ vacanamabraviṁ;"
    },
    {
      "id": "tha-ap548:11.3",
      "pali": "‘Kulappasādakānaggo,"
    },
    {
      "id": "tha-ap548:11.4",
      "pali": "yo tayā santhuto mune."
    },
    {
      "id": "tha-ap548:12.1",
      "pali": "Tādiso homahaṁ vīra,"
    },
    {
      "id": "tha-ap548:12.2",
      "pali": "buddhaseṭṭhassa sāsane’;"
    },
    {
      "id": "tha-ap548:12.3",
      "pali": "Tadā mahākāruṇiko,"
    },
    {
      "id": "tha-ap548:12.4",
      "pali": "siñcanto vāmatena maṁ."
    },
    {
      "id": "tha-ap548:13.1",
      "pali": "Āha maṁ ‘putta uttiṭṭha,"
    },
    {
      "id": "tha-ap548:13.2",
      "pali": "lacchase taṁ manorathaṁ;"
    },
    {
      "id": "tha-ap548:13.3",
      "pali": "Kathaṁ nāma jine kāraṁ,"
    },
    {
      "id": "tha-ap548:13.4",
      "pali": "katvāna viphalo siyā."
    },
    {
      "id": "tha-ap548:14.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap548:14.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap548:14.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap548:14.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap548:15.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap548:15.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap548:15.3",
      "pali": "Udāyi nāma nāmena,"
    },
    {
      "id": "tha-ap548:15.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap548:16.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "tha-ap548:16.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "tha-ap548:16.3",
      "pali": "Mettacitto paricariṁ,"
    },
    {
      "id": "tha-ap548:16.4",
      "pali": "paccayehi vināyakaṁ."
    },
    {
      "id": "tha-ap548:17.1",
      "pali": "Tena kammavipākena,"
    },
    {
      "id": "tha-ap548:17.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap548:17.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap548:17.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap548:18.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap548:18.2",
      "pali": "ramme kapilavatthave;"
    },
    {
      "id": "tha-ap548:18.3",
      "pali": "Jāto mahāmaccakule,"
    },
    {
      "id": "tha-ap548:18.4",
      "pali": "suddhodanamahīpate."
    },
    {
      "id": "tha-ap548:19.1",
      "pali": "Tadā ajāyi siddhattho,"
    },
    {
      "id": "tha-ap548:19.2",
      "pali": "ramme lumbinikānane;"
    },
    {
      "id": "tha-ap548:19.3",
      "pali": "Hitāya sabbalokassa,"
    },
    {
      "id": "tha-ap548:19.4",
      "pali": "sukhāya ca narāsabho."
    },
    {
      "id": "tha-ap548:20.1",
      "pali": "Tadaheva ahaṁ jāto,"
    },
    {
      "id": "tha-ap548:20.2",
      "pali": "saha teneva vaḍḍhito;"
    },
    {
      "id": "tha-ap548:20.3",
      "pali": "Piyo sahāyo dayito,"
    },
    {
      "id": "tha-ap548:20.4",
      "pali": "viyatto nītikovido."
    },
    {
      "id": "tha-ap548:21.1",
      "pali": "Ekūnatiṁso vayasā,"
    },
    {
      "id": "tha-ap548:21.2",
      "pali": "nikkhamitvā agārato;"
    },
    {
      "id": "tha-ap548:21.3",
      "pali": "Chabbassaṁ vītināmetvā,"
    },
    {
      "id": "tha-ap548:21.4",
      "pali": "āsi buddho vināyako."
    },
    {
      "id": "tha-ap548:22.1",
      "pali": "Jetvā sasenakaṁ māraṁ,"
    },
    {
      "id": "tha-ap548:22.2",
      "pali": "khepayitvāna āsave;"
    },
    {
      "id": "tha-ap548:22.3",
      "pali": "Bhavaṇṇavaṁ taritvāna,"
    },
    {
      "id": "tha-ap548:22.4",
      "pali": "buddho āsi sadevake."
    },
    {
      "id": "tha-ap548:23.1",
      "pali": "Isivhayaṁ gamitvāna,"
    },
    {
      "id": "tha-ap548:23.2",
      "pali": "vinetvā pañcavaggiye;"
    },
    {
      "id": "tha-ap548:23.3",
      "pali": "Tato vinesi bhagavā,"
    },
    {
      "id": "tha-ap548:23.4",
      "pali": "gantvā gantvā tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap548:24.1",
      "pali": "Veneyye vinayanto so,"
    },
    {
      "id": "tha-ap548:24.2",
      "pali": "saṅgaṇhanto sadevakaṁ;"
    },
    {
      "id": "tha-ap548:24.3",
      "pali": "Upecca magadhe giriṁ,"
    },
    {
      "id": "tha-ap548:24.4",
      "pali": "viharittha tadā jino."
    },
    {
      "id": "tha-ap548:25.1",
      "pali": "Tadā suddhodanenāhaṁ,"
    },
    {
      "id": "tha-ap548:25.2",
      "pali": "bhūmipālena pesito;"
    },
    {
      "id": "tha-ap548:25.3",
      "pali": "Gantvā disvā dasabalaṁ,"
    },
    {
      "id": "tha-ap548:25.4",
      "pali": "pabbajitvārahā ahuṁ."
    },
    {
      "id": "tha-ap548:26.1",
      "pali": "Tadā mahesiṁ yācitvā,"
    },
    {
      "id": "tha-ap548:26.2",
      "pali": "pāpayiṁ kapilavhayaṁ;"
    },
    {
      "id": "tha-ap548:26.3",
      "pali": "Tato purāhaṁ gantvāna,"
    },
    {
      "id": "tha-ap548:26.4",
      "pali": "pasādesiṁ mahākulaṁ."
    },
    {
      "id": "tha-ap548:27.1",
      "pali": "Jino tasmiṁ guṇe tuṭṭho,"
    },
    {
      "id": "tha-ap548:27.2",
      "pali": "maṁ mahāparisāya so;"
    },
    {
      "id": "tha-ap548:27.3",
      "pali": "Kulappasādakānaggaṁ,"
    },
    {
      "id": "tha-ap548:27.4",
      "pali": "paññāpesi vināyako."
    },
    {
      "id": "tha-ap548:28.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap548:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap548:28.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap548:29.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap548:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap548:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap548:30.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap548:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap548:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap548:31.1",
      "pali": "Itthaṁ sudaṁ āyasmā kāḷudāyī thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap548:32.1",
      "pali": "Kāḷudāyittherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
