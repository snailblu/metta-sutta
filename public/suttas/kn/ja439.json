{
  "uid": "ja439",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja439:1.1",
      "pali": "“Catudvāramidaṁ nagaraṁ,"
    },
    {
      "id": "ja439:1.2",
      "pali": "āyasaṁ daḷhapākāraṁ;"
    },
    {
      "id": "ja439:1.3",
      "pali": "Oruddhapaṭiruddhosmi,"
    },
    {
      "id": "ja439:1.4",
      "pali": "kiṁ pāpaṁ pakataṁ mayā”."
    },
    {
      "id": "ja439:2.1",
      "pali": "“Sabbe apihitā dvārā,"
    },
    {
      "id": "ja439:2.2",
      "pali": "oruddhosmi yathā dijo;"
    },
    {
      "id": "ja439:2.3",
      "pali": "Kimādhikaraṇaṁ yakkha,"
    },
    {
      "id": "ja439:2.4",
      "pali": "cakkābhinihato ahaṁ."
    },
    {
      "id": "ja439:3.1",
      "pali": "Laddhā satasahassāni,"
    },
    {
      "id": "ja439:3.2",
      "pali": "atirekāni vīsati;"
    },
    {
      "id": "ja439:3.3",
      "pali": "Anukampakānaṁ ñātīnaṁ,"
    },
    {
      "id": "ja439:3.4",
      "pali": "vacanaṁ samma nākari."
    },
    {
      "id": "ja439:4.1",
      "pali": "Laṅghiṁ samuddaṁ pakkhandi,"
    },
    {
      "id": "ja439:4.2",
      "pali": "sāgaraṁ appasiddhikaṁ;"
    },
    {
      "id": "ja439:4.3",
      "pali": "Catubbhi aṭṭhajjhagamā,"
    },
    {
      "id": "ja439:4.4",
      "pali": "aṭṭhāhipi ca soḷasa."
    },
    {
      "id": "ja439:5.1",
      "pali": "Soḷasāhi ca bāttiṁsa,"
    },
    {
      "id": "ja439:5.2",
      "pali": "atricchaṁ cakkamāsado;"
    },
    {
      "id": "ja439:5.3",
      "pali": "Icchāhatassa posassa,"
    },
    {
      "id": "ja439:5.4",
      "pali": "cakkaṁ bhamati matthake."
    },
    {
      "id": "ja439:6.1",
      "pali": "Uparivisālā duppūrā,"
    },
    {
      "id": "ja439:6.2",
      "pali": "icchā visaṭagāminī;"
    },
    {
      "id": "ja439:6.3",
      "pali": "Ye ca taṁ anugijjhanti,"
    },
    {
      "id": "ja439:6.4",
      "pali": "te honti cakkadhārino."
    },
    {
      "id": "ja439:7.1",
      "pali": "Bahubhaṇḍaṁ avahāya,"
    },
    {
      "id": "ja439:7.2",
      "pali": "maggaṁ appaṭivekkhiya;"
    },
    {
      "id": "ja439:7.3",
      "pali": "Yesañcetaṁ asaṅkhātaṁ,"
    },
    {
      "id": "ja439:7.4",
      "pali": "te honti cakkadhārino."
    },
    {
      "id": "ja439:8.1",
      "pali": "Kammaṁ samekkhe vipulañca bhogaṁ,"
    },
    {
      "id": "ja439:8.2",
      "pali": "Icchaṁ na seveyya anatthasaṁhitaṁ;"
    },
    {
      "id": "ja439:8.3",
      "pali": "Kareyya vākyaṁ anukampakānaṁ,"
    },
    {
      "id": "ja439:8.4",
      "pali": "Taṁ tādisaṁ nātivatteyya cakkaṁ”."
    },
    {
      "id": "ja439:9.1",
      "pali": "“Kīvaciraṁ nu me yakkha,"
    },
    {
      "id": "ja439:9.2",
      "pali": "cakkaṁ sirasi ṭhassati;"
    },
    {
      "id": "ja439:9.3",
      "pali": "Kati vassasahassāni,"
    },
    {
      "id": "ja439:9.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja439:10.1",
      "pali": "“Atisaro paccasaro,"
    },
    {
      "id": "ja439:10.2",
      "pali": "mittavinda suṇohi me;"
    },
    {
      "id": "ja439:10.3",
      "pali": "Cakkaṁ te sirasi māviddhaṁ,"
    },
    {
      "id": "ja439:10.4",
      "pali": "na taṁ jīvaṁ pamokkhasī”ti."
    },
    {
      "id": "ja439:11.1",
      "pali": "Catudvārajātakaṁ paṭhamaṁ."
    }
  ]
}
