{
  "uid": "ja416",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja416:1.1",
      "pali": "“Āgamissati me pāpaṁ,"
    },
    {
      "id": "ja416:1.2",
      "pali": "āgamissati me bhayaṁ;"
    },
    {
      "id": "ja416:1.3",
      "pali": "Tadā hi calitā sākhā,"
    },
    {
      "id": "ja416:1.4",
      "pali": "manussena migena vā”."
    },
    {
      "id": "ja416:2.1",
      "pali": "“Bhīruyā nūna me kāmo,"
    },
    {
      "id": "ja416:2.2",
      "pali": "avidūre vasantiyā;"
    },
    {
      "id": "ja416:2.3",
      "pali": "Karissati kisaṁ paṇḍuṁ,"
    },
    {
      "id": "ja416:2.4",
      "pali": "sāva sākhā parantapaṁ."
    },
    {
      "id": "ja416:3.1",
      "pali": "Socayissati maṁ kantā,"
    },
    {
      "id": "ja416:3.2",
      "pali": "gāme vasamaninditā;"
    },
    {
      "id": "ja416:3.3",
      "pali": "Karissati kisaṁ paṇḍuṁ,"
    },
    {
      "id": "ja416:3.4",
      "pali": "sāva sākhā parantapaṁ."
    },
    {
      "id": "ja416:4.1",
      "pali": "Tayā maṁ asitāpaṅgi,"
    },
    {
      "id": "ja416:4.2",
      "pali": "sitāni bhaṇitāni ca;"
    },
    {
      "id": "ja416:4.3",
      "pali": "Kisaṁ paṇḍuṁ karissanti,"
    },
    {
      "id": "ja416:4.4",
      "pali": "sāva sākhā parantapaṁ”."
    },
    {
      "id": "ja416:5.1",
      "pali": "“Agamā nūna so saddo,"
    },
    {
      "id": "ja416:5.2",
      "pali": "asaṁsi nūna so tava;"
    },
    {
      "id": "ja416:5.3",
      "pali": "Akkhātaṁ nūna taṁ tena,"
    },
    {
      "id": "ja416:5.4",
      "pali": "yo taṁ sākhamakampayi."
    },
    {
      "id": "ja416:6.1",
      "pali": "Idaṁ kho taṁ samāgamma,"
    },
    {
      "id": "ja416:6.2",
      "pali": "mama bālassa cintitaṁ;"
    },
    {
      "id": "ja416:6.3",
      "pali": "Tadā hi calitā sākhā,"
    },
    {
      "id": "ja416:6.4",
      "pali": "manussena migena vā”."
    },
    {
      "id": "ja416:7.1",
      "pali": "“Tatheva tvaṁ avedesi,"
    },
    {
      "id": "ja416:7.2",
      "pali": "Avañci pitaraṁ mama;"
    },
    {
      "id": "ja416:7.3",
      "pali": "Hantvā sākhāhi chādento,"
    },
    {
      "id": "ja416:7.4",
      "pali": "Āgamissati me bhayan”ti."
    },
    {
      "id": "ja416:8.1",
      "pali": "Parantapajātakaṁ ekādasamaṁ."
    },
    {
      "id": "ja416:8.2",
      "pali": "Gandhāravaggo dutiyo."
    },
    {
      "id": "ja416:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja416:10.1",
      "pali": "Varagāma mahākapi bhaggava ca,"
    },
    {
      "id": "ja416:10.2",
      "pali": "Daḷhadhamma sakuñjara kesavaro;"
    },
    {
      "id": "ja416:10.3",
      "pali": "Urago vidhuro puna jāgarataṁ,"
    },
    {
      "id": "ja416:10.4",
      "pali": "Atha kosalādhipa parantapa cāti."
    },
    {
      "id": "ja416:11.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja416:12.1",
      "pali": "Atha sattanipātamhi,"
    },
    {
      "id": "ja416:12.2",
      "pali": "vaggaṁ me bhaṇato suṇa;"
    },
    {
      "id": "ja416:12.3",
      "pali": "Kukku ca puna gandhāro,"
    },
    {
      "id": "ja416:12.4",
      "pali": "dveva vuttā mahesināti."
    },
    {
      "id": "ja416:13.1",
      "pali": "Sattakanipātaṁ niṭṭhitaṁ."
    }
  ]
}
