{
  "uid": "thag16.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.2:1.1",
      "pali": "“Samaṇassa ahu cintā,"
    },
    {
      "id": "thag16.2:1.2",
      "pali": "pārāpariyassa bhikkhuno;"
    },
    {
      "id": "thag16.2:1.3",
      "pali": "Ekakassa nisinnassa,"
    },
    {
      "id": "thag16.2:1.4",
      "pali": "pavivittassa jhāyino."
    },
    {
      "id": "thag16.2:2.1",
      "pali": "Kimānupubbaṁ puriso,"
    },
    {
      "id": "thag16.2:2.2",
      "pali": "kiṁ vataṁ kiṁ samācāraṁ;"
    },
    {
      "id": "thag16.2:2.3",
      "pali": "Attano kiccakārīssa,"
    },
    {
      "id": "thag16.2:2.4",
      "pali": "na ca kañci viheṭhaye."
    },
    {
      "id": "thag16.2:3.1",
      "pali": "Indriyāni manussānaṁ,"
    },
    {
      "id": "thag16.2:3.2",
      "pali": "hitāya ahitāya ca;"
    },
    {
      "id": "thag16.2:3.3",
      "pali": "Arakkhitāni ahitāya,"
    },
    {
      "id": "thag16.2:3.4",
      "pali": "rakkhitāni hitāya ca."
    },
    {
      "id": "thag16.2:4.1",
      "pali": "Indriyāneva sārakkhaṁ,"
    },
    {
      "id": "thag16.2:4.2",
      "pali": "indriyāni ca gopayaṁ;"
    },
    {
      "id": "thag16.2:4.3",
      "pali": "Attano kiccakārīssa,"
    },
    {
      "id": "thag16.2:4.4",
      "pali": "na ca kañci viheṭhaye."
    },
    {
      "id": "thag16.2:5.1",
      "pali": "Cakkhundriyañce rūpesu,"
    },
    {
      "id": "thag16.2:5.2",
      "pali": "gacchantaṁ anivārayaṁ;"
    },
    {
      "id": "thag16.2:5.3",
      "pali": "Anādīnavadassāvī,"
    },
    {
      "id": "thag16.2:5.4",
      "pali": "so dukkhā na hi muccati."
    },
    {
      "id": "thag16.2:6.1",
      "pali": "Sotindriyañce saddesu,"
    },
    {
      "id": "thag16.2:6.2",
      "pali": "gacchantaṁ anivārayaṁ;"
    },
    {
      "id": "thag16.2:6.3",
      "pali": "Anādīnavadassāvī,"
    },
    {
      "id": "thag16.2:6.4",
      "pali": "so dukkhā na hi muccati."
    },
    {
      "id": "thag16.2:7.1",
      "pali": "Anissaraṇadassāvī,"
    },
    {
      "id": "thag16.2:7.2",
      "pali": "gandhe ce paṭisevati;"
    },
    {
      "id": "thag16.2:7.3",
      "pali": "Na so muccati dukkhamhā,"
    },
    {
      "id": "thag16.2:7.4",
      "pali": "gandhesu adhimucchito."
    },
    {
      "id": "thag16.2:8.1",
      "pali": "Ambilaṁ madhuraggañca,"
    },
    {
      "id": "thag16.2:8.2",
      "pali": "tittakaggamanussaraṁ;"
    },
    {
      "id": "thag16.2:8.3",
      "pali": "Rasataṇhāya gadhito,"
    },
    {
      "id": "thag16.2:8.4",
      "pali": "hadayaṁ nāvabujjhati."
    },
    {
      "id": "thag16.2:9.1",
      "pali": "Subhānyappaṭikūlāni,"
    },
    {
      "id": "thag16.2:9.2",
      "pali": "phoṭṭhabbāni anussaraṁ;"
    },
    {
      "id": "thag16.2:9.3",
      "pali": "Ratto rāgādhikaraṇaṁ,"
    },
    {
      "id": "thag16.2:9.4",
      "pali": "vividhaṁ vindate dukhaṁ."
    },
    {
      "id": "thag16.2:10.1",
      "pali": "Manaṁ cetehi dhammehi,"
    },
    {
      "id": "thag16.2:10.2",
      "pali": "yo na sakkoti rakkhituṁ;"
    },
    {
      "id": "thag16.2:10.3",
      "pali": "Tato naṁ dukkhamanveti,"
    },
    {
      "id": "thag16.2:10.4",
      "pali": "sabbehetehi pañcahi."
    },
    {
      "id": "thag16.2:11.1",
      "pali": "Pubbalohitasampuṇṇaṁ,"
    },
    {
      "id": "thag16.2:11.2",
      "pali": "bahussa kuṇapassa ca;"
    },
    {
      "id": "thag16.2:11.3",
      "pali": "Naravīrakataṁ vagguṁ,"
    },
    {
      "id": "thag16.2:11.4",
      "pali": "samuggamiva cittitaṁ."
    },
    {
      "id": "thag16.2:12.1",
      "pali": "Kaṭukaṁ madhurassādaṁ,"
    },
    {
      "id": "thag16.2:12.2",
      "pali": "piyanibandhanaṁ dukhaṁ;"
    },
    {
      "id": "thag16.2:12.3",
      "pali": "Khuraṁva madhunā littaṁ,"
    },
    {
      "id": "thag16.2:12.4",
      "pali": "ullihaṁ nāvabujjhati."
    },
    {
      "id": "thag16.2:13.1",
      "pali": "Itthirūpe itthisare,"
    },
    {
      "id": "thag16.2:13.2",
      "pali": "phoṭṭhabbepi ca itthiyā;"
    },
    {
      "id": "thag16.2:13.3",
      "pali": "Itthigandhesu sāratto,"
    },
    {
      "id": "thag16.2:13.4",
      "pali": "vividhaṁ vindate dukhaṁ."
    },
    {
      "id": "thag16.2:14.1",
      "pali": "Itthisotāni sabbāni,"
    },
    {
      "id": "thag16.2:14.2",
      "pali": "sandanti pañca pañcasu;"
    },
    {
      "id": "thag16.2:14.3",
      "pali": "Tesamāvaraṇaṁ kātuṁ,"
    },
    {
      "id": "thag16.2:14.4",
      "pali": "yo sakkoti vīriyavā."
    },
    {
      "id": "thag16.2:15.1",
      "pali": "So atthavā so dhammaṭṭho,"
    },
    {
      "id": "thag16.2:15.2",
      "pali": "so dakkho so vicakkhaṇo;"
    },
    {
      "id": "thag16.2:15.3",
      "pali": "Kareyya ramamānopi,"
    },
    {
      "id": "thag16.2:15.4",
      "pali": "kiccaṁ dhammatthasaṁhitaṁ."
    },
    {
      "id": "thag16.2:16.1",
      "pali": "Atho sīdati saññuttaṁ,"
    },
    {
      "id": "thag16.2:16.2",
      "pali": "vajje kiccaṁ niratthakaṁ;"
    },
    {
      "id": "thag16.2:16.3",
      "pali": "‘Na taṁ kiccan’ti maññitvā,"
    },
    {
      "id": "thag16.2:16.4",
      "pali": "appamatto vicakkhaṇo."
    },
    {
      "id": "thag16.2:17.1",
      "pali": "Yañca atthena saññuttaṁ,"
    },
    {
      "id": "thag16.2:17.2",
      "pali": "yā ca dhammagatā rati;"
    },
    {
      "id": "thag16.2:17.3",
      "pali": "Taṁ samādāya vattetha,"
    },
    {
      "id": "thag16.2:17.4",
      "pali": "sā hi ve uttamā rati."
    },
    {
      "id": "thag16.2:18.1",
      "pali": "Uccāvacehupāyehi,"
    },
    {
      "id": "thag16.2:18.2",
      "pali": "Paresamabhijigīsati;"
    },
    {
      "id": "thag16.2:18.3",
      "pali": "Hantvā vadhitvā atha socayitvā,"
    },
    {
      "id": "thag16.2:18.4",
      "pali": "Ālopati sāhasā yo paresaṁ."
    },
    {
      "id": "thag16.2:19.1",
      "pali": "Tacchanto āṇiyā āṇiṁ,"
    },
    {
      "id": "thag16.2:19.2",
      "pali": "nihanti balavā yathā;"
    },
    {
      "id": "thag16.2:19.3",
      "pali": "Indriyānindriyeheva,"
    },
    {
      "id": "thag16.2:19.4",
      "pali": "nihanti kusalo tathā."
    },
    {
      "id": "thag16.2:20.1",
      "pali": "Saddhaṁ vīriyaṁ samādhiñca,"
    },
    {
      "id": "thag16.2:20.2",
      "pali": "satipaññañca bhāvayaṁ;"
    },
    {
      "id": "thag16.2:20.3",
      "pali": "Pañca pañcahi hantvāna,"
    },
    {
      "id": "thag16.2:20.4",
      "pali": "anīgho yāti brāhmaṇo."
    },
    {
      "id": "thag16.2:21.1",
      "pali": "So atthavā so dhammaṭṭho,"
    },
    {
      "id": "thag16.2:21.2",
      "pali": "katvā vākyānusāsaniṁ;"
    },
    {
      "id": "thag16.2:21.3",
      "pali": "Sabbena sabbaṁ buddhassa,"
    },
    {
      "id": "thag16.2:21.4",
      "pali": "so naro sukhamedhatī”ti."
    },
    {
      "id": "thag16.2:21.5",
      "pali": "… Pārāpariyo thero …."
    }
  ]
}
