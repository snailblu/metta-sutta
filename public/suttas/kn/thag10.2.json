{
  "uid": "thag10.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag10.2:1.1",
      "pali": "“Purato pacchato vāpi,"
    },
    {
      "id": "thag10.2:1.2",
      "pali": "aparo ce na vijjati;"
    },
    {
      "id": "thag10.2:1.3",
      "pali": "Atīva phāsu bhavati,"
    },
    {
      "id": "thag10.2:1.4",
      "pali": "ekassa vasato vane."
    },
    {
      "id": "thag10.2:2.1",
      "pali": "Handa eko gamissāmi,"
    },
    {
      "id": "thag10.2:2.2",
      "pali": "araññaṁ buddhavaṇṇitaṁ;"
    },
    {
      "id": "thag10.2:2.3",
      "pali": "Phāsu ekavihārissa,"
    },
    {
      "id": "thag10.2:2.4",
      "pali": "pahitattassa bhikkhuno."
    },
    {
      "id": "thag10.2:3.1",
      "pali": "Yogi-pītikaraṁ rammaṁ,"
    },
    {
      "id": "thag10.2:3.2",
      "pali": "mattakuñjarasevitaṁ;"
    },
    {
      "id": "thag10.2:3.3",
      "pali": "Eko attavasī khippaṁ,"
    },
    {
      "id": "thag10.2:3.4",
      "pali": "pavisissāmi kānanaṁ."
    },
    {
      "id": "thag10.2:4.1",
      "pali": "Supupphite sītavane,"
    },
    {
      "id": "thag10.2:4.2",
      "pali": "sītale girikandare;"
    },
    {
      "id": "thag10.2:4.3",
      "pali": "Gattāni parisiñcitvā,"
    },
    {
      "id": "thag10.2:4.4",
      "pali": "caṅkamissāmi ekako."
    },
    {
      "id": "thag10.2:5.1",
      "pali": "Ekākiyo adutiyo,"
    },
    {
      "id": "thag10.2:5.2",
      "pali": "ramaṇīye mahāvane;"
    },
    {
      "id": "thag10.2:5.3",
      "pali": "Kadāhaṁ viharissāmi,"
    },
    {
      "id": "thag10.2:5.4",
      "pali": "katakicco anāsavo."
    },
    {
      "id": "thag10.2:6.1",
      "pali": "Evaṁ me kattukāmassa,"
    },
    {
      "id": "thag10.2:6.2",
      "pali": "adhippāyo samijjhatu;"
    },
    {
      "id": "thag10.2:6.3",
      "pali": "Sādhayissāmahaṁyeva,"
    },
    {
      "id": "thag10.2:6.4",
      "pali": "nāñño aññassa kārako."
    },
    {
      "id": "thag10.2:7.1",
      "pali": "Esa bandhāmi sannāhaṁ,"
    },
    {
      "id": "thag10.2:7.2",
      "pali": "pavisissāmi kānanaṁ;"
    },
    {
      "id": "thag10.2:7.3",
      "pali": "Na tato nikkhamissāmi,"
    },
    {
      "id": "thag10.2:7.4",
      "pali": "appatto āsavakkhayaṁ."
    },
    {
      "id": "thag10.2:8.1",
      "pali": "Mālute upavāyante,"
    },
    {
      "id": "thag10.2:8.2",
      "pali": "sīte surabhigandhike;"
    },
    {
      "id": "thag10.2:8.3",
      "pali": "Avijjaṁ dālayissāmi,"
    },
    {
      "id": "thag10.2:8.4",
      "pali": "nisinno nagamuddhani."
    },
    {
      "id": "thag10.2:9.1",
      "pali": "Vane kusumasañchanne,"
    },
    {
      "id": "thag10.2:9.2",
      "pali": "pabbhāre nūna sītale;"
    },
    {
      "id": "thag10.2:9.3",
      "pali": "Vimuttisukhena sukhito,"
    },
    {
      "id": "thag10.2:9.4",
      "pali": "ramissāmi giribbaje."
    },
    {
      "id": "thag10.2:10.1",
      "pali": "Sohaṁ paripuṇṇasaṅkappo,"
    },
    {
      "id": "thag10.2:10.2",
      "pali": "cando pannaraso yathā;"
    },
    {
      "id": "thag10.2:10.3",
      "pali": "Sabbāsavaparikkhīṇo,"
    },
    {
      "id": "thag10.2:10.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag10.2:10.5",
      "pali": "… Ekavihāriyo thero …."
    }
  ]
}
