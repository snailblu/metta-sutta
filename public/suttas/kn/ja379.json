{
  "uid": "ja379",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja379:1.1",
      "pali": "“Kākolā kākasaṅghā ca,"
    },
    {
      "id": "ja379:1.2",
      "pali": "mayañca patataṁ varā;"
    },
    {
      "id": "ja379:1.3",
      "pali": "Sabbeva sadisā homa,"
    },
    {
      "id": "ja379:1.4",
      "pali": "imaṁ āgamma pabbataṁ."
    },
    {
      "id": "ja379:2.1",
      "pali": "Idha sīhā ca byagghā ca,"
    },
    {
      "id": "ja379:2.2",
      "pali": "siṅgālā ca migādhamā;"
    },
    {
      "id": "ja379:2.3",
      "pali": "Sabbeva sadisā honti,"
    },
    {
      "id": "ja379:2.4",
      "pali": "ayaṁ ko nāma pabbato”."
    },
    {
      "id": "ja379:3.1",
      "pali": "“Imaṁ nerūti jānanti,"
    },
    {
      "id": "ja379:3.2",
      "pali": "manussā pabbatuttamaṁ;"
    },
    {
      "id": "ja379:3.3",
      "pali": "Idha vaṇṇena sampannā,"
    },
    {
      "id": "ja379:3.4",
      "pali": "vasanti sabbapāṇino”."
    },
    {
      "id": "ja379:4.1",
      "pali": "“Amānanā yattha siyā,"
    },
    {
      "id": "ja379:4.2",
      "pali": "santānaṁ vā vimānanā;"
    },
    {
      "id": "ja379:4.3",
      "pali": "Hīnasammānanā vāpi,"
    },
    {
      "id": "ja379:4.4",
      "pali": "na tattha vasatiṁ vase."
    },
    {
      "id": "ja379:5.1",
      "pali": "Yatthālaso ca dakkho ca,"
    },
    {
      "id": "ja379:5.2",
      "pali": "sūro bhīru ca pūjiyā;"
    },
    {
      "id": "ja379:5.3",
      "pali": "Na tattha santo vasanti,"
    },
    {
      "id": "ja379:5.4",
      "pali": "avisesakare nare."
    },
    {
      "id": "ja379:6.1",
      "pali": "Nāyaṁ neru vibhajati,"
    },
    {
      "id": "ja379:6.2",
      "pali": "hīnaukkaṭṭhamajjhime;"
    },
    {
      "id": "ja379:6.3",
      "pali": "Avisesakaro neru,"
    },
    {
      "id": "ja379:6.4",
      "pali": "handa neruṁ jahāmase”ti."
    },
    {
      "id": "ja379:7.1",
      "pali": "Nerujātakaṁ catutthaṁ."
    }
  ]
}
