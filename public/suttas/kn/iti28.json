{
  "uid": "iti28",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti28:1.1",
      "pali": "(…) Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti28:2.1",
      "pali": "“Dvīhi, bhikkhave, dhammehi samannāgato bhikkhu diṭṭheva dhamme dukkhaṁ viharati savighātaṁ saupāyāsaṁ sapariḷāhaṁ;"
    },
    {
      "id": "iti28:2.2",
      "pali": "kāyassa bhedā paraṁ maraṇā duggati pāṭikaṅkhā."
    },
    {
      "id": "iti28:2.3",
      "pali": "Katamehi dvīhi?"
    },
    {
      "id": "iti28:2.4",
      "pali": "Indriyesu aguttadvāratāya ca, bhojane amattaññutāya ca."
    },
    {
      "id": "iti28:2.5",
      "pali": "Imehi kho, bhikkhave, dvīhi dhammehi samannāgato bhikkhu diṭṭheva dhamme dukkhaṁ viharati savighātaṁ saupāyāsaṁ sapariḷāhaṁ;"
    },
    {
      "id": "iti28:2.6",
      "pali": "kāyassa bhedā paraṁ maraṇā duggati pāṭikaṅkhā”ti."
    },
    {
      "id": "iti28:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti28:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti28:3.1",
      "pali": "“Cakkhu sotañca ghānañca,"
    },
    {
      "id": "iti28:3.2",
      "pali": "jivhā kāyo tathā mano;"
    },
    {
      "id": "iti28:3.3",
      "pali": "Etāni yassa dvārāni,"
    },
    {
      "id": "iti28:3.4",
      "pali": "aguttāni ca bhikkhuno."
    },
    {
      "id": "iti28:4.1",
      "pali": "Bhojanamhi amattaññū,"
    },
    {
      "id": "iti28:4.2",
      "pali": "indriyesu asaṁvuto;"
    },
    {
      "id": "iti28:4.3",
      "pali": "Kāyadukkhaṁ cetodukkhaṁ,"
    },
    {
      "id": "iti28:4.4",
      "pali": "dukkhaṁ so adhigacchati."
    },
    {
      "id": "iti28:5.1",
      "pali": "Ḍayhamānena kāyena,"
    },
    {
      "id": "iti28:5.2",
      "pali": "Ḍayhamānena cetasā;"
    },
    {
      "id": "iti28:5.3",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "iti28:5.4",
      "pali": "Dukkhaṁ viharati tādiso”ti."
    },
    {
      "id": "iti28:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti28:6.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
