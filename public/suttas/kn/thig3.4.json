{
  "uid": "thig3.4",
  "title": "Dantikātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.4:1.1",
      "pali": "“Divāvihārā nikkhamma,"
    },
    {
      "id": "thig3.4:1.2",
      "pali": "gijjhakūṭamhi pabbate;"
    },
    {
      "id": "thig3.4:1.3",
      "pali": "Nāgaṁ ogāhamuttiṇṇaṁ,"
    },
    {
      "id": "thig3.4:1.4",
      "pali": "nadītīramhi addasaṁ."
    },
    {
      "id": "thig3.4:2.1",
      "pali": "Puriso aṅkusamādāya,"
    },
    {
      "id": "thig3.4:2.2",
      "pali": "‘dehi pādan’ti yācati;"
    },
    {
      "id": "thig3.4:2.3",
      "pali": "Nāgo pasārayī pādaṁ,"
    },
    {
      "id": "thig3.4:2.4",
      "pali": "puriso nāgamāruhi."
    },
    {
      "id": "thig3.4:3.1",
      "pali": "Disvā adantaṁ damitaṁ,"
    },
    {
      "id": "thig3.4:3.2",
      "pali": "manussānaṁ vasaṁ gataṁ;"
    },
    {
      "id": "thig3.4:3.3",
      "pali": "Tato cittaṁ samādhesiṁ,"
    },
    {
      "id": "thig3.4:3.4",
      "pali": "khalu tāya vanaṁ gatā”ti."
    },
    {
      "id": "thig3.4:4.1",
      "pali": "… Dantikā therī …."
    }
  ]
}
