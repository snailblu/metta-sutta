{
  "uid": "tha-ap469",
  "title": "7 Labujaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap469:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap469:1.2",
      "pali": "ārāmiko ahaṁ tadā;"
    },
    {
      "id": "tha-ap469:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap469:1.4",
      "pali": "gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap469:2.1",
      "pali": "Labujaṁ phalamādāya,"
    },
    {
      "id": "tha-ap469:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap469:2.3",
      "pali": "Ākāseva ṭhito santo,"
    },
    {
      "id": "tha-ap469:2.4",
      "pali": "paṭiggaṇhi mahāyaso."
    },
    {
      "id": "tha-ap469:3.1",
      "pali": "Vittisañjanano mayhaṁ,"
    },
    {
      "id": "tha-ap469:3.2",
      "pali": "diṭṭhadhammasukhāvaho;"
    },
    {
      "id": "tha-ap469:3.3",
      "pali": "Phalaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap469:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap469:4.1",
      "pali": "Adhigañchiṁ tadā pītiṁ,"
    },
    {
      "id": "tha-ap469:4.2",
      "pali": "vipulaṁ sukhamuttamaṁ;"
    },
    {
      "id": "tha-ap469:4.3",
      "pali": "Uppajjateva ratanaṁ,"
    },
    {
      "id": "tha-ap469:4.4",
      "pali": "nibbattassa tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap469:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap469:5.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap469:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap469:5.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap469:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap469:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap469:6.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap469:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap469:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap469:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap469:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap469:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap469:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap469:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā labujaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap469:10.1",
      "pali": "Labujaphaladāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
