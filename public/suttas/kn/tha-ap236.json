{
  "uid": "tha-ap236",
  "title": "Kilañjadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap236:1.1",
      "pali": "“Tivarāyaṁ pure ramme,"
    },
    {
      "id": "tha-ap236:1.2",
      "pali": "naḷakāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap236:1.3",
      "pali": "Siddhatthe lokapajjote,"
    },
    {
      "id": "tha-ap236:1.4",
      "pali": "pasannā janatā tahiṁ."
    },
    {
      "id": "tha-ap236:2.1",
      "pali": "Pūjatthaṁ lokanāthassa,"
    },
    {
      "id": "tha-ap236:2.2",
      "pali": "kilañjaṁ pariyesati;"
    },
    {
      "id": "tha-ap236:2.3",
      "pali": "Buddhapūjaṁ karontānaṁ,"
    },
    {
      "id": "tha-ap236:2.4",
      "pali": "kilañjaṁ adadiṁ ahaṁ."
    },
    {
      "id": "tha-ap236:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap236:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap236:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap236:3.4",
      "pali": "kilañjassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap236:4.1",
      "pali": "Sattasattatikappamhi,"
    },
    {
      "id": "tha-ap236:4.2",
      "pali": "rājā āsiṁ jaladdharo;"
    },
    {
      "id": "tha-ap236:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap236:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap236:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap236:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap236:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap236:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kilañjadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap236:7.1",
      "pali": "Kilañjadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
