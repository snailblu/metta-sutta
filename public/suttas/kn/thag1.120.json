{
  "uid": "thag1.120",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.120:1.1",
      "pali": "“Pañcakkhandhā pariññātā,"
    },
    {
      "id": "thag1.120:1.2",
      "pali": "tiṭṭhanti chinnamūlakā;"
    },
    {
      "id": "thag1.120:1.3",
      "pali": "Dukkhakkhayo anuppatto,"
    },
    {
      "id": "thag1.120:1.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag1.120:1.5",
      "pali": "… Isidatto thero …"
    },
    {
      "id": "thag1.120:1.6",
      "pali": "vaggo dvādasamo."
    },
    {
      "id": "thag1.120:2.1",
      "pali": "Jento ca vacchagotto ca,"
    },
    {
      "id": "thag1.120:2.2",
      "pali": "vaccho ca vanasavhayo;"
    },
    {
      "id": "thag1.120:2.3",
      "pali": "Adhimutto mahānāmo,"
    },
    {
      "id": "thag1.120:2.4",
      "pali": "pārāpariyo yasopi ca;"
    },
    {
      "id": "thag1.120:2.5",
      "pali": "Kimilo vajjiputto ca,"
    },
    {
      "id": "thag1.120:2.6",
      "pali": "isidatto mahāyasoti."
    },
    {
      "id": "thag1.120:2.7",
      "pali": "Ekakanipāto niṭṭhito."
    },
    {
      "id": "thag1.120:3.1",
      "pali": "Vīsuttarasataṁ therā,"
    },
    {
      "id": "thag1.120:3.2",
      "pali": "katakiccā anāsavā;"
    },
    {
      "id": "thag1.120:3.3",
      "pali": "Ekakeva nipātamhi,"
    },
    {
      "id": "thag1.120:3.4",
      "pali": "susaṅgītā mahesibhīti."
    }
  ]
}
