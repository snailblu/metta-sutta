{
  "uid": "ja61",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja61:1.1",
      "pali": "“Asā lokitthiyo nāma,"
    },
    {
      "id": "ja61:1.2",
      "pali": "velā tāsaṁ na vijjati;"
    },
    {
      "id": "ja61:1.3",
      "pali": "Sārattā ca pagabbhā ca,"
    },
    {
      "id": "ja61:1.4",
      "pali": "sikhī sabbaghaso yathā;"
    },
    {
      "id": "ja61:1.5",
      "pali": "Tā hitvā pabbajissāmi,"
    },
    {
      "id": "ja61:1.6",
      "pali": "vivekamanubrūhayan”ti."
    },
    {
      "id": "ja61:2.1",
      "pali": "Asātamantajātakaṁ paṭhamaṁ."
    }
  ]
}
