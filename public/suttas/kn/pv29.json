{
  "uid": "pv29",
  "title": "4. Bhusapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv29:1.1",
      "pali": "“Bhusāni eko sāliṁ punāparo,"
    },
    {
      "id": "pv29:1.2",
      "pali": "Ayañca nārī sakamaṁsalohitaṁ;"
    },
    {
      "id": "pv29:1.3",
      "pali": "Tuvañca gūthaṁ asuciṁ akantaṁ,"
    },
    {
      "id": "pv29:1.4",
      "pali": "Paribhuñjasi kissa ayaṁ vipāko”ti."
    },
    {
      "id": "pv29:2.1",
      "pali": "“Ayaṁ pure mātaraṁ hiṁsati,"
    },
    {
      "id": "pv29:2.2",
      "pali": "Ayaṁ pana kūṭavāṇijo;"
    },
    {
      "id": "pv29:2.3",
      "pali": "Ayaṁ maṁsāni khāditvā,"
    },
    {
      "id": "pv29:2.4",
      "pali": "Musāvādena vañceti."
    },
    {
      "id": "pv29:3.1",
      "pali": "Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "pv29:3.2",
      "pali": "Agārinī sabbakulassa issarā;"
    },
    {
      "id": "pv29:3.3",
      "pali": "Santesu pariguhāmi,"
    },
    {
      "id": "pv29:3.4",
      "pali": "Mā ca kiñci ito adaṁ."
    },
    {
      "id": "pv29:4.1",
      "pali": "Musāvādena chādemi,"
    },
    {
      "id": "pv29:4.2",
      "pali": "‘natthi etaṁ mama gehe;"
    },
    {
      "id": "pv29:4.3",
      "pali": "Sace santaṁ niguhāmi,"
    },
    {
      "id": "pv29:4.4",
      "pali": "gūtho me hotu bhojanaṁ’."
    },
    {
      "id": "pv29:5.1",
      "pali": "Tassa kammassa vipākena,"
    },
    {
      "id": "pv29:5.2",
      "pali": "musāvādassa cūbhayaṁ;"
    },
    {
      "id": "pv29:5.3",
      "pali": "Sugandhaṁ sālino bhattaṁ,"
    },
    {
      "id": "pv29:5.4",
      "pali": "gūthaṁ me parivattati."
    },
    {
      "id": "pv29:6.1",
      "pali": "Avañjhāni ca kammāni,"
    },
    {
      "id": "pv29:6.2",
      "pali": "Na hi kammaṁ vinassati;"
    },
    {
      "id": "pv29:6.3",
      "pali": "Duggandhaṁ kiminaṁ mīḷaṁ,"
    },
    {
      "id": "pv29:6.4",
      "pali": "Bhuñjāmi ca pivāmi cā”ti."
    },
    {
      "id": "pv29:7.1",
      "pali": "Bhusapetavatthu catutthaṁ."
    }
  ]
}
