{
  "uid": "ja199",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja199:1.1",
      "pali": "“Ubhayaṁ me na khamati,"
    },
    {
      "id": "ja199:1.2",
      "pali": "ubhayaṁ me na ruccati;"
    },
    {
      "id": "ja199:1.3",
      "pali": "Yācāyaṁ koṭṭhamotiṇṇā,"
    },
    {
      "id": "ja199:1.4",
      "pali": "nāddasaṁ iti bhāsati."
    },
    {
      "id": "ja199:2.1",
      "pali": "Taṁ taṁ gāmapati brūmi,"
    },
    {
      "id": "ja199:2.2",
      "pali": "kadare appasmi jīvite;"
    },
    {
      "id": "ja199:2.3",
      "pali": "Dve māse saṅgaraṁ katvā,"
    },
    {
      "id": "ja199:2.4",
      "pali": "maṁsaṁ jaraggavaṁ kisaṁ;"
    },
    {
      "id": "ja199:2.5",
      "pali": "Appattakāle codesi,"
    },
    {
      "id": "ja199:2.6",
      "pali": "tampi mayhaṁ na ruccatī”ti."
    },
    {
      "id": "ja199:3.1",
      "pali": "Gahapatijātakaṁ navamaṁ."
    }
  ]
}
