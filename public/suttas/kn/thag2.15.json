{
  "uid": "thag2.15",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.15:1.1",
      "pali": "“Jano janamhi sambaddho,"
    },
    {
      "id": "thag2.15:1.2",
      "pali": "janamevassito jano;"
    },
    {
      "id": "thag2.15:1.3",
      "pali": "Jano janena heṭhīyati,"
    },
    {
      "id": "thag2.15:1.4",
      "pali": "heṭheti ca jano janaṁ."
    },
    {
      "id": "thag2.15:2.1",
      "pali": "Ko hi tassa janenattho,"
    },
    {
      "id": "thag2.15:2.2",
      "pali": "janena janitena vā;"
    },
    {
      "id": "thag2.15:2.3",
      "pali": "Janaṁ ohāya gacchaṁ taṁ,"
    },
    {
      "id": "thag2.15:2.4",
      "pali": "heṭhayitvā bahuṁ janan”ti."
    },
    {
      "id": "thag2.15:2.5",
      "pali": "… Sabbamitto thero …."
    }
  ]
}
