{
  "uid": "ps2.10",
  "title": "2.10. Suññakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps2.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ps2.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ps2.10:1.3",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi."
    },
    {
      "id": "ps2.10:1.4",
      "pali": "Ekamantaṁ nisinno kho āyasmā ānando bhagavantaṁ etadavoca—"
    },
    {
      "id": "ps2.10:2.1",
      "pali": "“‘Suñño loko, suñño loko’ti, bhante, vuccati."
    },
    {
      "id": "ps2.10:2.2",
      "pali": "Kittāvatā nu kho, bhante, ‘suñño loko’ti vuccatī”ti?"
    },
    {
      "id": "ps2.10:2.3",
      "pali": "“Yasmā kho, ānanda, suññaṁ attena vā attaniyena vā, tasmā ‘suñño loko’ti vuccati."
    },
    {
      "id": "ps2.10:2.4",
      "pali": "Kiñcānanda, suññaṁ attena vā attaniyena vā?"
    },
    {
      "id": "ps2.10:2.5",
      "pali": "Cakkhu kho, ānanda, suññaṁ attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:2.6",
      "pali": "Rūpā suññā attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:2.7",
      "pali": "Cakkhuviññāṇaṁ suññaṁ attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:2.8",
      "pali": "Cakkhusamphasso suñño attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:2.9",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā, tampi suññaṁ attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.1",
      "pali": "Sotaṁ suññaṁ …pe…"
    },
    {
      "id": "ps2.10:3.2",
      "pali": "saddā suññā …"
    },
    {
      "id": "ps2.10:3.3",
      "pali": "ghānaṁ suññaṁ …"
    },
    {
      "id": "ps2.10:3.4",
      "pali": "gandhā suññā …"
    },
    {
      "id": "ps2.10:3.5",
      "pali": "jivhā suññā …"
    },
    {
      "id": "ps2.10:3.6",
      "pali": "rasā suññā …"
    },
    {
      "id": "ps2.10:3.7",
      "pali": "kāyo suñño …"
    },
    {
      "id": "ps2.10:3.8",
      "pali": "phoṭṭhabbā suññā …"
    },
    {
      "id": "ps2.10:3.9",
      "pali": "mano suñño attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.10",
      "pali": "Dhammā suññā attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.11",
      "pali": "Manoviññāṇaṁ suññaṁ attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.12",
      "pali": "Manosamphasso suñño attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.13",
      "pali": "Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā, tampi suññaṁ attena vā attaniyena vā."
    },
    {
      "id": "ps2.10:3.14",
      "pali": "Yasmā kho, ānanda, suññaṁ attena vā attaniyena vā tasmā ‘suñño loko’ti vuccatī”ti."
    },
    {
      "id": "ps2.10:4.1",
      "pali": "Suññasuññaṁ, saṅkhārasuññaṁ, vipariṇāmasuññaṁ, aggasuññaṁ, lakkhaṇasuññaṁ, vikkhambhanasuññaṁ, tadaṅgasuññaṁ, samucchedasuññaṁ, paṭippassaddhisuññaṁ, nissaraṇasuññaṁ, ajjhattasuññaṁ, bahiddhāsuññaṁ, dubhatosuññaṁ, sabhāgasuññaṁ, visabhāgasuññaṁ, esanāsuññaṁ, pariggahasuññaṁ, paṭilābhasuññaṁ, paṭivedhasuññaṁ, ekattasuññaṁ, nānattasuññaṁ, khantisuññaṁ, adhiṭṭhānasuññaṁ, pariyogāhaṇasuññaṁ, sampajānassa pavattapariyādānaṁ sabbasuññatānaṁ paramatthasuññaṁ. [25]"
    },
    {
      "id": "ps2.10:5.1",
      "pali": "Katamaṁ <b>suññasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:5.2",
      "pali": "Cakkhu suññaṁ attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:5.3",
      "pali": "Sotaṁ suññaṁ …pe…"
    },
    {
      "id": "ps2.10:5.4",
      "pali": "ghānaṁ suññaṁ …"
    },
    {
      "id": "ps2.10:5.5",
      "pali": "jivhā suññā …"
    },
    {
      "id": "ps2.10:5.6",
      "pali": "kāyo suñño …"
    },
    {
      "id": "ps2.10:5.7",
      "pali": "mano suñño attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:5.8",
      "pali": "Idaṁ suññasuññaṁ."
    },
    {
      "id": "ps2.10:6.1",
      "pali": "Katamaṁ <b>saṅkhārasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:6.2",
      "pali": "Tayo saṅkhārā—"
    },
    {
      "id": "ps2.10:6.3",
      "pali": "puññābhisaṅkhāro, apuññābhisaṅkhāro, āneñjābhisaṅkhāro."
    },
    {
      "id": "ps2.10:6.4",
      "pali": "Puññābhisaṅkhāro apuññābhisaṅkhārena ca āneñjābhisaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:6.5",
      "pali": "Apuññābhisaṅkhāro puññābhisaṅkhārena ca āneñjābhisaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:6.6",
      "pali": "Āneñjābhisaṅkhāro puññābhisaṅkhārena ca apuññābhisaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:6.7",
      "pali": "Ime tayo saṅkhārā."
    },
    {
      "id": "ps2.10:7.1",
      "pali": "Aparepi tayo saṅkhārā—"
    },
    {
      "id": "ps2.10:7.2",
      "pali": "kāyasaṅkhāro, vacīsaṅkhāro, cittasaṅkhāro."
    },
    {
      "id": "ps2.10:7.3",
      "pali": "Kāyasaṅkhāro vacīsaṅkhārena ca cittasaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:7.4",
      "pali": "Vacīsaṅkhāro kāyasaṅkhārena ca cittasaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:7.5",
      "pali": "Cittasaṅkhāro kāyasaṅkhārena ca vacīsaṅkhārena ca suñño."
    },
    {
      "id": "ps2.10:7.6",
      "pali": "Ime tayo saṅkhārā."
    },
    {
      "id": "ps2.10:8.1",
      "pali": "Aparepi tayo saṅkhārā—"
    },
    {
      "id": "ps2.10:8.2",
      "pali": "atītā saṅkhārā, anāgatā saṅkhārā, paccuppannā saṅkhārā."
    },
    {
      "id": "ps2.10:8.3",
      "pali": "Atītā saṅkhārā anāgatehi ca paccuppannehi ca saṅkhārehi suññā."
    },
    {
      "id": "ps2.10:8.4",
      "pali": "Anāgatā saṅkhārā atītehi ca paccuppannehi ca saṅkhārehi suññā paccuppannā saṅkhārā atītehi ca anāgatehi ca saṅkhārehi suññā."
    },
    {
      "id": "ps2.10:8.5",
      "pali": "Ime tayo saṅkhārā;"
    },
    {
      "id": "ps2.10:8.6",
      "pali": "idaṁ saṅkhārasuññaṁ."
    },
    {
      "id": "ps2.10:9.1",
      "pali": "Katamaṁ <b>vipariṇāmasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:9.2",
      "pali": "Jātaṁ rūpaṁ sabhāvena suññaṁ."
    },
    {
      "id": "ps2.10:9.3",
      "pali": "Vigataṁ rūpaṁ vipariṇatañceva suññañca."
    },
    {
      "id": "ps2.10:9.4",
      "pali": "Jātā vedanā sabhāvena suññā."
    },
    {
      "id": "ps2.10:9.5",
      "pali": "Vigatā vedanā vipariṇatā ceva suññā ca …pe…"
    },
    {
      "id": "ps2.10:9.6",
      "pali": "jātā saññā …"
    },
    {
      "id": "ps2.10:9.7",
      "pali": "jātā saṅkhārā …"
    },
    {
      "id": "ps2.10:9.8",
      "pali": "jātaṁ viññāṇaṁ …"
    },
    {
      "id": "ps2.10:9.9",
      "pali": "jātaṁ cakkhu …pe…"
    },
    {
      "id": "ps2.10:9.10",
      "pali": "jāto bhavo sabhāvena suñño."
    },
    {
      "id": "ps2.10:9.11",
      "pali": "Vigato bhavo vipariṇato ceva suñño ca."
    },
    {
      "id": "ps2.10:9.12",
      "pali": "Idaṁ vipariṇāmasuññaṁ."
    },
    {
      "id": "ps2.10:10.1",
      "pali": "Katamaṁ <b>aggasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:10.2",
      "pali": "Aggametaṁ padaṁ seṭṭhametaṁ padaṁ visiṭṭhametaṁ padaṁ yadidaṁ sabbasaṅkhārasamatho sabbūpadhipaṭinissaggo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "ps2.10:10.3",
      "pali": "Idaṁ aggasuññaṁ."
    },
    {
      "id": "ps2.10:11.1",
      "pali": "Katamaṁ <b>lakkhaṇasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:11.2",
      "pali": "Dve lakkhaṇāni—"
    },
    {
      "id": "ps2.10:11.3",
      "pali": "bālalakkhaṇañca paṇḍitalakkhaṇañca."
    },
    {
      "id": "ps2.10:11.4",
      "pali": "Bālalakkhaṇaṁ paṇḍitalakkhaṇena suññaṁ."
    },
    {
      "id": "ps2.10:11.5",
      "pali": "Paṇḍitalakkhaṇaṁ bālalakkhaṇena suññaṁ."
    },
    {
      "id": "ps2.10:11.6",
      "pali": "Tīṇi lakkhaṇāni—"
    },
    {
      "id": "ps2.10:11.7",
      "pali": "uppādalakkhaṇaṁ, vayalakkhaṇaṁ, ṭhitaññathattalakkhaṇaṁ."
    },
    {
      "id": "ps2.10:11.8",
      "pali": "Uppādalakkhaṇaṁ vayalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:11.9",
      "pali": "Vayalakkhaṇaṁ uppādalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ, ṭhitaññathattalakkhaṇaṁ uppādalakkhaṇena ca vayalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.1",
      "pali": "Rūpassa uppādalakkhaṇaṁ vayalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.2",
      "pali": "Rūpassa vayalakkhaṇaṁ uppādalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.3",
      "pali": "Rūpassa ṭhitaññathattalakkhaṇaṁ uppādalakkhaṇena ca vayalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.4",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "ps2.10:12.5",
      "pali": "saññāya …"
    },
    {
      "id": "ps2.10:12.6",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "ps2.10:12.7",
      "pali": "viññāṇassa …"
    },
    {
      "id": "ps2.10:12.8",
      "pali": "cakkhussa …"
    },
    {
      "id": "ps2.10:12.9",
      "pali": "jarāmaraṇassa uppādalakkhaṇaṁ vayalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.10",
      "pali": "Jarāmaraṇassa vayalakkhaṇaṁ uppādalakkhaṇena ca ṭhitaññathattalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.11",
      "pali": "Jarāmaraṇassa ṭhitaññathattalakkhaṇaṁ uppādalakkhaṇena ca vayalakkhaṇena ca suññaṁ."
    },
    {
      "id": "ps2.10:12.12",
      "pali": "Idaṁ lakkhaṇasuññaṁ."
    },
    {
      "id": "ps2.10:13.1",
      "pali": "Katamaṁ <b>vikkhambhanasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:13.2",
      "pali": "Nekkhammena kāmacchando vikkhambhito ceva suñño ca."
    },
    {
      "id": "ps2.10:13.3",
      "pali": "Abyāpādena byāpādo vikkhambhito ceva suñño ca."
    },
    {
      "id": "ps2.10:13.4",
      "pali": "Ālokasaññāya thinamiddhaṁ vikkhambhitañceva suññañca."
    },
    {
      "id": "ps2.10:13.5",
      "pali": "Avikkhepena uddhaccaṁ vikkhambhitañceva suññañca."
    },
    {
      "id": "ps2.10:13.6",
      "pali": "Dhammavavatthānena vicikicchā vikkhambhitā ceva suññā ca."
    },
    {
      "id": "ps2.10:13.7",
      "pali": "Ñāṇena avijjā vikkhambhitā ceva suññā ca."
    },
    {
      "id": "ps2.10:13.8",
      "pali": "Pāmojjena arati vikkhambhitā ceva suññā ca."
    },
    {
      "id": "ps2.10:13.9",
      "pali": "Paṭhamena jhānena nīvaraṇā vikkhambhitā ceva suññā ca …pe…"
    },
    {
      "id": "ps2.10:13.10",
      "pali": "arahattamaggena sabbakilesā vikkhambhitā ceva suññā ca."
    },
    {
      "id": "ps2.10:13.11",
      "pali": "Idaṁ vikkhambhanasuññaṁ."
    },
    {
      "id": "ps2.10:14.1",
      "pali": "Katamaṁ <b>tadaṅgasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:14.2",
      "pali": "Nekkhammena kāmacchando tadaṅgasuñño."
    },
    {
      "id": "ps2.10:14.3",
      "pali": "Abyāpādena byāpādo tadaṅgasuñño."
    },
    {
      "id": "ps2.10:14.4",
      "pali": "Ālokasaññāya thinamiddhaṁ tadaṅgasuññaṁ."
    },
    {
      "id": "ps2.10:14.5",
      "pali": "Avikkhepena uddhaccaṁ tadaṅgasuññaṁ."
    },
    {
      "id": "ps2.10:14.6",
      "pali": "Dhammavavatthānena vicikicchā tadaṅgasuññā."
    },
    {
      "id": "ps2.10:14.7",
      "pali": "Ñāṇena avijjā tadaṅgasuññā."
    },
    {
      "id": "ps2.10:14.8",
      "pali": "Pāmojjena arati tadaṅgasuññā."
    },
    {
      "id": "ps2.10:14.9",
      "pali": "Paṭhamena jhānena nīvaraṇā tadaṅgasuññā …pe…"
    },
    {
      "id": "ps2.10:14.10",
      "pali": "vivaṭṭanānupassanāya saññogābhiniveso tadaṅgasuñño."
    },
    {
      "id": "ps2.10:14.11",
      "pali": "Idaṁ tadaṅgasuññaṁ."
    },
    {
      "id": "ps2.10:15.1",
      "pali": "Katamaṁ <b>samucchedasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:15.2",
      "pali": "Nekkhammena kāmacchando samucchinno ceva suñño ca."
    },
    {
      "id": "ps2.10:15.3",
      "pali": "Abyāpādena byāpādo samucchinno ceva suñño ca."
    },
    {
      "id": "ps2.10:15.4",
      "pali": "Ālokasaññāya thinamiddhaṁ samucchinnañceva suññañca."
    },
    {
      "id": "ps2.10:15.5",
      "pali": "Avikkhepena uddhaccaṁ samucchinnañceva suññañca."
    },
    {
      "id": "ps2.10:15.6",
      "pali": "Dhammavavatthānena vicikicchā samucchinnā ceva suññā ca."
    },
    {
      "id": "ps2.10:15.7",
      "pali": "Ñāṇena avijjā samucchinnā ceva suññā ca."
    },
    {
      "id": "ps2.10:15.8",
      "pali": "Pāmojjena arati samucchinnā ceva suññā ca."
    },
    {
      "id": "ps2.10:15.9",
      "pali": "Paṭhamena jhānena nīvaraṇā samucchinnā ceva suññā ca …pe…"
    },
    {
      "id": "ps2.10:15.10",
      "pali": "arahattamaggena sabbakilesā samucchinnā ceva suññā ca."
    },
    {
      "id": "ps2.10:15.11",
      "pali": "Idaṁ samucchedasuññaṁ."
    },
    {
      "id": "ps2.10:16.1",
      "pali": "Katamaṁ <b>paṭippassaddhisuññaṁ?</b>"
    },
    {
      "id": "ps2.10:16.2",
      "pali": "Nekkhammena kāmacchando paṭippassaddho ceva suñño ca."
    },
    {
      "id": "ps2.10:16.3",
      "pali": "Abyāpādena byāpādo paṭippassaddho ceva suñño ca."
    },
    {
      "id": "ps2.10:16.4",
      "pali": "Ālokasaññāya thinamiddhaṁ paṭippassaddhañceva suññañca."
    },
    {
      "id": "ps2.10:16.5",
      "pali": "Avikkhepena uddhaccaṁ paṭippassaddhañceva suññañca."
    },
    {
      "id": "ps2.10:16.6",
      "pali": "Dhammavavatthānena vicikicchā paṭippassaddhā ceva suññā ca."
    },
    {
      "id": "ps2.10:16.7",
      "pali": "Ñāṇena avijjā paṭippassaddhā ceva suññā ca."
    },
    {
      "id": "ps2.10:16.8",
      "pali": "Pāmojjena arati paṭippassaddhā ceva suññā ca."
    },
    {
      "id": "ps2.10:16.9",
      "pali": "Paṭhamena jhānena nīvaraṇā paṭippassaddhā ceva suññā ca …pe…"
    },
    {
      "id": "ps2.10:16.10",
      "pali": "arahattamaggena sabbakilesā paṭippassaddhā ceva suññā ca."
    },
    {
      "id": "ps2.10:16.11",
      "pali": "Idaṁ paṭippassaddhisuññaṁ."
    },
    {
      "id": "ps2.10:17.1",
      "pali": "Katamaṁ <b>nissaraṇasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:17.2",
      "pali": "Nekkhammena kāmacchando nissaṭo ceva suñño ca."
    },
    {
      "id": "ps2.10:17.3",
      "pali": "Abyāpādena byāpādo nissaṭo ceva suñño ca."
    },
    {
      "id": "ps2.10:17.4",
      "pali": "Ālokasaññāya thinamiddhaṁ nissaṭañceva suññañca."
    },
    {
      "id": "ps2.10:17.5",
      "pali": "Avikkhepena uddhaccaṁ nissaṭañceva suññañca."
    },
    {
      "id": "ps2.10:17.6",
      "pali": "Dhammavavatthānena vicikicchā nissaṭā ceva suññā ca."
    },
    {
      "id": "ps2.10:17.7",
      "pali": "Ñāṇena avijjā nissaṭā ceva suññā ca."
    },
    {
      "id": "ps2.10:17.8",
      "pali": "Pāmojjena arati nissaṭā ceva suññā ca."
    },
    {
      "id": "ps2.10:17.9",
      "pali": "Paṭhamena jhānena nīvaraṇā nissaṭā ceva suññā ca …pe…"
    },
    {
      "id": "ps2.10:17.10",
      "pali": "arahattamaggena sabbakilesā nissaṭā ceva suññā ca."
    },
    {
      "id": "ps2.10:17.11",
      "pali": "Idaṁ nissaraṇasuññaṁ."
    },
    {
      "id": "ps2.10:18.1",
      "pali": "Katamaṁ <b>ajjhattasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:18.2",
      "pali": "Ajjhattaṁ cakkhuṁ suññaṁ attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:18.3",
      "pali": "Ajjhattaṁ sotaṁ suññaṁ …"
    },
    {
      "id": "ps2.10:18.4",
      "pali": "ajjhattaṁ ghānaṁ suññaṁ …"
    },
    {
      "id": "ps2.10:18.5",
      "pali": "ajjhattaṁ jivhā suññā …"
    },
    {
      "id": "ps2.10:18.6",
      "pali": "ajjhattaṁ kāyo suñño …"
    },
    {
      "id": "ps2.10:18.7",
      "pali": "ajjhattaṁ mano suñño attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:18.8",
      "pali": "Idaṁ ajjhattasuññaṁ."
    },
    {
      "id": "ps2.10:19.1",
      "pali": "Katamaṁ <b>bahiddhāsuññaṁ?</b>"
    },
    {
      "id": "ps2.10:19.2",
      "pali": "Bahiddhā rūpā suññā …pe…"
    },
    {
      "id": "ps2.10:19.3",
      "pali": "bahiddhā dhammā suññā attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:19.4",
      "pali": "Idaṁ bahiddhāsuññaṁ."
    },
    {
      "id": "ps2.10:20.1",
      "pali": "Katamaṁ <b>dubhatosuññaṁ?</b>"
    },
    {
      "id": "ps2.10:20.2",
      "pali": "Yañca ajjhattaṁ cakkhu ye ca bahiddhā rūpā ubhayametaṁ suññaṁ attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:20.3",
      "pali": "Yañca ajjhattaṁ sotaṁ ye ca bahiddhā saddā …pe…"
    },
    {
      "id": "ps2.10:20.4",
      "pali": "yañca ajjhattaṁ ghānaṁ ye ca bahiddhā gandhā …"
    },
    {
      "id": "ps2.10:20.5",
      "pali": "yā ca ajjhattaṁ jivhā ye ca bahiddhā rasā …"
    },
    {
      "id": "ps2.10:20.6",
      "pali": "yo ca ajjhattaṁ kāyo ye ca bahiddhā phoṭṭhabbā …"
    },
    {
      "id": "ps2.10:20.7",
      "pali": "yo ca ajjhattaṁ mano ye ca bahiddhā dhammā ubhayametaṁ suññaṁ attena vā attaniyena vā niccena vā dhuvena vā sassatena vā avipariṇāmadhammena vā."
    },
    {
      "id": "ps2.10:20.8",
      "pali": "Idaṁ dubhatosuññaṁ."
    },
    {
      "id": "ps2.10:21.1",
      "pali": "Katamaṁ <b>sabhāgasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:21.2",
      "pali": "Cha ajjhattikāni āyatanāni sabhāgāni ceva suññāni ca."
    },
    {
      "id": "ps2.10:21.3",
      "pali": "Cha bāhirāni āyatanāni sabhāgāni ceva suññāni ca."
    },
    {
      "id": "ps2.10:21.4",
      "pali": "Cha viññāṇakāyā sabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:21.5",
      "pali": "Cha phassakāyā sabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:21.6",
      "pali": "Cha vedanākāyā sabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:21.7",
      "pali": "Cha saññākāyā sabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:21.8",
      "pali": "Cha cetanākāyā sabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:21.9",
      "pali": "Idaṁ sabhāgasuññaṁ."
    },
    {
      "id": "ps2.10:22.1",
      "pali": "Katamaṁ <b>visabhāgasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:22.2",
      "pali": "Cha ajjhattikāni āyatanāni chahi bāhirehi āyatanehi visabhāgāni ceva suññāni ca."
    },
    {
      "id": "ps2.10:22.3",
      "pali": "Cha bāhirāni āyatanāni chahi viññāṇakāyehi visabhāgāni ceva suññāni ca."
    },
    {
      "id": "ps2.10:22.4",
      "pali": "Cha viññāṇakāyā chahi phassakāyehi visabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:22.5",
      "pali": "Cha phassakāyā chahi vedanākāyehi visabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:22.6",
      "pali": "Cha vedanākāyā chahi saññākāyehi visabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:22.7",
      "pali": "Cha saññākāyā chahi cetanākāyehi visabhāgā ceva suññā ca."
    },
    {
      "id": "ps2.10:22.8",
      "pali": "Idaṁ visabhāgasuññaṁ."
    },
    {
      "id": "ps2.10:23.1",
      "pali": "Katamaṁ <b>esanāsuññaṁ?</b>"
    },
    {
      "id": "ps2.10:23.2",
      "pali": "Nekkhammesanā kāmacchandena suññā."
    },
    {
      "id": "ps2.10:23.3",
      "pali": "Abyāpādesanā byāpādena suññā."
    },
    {
      "id": "ps2.10:23.4",
      "pali": "Ālokasaññesanā thinamiddhena suññā."
    },
    {
      "id": "ps2.10:23.5",
      "pali": "Avikkhepesanā uddhaccena suññā."
    },
    {
      "id": "ps2.10:23.6",
      "pali": "Dhammavavatthānesanā vicikicchāya suññā."
    },
    {
      "id": "ps2.10:23.7",
      "pali": "Ñāṇesanā avijjāya suññā."
    },
    {
      "id": "ps2.10:23.8",
      "pali": "Pāmojjesanā aratiyā suññā."
    },
    {
      "id": "ps2.10:23.9",
      "pali": "Paṭhamajjhānesanā nīvaraṇehi suññā …pe…"
    },
    {
      "id": "ps2.10:23.10",
      "pali": "arahattamaggesanā sabbakilesehi suññā."
    },
    {
      "id": "ps2.10:23.11",
      "pali": "Idaṁ esanāsuññaṁ."
    },
    {
      "id": "ps2.10:24.1",
      "pali": "Katamaṁ <b>pariggahasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:24.2",
      "pali": "Nekkhammapariggaho kāmacchandena suñño."
    },
    {
      "id": "ps2.10:24.3",
      "pali": "Abyāpādapariggaho byāpādena suñño."
    },
    {
      "id": "ps2.10:24.4",
      "pali": "Ālokasaññāpariggaho thinamiddhena suñño."
    },
    {
      "id": "ps2.10:24.5",
      "pali": "Avikkhepapariggaho uddhaccena suñño."
    },
    {
      "id": "ps2.10:24.6",
      "pali": "Dhammavavatthānapariggaho vicikicchāya suñño."
    },
    {
      "id": "ps2.10:24.7",
      "pali": "Ñāṇapariggaho avijjāya suñño."
    },
    {
      "id": "ps2.10:24.8",
      "pali": "Pāmojjapariggaho aratiyā suñño."
    },
    {
      "id": "ps2.10:24.9",
      "pali": "Paṭhamajjhānapariggaho nīvaraṇehi suñño …pe…"
    },
    {
      "id": "ps2.10:24.10",
      "pali": "arahattamaggapariggaho sabbakilesehi suñño."
    },
    {
      "id": "ps2.10:24.11",
      "pali": "Idaṁ pariggahasuññaṁ."
    },
    {
      "id": "ps2.10:25.1",
      "pali": "Katamaṁ <b>paṭilābhasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:25.2",
      "pali": "Nekkhammapaṭilābho kāmacchandena suñño."
    },
    {
      "id": "ps2.10:25.3",
      "pali": "Abyāpādapaṭilābho byāpādena suñño."
    },
    {
      "id": "ps2.10:25.4",
      "pali": "Ālokasaññāpaṭilābho thinamiddhena suñño."
    },
    {
      "id": "ps2.10:25.5",
      "pali": "Avikkhepapaṭilābho uddhaccena suñño."
    },
    {
      "id": "ps2.10:25.6",
      "pali": "Dhammavavatthānapaṭilābho vicikicchāya suñño."
    },
    {
      "id": "ps2.10:25.7",
      "pali": "Ñāṇapaṭilābho avijjāya suñño."
    },
    {
      "id": "ps2.10:25.8",
      "pali": "Pāmojjapaṭilābho aratiyā suñño."
    },
    {
      "id": "ps2.10:25.9",
      "pali": "Paṭhamajjhānapaṭilābho nīvaraṇehi suñño …pe…"
    },
    {
      "id": "ps2.10:25.10",
      "pali": "arahattamaggapaṭilābho sabbakilesehi suñño."
    },
    {
      "id": "ps2.10:25.11",
      "pali": "Idaṁ paṭilābhasuññaṁ."
    },
    {
      "id": "ps2.10:26.1",
      "pali": "Katamaṁ <b>paṭivedhasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:26.2",
      "pali": "Nekkhammappaṭivedho kāmacchandena suñño."
    },
    {
      "id": "ps2.10:26.3",
      "pali": "Abyāpādappaṭivedho byāpādena suñño."
    },
    {
      "id": "ps2.10:26.4",
      "pali": "Ālokasaññāppaṭivedho thinamiddhena suñño."
    },
    {
      "id": "ps2.10:26.5",
      "pali": "Avikkhepappaṭivedho uddhaccena suñño."
    },
    {
      "id": "ps2.10:26.6",
      "pali": "Dhammavavatthānappaṭivedho vicikicchāya suñño."
    },
    {
      "id": "ps2.10:26.7",
      "pali": "Ñāṇappaṭivedho avijjāya suñño."
    },
    {
      "id": "ps2.10:26.8",
      "pali": "Pāmojjappaṭivedho aratiyā suñño."
    },
    {
      "id": "ps2.10:26.9",
      "pali": "Paṭhamajjhānappaṭivedho nīvaraṇehi suñño …pe…"
    },
    {
      "id": "ps2.10:26.10",
      "pali": "arahattamaggappaṭivedho sabbakilesehi suñño."
    },
    {
      "id": "ps2.10:26.11",
      "pali": "Idaṁ paṭivedhasuññaṁ."
    },
    {
      "id": "ps2.10:27.1",
      "pali": "Katamaṁ <b>ekattasuññaṁ, nānattasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:27.2",
      "pali": "Kāmacchando nānattaṁ, nekkhammaṁ ekattaṁ."
    },
    {
      "id": "ps2.10:27.3",
      "pali": "Nekkhammekattaṁ cetayato kāmacchandena suññaṁ."
    },
    {
      "id": "ps2.10:27.4",
      "pali": "Byāpādo nānattaṁ, abyāpādo ekattaṁ."
    },
    {
      "id": "ps2.10:27.5",
      "pali": "Abyāpādekattaṁ cetayato byāpādena suññaṁ."
    },
    {
      "id": "ps2.10:27.6",
      "pali": "Thinamiddhaṁ nānattaṁ, ālokasaññā ekattaṁ."
    },
    {
      "id": "ps2.10:27.7",
      "pali": "Ālokasaññekattaṁ cetayato thinamiddhena suññaṁ."
    },
    {
      "id": "ps2.10:27.8",
      "pali": "Uddhaccaṁ nānattaṁ, avikkhepo ekattaṁ."
    },
    {
      "id": "ps2.10:27.9",
      "pali": "Avikkhepekattaṁ cetayato uddhaccena suññaṁ."
    },
    {
      "id": "ps2.10:27.10",
      "pali": "Vicikicchā nānattaṁ, dhammavavatthānaṁ ekattaṁ."
    },
    {
      "id": "ps2.10:27.11",
      "pali": "Dhammavavatthānekattaṁ cetayato vicikicchāya suññaṁ."
    },
    {
      "id": "ps2.10:27.12",
      "pali": "Avijjā nānattaṁ, ñāṇaṁ ekattaṁ."
    },
    {
      "id": "ps2.10:27.13",
      "pali": "Ñāṇekattaṁ cetayato avijjāya suññaṁ."
    },
    {
      "id": "ps2.10:27.14",
      "pali": "Arati nānattaṁ, pāmojjaṁ ekattaṁ."
    },
    {
      "id": "ps2.10:27.15",
      "pali": "Pāmojjekattaṁ cetayato aratiyā suññaṁ."
    },
    {
      "id": "ps2.10:27.16",
      "pali": "Nīvaraṇā nānattaṁ, paṭhamajjhānaṁ ekattaṁ."
    },
    {
      "id": "ps2.10:27.17",
      "pali": "Paṭhamajjhānekattaṁ cetayato nīvaraṇehi suññaṁ …pe…"
    },
    {
      "id": "ps2.10:27.18",
      "pali": "sabbakilesā nānattaṁ, arahattamaggo ekattaṁ."
    },
    {
      "id": "ps2.10:27.19",
      "pali": "Arahattamaggekattaṁ cetayato sabbakilesehi suññaṁ."
    },
    {
      "id": "ps2.10:27.20",
      "pali": "Idaṁ ekattasuññaṁ nānattasuññaṁ."
    },
    {
      "id": "ps2.10:28.1",
      "pali": "Katamaṁ <b>khantisuññaṁ?</b>"
    },
    {
      "id": "ps2.10:28.2",
      "pali": "Nekkhammakhanti kāmacchandena suññā."
    },
    {
      "id": "ps2.10:28.3",
      "pali": "Abyāpādakhanti byāpādena suññā."
    },
    {
      "id": "ps2.10:28.4",
      "pali": "Ālokasaññākhanti thinamiddhena suññā."
    },
    {
      "id": "ps2.10:28.5",
      "pali": "Avikkhepakhanti uddhaccena suññā."
    },
    {
      "id": "ps2.10:28.6",
      "pali": "Dhammavavatthānakhanti vicikicchāya suññā."
    },
    {
      "id": "ps2.10:28.7",
      "pali": "Ñāṇakhanti avijjāya suññā."
    },
    {
      "id": "ps2.10:28.8",
      "pali": "Pāmojjakhanti aratiyā suññā."
    },
    {
      "id": "ps2.10:28.9",
      "pali": "Paṭhamajjhānakhanti nīvaraṇehi suññā …pe…"
    },
    {
      "id": "ps2.10:28.10",
      "pali": "arahattamaggakhanti sabbakilesehi suññā."
    },
    {
      "id": "ps2.10:28.11",
      "pali": "Idaṁ khantisuññaṁ."
    },
    {
      "id": "ps2.10:29.1",
      "pali": "Katamaṁ <b>adhiṭṭhānasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:29.2",
      "pali": "Nekkhammādhiṭṭhānaṁ kāmacchandena suññaṁ."
    },
    {
      "id": "ps2.10:29.3",
      "pali": "Abyāpādādhiṭṭhānaṁ byāpādena suññaṁ."
    },
    {
      "id": "ps2.10:29.4",
      "pali": "Ālokasaññādhiṭṭhānaṁ thinamiddhena suññaṁ."
    },
    {
      "id": "ps2.10:29.5",
      "pali": "Avikkhepādhiṭṭhānaṁ uddhaccena suññaṁ."
    },
    {
      "id": "ps2.10:29.6",
      "pali": "Dhammavavatthānādhiṭṭhānaṁ vicikicchāya suññaṁ."
    },
    {
      "id": "ps2.10:29.7",
      "pali": "Ñāṇādhiṭṭhānaṁ avijjāya suññaṁ."
    },
    {
      "id": "ps2.10:29.8",
      "pali": "Pāmojjādhiṭṭhānaṁ aratiyā suññaṁ."
    },
    {
      "id": "ps2.10:29.9",
      "pali": "Paṭhamajjhānādhiṭṭhānaṁ nīvaraṇehi suññaṁ …pe…"
    },
    {
      "id": "ps2.10:29.10",
      "pali": "arahattamaggādhiṭṭhānaṁ sabbakilesehi suññaṁ."
    },
    {
      "id": "ps2.10:29.11",
      "pali": "Idaṁ adhiṭṭhānasuññaṁ."
    },
    {
      "id": "ps2.10:30.1",
      "pali": "Katamaṁ <b>pariyogāhaṇasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:30.2",
      "pali": "Nekkhammapariyogāhaṇaṁ kāmacchandena suññaṁ."
    },
    {
      "id": "ps2.10:30.3",
      "pali": "Abyāpādapariyogāhaṇaṁ byāpādena suññaṁ."
    },
    {
      "id": "ps2.10:30.4",
      "pali": "Ālokasaññāpariyogāhaṇaṁ thinamiddhena suññaṁ."
    },
    {
      "id": "ps2.10:30.5",
      "pali": "Avikkhepapariyogāhaṇaṁ uddhaccena suññaṁ."
    },
    {
      "id": "ps2.10:30.6",
      "pali": "Dhammavavatthānapariyogāhaṇaṁ vicikicchāya suññaṁ."
    },
    {
      "id": "ps2.10:30.7",
      "pali": "Ñāṇapariyogāhaṇaṁ avijjāya suññaṁ."
    },
    {
      "id": "ps2.10:30.8",
      "pali": "Pāmojjapariyogāhaṇaṁ aratiyā suññaṁ."
    },
    {
      "id": "ps2.10:30.9",
      "pali": "Paṭhamajjhānapariyogāhaṇaṁ nīvaraṇehi suññaṁ …pe…"
    },
    {
      "id": "ps2.10:30.10",
      "pali": "arahattamaggapariyogāhaṇaṁ sabbakilesehi suññaṁ."
    },
    {
      "id": "ps2.10:30.11",
      "pali": "Idaṁ pariyogāhaṇasuññaṁ."
    },
    {
      "id": "ps2.10:31.1",
      "pali": "Katamaṁ <b>sampajānassa pavattapariyādānaṁ sabbasuññatānaṁ paramatthasuññaṁ?</b>"
    },
    {
      "id": "ps2.10:31.2",
      "pali": "Idha sampajāno nekkhammena kāmacchandassa pavattaṁ pariyādiyati, abyāpādena byāpādassa pavattaṁ pariyādiyati, ālokasaññāya thinamiddhassa pavattaṁ pariyādiyati, avikkhepena uddhaccassa pavattaṁ pariyādiyati, dhammavavatthānena vicikicchāya pavattaṁ pariyādiyati, ñāṇena avijjāya pavattaṁ pariyādiyati, pāmojjena aratiyā pavattaṁ pariyādiyati, paṭhamena jhānena nīvaraṇānaṁ pavattaṁ pariyādiyati …pe…"
    },
    {
      "id": "ps2.10:31.3",
      "pali": "arahattamaggena sabbakilesānaṁ pavattaṁ pariyādiyati."
    },
    {
      "id": "ps2.10:31.4",
      "pali": "Atha vā pana sampajānassa anupādisesāya nibbānadhātuyā parinibbāyantassa idaṁ ceva cakkhupavattaṁ pariyādiyati, aññañca cakkhupavattaṁ na uppajjati."
    },
    {
      "id": "ps2.10:31.5",
      "pali": "Idañceva sotapavattaṁ …pe…"
    },
    {
      "id": "ps2.10:31.6",
      "pali": "ghānapavattaṁ …"
    },
    {
      "id": "ps2.10:31.7",
      "pali": "jivhāpavattaṁ …"
    },
    {
      "id": "ps2.10:31.8",
      "pali": "kāyapavattaṁ …"
    },
    {
      "id": "ps2.10:31.9",
      "pali": "manopavattaṁ pariyādiyati, aññañca manopavattaṁ na uppajjati."
    },
    {
      "id": "ps2.10:31.10",
      "pali": "Idaṁ sampajānassa pavattapariyādānaṁ sabbasuññatānaṁ paramatthasuññanti."
    },
    {
      "id": "ps2.10:31.11",
      "pali": "Suññakathā niṭṭhitā."
    },
    {
      "id": "ps2.10:31.12",
      "pali": "Yuganaddhavaggo dutiyo."
    },
    {
      "id": "ps2.10:31.13",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ps2.10:32.1",
      "pali": "Yuganaddhā saccabojjhaṅgā,"
    },
    {
      "id": "ps2.10:32.2",
      "pali": "mettā virāgapañcamā;"
    },
    {
      "id": "ps2.10:32.3",
      "pali": "Paṭisambhidā dhammacakkaṁ,"
    },
    {
      "id": "ps2.10:32.4",
      "pali": "lokuttarabalasuññāti."
    },
    {
      "id": "ps2.10:32.5",
      "pali": "Esa nikāyadharehi ṭhapito, asamo dutiyo pavaro varavaggoti."
    }
  ]
}
