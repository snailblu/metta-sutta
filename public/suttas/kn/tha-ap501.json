{
  "uid": "tha-ap501",
  "title": "9 Naḷakuṭidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap501:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap501:1.2",
      "pali": "hārito nāma pabbato;"
    },
    {
      "id": "tha-ap501:1.3",
      "pali": "Sayambhū nārado nāma,"
    },
    {
      "id": "tha-ap501:1.4",
      "pali": "rukkhamūle vasī tadā."
    },
    {
      "id": "tha-ap501:2.1",
      "pali": "Naḷāgāraṁ karitvāna,"
    },
    {
      "id": "tha-ap501:2.2",
      "pali": "tiṇena chādayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap501:2.3",
      "pali": "Caṅkamaṁ sodhayitvāna,"
    },
    {
      "id": "tha-ap501:2.4",
      "pali": "sayambhussa adāsahaṁ."
    },
    {
      "id": "tha-ap501:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap501:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap501:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap501:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap501:4.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "tha-ap501:4.2",
      "pali": "naḷakuṭikanimmitaṁ;"
    },
    {
      "id": "tha-ap501:4.3",
      "pali": "Saṭṭhiyojanamubbedhaṁ,"
    },
    {
      "id": "tha-ap501:4.4",
      "pali": "tiṁsayojanavitthataṁ."
    },
    {
      "id": "tha-ap501:5.1",
      "pali": "Catuddasesu kappesu,"
    },
    {
      "id": "tha-ap501:5.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap501:5.3",
      "pali": "Ekasattatikkhattuñca,"
    },
    {
      "id": "tha-ap501:5.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap501:6.1",
      "pali": "Catutiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap501:6.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap501:6.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap501:6.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap501:7.1",
      "pali": "Dhammapāsādamāruyha,"
    },
    {
      "id": "tha-ap501:7.2",
      "pali": "sabbākāravarūpamaṁ;"
    },
    {
      "id": "tha-ap501:7.3",
      "pali": "Yadicchakāhaṁ vihare,"
    },
    {
      "id": "tha-ap501:7.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "tha-ap501:8.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap501:8.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap501:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap501:8.4",
      "pali": "naḷakuṭiyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap501:9.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap501:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap501:9.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap501:10.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap501:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap501:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap501:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap501:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap501:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap501:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā naḷakuṭidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap501:13.1",
      "pali": "Naḷakuṭidāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
