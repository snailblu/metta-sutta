{
  "uid": "thag1.42",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.42:1.1",
      "pali": "“Cāle upacāle sīsūpacāle (…),"
    },
    {
      "id": "thag1.42:1.2",
      "pali": "Patissatā nu kho viharatha;"
    },
    {
      "id": "thag1.42:1.3",
      "pali": "Āgato vo vālaṁ viya vedhī”ti."
    },
    {
      "id": "thag1.42:1.4",
      "pali": "… Khadiravaniyo thero …."
    }
  ]
}
