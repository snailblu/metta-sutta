{
  "uid": "ja254",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja254:1.1",
      "pali": "“Bhutvā tiṇaparighāsaṁ,"
    },
    {
      "id": "ja254:1.2",
      "pali": "bhutvā ācāmakuṇḍakaṁ;"
    },
    {
      "id": "ja254:1.3",
      "pali": "Etaṁ te bhojanaṁ āsi,"
    },
    {
      "id": "ja254:1.4",
      "pali": "kasmā dāni na bhuñjasi”."
    },
    {
      "id": "ja254:2.1",
      "pali": "“Yattha posaṁ na jānanti,"
    },
    {
      "id": "ja254:2.2",
      "pali": "jātiyā vinayena vā;"
    },
    {
      "id": "ja254:2.3",
      "pali": "Bahuṁ tattha mahābrahme,"
    },
    {
      "id": "ja254:2.4",
      "pali": "api ācāmakuṇḍakaṁ."
    },
    {
      "id": "ja254:3.1",
      "pali": "Tvañca kho maṁ pajānāsi,"
    },
    {
      "id": "ja254:3.2",
      "pali": "yādisāyaṁ hayuttamo;"
    },
    {
      "id": "ja254:3.3",
      "pali": "Jānanto jānamāgamma,"
    },
    {
      "id": "ja254:3.4",
      "pali": "na te bhakkhāmi kuṇḍakan”ti."
    },
    {
      "id": "ja254:4.1",
      "pali": "Kuṇḍakakucchisindhavajātakaṁ catutthaṁ."
    }
  ]
}
