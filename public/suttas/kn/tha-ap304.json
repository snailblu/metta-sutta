{
  "uid": "tha-ap304",
  "title": "Sabbagandhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap304:1.1",
      "pali": "“Gandhamālaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap304:1.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap304:1.3",
      "pali": "Adāsiṁ ujubhūtassa,"
    },
    {
      "id": "tha-ap304:1.4",
      "pali": "koseyyavatthamuttamaṁ."
    },
    {
      "id": "tha-ap304:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap304:2.2",
      "pali": "yaṁ vatthamadadiṁ pure;"
    },
    {
      "id": "tha-ap304:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap304:2.4",
      "pali": "gandhadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap304:3.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap304:3.2",
      "pali": "suceḷo nāma khattiyo;"
    },
    {
      "id": "tha-ap304:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap304:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap304:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap304:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap304:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap304:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā sabbagandhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap304:6.1",
      "pali": "Sabbagandhiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
