{
  "uid": "thig1.16",
  "title": "Vuḍḍhapabbajitasumanātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.16:1.1",
      "pali": "“Sukhaṁ tvaṁ vuḍḍhike sehi,"
    },
    {
      "id": "thig1.16:1.2",
      "pali": "katvā coḷena pārutā;"
    },
    {
      "id": "thig1.16:1.3",
      "pali": "Upasanto hi te rāgo,"
    },
    {
      "id": "thig1.16:1.4",
      "pali": "sītibhūtāsi nibbutā”ti."
    },
    {
      "id": "thig1.16:2.1",
      "pali": "… Sumanā vuḍḍhapabbajitā therī …."
    }
  ]
}
