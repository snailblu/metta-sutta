{
  "uid": "thig16.1",
  "title": "Sumedhātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig16.1:1.1",
      "pali": "Mantāvatiyā nagare,"
    },
    {
      "id": "thig16.1:1.2",
      "pali": "Rañño koñcassa aggamahesiyā;"
    },
    {
      "id": "thig16.1:1.3",
      "pali": "Dhītā āsiṁ sumedhā,"
    },
    {
      "id": "thig16.1:1.4",
      "pali": "Pasāditā sāsanakarehi."
    },
    {
      "id": "thig16.1:2.1",
      "pali": "Sīlavatī cittakathā,"
    },
    {
      "id": "thig16.1:2.2",
      "pali": "Bahussutā buddhasāsane vinitā;"
    },
    {
      "id": "thig16.1:2.3",
      "pali": "Mātāpitaro upagamma,"
    },
    {
      "id": "thig16.1:2.4",
      "pali": "Bhaṇati “ubhayo nisāmetha."
    },
    {
      "id": "thig16.1:3.1",
      "pali": "Nibbānābhiratāhaṁ,"
    },
    {
      "id": "thig16.1:3.2",
      "pali": "Asassataṁ bhavagataṁ yadipi dibbaṁ;"
    },
    {
      "id": "thig16.1:3.3",
      "pali": "Kimaṅgaṁ pana tucchā kāmā,"
    },
    {
      "id": "thig16.1:3.4",
      "pali": "Appassādā bahuvighātā."
    },
    {
      "id": "thig16.1:4.1",
      "pali": "Kāmā kaṭukā āsī,"
    },
    {
      "id": "thig16.1:4.2",
      "pali": "Visūpamā yesu mucchitā bālā;"
    },
    {
      "id": "thig16.1:4.3",
      "pali": "Te dīgharattaṁ niraye,"
    },
    {
      "id": "thig16.1:4.4",
      "pali": "Samappitā haññante dukkhitā."
    },
    {
      "id": "thig16.1:5.1",
      "pali": "Socanti pāpakammā,"
    },
    {
      "id": "thig16.1:5.2",
      "pali": "Vinipāte pāpavaddhino sadā;"
    },
    {
      "id": "thig16.1:5.3",
      "pali": "Kāyena ca vācāya ca,"
    },
    {
      "id": "thig16.1:5.4",
      "pali": "Manasā ca asaṁvutā bālā."
    },
    {
      "id": "thig16.1:6.1",
      "pali": "Bālā te duppaññā,"
    },
    {
      "id": "thig16.1:6.2",
      "pali": "Acetanā dukkhasamudayoruddhā;"
    },
    {
      "id": "thig16.1:6.3",
      "pali": "Desente ajānantā,"
    },
    {
      "id": "thig16.1:6.4",
      "pali": "Na bujjhare ariyasaccāni."
    },
    {
      "id": "thig16.1:7.1",
      "pali": "Saccāni amma buddhavaradesitāni,"
    },
    {
      "id": "thig16.1:7.2",
      "pali": "Te bahutarā ajānantā ye;"
    },
    {
      "id": "thig16.1:7.3",
      "pali": "Abhinandanti bhavagataṁ,"
    },
    {
      "id": "thig16.1:7.4",
      "pali": "Pihenti devesu upapattiṁ."
    },
    {
      "id": "thig16.1:8.1",
      "pali": "Devesupi upapatti,"
    },
    {
      "id": "thig16.1:8.2",
      "pali": "Asassatā bhavagate aniccamhi;"
    },
    {
      "id": "thig16.1:8.3",
      "pali": "Na ca santasanti bālā,"
    },
    {
      "id": "thig16.1:8.4",
      "pali": "Punappunaṁ jāyitabbassa."
    },
    {
      "id": "thig16.1:9.1",
      "pali": "Cattāro vinipātā,"
    },
    {
      "id": "thig16.1:9.2",
      "pali": "Duve ca gatiyo kathañci labbhanti;"
    },
    {
      "id": "thig16.1:9.3",
      "pali": "Na ca vinipātagatānaṁ,"
    },
    {
      "id": "thig16.1:9.4",
      "pali": "Pabbajjā atthi nirayesu."
    },
    {
      "id": "thig16.1:10.1",
      "pali": "Anujānātha maṁ ubhayo,"
    },
    {
      "id": "thig16.1:10.2",
      "pali": "Pabbajituṁ dasabalassa pāvacane;"
    },
    {
      "id": "thig16.1:10.3",
      "pali": "Appossukkā ghaṭissaṁ,"
    },
    {
      "id": "thig16.1:10.4",
      "pali": "Jātimaraṇappahānāya."
    },
    {
      "id": "thig16.1:11.1",
      "pali": "Kiṁ bhavagate abhinanditena,"
    },
    {
      "id": "thig16.1:11.2",
      "pali": "Kāyakalinā asārena;"
    },
    {
      "id": "thig16.1:11.3",
      "pali": "Bhavataṇhāya nirodhā,"
    },
    {
      "id": "thig16.1:11.4",
      "pali": "Anujānātha pabbajissāmi."
    },
    {
      "id": "thig16.1:12.1",
      "pali": "Buddhānaṁ uppādo vivajjito,"
    },
    {
      "id": "thig16.1:12.2",
      "pali": "Akkhaṇo khaṇo laddho;"
    },
    {
      "id": "thig16.1:12.3",
      "pali": "Sīlāni brahmacariyaṁ,"
    },
    {
      "id": "thig16.1:12.4",
      "pali": "Yāvajīvaṁ na dūseyyaṁ”."
    },
    {
      "id": "thig16.1:13.1",
      "pali": "Evaṁ bhaṇati sumedhā,"
    },
    {
      "id": "thig16.1:13.2",
      "pali": "Mātāpitaro “na tāva āhāraṁ;"
    },
    {
      "id": "thig16.1:13.3",
      "pali": "Āharissaṁ gahaṭṭhā,"
    },
    {
      "id": "thig16.1:13.4",
      "pali": "Maraṇavasaṁ gatāva hessāmi”."
    },
    {
      "id": "thig16.1:14.1",
      "pali": "Mātā dukkhitā rodati pitā ca,"
    },
    {
      "id": "thig16.1:14.2",
      "pali": "Assā sabbaso samabhihato;"
    },
    {
      "id": "thig16.1:14.3",
      "pali": "Ghaṭenti saññāpetuṁ,"
    },
    {
      "id": "thig16.1:14.4",
      "pali": "Pāsādatale chamāpatitaṁ."
    },
    {
      "id": "thig16.1:15.1",
      "pali": "“Uṭṭhehi puttaka kiṁ soci,"
    },
    {
      "id": "thig16.1:15.2",
      "pali": "Tena dinnāsi vāraṇavatimhi;"
    },
    {
      "id": "thig16.1:15.3",
      "pali": "Rājā anīkaratto,"
    },
    {
      "id": "thig16.1:15.4",
      "pali": "Abhirūpo tassa tvaṁ dinnā."
    },
    {
      "id": "thig16.1:16.1",
      "pali": "Aggamahesī bhavissasi,"
    },
    {
      "id": "thig16.1:16.2",
      "pali": "Anikarattassa rājino bhariyā;"
    },
    {
      "id": "thig16.1:16.3",
      "pali": "Sīlāni brahmacariyaṁ,"
    },
    {
      "id": "thig16.1:16.4",
      "pali": "Pabbajjā dukkarā puttaka."
    },
    {
      "id": "thig16.1:17.1",
      "pali": "Rajje āṇā dhanamissariyaṁ,"
    },
    {
      "id": "thig16.1:17.2",
      "pali": "Bhogā sukhā daharikāsi;"
    },
    {
      "id": "thig16.1:17.3",
      "pali": "Bhuñjāhi kāmabhoge,"
    },
    {
      "id": "thig16.1:17.4",
      "pali": "Vāreyyaṁ hotu te putta”."
    },
    {
      "id": "thig16.1:18.1",
      "pali": "Atha ne bhaṇati sumedhā,"
    },
    {
      "id": "thig16.1:18.2",
      "pali": "“Mā edisikāni bhavagatamasāraṁ;"
    },
    {
      "id": "thig16.1:18.3",
      "pali": "Pabbajjā vā hohiti,"
    },
    {
      "id": "thig16.1:18.4",
      "pali": "Maraṇaṁ vā me na ceva vāreyyaṁ."
    },
    {
      "id": "thig16.1:19.1",
      "pali": "Kimiva pūtikāyamasuciṁ,"
    },
    {
      "id": "thig16.1:19.2",
      "pali": "Savanagandhaṁ bhayānakaṁ kuṇapaṁ;"
    },
    {
      "id": "thig16.1:19.3",
      "pali": "Abhisaṁviseyyaṁ bhastaṁ,"
    },
    {
      "id": "thig16.1:19.4",
      "pali": "Asakiṁ paggharitaṁ asucipuṇṇaṁ."
    },
    {
      "id": "thig16.1:20.1",
      "pali": "Kimiva tahaṁ jānantī,"
    },
    {
      "id": "thig16.1:20.2",
      "pali": "Vikūlakaṁ maṁsasoṇitupalittaṁ;"
    },
    {
      "id": "thig16.1:20.3",
      "pali": "Kimikulālayaṁ sakuṇabhattaṁ,"
    },
    {
      "id": "thig16.1:20.4",
      "pali": "Kaḷevaraṁ kissa diyyati."
    },
    {
      "id": "thig16.1:21.1",
      "pali": "Nibbuyhati susānaṁ,"
    },
    {
      "id": "thig16.1:21.2",
      "pali": "Aciraṁ kāyo apetaviññāṇo;"
    },
    {
      "id": "thig16.1:21.3",
      "pali": "Chuddho kaḷiṅgaraṁ viya,"
    },
    {
      "id": "thig16.1:21.4",
      "pali": "Jigucchamānehi ñātīhi."
    },
    {
      "id": "thig16.1:22.1",
      "pali": "Chuddhūna naṁ susāne,"
    },
    {
      "id": "thig16.1:22.2",
      "pali": "Parabhattaṁ nhāyanti jigucchantā;"
    },
    {
      "id": "thig16.1:22.3",
      "pali": "Niyakā mātāpitaro,"
    },
    {
      "id": "thig16.1:22.4",
      "pali": "Kiṁ pana sādhāraṇā janatā."
    },
    {
      "id": "thig16.1:23.1",
      "pali": "Ajjhositā asāre,"
    },
    {
      "id": "thig16.1:23.2",
      "pali": "Kaḷevare aṭṭhinhārusaṅghāte;"
    },
    {
      "id": "thig16.1:23.3",
      "pali": "Kheḷassuccārassava,"
    },
    {
      "id": "thig16.1:23.4",
      "pali": "Paripuṇṇe pūtikāyamhi."
    },
    {
      "id": "thig16.1:24.1",
      "pali": "Yo naṁ vinibbhujitvā,"
    },
    {
      "id": "thig16.1:24.2",
      "pali": "Abbhantaramassa bāhiraṁ kayirā;"
    },
    {
      "id": "thig16.1:24.3",
      "pali": "Gandhassa asahamānā,"
    },
    {
      "id": "thig16.1:24.4",
      "pali": "Sakāpi mātā jiguccheyya."
    },
    {
      "id": "thig16.1:25.1",
      "pali": "Khandhadhātuāyatanaṁ,"
    },
    {
      "id": "thig16.1:25.2",
      "pali": "Saṅkhataṁ jātimūlakaṁ dukkhaṁ;"
    },
    {
      "id": "thig16.1:25.3",
      "pali": "Yoniso anuvicinantī,"
    },
    {
      "id": "thig16.1:25.4",
      "pali": "Vāreyyaṁ kissa iccheyyaṁ."
    },
    {
      "id": "thig16.1:26.1",
      "pali": "Divase divase tisatti,"
    },
    {
      "id": "thig16.1:26.2",
      "pali": "Satāni navanavā pateyyuṁ kāyamhi;"
    },
    {
      "id": "thig16.1:26.3",
      "pali": "Vassasatampi ca ghāto,"
    },
    {
      "id": "thig16.1:26.4",
      "pali": "Seyyo dukkhassa cevaṁ khayo."
    },
    {
      "id": "thig16.1:27.1",
      "pali": "Ajjhupagacche ghātaṁ,"
    },
    {
      "id": "thig16.1:27.2",
      "pali": "Yo viññāyevaṁ satthuno vacanaṁ;"
    },
    {
      "id": "thig16.1:27.3",
      "pali": "‘Dīgho tesaṁ saṁsāro,"
    },
    {
      "id": "thig16.1:27.4",
      "pali": "Punappunaṁ haññamānānaṁ’."
    },
    {
      "id": "thig16.1:28.1",
      "pali": "Devesu manussesu ca,"
    },
    {
      "id": "thig16.1:28.2",
      "pali": "Tiracchānayoniyā asurakāye;"
    },
    {
      "id": "thig16.1:28.3",
      "pali": "Petesu ca nirayesu ca,"
    },
    {
      "id": "thig16.1:28.4",
      "pali": "Aparimitā dissare ghātā."
    },
    {
      "id": "thig16.1:29.1",
      "pali": "Ghātā nirayesu bahū,"
    },
    {
      "id": "thig16.1:29.2",
      "pali": "Vinipātagatassa pīḷiyamānassa;"
    },
    {
      "id": "thig16.1:29.3",
      "pali": "Devesupi attāṇaṁ,"
    },
    {
      "id": "thig16.1:29.4",
      "pali": "Nibbānasukhā paraṁ natthi."
    },
    {
      "id": "thig16.1:30.1",
      "pali": "Pattā te nibbānaṁ,"
    },
    {
      "id": "thig16.1:30.2",
      "pali": "Ye yuttā dasabalassa pāvacane;"
    },
    {
      "id": "thig16.1:30.3",
      "pali": "Appossukkā ghaṭenti,"
    },
    {
      "id": "thig16.1:30.4",
      "pali": "Jātimaraṇappahānāya."
    },
    {
      "id": "thig16.1:31.1",
      "pali": "Ajjeva tātabhinikkha-"
    },
    {
      "id": "thig16.1:31.2",
      "pali": "Missaṁ bhogehi kiṁ asārehi;"
    },
    {
      "id": "thig16.1:31.3",
      "pali": "Nibbinnā me kāmā,"
    },
    {
      "id": "thig16.1:31.4",
      "pali": "Vantasamā tālavatthukatā”."
    },
    {
      "id": "thig16.1:32.1",
      "pali": "Sā cevaṁ bhaṇati pitara-"
    },
    {
      "id": "thig16.1:32.2",
      "pali": "Manīkaratto ca yassa sā dinnā;"
    },
    {
      "id": "thig16.1:32.3",
      "pali": "Upayāsi vāraṇavate,"
    },
    {
      "id": "thig16.1:32.4",
      "pali": "Vāreyyamupaṭṭhite kāle."
    },
    {
      "id": "thig16.1:33.1",
      "pali": "Atha asitanicitamuduke,"
    },
    {
      "id": "thig16.1:33.2",
      "pali": "Kese khaggena chindiya sumedhā;"
    },
    {
      "id": "thig16.1:33.3",
      "pali": "Pāsādaṁ pidahitvā,"
    },
    {
      "id": "thig16.1:33.4",
      "pali": "Paṭhamajjhānaṁ samāpajji."
    },
    {
      "id": "thig16.1:34.1",
      "pali": "Sā ca tahiṁ samāpannā,"
    },
    {
      "id": "thig16.1:34.2",
      "pali": "Anīkaratto ca āgato nagaraṁ;"
    },
    {
      "id": "thig16.1:34.3",
      "pali": "Pāsāde ca sumedhā,"
    },
    {
      "id": "thig16.1:34.4",
      "pali": "Aniccasaññaṁ subhāveti."
    },
    {
      "id": "thig16.1:35.1",
      "pali": "Sā ca manasi karoti,"
    },
    {
      "id": "thig16.1:35.2",
      "pali": "Anīkaratto ca āruhī turitaṁ;"
    },
    {
      "id": "thig16.1:35.3",
      "pali": "Maṇikanakabhūsitaṅgo,"
    },
    {
      "id": "thig16.1:35.4",
      "pali": "Katañjalī yācati sumedhaṁ."
    },
    {
      "id": "thig16.1:36.1",
      "pali": "“Rajje āṇādhanamissa-"
    },
    {
      "id": "thig16.1:36.2",
      "pali": "Riyaṁ bhogā sukhā daharikāsi;"
    },
    {
      "id": "thig16.1:36.3",
      "pali": "Bhuñjāhi kāmabhoge,"
    },
    {
      "id": "thig16.1:36.4",
      "pali": "Kāmasukhā dullabhā loke."
    },
    {
      "id": "thig16.1:37.1",
      "pali": "Nissaṭṭhaṁ te rajjaṁ,"
    },
    {
      "id": "thig16.1:37.2",
      "pali": "Bhoge bhuñjassu dehi dānāni;"
    },
    {
      "id": "thig16.1:37.3",
      "pali": "Mā dummanā ahosi,"
    },
    {
      "id": "thig16.1:37.4",
      "pali": "Mātāpitaro te dukkhitā”."
    },
    {
      "id": "thig16.1:38.1",
      "pali": "Taṁ taṁ bhaṇati sumedhā,"
    },
    {
      "id": "thig16.1:38.2",
      "pali": "Kāmehi anatthikā vigatamohā;"
    },
    {
      "id": "thig16.1:38.3",
      "pali": "“Mā kāme abhinandi,"
    },
    {
      "id": "thig16.1:38.4",
      "pali": "Kāmesvādīnavaṁ passa."
    },
    {
      "id": "thig16.1:39.1",
      "pali": "Cātuddīpo rājā,"
    },
    {
      "id": "thig16.1:39.2",
      "pali": "Mandhātā āsi kāmabhoginamaggo;"
    },
    {
      "id": "thig16.1:39.3",
      "pali": "Atitto kālaṅkato,"
    },
    {
      "id": "thig16.1:39.4",
      "pali": "Na cassa paripūritā icchā."
    },
    {
      "id": "thig16.1:40.1",
      "pali": "Satta ratanāni vasseyya,"
    },
    {
      "id": "thig16.1:40.2",
      "pali": "Vuṭṭhimā dasadisā samantena;"
    },
    {
      "id": "thig16.1:40.3",
      "pali": "Na catthi titti kāmānaṁ,"
    },
    {
      "id": "thig16.1:40.4",
      "pali": "Atittāva maranti narā."
    },
    {
      "id": "thig16.1:41.1",
      "pali": "Asisūnūpamā kāmā,"
    },
    {
      "id": "thig16.1:41.2",
      "pali": "kāmā sappasiropamā;"
    },
    {
      "id": "thig16.1:41.3",
      "pali": "Ukkopamā anudahanti,"
    },
    {
      "id": "thig16.1:41.4",
      "pali": "aṭṭhikaṅkala sannibhā."
    },
    {
      "id": "thig16.1:42.1",
      "pali": "Aniccā adhuvā kāmā,"
    },
    {
      "id": "thig16.1:42.2",
      "pali": "bahudukkhā mahāvisā;"
    },
    {
      "id": "thig16.1:42.3",
      "pali": "Ayoguḷova santatto,"
    },
    {
      "id": "thig16.1:42.4",
      "pali": "aghamūlā dukhapphalā."
    },
    {
      "id": "thig16.1:43.1",
      "pali": "Rukkhapphalūpamā kāmā,"
    },
    {
      "id": "thig16.1:43.2",
      "pali": "maṁsapesūpamā dukhā;"
    },
    {
      "id": "thig16.1:43.3",
      "pali": "Supinopamā vañcaniyā,"
    },
    {
      "id": "thig16.1:43.4",
      "pali": "kāmā yācitakūpamā."
    },
    {
      "id": "thig16.1:44.1",
      "pali": "Sattisūlūpamā kāmā,"
    },
    {
      "id": "thig16.1:44.2",
      "pali": "rogo gaṇḍo aghaṁ nighaṁ;"
    },
    {
      "id": "thig16.1:44.3",
      "pali": "Aṅgārakāsusadisā,"
    },
    {
      "id": "thig16.1:44.4",
      "pali": "aghamūlaṁ bhayaṁ vadho."
    },
    {
      "id": "thig16.1:45.1",
      "pali": "Evaṁ bahudukkhā kāmā,"
    },
    {
      "id": "thig16.1:45.2",
      "pali": "akkhātā antarāyikā;"
    },
    {
      "id": "thig16.1:45.3",
      "pali": "Gacchatha na me bhavagate,"
    },
    {
      "id": "thig16.1:45.4",
      "pali": "vissāso atthi attano."
    },
    {
      "id": "thig16.1:46.1",
      "pali": "Kiṁ mama paro karissati,"
    },
    {
      "id": "thig16.1:46.2",
      "pali": "Attano sīsamhi ḍayhamānamhi;"
    },
    {
      "id": "thig16.1:46.3",
      "pali": "Anubandhe jarāmaraṇe,"
    },
    {
      "id": "thig16.1:46.4",
      "pali": "Tassa ghātāya ghaṭitabbaṁ”."
    },
    {
      "id": "thig16.1:47.1",
      "pali": "Dvāraṁ apāpuritvānahaṁ,"
    },
    {
      "id": "thig16.1:47.2",
      "pali": "Mātāpitaro anīkarattañca;"
    },
    {
      "id": "thig16.1:47.3",
      "pali": "Disvāna chamaṁ nisinne,"
    },
    {
      "id": "thig16.1:47.4",
      "pali": "Rodante idamavocaṁ."
    },
    {
      "id": "thig16.1:48.1",
      "pali": "“Dīgho bālānaṁ saṁsāro,"
    },
    {
      "id": "thig16.1:48.2",
      "pali": "Punappunañca rodataṁ;"
    },
    {
      "id": "thig16.1:48.3",
      "pali": "Anamatagge pitu maraṇe,"
    },
    {
      "id": "thig16.1:48.4",
      "pali": "Bhātu vadhe attano ca vadhe."
    },
    {
      "id": "thig16.1:49.1",
      "pali": "Assu thaññaṁ rudhiraṁ,"
    },
    {
      "id": "thig16.1:49.2",
      "pali": "Saṁsāraṁ anamataggato saratha;"
    },
    {
      "id": "thig16.1:49.3",
      "pali": "Sattānaṁ saṁsarataṁ,"
    },
    {
      "id": "thig16.1:49.4",
      "pali": "Sarāhi aṭṭhīnañca sannicayaṁ."
    },
    {
      "id": "thig16.1:50.1",
      "pali": "Sara caturodadhī,"
    },
    {
      "id": "thig16.1:50.2",
      "pali": "Upanīte assuthaññarudhiramhi;"
    },
    {
      "id": "thig16.1:50.3",
      "pali": "Sara ekakappamaṭṭhīnaṁ,"
    },
    {
      "id": "thig16.1:50.4",
      "pali": "Sañcayaṁ vipulena samaṁ."
    },
    {
      "id": "thig16.1:51.1",
      "pali": "Anamatagge saṁsarato,"
    },
    {
      "id": "thig16.1:51.2",
      "pali": "Mahiṁ jambudīpamupanītaṁ;"
    },
    {
      "id": "thig16.1:51.3",
      "pali": "Kolaṭṭhimattaguḷikā,"
    },
    {
      "id": "thig16.1:51.4",
      "pali": "Mātā mātusveva nappahonti."
    },
    {
      "id": "thig16.1:52.1",
      "pali": "Tiṇakaṭṭhasākhāpalāsaṁ,"
    },
    {
      "id": "thig16.1:52.2",
      "pali": "Upanītaṁ anamataggato sara;"
    },
    {
      "id": "thig16.1:52.3",
      "pali": "Caturaṅgulikā ghaṭikā,"
    },
    {
      "id": "thig16.1:52.4",
      "pali": "Pitupitusveva nappahonti."
    },
    {
      "id": "thig16.1:53.1",
      "pali": "Sara kāṇakacchapaṁ pubba-"
    },
    {
      "id": "thig16.1:53.2",
      "pali": "Samudde aparato ca yugachiddaṁ;"
    },
    {
      "id": "thig16.1:53.3",
      "pali": "Siraṁ tassa ca paṭimukkaṁ,"
    },
    {
      "id": "thig16.1:53.4",
      "pali": "Manussalābhamhi opammaṁ."
    },
    {
      "id": "thig16.1:54.1",
      "pali": "Sara rūpaṁ pheṇapiṇḍopa-"
    },
    {
      "id": "thig16.1:54.2",
      "pali": "Massa kāyakalino asārassa;"
    },
    {
      "id": "thig16.1:54.3",
      "pali": "Khandhe passa anicce,"
    },
    {
      "id": "thig16.1:54.4",
      "pali": "Sarāhi niraye bahuvighāte."
    },
    {
      "id": "thig16.1:55.1",
      "pali": "Sara kaṭasiṁ vaḍḍhente,"
    },
    {
      "id": "thig16.1:55.2",
      "pali": "Punappunaṁ tāsu tāsu jātīsu;"
    },
    {
      "id": "thig16.1:55.3",
      "pali": "Sara kumbhīlabhayāni ca,"
    },
    {
      "id": "thig16.1:55.4",
      "pali": "Sarāhi cattāri saccāni."
    },
    {
      "id": "thig16.1:56.1",
      "pali": "Amatamhi vijjamāne,"
    },
    {
      "id": "thig16.1:56.2",
      "pali": "Kiṁ tava pañcakaṭukena pītena;"
    },
    {
      "id": "thig16.1:56.3",
      "pali": "Sabbā hi kāmaratiyo,"
    },
    {
      "id": "thig16.1:56.4",
      "pali": "Kaṭukatarā pañcakaṭukena."
    },
    {
      "id": "thig16.1:57.1",
      "pali": "Amatamhi vijjamāne,"
    },
    {
      "id": "thig16.1:57.2",
      "pali": "Kiṁ tava kāmehi ye pariḷāhā;"
    },
    {
      "id": "thig16.1:57.3",
      "pali": "Sabbā hi kāmaratiyo,"
    },
    {
      "id": "thig16.1:57.4",
      "pali": "Jalitā kuthitā kampitā santāpitā."
    },
    {
      "id": "thig16.1:58.1",
      "pali": "Asapattamhi samāne,"
    },
    {
      "id": "thig16.1:58.2",
      "pali": "Kiṁ tava kāmehi ye bahusapattā;"
    },
    {
      "id": "thig16.1:58.3",
      "pali": "Rājaggicoraudakappiyehi,"
    },
    {
      "id": "thig16.1:58.4",
      "pali": "Sādhāraṇā kāmā bahusapattā."
    },
    {
      "id": "thig16.1:59.1",
      "pali": "Mokkhamhi vijjamāne,"
    },
    {
      "id": "thig16.1:59.2",
      "pali": "Kiṁ tava kāmehi yesu vadhabandho;"
    },
    {
      "id": "thig16.1:59.3",
      "pali": "Kāmesu hi asakāmā,"
    },
    {
      "id": "thig16.1:59.4",
      "pali": "Vadhabandhadukhāni anubhonti."
    },
    {
      "id": "thig16.1:60.1",
      "pali": "Ādīpitā tiṇukkā,"
    },
    {
      "id": "thig16.1:60.2",
      "pali": "Gaṇhantaṁ dahanti neva muñcantaṁ;"
    },
    {
      "id": "thig16.1:60.3",
      "pali": "Ukkopamā hi kāmā,"
    },
    {
      "id": "thig16.1:60.4",
      "pali": "Dahanti ye te na muñcanti."
    },
    {
      "id": "thig16.1:61.1",
      "pali": "Mā appakassa hetu,"
    },
    {
      "id": "thig16.1:61.2",
      "pali": "Kāmasukhassa vipulaṁ jahī sukhaṁ;"
    },
    {
      "id": "thig16.1:61.3",
      "pali": "Mā puthulomova baḷisaṁ,"
    },
    {
      "id": "thig16.1:61.4",
      "pali": "Gilitvā pacchā vihaññasi."
    },
    {
      "id": "thig16.1:62.1",
      "pali": "Kāmaṁ kāmesu damassu,"
    },
    {
      "id": "thig16.1:62.2",
      "pali": "Tāva sunakhova saṅkhalābaddho;"
    },
    {
      "id": "thig16.1:62.3",
      "pali": "Kāhinti khu taṁ kāmā,"
    },
    {
      "id": "thig16.1:62.4",
      "pali": "Chātā sunakhaṁva caṇḍālā."
    },
    {
      "id": "thig16.1:63.1",
      "pali": "Aparimitañca dukkhaṁ,"
    },
    {
      "id": "thig16.1:63.2",
      "pali": "Bahūni ca cittadomanassāni;"
    },
    {
      "id": "thig16.1:63.3",
      "pali": "Anubhohisi kāmayutto,"
    },
    {
      "id": "thig16.1:63.4",
      "pali": "Paṭinissaja addhuve kāme."
    },
    {
      "id": "thig16.1:64.1",
      "pali": "Ajaramhi vijjamāne,"
    },
    {
      "id": "thig16.1:64.2",
      "pali": "Kiṁ tava kāmehi yesu jarā;"
    },
    {
      "id": "thig16.1:64.3",
      "pali": "Maraṇabyādhigahitā,"
    },
    {
      "id": "thig16.1:64.4",
      "pali": "Sabbā sabbattha jātiyo."
    },
    {
      "id": "thig16.1:65.1",
      "pali": "Idamajaramidamamaraṁ,"
    },
    {
      "id": "thig16.1:65.2",
      "pali": "Idamajarāmaraṁ padamasokaṁ;"
    },
    {
      "id": "thig16.1:65.3",
      "pali": "Asapattamasambādhaṁ,"
    },
    {
      "id": "thig16.1:65.4",
      "pali": "Akhalitamabhayaṁ nirupatāpaṁ."
    },
    {
      "id": "thig16.1:66.1",
      "pali": "Adhigatamidaṁ bahūhi,"
    },
    {
      "id": "thig16.1:66.2",
      "pali": "Amataṁ ajjāpi ca labhanīyamidaṁ;"
    },
    {
      "id": "thig16.1:66.3",
      "pali": "Yo yoniso payuñjati,"
    },
    {
      "id": "thig16.1:66.4",
      "pali": "Na ca sakkā aghaṭamānena”."
    },
    {
      "id": "thig16.1:67.1",
      "pali": "Evaṁ bhaṇati sumedhā,"
    },
    {
      "id": "thig16.1:67.2",
      "pali": "Saṅkhāragate ratiṁ alabhamānā;"
    },
    {
      "id": "thig16.1:67.3",
      "pali": "Anunentī anikarattaṁ,"
    },
    {
      "id": "thig16.1:67.4",
      "pali": "Kese ca chamaṁ khipi sumedhā."
    },
    {
      "id": "thig16.1:68.1",
      "pali": "Uṭṭhāya anikaratto,"
    },
    {
      "id": "thig16.1:68.2",
      "pali": "Pañjaliko yācatassā pitaraṁ so;"
    },
    {
      "id": "thig16.1:68.3",
      "pali": "“Vissajjetha sumedhaṁ,"
    },
    {
      "id": "thig16.1:68.4",
      "pali": "Pabbajituṁ vimokkhasaccadassā”."
    },
    {
      "id": "thig16.1:69.1",
      "pali": "Vissajjitā mātāpitūhi,"
    },
    {
      "id": "thig16.1:69.2",
      "pali": "pabbaji sokabhayabhītā;"
    },
    {
      "id": "thig16.1:69.3",
      "pali": "Cha abhiññā sacchikatā,"
    },
    {
      "id": "thig16.1:69.4",
      "pali": "aggaphalaṁ sikkhamānāya."
    },
    {
      "id": "thig16.1:70.1",
      "pali": "Acchariyamabbhutaṁ taṁ,"
    },
    {
      "id": "thig16.1:70.2",
      "pali": "Nibbānaṁ āsi rājakaññāya;"
    },
    {
      "id": "thig16.1:70.3",
      "pali": "Pubbenivāsacaritaṁ,"
    },
    {
      "id": "thig16.1:70.4",
      "pali": "Yathā byākari pacchime kāle."
    },
    {
      "id": "thig16.1:71.1",
      "pali": "“Bhagavati koṇāgamane,"
    },
    {
      "id": "thig16.1:71.2",
      "pali": "Saṅghārāmamhi navanivesamhi;"
    },
    {
      "id": "thig16.1:71.3",
      "pali": "Sakhiyo tisso janiyo,"
    },
    {
      "id": "thig16.1:71.4",
      "pali": "Vihāradānaṁ adāsimha."
    },
    {
      "id": "thig16.1:72.1",
      "pali": "Dasakkhattuṁ satakkhattuṁ,"
    },
    {
      "id": "thig16.1:72.2",
      "pali": "Dasasatakkhattuṁ satāni ca satakkhattuṁ;"
    },
    {
      "id": "thig16.1:72.3",
      "pali": "Devesu uppajjimha,"
    },
    {
      "id": "thig16.1:72.4",
      "pali": "Ko pana vādo manussesu."
    },
    {
      "id": "thig16.1:73.1",
      "pali": "Devesu mahiddhikā ahumha,"
    },
    {
      "id": "thig16.1:73.2",
      "pali": "Mānusakamhi ko pana vādo;"
    },
    {
      "id": "thig16.1:73.3",
      "pali": "Sattaratanassa mahesī,"
    },
    {
      "id": "thig16.1:73.4",
      "pali": "Itthiratanaṁ ahaṁ āsiṁ."
    },
    {
      "id": "thig16.1:74.1",
      "pali": "So hetu so pabhavo,"
    },
    {
      "id": "thig16.1:74.2",
      "pali": "Taṁ mūlaṁ sāva sāsane khantī;"
    },
    {
      "id": "thig16.1:74.3",
      "pali": "Taṁ paṭhamasamodhānaṁ,"
    },
    {
      "id": "thig16.1:74.4",
      "pali": "Taṁ dhammaratāya nibbānaṁ."
    },
    {
      "id": "thig16.1:75.1",
      "pali": "Evaṁ karonti ye sadda-"
    },
    {
      "id": "thig16.1:75.2",
      "pali": "Hanti vacanaṁ anomapaññassa;"
    },
    {
      "id": "thig16.1:75.3",
      "pali": "Nibbindanti bhavagate,"
    },
    {
      "id": "thig16.1:75.4",
      "pali": "Nibbinditvā virajjantī”ti."
    },
    {
      "id": "thig16.1:76.1",
      "pali": "Itthaṁ sudaṁ sumedhā therī gāthāyo abhāsitthāti."
    },
    {
      "id": "thig16.1:76.2",
      "pali": "Mahānipāto niṭṭhito."
    },
    {
      "id": "thig16.1:77.1",
      "pali": "Gāthāsatāni cattāri,"
    },
    {
      "id": "thig16.1:77.2",
      "pali": "asīti puna cuddasa;"
    },
    {
      "id": "thig16.1:77.3",
      "pali": "Theriyekuttarasatā,"
    },
    {
      "id": "thig16.1:77.4",
      "pali": "sabbā tā āsavakkhayāti."
    },
    {
      "id": "thig16.1:77.5",
      "pali": "Therīgāthāpāḷi niṭṭhitā."
    }
  ]
}
