{
  "uid": "tha-ap549",
  "title": "Abhayattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap549:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap549:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "tha-ap549:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap549:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "tha-ap549:2.1",
      "pali": "Saraṇagamane kiñci,"
    },
    {
      "id": "tha-ap549:2.2",
      "pali": "nivesesi tathāgato;"
    },
    {
      "id": "tha-ap549:2.3",
      "pali": "Kiñci sīle nivesesi,"
    },
    {
      "id": "tha-ap549:2.4",
      "pali": "dasakammapathuttame."
    },
    {
      "id": "tha-ap549:3.1",
      "pali": "Deti kassaci so vīro,"
    },
    {
      "id": "tha-ap549:3.2",
      "pali": "sāmaññaphalamuttamaṁ;"
    },
    {
      "id": "tha-ap549:3.3",
      "pali": "Samāpattī tathā aṭṭha,"
    },
    {
      "id": "tha-ap549:3.4",
      "pali": "tisso vijjā pavecchati."
    },
    {
      "id": "tha-ap549:4.1",
      "pali": "Chaḷabhiññāsu yojesi,"
    },
    {
      "id": "tha-ap549:4.2",
      "pali": "kiñci sattaṁ naruttamo;"
    },
    {
      "id": "tha-ap549:4.3",
      "pali": "Deti kassaci nātho so,"
    },
    {
      "id": "tha-ap549:4.4",
      "pali": "catasso paṭisambhidā."
    },
    {
      "id": "tha-ap549:5.1",
      "pali": "Bodhaneyyaṁ pajaṁ disvā,"
    },
    {
      "id": "tha-ap549:5.2",
      "pali": "asaṅkheyyampi yojanaṁ;"
    },
    {
      "id": "tha-ap549:5.3",
      "pali": "Khaṇena upagantvāna,"
    },
    {
      "id": "tha-ap549:5.4",
      "pali": "vineti narasārathi."
    },
    {
      "id": "tha-ap549:6.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap549:6.2",
      "pali": "ahosiṁ brāhmaṇatrajo;"
    },
    {
      "id": "tha-ap549:6.3",
      "pali": "Pāragū sabbavedānaṁ,"
    },
    {
      "id": "tha-ap549:6.4",
      "pali": "veyyākaraṇasammato."
    },
    {
      "id": "tha-ap549:7.1",
      "pali": "Niruttiyā ca kusalo,"
    },
    {
      "id": "tha-ap549:7.2",
      "pali": "nighaṇḍumhi visārado;"
    },
    {
      "id": "tha-ap549:7.3",
      "pali": "Padako keṭubhavidū,"
    },
    {
      "id": "tha-ap549:7.4",
      "pali": "chandovicitikovido."
    },
    {
      "id": "tha-ap549:8.1",
      "pali": "Jaṅghāvihāraṁ vicaraṁ,"
    },
    {
      "id": "tha-ap549:8.2",
      "pali": "haṁsārāmamupeccahaṁ;"
    },
    {
      "id": "tha-ap549:8.3",
      "pali": "Addasaṁ varadaṁ seṭṭhaṁ,"
    },
    {
      "id": "tha-ap549:8.4",
      "pali": "mahājanapurakkhataṁ."
    },
    {
      "id": "tha-ap549:9.1",
      "pali": "Desentaṁ virajaṁ dhammaṁ,"
    },
    {
      "id": "tha-ap549:9.2",
      "pali": "paccanīkamatī ahaṁ;"
    },
    {
      "id": "tha-ap549:9.3",
      "pali": "Upetvā tassa kalyāṇaṁ,"
    },
    {
      "id": "tha-ap549:9.4",
      "pali": "sutvāna vimalaṁ ahaṁ."
    },
    {
      "id": "tha-ap549:10.1",
      "pali": "Byāhataṁ punaruttaṁ vā,"
    },
    {
      "id": "tha-ap549:10.2",
      "pali": "apatthaṁ vā niratthakaṁ;"
    },
    {
      "id": "tha-ap549:10.3",
      "pali": "Nāddasaṁ tassa munino,"
    },
    {
      "id": "tha-ap549:10.4",
      "pali": "tato pabbajito ahaṁ."
    },
    {
      "id": "tha-ap549:11.1",
      "pali": "Nacireneva kālena,"
    },
    {
      "id": "tha-ap549:11.2",
      "pali": "sabbasattavisārado;"
    },
    {
      "id": "tha-ap549:11.3",
      "pali": "Nipuṇo buddhavacane,"
    },
    {
      "id": "tha-ap549:11.4",
      "pali": "ahosiṁ guṇisammato."
    },
    {
      "id": "tha-ap549:12.1",
      "pali": "Tadā catasso gāthāyo,"
    },
    {
      "id": "tha-ap549:12.2",
      "pali": "ganthayitvā subyañjanā;"
    },
    {
      "id": "tha-ap549:12.3",
      "pali": "Santhavitvā tilokaggaṁ,"
    },
    {
      "id": "tha-ap549:12.4",
      "pali": "desayissaṁ dine dine."
    },
    {
      "id": "tha-ap549:13.1",
      "pali": "‘Virattosi mahāvīro,"
    },
    {
      "id": "tha-ap549:13.2",
      "pali": "saṁsāre sabhaye vasaṁ;"
    },
    {
      "id": "tha-ap549:13.3",
      "pali": "Karuṇāya na nibbāyi,"
    },
    {
      "id": "tha-ap549:13.4",
      "pali": "tato kāruṇiko muni."
    },
    {
      "id": "tha-ap549:14.1",
      "pali": "Puthujjano vayo santo,"
    },
    {
      "id": "tha-ap549:14.2",
      "pali": "na kilesavaso ahu;"
    },
    {
      "id": "tha-ap549:14.3",
      "pali": "Sampajāno satiyutto,"
    },
    {
      "id": "tha-ap549:14.4",
      "pali": "tasmā eso acintiyo."
    },
    {
      "id": "tha-ap549:15.1",
      "pali": "Dubbalāni kilesāni,"
    },
    {
      "id": "tha-ap549:15.2",
      "pali": "yassāsayagatāni me;"
    },
    {
      "id": "tha-ap549:15.3",
      "pali": "Ñāṇaggiparidaḍḍhāni,"
    },
    {
      "id": "tha-ap549:15.4",
      "pali": "na khīyiṁsu tamabbhutaṁ."
    },
    {
      "id": "tha-ap549:16.1",
      "pali": "Yo sabbalokassa garu,"
    },
    {
      "id": "tha-ap549:16.2",
      "pali": "loko yassa tathā garu;"
    },
    {
      "id": "tha-ap549:16.3",
      "pali": "Tathāpi lokācariyo,"
    },
    {
      "id": "tha-ap549:16.4",
      "pali": "loko tassānuvattako’."
    },
    {
      "id": "tha-ap549:17.1",
      "pali": "Evamādīhi sambuddhaṁ,"
    },
    {
      "id": "tha-ap549:17.2",
      "pali": "kittayaṁ dhammadesanaṁ;"
    },
    {
      "id": "tha-ap549:17.3",
      "pali": "Yāvajīvaṁ karitvāna,"
    },
    {
      "id": "tha-ap549:17.4",
      "pali": "gato saggaṁ tato cuto."
    },
    {
      "id": "tha-ap549:18.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap549:18.2",
      "pali": "yaṁ buddhamabhikittayiṁ;"
    },
    {
      "id": "tha-ap549:18.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap549:18.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap549:19.1",
      "pali": "Devaloke mahārajjaṁ,"
    },
    {
      "id": "tha-ap549:19.2",
      "pali": "pādesiṁ kañcanagghiyaṁ;"
    },
    {
      "id": "tha-ap549:19.3",
      "pali": "Cakkavattī mahārajjaṁ,"
    },
    {
      "id": "tha-ap549:19.4",
      "pali": "bahusonubhaviṁ ahaṁ."
    },
    {
      "id": "tha-ap549:20.1",
      "pali": "Duve bhave pajāyāmi,"
    },
    {
      "id": "tha-ap549:20.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap549:20.3",
      "pali": "Aññaṁ gatiṁ na jānāmi,"
    },
    {
      "id": "tha-ap549:20.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap549:21.1",
      "pali": "Duve kule pajāyāmi,"
    },
    {
      "id": "tha-ap549:21.2",
      "pali": "khattiye atha brāhmaṇe;"
    },
    {
      "id": "tha-ap549:21.3",
      "pali": "Nīce kule na jāyāmi,"
    },
    {
      "id": "tha-ap549:21.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap549:22.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap549:22.2",
      "pali": "giribbajapuruttame;"
    },
    {
      "id": "tha-ap549:22.3",
      "pali": "Raññohaṁ bimbisārassa,"
    },
    {
      "id": "tha-ap549:22.4",
      "pali": "putto nāmena cābhayo."
    },
    {
      "id": "tha-ap549:23.1",
      "pali": "Pāpamittavasaṁ gantvā,"
    },
    {
      "id": "tha-ap549:23.2",
      "pali": "nigaṇṭhena vimohito;"
    },
    {
      "id": "tha-ap549:23.3",
      "pali": "Pesito nāṭaputtena,"
    },
    {
      "id": "tha-ap549:23.4",
      "pali": "buddhaseṭṭhamupeccahaṁ."
    },
    {
      "id": "tha-ap549:24.1",
      "pali": "Pucchitvā nipuṇaṁ pañhaṁ,"
    },
    {
      "id": "tha-ap549:24.2",
      "pali": "sutvā byākaraṇuttamaṁ;"
    },
    {
      "id": "tha-ap549:24.3",
      "pali": "Pabbajitvāna naciraṁ,"
    },
    {
      "id": "tha-ap549:24.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap549:25.1",
      "pali": "Kittayitvā jinavaraṁ,"
    },
    {
      "id": "tha-ap549:25.2",
      "pali": "kittito homi sabbadā;"
    },
    {
      "id": "tha-ap549:25.3",
      "pali": "Sugandhadehavadano,"
    },
    {
      "id": "tha-ap549:25.4",
      "pali": "āsiṁ sukhasamappito."
    },
    {
      "id": "tha-ap549:26.1",
      "pali": "Tikkhahāsalahupañño,"
    },
    {
      "id": "tha-ap549:26.2",
      "pali": "mahāpañño tathevahaṁ;"
    },
    {
      "id": "tha-ap549:26.3",
      "pali": "Vicittapaṭibhāno ca,"
    },
    {
      "id": "tha-ap549:26.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap549:27.1",
      "pali": "Abhitthavitvā padumuttarāhaṁ,"
    },
    {
      "id": "tha-ap549:27.2",
      "pali": "Pasannacitto asamaṁ sayambhuṁ;"
    },
    {
      "id": "tha-ap549:27.3",
      "pali": "Na gacchi kappāni apāyabhūmiṁ,"
    },
    {
      "id": "tha-ap549:27.4",
      "pali": "Sataṁsahassāni balena tassa."
    },
    {
      "id": "tha-ap549:28.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap549:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap549:28.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap549:29.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap549:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap549:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap549:30.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap549:30.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap549:30.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap549:31.1",
      "pali": "Itthaṁ sudaṁ āyasmā abhayo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap549:32.1",
      "pali": "Abhayattherassāpadānaṁ sattamaṁ."
    }
  ]
}
