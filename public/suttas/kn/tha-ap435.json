{
  "uid": "tha-ap435",
  "title": "3 Pāṭihīrasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap435:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap435:1.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap435:1.3",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap435:1.4",
      "pali": "nagaraṁ pāvisī tadā."
    },
    {
      "id": "tha-ap435:2.1",
      "pali": "Nagaraṁ pavisantassa,"
    },
    {
      "id": "tha-ap435:2.2",
      "pali": "upasantassa tādino;"
    },
    {
      "id": "tha-ap435:2.3",
      "pali": "Ratanāni pajjotiṁsu,"
    },
    {
      "id": "tha-ap435:2.4",
      "pali": "nigghoso āsi tāvade."
    },
    {
      "id": "tha-ap435:3.1",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap435:3.2",
      "pali": "bherī vajjumaghaṭṭitā;"
    },
    {
      "id": "tha-ap435:3.3",
      "pali": "Sayaṁ vīṇā pavajjanti,"
    },
    {
      "id": "tha-ap435:3.4",
      "pali": "buddhassa pavisato puraṁ."
    },
    {
      "id": "tha-ap435:4.1",
      "pali": "Buddhaseṭṭhaṁ namassāmi,"
    },
    {
      "id": "tha-ap435:4.2",
      "pali": "padumuttaramahāmuniṁ;"
    },
    {
      "id": "tha-ap435:4.3",
      "pali": "Pāṭihīrañca passitvā,"
    },
    {
      "id": "tha-ap435:4.4",
      "pali": "tattha cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap435:5.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap435:5.2",
      "pali": "aho no satthusampadā;"
    },
    {
      "id": "tha-ap435:5.3",
      "pali": "Acetanāpi turiyā,"
    },
    {
      "id": "tha-ap435:5.4",
      "pali": "sayameva pavajjare."
    },
    {
      "id": "tha-ap435:6.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap435:6.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap435:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap435:6.4",
      "pali": "buddhasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap435:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap435:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap435:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap435:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap435:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap435:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap435:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap435:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap435:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap435:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāṭihīrasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap435:11.1",
      "pali": "Pāṭihīrasaññakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
