{
  "uid": "tha-ap260",
  "title": "Paṇṇadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap260:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap260:1.2",
      "pali": "vākacīradharo ahaṁ;"
    },
    {
      "id": "tha-ap260:1.3",
      "pali": "Aloṇapaṇṇabhakkhomhi,"
    },
    {
      "id": "tha-ap260:1.4",
      "pali": "niyamesu ca saṁvuto."
    },
    {
      "id": "tha-ap260:2.1",
      "pali": "Pātarāse anuppatte,"
    },
    {
      "id": "tha-ap260:2.2",
      "pali": "siddhattho upagacchi maṁ;"
    },
    {
      "id": "tha-ap260:2.3",
      "pali": "Tāhaṁ buddhassa pādāsiṁ,"
    },
    {
      "id": "tha-ap260:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap260:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap260:3.2",
      "pali": "yaṁ paṇṇamadadiṁ tadā;"
    },
    {
      "id": "tha-ap260:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap260:3.4",
      "pali": "paṇṇadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap260:4.1",
      "pali": "Sattavīsatikappamhi,"
    },
    {
      "id": "tha-ap260:4.2",
      "pali": "rājā āsiṁ sadatthiyo;"
    },
    {
      "id": "tha-ap260:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap260:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap260:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap260:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap260:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap260:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā paṇṇadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap260:7.1",
      "pali": "Paṇṇadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
