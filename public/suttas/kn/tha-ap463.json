{
  "uid": "tha-ap463",
  "title": "Sālakusumiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap463:1.1",
      "pali": "“Parinibbute bhagavati,"
    },
    {
      "id": "tha-ap463:1.2",
      "pali": "jalajuttamanāmake;"
    },
    {
      "id": "tha-ap463:1.3",
      "pali": "Āropitamhi citake,"
    },
    {
      "id": "tha-ap463:1.4",
      "pali": "sālapupphamapūjayiṁ."
    },
    {
      "id": "tha-ap463:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap463:2.2",
      "pali": "Yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap463:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap463:2.4",
      "pali": "Citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap463:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap463:3.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap463:3.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap463:3.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap463:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap463:4.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap463:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap463:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap463:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap463:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap463:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap463:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap463:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sālakusumiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap463:7.1",
      "pali": "Sālakusumiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
