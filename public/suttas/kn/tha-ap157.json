{
  "uid": "tha-ap157",
  "title": "5 Mandāravapupphapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap157:1.1",
      "pali": "“Devaputto ahaṁ santo,"
    },
    {
      "id": "tha-ap157:1.2",
      "pali": "pūjayiṁ sikhināyakaṁ;"
    },
    {
      "id": "tha-ap157:1.3",
      "pali": "Mandāravena pupphena,"
    },
    {
      "id": "tha-ap157:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap157:2.1",
      "pali": "Sattāhaṁ chadanaṁ āsi,"
    },
    {
      "id": "tha-ap157:2.2",
      "pali": "dibbaṁ mālaṁ tathāgate;"
    },
    {
      "id": "tha-ap157:2.3",
      "pali": "Sabbe janā samāgantvā,"
    },
    {
      "id": "tha-ap157:2.4",
      "pali": "namassiṁsu tathāgataṁ."
    },
    {
      "id": "tha-ap157:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap157:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap157:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap157:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap157:4.1",
      "pali": "Ito ca dasame kappe,"
    },
    {
      "id": "tha-ap157:4.2",
      "pali": "rājāhosiṁ jutindharo;"
    },
    {
      "id": "tha-ap157:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap157:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap157:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap157:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap157:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap157:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā mandāravapupphapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap157:7.1",
      "pali": "Mandāravapupphapūjakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
