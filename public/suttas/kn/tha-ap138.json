{
  "uid": "tha-ap138",
  "title": "Campakapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap138:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap138:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap138:1.3",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap138:1.4",
      "pali": "osadhiṁ viya tārakaṁ."
    },
    {
      "id": "tha-ap138:2.1",
      "pali": "Tayo māṇavakā āsuṁ,"
    },
    {
      "id": "tha-ap138:2.2",
      "pali": "sake sippe susikkhitā;"
    },
    {
      "id": "tha-ap138:2.3",
      "pali": "Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap138:2.4",
      "pali": "anventi mama pacchato."
    },
    {
      "id": "tha-ap138:3.1",
      "pali": "Puṭake satta pupphāni,"
    },
    {
      "id": "tha-ap138:3.2",
      "pali": "nikkhittāni tapassinā;"
    },
    {
      "id": "tha-ap138:3.3",
      "pali": "Gahetvā tāni ñāṇamhi,"
    },
    {
      "id": "tha-ap138:3.4",
      "pali": "vessabhussābhiropayiṁ."
    },
    {
      "id": "tha-ap138:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap138:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap138:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap138:4.4",
      "pali": "ñāṇapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap138:5.1",
      "pali": "Ekūnatiṁsakappamhi,"
    },
    {
      "id": "tha-ap138:5.2",
      "pali": "vipulābhasanāmako;"
    },
    {
      "id": "tha-ap138:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap138:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap138:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap138:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap138:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap138:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā campakapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap138:8.1",
      "pali": "Campakapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
