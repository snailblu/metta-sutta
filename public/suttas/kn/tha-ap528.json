{
  "uid": "tha-ap528",
  "title": "Daṇḍadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap528:1.1",
      "pali": "“Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap528:1.2",
      "pali": "veḷuṁ chetvānahaṁ tadā;"
    },
    {
      "id": "tha-ap528:1.3",
      "pali": "Ālambaṇaṁ karitvāna,"
    },
    {
      "id": "tha-ap528:1.4",
      "pali": "saṅghassa adadiṁ bahuṁ."
    },
    {
      "id": "tha-ap528:2.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap528:2.2",
      "pali": "subbate abhivādiya;"
    },
    {
      "id": "tha-ap528:2.3",
      "pali": "Ālambadaṇḍaṁ datvāna,"
    },
    {
      "id": "tha-ap528:2.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap528:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap528:3.2",
      "pali": "yaṁ daṇḍamadadiṁ tadā;"
    },
    {
      "id": "tha-ap528:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap528:3.4",
      "pali": "daṇḍadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap528:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap528:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap528:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap528:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap528:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap528:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap528:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap528:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap528:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap528:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā daṇḍadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap528:8.1",
      "pali": "Daṇḍadāyakattherassāpadānaṁ chaṭṭhaṁ."
    },
    {
      "id": "tha-ap528:8.2",
      "pali": "Tevīsatimaṁ bhāṇavāraṁ."
    }
  ]
}
