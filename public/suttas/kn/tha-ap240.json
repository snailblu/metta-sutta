{
  "uid": "tha-ap240",
  "title": "Ambayāgadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap240:1.1",
      "pali": "“Sake sippe apatthaddho,"
    },
    {
      "id": "tha-ap240:1.2",
      "pali": "agamaṁ kānanaṁ ahaṁ;"
    },
    {
      "id": "tha-ap240:1.3",
      "pali": "Sambuddhaṁ yantaṁ disvāna,"
    },
    {
      "id": "tha-ap240:1.4",
      "pali": "ambayāgaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap240:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap240:2.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap240:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap240:2.4",
      "pali": "ambayāgassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap240:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap240:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap240:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap240:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambayāgadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap240:5.1",
      "pali": "Ambayāgadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
