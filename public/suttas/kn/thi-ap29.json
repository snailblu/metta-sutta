{
  "uid": "thi-ap29",
  "title": "9 Yasodharāpamukhadasabhikkhunīsahassaapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap29:1.1",
      "pali": "“Kappe ca satasahasse,"
    },
    {
      "id": "thi-ap29:1.2",
      "pali": "caturo ca asaṅkhiye;"
    },
    {
      "id": "thi-ap29:1.3",
      "pali": "Dīpaṅkaro nāma jino,"
    },
    {
      "id": "thi-ap29:1.4",
      "pali": "uppajji lokanāyako."
    },
    {
      "id": "thi-ap29:2.1",
      "pali": "Dīpaṅkaro mahāvīro,"
    },
    {
      "id": "thi-ap29:2.2",
      "pali": "viyākāsi vināyako;"
    },
    {
      "id": "thi-ap29:2.3",
      "pali": "Sumedhañca sumittañca,"
    },
    {
      "id": "thi-ap29:2.4",
      "pali": "samānasukhadukkhataṁ."
    },
    {
      "id": "thi-ap29:3.1",
      "pali": "Sadevakañca passanto,"
    },
    {
      "id": "thi-ap29:3.2",
      "pali": "vicaranto sadevakaṁ;"
    },
    {
      "id": "thi-ap29:3.3",
      "pali": "Tesaṁ pakittane amhe,"
    },
    {
      "id": "thi-ap29:3.4",
      "pali": "upagamma samāgamaṁ."
    },
    {
      "id": "thi-ap29:4.1",
      "pali": "Amhaṁ sabbapati hohi,"
    },
    {
      "id": "thi-ap29:4.2",
      "pali": "anāgatasamāgame;"
    },
    {
      "id": "thi-ap29:4.3",
      "pali": "Sabbāva tuyhaṁ bhariyā,"
    },
    {
      "id": "thi-ap29:4.4",
      "pali": "manāpā piyavādikā."
    },
    {
      "id": "thi-ap29:5.1",
      "pali": "Dānaṁ sīlamayaṁ sabbaṁ,"
    },
    {
      "id": "thi-ap29:5.2",
      "pali": "bhāvanā ca subhāvitā;"
    },
    {
      "id": "thi-ap29:5.3",
      "pali": "Dīgharattañca no sabbaṁ,"
    },
    {
      "id": "thi-ap29:5.4",
      "pali": "pariccattaṁ mahāmune."
    },
    {
      "id": "thi-ap29:6.1",
      "pali": "Gandhaṁ vilepanaṁ mālaṁ,"
    },
    {
      "id": "thi-ap29:6.2",
      "pali": "dīpañca ratanāmayaṁ;"
    },
    {
      "id": "thi-ap29:6.3",
      "pali": "Yaṁ kiñci patthitaṁ sabbaṁ,"
    },
    {
      "id": "thi-ap29:6.4",
      "pali": "pariccattaṁ mahāmuni."
    },
    {
      "id": "thi-ap29:7.1",
      "pali": "Aññaṁ vāpi kataṁ kammaṁ,"
    },
    {
      "id": "thi-ap29:7.2",
      "pali": "paribhogañca mānusaṁ;"
    },
    {
      "id": "thi-ap29:7.3",
      "pali": "Dīgharattañhi no sabbaṁ,"
    },
    {
      "id": "thi-ap29:7.4",
      "pali": "pariccattaṁ mahāmuni."
    },
    {
      "id": "thi-ap29:8.1",
      "pali": "Anekajātisaṁsāraṁ,"
    },
    {
      "id": "thi-ap29:8.2",
      "pali": "bahuṁ puññampi no kataṁ;"
    },
    {
      "id": "thi-ap29:8.3",
      "pali": "Issaramanubhotvāna,"
    },
    {
      "id": "thi-ap29:8.4",
      "pali": "saṁsaritvā bhavābhave."
    },
    {
      "id": "thi-ap29:9.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "thi-ap29:9.2",
      "pali": "sakyaputtanivesane;"
    },
    {
      "id": "thi-ap29:9.3",
      "pali": "Nānākulūpapannāyo,"
    },
    {
      "id": "thi-ap29:9.4",
      "pali": "accharā kāmavaṇṇinī."
    },
    {
      "id": "thi-ap29:10.1",
      "pali": "Lābhaggena yasaṁ pattā,"
    },
    {
      "id": "thi-ap29:10.2",
      "pali": "pūjitā sabbasakkatā;"
    },
    {
      "id": "thi-ap29:10.3",
      "pali": "Lābhiyo annapānānaṁ,"
    },
    {
      "id": "thi-ap29:10.4",
      "pali": "sadā sammānitā mayaṁ."
    },
    {
      "id": "thi-ap29:11.1",
      "pali": "Agāraṁ pajahitvāna,"
    },
    {
      "id": "thi-ap29:11.2",
      "pali": "pabbajimhanagāriyaṁ;"
    },
    {
      "id": "thi-ap29:11.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "thi-ap29:11.4",
      "pali": "sabbā pattāmha nibbutiṁ."
    },
    {
      "id": "thi-ap29:12.1",
      "pali": "Lābhiyo annapānānaṁ,"
    },
    {
      "id": "thi-ap29:12.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "thi-ap29:12.3",
      "pali": "Upenti paccayā sabbe,"
    },
    {
      "id": "thi-ap29:12.4",
      "pali": "sadā sakkatapūjitā."
    },
    {
      "id": "thi-ap29:13.1",
      "pali": "Kilesā jhāpitā amhaṁ,"
    },
    {
      "id": "thi-ap29:13.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap29:13.3",
      "pali": "viharāma anāsavā."
    },
    {
      "id": "thi-ap29:14.1",
      "pali": "Svāgataṁ vata no āsi,"
    },
    {
      "id": "thi-ap29:14.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap29:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap29:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap29:15.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap29:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap29:16.1",
      "pali": "Itthaṁ sudaṁ yasodharāpamukhāni dasabhikkhunīsahassāni bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap29:17.1",
      "pali": "Yasodharāpamukhadasabhikkhunīsahassāpadānaṁ navamaṁ."
    }
  ]
}
