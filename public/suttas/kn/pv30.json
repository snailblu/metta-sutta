{
  "uid": "pv30",
  "title": "5. Kumārapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv30:1.1",
      "pali": "Accherarūpaṁ sugatassa ñāṇaṁ,"
    },
    {
      "id": "pv30:1.2",
      "pali": "Satthā yathā puggalaṁ byākāsi;"
    },
    {
      "id": "pv30:1.3",
      "pali": "Ussannapuññāpi bhavanti heke,"
    },
    {
      "id": "pv30:1.4",
      "pali": "Parittapuññāpi bhavanti heke."
    },
    {
      "id": "pv30:2.1",
      "pali": "Ayaṁ kumāro sīvathikāya chaḍḍito,"
    },
    {
      "id": "pv30:2.2",
      "pali": "Aṅguṭṭhasnehena yāpeti rattiṁ;"
    },
    {
      "id": "pv30:2.3",
      "pali": "Na yakkhabhūtā na sarīsapā vā,"
    },
    {
      "id": "pv30:2.4",
      "pali": "Viheṭhayeyyuṁ katapuññaṁ kumāraṁ."
    },
    {
      "id": "pv30:3.1",
      "pali": "Sunakhāpimassa palihiṁsu pāde,"
    },
    {
      "id": "pv30:3.2",
      "pali": "Dhaṅkā siṅgālā parivattayanti;"
    },
    {
      "id": "pv30:3.3",
      "pali": "Gabbhāsayaṁ pakkhigaṇā haranti,"
    },
    {
      "id": "pv30:3.4",
      "pali": "Kākā pana akkhimalaṁ haranti."
    },
    {
      "id": "pv30:4.1",
      "pali": "Nayimassa rakkhaṁ vidahiṁsu keci,"
    },
    {
      "id": "pv30:4.2",
      "pali": "Na osadhaṁ sāsapadhūpanaṁ vā;"
    },
    {
      "id": "pv30:4.3",
      "pali": "Nakkhattayogampi na aggahesuṁ,"
    },
    {
      "id": "pv30:4.4",
      "pali": "Na sabbadhaññānipi ākiriṁsu."
    },
    {
      "id": "pv30:5.1",
      "pali": "Etādisaṁ uttamakicchapattaṁ,"
    },
    {
      "id": "pv30:5.2",
      "pali": "Rattābhataṁ sīvathikāya chaḍḍitaṁ;"
    },
    {
      "id": "pv30:5.3",
      "pali": "Nonītapiṇḍaṁva pavedhamānaṁ,"
    },
    {
      "id": "pv30:5.4",
      "pali": "Sasaṁsayaṁ jīvitasāvasesaṁ."
    },
    {
      "id": "pv30:6.1",
      "pali": "Tamaddasā devamanussapūjito,"
    },
    {
      "id": "pv30:6.2",
      "pali": "Disvā ca taṁ byākari bhūripañño;"
    },
    {
      "id": "pv30:6.3",
      "pali": "“Ayaṁ kumāro nagarassimassa,"
    },
    {
      "id": "pv30:6.4",
      "pali": "Aggakuliko bhavissati bhogato ca”."
    },
    {
      "id": "pv30:7.1",
      "pali": "“Kissa vataṁ kiṁ pana brahmacariyaṁ,"
    },
    {
      "id": "pv30:7.2",
      "pali": "Kissa suciṇṇassa ayaṁ vipāko;"
    },
    {
      "id": "pv30:7.3",
      "pali": "Etādisaṁ byasanaṁ pāpuṇitvā,"
    },
    {
      "id": "pv30:7.4",
      "pali": "Taṁ tādisaṁ paccanubhossatiddhin”ti."
    },
    {
      "id": "pv30:8.1",
      "pali": "Buddhapamukhassa bhikkhusaṅghassa,"
    },
    {
      "id": "pv30:8.2",
      "pali": "Pūjaṁ akāsi janatā uḷāraṁ;"
    },
    {
      "id": "pv30:8.3",
      "pali": "Tatrassa cittassahu aññathattaṁ,"
    },
    {
      "id": "pv30:8.4",
      "pali": "Vācaṁ abhāsi pharusaṁ asabbhaṁ."
    },
    {
      "id": "pv30:9.1",
      "pali": "So taṁ vitakkaṁ pavinodayitvā,"
    },
    {
      "id": "pv30:9.2",
      "pali": "Pītiṁ pasādaṁ paṭiladdhā pacchā;"
    },
    {
      "id": "pv30:9.3",
      "pali": "Tathāgataṁ jetavane vasantaṁ,"
    },
    {
      "id": "pv30:9.4",
      "pali": "Yāguyā upaṭṭhāsi sattarattaṁ."
    },
    {
      "id": "pv30:10.1",
      "pali": "Tassa vataṁ taṁ pana brahmacariyaṁ,"
    },
    {
      "id": "pv30:10.2",
      "pali": "Tassa suciṇṇassa ayaṁ vipāko;"
    },
    {
      "id": "pv30:10.3",
      "pali": "Etādisaṁ byasanaṁ pāpuṇitvā,"
    },
    {
      "id": "pv30:10.4",
      "pali": "Taṁ tādisaṁ paccanubhossatiddhiṁ."
    },
    {
      "id": "pv30:11.1",
      "pali": "Ṭhatvāna so vassasataṁ idheva,"
    },
    {
      "id": "pv30:11.2",
      "pali": "Sabbehi kāmehi samaṅgibhūto;"
    },
    {
      "id": "pv30:11.3",
      "pali": "Kāyassa bhedā abhisamparāyaṁ,"
    },
    {
      "id": "pv30:11.4",
      "pali": "Sahabyataṁ gacchati vāsavassāti."
    },
    {
      "id": "pv30:12.1",
      "pali": "Kumārapetavatthu pañcamaṁ."
    }
  ]
}
