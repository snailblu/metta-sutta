{
  "uid": "iti32",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti32:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti32:2.1",
      "pali": "“Dvīhi, bhikkhave, dhammehi samannāgato puggalo yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "iti32:2.2",
      "pali": "Katamehi dvīhi?"
    },
    {
      "id": "iti32:2.3",
      "pali": "Pāpakena ca sīlena, pāpikāya ca diṭṭhiyā."
    },
    {
      "id": "iti32:2.4",
      "pali": "Imehi kho, bhikkhave, dvīhi dhammehi samannāgato puggalo yathābhataṁ nikkhitto evaṁ niraye”ti."
    },
    {
      "id": "iti32:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti32:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti32:3.1",
      "pali": "“Pāpakena ca sīlena,"
    },
    {
      "id": "iti32:3.2",
      "pali": "pāpikāya ca diṭṭhiyā;"
    },
    {
      "id": "iti32:3.3",
      "pali": "Etehi dvīhi dhammehi,"
    },
    {
      "id": "iti32:3.4",
      "pali": "yo samannāgato naro;"
    },
    {
      "id": "iti32:3.5",
      "pali": "Kāyassa bhedā duppañño,"
    },
    {
      "id": "iti32:3.6",
      "pali": "nirayaṁ sopapajjatī”ti."
    },
    {
      "id": "iti32:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti32:4.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
