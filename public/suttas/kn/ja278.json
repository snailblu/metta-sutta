{
  "uid": "ja278",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja278:1.1",
      "pali": "“Kimatthamabhisandhāya,"
    },
    {
      "id": "ja278:1.2",
      "pali": "lahucittassa dubbhino;"
    },
    {
      "id": "ja278:1.3",
      "pali": "Sabbakāmadadasseva,"
    },
    {
      "id": "ja278:1.4",
      "pali": "imaṁ dukkhaṁ titikkhasi."
    },
    {
      "id": "ja278:2.1",
      "pali": "Siṅgena nihanāhetaṁ,"
    },
    {
      "id": "ja278:2.2",
      "pali": "padasā ca adhiṭṭhaha;"
    },
    {
      "id": "ja278:2.3",
      "pali": "Bhiyyo bālā pakujjheyyuṁ,"
    },
    {
      "id": "ja278:2.4",
      "pali": "no cassa paṭisedhako”."
    },
    {
      "id": "ja278:3.1",
      "pali": "“Mamevāyaṁ maññamāno,"
    },
    {
      "id": "ja278:3.2",
      "pali": "aññepevaṁ karissati;"
    },
    {
      "id": "ja278:3.3",
      "pali": "Te naṁ tattha vadhissanti,"
    },
    {
      "id": "ja278:3.4",
      "pali": "sā me mutti bhavissatī”ti."
    },
    {
      "id": "ja278:4.1",
      "pali": "Mahiṁsarājajātakaṁ aṭṭhamaṁ."
    }
  ]
}
