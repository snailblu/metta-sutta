{
  "uid": "ja475",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja475:1.1",
      "pali": "“Kuṭhārihattho puriso,"
    },
    {
      "id": "ja475:1.2",
      "pali": "vanamogayha tiṭṭhasi;"
    },
    {
      "id": "ja475:1.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja475:1.4",
      "pali": "kiṁ dāruṁ chetumicchasi”."
    },
    {
      "id": "ja475:2.1",
      "pali": "“Isso vanāni carasi,"
    },
    {
      "id": "ja475:2.2",
      "pali": "samāni visamāni ca;"
    },
    {
      "id": "ja475:2.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja475:2.4",
      "pali": "kiṁ dāruṁ nemiyā daḷhaṁ”."
    },
    {
      "id": "ja475:3.1",
      "pali": "“Neva sālo na khadiro,"
    },
    {
      "id": "ja475:3.2",
      "pali": "nāssakaṇṇo kuto dhavo;"
    },
    {
      "id": "ja475:3.3",
      "pali": "Rukkho ca phandano nāma,"
    },
    {
      "id": "ja475:3.4",
      "pali": "taṁ dāruṁ nemiyā daḷhaṁ”."
    },
    {
      "id": "ja475:4.1",
      "pali": "“Kīdisānissa pattāni,"
    },
    {
      "id": "ja475:4.2",
      "pali": "khandho vā pana kīdiso;"
    },
    {
      "id": "ja475:4.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja475:4.4",
      "pali": "yathā jānemu phandanaṁ”."
    },
    {
      "id": "ja475:5.1",
      "pali": "“Yassa sākhā palambanti,"
    },
    {
      "id": "ja475:5.2",
      "pali": "namanti na ca bhañjare;"
    },
    {
      "id": "ja475:5.3",
      "pali": "So rukkho phandano nāma,"
    },
    {
      "id": "ja475:5.4",
      "pali": "yassa mūle ahaṁ ṭhito."
    },
    {
      "id": "ja475:6.1",
      "pali": "Arānaṁ cakkanābhīnaṁ,"
    },
    {
      "id": "ja475:6.2",
      "pali": "īsānemirathassa ca;"
    },
    {
      "id": "ja475:6.3",
      "pali": "Sabbassa te kammaniyo,"
    },
    {
      "id": "ja475:6.4",
      "pali": "ayaṁ hessati phandano”."
    },
    {
      "id": "ja475:7.1",
      "pali": "“Iti phandanarukkhopi,"
    },
    {
      "id": "ja475:7.2",
      "pali": "tāvade ajjhabhāsatha;"
    },
    {
      "id": "ja475:7.3",
      "pali": "Mayhampi vacanaṁ atthi,"
    },
    {
      "id": "ja475:7.4",
      "pali": "bhāradvāja suṇohi me."
    },
    {
      "id": "ja475:8.1",
      "pali": "Issassa upakkhandhamhā,"
    },
    {
      "id": "ja475:8.2",
      "pali": "Ukkacca caturaṅgulaṁ;"
    },
    {
      "id": "ja475:8.3",
      "pali": "Tena nemiṁ pasāresi,"
    },
    {
      "id": "ja475:8.4",
      "pali": "Evaṁ daḷhataraṁ siyā."
    },
    {
      "id": "ja475:9.1",
      "pali": "Iti phandanarukkhopi,"
    },
    {
      "id": "ja475:9.2",
      "pali": "veraṁ appesi tāvade;"
    },
    {
      "id": "ja475:9.3",
      "pali": "Jātānañca ajātānaṁ,"
    },
    {
      "id": "ja475:9.4",
      "pali": "issānaṁ dukkhamāvahi."
    },
    {
      "id": "ja475:10.1",
      "pali": "Iccevaṁ phandano issaṁ,"
    },
    {
      "id": "ja475:10.2",
      "pali": "isso ca pana phandanaṁ;"
    },
    {
      "id": "ja475:10.3",
      "pali": "Aññamaññaṁ vivādena,"
    },
    {
      "id": "ja475:10.4",
      "pali": "aññamaññamaghātayuṁ."
    },
    {
      "id": "ja475:11.1",
      "pali": "Evameva manussānaṁ,"
    },
    {
      "id": "ja475:11.2",
      "pali": "vivādo yattha jāyati;"
    },
    {
      "id": "ja475:11.3",
      "pali": "Mayūranaccaṁ naccanti,"
    },
    {
      "id": "ja475:11.4",
      "pali": "yathā te issaphandanā."
    },
    {
      "id": "ja475:12.1",
      "pali": "Taṁ vo vadāmi bhaddaṁ vo,"
    },
    {
      "id": "ja475:12.2",
      "pali": "yāvantettha samāgatā;"
    },
    {
      "id": "ja475:12.3",
      "pali": "Sammodatha mā vivadatha,"
    },
    {
      "id": "ja475:12.4",
      "pali": "mā hotha issaphandanā."
    },
    {
      "id": "ja475:13.1",
      "pali": "Sāmaggimeva sikkhetha,"
    },
    {
      "id": "ja475:13.2",
      "pali": "buddhehetaṁ pasaṁsitaṁ;"
    },
    {
      "id": "ja475:13.3",
      "pali": "Sāmaggirato dhammaṭṭho,"
    },
    {
      "id": "ja475:13.4",
      "pali": "yogakkhemā na dhaṁsatī”ti."
    },
    {
      "id": "ja475:14.1",
      "pali": "Phandanajātakaṁ dutiyaṁ."
    }
  ]
}
