{
  "uid": "pv25",
  "title": "13. Ubbaripetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv25:1.1",
      "pali": "Ahu rājā brahmadatto,"
    },
    {
      "id": "pv25:1.2",
      "pali": "pañcālānaṁ rathesabho;"
    },
    {
      "id": "pv25:1.3",
      "pali": "Ahorattānamaccayā,"
    },
    {
      "id": "pv25:1.4",
      "pali": "rājā kālamakrubbatha."
    },
    {
      "id": "pv25:2.1",
      "pali": "Tassa āḷāhanaṁ gantvā,"
    },
    {
      "id": "pv25:2.2",
      "pali": "bhariyā kandati ubbarī;"
    },
    {
      "id": "pv25:2.3",
      "pali": "Brahmadattaṁ apassantī,"
    },
    {
      "id": "pv25:2.4",
      "pali": "brahmadattāti kandati."
    },
    {
      "id": "pv25:3.1",
      "pali": "Isi ca tattha āgacchi,"
    },
    {
      "id": "pv25:3.2",
      "pali": "sampannacaraṇo muni;"
    },
    {
      "id": "pv25:3.3",
      "pali": "So ca tattha apucchittha,"
    },
    {
      "id": "pv25:3.4",
      "pali": "ye tattha susamāgatā."
    },
    {
      "id": "pv25:4.1",
      "pali": "“Kassa idaṁ āḷāhanaṁ,"
    },
    {
      "id": "pv25:4.2",
      "pali": "nānāgandhasameritaṁ;"
    },
    {
      "id": "pv25:4.3",
      "pali": "Kassāyaṁ kandati bhariyā,"
    },
    {
      "id": "pv25:4.4",
      "pali": "ito dūragataṁ patiṁ;"
    },
    {
      "id": "pv25:4.5",
      "pali": "Brahmadattaṁ apassantī,"
    },
    {
      "id": "pv25:4.6",
      "pali": "‘brahmadattā’ti kandati”."
    },
    {
      "id": "pv25:5.1",
      "pali": "Te ca tattha viyākaṁsu,"
    },
    {
      "id": "pv25:5.2",
      "pali": "ye tattha susamāgatā;"
    },
    {
      "id": "pv25:5.3",
      "pali": "“Brahmadattassa bhadante,"
    },
    {
      "id": "pv25:5.4",
      "pali": "brahmadattassa mārisa."
    },
    {
      "id": "pv25:6.1",
      "pali": "Tassa idaṁ āḷāhanaṁ,"
    },
    {
      "id": "pv25:6.2",
      "pali": "nānāgandhasameritaṁ;"
    },
    {
      "id": "pv25:6.3",
      "pali": "Tassāyaṁ kandati bhariyā,"
    },
    {
      "id": "pv25:6.4",
      "pali": "ito dūragataṁ patiṁ;"
    },
    {
      "id": "pv25:6.5",
      "pali": "Brahmadattaṁ apassantī,"
    },
    {
      "id": "pv25:6.6",
      "pali": "‘brahmadattā’ti kandati”."
    },
    {
      "id": "pv25:7.1",
      "pali": "“Chaḷāsītisahassāni,"
    },
    {
      "id": "pv25:7.2",
      "pali": "brahmadattassanāmakā;"
    },
    {
      "id": "pv25:7.3",
      "pali": "Imasmiṁ āḷāhane daḍḍhā,"
    },
    {
      "id": "pv25:7.4",
      "pali": "tesaṁ kamanusocasī”ti."
    },
    {
      "id": "pv25:8.1",
      "pali": "“Yo rājā cūḷanīputto,"
    },
    {
      "id": "pv25:8.2",
      "pali": "pañcālānaṁ rathesabho;"
    },
    {
      "id": "pv25:8.3",
      "pali": "Taṁ bhante anusocāmi,"
    },
    {
      "id": "pv25:8.4",
      "pali": "bhattāraṁ sabbakāmadan”ti."
    },
    {
      "id": "pv25:9.1",
      "pali": "“Sabbe vāhesuṁ rājāno,"
    },
    {
      "id": "pv25:9.2",
      "pali": "brahmadattassanāmakā;"
    },
    {
      "id": "pv25:9.3",
      "pali": "Sabbeva cūḷanīputtā,"
    },
    {
      "id": "pv25:9.4",
      "pali": "pañcālānaṁ rathesabhā."
    },
    {
      "id": "pv25:10.1",
      "pali": "Sabbesaṁ anupubbena,"
    },
    {
      "id": "pv25:10.2",
      "pali": "mahesittamakārayi;"
    },
    {
      "id": "pv25:10.3",
      "pali": "Kasmā purimake hitvā,"
    },
    {
      "id": "pv25:10.4",
      "pali": "pacchimaṁ anusocasī”ti."
    },
    {
      "id": "pv25:11.1",
      "pali": "“Ātume itthibhūtāya,"
    },
    {
      "id": "pv25:11.2",
      "pali": "dīgharattāya mārisa;"
    },
    {
      "id": "pv25:11.3",
      "pali": "Yassā me itthibhūtāya,"
    },
    {
      "id": "pv25:11.4",
      "pali": "saṁsāre bahubhāsasī”ti."
    },
    {
      "id": "pv25:12.1",
      "pali": "“Ahu itthī ahu puriso,"
    },
    {
      "id": "pv25:12.2",
      "pali": "pasuyonimpi āgamā;"
    },
    {
      "id": "pv25:12.3",
      "pali": "Evametaṁ atītānaṁ,"
    },
    {
      "id": "pv25:12.4",
      "pali": "pariyanto na dissatī”ti."
    },
    {
      "id": "pv25:13.1",
      "pali": "“Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "pv25:13.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "pv25:13.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "pv25:13.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "pv25:14.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "pv25:14.2",
      "pali": "sokaṁ hadayanissitaṁ;"
    },
    {
      "id": "pv25:14.3",
      "pali": "Yo me sokaparetāya,"
    },
    {
      "id": "pv25:14.4",
      "pali": "patisokaṁ apānudi."
    },
    {
      "id": "pv25:15.1",
      "pali": "Sāhaṁ abbūḷhasallāsmi,"
    },
    {
      "id": "pv25:15.2",
      "pali": "sītibhūtāsmi nibbutā;"
    },
    {
      "id": "pv25:15.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "pv25:15.4",
      "pali": "tava sutvā mahāmunī”ti."
    },
    {
      "id": "pv25:16.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "pv25:16.2",
      "pali": "samaṇassa subhāsitaṁ;"
    },
    {
      "id": "pv25:16.3",
      "pali": "Pattacīvaramādāya,"
    },
    {
      "id": "pv25:16.4",
      "pali": "pabbaji anagāriyaṁ."
    },
    {
      "id": "pv25:17.1",
      "pali": "Sā ca pabbajitā santā,"
    },
    {
      "id": "pv25:17.2",
      "pali": "agārasmā anagāriyaṁ;"
    },
    {
      "id": "pv25:17.3",
      "pali": "Mettacittaṁ abhāvesi,"
    },
    {
      "id": "pv25:17.4",
      "pali": "brahmalokūpapattiyā."
    },
    {
      "id": "pv25:18.1",
      "pali": "Gāmā gāmaṁ vicarantī,"
    },
    {
      "id": "pv25:18.2",
      "pali": "nigame rājadhāniyo;"
    },
    {
      "id": "pv25:18.3",
      "pali": "Uruvelā nāma so gāmo,"
    },
    {
      "id": "pv25:18.4",
      "pali": "yattha kālamakrubbatha."
    },
    {
      "id": "pv25:19.1",
      "pali": "Mettacittaṁ ābhāvetvā,"
    },
    {
      "id": "pv25:19.2",
      "pali": "brahmalokūpapattiyā;"
    },
    {
      "id": "pv25:19.3",
      "pali": "Itthicittaṁ virājetvā,"
    },
    {
      "id": "pv25:19.4",
      "pali": "brahmalokūpagā ahūti."
    },
    {
      "id": "pv25:20.1",
      "pali": "Ubbaripetavatthu terasamaṁ."
    },
    {
      "id": "pv25:21.1",
      "pali": "Ubbarivaggo dutiyo."
    },
    {
      "id": "pv25:22.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "pv25:23.1",
      "pali": "Mocakaṁ mātā mattā ca,"
    },
    {
      "id": "pv25:23.2",
      "pali": "Nandā kuṇḍalīnā ghaṭo;"
    },
    {
      "id": "pv25:23.3",
      "pali": "Dve seṭṭhī tunnavāyo ca,"
    },
    {
      "id": "pv25:23.4",
      "pali": "Uttara suttakaṇṇa ubbarīti."
    }
  ]
}
