{
  "uid": "iti39",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti39:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti39:2.1",
      "pali": "“Tathāgatassa, bhikkhave, arahato sammāsambuddhassa dve dhammadesanā pariyāyena bhavanti."
    },
    {
      "id": "iti39:2.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "iti39:2.3",
      "pali": "‘Pāpaṁ pāpakato passathā’ti—"
    },
    {
      "id": "iti39:2.4",
      "pali": "ayaṁ paṭhamā dhammadesanā;"
    },
    {
      "id": "iti39:2.5",
      "pali": "‘pāpaṁ pāpakato disvā tattha nibbindatha virajjatha vimuccathā’ti—"
    },
    {
      "id": "iti39:2.6",
      "pali": "ayaṁ dutiyā dhammadesanā."
    },
    {
      "id": "iti39:2.7",
      "pali": "Tathāgatassa, bhikkhave, arahato sammāsambuddhassa imā dve dhammadesanā pariyāyena bhavantī”ti."
    },
    {
      "id": "iti39:2.8",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti39:2.9",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti39:3.1",
      "pali": "“Tathāgatassa buddhassa,"
    },
    {
      "id": "iti39:3.2",
      "pali": "sabbabhūtānukampino;"
    },
    {
      "id": "iti39:3.3",
      "pali": "Pariyāyavacanaṁ passa,"
    },
    {
      "id": "iti39:3.4",
      "pali": "dve ca dhammā pakāsitā."
    },
    {
      "id": "iti39:4.1",
      "pali": "Pāpakaṁ passatha cetaṁ,"
    },
    {
      "id": "iti39:4.2",
      "pali": "tattha cāpi virajjatha;"
    },
    {
      "id": "iti39:4.3",
      "pali": "Tato virattacittāse,"
    },
    {
      "id": "iti39:4.4",
      "pali": "dukkhassantaṁ karissathā”ti."
    },
    {
      "id": "iti39:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti39:5.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
