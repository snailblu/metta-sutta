{
  "uid": "bv25",
  "title": "25. Koṇāgamanabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv25:1.1",
      "pali": "“Kakusandhassa aparena,"
    },
    {
      "id": "bv25:1.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "bv25:1.3",
      "pali": "Koṇāgamano nāma jino,"
    },
    {
      "id": "bv25:1.4",
      "pali": "lokajeṭṭho narāsabho."
    },
    {
      "id": "bv25:2.1",
      "pali": "Dasa dhamme pūrayitvāna,"
    },
    {
      "id": "bv25:2.2",
      "pali": "kantāraṁ samatikkami;"
    },
    {
      "id": "bv25:2.3",
      "pali": "Pavāhiya malaṁ sabbaṁ,"
    },
    {
      "id": "bv25:2.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "bv25:3.1",
      "pali": "Dhammacakkaṁ pavattente,"
    },
    {
      "id": "bv25:3.2",
      "pali": "koṇāgamananāyake;"
    },
    {
      "id": "bv25:3.3",
      "pali": "Tiṁsakoṭisahassānaṁ,"
    },
    {
      "id": "bv25:3.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv25:4.1",
      "pali": "Pāṭihīraṁ karonte ca,"
    },
    {
      "id": "bv25:4.2",
      "pali": "paravādappamaddane;"
    },
    {
      "id": "bv25:4.3",
      "pali": "Vīsatikoṭisahassānaṁ,"
    },
    {
      "id": "bv25:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv25:5.1",
      "pali": "Tato vikubbanaṁ katvā,"
    },
    {
      "id": "bv25:5.2",
      "pali": "jino devapuraṁ gato;"
    },
    {
      "id": "bv25:5.3",
      "pali": "Vasate tattha sambuddho,"
    },
    {
      "id": "bv25:5.4",
      "pali": "silāya paṇḍukambale."
    },
    {
      "id": "bv25:6.1",
      "pali": "Pakaraṇe satta desento,"
    },
    {
      "id": "bv25:6.2",
      "pali": "vassaṁ vasati so muni;"
    },
    {
      "id": "bv25:6.3",
      "pali": "Dasakoṭisahassānaṁ,"
    },
    {
      "id": "bv25:6.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv25:7.1",
      "pali": "Tassāpi devadevassa,"
    },
    {
      "id": "bv25:7.2",
      "pali": "eko āsi samāgamo;"
    },
    {
      "id": "bv25:7.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv25:7.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv25:8.1",
      "pali": "Tiṁsabhikkhusahassānaṁ,"
    },
    {
      "id": "bv25:8.2",
      "pali": "tadā āsi samāgamo;"
    },
    {
      "id": "bv25:8.3",
      "pali": "Oghānamatikkantānaṁ,"
    },
    {
      "id": "bv25:8.4",
      "pali": "bhijjitānañca maccuyā."
    },
    {
      "id": "bv25:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv25:9.2",
      "pali": "pabbato nāma khattiyo;"
    },
    {
      "id": "bv25:9.3",
      "pali": "Mittāmaccehi sampanno,"
    },
    {
      "id": "bv25:9.4",
      "pali": "anantabalavāhano."
    },
    {
      "id": "bv25:10.1",
      "pali": "Sambuddhadassanaṁ gantvā,"
    },
    {
      "id": "bv25:10.2",
      "pali": "sutvā dhammamanuttaraṁ;"
    },
    {
      "id": "bv25:10.3",
      "pali": "Nimantetvā sajinasaṅghaṁ,"
    },
    {
      "id": "bv25:10.4",
      "pali": "dānaṁ datvā yadicchakaṁ."
    },
    {
      "id": "bv25:11.1",
      "pali": "Pattuṇṇaṁ cīnapaṭṭañca,"
    },
    {
      "id": "bv25:11.2",
      "pali": "koseyyaṁ kambalampi ca;"
    },
    {
      "id": "bv25:11.3",
      "pali": "Sovaṇṇapādukañceva,"
    },
    {
      "id": "bv25:11.4",
      "pali": "adāsiṁ satthusāvake."
    },
    {
      "id": "bv25:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv25:12.2",
      "pali": "saṅghamajjhe nisīdiya;"
    },
    {
      "id": "bv25:12.3",
      "pali": "‘Imamhi bhaddake kappe,"
    },
    {
      "id": "bv25:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv25:13.1",
      "pali": "Ahu kapilavhayā rammā,"
    },
    {
      "id": "bv25:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv25:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv25:14.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv25:14.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv25:14.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv25:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv25:15.1",
      "pali": "Sabbaññutaṁ gavesanto,"
    },
    {
      "id": "bv25:15.2",
      "pali": "dānaṁ datvā naruttame;"
    },
    {
      "id": "bv25:15.3",
      "pali": "Ohāyāhaṁ mahārajjaṁ,"
    },
    {
      "id": "bv25:15.4",
      "pali": "pabbajiṁ jinasantike."
    },
    {
      "id": "bv25:16.1",
      "pali": "Nagaraṁ sobhavatī nāma,"
    },
    {
      "id": "bv25:16.2",
      "pali": "sobho nāmāsi khattiyo;"
    },
    {
      "id": "bv25:16.3",
      "pali": "Vasate tattha nagare,"
    },
    {
      "id": "bv25:16.4",
      "pali": "sambuddhassa mahākulaṁ."
    },
    {
      "id": "bv25:17.1",
      "pali": "Brāhmaṇo yaññadatto ca,"
    },
    {
      "id": "bv25:17.2",
      "pali": "āsi buddhassa so pitā;"
    },
    {
      "id": "bv25:17.3",
      "pali": "Uttarā nāma janikā,"
    },
    {
      "id": "bv25:17.4",
      "pali": "koṇāgamanassa satthuno."
    },
    {
      "id": "bv25:18.1",
      "pali": "Tīṇi vassasahassāni,"
    },
    {
      "id": "bv25:18.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv25:18.3",
      "pali": "Tusitasantusitasantuṭṭhā,"
    },
    {
      "id": "bv25:18.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv25:19.1",
      "pali": "Anūnasoḷasasahassāni,"
    },
    {
      "id": "bv25:19.2",
      "pali": "Nāriyo samalaṅkatā;"
    },
    {
      "id": "bv25:19.3",
      "pali": "Rucigattā nāma nārī,"
    },
    {
      "id": "bv25:19.4",
      "pali": "Satthavāho nāma atrajo."
    },
    {
      "id": "bv25:20.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv25:20.2",
      "pali": "hatthiyānena nikkhami;"
    },
    {
      "id": "bv25:20.3",
      "pali": "Chamāsaṁ padhānacāraṁ,"
    },
    {
      "id": "bv25:20.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv25:21.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv25:21.2",
      "pali": "koṇāgamananāyako;"
    },
    {
      "id": "bv25:21.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv25:21.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv25:22.1",
      "pali": "Bhiyyaso uttaro nāma,"
    },
    {
      "id": "bv25:22.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv25:22.3",
      "pali": "Sotthijo nāmupaṭṭhāko,"
    },
    {
      "id": "bv25:22.4",
      "pali": "koṇāgamanassa satthuno."
    },
    {
      "id": "bv25:23.1",
      "pali": "Samuddā uttarā ceva,"
    },
    {
      "id": "bv25:23.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv25:23.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv25:23.4",
      "pali": "udumbaroti pavuccati."
    },
    {
      "id": "bv25:24.1",
      "pali": "Uggo ca somadevo ca,"
    },
    {
      "id": "bv25:24.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv25:24.3",
      "pali": "Sīvalā ceva sāmā ca,"
    },
    {
      "id": "bv25:24.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv25:25.1",
      "pali": "Uccattanena so buddho,"
    },
    {
      "id": "bv25:25.2",
      "pali": "tiṁsahatthasamuggato;"
    },
    {
      "id": "bv25:25.3",
      "pali": "Ukkāmukhe yathā kambu,"
    },
    {
      "id": "bv25:25.4",
      "pali": "evaṁ raṁsīhi maṇḍito."
    },
    {
      "id": "bv25:26.1",
      "pali": "Tiṁsavassasahassāni,"
    },
    {
      "id": "bv25:26.2",
      "pali": "āyu buddhassa tāvade;"
    },
    {
      "id": "bv25:26.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv25:26.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv25:27.1",
      "pali": "Dhammacetiṁ samussetvā,"
    },
    {
      "id": "bv25:27.2",
      "pali": "dhammadussavibhūsitaṁ;"
    },
    {
      "id": "bv25:27.3",
      "pali": "Dhammapupphaguḷaṁ katvā,"
    },
    {
      "id": "bv25:27.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv25:28.1",
      "pali": "Mahāvilāso tassa jano,"
    },
    {
      "id": "bv25:28.2",
      "pali": "siridhammappakāsano;"
    },
    {
      "id": "bv25:28.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv25:28.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv25:29.1",
      "pali": "Koṇāgamano sambuddho,"
    },
    {
      "id": "bv25:29.2",
      "pali": "Pabbatārāmamhi nibbuto;"
    },
    {
      "id": "bv25:29.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv25:29.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv25:30.1",
      "pali": "Koṇāgamanassa bhagavato vaṁso tevīsatimo."
    }
  ]
}
