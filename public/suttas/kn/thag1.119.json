{
  "uid": "thag1.119",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.119:1.1",
      "pali": "“Rukkhamūlagahanaṁ pasakkiya,"
    },
    {
      "id": "thag1.119:1.2",
      "pali": "Nibbānaṁ hadayasmiṁ opiya;"
    },
    {
      "id": "thag1.119:1.3",
      "pali": "Jhāya gotama mā ca pamādo,"
    },
    {
      "id": "thag1.119:1.4",
      "pali": "Kiṁ te biḷibiḷikā karissatī”ti."
    },
    {
      "id": "thag1.119:1.5",
      "pali": "… Vajjiputto thero …."
    }
  ]
}
