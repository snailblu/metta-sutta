{
  "uid": "ja409",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja409:1.1",
      "pali": "“Ahañce daḷhadhammassa,"
    },
    {
      "id": "ja409:1.2",
      "pali": "vahantī nābhirādhayiṁ;"
    },
    {
      "id": "ja409:1.3",
      "pali": "Dharantī urasi sallaṁ,"
    },
    {
      "id": "ja409:1.4",
      "pali": "yuddhe vikkantacārinī."
    },
    {
      "id": "ja409:2.1",
      "pali": "Nūna rājā na jānāti,"
    },
    {
      "id": "ja409:2.2",
      "pali": "mama vikkamaporisaṁ;"
    },
    {
      "id": "ja409:2.3",
      "pali": "Saṅgāme sukatantāni,"
    },
    {
      "id": "ja409:2.4",
      "pali": "dūtavippahitāni ca."
    },
    {
      "id": "ja409:3.1",
      "pali": "Sā nūnāhaṁ marissāmi,"
    },
    {
      "id": "ja409:3.2",
      "pali": "abandhu aparāyinī;"
    },
    {
      "id": "ja409:3.3",
      "pali": "Tadā hi kumbhakārassa,"
    },
    {
      "id": "ja409:3.4",
      "pali": "dinnā chakaṇahārikā”."
    },
    {
      "id": "ja409:4.1",
      "pali": "“Yāvatāsīsatī poso,"
    },
    {
      "id": "ja409:4.2",
      "pali": "tāvadeva pavīṇati;"
    },
    {
      "id": "ja409:4.3",
      "pali": "Atthāpāye jahanti naṁ,"
    },
    {
      "id": "ja409:4.4",
      "pali": "oṭṭhibyādhiṁva khattiyo."
    },
    {
      "id": "ja409:5.1",
      "pali": "Yo pubbe katakalyāṇo,"
    },
    {
      "id": "ja409:5.2",
      "pali": "katattho nāvabujjhati;"
    },
    {
      "id": "ja409:5.3",
      "pali": "Atthā tassa palujjanti,"
    },
    {
      "id": "ja409:5.4",
      "pali": "ye honti abhipatthitā."
    },
    {
      "id": "ja409:6.1",
      "pali": "Yo pubbe katakalyāṇo,"
    },
    {
      "id": "ja409:6.2",
      "pali": "katattho manubujjhati;"
    },
    {
      "id": "ja409:6.3",
      "pali": "Atthā tassa pavaḍḍhanti,"
    },
    {
      "id": "ja409:6.4",
      "pali": "ye honti abhipatthitā."
    },
    {
      "id": "ja409:7.1",
      "pali": "Taṁ vo vadāmi bhaddante,"
    },
    {
      "id": "ja409:7.2",
      "pali": "yāvantettha samāgatā;"
    },
    {
      "id": "ja409:7.3",
      "pali": "Sabbe kataññuno hotha,"
    },
    {
      "id": "ja409:7.4",
      "pali": "ciraṁ saggamhi ṭhassathā”ti."
    },
    {
      "id": "ja409:8.1",
      "pali": "Daḷhadhammajātakaṁ catutthaṁ."
    }
  ]
}
