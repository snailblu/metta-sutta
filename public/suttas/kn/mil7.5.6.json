{
  "uid": "mil7.5.6",
  "title": "Upacikāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.5.6:1.1",
      "pali": "“Bhante nāgasena, ‘jarasiṅgālassa dve aṅgāni gahetabbānī’ti yaṁ vadesi, katamāni tāni dve aṅgāni gahetabbānī”ti?"
    },
    {
      "id": "mil7.5.6:1.2",
      "pali": "“Yathā, mahārāja, jarasiṅgālo bhojanaṁ paṭilabhitvā ajigucchamāno yāvadatthaṁ āharayati;"
    },
    {
      "id": "mil7.5.6:1.3",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena bhojanaṁ paṭilabhitvā ajigucchamānena sarīrayāpanamattameva paribhuñjitabbaṁ."
    },
    {
      "id": "mil7.5.6:1.4",
      "pali": "Idaṁ, mahārāja, jarasiṅgālassa paṭhamaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.5.6:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, therena mahākassapena—"
    },
    {
      "id": "mil7.5.6:2.1",
      "pali": "‘Senāsanamhā oruyha,"
    },
    {
      "id": "mil7.5.6:2.2",
      "pali": "gāmaṁ piṇḍāya pāvisiṁ;"
    },
    {
      "id": "mil7.5.6:2.3",
      "pali": "Bhuñjantaṁ purisaṁ kuṭṭhiṁ,"
    },
    {
      "id": "mil7.5.6:2.4",
      "pali": "sakkacca naṁ upaṭṭhahiṁ."
    },
    {
      "id": "mil7.5.6:3.1",
      "pali": "So me pakkena hatthena,"
    },
    {
      "id": "mil7.5.6:3.2",
      "pali": "ālopaṁ upanāmayi;"
    },
    {
      "id": "mil7.5.6:3.3",
      "pali": "Ālopaṁ pakkhipantassa,"
    },
    {
      "id": "mil7.5.6:3.4",
      "pali": "aṅgulipettha chijjatha."
    },
    {
      "id": "mil7.5.6:4.1",
      "pali": "Kuṭṭamūlañca nissāya,"
    },
    {
      "id": "mil7.5.6:4.2",
      "pali": "ālopaṁ taṁ abhuñjisaṁ;"
    },
    {
      "id": "mil7.5.6:4.3",
      "pali": "Bhuñjamāne vā bhutte vā,"
    },
    {
      "id": "mil7.5.6:4.4",
      "pali": "jegucchaṁ me na vijjatī’ti."
    },
    {
      "id": "mil7.5.6:5.1",
      "pali": "Puna caparaṁ, mahārāja, jarasiṅgālo bhojanaṁ paṭilabhitvā na vicināti lūkhaṁ vā paṇītaṁ vāti;"
    },
    {
      "id": "mil7.5.6:5.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena bhojanaṁ paṭilabhitvā na vicinitabbaṁ ‘lūkhaṁ vā paṇītaṁ vā sampannaṁ vā asampannaṁ vā’ti, yathāladdhena santussitabbaṁ."
    },
    {
      "id": "mil7.5.6:5.3",
      "pali": "Idaṁ, mahārāja, jarasiṅgālassa dutiyaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.5.6:5.4",
      "pali": "Bhāsitampetaṁ, mahārāja, therena upasenena vaṅgantaputtena—"
    },
    {
      "id": "mil7.5.6:6.1",
      "pali": "‘Lūkhenapi ca santusse,"
    },
    {
      "id": "mil7.5.6:6.2",
      "pali": "nāññaṁ patthe rasaṁ bahuṁ;"
    },
    {
      "id": "mil7.5.6:6.3",
      "pali": "Rasesu anugiddhassa,"
    },
    {
      "id": "mil7.5.6:6.4",
      "pali": "jhāne na ramate mano;"
    },
    {
      "id": "mil7.5.6:6.5",
      "pali": "Itarītarena santuṭṭho,"
    },
    {
      "id": "mil7.5.6:6.6",
      "pali": "sāmaññaṁ paripūratī’”ti."
    },
    {
      "id": "mil7.5.6:7.1",
      "pali": "Jarasiṅgālaṅgapañho chaṭṭho."
    }
  ]
}
