{
  "uid": "iti29",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti29:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti29:2.1",
      "pali": "“Dvīhi, bhikkhave, dhammehi samannāgato bhikkhu diṭṭheva dhamme sukhaṁ viharati avighātaṁ anupāyāsaṁ apariḷāhaṁ;"
    },
    {
      "id": "iti29:2.2",
      "pali": "kāyassa bhedā paraṁ maraṇā sugati pāṭikaṅkhā."
    },
    {
      "id": "iti29:2.3",
      "pali": "Katamehi dvīhi?"
    },
    {
      "id": "iti29:2.4",
      "pali": "Indriyesu guttadvāratāya ca, bhojane mattaññutāya ca."
    },
    {
      "id": "iti29:2.5",
      "pali": "Imehi kho, bhikkhave, dvīhi dhammehi samannāgato bhikkhu diṭṭheva dhamme sukhaṁ viharati avighātaṁ anupāyāsaṁ apariḷāhaṁ;"
    },
    {
      "id": "iti29:2.6",
      "pali": "kāyassa bhedā paraṁ maraṇā sugati pāṭikaṅkhā”ti."
    },
    {
      "id": "iti29:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti29:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti29:3.1",
      "pali": "“Cakkhu sotañca ghānañca,"
    },
    {
      "id": "iti29:3.2",
      "pali": "jivhā kāyo tathā mano;"
    },
    {
      "id": "iti29:3.3",
      "pali": "Etāni yassa dvārāni,"
    },
    {
      "id": "iti29:3.4",
      "pali": "suguttāni ca bhikkhuno."
    },
    {
      "id": "iti29:4.1",
      "pali": "Bhojanamhi ca mattaññū,"
    },
    {
      "id": "iti29:4.2",
      "pali": "indriyesu ca saṁvuto;"
    },
    {
      "id": "iti29:4.3",
      "pali": "Kāyasukhaṁ cetosukhaṁ,"
    },
    {
      "id": "iti29:4.4",
      "pali": "sukhaṁ so adhigacchati."
    },
    {
      "id": "iti29:5.1",
      "pali": "Aḍayhamānena kāyena,"
    },
    {
      "id": "iti29:5.2",
      "pali": "Aḍayhamānena cetasā;"
    },
    {
      "id": "iti29:5.3",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "iti29:5.4",
      "pali": "Sukhaṁ viharati tādiso”ti."
    },
    {
      "id": "iti29:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti29:6.2",
      "pali": "Dutiyaṁ."
    }
  ]
}
