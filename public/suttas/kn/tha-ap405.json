{
  "uid": "tha-ap405",
  "title": "Mettaguttheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap405:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap405:1.2",
      "pali": "asoko nāma pabbato;"
    },
    {
      "id": "tha-ap405:1.3",
      "pali": "Tatthāsi assamo mayhaṁ,"
    },
    {
      "id": "tha-ap405:1.4",
      "pali": "vissakammena māpito."
    },
    {
      "id": "tha-ap405:2.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap405:2.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap405:2.3",
      "pali": "Nivāsayitvā pubbaṇhe,"
    },
    {
      "id": "tha-ap405:2.4",
      "pali": "piṇḍāya me upāgami."
    },
    {
      "id": "tha-ap405:3.1",
      "pali": "Upāgataṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap405:3.2",
      "pali": "sumedhaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap405:3.3",
      "pali": "Paggayha sugatapattaṁ,"
    },
    {
      "id": "tha-ap405:3.4",
      "pali": "sappitelaṁ apūrayiṁ."
    },
    {
      "id": "tha-ap405:4.1",
      "pali": "Datvānahaṁ buddhaseṭṭhe,"
    },
    {
      "id": "tha-ap405:4.2",
      "pali": "sumedhe lokanāyake;"
    },
    {
      "id": "tha-ap405:4.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap405:4.4",
      "pali": "bhiyyo hāsaṁ janesahaṁ."
    },
    {
      "id": "tha-ap405:5.1",
      "pali": "Iminā sappidānena,"
    },
    {
      "id": "tha-ap405:5.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap405:5.3",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap405:5.4",
      "pali": "labhāmi vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap405:6.1",
      "pali": "Vinipātaṁ vivajjetvā,"
    },
    {
      "id": "tha-ap405:6.2",
      "pali": "saṁsarāmi bhavābhave;"
    },
    {
      "id": "tha-ap405:6.3",
      "pali": "Tattha cittaṁ paṇidhitvā,"
    },
    {
      "id": "tha-ap405:6.4",
      "pali": "labhāmi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap405:7.1",
      "pali": "‘Lābhā tuyhaṁ suladdhaṁ te,"
    },
    {
      "id": "tha-ap405:7.2",
      "pali": "yaṁ maṁ addakkhi brāhmaṇa;"
    },
    {
      "id": "tha-ap405:7.3",
      "pali": "Mama dassanamāgamma,"
    },
    {
      "id": "tha-ap405:7.4",
      "pali": "arahattaṁ bhavissati."
    },
    {
      "id": "tha-ap405:8.1",
      "pali": "Vissattho hohi mā bhāyi,"
    },
    {
      "id": "tha-ap405:8.2",
      "pali": "adhigantvā mahāyasaṁ;"
    },
    {
      "id": "tha-ap405:8.3",
      "pali": "Mamañhi sappiṁ datvāna,"
    },
    {
      "id": "tha-ap405:8.4",
      "pali": "parimokkhasi jātiyā’."
    },
    {
      "id": "tha-ap405:9.1",
      "pali": "Iminā sappidānena,"
    },
    {
      "id": "tha-ap405:9.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap405:9.3",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap405:9.4",
      "pali": "labhase vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap405:10.1",
      "pali": "Iminā sappidānena,"
    },
    {
      "id": "tha-ap405:10.2",
      "pali": "mettacittavatāya ca;"
    },
    {
      "id": "tha-ap405:10.3",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap405:10.4",
      "pali": "devaloke ramissasi."
    },
    {
      "id": "tha-ap405:11.1",
      "pali": "Aṭṭhatiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap405:11.2",
      "pali": "devarājā bhavissasi;"
    },
    {
      "id": "tha-ap405:11.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap405:11.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap405:12.1",
      "pali": "Ekapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap405:12.2",
      "pali": "cakkavattī bhavissasi;"
    },
    {
      "id": "tha-ap405:12.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap405:12.4",
      "pali": "jambumaṇḍassa issaro."
    },
    {
      "id": "tha-ap405:13.1",
      "pali": "Mahāsamuddovakkhobho,"
    },
    {
      "id": "tha-ap405:13.2",
      "pali": "duddharo pathavī yathā;"
    },
    {
      "id": "tha-ap405:13.3",
      "pali": "Evamevaṁ ca te bhogā,"
    },
    {
      "id": "tha-ap405:13.4",
      "pali": "appameyyā bhavissare."
    },
    {
      "id": "tha-ap405:14.1",
      "pali": "Saṭṭhikoṭī hiraññassa,"
    },
    {
      "id": "tha-ap405:14.2",
      "pali": "cajitvā pabbajiṁ ahaṁ;"
    },
    {
      "id": "tha-ap405:14.3",
      "pali": "Kiṁ kusalaṁ gavesanto,"
    },
    {
      "id": "tha-ap405:14.4",
      "pali": "bāvariṁ upasaṅkamiṁ."
    },
    {
      "id": "tha-ap405:15.1",
      "pali": "Tattha mante adhīyāmi,"
    },
    {
      "id": "tha-ap405:15.2",
      "pali": "chaḷaṅgaṁ nāma lakkhaṇaṁ;"
    },
    {
      "id": "tha-ap405:15.3",
      "pali": "Tamandhakāraṁ vidhamaṁ,"
    },
    {
      "id": "tha-ap405:15.4",
      "pali": "uppajji tvaṁ mahāmuni."
    },
    {
      "id": "tha-ap405:16.1",
      "pali": "Tava dassanakāmohaṁ,"
    },
    {
      "id": "tha-ap405:16.2",
      "pali": "āgatomhi mahāmuni;"
    },
    {
      "id": "tha-ap405:16.3",
      "pali": "Tava dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap405:16.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap405:17.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap405:17.2",
      "pali": "sappiṁ buddhassadāsahaṁ;"
    },
    {
      "id": "tha-ap405:17.3",
      "pali": "Etthantare nābhijāne,"
    },
    {
      "id": "tha-ap405:17.4",
      "pali": "sappiṁ viññāpitaṁ mayā."
    },
    {
      "id": "tha-ap405:18.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap405:18.2",
      "pali": "uppajjati yadicchakaṁ;"
    },
    {
      "id": "tha-ap405:18.3",
      "pali": "Cittamaññāya nibbattaṁ,"
    },
    {
      "id": "tha-ap405:18.4",
      "pali": "sabbe santappayāmahaṁ."
    },
    {
      "id": "tha-ap405:19.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap405:19.2",
      "pali": "aho no satthu sampadā;"
    },
    {
      "id": "tha-ap405:19.3",
      "pali": "Thokañhi sappiṁ datvāna,"
    },
    {
      "id": "tha-ap405:19.4",
      "pali": "appameyyaṁ labhāmahaṁ."
    },
    {
      "id": "tha-ap405:20.1",
      "pali": "Mahāsamudde udakaṁ,"
    },
    {
      "id": "tha-ap405:20.2",
      "pali": "yāvatā nerupassato;"
    },
    {
      "id": "tha-ap405:20.3",
      "pali": "Mama sappiṁ upādāya,"
    },
    {
      "id": "tha-ap405:20.4",
      "pali": "kalabhāgaṁ na hessati."
    },
    {
      "id": "tha-ap405:21.1",
      "pali": "Yāvatā cakkavāḷassa,"
    },
    {
      "id": "tha-ap405:21.2",
      "pali": "kariyantassa rāsito;"
    },
    {
      "id": "tha-ap405:21.3",
      "pali": "Mama nibbattavatthānaṁ,"
    },
    {
      "id": "tha-ap405:21.4",
      "pali": "okāso so na sammati."
    },
    {
      "id": "tha-ap405:22.1",
      "pali": "Pabbatarājā himavā,"
    },
    {
      "id": "tha-ap405:22.2",
      "pali": "pavaropi siluccayo;"
    },
    {
      "id": "tha-ap405:22.3",
      "pali": "Mamānulittagandhassa,"
    },
    {
      "id": "tha-ap405:22.4",
      "pali": "upanidhiṁ na hessati."
    },
    {
      "id": "tha-ap405:23.1",
      "pali": "Vatthaṁ gandhañca sappiñca,"
    },
    {
      "id": "tha-ap405:23.2",
      "pali": "aññañca diṭṭhadhammikaṁ;"
    },
    {
      "id": "tha-ap405:23.3",
      "pali": "Asaṅkhatañca nibbānaṁ,"
    },
    {
      "id": "tha-ap405:23.4",
      "pali": "sappidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap405:24.1",
      "pali": "Satipaṭṭhānasayano,"
    },
    {
      "id": "tha-ap405:24.2",
      "pali": "samādhijhānagocaro;"
    },
    {
      "id": "tha-ap405:24.3",
      "pali": "Bojjhaṅgabhojano ajja,"
    },
    {
      "id": "tha-ap405:24.4",
      "pali": "sappidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap405:25.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap405:25.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap405:25.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap405:26.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap405:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap405:26.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap405:27.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap405:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap405:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap405:28.1",
      "pali": "Itthaṁ sudaṁ āyasmā mettagū thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap405:29.1",
      "pali": "Mettaguttherassāpadānaṁ tatiyaṁ."
    }
  ]
}
