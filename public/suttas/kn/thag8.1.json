{
  "uid": "thag8.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag8.1:1.1",
      "pali": "“Kammaṁ bahukaṁ na kāraye,"
    },
    {
      "id": "thag8.1:1.2",
      "pali": "Parivajjeyya janaṁ na uyyame;"
    },
    {
      "id": "thag8.1:1.3",
      "pali": "So ussukko rasānugiddho,"
    },
    {
      "id": "thag8.1:1.4",
      "pali": "Atthaṁ riñcati yo sukhādhivāho."
    },
    {
      "id": "thag8.1:2.1",
      "pali": "Paṅkoti hi naṁ avedayuṁ,"
    },
    {
      "id": "thag8.1:2.2",
      "pali": "Yāyaṁ vandanapūjanā kulesu;"
    },
    {
      "id": "thag8.1:2.3",
      "pali": "Sukhumaṁ sallaṁ durubbahaṁ,"
    },
    {
      "id": "thag8.1:2.4",
      "pali": "Sakkāro kāpurisena dujjaho."
    },
    {
      "id": "thag8.1:3.1",
      "pali": "Na parassupanidhāya,"
    },
    {
      "id": "thag8.1:3.2",
      "pali": "kammaṁ maccassa pāpakaṁ;"
    },
    {
      "id": "thag8.1:3.3",
      "pali": "Attanā taṁ na seveyya,"
    },
    {
      "id": "thag8.1:3.4",
      "pali": "kammabandhū hi mātiyā."
    },
    {
      "id": "thag8.1:4.1",
      "pali": "Na pare vacanā coro,"
    },
    {
      "id": "thag8.1:4.2",
      "pali": "na pare vacanā muni;"
    },
    {
      "id": "thag8.1:4.3",
      "pali": "Attā ca naṁ yathāvedi,"
    },
    {
      "id": "thag8.1:4.4",
      "pali": "devāpi naṁ tathā vidū."
    },
    {
      "id": "thag8.1:5.1",
      "pali": "Pare ca na vijānanti,"
    },
    {
      "id": "thag8.1:5.2",
      "pali": "mayamettha yamāmase;"
    },
    {
      "id": "thag8.1:5.3",
      "pali": "Ye ca tattha vijānanti,"
    },
    {
      "id": "thag8.1:5.4",
      "pali": "tato sammanti medhagā."
    },
    {
      "id": "thag8.1:6.1",
      "pali": "Jīvate vāpi sappañño,"
    },
    {
      "id": "thag8.1:6.2",
      "pali": "api vittaparikkhayo;"
    },
    {
      "id": "thag8.1:6.3",
      "pali": "Paññāya ca alābhena,"
    },
    {
      "id": "thag8.1:6.4",
      "pali": "vittavāpi na jīvati."
    },
    {
      "id": "thag8.1:7.1",
      "pali": "Sabbaṁ suṇāti sotena,"
    },
    {
      "id": "thag8.1:7.2",
      "pali": "sabbaṁ passati cakkhunā;"
    },
    {
      "id": "thag8.1:7.3",
      "pali": "Na ca diṭṭhaṁ sutaṁ dhīro,"
    },
    {
      "id": "thag8.1:7.4",
      "pali": "sabbaṁ ujjhitumarahati."
    },
    {
      "id": "thag8.1:8.1",
      "pali": "Cakkhumāssa yathā andho,"
    },
    {
      "id": "thag8.1:8.2",
      "pali": "sotavā badhiro yathā;"
    },
    {
      "id": "thag8.1:8.3",
      "pali": "Paññavāssa yathā mūgo,"
    },
    {
      "id": "thag8.1:8.4",
      "pali": "balavā dubbaloriva;"
    },
    {
      "id": "thag8.1:8.5",
      "pali": "Atha atthe samuppanne,"
    },
    {
      "id": "thag8.1:8.6",
      "pali": "sayetha matasāyikan”ti."
    },
    {
      "id": "thag8.1:8.7",
      "pali": "… Mahākaccāyano thero …."
    }
  ]
}
