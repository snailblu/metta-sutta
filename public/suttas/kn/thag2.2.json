{
  "uid": "thag2.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.2:1.1",
      "pali": "“Nayidaṁ anayena jīvitaṁ,"
    },
    {
      "id": "thag2.2:1.2",
      "pali": "Nāhāro hadayassa santiko;"
    },
    {
      "id": "thag2.2:1.3",
      "pali": "Āhāraṭṭhitiko samussayo,"
    },
    {
      "id": "thag2.2:1.4",
      "pali": "Iti disvāna carāmi esanaṁ."
    },
    {
      "id": "thag2.2:2.1",
      "pali": "Paṅkoti hi naṁ pavedayuṁ,"
    },
    {
      "id": "thag2.2:2.2",
      "pali": "Yāyaṁ vandanapūjanā kulesu;"
    },
    {
      "id": "thag2.2:2.3",
      "pali": "Sukhumaṁ sallaṁ durubbahaṁ,"
    },
    {
      "id": "thag2.2:2.4",
      "pali": "Sakkāro kāpurisena dujjaho”ti."
    },
    {
      "id": "thag2.2:2.5",
      "pali": "Itthaṁ sudaṁ āyasmā piṇḍolabhāradvājo thero gāthāyo abhāsitthāti."
    }
  ]
}
