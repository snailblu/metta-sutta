{
  "uid": "pv33",
  "title": "8. Dutiyamigaluddakapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv33:1.1",
      "pali": "“Kūṭāgāre ca pāsāde,"
    },
    {
      "id": "pv33:1.2",
      "pali": "pallaṅke gonakatthate;"
    },
    {
      "id": "pv33:1.3",
      "pali": "Pañcaṅgikena turiyena,"
    },
    {
      "id": "pv33:1.4",
      "pali": "ramasi suppavādite."
    },
    {
      "id": "pv33:2.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "pv33:2.2",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "pv33:2.3",
      "pali": "Apaviddho susānasmiṁ,"
    },
    {
      "id": "pv33:2.4",
      "pali": "bahudukkhaṁ nigacchasi."
    },
    {
      "id": "pv33:3.1",
      "pali": "Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv33:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv33:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv33:3.4",
      "pali": "idaṁ dukkhaṁ nigacchasi”."
    },
    {
      "id": "pv33:4.1",
      "pali": "“Ahaṁ rājagahe ramme,"
    },
    {
      "id": "pv33:4.2",
      "pali": "ramaṇīye giribbaje;"
    },
    {
      "id": "pv33:4.3",
      "pali": "Migaluddo pure āsiṁ,"
    },
    {
      "id": "pv33:4.4",
      "pali": "luddo cāsimasaññato."
    },
    {
      "id": "pv33:5.1",
      "pali": "Tassa me sahāyo suhadayo,"
    },
    {
      "id": "pv33:5.2",
      "pali": "Saddho āsi upāsako;"
    },
    {
      "id": "pv33:5.3",
      "pali": "Tassa kulupako bhikkhu,"
    },
    {
      "id": "pv33:5.4",
      "pali": "Āsi gotamasāvako;"
    },
    {
      "id": "pv33:5.5",
      "pali": "Sopi maṁ anukampanto,"
    },
    {
      "id": "pv33:5.6",
      "pali": "Nivāresi punappunaṁ."
    },
    {
      "id": "pv33:6.1",
      "pali": "‘Mākāsi pāpakaṁ kammaṁ,"
    },
    {
      "id": "pv33:6.2",
      "pali": "Mā tāta duggatiṁ agā;"
    },
    {
      "id": "pv33:6.3",
      "pali": "Sace icchasi pecca sukhaṁ,"
    },
    {
      "id": "pv33:6.4",
      "pali": "Virama pāṇavadhā asaṁyamā’."
    },
    {
      "id": "pv33:7.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "pv33:7.2",
      "pali": "Sukhakāmassa hitānukampino;"
    },
    {
      "id": "pv33:7.3",
      "pali": "Nākāsiṁ sakalānusāsaniṁ,"
    },
    {
      "id": "pv33:7.4",
      "pali": "Cirapāpābhirato abuddhimā."
    },
    {
      "id": "pv33:8.1",
      "pali": "So maṁ puna bhūrisumedhaso,"
    },
    {
      "id": "pv33:8.2",
      "pali": "Anukampāya saṁyame nivesayi;"
    },
    {
      "id": "pv33:8.3",
      "pali": "‘Sace divā hanasi pāṇino,"
    },
    {
      "id": "pv33:8.4",
      "pali": "Atha te rattiṁ bhavatu saṁyamo’."
    },
    {
      "id": "pv33:9.1",
      "pali": "Svāhaṁ divā hanitvā pāṇino,"
    },
    {
      "id": "pv33:9.2",
      "pali": "Virato rattimahosi saññato;"
    },
    {
      "id": "pv33:9.3",
      "pali": "Rattāhaṁ paricāremi,"
    },
    {
      "id": "pv33:9.4",
      "pali": "Divā khajjāmi duggato."
    },
    {
      "id": "pv33:10.1",
      "pali": "Tassa kammassa kusalassa,"
    },
    {
      "id": "pv33:10.2",
      "pali": "Anubhomi rattiṁ amānusiṁ;"
    },
    {
      "id": "pv33:10.3",
      "pali": "Divā paṭihatāva kukkurā,"
    },
    {
      "id": "pv33:10.4",
      "pali": "Upadhāvanti samantā khādituṁ."
    },
    {
      "id": "pv33:11.1",
      "pali": "Ye ca te satatānuyogino,"
    },
    {
      "id": "pv33:11.2",
      "pali": "Dhuvaṁ payuttā sugatassa sāsane;"
    },
    {
      "id": "pv33:11.3",
      "pali": "Maññāmi te amatameva kevalaṁ,"
    },
    {
      "id": "pv33:11.4",
      "pali": "Adhigacchanti padaṁ asaṅkhatan”ti."
    },
    {
      "id": "pv33:12.1",
      "pali": "Dutiyamigaluddakapetavatthu aṭṭhamaṁ."
    }
  ]
}
