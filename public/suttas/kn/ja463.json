{
  "uid": "ja463",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja463:1.1",
      "pali": "“Ummujjanti nimujjanti,"
    },
    {
      "id": "ja463:1.2",
      "pali": "manussā khuranāsikā;"
    },
    {
      "id": "ja463:1.3",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:1.4",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:2.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:2.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:2.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:2.4",
      "pali": "khuramālīti vuccati”."
    },
    {
      "id": "ja463:3.1",
      "pali": "“Yathā aggīva suriyova,"
    },
    {
      "id": "ja463:3.2",
      "pali": "samuddo paṭidissati;"
    },
    {
      "id": "ja463:3.3",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:3.4",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:4.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:4.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:4.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:4.4",
      "pali": "aggimālīti vuccati”."
    },
    {
      "id": "ja463:5.1",
      "pali": "“Yathā dadhīva khīraṁva,"
    },
    {
      "id": "ja463:5.2",
      "pali": "samuddo paṭidissati;"
    },
    {
      "id": "ja463:5.3",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:5.4",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:6.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:6.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:6.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:6.4",
      "pali": "dadhimālīti vuccati”."
    },
    {
      "id": "ja463:7.1",
      "pali": "“Yathā kusova sassova,"
    },
    {
      "id": "ja463:7.2",
      "pali": "samuddo paṭidissati;"
    },
    {
      "id": "ja463:7.3",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:7.4",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:8.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:8.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:8.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:8.4",
      "pali": "kusamālīti vuccati”."
    },
    {
      "id": "ja463:9.1",
      "pali": "“Yathā naḷova veḷūva,"
    },
    {
      "id": "ja463:9.2",
      "pali": "samuddo paṭidissati;"
    },
    {
      "id": "ja463:9.3",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:9.4",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:10.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:10.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:10.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:10.4",
      "pali": "naḷamālīti vuccati”."
    },
    {
      "id": "ja463:11.1",
      "pali": "“Mahabbhayo bhiṁsanako,"
    },
    {
      "id": "ja463:11.2",
      "pali": "saddo suyyatimānuso;"
    },
    {
      "id": "ja463:11.3",
      "pali": "Yathā sobbho papātova,"
    },
    {
      "id": "ja463:11.4",
      "pali": "samuddo paṭidissati;"
    },
    {
      "id": "ja463:11.5",
      "pali": "Suppārakaṁ taṁ pucchāma,"
    },
    {
      "id": "ja463:11.6",
      "pali": "samuddo katamo ayaṁ”."
    },
    {
      "id": "ja463:12.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja463:12.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja463:12.3",
      "pali": "Nāvāya vippanaṭṭhāya,"
    },
    {
      "id": "ja463:12.4",
      "pali": "baḷavāmukhīti vuccati."
    },
    {
      "id": "ja463:13.1",
      "pali": "Yato sarāmi attānaṁ,"
    },
    {
      "id": "ja463:13.2",
      "pali": "Yato pattosmi viññutaṁ;"
    },
    {
      "id": "ja463:13.3",
      "pali": "Nābhijānāmi sañcicca,"
    },
    {
      "id": "ja463:13.4",
      "pali": "Ekapāṇampi hiṁsitaṁ;"
    },
    {
      "id": "ja463:13.5",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "ja463:13.6",
      "pali": "Sotthiṁ nāvā nivattatū”ti."
    },
    {
      "id": "ja463:14.1",
      "pali": "Suppārakajātakaṁ navamaṁ."
    },
    {
      "id": "ja463:15.1",
      "pali": "Ekādasakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja463:16.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja463:17.1",
      "pali": "Sirimātusuposakanāgavaro,"
    },
    {
      "id": "ja463:17.2",
      "pali": "Puna juṇhaka dhammamudayavaro;"
    },
    {
      "id": "ja463:17.3",
      "pali": "Atha pāni yudhañcayako ca dasa-"
    },
    {
      "id": "ja463:17.4",
      "pali": "Ratha saṁvara pāragatena navāti."
    }
  ]
}
