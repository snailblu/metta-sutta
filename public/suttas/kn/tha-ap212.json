{
  "uid": "tha-ap212",
  "title": "10 Pāpanivāriyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap212:1.1",
      "pali": "“Tissassa tu bhagavato,"
    },
    {
      "id": "tha-ap212:1.2",
      "pali": "devadevassa tādino;"
    },
    {
      "id": "tha-ap212:1.3",
      "pali": "Ekacchattaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap212:1.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap212:2.1",
      "pali": "Nivutaṁ hoti me pāpaṁ,"
    },
    {
      "id": "tha-ap212:2.2",
      "pali": "kusalassupasampadā;"
    },
    {
      "id": "tha-ap212:2.3",
      "pali": "Ākāse chattaṁ dhārenti,"
    },
    {
      "id": "tha-ap212:2.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap212:3.1",
      "pali": "Carimaṁ vattate mayhaṁ,"
    },
    {
      "id": "tha-ap212:3.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap212:3.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap212:3.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap212:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap212:4.2",
      "pali": "yaṁ chattamadadiṁ tadā;"
    },
    {
      "id": "tha-ap212:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap212:4.4",
      "pali": "chattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap212:5.1",
      "pali": "Dvesattatimhito kappe,"
    },
    {
      "id": "tha-ap212:5.2",
      "pali": "aṭṭhāsiṁsu janādhipā;"
    },
    {
      "id": "tha-ap212:5.3",
      "pali": "Mahānidānanāmena,"
    },
    {
      "id": "tha-ap212:5.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap212:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap212:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap212:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap212:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pāpanivāriyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap212:8.1",
      "pali": "Pāpanivāriyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap212:9.1",
      "pali": "Kaṇikārapupphiyavaggo ekavīsatimo."
    },
    {
      "id": "tha-ap212:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap212:11.1",
      "pali": "Kaṇikāro minelañca,"
    },
    {
      "id": "tha-ap212:11.2",
      "pali": "kiṅkaṇi taraṇena ca;"
    },
    {
      "id": "tha-ap212:11.3",
      "pali": "Nigguṇḍipupphī dakado,"
    },
    {
      "id": "tha-ap212:11.4",
      "pali": "salalo ca kuraṇḍako;"
    },
    {
      "id": "tha-ap212:11.5",
      "pali": "Ādhārako pāpavārī,"
    },
    {
      "id": "tha-ap212:11.6",
      "pali": "aṭṭhatālīsa gāthakāti."
    }
  ]
}
