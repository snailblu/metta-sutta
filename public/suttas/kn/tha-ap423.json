{
  "uid": "tha-ap423",
  "title": "Sakiṁsammajjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap423:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap423:1.2",
      "pali": "pāṭaliṁ bodhimuttamaṁ;"
    },
    {
      "id": "tha-ap423:1.3",
      "pali": "Disvāva taṁ pādapaggaṁ,"
    },
    {
      "id": "tha-ap423:1.4",
      "pali": "tattha cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap423:2.1",
      "pali": "Sammajjaniṁ gahetvāna,"
    },
    {
      "id": "tha-ap423:2.2",
      "pali": "bodhiṁ sammajji tāvade;"
    },
    {
      "id": "tha-ap423:2.3",
      "pali": "Sammajjitvāna taṁ bodhiṁ,"
    },
    {
      "id": "tha-ap423:2.4",
      "pali": "avandiṁ pāṭaliṁ ahaṁ."
    },
    {
      "id": "tha-ap423:3.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap423:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap423:3.3",
      "pali": "Namassamāno taṁ bodhiṁ,"
    },
    {
      "id": "tha-ap423:3.4",
      "pali": "gañchiṁ paṭikuṭiṁ ahaṁ."
    },
    {
      "id": "tha-ap423:4.1",
      "pali": "Tādimaggena gacchāmi,"
    },
    {
      "id": "tha-ap423:4.2",
      "pali": "saranto bodhimuttamaṁ;"
    },
    {
      "id": "tha-ap423:4.3",
      "pali": "Ajagaro maṁ pīḷesi,"
    },
    {
      "id": "tha-ap423:4.4",
      "pali": "ghorarūpo mahabbalo."
    },
    {
      "id": "tha-ap423:5.1",
      "pali": "Āsanne me kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap423:5.2",
      "pali": "phalena tosayī mamaṁ;"
    },
    {
      "id": "tha-ap423:5.3",
      "pali": "Kaḷevaraṁ me gilati,"
    },
    {
      "id": "tha-ap423:5.4",
      "pali": "devaloke ramāmahaṁ."
    },
    {
      "id": "tha-ap423:6.1",
      "pali": "Anāvilaṁ mama cittaṁ,"
    },
    {
      "id": "tha-ap423:6.2",
      "pali": "visuddhaṁ paṇḍaraṁ sadā;"
    },
    {
      "id": "tha-ap423:6.3",
      "pali": "Sokasallaṁ na jānāmi,"
    },
    {
      "id": "tha-ap423:6.4",
      "pali": "cittasantāpanaṁ mama."
    },
    {
      "id": "tha-ap423:7.1",
      "pali": "Kuṭṭhaṁ gaṇḍo kilāso ca,"
    },
    {
      "id": "tha-ap423:7.2",
      "pali": "apamāro vitacchikā;"
    },
    {
      "id": "tha-ap423:7.3",
      "pali": "Daddu kaṇḍu ca me natthi,"
    },
    {
      "id": "tha-ap423:7.4",
      "pali": "phalaṁ sammajjanāyidaṁ."
    },
    {
      "id": "tha-ap423:8.1",
      "pali": "Soko ca paridevo ca,"
    },
    {
      "id": "tha-ap423:8.2",
      "pali": "hadaye me na vijjati;"
    },
    {
      "id": "tha-ap423:8.3",
      "pali": "Abhantaṁ ujukaṁ cittaṁ,"
    },
    {
      "id": "tha-ap423:8.4",
      "pali": "phalaṁ sammajjanāyidaṁ."
    },
    {
      "id": "tha-ap423:9.1",
      "pali": "Samādhīsu na majjāmi,"
    },
    {
      "id": "tha-ap423:9.2",
      "pali": "visadaṁ hoti mānasaṁ;"
    },
    {
      "id": "tha-ap423:9.3",
      "pali": "Yaṁ yaṁ samādhimicchāmi,"
    },
    {
      "id": "tha-ap423:9.4",
      "pali": "so so sampajjate mamaṁ."
    },
    {
      "id": "tha-ap423:10.1",
      "pali": "Rajanīye na rajjāmi,"
    },
    {
      "id": "tha-ap423:10.2",
      "pali": "atho dussaniyesu ca;"
    },
    {
      "id": "tha-ap423:10.3",
      "pali": "Mohanīye na muyhāmi,"
    },
    {
      "id": "tha-ap423:10.4",
      "pali": "phalaṁ sammajjanāyidaṁ."
    },
    {
      "id": "tha-ap423:11.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap423:11.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap423:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap423:11.4",
      "pali": "phalaṁ sammajjanāyidaṁ."
    },
    {
      "id": "tha-ap423:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap423:12.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap423:12.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap423:12.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap423:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap423:13.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap423:13.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap423:13.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap423:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap423:14.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap423:14.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap423:14.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap423:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā sakiṁsammajjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap423:16.1",
      "pali": "Sakiṁsammajjakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
