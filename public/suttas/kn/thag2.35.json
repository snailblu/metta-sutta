{
  "uid": "thag2.35",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.35:1.1",
      "pali": "“Devo ca vassati, devo ca gaḷagaḷāyati,"
    },
    {
      "id": "thag2.35:1.2",
      "pali": "Ekako cāhaṁ bherave bile viharāmi;"
    },
    {
      "id": "thag2.35:1.3",
      "pali": "Tassa mayhaṁ ekakassa bherave bile viharato,"
    },
    {
      "id": "thag2.35:1.4",
      "pali": "Natthi bhayaṁ vā chambhitattaṁ vā lomahaṁso vā."
    },
    {
      "id": "thag2.35:2.1",
      "pali": "Dhammatā mamesā yassa me,"
    },
    {
      "id": "thag2.35:2.2",
      "pali": "Ekakassa bherave bile;"
    },
    {
      "id": "thag2.35:2.3",
      "pali": "Viharato natthi bhayaṁ vā,"
    },
    {
      "id": "thag2.35:2.4",
      "pali": "Chambhitattaṁ vā lomahaṁso vā”ti."
    },
    {
      "id": "thag2.35:2.5",
      "pali": "… Sambulakaccāno thero …."
    }
  ]
}
