{
  "uid": "tha-ap305",
  "title": "Paramannadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap305:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap305:1.2",
      "pali": "udayantaṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap305:1.3",
      "pali": "Vipassiṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap305:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap305:2.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap305:2.2",
      "pali": "abhinesiṁ sakaṁ gharaṁ;"
    },
    {
      "id": "tha-ap305:2.3",
      "pali": "Abhinetvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap305:2.4",
      "pali": "paramannamadāsahaṁ."
    },
    {
      "id": "tha-ap305:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap305:3.2",
      "pali": "paramannamadiṁ tadā;"
    },
    {
      "id": "tha-ap305:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap305:3.4",
      "pali": "paramannassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap305:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap305:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap305:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap305:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā paramannadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap305:6.1",
      "pali": "Paramannadāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
