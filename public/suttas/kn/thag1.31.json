{
  "uid": "thag1.31",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.31:1.1",
      "pali": "“Phuṭṭho ḍaṁsehi makasehi,"
    },
    {
      "id": "thag1.31:1.2",
      "pali": "araññasmiṁ brahāvane;"
    },
    {
      "id": "thag1.31:1.3",
      "pali": "Nāgo saṅgāmasīseva,"
    },
    {
      "id": "thag1.31:1.4",
      "pali": "sato tatrādhivāsaye”ti."
    },
    {
      "id": "thag1.31:1.5",
      "pali": "… Gahvaratīriyo thero …."
    }
  ]
}
