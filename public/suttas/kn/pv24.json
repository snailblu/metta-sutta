{
  "uid": "pv24",
  "title": "12. Kaṇṇamuṇḍapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv24:1.1",
      "pali": "“Soṇṇasopānaphalakā,"
    },
    {
      "id": "pv24:1.2",
      "pali": "soṇṇavālukasanthatā;"
    },
    {
      "id": "pv24:1.3",
      "pali": "Tattha sogandhiyā vaggū,"
    },
    {
      "id": "pv24:1.4",
      "pali": "sucigandhā manoramā."
    },
    {
      "id": "pv24:2.1",
      "pali": "Nānārukkhehi sañchannā,"
    },
    {
      "id": "pv24:2.2",
      "pali": "nānāgandhasameritā;"
    },
    {
      "id": "pv24:2.3",
      "pali": "Nānāpadumasañchannā,"
    },
    {
      "id": "pv24:2.4",
      "pali": "puṇḍarīkasamotatā."
    },
    {
      "id": "pv24:3.1",
      "pali": "Surabhiṁ sampavāyanti,"
    },
    {
      "id": "pv24:3.2",
      "pali": "manuññā māluteritā;"
    },
    {
      "id": "pv24:3.3",
      "pali": "Haṁsakoñcābhirudā ca,"
    },
    {
      "id": "pv24:3.4",
      "pali": "cakkavakkābhikūjitā."
    },
    {
      "id": "pv24:4.1",
      "pali": "Nānādijagaṇākiṇṇā,"
    },
    {
      "id": "pv24:4.2",
      "pali": "nānāsaragaṇāyutā;"
    },
    {
      "id": "pv24:4.3",
      "pali": "Nānāphaladharā rukkhā,"
    },
    {
      "id": "pv24:4.4",
      "pali": "nānāpupphadharā vanā."
    },
    {
      "id": "pv24:5.1",
      "pali": "Na manussesu īdisaṁ,"
    },
    {
      "id": "pv24:5.2",
      "pali": "nagaraṁ yādisaṁ idaṁ;"
    },
    {
      "id": "pv24:5.3",
      "pali": "Pāsādā bahukā tuyhaṁ,"
    },
    {
      "id": "pv24:5.4",
      "pali": "sovaṇṇarūpiyāmayā;"
    },
    {
      "id": "pv24:5.5",
      "pali": "Daddallamānā ābhenti,"
    },
    {
      "id": "pv24:5.6",
      "pali": "samantā caturo disā."
    },
    {
      "id": "pv24:6.1",
      "pali": "Pañca dāsisatā tuyhaṁ,"
    },
    {
      "id": "pv24:6.2",
      "pali": "yā temā paricārikā;"
    },
    {
      "id": "pv24:6.3",
      "pali": "Tā kambukāyūradharā,"
    },
    {
      "id": "pv24:6.4",
      "pali": "kañcanāveḷabhūsitā."
    },
    {
      "id": "pv24:7.1",
      "pali": "Pallaṅkā bahukā tuyhaṁ,"
    },
    {
      "id": "pv24:7.2",
      "pali": "sovaṇṇarūpiyāmayā;"
    },
    {
      "id": "pv24:7.3",
      "pali": "Kadalimigasañchannā,"
    },
    {
      "id": "pv24:7.4",
      "pali": "sajjā gonakasanthatā."
    },
    {
      "id": "pv24:8.1",
      "pali": "Yattha tvaṁ vāsūpagatā,"
    },
    {
      "id": "pv24:8.2",
      "pali": "sabbakāmasamiddhinī;"
    },
    {
      "id": "pv24:8.3",
      "pali": "Sampattāyaḍḍharattāya,"
    },
    {
      "id": "pv24:8.4",
      "pali": "tato uṭṭhāya gacchasi."
    },
    {
      "id": "pv24:9.1",
      "pali": "Uyyānabhūmiṁ gantvāna,"
    },
    {
      "id": "pv24:9.2",
      "pali": "pokkharaññā samantato;"
    },
    {
      "id": "pv24:9.3",
      "pali": "Tassā tīre tuvaṁ ṭhāsi,"
    },
    {
      "id": "pv24:9.4",
      "pali": "harite saddale subhe."
    },
    {
      "id": "pv24:10.1",
      "pali": "Tato te kaṇṇamuṇḍo sunakho,"
    },
    {
      "id": "pv24:10.2",
      "pali": "Aṅgamaṅgāni khādati;"
    },
    {
      "id": "pv24:10.3",
      "pali": "Yadā ca khāyitā āsi,"
    },
    {
      "id": "pv24:10.4",
      "pali": "Aṭṭhisaṅkhalikā katā;"
    },
    {
      "id": "pv24:10.5",
      "pali": "Ogāhasi pokkharaṇiṁ,"
    },
    {
      "id": "pv24:10.6",
      "pali": "Hoti kāyo yathā pure."
    },
    {
      "id": "pv24:11.1",
      "pali": "Tato tvaṁ aṅgapaccaṅgī,"
    },
    {
      "id": "pv24:11.2",
      "pali": "sucāru piyadassanā;"
    },
    {
      "id": "pv24:11.3",
      "pali": "Vatthena pārupitvāna,"
    },
    {
      "id": "pv24:11.4",
      "pali": "āyāsi mama santikaṁ."
    },
    {
      "id": "pv24:12.1",
      "pali": "Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv24:12.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv24:12.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv24:12.4",
      "pali": "kaṇṇamuṇḍo sunakho tava;"
    },
    {
      "id": "pv24:12.5",
      "pali": "Aṅgamaṅgāni khādatī”ti."
    },
    {
      "id": "pv24:13.1",
      "pali": "“Kimilāyaṁ gahapati,"
    },
    {
      "id": "pv24:13.2",
      "pali": "saddho āsi upāsako;"
    },
    {
      "id": "pv24:13.3",
      "pali": "Tassāhaṁ bhariyā āsiṁ,"
    },
    {
      "id": "pv24:13.4",
      "pali": "dussīlā aticārinī."
    },
    {
      "id": "pv24:14.1",
      "pali": "So maṁ aticaramānāya,"
    },
    {
      "id": "pv24:14.2",
      "pali": "sāmiko etadabravi;"
    },
    {
      "id": "pv24:14.3",
      "pali": "‘Netaṁ channaṁ patirūpaṁ,"
    },
    {
      "id": "pv24:14.4",
      "pali": "yaṁ tvaṁ aticarāsi maṁ’."
    },
    {
      "id": "pv24:15.1",
      "pali": "Sāhaṁ ghorañca sapathaṁ,"
    },
    {
      "id": "pv24:15.2",
      "pali": "musāvādañca bhāsisaṁ;"
    },
    {
      "id": "pv24:15.3",
      "pali": "‘Nāhaṁ taṁ aticarāmi,"
    },
    {
      "id": "pv24:15.4",
      "pali": "kāyena uda cetasā."
    },
    {
      "id": "pv24:16.1",
      "pali": "Sacāhaṁ taṁ aticarāmi,"
    },
    {
      "id": "pv24:16.2",
      "pali": "kāyena uda cetasā;"
    },
    {
      "id": "pv24:16.3",
      "pali": "Kaṇṇamuṇḍoyaṁ sunakho,"
    },
    {
      "id": "pv24:16.4",
      "pali": "aṅgamaṅgāni khādatu’."
    },
    {
      "id": "pv24:17.1",
      "pali": "Tassa kammassa vipākaṁ,"
    },
    {
      "id": "pv24:17.2",
      "pali": "musāvādassa cūbhayaṁ;"
    },
    {
      "id": "pv24:17.3",
      "pali": "Satteva vassasatāni,"
    },
    {
      "id": "pv24:17.4",
      "pali": "anubhūtaṁ yato hi me;"
    },
    {
      "id": "pv24:17.5",
      "pali": "Kaṇṇamuṇḍo ca sunakho,"
    },
    {
      "id": "pv24:17.6",
      "pali": "aṅgamaṅgāni khādati."
    },
    {
      "id": "pv24:18.1",
      "pali": "Tvañca deva bahukāro,"
    },
    {
      "id": "pv24:18.2",
      "pali": "atthāya me idhāgato;"
    },
    {
      "id": "pv24:18.3",
      "pali": "Sumuttāhaṁ kaṇṇamuṇḍassa,"
    },
    {
      "id": "pv24:18.4",
      "pali": "asokā akutobhayā."
    },
    {
      "id": "pv24:19.1",
      "pali": "Tāhaṁ deva namassāmi,"
    },
    {
      "id": "pv24:19.2",
      "pali": "yācāmi pañjalīkatā;"
    },
    {
      "id": "pv24:19.3",
      "pali": "Bhuñja amānuse kāme,"
    },
    {
      "id": "pv24:19.4",
      "pali": "rama deva mayā sahā”ti."
    },
    {
      "id": "pv24:20.1",
      "pali": "“Bhuttā amānusā kāmā,"
    },
    {
      "id": "pv24:20.2",
      "pali": "ramitomhi tayā saha;"
    },
    {
      "id": "pv24:20.3",
      "pali": "Tāhaṁ subhage yācāmi,"
    },
    {
      "id": "pv24:20.4",
      "pali": "khippaṁ paṭinayāhi man”ti."
    },
    {
      "id": "pv24:21.1",
      "pali": "Kaṇṇamuṇḍapetivatthu dvādasamaṁ."
    }
  ]
}
