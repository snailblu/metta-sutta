{
  "uid": "thig5.9",
  "title": "Bhaddākuṇḍalakesātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.9:1.1",
      "pali": "“Lūnakesī paṅkadharī,"
    },
    {
      "id": "thig5.9:1.2",
      "pali": "ekasāṭī pure cariṁ;"
    },
    {
      "id": "thig5.9:1.3",
      "pali": "Avajje vajjamatinī,"
    },
    {
      "id": "thig5.9:1.4",
      "pali": "vajje cāvajjadassinī."
    },
    {
      "id": "thig5.9:2.1",
      "pali": "Divāvihārā nikkhamma,"
    },
    {
      "id": "thig5.9:2.2",
      "pali": "gijjhakūṭamhi pabbate;"
    },
    {
      "id": "thig5.9:2.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "thig5.9:2.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "thig5.9:3.1",
      "pali": "Nihacca jāṇuṁ vanditvā,"
    },
    {
      "id": "thig5.9:3.2",
      "pali": "sammukhā añjaliṁ akaṁ;"
    },
    {
      "id": "thig5.9:3.3",
      "pali": "‘Ehi bhadde’ti maṁ avaca,"
    },
    {
      "id": "thig5.9:3.4",
      "pali": "sā me āsūpasampadā."
    },
    {
      "id": "thig5.9:4.1",
      "pali": "Ciṇṇā aṅgā ca magadhā,"
    },
    {
      "id": "thig5.9:4.2",
      "pali": "vajjī kāsī ca kosalā;"
    },
    {
      "id": "thig5.9:4.3",
      "pali": "Anaṇā paṇṇāsa vassāni,"
    },
    {
      "id": "thig5.9:4.4",
      "pali": "raṭṭhapiṇḍaṁ abhuñjahaṁ."
    },
    {
      "id": "thig5.9:5.1",
      "pali": "Puññaṁ vata pasavi bahuṁ,"
    },
    {
      "id": "thig5.9:5.2",
      "pali": "Sappañño vatāyaṁ upāsako;"
    },
    {
      "id": "thig5.9:5.3",
      "pali": "Yo bhaddāya cīvaraṁ adāsi,"
    },
    {
      "id": "thig5.9:5.4",
      "pali": "Vippamuttāya sabbaganthehī”ti."
    },
    {
      "id": "thig5.9:6.1",
      "pali": "… Bhaddā kuṇḍalakesā therī …."
    }
  ]
}
