{
  "uid": "tha-ap488",
  "title": "Dhātupūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap488:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap488:1.2",
      "pali": "siddhatthe lokanāyake;"
    },
    {
      "id": "tha-ap488:1.3",
      "pali": "Mama ñātī samānetvā,"
    },
    {
      "id": "tha-ap488:1.4",
      "pali": "dhātupūjaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap488:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap488:2.2",
      "pali": "yaṁ dhātumabhipūjayiṁ;"
    },
    {
      "id": "tha-ap488:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap488:2.4",
      "pali": "dhātupūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap488:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap488:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap488:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap488:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap488:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap488:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap488:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap488:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap488:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap488:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhātupūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap488:7.1",
      "pali": "Dhātupūjakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
