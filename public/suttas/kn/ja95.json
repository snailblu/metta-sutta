{
  "uid": "ja95",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja95:1.1",
      "pali": "“Aniccā vata saṅkhārā,"
    },
    {
      "id": "ja95:1.2",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "ja95:1.3",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "ja95:1.4",
      "pali": "tesaṁ vūpasamo sukho”ti."
    },
    {
      "id": "ja95:2.1",
      "pali": "Mahāsudassanajātakaṁ pañcamaṁ."
    }
  ]
}
