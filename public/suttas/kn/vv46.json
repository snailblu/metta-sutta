{
  "uid": "vv46",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv46:1.1",
      "pali": "“Dibbaṁ te ambavanaṁ rammaṁ,"
    },
    {
      "id": "vv46:1.2",
      "pali": "Pāsādettha mahallako;"
    },
    {
      "id": "vv46:1.3",
      "pali": "Nānātūriyasaṅghuṭṭho,"
    },
    {
      "id": "vv46:1.4",
      "pali": "Accharāgaṇaghosito."
    },
    {
      "id": "vv46:2.1",
      "pali": "Padīpo cettha jalati,"
    },
    {
      "id": "vv46:2.2",
      "pali": "niccaṁ sovaṇṇayo mahā;"
    },
    {
      "id": "vv46:2.3",
      "pali": "Dussaphalehi rukkhehi,"
    },
    {
      "id": "vv46:2.4",
      "pali": "samantā parivārito."
    },
    {
      "id": "vv46:3.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv46:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv46:3.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv46:4.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv46:4.2",
      "pali": "…pe…"
    },
    {
      "id": "vv46:4.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv46:5.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv46:5.2",
      "pali": "Purimāya jātiyā manussaloke;"
    },
    {
      "id": "vv46:5.3",
      "pali": "Vihāraṁ saṅghassa kāresiṁ,"
    },
    {
      "id": "vv46:5.4",
      "pali": "Ambehi parivāritaṁ."
    },
    {
      "id": "vv46:6.1",
      "pali": "Pariyosite vihāre,"
    },
    {
      "id": "vv46:6.2",
      "pali": "kārente niṭṭhite mahe;"
    },
    {
      "id": "vv46:6.3",
      "pali": "Ambehi chādayitvāna,"
    },
    {
      "id": "vv46:6.4",
      "pali": "katvā dussamaye phale."
    },
    {
      "id": "vv46:7.1",
      "pali": "Padīpaṁ tattha jāletvā,"
    },
    {
      "id": "vv46:7.2",
      "pali": "bhojayitvā gaṇuttamaṁ;"
    },
    {
      "id": "vv46:7.3",
      "pali": "Niyyādesiṁ taṁ saṅghassa,"
    },
    {
      "id": "vv46:7.4",
      "pali": "pasannā sehi pāṇibhi."
    },
    {
      "id": "vv46:8.1",
      "pali": "Tena me ambavanaṁ rammaṁ,"
    },
    {
      "id": "vv46:8.2",
      "pali": "pāsādettha mahallako;"
    },
    {
      "id": "vv46:8.3",
      "pali": "Nānātūriyasaṅghuṭṭho,"
    },
    {
      "id": "vv46:8.4",
      "pali": "accharāgaṇaghosito."
    },
    {
      "id": "vv46:9.1",
      "pali": "Padīpo cettha jalati,"
    },
    {
      "id": "vv46:9.2",
      "pali": "niccaṁ sovaṇṇayo mahā;"
    },
    {
      "id": "vv46:9.3",
      "pali": "Dussaphalehi rukkhehi,"
    },
    {
      "id": "vv46:9.4",
      "pali": "samantā parivārito."
    },
    {
      "id": "vv46:10.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv46:10.2",
      "pali": "…pe…"
    },
    {
      "id": "vv46:10.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv46:11.1",
      "pali": "Ambavimānaṁ aṭṭhamaṁ."
    }
  ]
}
