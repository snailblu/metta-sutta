{
  "uid": "tha-ap318",
  "title": "6 Āsanasanthavikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap318:1.1",
      "pali": "“Cetiyaṁ uttamaṁ nāma,"
    },
    {
      "id": "tha-ap318:1.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap318:1.3",
      "pali": "Araññe irīṇe vane,"
    },
    {
      "id": "tha-ap318:1.4",
      "pali": "andhāhiṇḍāmahaṁ tadā."
    },
    {
      "id": "tha-ap318:2.1",
      "pali": "Pavanā nikkhamantena,"
    },
    {
      "id": "tha-ap318:2.2",
      "pali": "diṭṭhaṁ sīhāsanaṁ mayā;"
    },
    {
      "id": "tha-ap318:2.3",
      "pali": "Ekaṁsaṁ añjaliṁ katvā,"
    },
    {
      "id": "tha-ap318:2.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap318:3.1",
      "pali": "Divasabhāgaṁ thavitvāna,"
    },
    {
      "id": "tha-ap318:3.2",
      "pali": "buddhaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap318:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap318:3.4",
      "pali": "imaṁ vācaṁ udīrayiṁ."
    },
    {
      "id": "tha-ap318:4.1",
      "pali": "‘Namo te purisājañña,"
    },
    {
      "id": "tha-ap318:4.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap318:4.3",
      "pali": "Sabbaññūsi mahāvīra,"
    },
    {
      "id": "tha-ap318:4.4",
      "pali": "lokajeṭṭha narāsabha’."
    },
    {
      "id": "tha-ap318:5.1",
      "pali": "Abhitthavitvā sikhinaṁ,"
    },
    {
      "id": "tha-ap318:5.2",
      "pali": "nimittakaraṇenahaṁ;"
    },
    {
      "id": "tha-ap318:5.3",
      "pali": "Āsanaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap318:5.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap318:6.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap318:6.2",
      "pali": "yaṁ thaviṁ vadataṁ varaṁ;"
    },
    {
      "id": "tha-ap318:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap318:6.4",
      "pali": "thomanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap318:7.1",
      "pali": "Sattavīse ito kappe,"
    },
    {
      "id": "tha-ap318:7.2",
      "pali": "atulā satta āsu te;"
    },
    {
      "id": "tha-ap318:7.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap318:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap318:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap318:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap318:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap318:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā āsanasanthaviko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap318:10.1",
      "pali": "Āsanasanthavikattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
