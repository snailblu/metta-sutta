{
  "uid": "ja530",
  "title": "Soṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja530:1.1",
      "pali": "Disvā nisinnaṁ rājānaṁ,"
    },
    {
      "id": "ja530:1.2",
      "pali": "brahmadattaṁ rathesabhaṁ;"
    },
    {
      "id": "ja530:1.3",
      "pali": "Athassa paṭivedesi,"
    },
    {
      "id": "ja530:1.4",
      "pali": "“yassāsi anukampako."
    },
    {
      "id": "ja530:2.1",
      "pali": "Saṅkiccāyaṁ anuppatto,"
    },
    {
      "id": "ja530:2.2",
      "pali": "isīnaṁ sādhusammato;"
    },
    {
      "id": "ja530:2.3",
      "pali": "Taramānarūpo niyyāhi,"
    },
    {
      "id": "ja530:2.4",
      "pali": "khippaṁ passa mahesinaṁ”."
    },
    {
      "id": "ja530:3.1",
      "pali": "Tato ca rājā taramāno,"
    },
    {
      "id": "ja530:3.2",
      "pali": "yuttamāruyha sandanaṁ;"
    },
    {
      "id": "ja530:3.3",
      "pali": "Mittāmaccaparibyūḷho,"
    },
    {
      "id": "ja530:3.4",
      "pali": "agamāsi rathesabho."
    },
    {
      "id": "ja530:4.1",
      "pali": "Nikkhippa pañca kakudhāni,"
    },
    {
      "id": "ja530:4.2",
      "pali": "kāsīnaṁ raṭṭhavaḍḍhano;"
    },
    {
      "id": "ja530:4.3",
      "pali": "Vālabījanimuṇhīsaṁ,"
    },
    {
      "id": "ja530:4.4",
      "pali": "khaggaṁ chattañcupāhanaṁ."
    },
    {
      "id": "ja530:5.1",
      "pali": "Oruyha rājā yānamhā,"
    },
    {
      "id": "ja530:5.2",
      "pali": "ṭhapayitvā paṭicchadaṁ;"
    },
    {
      "id": "ja530:5.3",
      "pali": "Āsīnaṁ dāyapassasmiṁ,"
    },
    {
      "id": "ja530:5.4",
      "pali": "saṅkiccamupasaṅkami."
    },
    {
      "id": "ja530:6.1",
      "pali": "Upasaṅkamitvā so rājā,"
    },
    {
      "id": "ja530:6.2",
      "pali": "sammodi isinā saha;"
    },
    {
      "id": "ja530:6.3",
      "pali": "Taṁ kathaṁ vītisāretvā,"
    },
    {
      "id": "ja530:6.4",
      "pali": "ekamantaṁ upāvisi."
    },
    {
      "id": "ja530:7.1",
      "pali": "Ekamantaṁ nisinnova,"
    },
    {
      "id": "ja530:7.2",
      "pali": "atha kālaṁ amaññatha;"
    },
    {
      "id": "ja530:7.3",
      "pali": "Tato pāpāni kammāni,"
    },
    {
      "id": "ja530:7.4",
      "pali": "pucchituṁ paṭipajjatha."
    },
    {
      "id": "ja530:8.1",
      "pali": "“Isiṁ pucchāma saṅkiccaṁ,"
    },
    {
      "id": "ja530:8.2",
      "pali": "isīnaṁ sādhusammataṁ;"
    },
    {
      "id": "ja530:8.3",
      "pali": "Āsīnaṁ dāyapassasmiṁ,"
    },
    {
      "id": "ja530:8.4",
      "pali": "isisaṅghapurakkhataṁ."
    },
    {
      "id": "ja530:9.1",
      "pali": "Kaṁ gatiṁ pecca gacchanti,"
    },
    {
      "id": "ja530:9.2",
      "pali": "narā dhammāticārino;"
    },
    {
      "id": "ja530:9.3",
      "pali": "Aticiṇṇo mayā dhammo,"
    },
    {
      "id": "ja530:9.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja530:10.1",
      "pali": "Isī avaca saṅkicco,"
    },
    {
      "id": "ja530:10.2",
      "pali": "kāsīnaṁ raṭṭhavaḍḍhanaṁ;"
    },
    {
      "id": "ja530:10.3",
      "pali": "Āsīnaṁ dāyapassasmiṁ,"
    },
    {
      "id": "ja530:10.4",
      "pali": "“mahārāja suṇohi me."
    },
    {
      "id": "ja530:11.1",
      "pali": "Uppathena vajantassa,"
    },
    {
      "id": "ja530:11.2",
      "pali": "yo maggamanusāsati;"
    },
    {
      "id": "ja530:11.3",
      "pali": "Tassa ce vacanaṁ kayirā,"
    },
    {
      "id": "ja530:11.4",
      "pali": "nāssa maggeyya kaṇṭako."
    },
    {
      "id": "ja530:12.1",
      "pali": "Adhammaṁ paṭipannassa,"
    },
    {
      "id": "ja530:12.2",
      "pali": "yo dhammamanusāsati;"
    },
    {
      "id": "ja530:12.3",
      "pali": "Tassa ce vacanaṁ kayirā,"
    },
    {
      "id": "ja530:12.4",
      "pali": "na so gaccheyya duggatiṁ”."
    },
    {
      "id": "ja530:13.1",
      "pali": "“Dhammo patho mahārāja,"
    },
    {
      "id": "ja530:13.2",
      "pali": "adhammo pana uppatho;"
    },
    {
      "id": "ja530:13.3",
      "pali": "Adhammo nirayaṁ neti,"
    },
    {
      "id": "ja530:13.4",
      "pali": "dhammo pāpeti suggatiṁ."
    },
    {
      "id": "ja530:14.1",
      "pali": "Adhammacārino rāja,"
    },
    {
      "id": "ja530:14.2",
      "pali": "narā visamajīvino;"
    },
    {
      "id": "ja530:14.3",
      "pali": "Yaṁ gatiṁ pecca gacchanti,"
    },
    {
      "id": "ja530:14.4",
      "pali": "niraye te suṇohi me."
    },
    {
      "id": "ja530:15.1",
      "pali": "Sañjīvo kāḷasutto ca,"
    },
    {
      "id": "ja530:15.2",
      "pali": "saṅghāto dve ca roruvā;"
    },
    {
      "id": "ja530:15.3",
      "pali": "Athāparo mahāvīci,"
    },
    {
      "id": "ja530:15.4",
      "pali": "tāpano ca patāpano."
    },
    {
      "id": "ja530:16.1",
      "pali": "Iccete aṭṭha nirayā,"
    },
    {
      "id": "ja530:16.2",
      "pali": "akkhātā duratikkamā;"
    },
    {
      "id": "ja530:16.3",
      "pali": "Ākiṇṇā luddakammehi,"
    },
    {
      "id": "ja530:16.4",
      "pali": "paccekā soḷasussadā."
    },
    {
      "id": "ja530:17.1",
      "pali": "Kadariyatāpanā ghorā,"
    },
    {
      "id": "ja530:17.2",
      "pali": "accimanto mahabbhayā;"
    },
    {
      "id": "ja530:17.3",
      "pali": "Lomahaṁsanarūpā ca,"
    },
    {
      "id": "ja530:17.4",
      "pali": "bhesmā paṭibhayā dukhā."
    },
    {
      "id": "ja530:18.1",
      "pali": "Catukkaṇṇā catudvārā,"
    },
    {
      "id": "ja530:18.2",
      "pali": "vibhattā bhāgaso mitā;"
    },
    {
      "id": "ja530:18.3",
      "pali": "Ayopākārapariyantā,"
    },
    {
      "id": "ja530:18.4",
      "pali": "ayasā paṭikujjitā."
    },
    {
      "id": "ja530:19.1",
      "pali": "Tesaṁ ayomayā bhūmi,"
    },
    {
      "id": "ja530:19.2",
      "pali": "jalitā tejasā yutā;"
    },
    {
      "id": "ja530:19.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "ja530:19.4",
      "pali": "phuṭā tiṭṭhanti sabbadā."
    },
    {
      "id": "ja530:20.1",
      "pali": "Ete patanti niraye,"
    },
    {
      "id": "ja530:20.2",
      "pali": "uddhampādā avaṁsirā;"
    },
    {
      "id": "ja530:20.3",
      "pali": "Isīnaṁ ativattāro,"
    },
    {
      "id": "ja530:20.4",
      "pali": "saññatānaṁ tapassinaṁ."
    },
    {
      "id": "ja530:21.1",
      "pali": "Te bhūnahuno paccanti,"
    },
    {
      "id": "ja530:21.2",
      "pali": "macchā bilakatā yathā;"
    },
    {
      "id": "ja530:21.3",
      "pali": "Saṁvacchare asaṅkheyye,"
    },
    {
      "id": "ja530:21.4",
      "pali": "narā kibbisakārino."
    },
    {
      "id": "ja530:22.1",
      "pali": "Ḍayhamānena gattena,"
    },
    {
      "id": "ja530:22.2",
      "pali": "niccaṁ santarabāhiraṁ;"
    },
    {
      "id": "ja530:22.3",
      "pali": "Nirayā nādhigacchanti,"
    },
    {
      "id": "ja530:22.4",
      "pali": "dvāraṁ nikkhamanesino."
    },
    {
      "id": "ja530:23.1",
      "pali": "Puratthimena dhāvanti,"
    },
    {
      "id": "ja530:23.2",
      "pali": "tato dhāvanti pacchato;"
    },
    {
      "id": "ja530:23.3",
      "pali": "Uttarenapi dhāvanti,"
    },
    {
      "id": "ja530:23.4",
      "pali": "tato dhāvanti dakkhiṇaṁ;"
    },
    {
      "id": "ja530:23.5",
      "pali": "Yaṁ yañhi dvāraṁ gacchanti,"
    },
    {
      "id": "ja530:23.6",
      "pali": "taṁ tadeva pidhīyare."
    },
    {
      "id": "ja530:24.1",
      "pali": "Bahūni vassasahassāni,"
    },
    {
      "id": "ja530:24.2",
      "pali": "janā nirayagāmino;"
    },
    {
      "id": "ja530:24.3",
      "pali": "Bāhā paggayha kandanti,"
    },
    {
      "id": "ja530:24.4",
      "pali": "patvā dukkhaṁ anappakaṁ."
    },
    {
      "id": "ja530:25.1",
      "pali": "Āsīvisaṁva kupitaṁ,"
    },
    {
      "id": "ja530:25.2",
      "pali": "tejassiṁ duratikkamaṁ;"
    },
    {
      "id": "ja530:25.3",
      "pali": "Na sādhurūpe āsīde,"
    },
    {
      "id": "ja530:25.4",
      "pali": "saññatānaṁ tapassinaṁ."
    },
    {
      "id": "ja530:26.1",
      "pali": "Atikāyo mahissāso,"
    },
    {
      "id": "ja530:26.2",
      "pali": "ajjuno kekakādhipo;"
    },
    {
      "id": "ja530:26.3",
      "pali": "Sahassabāhu ucchinno,"
    },
    {
      "id": "ja530:26.4",
      "pali": "isimāsajja gotamaṁ."
    },
    {
      "id": "ja530:27.1",
      "pali": "Arajaṁ rajasā vacchaṁ,"
    },
    {
      "id": "ja530:27.2",
      "pali": "Kisaṁ avakiriya daṇḍakī;"
    },
    {
      "id": "ja530:27.3",
      "pali": "Tālova mūlato chinno,"
    },
    {
      "id": "ja530:27.4",
      "pali": "Sa rājā vibhavaṅgato."
    },
    {
      "id": "ja530:28.1",
      "pali": "Upahacca manaṁ majjho,"
    },
    {
      "id": "ja530:28.2",
      "pali": "mātaṅgasmiṁ yasassine;"
    },
    {
      "id": "ja530:28.3",
      "pali": "Sapārisajjo ucchinno,"
    },
    {
      "id": "ja530:28.4",
      "pali": "majjhāraññaṁ tadā ahu."
    },
    {
      "id": "ja530:29.1",
      "pali": "Kaṇhadīpāyanāsajja,"
    },
    {
      "id": "ja530:29.2",
      "pali": "Isiṁ andhakaveṇḍayo;"
    },
    {
      "id": "ja530:29.3",
      "pali": "Aññoññaṁ musalā hantvā,"
    },
    {
      "id": "ja530:29.4",
      "pali": "Sampattā yamasādhanaṁ."
    },
    {
      "id": "ja530:30.1",
      "pali": "Athāyaṁ isinā satto,"
    },
    {
      "id": "ja530:30.2",
      "pali": "antalikkhacaro pure;"
    },
    {
      "id": "ja530:30.3",
      "pali": "Pāvekkhi pathaviṁ cecco,"
    },
    {
      "id": "ja530:30.4",
      "pali": "hīnatto pattapariyāyaṁ."
    },
    {
      "id": "ja530:31.1",
      "pali": "Tasmā hi chandāgamanaṁ,"
    },
    {
      "id": "ja530:31.2",
      "pali": "nappasaṁsanti paṇḍitā;"
    },
    {
      "id": "ja530:31.3",
      "pali": "Aduṭṭhacitto bhāseyya,"
    },
    {
      "id": "ja530:31.4",
      "pali": "giraṁ saccūpasaṁhitaṁ."
    },
    {
      "id": "ja530:32.1",
      "pali": "Manasā ce paduṭṭhena,"
    },
    {
      "id": "ja530:32.2",
      "pali": "yo naro pekkhate muniṁ;"
    },
    {
      "id": "ja530:32.3",
      "pali": "Vijjācaraṇasampannaṁ,"
    },
    {
      "id": "ja530:32.4",
      "pali": "gantā so nirayaṁ adho."
    },
    {
      "id": "ja530:33.1",
      "pali": "Ye vuḍḍhe paribhāsanti,"
    },
    {
      "id": "ja530:33.2",
      "pali": "pharusūpakkamā janā;"
    },
    {
      "id": "ja530:33.3",
      "pali": "Anapaccā adāyādā,"
    },
    {
      "id": "ja530:33.4",
      "pali": "tālavatthu bhavanti te."
    },
    {
      "id": "ja530:34.1",
      "pali": "Yo ca pabbajitaṁ hanti,"
    },
    {
      "id": "ja530:34.2",
      "pali": "katakiccaṁ mahesinaṁ;"
    },
    {
      "id": "ja530:34.3",
      "pali": "Sa kāḷasutte niraye,"
    },
    {
      "id": "ja530:34.4",
      "pali": "cirarattāya paccati."
    },
    {
      "id": "ja530:35.1",
      "pali": "Yo ca rājā adhammaṭṭho,"
    },
    {
      "id": "ja530:35.2",
      "pali": "raṭṭhaviddhaṁsano mago;"
    },
    {
      "id": "ja530:35.3",
      "pali": "Tāpayitvā janapadaṁ,"
    },
    {
      "id": "ja530:35.4",
      "pali": "tāpane pecca paccati."
    },
    {
      "id": "ja530:36.1",
      "pali": "So ca vassasahassāni,"
    },
    {
      "id": "ja530:36.2",
      "pali": "sataṁ dibbāni paccati;"
    },
    {
      "id": "ja530:36.3",
      "pali": "Accisaṅghapareto so,"
    },
    {
      "id": "ja530:36.4",
      "pali": "dukkhaṁ vedeti vedanaṁ."
    },
    {
      "id": "ja530:37.1",
      "pali": "Tassa aggisikhā kāyā,"
    },
    {
      "id": "ja530:37.2",
      "pali": "niccharanti pabhassarā;"
    },
    {
      "id": "ja530:37.3",
      "pali": "Tejobhakkhassa gattāni,"
    },
    {
      "id": "ja530:37.4",
      "pali": "lomehi ca nakhehi ca."
    },
    {
      "id": "ja530:38.1",
      "pali": "Ḍayhamānena gattena,"
    },
    {
      "id": "ja530:38.2",
      "pali": "niccaṁ santarabāhiraṁ;"
    },
    {
      "id": "ja530:38.3",
      "pali": "Dukkhābhitunno nadati,"
    },
    {
      "id": "ja530:38.4",
      "pali": "nāgo tuttaṭṭito yathā."
    },
    {
      "id": "ja530:39.1",
      "pali": "Yo lobhā pitaraṁ hanti,"
    },
    {
      "id": "ja530:39.2",
      "pali": "dosā vā purisādhamo;"
    },
    {
      "id": "ja530:39.3",
      "pali": "Sa kāḷasutte niraye,"
    },
    {
      "id": "ja530:39.4",
      "pali": "cirarattāya paccati."
    },
    {
      "id": "ja530:40.1",
      "pali": "Sa tādiso paccati lohakumbhiyaṁ,"
    },
    {
      "id": "ja530:40.2",
      "pali": "Pakkañca sattīhi hananti nittacaṁ;"
    },
    {
      "id": "ja530:40.3",
      "pali": "Andhaṁ karitvā muttakarīsabhakkhaṁ,"
    },
    {
      "id": "ja530:40.4",
      "pali": "Khāre nimujjanti tathāvidhaṁ naraṁ."
    },
    {
      "id": "ja530:41.1",
      "pali": "Tattaṁ pakkuthitamayoguḷañca,"
    },
    {
      "id": "ja530:41.2",
      "pali": "Dīghe ca phāle cirarattatāpite;"
    },
    {
      "id": "ja530:41.3",
      "pali": "Vikkhambhamādāya vibandharajjubhi,"
    },
    {
      "id": "ja530:41.4",
      "pali": "Vivaṭe mukhe sampavisanti rakkhasā."
    },
    {
      "id": "ja530:42.1",
      "pali": "Sāmā ca soṇā sabalā ca gijjhā,"
    },
    {
      "id": "ja530:42.2",
      "pali": "Kākoḷasaṅghā ca dijā ayomukhā;"
    },
    {
      "id": "ja530:42.3",
      "pali": "Saṅgamma khādanti vipphandamānaṁ,"
    },
    {
      "id": "ja530:42.4",
      "pali": "Jivhaṁ vibhajja vighāsaṁ salohitaṁ."
    },
    {
      "id": "ja530:43.1",
      "pali": "Taṁ daḍḍhatālaṁ paribhinnagattaṁ,"
    },
    {
      "id": "ja530:43.2",
      "pali": "Nippothayantā anuvicaranti rakkhasā;"
    },
    {
      "id": "ja530:43.3",
      "pali": "Ratī hi nesaṁ dukhino panītare,"
    },
    {
      "id": "ja530:43.4",
      "pali": "Etādisasmiṁ niraye vasanti;"
    },
    {
      "id": "ja530:43.5",
      "pali": "Ye keci loke idha pettighātino."
    },
    {
      "id": "ja530:44.1",
      "pali": "Putto ca mātaraṁ hantvā,"
    },
    {
      "id": "ja530:44.2",
      "pali": "ito gantvā yamakkhayaṁ;"
    },
    {
      "id": "ja530:44.3",
      "pali": "Bhusamāpajjate dukkhaṁ,"
    },
    {
      "id": "ja530:44.4",
      "pali": "attakammaphalūpago."
    },
    {
      "id": "ja530:45.1",
      "pali": "Amanussā atibalā,"
    },
    {
      "id": "ja530:45.2",
      "pali": "hantāraṁ janayantiyā;"
    },
    {
      "id": "ja530:45.3",
      "pali": "Ayomayehi vālehi,"
    },
    {
      "id": "ja530:45.4",
      "pali": "pīḷayanti punappunaṁ."
    },
    {
      "id": "ja530:46.1",
      "pali": "Tamassavaṁ sakā gattā,"
    },
    {
      "id": "ja530:46.2",
      "pali": "rudhiraṁ attasambhavaṁ;"
    },
    {
      "id": "ja530:46.3",
      "pali": "Tambalohavilīnaṁva,"
    },
    {
      "id": "ja530:46.4",
      "pali": "tattaṁ pāyenti mattighaṁ."
    },
    {
      "id": "ja530:47.1",
      "pali": "Jigucchaṁ kuṇapaṁ pūtiṁ,"
    },
    {
      "id": "ja530:47.2",
      "pali": "Duggandhaṁ gūthakaddamaṁ;"
    },
    {
      "id": "ja530:47.3",
      "pali": "Pubbalohitasaṅkāsaṁ,"
    },
    {
      "id": "ja530:47.4",
      "pali": "Rahadamogayha tiṭṭhati."
    },
    {
      "id": "ja530:48.1",
      "pali": "Tamenaṁ kimayo tattha,"
    },
    {
      "id": "ja530:48.2",
      "pali": "atikāyā ayomukhā;"
    },
    {
      "id": "ja530:48.3",
      "pali": "Chaviṁ bhetvāna khādanti,"
    },
    {
      "id": "ja530:48.4",
      "pali": "saṅgiddhā maṁsalohite."
    },
    {
      "id": "ja530:49.1",
      "pali": "So ca taṁ nirayaṁ patto,"
    },
    {
      "id": "ja530:49.2",
      "pali": "nimuggo sataporisaṁ;"
    },
    {
      "id": "ja530:49.3",
      "pali": "Pūtikaṁ kuṇapaṁ vāti,"
    },
    {
      "id": "ja530:49.4",
      "pali": "samantā satayojanaṁ."
    },
    {
      "id": "ja530:50.1",
      "pali": "Cakkhumāpi hi cakkhūhi,"
    },
    {
      "id": "ja530:50.2",
      "pali": "tena gandhena jīyati;"
    },
    {
      "id": "ja530:50.3",
      "pali": "Etādisaṁ brahmadatta,"
    },
    {
      "id": "ja530:50.4",
      "pali": "mātugho labhate dukhaṁ."
    },
    {
      "id": "ja530:51.1",
      "pali": "Khuradhāramanukkamma,"
    },
    {
      "id": "ja530:51.2",
      "pali": "tikkhaṁ durabhisambhavaṁ;"
    },
    {
      "id": "ja530:51.3",
      "pali": "Patanti gabbhapātiyo,"
    },
    {
      "id": "ja530:51.4",
      "pali": "duggaṁ vetaraṇiṁ nadiṁ."
    },
    {
      "id": "ja530:52.1",
      "pali": "Ayomayā simbaliyo,"
    },
    {
      "id": "ja530:52.2",
      "pali": "soḷasaṅgulakaṇṭakā;"
    },
    {
      "id": "ja530:52.3",
      "pali": "Ubhato abhilambanti,"
    },
    {
      "id": "ja530:52.4",
      "pali": "duggaṁ vetaraṇiṁ nadiṁ."
    },
    {
      "id": "ja530:53.1",
      "pali": "Te accimanto tiṭṭhanti,"
    },
    {
      "id": "ja530:53.2",
      "pali": "aggikkhandhāva ārakā;"
    },
    {
      "id": "ja530:53.3",
      "pali": "Ādittā jātavedena,"
    },
    {
      "id": "ja530:53.4",
      "pali": "uddhaṁ yojanamuggatā."
    },
    {
      "id": "ja530:54.1",
      "pali": "Ete vajanti niraye,"
    },
    {
      "id": "ja530:54.2",
      "pali": "tatte tikhiṇakaṇṭake;"
    },
    {
      "id": "ja530:54.3",
      "pali": "Nāriyo ca aticārā,"
    },
    {
      "id": "ja530:54.4",
      "pali": "narā ca paradāragū."
    },
    {
      "id": "ja530:55.1",
      "pali": "Te patanti adhokkhandhā,"
    },
    {
      "id": "ja530:55.2",
      "pali": "vivattā vihatā puthū;"
    },
    {
      "id": "ja530:55.3",
      "pali": "Sayanti vinividdhaṅgā,"
    },
    {
      "id": "ja530:55.4",
      "pali": "dīghaṁ jagganti sabbadā."
    },
    {
      "id": "ja530:56.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "ja530:56.2",
      "pali": "mahatiṁ pabbatūpamaṁ;"
    },
    {
      "id": "ja530:56.3",
      "pali": "Lohakumbhiṁ pavajjanti,"
    },
    {
      "id": "ja530:56.4",
      "pali": "tattaṁ aggisamūdakaṁ."
    },
    {
      "id": "ja530:57.1",
      "pali": "Evaṁ divā ca ratto ca,"
    },
    {
      "id": "ja530:57.2",
      "pali": "dussīlā mohapārutā;"
    },
    {
      "id": "ja530:57.3",
      "pali": "Anubhonti sakaṁ kammaṁ,"
    },
    {
      "id": "ja530:57.4",
      "pali": "pubbe dukkaṭamattano."
    },
    {
      "id": "ja530:58.1",
      "pali": "Yā ca bhariyā dhanakkītā,"
    },
    {
      "id": "ja530:58.2",
      "pali": "sāmikaṁ atimaññati;"
    },
    {
      "id": "ja530:58.3",
      "pali": "Sassuṁ vā sasuraṁ vāpi,"
    },
    {
      "id": "ja530:58.4",
      "pali": "jeṭṭhaṁ vāpi nanandaraṁ."
    },
    {
      "id": "ja530:59.1",
      "pali": "Tassā vaṅkena jivhaggaṁ,"
    },
    {
      "id": "ja530:59.2",
      "pali": "nibbahanti sabandhanaṁ;"
    },
    {
      "id": "ja530:59.3",
      "pali": "Sa byāmamattaṁ kiminaṁ,"
    },
    {
      "id": "ja530:59.4",
      "pali": "jivhaṁ passati attani;"
    },
    {
      "id": "ja530:59.5",
      "pali": "Viññāpetuṁ na sakkoti,"
    },
    {
      "id": "ja530:59.6",
      "pali": "tāpane pecca paccati."
    },
    {
      "id": "ja530:60.1",
      "pali": "Orabbhikā sūkarikā,"
    },
    {
      "id": "ja530:60.2",
      "pali": "macchikā migabandhakā;"
    },
    {
      "id": "ja530:60.3",
      "pali": "Corā goghātakā luddā,"
    },
    {
      "id": "ja530:60.4",
      "pali": "avaṇṇe vaṇṇakārakā."
    },
    {
      "id": "ja530:61.1",
      "pali": "Sattīhi lohakūṭehi,"
    },
    {
      "id": "ja530:61.2",
      "pali": "nettiṁsehi usūhi ca;"
    },
    {
      "id": "ja530:61.3",
      "pali": "Haññamānā khāranadiṁ,"
    },
    {
      "id": "ja530:61.4",
      "pali": "papatanti avaṁsirā."
    },
    {
      "id": "ja530:62.1",
      "pali": "Sāyaṁ pāto kūṭakārī,"
    },
    {
      "id": "ja530:62.2",
      "pali": "ayokūṭehi haññati;"
    },
    {
      "id": "ja530:62.3",
      "pali": "Tato vantaṁ durattānaṁ,"
    },
    {
      "id": "ja530:62.4",
      "pali": "paresaṁ bhuñjare sadā."
    },
    {
      "id": "ja530:63.1",
      "pali": "Dhaṅkā bheraṇḍakā gijjhā,"
    },
    {
      "id": "ja530:63.2",
      "pali": "kākoḷā ca ayomukhā;"
    },
    {
      "id": "ja530:63.3",
      "pali": "Vipphandamānaṁ khādanti,"
    },
    {
      "id": "ja530:63.4",
      "pali": "naraṁ kibbisakārakaṁ."
    },
    {
      "id": "ja530:64.1",
      "pali": "Ye migena migaṁ hanti,"
    },
    {
      "id": "ja530:64.2",
      "pali": "pakkhiṁ vā pana pakkhinā;"
    },
    {
      "id": "ja530:64.3",
      "pali": "Asanto rajasā channā,"
    },
    {
      "id": "ja530:64.4",
      "pali": "gantā te nirayussadaṁ."
    },
    {
      "id": "ja530:65.1",
      "pali": "Santo ca uddhaṁ gacchanti,"
    },
    {
      "id": "ja530:65.2",
      "pali": "suciṇṇenidha kammunā;"
    },
    {
      "id": "ja530:65.3",
      "pali": "Suciṇṇassa phalaṁ passa,"
    },
    {
      "id": "ja530:65.4",
      "pali": "saindā devā sabrahmakā."
    },
    {
      "id": "ja530:66.1",
      "pali": "Taṁ taṁ brūmi mahārāja,"
    },
    {
      "id": "ja530:66.2",
      "pali": "Dhammaṁ raṭṭhapatī cara;"
    },
    {
      "id": "ja530:66.3",
      "pali": "Tathā rāja carāhi dhammaṁ,"
    },
    {
      "id": "ja530:66.4",
      "pali": "Yathā taṁ suciṇṇaṁ nānutappeyya pacchā”ti."
    },
    {
      "id": "ja530:67.1",
      "pali": "Saṅkiccajātakaṁ dutiyaṁ."
    },
    {
      "id": "ja530:68.1",
      "pali": "Saṭṭhinipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja530:69.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja530:70.1",
      "pali": "Atha saṭṭhinipātamhi,"
    },
    {
      "id": "ja530:70.2",
      "pali": "Suṇātha mama bhāsitaṁ;"
    },
    {
      "id": "ja530:70.3",
      "pali": "Jātakasavhayano pavaro,"
    },
    {
      "id": "ja530:70.4",
      "pali": "Soṇakaarindamasavhayano;"
    },
    {
      "id": "ja530:70.5",
      "pali": "Tathā vuttarathesabhakiccavaroti."
    }
  ]
}
