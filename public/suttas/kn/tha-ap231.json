{
  "uid": "tha-ap231",
  "title": "9 Sukatāveḷiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap231:1.1",
      "pali": "“Asito nāma nāmena,"
    },
    {
      "id": "tha-ap231:1.2",
      "pali": "mālākāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap231:1.3",
      "pali": "Āveḷaṁ paggahetvāna,"
    },
    {
      "id": "tha-ap231:1.4",
      "pali": "rañño dātuṁ vajāmahaṁ."
    },
    {
      "id": "tha-ap231:2.1",
      "pali": "Asampattomhi rājānaṁ,"
    },
    {
      "id": "tha-ap231:2.2",
      "pali": "addasaṁ sikhināyakaṁ;"
    },
    {
      "id": "tha-ap231:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap231:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap231:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap231:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap231:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap231:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap231:4.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap231:4.2",
      "pali": "rājāhosiṁ mahabbalo;"
    },
    {
      "id": "tha-ap231:4.3",
      "pali": "Vebhāro nāma nāmena,"
    },
    {
      "id": "tha-ap231:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap231:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap231:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap231:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap231:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sukatāveḷiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap231:7.1",
      "pali": "Sukatāveḷiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
