{
  "uid": "tha-ap132",
  "title": "Padumapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap132:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap132:1.2",
      "pali": "gotamo nāma pabbato;"
    },
    {
      "id": "tha-ap132:1.3",
      "pali": "Nānārukkhehi sañchanno,"
    },
    {
      "id": "tha-ap132:1.4",
      "pali": "mahābhūtagaṇālayo."
    },
    {
      "id": "tha-ap132:2.1",
      "pali": "Vemajjhamhi ca tassāsi,"
    },
    {
      "id": "tha-ap132:2.2",
      "pali": "assamo abhinimmito;"
    },
    {
      "id": "tha-ap132:2.3",
      "pali": "Purakkhato sasissehi,"
    },
    {
      "id": "tha-ap132:2.4",
      "pali": "vasāmi assame ahaṁ."
    },
    {
      "id": "tha-ap132:3.1",
      "pali": "Āyantu me sissagaṇā,"
    },
    {
      "id": "tha-ap132:3.2",
      "pali": "padumaṁ āharantu me;"
    },
    {
      "id": "tha-ap132:3.3",
      "pali": "Buddhapūjaṁ karissāmi,"
    },
    {
      "id": "tha-ap132:3.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap132:4.1",
      "pali": "Evanti te paṭissutvā,"
    },
    {
      "id": "tha-ap132:4.2",
      "pali": "padumaṁ āhariṁsu me;"
    },
    {
      "id": "tha-ap132:4.3",
      "pali": "Tathā nimittaṁ katvāhaṁ,"
    },
    {
      "id": "tha-ap132:4.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap132:5.1",
      "pali": "Sisse tadā samānetvā,"
    },
    {
      "id": "tha-ap132:5.2",
      "pali": "sādhukaṁ anusāsahaṁ;"
    },
    {
      "id": "tha-ap132:5.3",
      "pali": "Mā kho tumhe pamajjittha,"
    },
    {
      "id": "tha-ap132:5.4",
      "pali": "appamādo sukhāvaho."
    },
    {
      "id": "tha-ap132:6.1",
      "pali": "Evaṁ samanusāsitvā,"
    },
    {
      "id": "tha-ap132:6.2",
      "pali": "te sisse vacanakkhame;"
    },
    {
      "id": "tha-ap132:6.3",
      "pali": "Appamādaguṇe yutto,"
    },
    {
      "id": "tha-ap132:6.4",
      "pali": "tadā kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap132:7.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap132:7.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap132:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap132:7.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap132:8.1",
      "pali": "Ekapaññāsakappamhi,"
    },
    {
      "id": "tha-ap132:8.2",
      "pali": "rājā āsiṁ jaluttamo;"
    },
    {
      "id": "tha-ap132:8.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap132:8.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap132:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap132:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap132:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap132:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap132:11.1",
      "pali": "Padumapūjakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap132:12.1",
      "pali": "Sereyyavaggo terasamo."
    },
    {
      "id": "tha-ap132:13.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap132:14.1",
      "pali": "Sereyyako pupphathūpi,"
    },
    {
      "id": "tha-ap132:14.2",
      "pali": "pāyaso gandhathomako;"
    },
    {
      "id": "tha-ap132:14.3",
      "pali": "Āsani phalasaññī ca,"
    },
    {
      "id": "tha-ap132:14.4",
      "pali": "gaṇṭhipadumapupphiyo;"
    },
    {
      "id": "tha-ap132:14.5",
      "pali": "Pañcuttarasatā gāthā,"
    },
    {
      "id": "tha-ap132:14.6",
      "pali": "gaṇitā atthadassibhi."
    }
  ]
}
