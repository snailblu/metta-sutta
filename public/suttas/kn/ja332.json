{
  "uid": "ja332",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja332:1.1",
      "pali": "“Api hantvā hato brūti,"
    },
    {
      "id": "ja332:1.2",
      "pali": "jetvā jitoti bhāsati;"
    },
    {
      "id": "ja332:1.3",
      "pali": "Pubbamakkhāyino rāja,"
    },
    {
      "id": "ja332:1.4",
      "pali": "aññadatthu na saddahe."
    },
    {
      "id": "ja332:2.1",
      "pali": "Tasmā paṇḍitajātiyo,"
    },
    {
      "id": "ja332:2.2",
      "pali": "suṇeyya itarassapi;"
    },
    {
      "id": "ja332:2.3",
      "pali": "Ubhinnaṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja332:2.4",
      "pali": "yathā dhammo tathā kare."
    },
    {
      "id": "ja332:3.1",
      "pali": "Alaso gihī kāmabhogī na sādhu,"
    },
    {
      "id": "ja332:3.2",
      "pali": "Asaññato pabbajito na sādhu;"
    },
    {
      "id": "ja332:3.3",
      "pali": "Rājā na sādhu anisammakārī,"
    },
    {
      "id": "ja332:3.4",
      "pali": "Yo paṇḍito kodhano taṁ na sādhu."
    },
    {
      "id": "ja332:4.1",
      "pali": "Nisamma khattiyo kayirā,"
    },
    {
      "id": "ja332:4.2",
      "pali": "nānisamma disampati;"
    },
    {
      "id": "ja332:4.3",
      "pali": "Nisammakārino rāja,"
    },
    {
      "id": "ja332:4.4",
      "pali": "yaso kitti ca vaḍḍhatī”ti."
    },
    {
      "id": "ja332:5.1",
      "pali": "Rathalaṭṭhijātakaṁ dutiyaṁ."
    }
  ]
}
