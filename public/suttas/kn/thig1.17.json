{
  "uid": "thig1.17",
  "title": "Dhammātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.17:1.1",
      "pali": "“Piṇḍapātaṁ caritvāna,"
    },
    {
      "id": "thig1.17:1.2",
      "pali": "daṇḍamolubbha dubbalā;"
    },
    {
      "id": "thig1.17:1.3",
      "pali": "Vedhamānehi gattehi,"
    },
    {
      "id": "thig1.17:1.4",
      "pali": "tattheva nipatiṁ chamā;"
    },
    {
      "id": "thig1.17:1.5",
      "pali": "Disvā ādīnavaṁ kāye,"
    },
    {
      "id": "thig1.17:1.6",
      "pali": "atha cittaṁ vimucci me”ti."
    },
    {
      "id": "thig1.17:2.1",
      "pali": "… Dhammā therī …."
    }
  ]
}
