{
  "uid": "ja424",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja424:1.1",
      "pali": "“Ādittasmiṁ agārasmiṁ,"
    },
    {
      "id": "ja424:1.2",
      "pali": "yaṁ nīharati bhājanaṁ;"
    },
    {
      "id": "ja424:1.3",
      "pali": "Taṁ tassa hoti atthāya,"
    },
    {
      "id": "ja424:1.4",
      "pali": "no ca yaṁ tattha ḍayhati."
    },
    {
      "id": "ja424:2.1",
      "pali": "Evamādīpito loko,"
    },
    {
      "id": "ja424:2.2",
      "pali": "jarāya maraṇena ca;"
    },
    {
      "id": "ja424:2.3",
      "pali": "Nīharetheva dānena,"
    },
    {
      "id": "ja424:2.4",
      "pali": "dinnaṁ hoti sunīhataṁ”."
    },
    {
      "id": "ja424:3.1",
      "pali": "“Yo dhammaladdhassa dadāti dānaṁ,"
    },
    {
      "id": "ja424:3.2",
      "pali": "Uṭṭhānaviriyādhigatassa jantu;"
    },
    {
      "id": "ja424:3.3",
      "pali": "Atikkamma so vetaraṇiṁ yamassa,"
    },
    {
      "id": "ja424:3.4",
      "pali": "Dibbāni ṭhānāni upeti macco."
    },
    {
      "id": "ja424:4.1",
      "pali": "Dānañca yuddhañca samānamāhu,"
    },
    {
      "id": "ja424:4.2",
      "pali": "Appāpi santā bahuke jinanti;"
    },
    {
      "id": "ja424:4.3",
      "pali": "Appampi ce saddahāno dadāti,"
    },
    {
      "id": "ja424:4.4",
      "pali": "Teneva so hoti sukhī parattha."
    },
    {
      "id": "ja424:5.1",
      "pali": "Viceyya dānaṁ sugatappasatthaṁ,"
    },
    {
      "id": "ja424:5.2",
      "pali": "Ye dakkhiṇeyyā idha jīvaloke;"
    },
    {
      "id": "ja424:5.3",
      "pali": "Etesu dinnāni mahapphalāni,"
    },
    {
      "id": "ja424:5.4",
      "pali": "Bījāni vuttāni yathā sukhette."
    },
    {
      "id": "ja424:6.1",
      "pali": "Yo pāṇabhūtāni aheṭhayaṁ caraṁ,"
    },
    {
      "id": "ja424:6.2",
      "pali": "Parūpavādā na karoti pāpaṁ;"
    },
    {
      "id": "ja424:6.3",
      "pali": "Bhīruṁ pasaṁsanti na tattha sūraṁ,"
    },
    {
      "id": "ja424:6.4",
      "pali": "Bhayā hi santo na karonti pāpaṁ."
    },
    {
      "id": "ja424:7.1",
      "pali": "Hīnena brahmacariyena,"
    },
    {
      "id": "ja424:7.2",
      "pali": "khattiye upapajjati;"
    },
    {
      "id": "ja424:7.3",
      "pali": "Majjhimena ca devattaṁ,"
    },
    {
      "id": "ja424:7.4",
      "pali": "uttamena visujjhati."
    },
    {
      "id": "ja424:8.1",
      "pali": "Addhā hi dānaṁ bahudhā pasatthaṁ,"
    },
    {
      "id": "ja424:8.2",
      "pali": "Dānā ca kho dhammapadaṁva seyyo;"
    },
    {
      "id": "ja424:8.3",
      "pali": "Pubbeva hi pubbatareva santo,"
    },
    {
      "id": "ja424:8.4",
      "pali": "Nibbānamevajjhagamuṁ sapaññā”ti."
    },
    {
      "id": "ja424:9.1",
      "pali": "Ādittajātakaṁ aṭṭhamaṁ."
    }
  ]
}
