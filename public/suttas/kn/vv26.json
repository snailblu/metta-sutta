{
  "uid": "vv26",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv26:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv26:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv26:1.3",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv26:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv26:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv26:2.3",
      "pali": "vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv26:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv26:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv26:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv26:4.1",
      "pali": "“Suniddāti maṁ aññaṁsu,"
    },
    {
      "id": "vv26:4.2",
      "pali": "rājagahasmiṁ upāsikā;"
    },
    {
      "id": "vv26:4.3",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "vv26:4.4",
      "pali": "saṁvibhāgaratā sadā."
    },
    {
      "id": "vv26:5.1",
      "pali": "(…)"
    },
    {
      "id": "vv26:6.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv26:6.2",
      "pali": "ariyasaccāna kovidā;"
    },
    {
      "id": "vv26:6.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv26:6.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv26:7.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv26:7.2",
      "pali": "…pe…"
    },
    {
      "id": "vv26:7.3",
      "pali": "vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv26:8.1",
      "pali": "Suniddāvimānaṁ navamaṁ."
    }
  ]
}
