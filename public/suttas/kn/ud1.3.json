{
  "uid": "ud1.3",
  "title": "Tatiyabodhisutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud1.3:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud1.3:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre bodhirukkhamūle paṭhamābhisambuddho."
    },
    {
      "id": "ud1.3:1.3",
      "pali": "Tena kho pana samayena bhagavā sattāhaṁ ekapallaṅkena nisinno hoti vimuttisukhapaṭisaṁvedī."
    },
    {
      "id": "ud1.3:1.4",
      "pali": "Atha kho bhagavā tassa sattāhassa accayena tamhā samādhimhā vuṭṭhahitvā rattiyā pacchimaṁ yāmaṁ paṭiccasamuppādaṁ anulomapaṭilomaṁ sādhukaṁ manasākāsi:"
    },
    {
      "id": "ud1.3:2.1",
      "pali": "“Iti imasmiṁ sati idaṁ hoti, imassuppādā idaṁ uppajjati,"
    },
    {
      "id": "ud1.3:2.2",
      "pali": "imasmiṁ asati idaṁ na hoti, imassa nirodhā idaṁ nirujjhati; yadidaṁ—"
    },
    {
      "id": "ud1.3:2.3",
      "pali": "avijjāpaccayā saṅkhārā,"
    },
    {
      "id": "ud1.3:2.4",
      "pali": "saṅkhārapaccayā viññāṇaṁ,"
    },
    {
      "id": "ud1.3:2.5",
      "pali": "viññāṇapaccayā nāmarūpaṁ,"
    },
    {
      "id": "ud1.3:2.6",
      "pali": "nāmarūpapaccayā saḷāyatanaṁ,"
    },
    {
      "id": "ud1.3:2.7",
      "pali": "saḷāyatanapaccayā phasso,"
    },
    {
      "id": "ud1.3:2.8",
      "pali": "phassapaccayā vedanā,"
    },
    {
      "id": "ud1.3:2.9",
      "pali": "vedanāpaccayā taṇhā,"
    },
    {
      "id": "ud1.3:2.10",
      "pali": "taṇhāpaccayā upādānaṁ,"
    },
    {
      "id": "ud1.3:2.11",
      "pali": "upādānapaccayā bhavo,"
    },
    {
      "id": "ud1.3:2.12",
      "pali": "bhavapaccayā jāti,"
    },
    {
      "id": "ud1.3:2.13",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "ud1.3:2.14",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "ud1.3:3.1",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho,"
    },
    {
      "id": "ud1.3:3.2",
      "pali": "saṅkhāranirodhā viññāṇanirodho,"
    },
    {
      "id": "ud1.3:3.3",
      "pali": "viññāṇanirodhā nāmarūpanirodho,"
    },
    {
      "id": "ud1.3:3.4",
      "pali": "nāmarūpanirodhā saḷāyatananirodho,"
    },
    {
      "id": "ud1.3:3.5",
      "pali": "saḷāyatananirodhā phassanirodho,"
    },
    {
      "id": "ud1.3:3.6",
      "pali": "phassanirodhā vedanānirodho,"
    },
    {
      "id": "ud1.3:3.7",
      "pali": "vedanānirodhā taṇhānirodho,"
    },
    {
      "id": "ud1.3:3.8",
      "pali": "taṇhānirodhā upādānanirodho,"
    },
    {
      "id": "ud1.3:3.9",
      "pali": "upādānanirodhā bhavanirodho,"
    },
    {
      "id": "ud1.3:3.10",
      "pali": "bhavanirodhā jātinirodho,"
    },
    {
      "id": "ud1.3:3.11",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "ud1.3:3.12",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "ud1.3:4.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud1.3:5.1",
      "pali": "“Yadā have pātubhavanti dhammā,"
    },
    {
      "id": "ud1.3:5.2",
      "pali": "Ātāpino jhāyato brāhmaṇassa;"
    },
    {
      "id": "ud1.3:5.3",
      "pali": "Vidhūpayaṁ tiṭṭhati mārasenaṁ,"
    },
    {
      "id": "ud1.3:5.4",
      "pali": "Sūriyova obhāsayamantalikkhan”ti."
    },
    {
      "id": "ud1.3:5.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
