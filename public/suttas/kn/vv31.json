{
  "uid": "vv31",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv31:1.1",
      "pali": "“Pallaṅkaseṭṭhe maṇisoṇṇacitte,"
    },
    {
      "id": "vv31:1.2",
      "pali": "Pupphābhikiṇṇe sayane uḷāre;"
    },
    {
      "id": "vv31:1.3",
      "pali": "Tatthacchasi devi mahānubhāve,"
    },
    {
      "id": "vv31:1.4",
      "pali": "Uccāvacā iddhi vikubbamānā."
    },
    {
      "id": "vv31:2.1",
      "pali": "Imā ca te accharāyo samantato,"
    },
    {
      "id": "vv31:2.2",
      "pali": "Naccanti gāyanti pamodayanti;"
    },
    {
      "id": "vv31:2.3",
      "pali": "Deviddhipattāsi mahānubhāve,"
    },
    {
      "id": "vv31:2.4",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv31:2.5",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv31:2.6",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv31:3.1",
      "pali": "“Ahaṁ manussesu manussabhūtā,"
    },
    {
      "id": "vv31:3.2",
      "pali": "Aḍḍhe kule suṇisā ahosiṁ;"
    },
    {
      "id": "vv31:3.3",
      "pali": "Akkodhanā bhattuvasānuvattinī,"
    },
    {
      "id": "vv31:3.4",
      "pali": "Uposathe appamattā ahosiṁ."
    },
    {
      "id": "vv31:4.1",
      "pali": "Manussabhūtā daharā apāpikā,"
    },
    {
      "id": "vv31:4.2",
      "pali": "Pasannacittā patimābhirādhayiṁ;"
    },
    {
      "id": "vv31:4.3",
      "pali": "Divā ca ratto ca manāpacārinī,"
    },
    {
      "id": "vv31:4.4",
      "pali": "Ahaṁ pure sīlavatī ahosiṁ."
    },
    {
      "id": "vv31:5.1",
      "pali": "Pāṇātipātā viratā acorikā,"
    },
    {
      "id": "vv31:5.2",
      "pali": "Saṁsuddhakāyā sucibrahmacārinī;"
    },
    {
      "id": "vv31:5.3",
      "pali": "Amajjapā no ca musā abhāṇiṁ,"
    },
    {
      "id": "vv31:5.4",
      "pali": "Sikkhāpadesu paripūrakārinī."
    },
    {
      "id": "vv31:6.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv31:6.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv31:6.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv31:6.4",
      "pali": "pasannamānasā ahaṁ."
    },
    {
      "id": "vv31:7.1",
      "pali": "Aṭṭhaṅgupetaṁ anudhammacārinī,"
    },
    {
      "id": "vv31:7.2",
      "pali": "Uposathaṁ pītimanā upāvasiṁ;"
    },
    {
      "id": "vv31:7.3",
      "pali": "Imañca ariyaṁ aṭṭhaṅgavarehupetaṁ,"
    },
    {
      "id": "vv31:7.4",
      "pali": "Samādiyitvā kusalaṁ sukhudrayaṁ;"
    },
    {
      "id": "vv31:7.5",
      "pali": "Patimhi kalyāṇī vasānuvattinī,"
    },
    {
      "id": "vv31:7.6",
      "pali": "Ahosiṁ pubbe sugatassa sāvikā."
    },
    {
      "id": "vv31:8.1",
      "pali": "Etādisaṁ kusalaṁ jīvaloke,"
    },
    {
      "id": "vv31:8.2",
      "pali": "Kammaṁ karitvāna visesabhāginī;"
    },
    {
      "id": "vv31:8.3",
      "pali": "Kāyassa bhedā abhisamparāyaṁ,"
    },
    {
      "id": "vv31:8.4",
      "pali": "Deviddhipattā sugatimhi āgatā."
    },
    {
      "id": "vv31:9.1",
      "pali": "Vimānapāsādavare manorame,"
    },
    {
      "id": "vv31:9.2",
      "pali": "Parivāritā accharāsaṅgaṇena;"
    },
    {
      "id": "vv31:9.3",
      "pali": "Sayaṁpabhā devagaṇā ramenti maṁ,"
    },
    {
      "id": "vv31:9.4",
      "pali": "Dīghāyukiṁ devavimānamāgatan”ti."
    },
    {
      "id": "vv31:10.1",
      "pali": "Pallaṅkavimānaṁ tatiyaṁ."
    }
  ]
}
