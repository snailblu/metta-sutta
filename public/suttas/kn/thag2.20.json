{
  "uid": "thag2.20",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.20:1.1",
      "pali": "“Pare ca naṁ pasaṁsanti,"
    },
    {
      "id": "thag2.20:1.2",
      "pali": "attā ce asamāhito;"
    },
    {
      "id": "thag2.20:1.3",
      "pali": "Moghaṁ pare pasaṁsanti,"
    },
    {
      "id": "thag2.20:1.4",
      "pali": "attā hi asamāhito."
    },
    {
      "id": "thag2.20:2.1",
      "pali": "Pare ca naṁ garahanti,"
    },
    {
      "id": "thag2.20:2.2",
      "pali": "attā ce susamāhito;"
    },
    {
      "id": "thag2.20:2.3",
      "pali": "Moghaṁ pare garahanti,"
    },
    {
      "id": "thag2.20:2.4",
      "pali": "attā hi susamāhito”ti."
    },
    {
      "id": "thag2.20:2.5",
      "pali": "… Sirimā thero …."
    },
    {
      "id": "thag2.20:2.6",
      "pali": "vaggo dutiyo."
    },
    {
      "id": "thag2.20:3.1",
      "pali": "Cundo ca jotidāso ca,"
    },
    {
      "id": "thag2.20:3.2",
      "pali": "thero heraññakāni ca;"
    },
    {
      "id": "thag2.20:3.3",
      "pali": "Somamitto sabbamitto,"
    },
    {
      "id": "thag2.20:3.4",
      "pali": "kāḷo tisso ca kimilo;"
    },
    {
      "id": "thag2.20:3.5",
      "pali": "Nando ca sirimā ceva,"
    },
    {
      "id": "thag2.20:3.6",
      "pali": "dasa therā mahiddhikāti."
    }
  ]
}
