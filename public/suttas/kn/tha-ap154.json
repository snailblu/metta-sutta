{
  "uid": "tha-ap154",
  "title": "Tambapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap154:1.1",
      "pali": "“Parakammāyane yutto,"
    },
    {
      "id": "tha-ap154:1.2",
      "pali": "aparādhaṁ akāsahaṁ;"
    },
    {
      "id": "tha-ap154:1.3",
      "pali": "Vanantaṁ abhidhāvissaṁ,"
    },
    {
      "id": "tha-ap154:1.4",
      "pali": "bhayaverasamappito."
    },
    {
      "id": "tha-ap154:2.1",
      "pali": "Pupphitaṁ pādapaṁ disvā,"
    },
    {
      "id": "tha-ap154:2.2",
      "pali": "piṇḍibandhaṁ sunimmitaṁ;"
    },
    {
      "id": "tha-ap154:2.3",
      "pali": "Tambapupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap154:2.4",
      "pali": "bodhiyaṁ okiriṁ ahaṁ."
    },
    {
      "id": "tha-ap154:3.1",
      "pali": "Sammajjitvāna taṁ bodhiṁ,"
    },
    {
      "id": "tha-ap154:3.2",
      "pali": "pāṭaliṁ pādaputtamaṁ;"
    },
    {
      "id": "tha-ap154:3.3",
      "pali": "Pallaṅkaṁ ābhujitvāna,"
    },
    {
      "id": "tha-ap154:3.4",
      "pali": "bodhimūle upāvisiṁ."
    },
    {
      "id": "tha-ap154:4.1",
      "pali": "Gatamaggaṁ gavesantā,"
    },
    {
      "id": "tha-ap154:4.2",
      "pali": "āgacchuṁ mama santikaṁ;"
    },
    {
      "id": "tha-ap154:4.3",
      "pali": "Te ca disvānahaṁ tattha,"
    },
    {
      "id": "tha-ap154:4.4",
      "pali": "āvajjiṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap154:5.1",
      "pali": "Vanditvāna ahaṁ bodhiṁ,"
    },
    {
      "id": "tha-ap154:5.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap154:5.3",
      "pali": "Anekatāle papatiṁ,"
    },
    {
      "id": "tha-ap154:5.4",
      "pali": "giridugge bhayānake."
    },
    {
      "id": "tha-ap154:6.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap154:6.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap154:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap154:6.4",
      "pali": "bodhipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap154:7.1",
      "pali": "Ito ca tatiye kappe,"
    },
    {
      "id": "tha-ap154:7.2",
      "pali": "rājā susaññato ahaṁ;"
    },
    {
      "id": "tha-ap154:7.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap154:7.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap154:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap154:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap154:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap154:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā tambapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap154:10.1",
      "pali": "Tambapupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
