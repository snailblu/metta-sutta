{
  "uid": "iti24",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti24:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti24:2.1",
      "pali": "“Ekapuggalassa, bhikkhave, kappaṁ sandhāvato saṁsarato siyā evaṁ mahā aṭṭhikaṅkalo aṭṭhipuñjo aṭṭhirāsi yathāyaṁ vepullo pabbato, sace saṁhārako assa, sambhatañca na vinasseyyā”ti."
    },
    {
      "id": "iti24:2.2",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti24:2.3",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti24:3.1",
      "pali": "“Ekassekena kappena,"
    },
    {
      "id": "iti24:3.2",
      "pali": "puggalassaṭṭhisañcayo;"
    },
    {
      "id": "iti24:3.3",
      "pali": "Siyā pabbatasamo rāsi,"
    },
    {
      "id": "iti24:3.4",
      "pali": "iti vuttaṁ mahesinā."
    },
    {
      "id": "iti24:4.1",
      "pali": "So kho panāyaṁ akkhāto,"
    },
    {
      "id": "iti24:4.2",
      "pali": "vepullo pabbato mahā;"
    },
    {
      "id": "iti24:4.3",
      "pali": "Uttaro gijjhakūṭassa,"
    },
    {
      "id": "iti24:4.4",
      "pali": "magadhānaṁ giribbaje."
    },
    {
      "id": "iti24:5.1",
      "pali": "Yato ca ariyasaccāni,"
    },
    {
      "id": "iti24:5.2",
      "pali": "sammappaññāya passati;"
    },
    {
      "id": "iti24:5.3",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "iti24:5.4",
      "pali": "dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "iti24:5.5",
      "pali": "Ariyañcaṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "iti24:5.6",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "iti24:6.1",
      "pali": "Sa sattakkhattuṁ paramaṁ,"
    },
    {
      "id": "iti24:6.2",
      "pali": "sandhāvitvāna puggalo;"
    },
    {
      "id": "iti24:6.3",
      "pali": "Dukkhassantakaro hoti,"
    },
    {
      "id": "iti24:6.4",
      "pali": "sabbasaṁyojanakkhayā”ti."
    },
    {
      "id": "iti24:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti24:7.2",
      "pali": "Catutthaṁ."
    }
  ]
}
