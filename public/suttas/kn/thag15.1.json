{
  "uid": "thag15.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag15.1:1.1",
      "pali": "“Esa bhiyyo pasīdāmi,"
    },
    {
      "id": "thag15.1:1.2",
      "pali": "sutvā dhammaṁ mahārasaṁ;"
    },
    {
      "id": "thag15.1:1.3",
      "pali": "Virāgo desito dhammo,"
    },
    {
      "id": "thag15.1:1.4",
      "pali": "anupādāya sabbaso”."
    },
    {
      "id": "thag15.1:2.1",
      "pali": "“Bahūni loke citrāni,"
    },
    {
      "id": "thag15.1:2.2",
      "pali": "asmiṁ pathavimaṇḍale;"
    },
    {
      "id": "thag15.1:2.3",
      "pali": "Mathenti maññe saṅkappaṁ,"
    },
    {
      "id": "thag15.1:2.4",
      "pali": "subhaṁ rāgūpasaṁhitaṁ."
    },
    {
      "id": "thag15.1:3.1",
      "pali": "Rajamuhatañca vātena,"
    },
    {
      "id": "thag15.1:3.2",
      "pali": "yathā meghopasammaye;"
    },
    {
      "id": "thag15.1:3.3",
      "pali": "Evaṁ sammanti saṅkappā,"
    },
    {
      "id": "thag15.1:3.4",
      "pali": "yadā paññāya passati."
    },
    {
      "id": "thag15.1:4.1",
      "pali": "Sabbe saṅkhārā aniccāti,"
    },
    {
      "id": "thag15.1:4.2",
      "pali": "yadā paññāya passati;"
    },
    {
      "id": "thag15.1:4.3",
      "pali": "Atha nibbindati dukkhe,"
    },
    {
      "id": "thag15.1:4.4",
      "pali": "esa maggo visuddhiyā."
    },
    {
      "id": "thag15.1:5.1",
      "pali": "Sabbe saṅkhārā dukkhāti,"
    },
    {
      "id": "thag15.1:5.2",
      "pali": "yadā paññāya passati;"
    },
    {
      "id": "thag15.1:5.3",
      "pali": "Atha nibbindati dukkhe,"
    },
    {
      "id": "thag15.1:5.4",
      "pali": "esa maggo visuddhiyā."
    },
    {
      "id": "thag15.1:6.1",
      "pali": "Sabbe dhammā anattāti,"
    },
    {
      "id": "thag15.1:6.2",
      "pali": "yadā paññāya passati;"
    },
    {
      "id": "thag15.1:6.3",
      "pali": "Atha nibbindati dukkhe,"
    },
    {
      "id": "thag15.1:6.4",
      "pali": "esa maggo visuddhiyā."
    },
    {
      "id": "thag15.1:7.1",
      "pali": "Buddhānubuddho yo thero,"
    },
    {
      "id": "thag15.1:7.2",
      "pali": "koṇḍañño tibbanikkamo;"
    },
    {
      "id": "thag15.1:7.3",
      "pali": "Pahīnajātimaraṇo,"
    },
    {
      "id": "thag15.1:7.4",
      "pali": "brahmacariyassa kevalī."
    },
    {
      "id": "thag15.1:8.1",
      "pali": "Oghapāso daḷhakhilo,"
    },
    {
      "id": "thag15.1:8.2",
      "pali": "Pabbato duppadālayo;"
    },
    {
      "id": "thag15.1:8.3",
      "pali": "Chetvā khilañca pāsañca,"
    },
    {
      "id": "thag15.1:8.4",
      "pali": "Selaṁ bhetvāna dubbhidaṁ;"
    },
    {
      "id": "thag15.1:8.5",
      "pali": "Tiṇṇo pāraṅgato jhāyī,"
    },
    {
      "id": "thag15.1:8.6",
      "pali": "Mutto so mārabandhanā."
    },
    {
      "id": "thag15.1:9.1",
      "pali": "Uddhato capalo bhikkhu,"
    },
    {
      "id": "thag15.1:9.2",
      "pali": "mitte āgamma pāpake;"
    },
    {
      "id": "thag15.1:9.3",
      "pali": "Saṁsīdati mahoghasmiṁ,"
    },
    {
      "id": "thag15.1:9.4",
      "pali": "ūmiyā paṭikujjito."
    },
    {
      "id": "thag15.1:10.1",
      "pali": "Anuddhato acapalo,"
    },
    {
      "id": "thag15.1:10.2",
      "pali": "nipako saṁvutindriyo;"
    },
    {
      "id": "thag15.1:10.3",
      "pali": "Kalyāṇamitto medhāvī,"
    },
    {
      "id": "thag15.1:10.4",
      "pali": "dukkhassantakaro siyā."
    },
    {
      "id": "thag15.1:11.1",
      "pali": "Kālapabbaṅgasaṅkāso,"
    },
    {
      "id": "thag15.1:11.2",
      "pali": "kiso dhamanisanthato;"
    },
    {
      "id": "thag15.1:11.3",
      "pali": "Mattaññū annapānasmiṁ,"
    },
    {
      "id": "thag15.1:11.4",
      "pali": "adīnamanaso naro."
    },
    {
      "id": "thag15.1:12.1",
      "pali": "Phuṭṭho ḍaṁsehi makasehi,"
    },
    {
      "id": "thag15.1:12.2",
      "pali": "araññasmiṁ brahāvane;"
    },
    {
      "id": "thag15.1:12.3",
      "pali": "Nāgo saṅgāmasīseva,"
    },
    {
      "id": "thag15.1:12.4",
      "pali": "sato tatrādhivāsaye."
    },
    {
      "id": "thag15.1:13.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag15.1:13.2",
      "pali": "… pe"
    },
    {
      "id": "thag15.1:13.3",
      "pali": "…"
    },
    {
      "id": "thag15.1:13.4",
      "pali": "nibbisaṁ bhatako yathā."
    },
    {
      "id": "thag15.1:14.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag15.1:14.2",
      "pali": "… pe"
    },
    {
      "id": "thag15.1:14.3",
      "pali": "…"
    },
    {
      "id": "thag15.1:14.4",
      "pali": "sampajāno patissato."
    },
    {
      "id": "thag15.1:15.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag15.1:15.2",
      "pali": "… pe"
    },
    {
      "id": "thag15.1:15.3",
      "pali": "…"
    },
    {
      "id": "thag15.1:15.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag15.1:16.1",
      "pali": "Yassa catthāya pabbajito,"
    },
    {
      "id": "thag15.1:16.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag15.1:16.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag15.1:16.4",
      "pali": "kiṁ me saddhivihārinā”ti."
    },
    {
      "id": "thag15.1:16.5",
      "pali": "… Aññāsikoṇḍañño thero …."
    }
  ]
}
