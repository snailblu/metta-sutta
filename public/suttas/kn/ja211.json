{
  "uid": "ja211",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja211:1.1",
      "pali": "“Akāsi yoggaṁ dhuvamappamatto,"
    },
    {
      "id": "ja211:1.2",
      "pali": "Saṁvaccharaṁ bīraṇathambhakasmiṁ;"
    },
    {
      "id": "ja211:1.3",
      "pali": "Byākāsi saññaṁ parisaṁ vigayha,"
    },
    {
      "id": "ja211:1.4",
      "pali": "Na niyyamo tāyati appapaññaṁ”."
    },
    {
      "id": "ja211:2.1",
      "pali": "“Dvayaṁ yācanako tāta,"
    },
    {
      "id": "ja211:2.2",
      "pali": "somadatta nigacchati;"
    },
    {
      "id": "ja211:2.3",
      "pali": "Alābhaṁ dhanalābhaṁ vā,"
    },
    {
      "id": "ja211:2.4",
      "pali": "evaṁ dhammā hi yācanā”ti."
    },
    {
      "id": "ja211:3.1",
      "pali": "Somadattajātakaṁ paṭhamaṁ."
    }
  ]
}
