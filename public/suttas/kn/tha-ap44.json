{
  "uid": "tha-ap44",
  "title": "2 Soṇakoḷivisattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap44:1.1",
      "pali": "“Anomadassissa munino,"
    },
    {
      "id": "tha-ap44:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap44:1.3",
      "pali": "Sudhāya lepanaṁ katvā,"
    },
    {
      "id": "tha-ap44:1.4",
      "pali": "caṅkamaṁ kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap44:2.1",
      "pali": "Nānāvaṇṇehi pupphehi,"
    },
    {
      "id": "tha-ap44:2.2",
      "pali": "caṅkamaṁ santhariṁ ahaṁ;"
    },
    {
      "id": "tha-ap44:2.3",
      "pali": "Ākāse vitānaṁ katvā,"
    },
    {
      "id": "tha-ap44:2.4",
      "pali": "bhojayiṁ buddhamuttamaṁ."
    },
    {
      "id": "tha-ap44:3.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap44:3.2",
      "pali": "abhivādetvāna subbataṁ;"
    },
    {
      "id": "tha-ap44:3.3",
      "pali": "Dīghasālaṁ bhagavato,"
    },
    {
      "id": "tha-ap44:3.4",
      "pali": "niyyādesimahaṁ tadā."
    },
    {
      "id": "tha-ap44:4.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap44:4.2",
      "pali": "satthā loke anuttaro;"
    },
    {
      "id": "tha-ap44:4.3",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap44:4.4",
      "pali": "anukampāya cakkhumā."
    },
    {
      "id": "tha-ap44:5.1",
      "pali": "Paṭiggahetvāna sambuddho,"
    },
    {
      "id": "tha-ap44:5.2",
      "pali": "dakkhiṇeyyo sadevake;"
    },
    {
      "id": "tha-ap44:5.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap44:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap44:6.1",
      "pali": "‘Yo so haṭṭhena cittena,"
    },
    {
      "id": "tha-ap44:6.2",
      "pali": "dīghasālaṁ adāsi me;"
    },
    {
      "id": "tha-ap44:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap44:6.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap44:7.1",
      "pali": "Imassa maccukālamhi,"
    },
    {
      "id": "tha-ap44:7.2",
      "pali": "puññakammasamaṅgino;"
    },
    {
      "id": "tha-ap44:7.3",
      "pali": "Sahassayuttassaratho,"
    },
    {
      "id": "tha-ap44:7.4",
      "pali": "upaṭṭhissati tāvade."
    },
    {
      "id": "tha-ap44:8.1",
      "pali": "Tena yānenayaṁ poso,"
    },
    {
      "id": "tha-ap44:8.2",
      "pali": "devalokaṁ gamissati;"
    },
    {
      "id": "tha-ap44:8.3",
      "pali": "Anumodissare devā,"
    },
    {
      "id": "tha-ap44:8.4",
      "pali": "sampatte kusalabbhave."
    },
    {
      "id": "tha-ap44:9.1",
      "pali": "Mahārahaṁ byamhaṁ seṭṭhaṁ,"
    },
    {
      "id": "tha-ap44:9.2",
      "pali": "ratanamattikalepanaṁ;"
    },
    {
      "id": "tha-ap44:9.3",
      "pali": "Kūṭāgāravarūpetaṁ,"
    },
    {
      "id": "tha-ap44:9.4",
      "pali": "byamhaṁ ajjhāvasissati."
    },
    {
      "id": "tha-ap44:10.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap44:10.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap44:10.3",
      "pali": "Pañcavīsati kappāni,"
    },
    {
      "id": "tha-ap44:10.4",
      "pali": "devarājā bhavissati."
    },
    {
      "id": "tha-ap44:11.1",
      "pali": "Sattasattatikkhattuñca,"
    },
    {
      "id": "tha-ap44:11.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap44:11.3",
      "pali": "Yasodharasanāmā te,"
    },
    {
      "id": "tha-ap44:11.4",
      "pali": "sabbepi ekanāmakā."
    },
    {
      "id": "tha-ap44:12.1",
      "pali": "Dve sampattī anubhotvā,"
    },
    {
      "id": "tha-ap44:12.2",
      "pali": "Vaḍḍhetvā puññasañcayaṁ;"
    },
    {
      "id": "tha-ap44:12.3",
      "pali": "Aṭṭhavīsatikappamhi,"
    },
    {
      "id": "tha-ap44:12.4",
      "pali": "Cakkavattī bhavissati."
    },
    {
      "id": "tha-ap44:13.1",
      "pali": "Tatrāpi byamhaṁ pavaraṁ,"
    },
    {
      "id": "tha-ap44:13.2",
      "pali": "vissakammena māpitaṁ;"
    },
    {
      "id": "tha-ap44:13.3",
      "pali": "Dasasaddāvivittaṁ taṁ,"
    },
    {
      "id": "tha-ap44:13.4",
      "pali": "puramajjhāvasissati."
    },
    {
      "id": "tha-ap44:14.1",
      "pali": "Aparimeyye ito kappe,"
    },
    {
      "id": "tha-ap44:14.2",
      "pali": "bhūmipālo mahiddhiko;"
    },
    {
      "id": "tha-ap44:14.3",
      "pali": "Okkāko nāma nāmena,"
    },
    {
      "id": "tha-ap44:14.4",
      "pali": "rājā raṭṭhe bhavissati."
    },
    {
      "id": "tha-ap44:15.1",
      "pali": "Soḷasitthisahassānaṁ,"
    },
    {
      "id": "tha-ap44:15.2",
      "pali": "sabbāsaṁ pavarā ca sā;"
    },
    {
      "id": "tha-ap44:15.3",
      "pali": "Abhijātā khattiyānī,"
    },
    {
      "id": "tha-ap44:15.4",
      "pali": "nava putte janessati."
    },
    {
      "id": "tha-ap44:16.1",
      "pali": "Nava putte janetvāna,"
    },
    {
      "id": "tha-ap44:16.2",
      "pali": "khattiyānī marissati;"
    },
    {
      "id": "tha-ap44:16.3",
      "pali": "Taruṇī ca piyā kaññā,"
    },
    {
      "id": "tha-ap44:16.4",
      "pali": "mahesittaṁ karissati."
    },
    {
      "id": "tha-ap44:17.1",
      "pali": "Okkākaṁ tosayitvāna,"
    },
    {
      "id": "tha-ap44:17.2",
      "pali": "varaṁ kaññā labhissati;"
    },
    {
      "id": "tha-ap44:17.3",
      "pali": "Varaṁ laddhāna sā kaññā,"
    },
    {
      "id": "tha-ap44:17.4",
      "pali": "putte pabbājayissati."
    },
    {
      "id": "tha-ap44:18.1",
      "pali": "Pabbājitā ca te sabbe,"
    },
    {
      "id": "tha-ap44:18.2",
      "pali": "gamissanti naguttamaṁ;"
    },
    {
      "id": "tha-ap44:18.3",
      "pali": "Jātibhedabhayā sabbe,"
    },
    {
      "id": "tha-ap44:18.4",
      "pali": "bhaginīhi vasissare."
    },
    {
      "id": "tha-ap44:19.1",
      "pali": "Ekā ca kaññā byādhīhi,"
    },
    {
      "id": "tha-ap44:19.2",
      "pali": "bhavissati parikkhatā;"
    },
    {
      "id": "tha-ap44:19.3",
      "pali": "Mā no jāti pabhijjīti,"
    },
    {
      "id": "tha-ap44:19.4",
      "pali": "nikhaṇissanti khattiyā."
    },
    {
      "id": "tha-ap44:20.1",
      "pali": "Khattiyo nīharitvāna,"
    },
    {
      "id": "tha-ap44:20.2",
      "pali": "tāya saddhiṁ vasissati;"
    },
    {
      "id": "tha-ap44:20.3",
      "pali": "Bhavissati tadā bhedo,"
    },
    {
      "id": "tha-ap44:20.4",
      "pali": "okkākakulasambhavo."
    },
    {
      "id": "tha-ap44:21.1",
      "pali": "Tesaṁ pajā bhavissanti,"
    },
    {
      "id": "tha-ap44:21.2",
      "pali": "koḷiyā nāma jātiyā;"
    },
    {
      "id": "tha-ap44:21.3",
      "pali": "Tattha mānusakaṁ bhogaṁ,"
    },
    {
      "id": "tha-ap44:21.4",
      "pali": "anubhossatinappakaṁ."
    },
    {
      "id": "tha-ap44:22.1",
      "pali": "Tamhā kāyā cavitvāna,"
    },
    {
      "id": "tha-ap44:22.2",
      "pali": "devalokaṁ gamissati;"
    },
    {
      "id": "tha-ap44:22.3",
      "pali": "Tatrāpi pavaraṁ byamhaṁ,"
    },
    {
      "id": "tha-ap44:22.4",
      "pali": "labhissati manoramaṁ."
    },
    {
      "id": "tha-ap44:23.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap44:23.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap44:23.3",
      "pali": "Āgantvāna manussattaṁ,"
    },
    {
      "id": "tha-ap44:23.4",
      "pali": "soṇo nāma bhavissati."
    },
    {
      "id": "tha-ap44:24.1",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "tha-ap44:24.2",
      "pali": "Padahaṁ satthu sāsane;"
    },
    {
      "id": "tha-ap44:24.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap44:24.4",
      "pali": "Nibbāyissatināsavo."
    },
    {
      "id": "tha-ap44:25.1",
      "pali": "Anantadassī bhagavā,"
    },
    {
      "id": "tha-ap44:25.2",
      "pali": "gotamo sakyapuṅgavo;"
    },
    {
      "id": "tha-ap44:25.3",
      "pali": "Visesaññū mahāvīro,"
    },
    {
      "id": "tha-ap44:25.4",
      "pali": "aggaṭṭhāne ṭhapessati’."
    },
    {
      "id": "tha-ap44:26.1",
      "pali": "Vuṭṭhamhi deve caturaṅgulamhi,"
    },
    {
      "id": "tha-ap44:26.2",
      "pali": "Tiṇe anileritaaṅgaṇamhi;"
    },
    {
      "id": "tha-ap44:26.3",
      "pali": "Ṭhatvāna yogassa payuttatādino,"
    },
    {
      "id": "tha-ap44:26.4",
      "pali": "Tatottariṁ pāramatā na vijjati."
    },
    {
      "id": "tha-ap44:27.1",
      "pali": "Uttame damathe danto,"
    },
    {
      "id": "tha-ap44:27.2",
      "pali": "cittaṁ me supaṇīhitaṁ;"
    },
    {
      "id": "tha-ap44:27.3",
      "pali": "Bhāro me ohito sabbo,"
    },
    {
      "id": "tha-ap44:27.4",
      "pali": "nibbutomhi anāsavo."
    },
    {
      "id": "tha-ap44:28.1",
      "pali": "Aṅgīraso mahānāgo,"
    },
    {
      "id": "tha-ap44:28.2",
      "pali": "abhijātova kesarī;"
    },
    {
      "id": "tha-ap44:28.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap44:28.4",
      "pali": "etadagge ṭhapesi maṁ."
    },
    {
      "id": "tha-ap44:29.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap44:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap44:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap44:30.1",
      "pali": "Itthaṁ sudaṁ āyasmā soṇo koḷiviso thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap44:31.1",
      "pali": "Soṇakoḷivisattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
