{
  "uid": "tha-ap267",
  "title": "Biḷālidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap267:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap267:1.2",
      "pali": "romaso nāma pabbato;"
    },
    {
      "id": "tha-ap267:1.3",
      "pali": "Tamhi pabbatapādamhi,"
    },
    {
      "id": "tha-ap267:1.4",
      "pali": "samaṇo bhāvitindriyo."
    },
    {
      "id": "tha-ap267:2.1",
      "pali": "Biḷāliyo gahetvāna,"
    },
    {
      "id": "tha-ap267:2.2",
      "pali": "samaṇassa adāsahaṁ;"
    },
    {
      "id": "tha-ap267:2.3",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap267:2.4",
      "pali": "sayambhū aparājito."
    },
    {
      "id": "tha-ap267:3.1",
      "pali": "Biḷālī te mama dinnā,"
    },
    {
      "id": "tha-ap267:3.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap267:3.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap267:3.4",
      "pali": "phalaṁ nibbattataṁ tava."
    },
    {
      "id": "tha-ap267:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap267:4.2",
      "pali": "yaṁ biḷālimadāsahaṁ;"
    },
    {
      "id": "tha-ap267:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap267:4.4",
      "pali": "biḷāliyā idaṁ phalaṁ."
    },
    {
      "id": "tha-ap267:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap267:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap267:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap267:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā biḷālidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap267:7.1",
      "pali": "Biḷālidāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
