{
  "uid": "thag1.16",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.16:1.1",
      "pali": "“Yathāpi bhaddo ājañño,"
    },
    {
      "id": "thag1.16:1.2",
      "pali": "naṅgalāvattanī sikhī;"
    },
    {
      "id": "thag1.16:1.3",
      "pali": "Gacchati appakasirena,"
    },
    {
      "id": "thag1.16:1.4",
      "pali": "evaṁ rattindivā mama;"
    },
    {
      "id": "thag1.16:1.5",
      "pali": "Gacchanti appakasirena,"
    },
    {
      "id": "thag1.16:1.6",
      "pali": "sukhe laddhe nirāmise”ti."
    },
    {
      "id": "thag1.16:1.7",
      "pali": "… Belaṭṭhasīso thero …."
    }
  ]
}
