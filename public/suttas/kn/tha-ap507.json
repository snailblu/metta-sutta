{
  "uid": "tha-ap507",
  "title": "5 Pādaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap507:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap507:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap507:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap507:1.4",
      "pali": "Pādaphalaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap507:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap507:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap507:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap507:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap507:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap507:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap507:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap507:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap507:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap507:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap507:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap507:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap507:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap507:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pādaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap507:7.1",
      "pali": "Pādaphaliyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
