{
  "uid": "thag14.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag14.1:1.1",
      "pali": "“Yadā ahaṁ pabbajito,"
    },
    {
      "id": "thag14.1:1.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag14.1:1.3",
      "pali": "Nābhijānāmi saṅkappaṁ,"
    },
    {
      "id": "thag14.1:1.4",
      "pali": "anariyaṁ dosasaṁhitaṁ."
    },
    {
      "id": "thag14.1:2.1",
      "pali": "‘Ime haññantu vajjhantu,"
    },
    {
      "id": "thag14.1:2.2",
      "pali": "dukkhaṁ pappontu pāṇino’;"
    },
    {
      "id": "thag14.1:2.3",
      "pali": "Saṅkappaṁ nābhijānāmi,"
    },
    {
      "id": "thag14.1:2.4",
      "pali": "imasmiṁ dīghamantare."
    },
    {
      "id": "thag14.1:3.1",
      "pali": "Mettañca abhijānāmi,"
    },
    {
      "id": "thag14.1:3.2",
      "pali": "appamāṇaṁ subhāvitaṁ;"
    },
    {
      "id": "thag14.1:3.3",
      "pali": "Anupubbaṁ paricitaṁ,"
    },
    {
      "id": "thag14.1:3.4",
      "pali": "yathā buddhena desitaṁ."
    },
    {
      "id": "thag14.1:4.1",
      "pali": "Sabbamitto sabbasakho,"
    },
    {
      "id": "thag14.1:4.2",
      "pali": "sabbabhūtānukampako;"
    },
    {
      "id": "thag14.1:4.3",
      "pali": "Mettacittañca bhāvemi,"
    },
    {
      "id": "thag14.1:4.4",
      "pali": "abyāpajjarato sadā."
    },
    {
      "id": "thag14.1:5.1",
      "pali": "Asaṁhīraṁ asaṅkuppaṁ,"
    },
    {
      "id": "thag14.1:5.2",
      "pali": "cittaṁ āmodayāmahaṁ;"
    },
    {
      "id": "thag14.1:5.3",
      "pali": "Brahmavihāraṁ bhāvemi,"
    },
    {
      "id": "thag14.1:5.4",
      "pali": "akāpurisasevitaṁ."
    },
    {
      "id": "thag14.1:6.1",
      "pali": "Avitakkaṁ samāpanno,"
    },
    {
      "id": "thag14.1:6.2",
      "pali": "sammāsambuddhasāvako;"
    },
    {
      "id": "thag14.1:6.3",
      "pali": "Ariyena tuṇhībhāvena,"
    },
    {
      "id": "thag14.1:6.4",
      "pali": "upeto hoti tāvade."
    },
    {
      "id": "thag14.1:7.1",
      "pali": "Yathāpi pabbato selo,"
    },
    {
      "id": "thag14.1:7.2",
      "pali": "acalo suppatiṭṭhito;"
    },
    {
      "id": "thag14.1:7.3",
      "pali": "Evaṁ mohakkhayā bhikkhu,"
    },
    {
      "id": "thag14.1:7.4",
      "pali": "pabbatova na vedhati."
    },
    {
      "id": "thag14.1:8.1",
      "pali": "Anaṅgaṇassa posassa,"
    },
    {
      "id": "thag14.1:8.2",
      "pali": "niccaṁ sucigavesino;"
    },
    {
      "id": "thag14.1:8.3",
      "pali": "Vālaggamattaṁ pāpassa,"
    },
    {
      "id": "thag14.1:8.4",
      "pali": "abbhamattaṁva khāyati."
    },
    {
      "id": "thag14.1:9.1",
      "pali": "Nagaraṁ yathā paccantaṁ,"
    },
    {
      "id": "thag14.1:9.2",
      "pali": "guttaṁ santarabāhiraṁ;"
    },
    {
      "id": "thag14.1:9.3",
      "pali": "Evaṁ gopetha attānaṁ,"
    },
    {
      "id": "thag14.1:9.4",
      "pali": "khaṇo vo mā upaccagā."
    },
    {
      "id": "thag14.1:10.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag14.1:10.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "thag14.1:10.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "thag14.1:10.4",
      "pali": "nibbisaṁ bhatako yathā."
    },
    {
      "id": "thag14.1:11.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag14.1:11.2",
      "pali": "… pe"
    },
    {
      "id": "thag14.1:11.3",
      "pali": "…"
    },
    {
      "id": "thag14.1:11.4",
      "pali": "sampajāno patissato."
    },
    {
      "id": "thag14.1:12.1",
      "pali": "Pariciṇṇo mayā satthā,"
    },
    {
      "id": "thag14.1:12.2",
      "pali": "kataṁ buddhassa sāsanaṁ;"
    },
    {
      "id": "thag14.1:12.3",
      "pali": "Ohito garuko bhāro,"
    },
    {
      "id": "thag14.1:12.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag14.1:13.1",
      "pali": "Yassa catthāya pabbajito,"
    },
    {
      "id": "thag14.1:13.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag14.1:13.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag14.1:13.4",
      "pali": "sabbasaṁyojanakkhayo."
    },
    {
      "id": "thag14.1:14.1",
      "pali": "Sampādethappamādena,"
    },
    {
      "id": "thag14.1:14.2",
      "pali": "esā me anusāsanī;"
    },
    {
      "id": "thag14.1:14.3",
      "pali": "Handāhaṁ parinibbissaṁ,"
    },
    {
      "id": "thag14.1:14.4",
      "pali": "vippamuttomhi sabbadhī”ti."
    },
    {
      "id": "thag14.1:14.5",
      "pali": "… Khadiravaniyarevato thero …."
    }
  ]
}
