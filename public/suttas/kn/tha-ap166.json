{
  "uid": "tha-ap166",
  "title": "Desapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap166:1.1",
      "pali": "“Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap166:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap166:1.3",
      "pali": "Abbhuggantvāna vehāsaṁ,"
    },
    {
      "id": "tha-ap166:1.4",
      "pali": "gacchate anilañjase."
    },
    {
      "id": "tha-ap166:2.1",
      "pali": "Yamhi dese ṭhito satthā,"
    },
    {
      "id": "tha-ap166:2.2",
      "pali": "abbhuggacchi mahāmuni;"
    },
    {
      "id": "tha-ap166:2.3",
      "pali": "Tāhaṁ desaṁ apūjesiṁ,"
    },
    {
      "id": "tha-ap166:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap166:3.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap166:3.2",
      "pali": "addasaṁ yaṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap166:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap166:3.4",
      "pali": "desapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap166:4.1",
      "pali": "Ekādase kappasate,"
    },
    {
      "id": "tha-ap166:4.2",
      "pali": "gosujātasanāmako;"
    },
    {
      "id": "tha-ap166:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap166:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap166:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap166:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap166:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap166:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā desapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap166:7.1",
      "pali": "Desapūjakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
