{
  "uid": "ja118",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja118:1.1",
      "pali": "“Nācintayanto puriso,"
    },
    {
      "id": "ja118:1.2",
      "pali": "visesamadhigacchati;"
    },
    {
      "id": "ja118:1.3",
      "pali": "Cintitassa phalaṁ passa,"
    },
    {
      "id": "ja118:1.4",
      "pali": "muttosmi vadhabandhanā”ti."
    },
    {
      "id": "ja118:2.1",
      "pali": "Vaṭṭakajātakaṁ aṭṭhamaṁ."
    }
  ]
}
