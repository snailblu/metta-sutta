{
  "uid": "tha-ap519",
  "title": "Kuṭajapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap519:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap519:1.2",
      "pali": "vasalo nāma pabbato;"
    },
    {
      "id": "tha-ap519:1.3",
      "pali": "Buddho sudassano nāma,"
    },
    {
      "id": "tha-ap519:1.4",
      "pali": "vasate pabbatantare."
    },
    {
      "id": "tha-ap519:2.1",
      "pali": "Pupphaṁ hemavantaṁ gayha,"
    },
    {
      "id": "tha-ap519:2.2",
      "pali": "vehāsaṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap519:2.3",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap519:2.4",
      "pali": "oghatiṇṇamanāsavaṁ."
    },
    {
      "id": "tha-ap519:3.1",
      "pali": "Pupphaṁ kuṭajamādāya,"
    },
    {
      "id": "tha-ap519:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap519:3.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap519:3.4",
      "pali": "sayambhussa mahesino."
    },
    {
      "id": "tha-ap519:4.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap519:4.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap519:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap519:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap519:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap519:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap519:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap519:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap519:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap519:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap519:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap519:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap519:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap519:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā kuṭajapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap519:9.1",
      "pali": "Kuṭajapupphiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
