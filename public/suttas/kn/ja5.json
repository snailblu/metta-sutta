{
  "uid": "ja5",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja5:1.1",
      "pali": "“Kimagghati taṇḍulanāḷikāyaṁ,"
    },
    {
      "id": "ja5:1.2",
      "pali": "Assāna mūlāya vadehi rāja;"
    },
    {
      "id": "ja5:1.3",
      "pali": "Bārāṇasiṁ santarabāhirantaṁ,"
    },
    {
      "id": "ja5:1.4",
      "pali": "Ayamagghati taṇḍulanāḷikā”ti."
    },
    {
      "id": "ja5:2.1",
      "pali": "Taṇḍulanāḷijātakaṁ pañcamaṁ."
    }
  ]
}
