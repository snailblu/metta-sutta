{
  "uid": "tha-ap365",
  "title": "Bhisamuḷāladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap365:1.1",
      "pali": "“Phusso nāmāsi sambuddho,"
    },
    {
      "id": "tha-ap365:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap365:1.3",
      "pali": "Vivekakāmo sabbaññū,"
    },
    {
      "id": "tha-ap365:1.4",
      "pali": "āgañchi mama santike."
    },
    {
      "id": "tha-ap365:2.1",
      "pali": "Tasmiṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap365:2.2",
      "pali": "mahākāruṇike jine;"
    },
    {
      "id": "tha-ap365:2.3",
      "pali": "Bhisamuḷālaṁ paggayha,"
    },
    {
      "id": "tha-ap365:2.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap365:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap365:3.2",
      "pali": "yaṁ bhisamadadiṁ tadā;"
    },
    {
      "id": "tha-ap365:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap365:3.4",
      "pali": "bhisadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap365:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap365:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap365:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap365:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhisamuḷāladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap365:6.1",
      "pali": "Bhisamuḷāladāyakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
