{
  "uid": "thag5.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.3:1.1",
      "pali": "“Vassati devo yathā sugītaṁ,"
    },
    {
      "id": "thag5.3:1.2",
      "pali": "Channā me kuṭikā sukhā nivātā;"
    },
    {
      "id": "thag5.3:1.3",
      "pali": "Tassaṁ viharāmi vūpasanto,"
    },
    {
      "id": "thag5.3:1.4",
      "pali": "Atha ce patthayasī pavassa deva."
    },
    {
      "id": "thag5.3:2.1",
      "pali": "Vassati devo yathā sugītaṁ,"
    },
    {
      "id": "thag5.3:2.2",
      "pali": "Channā me kuṭikā sukhā nivātā;"
    },
    {
      "id": "thag5.3:2.3",
      "pali": "Tassaṁ viharāmi santacitto,"
    },
    {
      "id": "thag5.3:2.4",
      "pali": "Atha ce patthayasī pavassa deva."
    },
    {
      "id": "thag5.3:3.1",
      "pali": "Vassati devo,"
    },
    {
      "id": "thag5.3:3.2",
      "pali": "… pe …"
    },
    {
      "id": "thag5.3:3.3",
      "pali": "tassaṁ viharāmi vītarāgo,"
    },
    {
      "id": "thag5.3:3.4",
      "pali": "… pe …"
    },
    {
      "id": "thag5.3:4.1",
      "pali": "Vassati devo,"
    },
    {
      "id": "thag5.3:4.2",
      "pali": "… pe …"
    },
    {
      "id": "thag5.3:4.3",
      "pali": "tassaṁ viharāmi vītadoso,"
    },
    {
      "id": "thag5.3:4.4",
      "pali": "… pe …"
    },
    {
      "id": "thag5.3:5.1",
      "pali": "Vassati devo,"
    },
    {
      "id": "thag5.3:5.2",
      "pali": "… pe …"
    },
    {
      "id": "thag5.3:5.3",
      "pali": "tassaṁ viharāmi vītamoho,"
    },
    {
      "id": "thag5.3:5.4",
      "pali": "Atha ce patthayasī pavassa devā”ti."
    },
    {
      "id": "thag5.3:5.5",
      "pali": "… Girimānando thero …."
    }
  ]
}
