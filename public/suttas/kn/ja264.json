{
  "uid": "ja264",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja264:1.1",
      "pali": "“Panādo nāma so rājā,"
    },
    {
      "id": "ja264:1.2",
      "pali": "yassa yūpo suvaṇṇayo;"
    },
    {
      "id": "ja264:1.3",
      "pali": "Tiriyaṁ soḷasubbedho,"
    },
    {
      "id": "ja264:1.4",
      "pali": "uddhamāhu sahassadhā."
    },
    {
      "id": "ja264:2.1",
      "pali": "Sahassakaṇḍo satageṇḍu,"
    },
    {
      "id": "ja264:2.2",
      "pali": "dhajālu haritāmayo;"
    },
    {
      "id": "ja264:2.3",
      "pali": "Anaccuṁ tattha gandhabbā,"
    },
    {
      "id": "ja264:2.4",
      "pali": "cha sahassāni sattadhā."
    },
    {
      "id": "ja264:3.1",
      "pali": "Evametaṁ tadā āsi,"
    },
    {
      "id": "ja264:3.2",
      "pali": "yathā bhāsasi bhaddaji;"
    },
    {
      "id": "ja264:3.3",
      "pali": "Sakko ahaṁ tadā āsiṁ,"
    },
    {
      "id": "ja264:3.4",
      "pali": "veyyāvaccakaro tavā”ti."
    },
    {
      "id": "ja264:4.1",
      "pali": "Mahāpanādajātakaṁ catutthaṁ."
    }
  ]
}
