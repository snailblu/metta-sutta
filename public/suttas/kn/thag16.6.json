{
  "uid": "thag16.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.6:1.1",
      "pali": "“Paripuṇṇakāyo suruci,"
    },
    {
      "id": "thag16.6:1.2",
      "pali": "Sujāto cārudassano;"
    },
    {
      "id": "thag16.6:1.3",
      "pali": "Suvaṇṇavaṇṇosi bhagavā,"
    },
    {
      "id": "thag16.6:1.4",
      "pali": "Susukkadāṭhosi vīriyavā."
    },
    {
      "id": "thag16.6:2.1",
      "pali": "Narassa hi sujātassa,"
    },
    {
      "id": "thag16.6:2.2",
      "pali": "ye bhavanti viyañjanā;"
    },
    {
      "id": "thag16.6:2.3",
      "pali": "Sabbe te tava kāyasmiṁ,"
    },
    {
      "id": "thag16.6:2.4",
      "pali": "mahāpurisalakkhaṇā."
    },
    {
      "id": "thag16.6:3.1",
      "pali": "Pasannanetto sumukho,"
    },
    {
      "id": "thag16.6:3.2",
      "pali": "brahā uju patāpavā;"
    },
    {
      "id": "thag16.6:3.3",
      "pali": "Majjhe samaṇasaṅghassa,"
    },
    {
      "id": "thag16.6:3.4",
      "pali": "ādiccova virocasi."
    },
    {
      "id": "thag16.6:4.1",
      "pali": "Kalyāṇadassano bhikkhu,"
    },
    {
      "id": "thag16.6:4.2",
      "pali": "kañcanasannibhattaco;"
    },
    {
      "id": "thag16.6:4.3",
      "pali": "Kiṁ te samaṇabhāvena,"
    },
    {
      "id": "thag16.6:4.4",
      "pali": "evaṁ uttamavaṇṇino."
    },
    {
      "id": "thag16.6:5.1",
      "pali": "Rājā arahasi bhavituṁ,"
    },
    {
      "id": "thag16.6:5.2",
      "pali": "cakkavattī rathesabho;"
    },
    {
      "id": "thag16.6:5.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "thag16.6:5.4",
      "pali": "jambusaṇḍassa issaro."
    },
    {
      "id": "thag16.6:6.1",
      "pali": "Khattiyā bhogī rājāno,"
    },
    {
      "id": "thag16.6:6.2",
      "pali": "anuyantā bhavanti te;"
    },
    {
      "id": "thag16.6:6.3",
      "pali": "Rājābhirājā manujindo,"
    },
    {
      "id": "thag16.6:6.4",
      "pali": "rajjaṁ kārehi gotama”."
    },
    {
      "id": "thag16.6:7.1",
      "pali": "“Rājāhamasmi sela,"
    },
    {
      "id": "thag16.6:7.2",
      "pali": "(selāti bhagavā)"
    },
    {
      "id": "thag16.6:7.3",
      "pali": "Dhammarājā anuttaro;"
    },
    {
      "id": "thag16.6:7.4",
      "pali": "Dhammena cakkaṁ vattemi,"
    },
    {
      "id": "thag16.6:7.5",
      "pali": "Cakkaṁ appaṭivattiyaṁ”."
    },
    {
      "id": "thag16.6:8.1",
      "pali": "“Sambuddho paṭijānāsi,"
    },
    {
      "id": "thag16.6:8.2",
      "pali": "(iti selo brāhmaṇo)"
    },
    {
      "id": "thag16.6:8.3",
      "pali": "Dhammarājā anuttaro;"
    },
    {
      "id": "thag16.6:8.4",
      "pali": "‘Dhammena cakkaṁ vattemi’,"
    },
    {
      "id": "thag16.6:8.5",
      "pali": "Iti bhāsatha gotama."
    },
    {
      "id": "thag16.6:9.1",
      "pali": "Ko nu senāpati bhoto,"
    },
    {
      "id": "thag16.6:9.2",
      "pali": "sāvako satthuranvayo;"
    },
    {
      "id": "thag16.6:9.3",
      "pali": "Ko tetamanuvatteti,"
    },
    {
      "id": "thag16.6:9.4",
      "pali": "dhammacakkaṁ pavattitaṁ”."
    },
    {
      "id": "thag16.6:10.1",
      "pali": "“Mayā pavattitaṁ cakkaṁ,"
    },
    {
      "id": "thag16.6:10.2",
      "pali": "(selāti bhagavā)"
    },
    {
      "id": "thag16.6:10.3",
      "pali": "Dhammacakkaṁ anuttaraṁ;"
    },
    {
      "id": "thag16.6:10.4",
      "pali": "Sāriputto anuvatteti,"
    },
    {
      "id": "thag16.6:10.5",
      "pali": "Anujāto tathāgataṁ."
    },
    {
      "id": "thag16.6:11.1",
      "pali": "Abhiññeyyaṁ abhiññātaṁ,"
    },
    {
      "id": "thag16.6:11.2",
      "pali": "bhāvetabbañca bhāvitaṁ;"
    },
    {
      "id": "thag16.6:11.3",
      "pali": "Pahātabbaṁ pahīnaṁ me,"
    },
    {
      "id": "thag16.6:11.4",
      "pali": "tasmā buddhosmi brāhmaṇa."
    },
    {
      "id": "thag16.6:12.1",
      "pali": "Vinayassu mayi kaṅkhaṁ,"
    },
    {
      "id": "thag16.6:12.2",
      "pali": "adhimuccassu brāhmaṇa;"
    },
    {
      "id": "thag16.6:12.3",
      "pali": "Dullabhaṁ dassanaṁ hoti,"
    },
    {
      "id": "thag16.6:12.4",
      "pali": "sambuddhānaṁ abhiṇhaso."
    },
    {
      "id": "thag16.6:13.1",
      "pali": "Yesaṁ ve dullabho loke,"
    },
    {
      "id": "thag16.6:13.2",
      "pali": "pātubhāvo abhiṇhaso;"
    },
    {
      "id": "thag16.6:13.3",
      "pali": "Sohaṁ brāhmaṇa buddhosmi,"
    },
    {
      "id": "thag16.6:13.4",
      "pali": "sallakatto anuttaro."
    },
    {
      "id": "thag16.6:14.1",
      "pali": "Brahmabhūto atitulo,"
    },
    {
      "id": "thag16.6:14.2",
      "pali": "mārasenappamaddano;"
    },
    {
      "id": "thag16.6:14.3",
      "pali": "Sabbāmitte vase katvā,"
    },
    {
      "id": "thag16.6:14.4",
      "pali": "modāmi akutobhayo”."
    },
    {
      "id": "thag16.6:15.1",
      "pali": "“Idaṁ bhonto nisāmetha,"
    },
    {
      "id": "thag16.6:15.2",
      "pali": "yathā bhāsati cakkhumā;"
    },
    {
      "id": "thag16.6:15.3",
      "pali": "Sallakatto mahāvīro,"
    },
    {
      "id": "thag16.6:15.4",
      "pali": "sīhova nadatī vane."
    },
    {
      "id": "thag16.6:16.1",
      "pali": "Brahmabhūtaṁ atitulaṁ,"
    },
    {
      "id": "thag16.6:16.2",
      "pali": "mārasenappamaddanaṁ;"
    },
    {
      "id": "thag16.6:16.3",
      "pali": "Ko disvā nappasīdeyya,"
    },
    {
      "id": "thag16.6:16.4",
      "pali": "api kaṇhābhijātiko."
    },
    {
      "id": "thag16.6:17.1",
      "pali": "Yo maṁ icchati anvetu,"
    },
    {
      "id": "thag16.6:17.2",
      "pali": "yo vā nicchati gacchatu;"
    },
    {
      "id": "thag16.6:17.3",
      "pali": "Idhāhaṁ pabbajissāmi,"
    },
    {
      "id": "thag16.6:17.4",
      "pali": "varapaññassa santike”."
    },
    {
      "id": "thag16.6:18.1",
      "pali": "“Etañce ruccati bhoto,"
    },
    {
      "id": "thag16.6:18.2",
      "pali": "sammāsambuddhasāsanaṁ;"
    },
    {
      "id": "thag16.6:18.3",
      "pali": "Mayampi pabbajissāma,"
    },
    {
      "id": "thag16.6:18.4",
      "pali": "varapaññassa santike”."
    },
    {
      "id": "thag16.6:19.1",
      "pali": "“Brāhmaṇā tisatā ime,"
    },
    {
      "id": "thag16.6:19.2",
      "pali": "yācanti pañjalīkatā;"
    },
    {
      "id": "thag16.6:19.3",
      "pali": "‘Brahmacariyaṁ carissāma,"
    },
    {
      "id": "thag16.6:19.4",
      "pali": "bhagavā tava santike’”."
    },
    {
      "id": "thag16.6:20.1",
      "pali": "“Svākkhātaṁ brahmacariyaṁ,"
    },
    {
      "id": "thag16.6:20.2",
      "pali": "(selāti bhagavā)"
    },
    {
      "id": "thag16.6:20.3",
      "pali": "Sandiṭṭhikamakālikaṁ;"
    },
    {
      "id": "thag16.6:20.4",
      "pali": "Yattha amoghā pabbajjā,"
    },
    {
      "id": "thag16.6:20.5",
      "pali": "Appamattassa sikkhato”."
    },
    {
      "id": "thag16.6:21.1",
      "pali": "“Yaṁ taṁ saraṇamāgamha,"
    },
    {
      "id": "thag16.6:21.2",
      "pali": "ito aṭṭhame cakkhuma;"
    },
    {
      "id": "thag16.6:21.3",
      "pali": "Sattarattena bhagavā,"
    },
    {
      "id": "thag16.6:21.4",
      "pali": "dantāmha tava sāsane."
    },
    {
      "id": "thag16.6:22.1",
      "pali": "Tuvaṁ buddho tuvaṁ satthā,"
    },
    {
      "id": "thag16.6:22.2",
      "pali": "tuvaṁ mārābhibhū muni;"
    },
    {
      "id": "thag16.6:22.3",
      "pali": "Tuvaṁ anusaye chetvā,"
    },
    {
      "id": "thag16.6:22.4",
      "pali": "tiṇṇo tāresimaṁ pajaṁ."
    },
    {
      "id": "thag16.6:23.1",
      "pali": "Upadhī te samatikkantā,"
    },
    {
      "id": "thag16.6:23.2",
      "pali": "āsavā te padālitā;"
    },
    {
      "id": "thag16.6:23.3",
      "pali": "Sīhova anupādāno,"
    },
    {
      "id": "thag16.6:23.4",
      "pali": "pahīnabhayabheravo."
    },
    {
      "id": "thag16.6:24.1",
      "pali": "Bhikkhavo tisatā ime,"
    },
    {
      "id": "thag16.6:24.2",
      "pali": "tiṭṭhanti pañjalīkatā;"
    },
    {
      "id": "thag16.6:24.3",
      "pali": "Pāde vīra pasārehi,"
    },
    {
      "id": "thag16.6:24.4",
      "pali": "nāgā vandantu satthuno”ti."
    },
    {
      "id": "thag16.6:24.5",
      "pali": "… Selo thero …."
    }
  ]
}
