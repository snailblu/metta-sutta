{
  "uid": "tha-ap58",
  "title": "Saparivārāsanattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap58:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap58:1.2",
      "pali": "piṇḍapātaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap58:1.3",
      "pali": "Gantvā kiliṭṭhakaṁ ṭhānaṁ,"
    },
    {
      "id": "tha-ap58:1.4",
      "pali": "mallikāhi parikkhitaṁ."
    },
    {
      "id": "tha-ap58:2.1",
      "pali": "Tamhāsanamhi āsīno,"
    },
    {
      "id": "tha-ap58:2.2",
      "pali": "buddho lokagganāyako;"
    },
    {
      "id": "tha-ap58:2.3",
      "pali": "Akittayi piṇḍapātaṁ,"
    },
    {
      "id": "tha-ap58:2.4",
      "pali": "ujubhūto samāhito."
    },
    {
      "id": "tha-ap58:3.1",
      "pali": "Yathāpi bhaddake khette,"
    },
    {
      "id": "tha-ap58:3.2",
      "pali": "bījaṁ appampi ropitaṁ;"
    },
    {
      "id": "tha-ap58:3.3",
      "pali": "Sammā dhāraṁ pavecchante,"
    },
    {
      "id": "tha-ap58:3.4",
      "pali": "phalaṁ toseti kassakaṁ."
    },
    {
      "id": "tha-ap58:4.1",
      "pali": "Tathevāyaṁ piṇḍapāto,"
    },
    {
      "id": "tha-ap58:4.2",
      "pali": "sukhette ropito tayā;"
    },
    {
      "id": "tha-ap58:4.3",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap58:4.4",
      "pali": "phalaṁ te tosayissati."
    },
    {
      "id": "tha-ap58:5.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap58:5.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap58:5.3",
      "pali": "Piṇḍapātaṁ gahetvāna,"
    },
    {
      "id": "tha-ap58:5.4",
      "pali": "pakkāmi uttarāmukho."
    },
    {
      "id": "tha-ap58:6.1",
      "pali": "Saṁvuto pātimokkhasmiṁ,"
    },
    {
      "id": "tha-ap58:6.2",
      "pali": "indriyesu ca pañcasu;"
    },
    {
      "id": "tha-ap58:6.3",
      "pali": "Pavivekamanuyutto,"
    },
    {
      "id": "tha-ap58:6.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap58:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap58:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap58:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap58:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā saparivārāsano thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap58:9.1",
      "pali": "Saparivārāsanattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
