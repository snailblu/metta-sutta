{
  "uid": "tha-ap140",
  "title": "8 Ekapasādaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap140:1.1",
      "pali": "“Nārado iti me nāmaṁ,"
    },
    {
      "id": "tha-ap140:1.2",
      "pali": "kesavo iti maṁ vidū;"
    },
    {
      "id": "tha-ap140:1.3",
      "pali": "Kusalākusalaṁ esaṁ,"
    },
    {
      "id": "tha-ap140:1.4",
      "pali": "agamaṁ buddhasantikaṁ."
    },
    {
      "id": "tha-ap140:2.1",
      "pali": "Mettacitto kāruṇiko,"
    },
    {
      "id": "tha-ap140:2.2",
      "pali": "atthadassī mahāmuni;"
    },
    {
      "id": "tha-ap140:2.3",
      "pali": "Assāsayanto satte so,"
    },
    {
      "id": "tha-ap140:2.4",
      "pali": "dhammaṁ deseti cakkhumā."
    },
    {
      "id": "tha-ap140:3.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap140:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap140:3.3",
      "pali": "Satthāraṁ abhivādetvā,"
    },
    {
      "id": "tha-ap140:3.4",
      "pali": "pakkāmiṁ pācināmukho."
    },
    {
      "id": "tha-ap140:4.1",
      "pali": "Sattarase kappasate,"
    },
    {
      "id": "tha-ap140:4.2",
      "pali": "rājā āsi mahīpati;"
    },
    {
      "id": "tha-ap140:4.3",
      "pali": "Amittatāpano nāma,"
    },
    {
      "id": "tha-ap140:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap140:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap140:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap140:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap140:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekapasādaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap140:7.1",
      "pali": "Ekapasādaniyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
