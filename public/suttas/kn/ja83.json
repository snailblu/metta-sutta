{
  "uid": "ja83",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja83:1.1",
      "pali": "“Mitto have sattapadena hoti,"
    },
    {
      "id": "ja83:1.2",
      "pali": "Sahāyo pana dvādasakena hoti;"
    },
    {
      "id": "ja83:1.3",
      "pali": "Māsaḍḍhamāsena ca ñāti hoti,"
    },
    {
      "id": "ja83:1.4",
      "pali": "Tatuttariṁ attasamopi hoti;"
    },
    {
      "id": "ja83:1.5",
      "pali": "Sohaṁ kathaṁ attasukhassa hetu,"
    },
    {
      "id": "ja83:1.6",
      "pali": "Cirasanthutaṁ kāḷakaṇṇiṁ jaheyyan”ti."
    },
    {
      "id": "ja83:2.1",
      "pali": "Kāḷakaṇṇijātakaṁ tatiyaṁ"
    }
  ]
}
