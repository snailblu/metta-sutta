{
  "uid": "ja285",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja285:1.1",
      "pali": "“Dariyā satta vassāni,"
    },
    {
      "id": "ja285:1.2",
      "pali": "tiṁsamattā vasāmase;"
    },
    {
      "id": "ja285:1.3",
      "pali": "Haññāma maṇino ābhaṁ,"
    },
    {
      "id": "ja285:1.4",
      "pali": "iti no mantanaṁ ahu."
    },
    {
      "id": "ja285:2.1",
      "pali": "Yāvatā maṇiṁ ghaṁsāma,"
    },
    {
      "id": "ja285:2.2",
      "pali": "bhiyyo vodāyate maṇi;"
    },
    {
      "id": "ja285:2.3",
      "pali": "Idañca dāni pucchāma,"
    },
    {
      "id": "ja285:2.4",
      "pali": "kiṁ kiccaṁ idha maññasi”."
    },
    {
      "id": "ja285:3.1",
      "pali": "“Ayaṁ maṇi veḷūriyo,"
    },
    {
      "id": "ja285:3.2",
      "pali": "akāco vimalo subho;"
    },
    {
      "id": "ja285:3.3",
      "pali": "Nāssa sakkā siriṁ hantuṁ,"
    },
    {
      "id": "ja285:3.4",
      "pali": "apakkamatha sūkarā”ti."
    },
    {
      "id": "ja285:4.1",
      "pali": "Maṇisūkarajātakaṁ pañcamaṁ."
    }
  ]
}
