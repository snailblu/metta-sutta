{
  "uid": "tha-ap50",
  "title": "8 Caṅkamanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap50:1.1",
      "pali": "“Atthadassissa munino,"
    },
    {
      "id": "tha-ap50:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap50:1.3",
      "pali": "Iṭṭhakāhi cinitvāna,"
    },
    {
      "id": "tha-ap50:1.4",
      "pali": "caṅkamaṁ kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap50:2.1",
      "pali": "Uccato pañcaratanaṁ,"
    },
    {
      "id": "tha-ap50:2.2",
      "pali": "caṅkamaṁ sādhumāpitaṁ;"
    },
    {
      "id": "tha-ap50:2.3",
      "pali": "Āyāmato hatthasataṁ,"
    },
    {
      "id": "tha-ap50:2.4",
      "pali": "bhāvanīyyaṁ manoramaṁ."
    },
    {
      "id": "tha-ap50:3.1",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap50:3.2",
      "pali": "atthadassī naruttamo;"
    },
    {
      "id": "tha-ap50:3.3",
      "pali": "Hatthena pulinaṁ gayha,"
    },
    {
      "id": "tha-ap50:3.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap50:4.1",
      "pali": "‘Iminā pulinadānena,"
    },
    {
      "id": "tha-ap50:4.2",
      "pali": "caṅkamaṁ sukatena ca;"
    },
    {
      "id": "tha-ap50:4.3",
      "pali": "Sattaratanasampannaṁ,"
    },
    {
      "id": "tha-ap50:4.4",
      "pali": "pulinaṁ anubhossati."
    },
    {
      "id": "tha-ap50:5.1",
      "pali": "Tīṇi kappāni devesu,"
    },
    {
      "id": "tha-ap50:5.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap50:5.3",
      "pali": "Anubhossati sampattiṁ,"
    },
    {
      "id": "tha-ap50:5.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap50:6.1",
      "pali": "Manussalokamāgantvā,"
    },
    {
      "id": "tha-ap50:6.2",
      "pali": "rājā raṭṭhe bhavissati;"
    },
    {
      "id": "tha-ap50:6.3",
      "pali": "Tikkhattuṁ cakkavattī ca,"
    },
    {
      "id": "tha-ap50:6.4",
      "pali": "mahiyā so bhavissati’."
    },
    {
      "id": "tha-ap50:7.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap50:7.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap50:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap50:7.4",
      "pali": "caṅkamassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap50:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap50:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap50:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap50:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā caṅkamanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap50:10.1",
      "pali": "Caṅkamanadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
