{
  "uid": "ja149",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja149:1.1",
      "pali": "“Ekapaṇṇo ayaṁ rukkho,"
    },
    {
      "id": "ja149:1.2",
      "pali": "na bhūmyā caturaṅgulo;"
    },
    {
      "id": "ja149:1.3",
      "pali": "Phalena visakappena,"
    },
    {
      "id": "ja149:1.4",
      "pali": "mahāyaṁ kiṁ bhavissatī”ti."
    },
    {
      "id": "ja149:2.1",
      "pali": "Ekapaṇṇajātakaṁ navamaṁ."
    }
  ]
}
