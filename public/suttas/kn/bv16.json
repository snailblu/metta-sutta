{
  "uid": "bv16",
  "title": "16 Atthadassībuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv16:1.1",
      "pali": "“Tattheva maṇḍakappamhi,"
    },
    {
      "id": "bv16:1.2",
      "pali": "atthadassī mahāyaso;"
    },
    {
      "id": "bv16:1.3",
      "pali": "Mahātamaṁ nihantvāna,"
    },
    {
      "id": "bv16:1.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "bv16:2.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv16:2.2",
      "pali": "dhammacakkaṁ pavattayi;"
    },
    {
      "id": "bv16:2.3",
      "pali": "Amatena tappayī lokaṁ,"
    },
    {
      "id": "bv16:2.4",
      "pali": "dasasahassisadevakaṁ."
    },
    {
      "id": "bv16:3.1",
      "pali": "Tassāpi lokanāthassa,"
    },
    {
      "id": "bv16:3.2",
      "pali": "Ahesuṁ abhisamayā tayo;"
    },
    {
      "id": "bv16:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv16:3.4",
      "pali": "Paṭhamābhisamayo ahu."
    },
    {
      "id": "bv16:4.1",
      "pali": "Yadā buddho atthadassī,"
    },
    {
      "id": "bv16:4.2",
      "pali": "carate devacārikaṁ;"
    },
    {
      "id": "bv16:4.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv16:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv16:5.1",
      "pali": "Punāparaṁ yadā buddho,"
    },
    {
      "id": "bv16:5.2",
      "pali": "desesi pitusantike;"
    },
    {
      "id": "bv16:5.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv16:5.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv16:6.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv16:6.2",
      "pali": "tassāpi ca mahesino;"
    },
    {
      "id": "bv16:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv16:6.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv16:7.1",
      "pali": "Aṭṭhanavutisahassānaṁ,"
    },
    {
      "id": "bv16:7.2",
      "pali": "paṭhamo āsi samāgamo;"
    },
    {
      "id": "bv16:7.3",
      "pali": "Aṭṭhāsītisahassānaṁ,"
    },
    {
      "id": "bv16:7.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv16:8.1",
      "pali": "Aṭṭhasattatisatasahassānaṁ,"
    },
    {
      "id": "bv16:8.2",
      "pali": "Tatiyo āsi samāgamo;"
    },
    {
      "id": "bv16:8.3",
      "pali": "Anupādā vimuttānaṁ,"
    },
    {
      "id": "bv16:8.4",
      "pali": "Vimalānaṁ mahesinaṁ."
    },
    {
      "id": "bv16:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv16:9.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "bv16:9.3",
      "pali": "Susīmo nāma nāmena,"
    },
    {
      "id": "bv16:9.4",
      "pali": "mahiyā seṭṭhasammato."
    },
    {
      "id": "bv16:10.1",
      "pali": "Dibbaṁ mandāravaṁ pupphaṁ,"
    },
    {
      "id": "bv16:10.2",
      "pali": "padumaṁ pārichattakaṁ;"
    },
    {
      "id": "bv16:10.3",
      "pali": "Devalokāharitvāna,"
    },
    {
      "id": "bv16:10.4",
      "pali": "sambuddhamabhipūjayiṁ."
    },
    {
      "id": "bv16:11.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv16:11.2",
      "pali": "atthadassī mahāmuni;"
    },
    {
      "id": "bv16:11.3",
      "pali": "‘Aṭṭhārase kappasate,"
    },
    {
      "id": "bv16:11.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv16:12.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv16:12.2",
      "pali": "…pe…"
    },
    {
      "id": "bv16:12.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv16:13.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv16:13.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "bv16:13.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv16:13.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv16:14.1",
      "pali": "Sobhanaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv16:14.2",
      "pali": "sāgaro nāma khattiyo;"
    },
    {
      "id": "bv16:14.3",
      "pali": "Sudassanā nāma janikā,"
    },
    {
      "id": "bv16:14.4",
      "pali": "atthadassissa satthuno."
    },
    {
      "id": "bv16:15.1",
      "pali": "Dasavassasahassāni,"
    },
    {
      "id": "bv16:15.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv16:15.3",
      "pali": "Amaragiri sugiri vāhanā,"
    },
    {
      "id": "bv16:15.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv16:16.1",
      "pali": "Tettiṁsañca sahassāni,"
    },
    {
      "id": "bv16:16.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv16:16.3",
      "pali": "Visākhā nāma nārī ca,"
    },
    {
      "id": "bv16:16.4",
      "pali": "selo nāmāsi atrajo."
    },
    {
      "id": "bv16:17.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv16:17.2",
      "pali": "assayānena nikkhami;"
    },
    {
      "id": "bv16:17.3",
      "pali": "Anūnaaṭṭhamāsāni,"
    },
    {
      "id": "bv16:17.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv16:18.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv16:18.2",
      "pali": "atthadassī mahāyaso;"
    },
    {
      "id": "bv16:18.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv16:18.4",
      "pali": "anomuyyāne narāsabho."
    },
    {
      "id": "bv16:19.1",
      "pali": "Santo ca upasanto ca,"
    },
    {
      "id": "bv16:19.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv16:19.3",
      "pali": "Abhayo nāmupaṭṭhāko,"
    },
    {
      "id": "bv16:19.4",
      "pali": "atthadassissa satthuno."
    },
    {
      "id": "bv16:20.1",
      "pali": "Dhammā ceva sudhammā ca,"
    },
    {
      "id": "bv16:20.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv16:20.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv16:20.4",
      "pali": "campakoti pavuccati."
    },
    {
      "id": "bv16:21.1",
      "pali": "Nakulo ca nisabho ca,"
    },
    {
      "id": "bv16:21.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv16:21.3",
      "pali": "Makilā ca sunandā ca,"
    },
    {
      "id": "bv16:21.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv16:22.1",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv16:22.2",
      "pali": "asītihatthamuggato;"
    },
    {
      "id": "bv16:22.3",
      "pali": "Sobhate sālarājāva,"
    },
    {
      "id": "bv16:22.4",
      "pali": "uḷurājāva pūrito."
    },
    {
      "id": "bv16:23.1",
      "pali": "Tassa pākatikā raṁsī,"
    },
    {
      "id": "bv16:23.2",
      "pali": "anekasatakoṭiyo;"
    },
    {
      "id": "bv16:23.3",
      "pali": "Uddhaṁ adho dasa disā,"
    },
    {
      "id": "bv16:23.4",
      "pali": "pharanti yojanaṁ sadā."
    },
    {
      "id": "bv16:24.1",
      "pali": "Sopi buddho narāsabho,"
    },
    {
      "id": "bv16:24.2",
      "pali": "sabbasattuttamo muni;"
    },
    {
      "id": "bv16:24.3",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv16:24.4",
      "pali": "loke aṭṭhāsi cakkhumā."
    },
    {
      "id": "bv16:25.1",
      "pali": "Atulaṁ dassetvā obhāsaṁ,"
    },
    {
      "id": "bv16:25.2",
      "pali": "virocetvā sadevake;"
    },
    {
      "id": "bv16:25.3",
      "pali": "Sopi aniccataṁ patto,"
    },
    {
      "id": "bv16:25.4",
      "pali": "yathaggupādānasaṅkhayā."
    },
    {
      "id": "bv16:26.1",
      "pali": "Atthadassī jinavaro,"
    },
    {
      "id": "bv16:26.2",
      "pali": "Anomārāmamhi nibbuto;"
    },
    {
      "id": "bv16:26.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv16:26.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv16:27.1",
      "pali": "Atthadassissa bhagavato vaṁso cuddasamo."
    }
  ]
}
