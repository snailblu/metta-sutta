{
  "uid": "pv35",
  "title": "10. Dhātuvivaṇṇapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv35:1.1",
      "pali": "“Antalikkhasmiṁ tiṭṭhanto,"
    },
    {
      "id": "pv35:1.2",
      "pali": "Duggandho pūti vāyasi;"
    },
    {
      "id": "pv35:1.3",
      "pali": "Mukhañca te kimayo pūtigandhaṁ,"
    },
    {
      "id": "pv35:1.4",
      "pali": "Khādanti kiṁ kammamakāsi pubbe."
    },
    {
      "id": "pv35:2.1",
      "pali": "Tato satthaṁ gahetvāna,"
    },
    {
      "id": "pv35:2.2",
      "pali": "okkantanti punappunaṁ;"
    },
    {
      "id": "pv35:2.3",
      "pali": "Khārena paripphositvā,"
    },
    {
      "id": "pv35:2.4",
      "pali": "okkantanti punappunaṁ."
    },
    {
      "id": "pv35:3.1",
      "pali": "Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv35:3.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv35:3.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv35:3.4",
      "pali": "idaṁ dukkhaṁ nigacchasī”ti."
    },
    {
      "id": "pv35:4.1",
      "pali": "“Ahaṁ rājagahe ramme,"
    },
    {
      "id": "pv35:4.2",
      "pali": "ramaṇīye giribbaje;"
    },
    {
      "id": "pv35:4.3",
      "pali": "Issaro dhanadhaññassa,"
    },
    {
      "id": "pv35:4.4",
      "pali": "supahūtassa mārisa."
    },
    {
      "id": "pv35:5.1",
      "pali": "Tassāyaṁ me bhariyā ca,"
    },
    {
      "id": "pv35:5.2",
      "pali": "dhītā ca suṇisā ca me;"
    },
    {
      "id": "pv35:5.3",
      "pali": "Tā mālaṁ uppalañcāpi,"
    },
    {
      "id": "pv35:5.4",
      "pali": "paccagghañca vilepanaṁ;"
    },
    {
      "id": "pv35:5.5",
      "pali": "Thūpaṁ harantiyo vāresiṁ,"
    },
    {
      "id": "pv35:5.6",
      "pali": "taṁ pāpaṁ pakataṁ mayā."
    },
    {
      "id": "pv35:6.1",
      "pali": "Chaḷāsītisahassāni,"
    },
    {
      "id": "pv35:6.2",
      "pali": "mayaṁ paccattavedanā;"
    },
    {
      "id": "pv35:6.3",
      "pali": "Thūpapūjaṁ vivaṇṇetvā,"
    },
    {
      "id": "pv35:6.4",
      "pali": "paccāma niraye bhusaṁ."
    },
    {
      "id": "pv35:7.1",
      "pali": "Ye ca kho thūpapūjāya,"
    },
    {
      "id": "pv35:7.2",
      "pali": "vattante arahato mahe;"
    },
    {
      "id": "pv35:7.3",
      "pali": "Ādīnavaṁ pakāsenti,"
    },
    {
      "id": "pv35:7.4",
      "pali": "vivecayetha ne tato."
    },
    {
      "id": "pv35:8.1",
      "pali": "Imā ca passa āyantiyo,"
    },
    {
      "id": "pv35:8.2",
      "pali": "Māladhārī alaṅkatā;"
    },
    {
      "id": "pv35:8.3",
      "pali": "Mālāvipākaṁnubhontiyo,"
    },
    {
      "id": "pv35:8.4",
      "pali": "Samiddhā ca tā yasassiniyo."
    },
    {
      "id": "pv35:9.1",
      "pali": "Tañca disvāna accheraṁ,"
    },
    {
      "id": "pv35:9.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "pv35:9.3",
      "pali": "Namo karonti sappaññā,"
    },
    {
      "id": "pv35:9.4",
      "pali": "vandanti taṁ mahāmuniṁ."
    },
    {
      "id": "pv35:10.1",
      "pali": "Sohaṁ nūna ito gantvā,"
    },
    {
      "id": "pv35:10.2",
      "pali": "yoniṁ laddhāna mānusiṁ;"
    },
    {
      "id": "pv35:10.3",
      "pali": "Thūpapūjaṁ karissāmi,"
    },
    {
      "id": "pv35:10.4",
      "pali": "appamatto punappunan”ti."
    },
    {
      "id": "pv35:11.1",
      "pali": "Dhātuvivaṇṇapetavatthu dasamaṁ."
    },
    {
      "id": "pv35:12.1",
      "pali": "Cūḷavaggo tatiyo."
    },
    {
      "id": "pv35:13.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "pv35:14.1",
      "pali": "Abhijjamāno kuṇḍiyo,"
    },
    {
      "id": "pv35:14.2",
      "pali": "rathakārī bhusena ca;"
    },
    {
      "id": "pv35:14.3",
      "pali": "Kumāro gaṇikā ceva,"
    },
    {
      "id": "pv35:14.4",
      "pali": "dve luddā piṭṭhipūjanā;"
    },
    {
      "id": "pv35:14.5",
      "pali": "Vaggo tena pavuccatīti."
    }
  ]
}
