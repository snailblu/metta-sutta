{
  "uid": "tha-ap358",
  "title": "Ambayāgudāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap358:1.1",
      "pali": "“Sataraṁsī nāma sambuddho,"
    },
    {
      "id": "tha-ap358:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap358:1.3",
      "pali": "Vuṭṭhahitvā samādhimhā,"
    },
    {
      "id": "tha-ap358:1.4",
      "pali": "bhikkhāya mamupāgami."
    },
    {
      "id": "tha-ap358:2.1",
      "pali": "Paccekabuddhaṁ disvāna,"
    },
    {
      "id": "tha-ap358:2.2",
      "pali": "ambayāguṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap358:2.3",
      "pali": "Vippasannamanaṁ tassa,"
    },
    {
      "id": "tha-ap358:2.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap358:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap358:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap358:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap358:3.4",
      "pali": "ambayāguyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap358:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap358:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap358:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap358:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ambayāgudāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap358:6.1",
      "pali": "Ambayāgudāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
