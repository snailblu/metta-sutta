{
  "uid": "tha-ap12",
  "title": "Ānandattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap12:1.1",
      "pali": "“Ārāmadvārā nikkhamma,"
    },
    {
      "id": "tha-ap12:1.2",
      "pali": "padumuttaro mahāmuni;"
    },
    {
      "id": "tha-ap12:1.3",
      "pali": "Vassento amataṁ vuṭṭhiṁ,"
    },
    {
      "id": "tha-ap12:1.4",
      "pali": "nibbāpesi mahājanaṁ."
    },
    {
      "id": "tha-ap12:2.1",
      "pali": "Satasahassaṁ te dhīrā,"
    },
    {
      "id": "tha-ap12:2.2",
      "pali": "chaḷabhiññā mahiddhikā;"
    },
    {
      "id": "tha-ap12:2.3",
      "pali": "Parivārenti sambuddhaṁ,"
    },
    {
      "id": "tha-ap12:2.4",
      "pali": "chāyāva anapāyinī."
    },
    {
      "id": "tha-ap12:3.1",
      "pali": "Hatthikkhandhagato āsiṁ,"
    },
    {
      "id": "tha-ap12:3.2",
      "pali": "setacchattaṁ varuttamaṁ;"
    },
    {
      "id": "tha-ap12:3.3",
      "pali": "Sucārurūpaṁ disvāna,"
    },
    {
      "id": "tha-ap12:3.4",
      "pali": "vitti me udapajjatha."
    },
    {
      "id": "tha-ap12:4.1",
      "pali": "Oruyha hatthikhandhamhā,"
    },
    {
      "id": "tha-ap12:4.2",
      "pali": "upagacchiṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap12:4.3",
      "pali": "Ratanāmayachattaṁ me,"
    },
    {
      "id": "tha-ap12:4.4",
      "pali": "buddhaseṭṭhassa dhārayiṁ."
    },
    {
      "id": "tha-ap12:5.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap12:5.2",
      "pali": "padumuttaro mahāisi;"
    },
    {
      "id": "tha-ap12:5.3",
      "pali": "Taṁ kathaṁ ṭhapayitvāna,"
    },
    {
      "id": "tha-ap12:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap12:6.1",
      "pali": "‘Yo so chattamadhāresi,"
    },
    {
      "id": "tha-ap12:6.2",
      "pali": "soṇṇālaṅkārabhūsitaṁ;"
    },
    {
      "id": "tha-ap12:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap12:6.4",
      "pali": "suṇotha mama bhāsato."
    },
    {
      "id": "tha-ap12:7.1",
      "pali": "Ito gantvā ayaṁ poso,"
    },
    {
      "id": "tha-ap12:7.2",
      "pali": "tusitaṁ āvasissati;"
    },
    {
      "id": "tha-ap12:7.3",
      "pali": "Anubhossati sampattiṁ,"
    },
    {
      "id": "tha-ap12:7.4",
      "pali": "accharāhi purakkhato."
    },
    {
      "id": "tha-ap12:8.1",
      "pali": "Catuttiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap12:8.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap12:8.3",
      "pali": "Balādhipo aṭṭhasataṁ,"
    },
    {
      "id": "tha-ap12:8.4",
      "pali": "vasudhaṁ āvasissati."
    },
    {
      "id": "tha-ap12:9.1",
      "pali": "Aṭṭhapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap12:9.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap12:9.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap12:9.4",
      "pali": "mahiyā kārayissati."
    },
    {
      "id": "tha-ap12:10.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap12:10.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap12:10.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap12:10.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap12:11.1",
      "pali": "Sakyānaṁ kulaketussa,"
    },
    {
      "id": "tha-ap12:11.2",
      "pali": "ñātibandhu bhavissati;"
    },
    {
      "id": "tha-ap12:11.3",
      "pali": "Ānando nāma nāmena,"
    },
    {
      "id": "tha-ap12:11.4",
      "pali": "upaṭṭhāko mahesino."
    },
    {
      "id": "tha-ap12:12.1",
      "pali": "Ātāpī nipako cāpi,"
    },
    {
      "id": "tha-ap12:12.2",
      "pali": "bāhusacce sukovido;"
    },
    {
      "id": "tha-ap12:12.3",
      "pali": "Nivātavutti atthaddho,"
    },
    {
      "id": "tha-ap12:12.4",
      "pali": "sabbapāṭhī bhavissati."
    },
    {
      "id": "tha-ap12:13.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap12:13.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap12:13.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap12:13.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap12:14.1",
      "pali": "Santi āraññakā nāgā,"
    },
    {
      "id": "tha-ap12:14.2",
      "pali": "kuñjarā saṭṭhihāyanā;"
    },
    {
      "id": "tha-ap12:14.3",
      "pali": "Tidhāpabhinnā mātaṅgā,"
    },
    {
      "id": "tha-ap12:14.4",
      "pali": "īsādantā urūḷhavā."
    },
    {
      "id": "tha-ap12:15.1",
      "pali": "Anekasatasahassā,"
    },
    {
      "id": "tha-ap12:15.2",
      "pali": "paṇḍitāpi mahiddhikā;"
    },
    {
      "id": "tha-ap12:15.3",
      "pali": "Sabbe te buddhanāgassa,"
    },
    {
      "id": "tha-ap12:15.4",
      "pali": "na hontupaṇidhimhi te’."
    },
    {
      "id": "tha-ap12:16.1",
      "pali": "Ādiyāme namassāmi,"
    },
    {
      "id": "tha-ap12:16.2",
      "pali": "majjhime atha pacchime;"
    },
    {
      "id": "tha-ap12:16.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap12:16.4",
      "pali": "buddhaseṭṭhaṁ upaṭṭhahiṁ."
    },
    {
      "id": "tha-ap12:17.1",
      "pali": "Ātāpī nipako cāpi,"
    },
    {
      "id": "tha-ap12:17.2",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "tha-ap12:17.3",
      "pali": "Sotāpattiphalaṁ patto,"
    },
    {
      "id": "tha-ap12:17.4",
      "pali": "sekhabhūmīsu kovido."
    },
    {
      "id": "tha-ap12:18.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap12:18.2",
      "pali": "yaṁ kammamabhinīhariṁ;"
    },
    {
      "id": "tha-ap12:18.3",
      "pali": "Tāhaṁ bhūmimanuppatto,"
    },
    {
      "id": "tha-ap12:18.4",
      "pali": "ṭhitā saddhammamācalā."
    },
    {
      "id": "tha-ap12:19.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap12:19.2",
      "pali": "buddhaseṭṭhassa santike;"
    },
    {
      "id": "tha-ap12:19.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap12:19.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap12:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap12:20.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap12:20.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap12:20.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap12:21.1",
      "pali": "Itthaṁ sudaṁ āyasmā ānando thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap12:22.1",
      "pali": "Ānandattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap12:23.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap12:24.1",
      "pali": "Buddho paccekabuddho ca,"
    },
    {
      "id": "tha-ap12:24.2",
      "pali": "sāriputto ca kolito;"
    },
    {
      "id": "tha-ap12:24.3",
      "pali": "Kassapo anuruddho ca,"
    },
    {
      "id": "tha-ap12:24.4",
      "pali": "puṇṇatthero upāli ca."
    },
    {
      "id": "tha-ap12:25.1",
      "pali": "Aññāsikoṇḍañño piṇḍolo,"
    },
    {
      "id": "tha-ap12:25.2",
      "pali": "revatānandapaṇḍito;"
    },
    {
      "id": "tha-ap12:25.3",
      "pali": "Chasatāni ca paññāsa,"
    },
    {
      "id": "tha-ap12:25.4",
      "pali": "gāthāyo sabbapiṇḍitā."
    },
    {
      "id": "tha-ap12:26.1",
      "pali": "Apadāne buddhavaggo paṭhamo."
    }
  ]
}
