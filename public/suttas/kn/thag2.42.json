{
  "uid": "thag2.42",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.42:1.1",
      "pali": "“Yo have daharo bhikkhu,"
    },
    {
      "id": "thag2.42:1.2",
      "pali": "yuñjati buddhasāsane;"
    },
    {
      "id": "thag2.42:1.3",
      "pali": "Jāgaro sa hi suttesu,"
    },
    {
      "id": "thag2.42:1.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "thag2.42:2.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "thag2.42:2.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "thag2.42:2.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "thag2.42:2.4",
      "pali": "saraṁ buddhāna sāsanan”ti."
    },
    {
      "id": "thag2.42:2.5",
      "pali": "… Dhammapālo thero …."
    }
  ]
}
