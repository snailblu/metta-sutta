{
  "uid": "pv14",
  "title": "2. Sāriputtattheramātupetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv14:1.1",
      "pali": "“Naggā dubbaṇṇarūpāsi,"
    },
    {
      "id": "pv14:1.2",
      "pali": "kisā dhamanisanthatā;"
    },
    {
      "id": "pv14:1.3",
      "pali": "Upphāsulike kisike,"
    },
    {
      "id": "pv14:1.4",
      "pali": "kā nu tvaṁ idha tiṭṭhasi”."
    },
    {
      "id": "pv14:2.1",
      "pali": "“Ahaṁ te sakiyā mātā,"
    },
    {
      "id": "pv14:2.2",
      "pali": "pubbe aññāsu jātīsu;"
    },
    {
      "id": "pv14:2.3",
      "pali": "Upapannā pettivisayaṁ,"
    },
    {
      "id": "pv14:2.4",
      "pali": "khuppipāsasamappitā."
    },
    {
      "id": "pv14:3.1",
      "pali": "Chaḍḍitaṁ khipitaṁ kheḷaṁ,"
    },
    {
      "id": "pv14:3.2",
      "pali": "siṅghāṇikaṁ silesumaṁ;"
    },
    {
      "id": "pv14:3.3",
      "pali": "Vasañca ḍayhamānānaṁ,"
    },
    {
      "id": "pv14:3.4",
      "pali": "vijātānañca lohitaṁ."
    },
    {
      "id": "pv14:4.1",
      "pali": "Vaṇikānañca yaṁ ghāna-"
    },
    {
      "id": "pv14:4.2",
      "pali": "sīsacchinnāna lohitaṁ;"
    },
    {
      "id": "pv14:4.3",
      "pali": "Khudāparetā bhuñjāmi,"
    },
    {
      "id": "pv14:4.4",
      "pali": "itthipurisanissitaṁ."
    },
    {
      "id": "pv14:5.1",
      "pali": "Pubbalohitaṁ bhakkhāmi,"
    },
    {
      "id": "pv14:5.2",
      "pali": "pasūnaṁ mānusāna ca;"
    },
    {
      "id": "pv14:5.3",
      "pali": "Aleṇā anagārā ca,"
    },
    {
      "id": "pv14:5.4",
      "pali": "nīlamañcaparāyaṇā."
    },
    {
      "id": "pv14:6.1",
      "pali": "Dehi puttaka me dānaṁ,"
    },
    {
      "id": "pv14:6.2",
      "pali": "datvā anvādisāhi me;"
    },
    {
      "id": "pv14:6.3",
      "pali": "Appeva nāma mucceyyaṁ,"
    },
    {
      "id": "pv14:6.4",
      "pali": "pubbalohitabhojanā”ti."
    },
    {
      "id": "pv14:7.1",
      "pali": "Mātuyā vacanaṁ sutvā,"
    },
    {
      "id": "pv14:7.2",
      "pali": "upatissonukampako;"
    },
    {
      "id": "pv14:7.3",
      "pali": "Āmantayi moggallānaṁ,"
    },
    {
      "id": "pv14:7.4",
      "pali": "anuruddhañca kappinaṁ."
    },
    {
      "id": "pv14:8.1",
      "pali": "Catasso kuṭiyo katvā,"
    },
    {
      "id": "pv14:8.2",
      "pali": "saṅghe cātuddise adā;"
    },
    {
      "id": "pv14:8.3",
      "pali": "Kuṭiyo annapānañca,"
    },
    {
      "id": "pv14:8.4",
      "pali": "mātu dakkhiṇamādisī."
    },
    {
      "id": "pv14:9.1",
      "pali": "Samanantarānuddiṭṭhe,"
    },
    {
      "id": "pv14:9.2",
      "pali": "vipāko udapajjatha;"
    },
    {
      "id": "pv14:9.3",
      "pali": "Bhojanaṁ pānīyaṁ vatthaṁ,"
    },
    {
      "id": "pv14:9.4",
      "pali": "dakkhiṇāya idaṁ phalaṁ."
    },
    {
      "id": "pv14:10.1",
      "pali": "Tato suddhā sucivasanā,"
    },
    {
      "id": "pv14:10.2",
      "pali": "kāsikuttamadhārinī;"
    },
    {
      "id": "pv14:10.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "pv14:10.4",
      "pali": "kolitaṁ upasaṅkami."
    },
    {
      "id": "pv14:11.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "pv14:11.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "pv14:11.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "pv14:11.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "pv14:12.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "pv14:12.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "pv14:12.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "pv14:12.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "pv14:13.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "pv14:13.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "pv14:13.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "pv14:13.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "pv14:14.1",
      "pali": "“Sāriputtassāhaṁ mātā,"
    },
    {
      "id": "pv14:14.2",
      "pali": "pubbe aññāsu jātīsu;"
    },
    {
      "id": "pv14:14.3",
      "pali": "Upapannā pettivisayaṁ,"
    },
    {
      "id": "pv14:14.4",
      "pali": "khuppipāsasamappitā."
    },
    {
      "id": "pv14:15.1",
      "pali": "Chaḍḍitaṁ khipitaṁ kheḷaṁ,"
    },
    {
      "id": "pv14:15.2",
      "pali": "siṅghāṇikaṁ silesumaṁ;"
    },
    {
      "id": "pv14:15.3",
      "pali": "Vasañca ḍayhamānānaṁ,"
    },
    {
      "id": "pv14:15.4",
      "pali": "vijātānañca lohitaṁ."
    },
    {
      "id": "pv14:16.1",
      "pali": "Vaṇikānañca yaṁ ghāna-"
    },
    {
      "id": "pv14:16.2",
      "pali": "sīsacchinnāna lohitaṁ;"
    },
    {
      "id": "pv14:16.3",
      "pali": "Khudāparetā bhuñjāmi,"
    },
    {
      "id": "pv14:16.4",
      "pali": "itthipurisanissitaṁ."
    },
    {
      "id": "pv14:17.1",
      "pali": "Pubbalohitaṁ bhakkhissaṁ,"
    },
    {
      "id": "pv14:17.2",
      "pali": "pasūnaṁ mānusāna ca;"
    },
    {
      "id": "pv14:17.3",
      "pali": "Aleṇā anagārā ca,"
    },
    {
      "id": "pv14:17.4",
      "pali": "nīlamañcaparāyaṇā."
    },
    {
      "id": "pv14:18.1",
      "pali": "Sāriputtassa dānena,"
    },
    {
      "id": "pv14:18.2",
      "pali": "modāmi akutobhayā;"
    },
    {
      "id": "pv14:18.3",
      "pali": "Muniṁ kāruṇikaṁ loke,"
    },
    {
      "id": "pv14:18.4",
      "pali": "bhante vanditumāgatā”ti."
    },
    {
      "id": "pv14:19.1",
      "pali": "Sāriputtattherassa mātupetivatthu dutiyaṁ."
    }
  ]
}
