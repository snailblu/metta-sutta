{
  "uid": "mil5.2.2",
  "title": "Abhejjavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil5.2.2:1.1",
      "pali": "“Bhante nāgasena, bhāsitampetaṁ bhagavatā—"
    },
    {
      "id": "mil5.2.2:1.2",
      "pali": "‘natthānanda, tathāgatassa dhammesu ācariyamuṭṭhī’ti, puna ca therena mālukyaputtena pañhaṁ puṭṭho na byākāsi."
    },
    {
      "id": "mil5.2.2:1.3",
      "pali": "Eso kho, bhante nāgasena, pañho dvayanto ekantanissito bhavissati ajānanena vā guyhakaraṇena vā."
    },
    {
      "id": "mil5.2.2:1.4",
      "pali": "Yadi, bhante nāgasena, bhagavatā bhaṇitaṁ—"
    },
    {
      "id": "mil5.2.2:1.5",
      "pali": "‘natthānanda, tathāgatassa dhammesu ācariyamuṭṭhī’ti, tena hi therassa mālukyaputtassa ajānantena na byākataṁ."
    },
    {
      "id": "mil5.2.2:1.6",
      "pali": "Yadi jānantena na byākataṁ, tena hi atthi tathāgatassa dhammesu ācariyamuṭṭhi."
    },
    {
      "id": "mil5.2.2:1.7",
      "pali": "Ayampi ubhato koṭiko pañho tavānuppatto, so tayā nibbāhitabbo”ti."
    },
    {
      "id": "mil5.2.2:2.1",
      "pali": "“Bhāsitampetaṁ, mahārāja, bhagavatā ‘natthānanda, tathāgatassa dhammesu ācariyamuṭṭhī’ti, abyākato ca therena mālukyaputtena pucchito pañho, tañca pana na ajānantena na guyhakaraṇena."
    },
    {
      "id": "mil5.2.2:2.2",
      "pali": "Cattārimāni, mahārāja, pañhabyākaraṇāni."
    },
    {
      "id": "mil5.2.2:2.3",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "mil5.2.2:2.4",
      "pali": "Ekaṁsabyākaraṇīyo pañho vibhajjabyākaraṇīyo pañho paṭipucchābyākaraṇīyo pañho ṭhapanīyo pañhoti."
    },
    {
      "id": "mil5.2.2:3.1",
      "pali": "Katamo ca, mahārāja, ekaṁsabyākaraṇīyo pañho?"
    },
    {
      "id": "mil5.2.2:3.2",
      "pali": "‘Rūpaṁ aniccan’ti ekaṁsabyākaraṇīyo pañho,"
    },
    {
      "id": "mil5.2.2:3.3",
      "pali": "‘vedanā aniccā’ti …pe…"
    },
    {
      "id": "mil5.2.2:3.4",
      "pali": "‘saññā aniccā’ti …pe…"
    },
    {
      "id": "mil5.2.2:3.5",
      "pali": "‘saṅkhārā aniccā’ti …pe…"
    },
    {
      "id": "mil5.2.2:3.6",
      "pali": "‘viññāṇaṁ aniccan’ti ekaṁsabyākaraṇīyo pañho, ayaṁ ekaṁsabyākaraṇīyo pañho."
    },
    {
      "id": "mil5.2.2:4.1",
      "pali": "Katamo vibhajjabyākaraṇīyo pañho?"
    },
    {
      "id": "mil5.2.2:4.2",
      "pali": "‘Aniccaṁ pana rūpan’ti vibhajjabyākaraṇīyo pañho,"
    },
    {
      "id": "mil5.2.2:4.3",
      "pali": "‘aniccā pana vedanā’ti …pe…"
    },
    {
      "id": "mil5.2.2:4.4",
      "pali": "‘aniccā pana saññā’ti …pe…"
    },
    {
      "id": "mil5.2.2:4.5",
      "pali": "‘aniccā pana saṅkhārā’ti …pe…"
    },
    {
      "id": "mil5.2.2:4.6",
      "pali": "‘aniccaṁ pana viññāṇan’ti vibhajjabyākaraṇīyo pañho, ayaṁ vibhajjabyākaraṇīyo pañho."
    },
    {
      "id": "mil5.2.2:5.1",
      "pali": "Katamo paṭipucchābyākaraṇīyo pañho?"
    },
    {
      "id": "mil5.2.2:5.2",
      "pali": "‘Kiṁ nu kho cakkhunā sabbaṁ vijānātī’ti ayaṁ paṭipucchābyākaraṇīyo pañho."
    },
    {
      "id": "mil5.2.2:6.1",
      "pali": "Katamo ṭhapanīyo pañho?"
    },
    {
      "id": "mil5.2.2:6.2",
      "pali": "‘Sassato loko’ti ṭhapanīyo pañho,"
    },
    {
      "id": "mil5.2.2:6.3",
      "pali": "‘asassato loko’ti,"
    },
    {
      "id": "mil5.2.2:6.4",
      "pali": "‘antavā loko’ti,"
    },
    {
      "id": "mil5.2.2:6.5",
      "pali": "‘anantavā loko’ti,"
    },
    {
      "id": "mil5.2.2:6.6",
      "pali": "‘antavā ca anantavā ca loko’ti,"
    },
    {
      "id": "mil5.2.2:6.7",
      "pali": "‘nevantavā nānantavā loko’ti,"
    },
    {
      "id": "mil5.2.2:6.8",
      "pali": "‘taṁ jīvaṁ taṁ sarīran’ti,"
    },
    {
      "id": "mil5.2.2:6.9",
      "pali": "‘aññaṁ jīvaṁ aññaṁ sarīran’ti,"
    },
    {
      "id": "mil5.2.2:6.10",
      "pali": "‘hoti tathāgato paraṁ maraṇā’ti,"
    },
    {
      "id": "mil5.2.2:6.11",
      "pali": "‘na hoti tathāgato paraṁ maraṇā’ti,"
    },
    {
      "id": "mil5.2.2:6.12",
      "pali": "‘hoti ca na ca hoti tathāgato paraṁ maraṇā’ti,"
    },
    {
      "id": "mil5.2.2:6.13",
      "pali": "‘neva hoti na na hoti tathāgato paraṁ maraṇā’ti ṭhapanīyo pañho,"
    },
    {
      "id": "mil5.2.2:6.14",
      "pali": "ayaṁ ṭhapanīyo pañho."
    },
    {
      "id": "mil5.2.2:7.1",
      "pali": "Bhagavā, mahārāja, therassa mālukyaputtassa taṁ ṭhapanīyaṁ pañhaṁ na byākāsi."
    },
    {
      "id": "mil5.2.2:7.2",
      "pali": "So pana pañho kiṅkāraṇā ṭhapanīyo?"
    },
    {
      "id": "mil5.2.2:7.3",
      "pali": "Na tassa dīpanāya hetu vā kāraṇaṁ vā atthi, tasmā so pañho ṭhapanīyo."
    },
    {
      "id": "mil5.2.2:7.4",
      "pali": "Natthi buddhānaṁ bhagavantānaṁ akāraṇamahetukaṁ giramudīraṇan”ti."
    },
    {
      "id": "mil5.2.2:7.5",
      "pali": "“Sādhu, bhante nāgasena, evametaṁ tathā sampaṭicchāmī”ti."
    },
    {
      "id": "mil5.2.2:8.1",
      "pali": "Abyākaraṇīyapañho dutiyo."
    }
  ]
}
