{
  "uid": "tha-ap296",
  "title": "Saddasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap296:1.1",
      "pali": "“Anuggatamhi ādicce,"
    },
    {
      "id": "tha-ap296:1.2",
      "pali": "panādo vipulo ahu;"
    },
    {
      "id": "tha-ap296:1.3",
      "pali": "Buddhaseṭṭhassa lokamhi,"
    },
    {
      "id": "tha-ap296:1.4",
      "pali": "pātubhāvo mahesino."
    },
    {
      "id": "tha-ap296:2.1",
      "pali": "Ghosamassosahaṁ tattha,"
    },
    {
      "id": "tha-ap296:2.2",
      "pali": "na ca passāmi taṁ jinaṁ;"
    },
    {
      "id": "tha-ap296:2.3",
      "pali": "Maraṇañca anuppatto,"
    },
    {
      "id": "tha-ap296:2.4",
      "pali": "buddhasaññamanussariṁ."
    },
    {
      "id": "tha-ap296:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap296:3.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap296:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap296:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap296:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap296:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap296:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap296:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā saddasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap296:6.1",
      "pali": "Saddasaññakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
