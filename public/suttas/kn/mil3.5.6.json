{
  "uid": "mil3.5.6",
  "title": "6. Vedagūpañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.5.6:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.5.6:1.2",
      "pali": "“bhante nāgasena, vedagū upalabbhatī”ti?"
    },
    {
      "id": "mil3.5.6:1.3",
      "pali": "Thero āha—"
    },
    {
      "id": "mil3.5.6:1.4",
      "pali": "“paramatthena kho, mahārāja, vedagū nupalabbhatī”ti."
    },
    {
      "id": "mil3.5.6:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.5.6:3.1",
      "pali": "Vedagūpañho chaṭṭho."
    }
  ]
}
