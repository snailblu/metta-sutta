{
  "uid": "tha-ap179",
  "title": "Ekadīpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap179:1.1",
      "pali": "“Padumuttarassa munino,"
    },
    {
      "id": "tha-ap179:1.2",
      "pali": "saḷale bodhimuttame;"
    },
    {
      "id": "tha-ap179:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap179:1.4",
      "pali": "ekadīpaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap179:2.1",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap179:2.2",
      "pali": "nibbatte puññasañcaye;"
    },
    {
      "id": "tha-ap179:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap179:2.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap179:3.1",
      "pali": "Soḷase kappasahasse,"
    },
    {
      "id": "tha-ap179:3.2",
      "pali": "ito te caturo janā;"
    },
    {
      "id": "tha-ap179:3.3",
      "pali": "Candābhā nāma nāmena,"
    },
    {
      "id": "tha-ap179:3.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap179:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap179:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap179:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap179:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekadīpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap179:6.1",
      "pali": "Ekadīpiyattherassāpadānaṁ sattamaṁ."
    },
    {
      "id": "tha-ap179:6.2",
      "pali": "Navamaṁ bhāṇavāraṁ."
    }
  ]
}
