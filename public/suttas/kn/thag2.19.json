{
  "uid": "thag2.19",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.19:1.1",
      "pali": "“Ayoniso manasikārā,"
    },
    {
      "id": "thag2.19:1.2",
      "pali": "maṇḍanaṁ anuyuñjisaṁ;"
    },
    {
      "id": "thag2.19:1.3",
      "pali": "Uddhato capalo cāsiṁ,"
    },
    {
      "id": "thag2.19:1.4",
      "pali": "kāmarāgena aṭṭito."
    },
    {
      "id": "thag2.19:2.1",
      "pali": "Upāyakusalenāhaṁ,"
    },
    {
      "id": "thag2.19:2.2",
      "pali": "buddhenādiccabandhunā;"
    },
    {
      "id": "thag2.19:2.3",
      "pali": "Yoniso paṭipajjitvā,"
    },
    {
      "id": "thag2.19:2.4",
      "pali": "bhave cittaṁ udabbahin”ti."
    },
    {
      "id": "thag2.19:2.5",
      "pali": "… Nando thero …."
    }
  ]
}
