{
  "uid": "tha-ap248",
  "title": "Pattadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap248:1.1",
      "pali": "“Paramena damathena,"
    },
    {
      "id": "tha-ap248:1.2",
      "pali": "siddhatthassa mahesino;"
    },
    {
      "id": "tha-ap248:1.3",
      "pali": "Pattadānaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap248:1.4",
      "pali": "ujubhūtassa tādino."
    },
    {
      "id": "tha-ap248:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap248:2.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap248:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap248:2.4",
      "pali": "pattadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap248:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap248:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap248:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap248:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā pattadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap248:5.1",
      "pali": "Pattadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
