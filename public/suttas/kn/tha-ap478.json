{
  "uid": "tha-ap478",
  "title": "Kusaṭṭhakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap478:1.1",
      "pali": "“Kassapassa bhagavato,"
    },
    {
      "id": "tha-ap478:1.2",
      "pali": "brāhmaṇassa vusīmato;"
    },
    {
      "id": "tha-ap478:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap478:1.4",
      "pali": "kusaṭṭhakamadāsahaṁ."
    },
    {
      "id": "tha-ap478:2.1",
      "pali": "Imasmiṁyeva kappasmiṁ,"
    },
    {
      "id": "tha-ap478:2.2",
      "pali": "kusaṭṭhakamadāsahaṁ;"
    },
    {
      "id": "tha-ap478:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap478:2.4",
      "pali": "kusaṭṭhakassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap478:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap478:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap478:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap478:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap478:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap478:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap478:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap478:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap478:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap478:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kusaṭṭhakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap478:7.1",
      "pali": "Kusaṭṭhakadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
