{
  "uid": "iti19",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti19:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti19:2.1",
      "pali": "“Ekadhammo, bhikkhave, loke uppajjamāno uppajjati bahujanahitāya bahujanasukhāya bahuno janassa atthāya hitāya sukhāya devamanussānaṁ."
    },
    {
      "id": "iti19:2.2",
      "pali": "Katamo ekadhammo?"
    },
    {
      "id": "iti19:2.3",
      "pali": "Saṅghasāmaggī."
    },
    {
      "id": "iti19:2.4",
      "pali": "Saṅghe kho pana, bhikkhave, samagge na ceva aññamaññaṁ bhaṇḍanāni honti, na ca aññamaññaṁ paribhāsā honti, na ca aññamaññaṁ parikkhepā honti, na ca aññamaññaṁ pariccajanā honti."
    },
    {
      "id": "iti19:2.5",
      "pali": "Tattha appasannā ceva pasīdanti, pasannānañca bhiyyobhāvo hotī”ti."
    },
    {
      "id": "iti19:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti19:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti19:3.1",
      "pali": "“Sukhā saṅghassa sāmaggī,"
    },
    {
      "id": "iti19:3.2",
      "pali": "samaggānañcanuggaho;"
    },
    {
      "id": "iti19:3.3",
      "pali": "Samaggarato dhammaṭṭho,"
    },
    {
      "id": "iti19:3.4",
      "pali": "yogakkhemā na dhaṁsati;"
    },
    {
      "id": "iti19:3.5",
      "pali": "Saṅghaṁ samaggaṁ katvāna,"
    },
    {
      "id": "iti19:3.6",
      "pali": "kappaṁ saggamhi modatī”ti."
    },
    {
      "id": "iti19:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti19:4.2",
      "pali": "Navamaṁ."
    }
  ]
}
