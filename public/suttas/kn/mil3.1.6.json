{
  "uid": "mil3.1.6",
  "title": "6. Paṭisandhipañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.1.6:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.1.6:1.2",
      "pali": "“bhante nāgasena, atthi koci mato na paṭisandahatī”ti."
    },
    {
      "id": "mil3.1.6:1.3",
      "pali": "Thero āha—"
    },
    {
      "id": "mil3.1.6:1.4",
      "pali": "“koci paṭisandahati, koci na paṭisandahatī”ti."
    },
    {
      "id": "mil3.1.6:1.5",
      "pali": "“Ko paṭisandahati, ko na paṭisandahatī”ti?"
    },
    {
      "id": "mil3.1.6:1.6",
      "pali": "“Sakileso, mahārāja, paṭisandahati, nikkileso na paṭisandahatī”ti."
    },
    {
      "id": "mil3.1.6:1.7",
      "pali": "“Tvaṁ pana, bhante nāgasena, paṭisandahissasī”ti?"
    },
    {
      "id": "mil3.1.6:1.8",
      "pali": "“Sace, mahārāja, saupādāno bhavissāmi paṭisandahissāmi, sace anupādāno bhavissāmi na paṭisandahissāmī”ti."
    },
    {
      "id": "mil3.1.6:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.1.6:3.1",
      "pali": "Paṭisandhipañho chaṭṭho."
    }
  ]
}
