{
  "uid": "thig1.1",
  "title": "Aññatarātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.1:1.1",
      "pali": "“Sukhaṁ supāhi therike,"
    },
    {
      "id": "thig1.1:1.2",
      "pali": "Katvā coḷena pārutā;"
    },
    {
      "id": "thig1.1:1.3",
      "pali": "Upasanto hi te rāgo,"
    },
    {
      "id": "thig1.1:1.4",
      "pali": "Sukkhaḍākaṁ va kumbhiyan”ti."
    },
    {
      "id": "thig1.1:2.1",
      "pali": "Itthaṁ sudaṁ aññatarā therī apaññātā bhikkhunī gāthaṁ abhāsitthāti."
    }
  ]
}
