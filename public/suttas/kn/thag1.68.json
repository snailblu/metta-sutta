{
  "uid": "thag1.68",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.68:1.1",
      "pali": "“Adhicetaso appamajjato,"
    },
    {
      "id": "thag1.68:1.2",
      "pali": "Munino monapathesu sikkhato;"
    },
    {
      "id": "thag1.68:1.3",
      "pali": "Sokā na bhavanti tādino,"
    },
    {
      "id": "thag1.68:1.4",
      "pali": "Upasantassa sadā satīmato”ti."
    },
    {
      "id": "thag1.68:1.5",
      "pali": "… Ekudāniyo thero …."
    }
  ]
}
