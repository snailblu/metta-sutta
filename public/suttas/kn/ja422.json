{
  "uid": "ja422",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja422:1.1",
      "pali": "“Dhammo have hato hanti,"
    },
    {
      "id": "ja422:1.2",
      "pali": "Nāhato hanti kiñcanaṁ;"
    },
    {
      "id": "ja422:1.3",
      "pali": "Tasmā hi dhammaṁ na hane,"
    },
    {
      "id": "ja422:1.4",
      "pali": "Mā tvaṁ dhammo hato hani."
    },
    {
      "id": "ja422:2.1",
      "pali": "Alikaṁ bhāsamānassa,"
    },
    {
      "id": "ja422:2.2",
      "pali": "apakkamanti devatā;"
    },
    {
      "id": "ja422:2.3",
      "pali": "Pūtikañca mukhaṁ vāti,"
    },
    {
      "id": "ja422:2.4",
      "pali": "sakaṭṭhānā ca dhaṁsati;"
    },
    {
      "id": "ja422:2.5",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:2.6",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:3.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:3.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:3.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:3.4",
      "pali": "bhūmiyaṁ tiṭṭha cetiya."
    },
    {
      "id": "ja422:4.1",
      "pali": "Akāle vassatī tassa,"
    },
    {
      "id": "ja422:4.2",
      "pali": "kāle tassa na vassati;"
    },
    {
      "id": "ja422:4.3",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:4.4",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:5.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:5.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:5.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:5.4",
      "pali": "bhūmiṁ pavisa cetiya."
    },
    {
      "id": "ja422:6.1",
      "pali": "Jivhā tassa dvidhā hoti,"
    },
    {
      "id": "ja422:6.2",
      "pali": "uragasseva disampati;"
    },
    {
      "id": "ja422:6.3",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:6.4",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:7.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:7.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:7.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:7.4",
      "pali": "bhiyyo pavisa cetiya."
    },
    {
      "id": "ja422:8.1",
      "pali": "Jivhā tassa na bhavati,"
    },
    {
      "id": "ja422:8.2",
      "pali": "macchasseva disampati;"
    },
    {
      "id": "ja422:8.3",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:8.4",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:9.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:9.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:9.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:9.4",
      "pali": "bhiyyo pavisa cetiya."
    },
    {
      "id": "ja422:10.1",
      "pali": "Thiyova tassa jāyanti,"
    },
    {
      "id": "ja422:10.2",
      "pali": "na pumā jāyare kule;"
    },
    {
      "id": "ja422:10.3",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:10.4",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:11.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:11.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:11.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:11.4",
      "pali": "bhiyyo pavisa cetiya."
    },
    {
      "id": "ja422:12.1",
      "pali": "Puttā tassa na bhavanti,"
    },
    {
      "id": "ja422:12.2",
      "pali": "pakkamanti disodisaṁ;"
    },
    {
      "id": "ja422:12.3",
      "pali": "Yo jānaṁ pucchito pañhaṁ,"
    },
    {
      "id": "ja422:12.4",
      "pali": "aññathā naṁ viyākare."
    },
    {
      "id": "ja422:13.1",
      "pali": "Sace hi saccaṁ bhaṇasi,"
    },
    {
      "id": "ja422:13.2",
      "pali": "hohi rāja yathā pure;"
    },
    {
      "id": "ja422:13.3",
      "pali": "Musā ce bhāsase rāja,"
    },
    {
      "id": "ja422:13.4",
      "pali": "bhiyyo pavisa cetiya”."
    },
    {
      "id": "ja422:14.1",
      "pali": "“Sa rājā isinā satto,"
    },
    {
      "id": "ja422:14.2",
      "pali": "antalikkhacaro pure;"
    },
    {
      "id": "ja422:14.3",
      "pali": "Pāvekkhi pathaviṁ cecco,"
    },
    {
      "id": "ja422:14.4",
      "pali": "hīnatto patva pariyāyaṁ."
    },
    {
      "id": "ja422:15.1",
      "pali": "Tasmā hi chandāgamanaṁ,"
    },
    {
      "id": "ja422:15.2",
      "pali": "Nappasaṁsanti paṇḍitā;"
    },
    {
      "id": "ja422:15.3",
      "pali": "Aduṭṭhacitto bhāseyya,"
    },
    {
      "id": "ja422:15.4",
      "pali": "Giraṁ saccūpasaṁhitanti”."
    },
    {
      "id": "ja422:16.1",
      "pali": "Cetiyajātakaṁ chaṭṭhaṁ."
    }
  ]
}
