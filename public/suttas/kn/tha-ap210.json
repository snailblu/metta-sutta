{
  "uid": "tha-ap210",
  "title": "Koraṇḍapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap210:1.1",
      "pali": "“Akkantañca padaṁ disvā,"
    },
    {
      "id": "tha-ap210:1.2",
      "pali": "cakkālaṅkārabhūsitaṁ;"
    },
    {
      "id": "tha-ap210:1.3",
      "pali": "Padenānupadaṁ yanto,"
    },
    {
      "id": "tha-ap210:1.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap210:2.1",
      "pali": "Koraṇḍaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap210:2.2",
      "pali": "samūlaṁ pūjitaṁ mayā;"
    },
    {
      "id": "tha-ap210:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap210:2.4",
      "pali": "avandiṁ padamuttamaṁ."
    },
    {
      "id": "tha-ap210:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap210:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap210:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap210:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap210:4.1",
      "pali": "Sattapaññāsakappamhi,"
    },
    {
      "id": "tha-ap210:4.2",
      "pali": "eko vītamalo ahuṁ;"
    },
    {
      "id": "tha-ap210:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap210:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap210:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap210:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap210:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap210:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā koraṇḍapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap210:7.1",
      "pali": "Koraṇḍapupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
