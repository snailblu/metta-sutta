{
  "uid": "thag1.35",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.35:1.1",
      "pali": "“Sukhaṁ sukhattho labhate tadācaraṁ,"
    },
    {
      "id": "thag1.35:1.2",
      "pali": "Kittiñca pappoti yasassa vaḍḍhati;"
    },
    {
      "id": "thag1.35:1.3",
      "pali": "Yo ariyamaṭṭhaṅgikamañjasaṁ ujuṁ,"
    },
    {
      "id": "thag1.35:1.4",
      "pali": "Bhāveti maggaṁ amatassa pattiyā”ti."
    },
    {
      "id": "thag1.35:1.5",
      "pali": "… Sāmaññakānitthero …."
    }
  ]
}
