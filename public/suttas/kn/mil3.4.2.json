{
  "uid": "mil3.4.2",
  "title": "2. Nāgasenapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.4.2:1.1",
      "pali": "Thero āha—"
    },
    {
      "id": "mil3.4.2:1.2",
      "pali": "“loṇaṁ, mahārāja, cakkhuviññeyyan”ti."
    },
    {
      "id": "mil3.4.2:1.3",
      "pali": "“Āma, bhante, cakkhuviññeyyan”ti."
    },
    {
      "id": "mil3.4.2:1.4",
      "pali": "“Suṭṭhu kho, mahārāja, jānāhī”ti."
    },
    {
      "id": "mil3.4.2:1.5",
      "pali": "“Kiṁ pana, bhante, jivhāviññeyyan”ti?"
    },
    {
      "id": "mil3.4.2:1.6",
      "pali": "“Āma, mahārāja, jivhāviññeyyan”ti."
    },
    {
      "id": "mil3.4.2:1.7",
      "pali": "“Kiṁ pana, bhante, sabbaṁ loṇaṁ jivhāya vijānātī”ti?"
    },
    {
      "id": "mil3.4.2:1.8",
      "pali": "“Āma, mahārāja, sabbaṁ loṇaṁ jivhāya vijānāti”."
    },
    {
      "id": "mil3.4.2:2.1",
      "pali": "“Yadi, bhante, sabbaṁ loṇaṁ jivhāya vijānāti, kissa pana taṁ sakaṭehi balībaddā āharanti, nanu loṇameva āharitabban”ti?"
    },
    {
      "id": "mil3.4.2:2.2",
      "pali": "“Na sakkā, mahārāja, loṇameva āharituṁ ekatobhāvagatā ete dhammā gocaranānattagatā loṇaṁ garubhāvo cāti."
    },
    {
      "id": "mil3.4.2:2.3",
      "pali": "Sakkā pana, mahārāja, loṇaṁ tulāya tulayitun”ti?"
    },
    {
      "id": "mil3.4.2:2.4",
      "pali": "“Āma, bhante, sakkā”ti."
    },
    {
      "id": "mil3.4.2:2.5",
      "pali": "“Na sakkā, mahārāja, loṇaṁ tulāya tulayituṁ, garubhāvo tulāya tuliyatī”ti."
    },
    {
      "id": "mil3.4.2:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.4.2:4.1",
      "pali": "Nāgasenapañho dutiyo."
    }
  ]
}
