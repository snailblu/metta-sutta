{
  "uid": "thag1.96",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.96:1.1",
      "pali": "“Ekapupphaṁ cajitvāna,"
    },
    {
      "id": "thag1.96:1.2",
      "pali": "asīti vassakoṭiyo;"
    },
    {
      "id": "thag1.96:1.3",
      "pali": "Saggesu paricāretvā,"
    },
    {
      "id": "thag1.96:1.4",
      "pali": "sesakenamhi nibbuto”ti."
    },
    {
      "id": "thag1.96:1.5",
      "pali": "… Khaṇḍasumano thero …."
    }
  ]
}
