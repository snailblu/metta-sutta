{
  "uid": "thag1.101",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.101:1.1",
      "pali": "“Hitvā gihittaṁ anavositatto,"
    },
    {
      "id": "thag1.101:1.2",
      "pali": "Mukhanaṅgalī odariko kusīto;"
    },
    {
      "id": "thag1.101:1.3",
      "pali": "Mahāvarāhova nivāpapuṭṭho,"
    },
    {
      "id": "thag1.101:1.4",
      "pali": "Punappunaṁ gabbhamupeti mando”ti."
    },
    {
      "id": "thag1.101:1.5",
      "pali": "… Belaṭṭhāniko thero …."
    }
  ]
}
