{
  "uid": "ja222",
  "title": "Kāsāvavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja222:1.1",
      "pali": "“Idaṁ tadācariyavaco,"
    },
    {
      "id": "ja222:1.2",
      "pali": "pārāsariyo yadabravi;"
    },
    {
      "id": "ja222:1.3",
      "pali": "Māsu tvaṁ akari pāpaṁ,"
    },
    {
      "id": "ja222:1.4",
      "pali": "yaṁ tvaṁ pacchā kataṁ tape."
    },
    {
      "id": "ja222:2.1",
      "pali": "Yāni karoti puriso,"
    },
    {
      "id": "ja222:2.2",
      "pali": "tāni attani passati;"
    },
    {
      "id": "ja222:2.3",
      "pali": "Kalyāṇakārī kalyāṇaṁ,"
    },
    {
      "id": "ja222:2.4",
      "pali": "pāpakārī ca pāpakaṁ;"
    },
    {
      "id": "ja222:2.5",
      "pali": "Yādisaṁ vapate bījaṁ,"
    },
    {
      "id": "ja222:2.6",
      "pali": "tādisaṁ harate phalan”ti."
    },
    {
      "id": "ja222:3.1",
      "pali": "Cūḷanandiyajātakaṁ dutiyaṁ."
    }
  ]
}
