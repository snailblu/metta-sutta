{
  "uid": "tha-ap40",
  "title": "8 Āyāgadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap40:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap40:1.2",
      "pali": "sikhimhi vadataṁ vare;"
    },
    {
      "id": "tha-ap40:1.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap40:1.4",
      "pali": "avandiṁ thūpamuttamaṁ."
    },
    {
      "id": "tha-ap40:2.1",
      "pali": "Vaḍḍhakīhi kathāpetvā,"
    },
    {
      "id": "tha-ap40:2.2",
      "pali": "mūlaṁ datvānahaṁ tadā;"
    },
    {
      "id": "tha-ap40:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap40:2.4",
      "pali": "āyāgaṁ kārapesahaṁ."
    },
    {
      "id": "tha-ap40:3.1",
      "pali": "Aṭṭha kappāni devesu,"
    },
    {
      "id": "tha-ap40:3.2",
      "pali": "abbokiṇṇaṁ vasiṁ ahaṁ;"
    },
    {
      "id": "tha-ap40:3.3",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap40:3.4",
      "pali": "vokiṇṇaṁ saṁsariṁ ahaṁ."
    },
    {
      "id": "tha-ap40:4.1",
      "pali": "Kāye visaṁ na kamati,"
    },
    {
      "id": "tha-ap40:4.2",
      "pali": "satthāni na ca hanti me;"
    },
    {
      "id": "tha-ap40:4.3",
      "pali": "Udakehaṁ na miyyāmi,"
    },
    {
      "id": "tha-ap40:4.4",
      "pali": "āyāgassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap40:5.1",
      "pali": "Yadicchāmi ahaṁ vassaṁ,"
    },
    {
      "id": "tha-ap40:5.2",
      "pali": "mahāmegho pavassati;"
    },
    {
      "id": "tha-ap40:5.3",
      "pali": "Devāpi me vasaṁ enti,"
    },
    {
      "id": "tha-ap40:5.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap40:6.1",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap40:6.2",
      "pali": "tiṁsakkhattuṁ ahosahaṁ;"
    },
    {
      "id": "tha-ap40:6.3",
      "pali": "Na maṁ kecāvajānanti,"
    },
    {
      "id": "tha-ap40:6.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap40:7.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap40:7.2",
      "pali": "āyāgaṁ yamakārayiṁ;"
    },
    {
      "id": "tha-ap40:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap40:7.4",
      "pali": "āyāgassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap40:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap40:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap40:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap40:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā āyāgadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap40:10.1",
      "pali": "Āyāgadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
