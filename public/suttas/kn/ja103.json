{
  "uid": "ja103",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja103:1.1",
      "pali": "“Yattha verī nivisati,"
    },
    {
      "id": "ja103:1.2",
      "pali": "na vase tattha paṇḍito;"
    },
    {
      "id": "ja103:1.3",
      "pali": "Ekarattaṁ dirattaṁ vā,"
    },
    {
      "id": "ja103:1.4",
      "pali": "dukkhaṁ vasati verisū”ti."
    },
    {
      "id": "ja103:2.1",
      "pali": "Verijātakaṁ tatiyaṁ."
    }
  ]
}
