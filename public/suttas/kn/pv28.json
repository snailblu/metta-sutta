{
  "uid": "pv28",
  "title": "3. Rathakārapetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv28:1.1",
      "pali": "“Veḷuriyathambhaṁ ruciraṁ pabhassaraṁ,"
    },
    {
      "id": "pv28:1.2",
      "pali": "Vimānamāruyha anekacittaṁ;"
    },
    {
      "id": "pv28:1.3",
      "pali": "Tatthacchasi devi mahānubhāve,"
    },
    {
      "id": "pv28:1.4",
      "pali": "Pathaddhani pannaraseva cando."
    },
    {
      "id": "pv28:2.1",
      "pali": "Vaṇṇo ca te kanakassa sannibho,"
    },
    {
      "id": "pv28:2.2",
      "pali": "Uttattarūpo bhusa dassaneyyo;"
    },
    {
      "id": "pv28:2.3",
      "pali": "Pallaṅkaseṭṭhe atule nisinnā,"
    },
    {
      "id": "pv28:2.4",
      "pali": "Ekā tuvaṁ natthi ca tuyha sāmiko."
    },
    {
      "id": "pv28:3.1",
      "pali": "Imā ca te pokkharaṇī samantā,"
    },
    {
      "id": "pv28:3.2",
      "pali": "Pahūtamalyā bahupuṇḍarīkā;"
    },
    {
      "id": "pv28:3.3",
      "pali": "Suvaṇṇacuṇṇehi samantamotthatā,"
    },
    {
      "id": "pv28:3.4",
      "pali": "Na tattha paṅko paṇako ca vijjati."
    },
    {
      "id": "pv28:4.1",
      "pali": "Haṁsā cime dassanīyā manoramā,"
    },
    {
      "id": "pv28:4.2",
      "pali": "Udakasmimanupariyanti sabbadā;"
    },
    {
      "id": "pv28:4.3",
      "pali": "Samayya vaggūpanadanti sabbe,"
    },
    {
      "id": "pv28:4.4",
      "pali": "Bindussarā dundubhīnaṁva ghoso."
    },
    {
      "id": "pv28:5.1",
      "pali": "Daddallamānā yasasā yasassinī,"
    },
    {
      "id": "pv28:5.2",
      "pali": "Nāvāya ca tvaṁ avalamba tiṭṭhasi;"
    },
    {
      "id": "pv28:5.3",
      "pali": "Āḷārapamhe hasite piyaṁvade,"
    },
    {
      "id": "pv28:5.4",
      "pali": "Sabbaṅgakalyāṇi bhusaṁ virocasi."
    },
    {
      "id": "pv28:6.1",
      "pali": "Idaṁ vimānaṁ virajaṁ same ṭhitaṁ,"
    },
    {
      "id": "pv28:6.2",
      "pali": "Uyyānavantaṁ ratinandivaḍḍhanaṁ;"
    },
    {
      "id": "pv28:6.3",
      "pali": "Icchāmahaṁ nāri anomadassane,"
    },
    {
      "id": "pv28:6.4",
      "pali": "Tayā saha nandane idha moditun”ti."
    },
    {
      "id": "pv28:7.1",
      "pali": "“Karohi kammaṁ idha vedanīyaṁ,"
    },
    {
      "id": "pv28:7.2",
      "pali": "Cittañca te idha nihitaṁ bhavatu;"
    },
    {
      "id": "pv28:7.3",
      "pali": "Katvāna kammaṁ idha vedanīyaṁ,"
    },
    {
      "id": "pv28:7.4",
      "pali": "Evaṁ mamaṁ lacchasi kāmakāminin”ti."
    },
    {
      "id": "pv28:8.1",
      "pali": "“Sādhū”ti so tassā paṭissuṇitvā,"
    },
    {
      "id": "pv28:8.2",
      "pali": "Akāsi kammaṁ tahiṁ vedanīyaṁ;"
    },
    {
      "id": "pv28:8.3",
      "pali": "Katvāna kammaṁ tahiṁ vedanīyaṁ,"
    },
    {
      "id": "pv28:8.4",
      "pali": "Upapajji so māṇavo tassā sahabyatanti."
    },
    {
      "id": "pv28:9.1",
      "pali": "Rathakārapetivatthu tatiyaṁ."
    },
    {
      "id": "pv28:9.2",
      "pali": "Bhāṇavāraṁ dutiyaṁ."
    }
  ]
}
