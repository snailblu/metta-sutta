{
  "uid": "ja295",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja295:1.1",
      "pali": "“Usabhasseva te khandho,"
    },
    {
      "id": "ja295:1.2",
      "pali": "sīhasseva vijambhitaṁ;"
    },
    {
      "id": "ja295:1.3",
      "pali": "Migarāja namo tyatthu,"
    },
    {
      "id": "ja295:1.4",
      "pali": "api kiñci labhāmase”."
    },
    {
      "id": "ja295:2.1",
      "pali": "“Kulaputtova jānāti,"
    },
    {
      "id": "ja295:2.2",
      "pali": "kulaputtaṁ pasaṁsituṁ;"
    },
    {
      "id": "ja295:2.3",
      "pali": "Mayūragīvasaṅkāsa,"
    },
    {
      "id": "ja295:2.4",
      "pali": "ito pariyāhi vāyasa”."
    },
    {
      "id": "ja295:3.1",
      "pali": "“Migānaṁ siṅgālo anto,"
    },
    {
      "id": "ja295:3.2",
      "pali": "pakkhīnaṁ pana vāyaso;"
    },
    {
      "id": "ja295:3.3",
      "pali": "Eraṇḍo anto rukkhānaṁ,"
    },
    {
      "id": "ja295:3.4",
      "pali": "tayo antā samāgatā”ti."
    },
    {
      "id": "ja295:4.1",
      "pali": "Antajātakaṁ pañcamaṁ."
    }
  ]
}
