{
  "uid": "ja143",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja143:1.1",
      "pali": "“Lasī ca te nipphalitā,"
    },
    {
      "id": "ja143:1.2",
      "pali": "matthako ca padālito;"
    },
    {
      "id": "ja143:1.3",
      "pali": "Sabbā te phāsukā bhaggā,"
    },
    {
      "id": "ja143:1.4",
      "pali": "ajja kho tvaṁ virocasī”ti."
    },
    {
      "id": "ja143:2.1",
      "pali": "Virocanajātakaṁ tatiyaṁ."
    }
  ]
}
