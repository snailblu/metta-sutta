{
  "uid": "thag4.12",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.12:1.1",
      "pali": "“Pabbajiṁ jīvikatthohaṁ,"
    },
    {
      "id": "thag4.12:1.2",
      "pali": "laddhāna upasampadaṁ;"
    },
    {
      "id": "thag4.12:1.3",
      "pali": "Tato saddhaṁ paṭilabhiṁ,"
    },
    {
      "id": "thag4.12:1.4",
      "pali": "daḷhavīriyo parakkamiṁ."
    },
    {
      "id": "thag4.12:2.1",
      "pali": "Kāmaṁ bhijjatuyaṁ kāyo,"
    },
    {
      "id": "thag4.12:2.2",
      "pali": "maṁsapesī visīyaruṁ;"
    },
    {
      "id": "thag4.12:2.3",
      "pali": "Ubho jaṇṇukasandhīhi,"
    },
    {
      "id": "thag4.12:2.4",
      "pali": "jaṅghāyo papatantu me."
    },
    {
      "id": "thag4.12:3.1",
      "pali": "Nāsissaṁ na pivissāmi,"
    },
    {
      "id": "thag4.12:3.2",
      "pali": "vihārā ca na nikkhame;"
    },
    {
      "id": "thag4.12:3.3",
      "pali": "Napi passaṁ nipātessaṁ,"
    },
    {
      "id": "thag4.12:3.4",
      "pali": "taṇhāsalle anūhate."
    },
    {
      "id": "thag4.12:4.1",
      "pali": "Tassa mevaṁ viharato,"
    },
    {
      "id": "thag4.12:4.2",
      "pali": "passa vīriyaparakkamaṁ;"
    },
    {
      "id": "thag4.12:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag4.12:4.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag4.12:4.5",
      "pali": "… Mudito thero …"
    },
    {
      "id": "thag4.12:4.6",
      "pali": "Catukkanipāto niṭṭhito."
    },
    {
      "id": "thag4.12:5.1",
      "pali": "Nāgasamālo bhagu ca,"
    },
    {
      "id": "thag4.12:5.2",
      "pali": "sabhiyo nandakopi ca;"
    },
    {
      "id": "thag4.12:5.3",
      "pali": "Jambuko senako thero,"
    },
    {
      "id": "thag4.12:5.4",
      "pali": "sambhūto rāhulopi ca."
    },
    {
      "id": "thag4.12:6.1",
      "pali": "Bhavati candano thero,"
    },
    {
      "id": "thag4.12:6.2",
      "pali": "dasete buddhasāvakā;"
    },
    {
      "id": "thag4.12:6.3",
      "pali": "Dhammiko sappako thero,"
    },
    {
      "id": "thag4.12:6.4",
      "pali": "mudito cāpi te tayo;"
    },
    {
      "id": "thag4.12:6.5",
      "pali": "Gāthāyo dve ca paññāsa,"
    },
    {
      "id": "thag4.12:6.6",
      "pali": "therā sabbepi terasāti."
    }
  ]
}
