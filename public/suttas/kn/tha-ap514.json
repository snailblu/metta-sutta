{
  "uid": "tha-ap514",
  "title": "2 Kapitthaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap514:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap514:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap514:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap514:1.4",
      "pali": "Kapitthaṁ adadiṁ phalaṁ."
    },
    {
      "id": "tha-ap514:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap514:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap514:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap514:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap514:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap514:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap514:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap514:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap514:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap514:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap514:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap514:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap514:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap514:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kapitthaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap514:7.1",
      "pali": "Kapitthaphaladāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
