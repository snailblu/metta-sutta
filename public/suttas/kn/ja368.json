{
  "uid": "ja368",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja368:1.1",
      "pali": "“Amittahatthatthagatā,"
    },
    {
      "id": "ja368:1.2",
      "pali": "tacasārasamappitā;"
    },
    {
      "id": "ja368:1.3",
      "pali": "Pasannamukhavaṇṇāttha,"
    },
    {
      "id": "ja368:1.4",
      "pali": "kasmā tumhe na socatha”."
    },
    {
      "id": "ja368:2.1",
      "pali": "“Na socanāya paridevanāya,"
    },
    {
      "id": "ja368:2.2",
      "pali": "Atthova labbho api appakopi;"
    },
    {
      "id": "ja368:2.3",
      "pali": "Socantamenaṁ dukhitaṁ viditvā,"
    },
    {
      "id": "ja368:2.4",
      "pali": "Paccatthikā attamanā bhavanti."
    },
    {
      "id": "ja368:3.1",
      "pali": "Yato ca kho paṇḍito āpadāsu,"
    },
    {
      "id": "ja368:3.2",
      "pali": "Na vedhatī atthavinicchayaññū;"
    },
    {
      "id": "ja368:3.3",
      "pali": "Paccatthikāssa dukhitā bhavanti,"
    },
    {
      "id": "ja368:3.4",
      "pali": "Disvā mukhaṁ avikāraṁ purāṇaṁ."
    },
    {
      "id": "ja368:4.1",
      "pali": "Jappena mantena subhāsitena,"
    },
    {
      "id": "ja368:4.2",
      "pali": "Anuppadānena paveṇiyā vā;"
    },
    {
      "id": "ja368:4.3",
      "pali": "Yathā yathā yattha labhetha atthaṁ,"
    },
    {
      "id": "ja368:4.4",
      "pali": "Tathā tathā tattha parakkameyya."
    },
    {
      "id": "ja368:5.1",
      "pali": "Yato ca jāneyya alabbhaneyyo,"
    },
    {
      "id": "ja368:5.2",
      "pali": "Mayā va aññena vā esa attho;"
    },
    {
      "id": "ja368:5.3",
      "pali": "Asocamāno adhivāsayeyya,"
    },
    {
      "id": "ja368:5.4",
      "pali": "Kammaṁ daḷhaṁ kinti karomi dānī”ti."
    },
    {
      "id": "ja368:6.1",
      "pali": "Tacasārajātakaṁ aṭṭhamaṁ."
    }
  ]
}
