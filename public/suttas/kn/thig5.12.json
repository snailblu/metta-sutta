{
  "uid": "thig5.12",
  "title": "Candātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.12:1.1",
      "pali": "“Duggatāhaṁ pure āsiṁ,"
    },
    {
      "id": "thig5.12:1.2",
      "pali": "vidhavā ca aputtikā;"
    },
    {
      "id": "thig5.12:1.3",
      "pali": "Vinā mittehi ñātīhi,"
    },
    {
      "id": "thig5.12:1.4",
      "pali": "bhattacoḷassa nādhigaṁ."
    },
    {
      "id": "thig5.12:2.1",
      "pali": "Pattaṁ daṇḍañca gaṇhitvā,"
    },
    {
      "id": "thig5.12:2.2",
      "pali": "bhikkhamānā kulā kulaṁ;"
    },
    {
      "id": "thig5.12:2.3",
      "pali": "Sītuṇhena ca ḍayhantī,"
    },
    {
      "id": "thig5.12:2.4",
      "pali": "satta vassāni cārihaṁ."
    },
    {
      "id": "thig5.12:3.1",
      "pali": "Bhikkhuniṁ puna disvāna,"
    },
    {
      "id": "thig5.12:3.2",
      "pali": "annapānassa lābhiniṁ;"
    },
    {
      "id": "thig5.12:3.3",
      "pali": "Upasaṅkamma avocaṁ,"
    },
    {
      "id": "thig5.12:3.4",
      "pali": "‘pabbajjaṁ anagāriyaṁ’."
    },
    {
      "id": "thig5.12:4.1",
      "pali": "Sā ca maṁ anukampāya,"
    },
    {
      "id": "thig5.12:4.2",
      "pali": "pabbājesi paṭācārā;"
    },
    {
      "id": "thig5.12:4.3",
      "pali": "Tato maṁ ovaditvāna,"
    },
    {
      "id": "thig5.12:4.4",
      "pali": "paramatthe niyojayi."
    },
    {
      "id": "thig5.12:5.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig5.12:5.2",
      "pali": "akāsiṁ anusāsaniṁ;"
    },
    {
      "id": "thig5.12:5.3",
      "pali": "Amogho ayyāyovādo,"
    },
    {
      "id": "thig5.12:5.4",
      "pali": "tevijjāmhi anāsavā”ti."
    },
    {
      "id": "thig5.12:6.1",
      "pali": "… Candā therī …."
    },
    {
      "id": "thig5.12:7.1",
      "pali": "Pañcakanipāto niṭṭhito."
    }
  ]
}
