{
  "uid": "thig1.18",
  "title": "Saṅghātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.18:1.1",
      "pali": "“Hitvā ghare pabbajitvā,"
    },
    {
      "id": "thig1.18:1.2",
      "pali": "hitvā puttaṁ pasuṁ piyaṁ;"
    },
    {
      "id": "thig1.18:1.3",
      "pali": "Hitvā rāgañca dosañca,"
    },
    {
      "id": "thig1.18:1.4",
      "pali": "avijjañca virājiya;"
    },
    {
      "id": "thig1.18:1.5",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "thig1.18:1.6",
      "pali": "upasantāmhi nibbutā”ti."
    },
    {
      "id": "thig1.18:2.1",
      "pali": "… Saṅghā therī …."
    },
    {
      "id": "thig1.18:3.1",
      "pali": "Ekakanipāto niṭṭhito."
    }
  ]
}
