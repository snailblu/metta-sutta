{
  "uid": "ja112",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja112:1.1",
      "pali": "“Yena sattubilaṅgā ca,"
    },
    {
      "id": "ja112:1.2",
      "pali": "Diguṇapalāso ca pupphito;"
    },
    {
      "id": "ja112:1.3",
      "pali": "Yena dadāmi tena vadāmi,"
    },
    {
      "id": "ja112:1.4",
      "pali": "Yena na dadāmi na tena vadāmi;"
    },
    {
      "id": "ja112:1.5",
      "pali": "Esa maggo yavamajjhakassa,"
    },
    {
      "id": "ja112:1.6",
      "pali": "Etaṁ channapathaṁ vijānāhī”ti."
    },
    {
      "id": "ja112:2.1",
      "pali": "Amarādevīpañhajātakaṁ dutiyaṁ."
    }
  ]
}
