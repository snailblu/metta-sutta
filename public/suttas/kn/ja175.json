{
  "uid": "ja175",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja175:1.1",
      "pali": "“Sabbesu kira bhūtesu,"
    },
    {
      "id": "ja175:1.2",
      "pali": "santi sīlasamāhitā;"
    },
    {
      "id": "ja175:1.3",
      "pali": "Passa sākhāmigaṁ jammaṁ,"
    },
    {
      "id": "ja175:1.4",
      "pali": "ādiccamupatiṭṭhati”."
    },
    {
      "id": "ja175:2.1",
      "pali": "“Nāssa sīlaṁ vijānātha,"
    },
    {
      "id": "ja175:2.2",
      "pali": "anaññāya pasaṁsatha;"
    },
    {
      "id": "ja175:2.3",
      "pali": "Aggihuttañca uhannaṁ,"
    },
    {
      "id": "ja175:2.4",
      "pali": "dve ca bhinnā kamaṇḍalū”ti."
    },
    {
      "id": "ja175:3.1",
      "pali": "Ādiccupaṭṭhānajātakaṁ pañcamaṁ."
    }
  ]
}
