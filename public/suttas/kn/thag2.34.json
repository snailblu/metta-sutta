{
  "uid": "thag2.34",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.34:1.1",
      "pali": "“Diṭṭhā mayā dhammadharā upāsakā,"
    },
    {
      "id": "thag2.34:1.2",
      "pali": "Kāmā aniccā iti bhāsamānā;"
    },
    {
      "id": "thag2.34:1.3",
      "pali": "Sārattarattā maṇikuṇḍalesu,"
    },
    {
      "id": "thag2.34:1.4",
      "pali": "Puttesu dāresu ca te apekkhā."
    },
    {
      "id": "thag2.34:2.1",
      "pali": "Addhā na jānanti yatodha dhammaṁ,"
    },
    {
      "id": "thag2.34:2.2",
      "pali": "Kāmā aniccā iti cāpi āhu;"
    },
    {
      "id": "thag2.34:2.3",
      "pali": "Rāgañca tesaṁ na balatthi chettuṁ,"
    },
    {
      "id": "thag2.34:2.4",
      "pali": "Tasmā sitā puttadāraṁ dhanañcā”ti."
    },
    {
      "id": "thag2.34:2.5",
      "pali": "… Isidinno thero …."
    }
  ]
}
