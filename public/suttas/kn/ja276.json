{
  "uid": "ja276",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja276:1.1",
      "pali": "“Tava saddhañca sīlañca,"
    },
    {
      "id": "ja276:1.2",
      "pali": "viditvāna janādhipa;"
    },
    {
      "id": "ja276:1.3",
      "pali": "Vaṇṇaṁ añjanavaṇṇena,"
    },
    {
      "id": "ja276:1.4",
      "pali": "kāliṅgasmiṁ nimimhase”."
    },
    {
      "id": "ja276:2.1",
      "pali": "“Annabhaccā cabhaccā ca,"
    },
    {
      "id": "ja276:2.2",
      "pali": "yodha uddissa gacchati;"
    },
    {
      "id": "ja276:2.3",
      "pali": "Sabbe te appaṭikkhippā,"
    },
    {
      "id": "ja276:2.4",
      "pali": "pubbācariyavaco idaṁ."
    },
    {
      "id": "ja276:3.1",
      "pali": "Dadāmi vo brāhmaṇā nāgametaṁ,"
    },
    {
      "id": "ja276:3.2",
      "pali": "Rājārahaṁ rājabhoggaṁ yasassinaṁ;"
    },
    {
      "id": "ja276:3.3",
      "pali": "Alaṅkataṁ hemajālābhichannaṁ,"
    },
    {
      "id": "ja276:3.4",
      "pali": "Sasārathiṁ gacchatha yena kāman”ti."
    },
    {
      "id": "ja276:4.1",
      "pali": "Garudhammajātakaṁ chaṭṭhaṁ."
    }
  ]
}
