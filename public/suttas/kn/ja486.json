{
  "uid": "ja486",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja486:1.1",
      "pali": "“Ukkā cilācā bandhanti dīpe,"
    },
    {
      "id": "ja486:1.2",
      "pali": "Pajā mamaṁ khādituṁ patthayanti;"
    },
    {
      "id": "ja486:1.3",
      "pali": "Mittaṁ sahāyañca vadehi senaka,"
    },
    {
      "id": "ja486:1.4",
      "pali": "Ācikkha ñātibyasanaṁ dijānaṁ”."
    },
    {
      "id": "ja486:2.1",
      "pali": "“Dijo dijānaṁ pavarosi pakkhima,"
    },
    {
      "id": "ja486:2.2",
      "pali": "Ukkusarāja saraṇaṁ taṁ upema;"
    },
    {
      "id": "ja486:2.3",
      "pali": "Pajā mamaṁ khādituṁ patthayanti,"
    },
    {
      "id": "ja486:2.4",
      "pali": "Luddā cilācā bhava me sukhāya”."
    },
    {
      "id": "ja486:3.1",
      "pali": "“Mittaṁ sahāyañca karonti paṇḍitā,"
    },
    {
      "id": "ja486:3.2",
      "pali": "Kāle akāle sukhamesamānā;"
    },
    {
      "id": "ja486:3.3",
      "pali": "Karomi te senaka etamatthaṁ,"
    },
    {
      "id": "ja486:3.4",
      "pali": "Ariyo hi ariyassa karoti kiccaṁ”."
    },
    {
      "id": "ja486:4.1",
      "pali": "“Yaṁ hoti kiccaṁ anukampakena,"
    },
    {
      "id": "ja486:4.2",
      "pali": "Ariyassa ariyena kataṁ tayīdaṁ;"
    },
    {
      "id": "ja486:4.3",
      "pali": "Attānurakkhī bhava mā adayhi,"
    },
    {
      "id": "ja486:4.4",
      "pali": "Lacchāma putte tayi jīvamāne”."
    },
    {
      "id": "ja486:5.1",
      "pali": "“Taveva rakkhāvaraṇaṁ karonto,"
    },
    {
      "id": "ja486:5.2",
      "pali": "Sarīrabhedāpi na santasāmi;"
    },
    {
      "id": "ja486:5.3",
      "pali": "Karonti heke sakhīnaṁ sakhāro,"
    },
    {
      "id": "ja486:5.4",
      "pali": "Pāṇaṁ cajantā satamesa dhammo”."
    },
    {
      "id": "ja486:6.1",
      "pali": "“Sudukkaraṁ kammamakāsi,"
    },
    {
      "id": "ja486:6.2",
      "pali": "aṇḍajāyaṁ vihaṅgamo;"
    },
    {
      "id": "ja486:6.3",
      "pali": "Atthāya kuraro putte,"
    },
    {
      "id": "ja486:6.4",
      "pali": "aḍḍharatte anāgate”."
    },
    {
      "id": "ja486:7.1",
      "pali": "“Cutāpi heke khalitā sakammunā,"
    },
    {
      "id": "ja486:7.2",
      "pali": "Mittānukampāya patiṭṭhahanti;"
    },
    {
      "id": "ja486:7.3",
      "pali": "Puttā mamaṭṭā gatimāgatosmi,"
    },
    {
      "id": "ja486:7.4",
      "pali": "Atthaṁ caretho mama vāricara”."
    },
    {
      "id": "ja486:8.1",
      "pali": "“Dhanena dhaññena ca attanā ca,"
    },
    {
      "id": "ja486:8.2",
      "pali": "Mittaṁ sahāyañca karonti paṇḍitā;"
    },
    {
      "id": "ja486:8.3",
      "pali": "Karomi te senaka etamatthaṁ,"
    },
    {
      "id": "ja486:8.4",
      "pali": "Ariyo hi ariyassa karoti kiccaṁ”."
    },
    {
      "id": "ja486:9.1",
      "pali": "“Appossukko tāta tuvaṁ nisīda,"
    },
    {
      "id": "ja486:9.2",
      "pali": "Putto pitu carati atthacariyaṁ;"
    },
    {
      "id": "ja486:9.3",
      "pali": "Ahaṁ carissāmi tavetamatthaṁ,"
    },
    {
      "id": "ja486:9.4",
      "pali": "Senassa putte paritāyamāno”."
    },
    {
      "id": "ja486:10.1",
      "pali": "“Addhā hi tāta satamesa dhammo,"
    },
    {
      "id": "ja486:10.2",
      "pali": "Putto pitu yaṁ care atthacariyaṁ;"
    },
    {
      "id": "ja486:10.3",
      "pali": "Appeva maṁ disvāna pavaḍḍhakāyaṁ,"
    },
    {
      "id": "ja486:10.4",
      "pali": "Senassa puttā na viheṭhayeyyuṁ”."
    },
    {
      "id": "ja486:11.1",
      "pali": "“Pasū manussā migavīraseṭṭha,"
    },
    {
      "id": "ja486:11.2",
      "pali": "Bhayaṭṭitā seṭṭhamupabbajanti;"
    },
    {
      "id": "ja486:11.3",
      "pali": "Puttā mamaṭṭā gatimāgatosmi,"
    },
    {
      "id": "ja486:11.4",
      "pali": "Tvaṁ nosi rājā bhava me sukhāya”."
    },
    {
      "id": "ja486:12.1",
      "pali": "“Karomi te senaka etamatthaṁ,"
    },
    {
      "id": "ja486:12.2",
      "pali": "Āyāmi te taṁ disataṁ vadhāya;"
    },
    {
      "id": "ja486:12.3",
      "pali": "Kathañhi viññū pahu sampajāno,"
    },
    {
      "id": "ja486:12.4",
      "pali": "Na vāyame attajanassa guttiyā”."
    },
    {
      "id": "ja486:13.1",
      "pali": "“Mittañca kayirātha suhadayañca,"
    },
    {
      "id": "ja486:13.2",
      "pali": "Ayirañca kayirātha sukhāgamāya;"
    },
    {
      "id": "ja486:13.3",
      "pali": "Nivatthakocova sarebhihantvā,"
    },
    {
      "id": "ja486:13.4",
      "pali": "Modāma puttehi samaṅgibhūtā."
    },
    {
      "id": "ja486:14.1",
      "pali": "Sakamittassa kammena,"
    },
    {
      "id": "ja486:14.2",
      "pali": "sahāyassāpalāyino;"
    },
    {
      "id": "ja486:14.3",
      "pali": "Kūjantamupakūjanti,"
    },
    {
      "id": "ja486:14.4",
      "pali": "lomasā hadayaṅgamaṁ."
    },
    {
      "id": "ja486:15.1",
      "pali": "Mittaṁ sahāyaṁ adhigamma paṇḍito,"
    },
    {
      "id": "ja486:15.2",
      "pali": "So bhuñjatī putta pasuṁ dhanaṁ vā;"
    },
    {
      "id": "ja486:15.3",
      "pali": "Ahañca puttā ca patī ca mayhaṁ,"
    },
    {
      "id": "ja486:15.4",
      "pali": "Mittānukampāya samaṅgibhūtā."
    },
    {
      "id": "ja486:16.1",
      "pali": "Rājavatā sūravatā ca attho,"
    },
    {
      "id": "ja486:16.2",
      "pali": "Sampannasakhissa bhavanti hete;"
    },
    {
      "id": "ja486:16.3",
      "pali": "So mittavā yasavā uggatatto,"
    },
    {
      "id": "ja486:16.4",
      "pali": "Asmiṁdhaloke modati kāmakāmī."
    },
    {
      "id": "ja486:17.1",
      "pali": "Karaṇīyāni mittāni,"
    },
    {
      "id": "ja486:17.2",
      "pali": "daliddenāpi senaka;"
    },
    {
      "id": "ja486:17.3",
      "pali": "Passa mittānukampāya,"
    },
    {
      "id": "ja486:17.4",
      "pali": "samaggamhā sañātake."
    },
    {
      "id": "ja486:18.1",
      "pali": "Sūrena balavantena,"
    },
    {
      "id": "ja486:18.2",
      "pali": "yo mitte kurute dijo;"
    },
    {
      "id": "ja486:18.3",
      "pali": "Evaṁ so sukhito hoti,"
    },
    {
      "id": "ja486:18.4",
      "pali": "yathāhaṁ tvañca senakāti”."
    },
    {
      "id": "ja486:19.1",
      "pali": "Mahāukkusajātakaṁ tatiyaṁ."
    }
  ]
}
