{
  "uid": "tha-ap167",
  "title": "5 Kaṇikārachattiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap167:1.1",
      "pali": "“Vessabhū nāma sambuddho,"
    },
    {
      "id": "tha-ap167:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap167:1.3",
      "pali": "Divāvihārāya muni,"
    },
    {
      "id": "tha-ap167:1.4",
      "pali": "ogāhayi mahāvanaṁ."
    },
    {
      "id": "tha-ap167:2.1",
      "pali": "Kaṇikāraṁ ocinitvā,"
    },
    {
      "id": "tha-ap167:2.2",
      "pali": "chattaṁ katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap167:2.3",
      "pali": "Pupphacchadanaṁ katvāna,"
    },
    {
      "id": "tha-ap167:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap167:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap167:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap167:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap167:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap167:4.1",
      "pali": "Ito vīsatikappamhi,"
    },
    {
      "id": "tha-ap167:4.2",
      "pali": "soṇṇābhā aṭṭha khattiyā;"
    },
    {
      "id": "tha-ap167:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap167:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap167:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap167:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap167:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap167:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kaṇikārachattiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap167:7.1",
      "pali": "Kaṇikārachattiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
