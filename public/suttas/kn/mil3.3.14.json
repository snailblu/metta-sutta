{
  "uid": "mil3.3.14",
  "title": "14. Vicāralakkhaṇapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.3.14:1.1",
      "pali": "“Bhante nāgasena, kiṁlakkhaṇo vicāro”ti?"
    },
    {
      "id": "mil3.3.14:1.2",
      "pali": "“Anumajjanalakkhaṇo, mahārāja, vicāro”ti."
    },
    {
      "id": "mil3.3.14:2.1",
      "pali": "“Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.3.14:2.2",
      "pali": "“Yathā, mahārāja, kaṁsathālaṁ ākoṭitaṁ pacchā anuravati anusandahati, yathā, mahārāja, ākoṭanā, evaṁ vitakko daṭṭhabbo."
    },
    {
      "id": "mil3.3.14:2.3",
      "pali": "Yathā anuravanā, evaṁ vicāro daṭṭhabbo”ti."
    },
    {
      "id": "mil3.3.14:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.3.14:4.1",
      "pali": "Vicāralakkhaṇapañho cuddasamo."
    },
    {
      "id": "mil3.3.14:5.1",
      "pali": "Vicāravaggo tatiyo."
    },
    {
      "id": "mil3.3.14:6.1",
      "pali": "Imasmiṁ vagge cuddasa pañhā."
    }
  ]
}
