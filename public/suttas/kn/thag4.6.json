{
  "uid": "thag4.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.6:1.1",
      "pali": "“Svāgataṁ vata me āsi,"
    },
    {
      "id": "thag4.6:1.2",
      "pali": "gayāyaṁ gayaphagguyā;"
    },
    {
      "id": "thag4.6:1.3",
      "pali": "Yaṁ addasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "thag4.6:1.4",
      "pali": "desentaṁ dhammamuttamaṁ."
    },
    {
      "id": "thag4.6:2.1",
      "pali": "Mahappabhaṁ gaṇācariyaṁ,"
    },
    {
      "id": "thag4.6:2.2",
      "pali": "aggapattaṁ vināyakaṁ;"
    },
    {
      "id": "thag4.6:2.3",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "thag4.6:2.4",
      "pali": "jinaṁ atuladassanaṁ."
    },
    {
      "id": "thag4.6:3.1",
      "pali": "Mahānāgaṁ mahāvīraṁ,"
    },
    {
      "id": "thag4.6:3.2",
      "pali": "mahājutimanāsavaṁ;"
    },
    {
      "id": "thag4.6:3.3",
      "pali": "Sabbāsavaparikkhīṇaṁ,"
    },
    {
      "id": "thag4.6:3.4",
      "pali": "satthāramakutobhayaṁ."
    },
    {
      "id": "thag4.6:4.1",
      "pali": "Cirasaṅkiliṭṭhaṁ vata maṁ,"
    },
    {
      "id": "thag4.6:4.2",
      "pali": "diṭṭhisandānabandhitaṁ;"
    },
    {
      "id": "thag4.6:4.3",
      "pali": "Vimocayi so bhagavā,"
    },
    {
      "id": "thag4.6:4.4",
      "pali": "sabbaganthehi senakan”ti."
    },
    {
      "id": "thag4.6:4.5",
      "pali": "… Senako thero …."
    }
  ]
}
