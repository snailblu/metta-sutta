{
  "uid": "vv35",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv35:1.1",
      "pali": "“Phalikarajatahemajālachannaṁ,"
    },
    {
      "id": "vv35:1.2",
      "pali": "Vividhacitratalamaddasaṁ surammaṁ;"
    },
    {
      "id": "vv35:1.3",
      "pali": "Byamhaṁ sunimmitaṁ toraṇūpapannaṁ,"
    },
    {
      "id": "vv35:1.4",
      "pali": "Rucakupakiṇṇamidaṁ subhaṁ vimānaṁ."
    },
    {
      "id": "vv35:2.1",
      "pali": "Bhāti ca dasa disā nabheva suriyo,"
    },
    {
      "id": "vv35:2.2",
      "pali": "Sarade tamonudo sahassaraṁsī;"
    },
    {
      "id": "vv35:2.3",
      "pali": "Tathā tapati midaṁ tava vimānaṁ,"
    },
    {
      "id": "vv35:2.4",
      "pali": "Jalamiva dhūmasikho nise nabhagge."
    },
    {
      "id": "vv35:3.1",
      "pali": "Musatīva nayanaṁ sateratāva,"
    },
    {
      "id": "vv35:3.2",
      "pali": "Ākāse ṭhapitamidaṁ manuññaṁ;"
    },
    {
      "id": "vv35:3.3",
      "pali": "Vīṇāmurajasammatāḷaghuṭṭhaṁ,"
    },
    {
      "id": "vv35:3.4",
      "pali": "Iddhaṁ indapuraṁ yathā tavedaṁ."
    },
    {
      "id": "vv35:4.1",
      "pali": "Padumakumuduppalakuvalayaṁ,"
    },
    {
      "id": "vv35:4.2",
      "pali": "Yodhika bandhukanojakā ca santi;"
    },
    {
      "id": "vv35:4.3",
      "pali": "Sālakusumitapupphitā asokā,"
    },
    {
      "id": "vv35:4.4",
      "pali": "Vividhadumaggasugandhasevitamidaṁ."
    },
    {
      "id": "vv35:5.1",
      "pali": "Saḷalalabujabhujaka saṁyuttā,"
    },
    {
      "id": "vv35:5.2",
      "pali": "Kusakasuphullitalatāvalambinīhi;"
    },
    {
      "id": "vv35:5.3",
      "pali": "Maṇijālasadisā yasassinī,"
    },
    {
      "id": "vv35:5.4",
      "pali": "Rammā pokkharaṇī upaṭṭhitā te."
    },
    {
      "id": "vv35:6.1",
      "pali": "Udakaruhā ca yetthi pupphajātā,"
    },
    {
      "id": "vv35:6.2",
      "pali": "Thalajā ye ca santi rukkhajātā;"
    },
    {
      "id": "vv35:6.3",
      "pali": "Mānusakāmānussakā ca dibbā,"
    },
    {
      "id": "vv35:6.4",
      "pali": "Sabbe tuyhaṁ nivesanamhi jātā."
    },
    {
      "id": "vv35:7.1",
      "pali": "Kissa saṁyamadamassayaṁ vipāko,"
    },
    {
      "id": "vv35:7.2",
      "pali": "Kenāsi kammaphalenidhūpapannā;"
    },
    {
      "id": "vv35:7.3",
      "pali": "Yathā ca te adhigatamidaṁ vimānaṁ,"
    },
    {
      "id": "vv35:7.4",
      "pali": "Tadanupadaṁ avacāsiḷārapamhe”ti."
    },
    {
      "id": "vv35:8.1",
      "pali": "“Yathā ca me adhigatamidaṁ vimānaṁ,"
    },
    {
      "id": "vv35:8.2",
      "pali": "Koñcamayūracakorasaṅghacaritaṁ;"
    },
    {
      "id": "vv35:8.3",
      "pali": "Dibyapilavahaṁsarājaciṇṇaṁ,"
    },
    {
      "id": "vv35:8.4",
      "pali": "Dijakāraṇḍavakokilābhinaditaṁ."
    },
    {
      "id": "vv35:9.1",
      "pali": "Nānāsantānakapuppharukkhavividhā,"
    },
    {
      "id": "vv35:9.2",
      "pali": "Pāṭalijambuasokarukkhavantaṁ;"
    },
    {
      "id": "vv35:9.3",
      "pali": "Yathā ca me adhigatamidaṁ vimānaṁ,"
    },
    {
      "id": "vv35:9.4",
      "pali": "Taṁ te pavedayāmi suṇohi bhante."
    },
    {
      "id": "vv35:10.1",
      "pali": "Magadhavarapuratthimena,"
    },
    {
      "id": "vv35:10.2",
      "pali": "Nāḷakagāmo nāma atthi bhante;"
    },
    {
      "id": "vv35:10.3",
      "pali": "Tattha ahosiṁ pure suṇisā,"
    },
    {
      "id": "vv35:10.4",
      "pali": "Pesavatīti tattha jāniṁsu mamaṁ."
    },
    {
      "id": "vv35:11.1",
      "pali": "Sāhamapacitatthadhammakusalaṁ,"
    },
    {
      "id": "vv35:11.2",
      "pali": "Devamanussapūjitaṁ mahantaṁ;"
    },
    {
      "id": "vv35:11.3",
      "pali": "Upatissaṁ nibbutamappameyyaṁ,"
    },
    {
      "id": "vv35:11.4",
      "pali": "Muditamanā kusumehi abbhukiriṁ."
    },
    {
      "id": "vv35:12.1",
      "pali": "Paramagatigatañca pūjayitvā,"
    },
    {
      "id": "vv35:12.2",
      "pali": "Antimadehadharaṁ isiṁ uḷāraṁ;"
    },
    {
      "id": "vv35:12.3",
      "pali": "Pahāya mānusakaṁ samussayaṁ,"
    },
    {
      "id": "vv35:12.4",
      "pali": "Tidasagatā idha māvasāmi ṭhānan”ti."
    },
    {
      "id": "vv35:13.1",
      "pali": "Pesavatīvimānaṁ sattamaṁ."
    }
  ]
}
