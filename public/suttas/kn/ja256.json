{
  "uid": "ja256",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja256:1.1",
      "pali": "“Jarūdapānaṁ khaṇamānā,"
    },
    {
      "id": "ja256:1.2",
      "pali": "vāṇijā udakatthikā;"
    },
    {
      "id": "ja256:1.3",
      "pali": "Ajjhagamuṁ ayasaṁ lohaṁ,"
    },
    {
      "id": "ja256:1.4",
      "pali": "tipusīsañca vāṇijā;"
    },
    {
      "id": "ja256:1.5",
      "pali": "Rajataṁ jātarūpañca,"
    },
    {
      "id": "ja256:1.6",
      "pali": "muttā veḷuriyā bahū."
    },
    {
      "id": "ja256:2.1",
      "pali": "Te ca tena asantuṭṭhā,"
    },
    {
      "id": "ja256:2.2",
      "pali": "bhiyyo bhiyyo akhāṇisuṁ;"
    },
    {
      "id": "ja256:2.3",
      "pali": "Te tatthāsīviso ghoro,"
    },
    {
      "id": "ja256:2.4",
      "pali": "tejassī tejasā hani."
    },
    {
      "id": "ja256:3.1",
      "pali": "Tasmā khaṇe nātikhaṇe,"
    },
    {
      "id": "ja256:3.2",
      "pali": "Atikhātaṁ hi pāpakaṁ;"
    },
    {
      "id": "ja256:3.3",
      "pali": "Khātena ca dhanaṁ laddhaṁ,"
    },
    {
      "id": "ja256:3.4",
      "pali": "Atikhātena nāsitan”ti."
    },
    {
      "id": "ja256:4.1",
      "pali": "Jarūdapānajātakaṁ chaṭṭhaṁ."
    }
  ]
}
