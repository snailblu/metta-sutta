{
  "uid": "iti9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti9:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti9:2.1",
      "pali": "“Lobhaṁ, bhikkhave, anabhijānaṁ aparijānaṁ tattha cittaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "iti9:2.2",
      "pali": "Lobhañca kho, bhikkhave, abhijānaṁ parijānaṁ tattha cittaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "iti9:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti9:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti9:3.1",
      "pali": "“Yena lobhena luddhāse,"
    },
    {
      "id": "iti9:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti9:3.3",
      "pali": "Taṁ lobhaṁ sammadaññāya,"
    },
    {
      "id": "iti9:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti9:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti9:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti9:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti9:4.2",
      "pali": "Navamaṁ."
    }
  ]
}
