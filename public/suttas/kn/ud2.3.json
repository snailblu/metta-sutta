{
  "uid": "ud2.3",
  "title": "Daṇḍasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud2.3:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud2.3:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud2.3:1.3",
      "pali": "Tena kho pana samayena sambahulā kumārakā antarā ca sāvatthiṁ antarā ca jetavanaṁ ahiṁ daṇḍena hananti."
    },
    {
      "id": "ud2.3:1.4",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisi."
    },
    {
      "id": "ud2.3:1.5",
      "pali": "Addasā kho bhagavā sambahule kumārake antarā ca sāvatthiṁ antarā ca jetavanaṁ ahiṁ daṇḍena hanante."
    },
    {
      "id": "ud2.3:2.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud2.3:3.1",
      "pali": "“Sukhakāmāni bhūtāni,"
    },
    {
      "id": "ud2.3:3.2",
      "pali": "yo daṇḍena vihiṁsati;"
    },
    {
      "id": "ud2.3:3.3",
      "pali": "Attano sukhamesāno,"
    },
    {
      "id": "ud2.3:3.4",
      "pali": "pecca so na labhate sukhaṁ."
    },
    {
      "id": "ud2.3:4.1",
      "pali": "Sukhakāmāni bhūtāni,"
    },
    {
      "id": "ud2.3:4.2",
      "pali": "yo daṇḍena na hiṁsati;"
    },
    {
      "id": "ud2.3:4.3",
      "pali": "Attano sukhamesāno,"
    },
    {
      "id": "ud2.3:4.4",
      "pali": "pecca so labhate sukhan”ti."
    },
    {
      "id": "ud2.3:4.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
