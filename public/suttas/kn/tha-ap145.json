{
  "uid": "tha-ap145",
  "title": "Vedikārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap145:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap145:1.2",
      "pali": "piyadassīnaruttame;"
    },
    {
      "id": "tha-ap145:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap145:1.4",
      "pali": "muttāvedimakāsahaṁ."
    },
    {
      "id": "tha-ap145:2.1",
      "pali": "Maṇīhi parivāretvā,"
    },
    {
      "id": "tha-ap145:2.2",
      "pali": "akāsiṁ vedimuttamaṁ;"
    },
    {
      "id": "tha-ap145:2.3",
      "pali": "Vedikāya mahaṁ katvā,"
    },
    {
      "id": "tha-ap145:2.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap145:3.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap145:3.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap145:3.3",
      "pali": "Maṇī dhārenti ākāse,"
    },
    {
      "id": "tha-ap145:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap145:4.1",
      "pali": "Soḷaseto kappasate,"
    },
    {
      "id": "tha-ap145:4.2",
      "pali": "maṇippabhāsanāmakā;"
    },
    {
      "id": "tha-ap145:4.3",
      "pali": "Chattiṁsāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap145:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap145:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap145:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap145:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap145:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā vedikārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap145:7.1",
      "pali": "Vedikārakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
