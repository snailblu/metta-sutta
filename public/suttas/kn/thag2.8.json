{
  "uid": "thag2.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.8:1.1",
      "pali": "“Khīṇā hi mayhaṁ jāti,"
    },
    {
      "id": "thag2.8:1.2",
      "pali": "vusitaṁ jinasāsanaṁ;"
    },
    {
      "id": "thag2.8:1.3",
      "pali": "Pahīno jālasaṅkhāto,"
    },
    {
      "id": "thag2.8:1.4",
      "pali": "bhavanetti samūhatā."
    },
    {
      "id": "thag2.8:2.1",
      "pali": "Yassatthāya pabbajito,"
    },
    {
      "id": "thag2.8:2.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag2.8:2.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag2.8:2.4",
      "pali": "sabbasaṁyojanakkhayo”ti."
    },
    {
      "id": "thag2.8:2.5",
      "pali": "… Surādho thero …."
    }
  ]
}
