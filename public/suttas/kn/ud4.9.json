{
  "uid": "ud4.9",
  "title": "Upasenasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud4.9:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud4.9:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "ud4.9:1.3",
      "pali": "Atha kho āyasmato upasenassa vaṅgantaputtassa rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "ud4.9:1.4",
      "pali": "“lābhā vata me, suladdhaṁ vata me,"
    },
    {
      "id": "ud4.9:1.5",
      "pali": "satthā ca me bhagavā arahaṁ sammāsambuddho;"
    },
    {
      "id": "ud4.9:1.6",
      "pali": "svākkhāte camhi dhammavinaye agārasmā anagāriyaṁ pabbajito;"
    },
    {
      "id": "ud4.9:1.7",
      "pali": "sabrahmacārino ca me sīlavanto kalyāṇadhammā;"
    },
    {
      "id": "ud4.9:1.8",
      "pali": "sīlesu camhi paripūrakārī;"
    },
    {
      "id": "ud4.9:1.9",
      "pali": "susamāhito camhi ekaggacitto;"
    },
    {
      "id": "ud4.9:1.10",
      "pali": "arahā camhi khīṇāsavo;"
    },
    {
      "id": "ud4.9:1.11",
      "pali": "mahiddhiko camhi mahānubhāvo."
    },
    {
      "id": "ud4.9:1.12",
      "pali": "Bhaddakaṁ me jīvitaṁ, bhaddakaṁ maraṇan”ti."
    },
    {
      "id": "ud4.9:2.1",
      "pali": "Atha kho bhagavā āyasmato upasenassa vaṅgantaputtassa cetasā cetoparivitakkamaññāya tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud4.9:3.1",
      "pali": "“Yaṁ jīvitaṁ na tapati,"
    },
    {
      "id": "ud4.9:3.2",
      "pali": "maraṇante na socati;"
    },
    {
      "id": "ud4.9:3.3",
      "pali": "Sa ve diṭṭhapado dhīro,"
    },
    {
      "id": "ud4.9:3.4",
      "pali": "sokamajjhe na socati."
    },
    {
      "id": "ud4.9:4.1",
      "pali": "Ucchinnabhavataṇhassa,"
    },
    {
      "id": "ud4.9:4.2",
      "pali": "santacittassa bhikkhuno;"
    },
    {
      "id": "ud4.9:4.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "ud4.9:4.4",
      "pali": "natthi tassa punabbhavo”ti."
    },
    {
      "id": "ud4.9:4.5",
      "pali": "Navamaṁ."
    }
  ]
}
