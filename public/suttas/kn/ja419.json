{
  "uid": "ja419",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja419:1.1",
      "pali": "“Idaṁ suvaṇṇakāyūraṁ,"
    },
    {
      "id": "ja419:1.2",
      "pali": "muttā veḷuriyā bahū;"
    },
    {
      "id": "ja419:1.3",
      "pali": "Sabbaṁ harassu bhaddante,"
    },
    {
      "id": "ja419:1.4",
      "pali": "mañca dāsīti sāvaya”."
    },
    {
      "id": "ja419:2.1",
      "pali": "“Oropayassu kalyāṇi,"
    },
    {
      "id": "ja419:2.2",
      "pali": "mā bāḷhaṁ paridevasi;"
    },
    {
      "id": "ja419:2.3",
      "pali": "Na cāhaṁ abhijānāmi,"
    },
    {
      "id": "ja419:2.4",
      "pali": "ahantvā dhanamābhataṁ”."
    },
    {
      "id": "ja419:3.1",
      "pali": "“Yato sarāmi attānaṁ,"
    },
    {
      "id": "ja419:3.2",
      "pali": "yato pattāsmi viññutaṁ;"
    },
    {
      "id": "ja419:3.3",
      "pali": "Na cāhaṁ abhijānāmi,"
    },
    {
      "id": "ja419:3.4",
      "pali": "aññaṁ piyataraṁ tayā."
    },
    {
      "id": "ja419:4.1",
      "pali": "Ehi taṁ upagūhissaṁ,"
    },
    {
      "id": "ja419:4.2",
      "pali": "karissañca padakkhiṇaṁ;"
    },
    {
      "id": "ja419:4.3",
      "pali": "Na hi dāni puna atthi,"
    },
    {
      "id": "ja419:4.4",
      "pali": "mama tuyhañca saṅgamo”."
    },
    {
      "id": "ja419:5.1",
      "pali": "“Na hi sabbesu ṭhānesu,"
    },
    {
      "id": "ja419:5.2",
      "pali": "puriso hoti paṇḍito;"
    },
    {
      "id": "ja419:5.3",
      "pali": "Itthīpi paṇḍitā hoti,"
    },
    {
      "id": "ja419:5.4",
      "pali": "tattha tattha vicakkhaṇā."
    },
    {
      "id": "ja419:6.1",
      "pali": "Na hi sabbesu ṭhānesu,"
    },
    {
      "id": "ja419:6.2",
      "pali": "puriso hoti paṇḍito;"
    },
    {
      "id": "ja419:6.3",
      "pali": "Itthīpi paṇḍitā hoti,"
    },
    {
      "id": "ja419:6.4",
      "pali": "lahuṁ atthaṁ vicintikā."
    },
    {
      "id": "ja419:7.1",
      "pali": "Lahuñca vata khippañca,"
    },
    {
      "id": "ja419:7.2",
      "pali": "nikaṭṭhe samacetayi;"
    },
    {
      "id": "ja419:7.3",
      "pali": "Migaṁ puṇṇāyateneva,"
    },
    {
      "id": "ja419:7.4",
      "pali": "sulasā sattukaṁ vadhi."
    },
    {
      "id": "ja419:8.1",
      "pali": "Yodha uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja419:8.2",
      "pali": "na khippamanubujjhati;"
    },
    {
      "id": "ja419:8.3",
      "pali": "So haññati mandamati,"
    },
    {
      "id": "ja419:8.4",
      "pali": "corova girigabbhare."
    },
    {
      "id": "ja419:9.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja419:9.2",
      "pali": "khippameva nibodhati;"
    },
    {
      "id": "ja419:9.3",
      "pali": "Muccate sattusambādhā,"
    },
    {
      "id": "ja419:9.4",
      "pali": "sulasā sattukāmivā”ti."
    },
    {
      "id": "ja419:10.1",
      "pali": "Sulasājātakaṁ tatiyaṁ."
    }
  ]
}
