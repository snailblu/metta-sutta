{
  "uid": "tha-ap87",
  "title": "Raṁsisaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap87:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap87:1.2",
      "pali": "vāsaṁ kappesahaṁ pure;"
    },
    {
      "id": "tha-ap87:1.3",
      "pali": "Ajinuttaravāsohaṁ,"
    },
    {
      "id": "tha-ap87:1.4",
      "pali": "vasāmi pabbatantare."
    },
    {
      "id": "tha-ap87:2.1",
      "pali": "Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap87:2.2",
      "pali": "Sataraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap87:2.3",
      "pali": "Vanantaragataṁ disvā,"
    },
    {
      "id": "tha-ap87:2.4",
      "pali": "Sālarājaṁva pupphitaṁ."
    },
    {
      "id": "tha-ap87:3.1",
      "pali": "Raṁsyā cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap87:3.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap87:3.3",
      "pali": "Paggayha añjaliṁ vandiṁ,"
    },
    {
      "id": "tha-ap87:3.4",
      "pali": "sirasā ukkuṭī ahaṁ."
    },
    {
      "id": "tha-ap87:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap87:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap87:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap87:4.4",
      "pali": "raṁsisaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap87:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap87:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap87:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap87:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā raṁsisaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap87:7.1",
      "pali": "Raṁsisaññakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
