{
  "uid": "vv33",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv33:1.1",
      "pali": "“Sattatantiṁ sumadhuraṁ,"
    },
    {
      "id": "vv33:1.2",
      "pali": "Rāmaṇeyyaṁ avācayiṁ;"
    },
    {
      "id": "vv33:1.3",
      "pali": "So maṁ raṅgamhi avheti,"
    },
    {
      "id": "vv33:1.4",
      "pali": "‘Saraṇaṁ me hohi kosiyā’”ti."
    },
    {
      "id": "vv33:2.1",
      "pali": "“Ahaṁ te saraṇaṁ homi,"
    },
    {
      "id": "vv33:2.2",
      "pali": "Ahamācariyapūjako;"
    },
    {
      "id": "vv33:2.3",
      "pali": "Na taṁ jayissati sisso,"
    },
    {
      "id": "vv33:2.4",
      "pali": "Sissamācariya jessasī”ti."
    },
    {
      "id": "vv33:3.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv33:3.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv33:3.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv33:3.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv33:4.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv33:4.2",
      "pali": "kena te idha mijjhati;"
    },
    {
      "id": "vv33:4.3",
      "pali": "Uppajjanti ca te bhogā,"
    },
    {
      "id": "vv33:4.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv33:5.1",
      "pali": "Pucchāmi taṁ devi mahānubhāve,"
    },
    {
      "id": "vv33:5.2",
      "pali": "Manussabhūtā kimakāsi puññaṁ;"
    },
    {
      "id": "vv33:5.3",
      "pali": "Kenāsi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv33:5.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:6.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv33:6.2",
      "pali": "moggallānena pucchitā;"
    },
    {
      "id": "vv33:6.3",
      "pali": "Pañhaṁ puṭṭhā viyākāsi,"
    },
    {
      "id": "vv33:6.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv33:7.1",
      "pali": "“Vatthuttamadāyikā nārī,"
    },
    {
      "id": "vv33:7.2",
      "pali": "Pavarā hoti naresu nārīsu;"
    },
    {
      "id": "vv33:7.3",
      "pali": "Evaṁ piyarūpadāyikā manāpaṁ,"
    },
    {
      "id": "vv33:7.4",
      "pali": "Dibbaṁ sā labhate upecca ṭhānaṁ."
    },
    {
      "id": "vv33:8.1",
      "pali": "Tassā me passa vimānaṁ,"
    },
    {
      "id": "vv33:8.2",
      "pali": "Accharā kāmavaṇṇinīhamasmi;"
    },
    {
      "id": "vv33:8.3",
      "pali": "Accharāsahassassāhaṁ,"
    },
    {
      "id": "vv33:8.4",
      "pali": "Pavarā passa puññānaṁ vipākaṁ."
    },
    {
      "id": "vv33:9.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv33:9.2",
      "pali": "tena me idha mijjhati;"
    },
    {
      "id": "vv33:9.3",
      "pali": "Uppajjanti ca me bhogā,"
    },
    {
      "id": "vv33:9.4",
      "pali": "ye keci manaso piyā."
    },
    {
      "id": "vv33:10.1",
      "pali": "Akkhāmi te bhikkhu mahānubhāva,"
    },
    {
      "id": "vv33:10.2",
      "pali": "Manussabhūtā yamakāsi puññaṁ;"
    },
    {
      "id": "vv33:10.3",
      "pali": "Tenamhi evaṁ jalitānubhāvā,"
    },
    {
      "id": "vv33:10.4",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:11.1",
      "pali": "(Anantaraṁ caturavimānaṁ yathā vatthadāyikāvimānaṁ tathā vitthāretabbaṁ.)"
    },
