      "id": "vv33:56.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:56.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:57.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv33:57.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:57.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:58.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv33:58.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:58.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv33:59.1",
      "pali": "“Sassuñcāhaṁ sasurañca,"
    },
    {
      "id": "vv33:59.2",
      "pali": "Caṇḍike kodhane ca pharuse ca;"
    },
    {
      "id": "vv33:59.3",
      "pali": "Anusūyikā upaṭṭhāsiṁ,"
    },
    {
      "id": "vv33:59.4",
      "pali": "Appamattā sakena sīlena."
    },
    {
      "id": "vv33:60.1",
      "pali": "Tassā me passa vimānaṁ,"
    },
    {
      "id": "vv33:60.2",
      "pali": "Accharā kāmavaṇṇinīhamasmi;"
    },
    {
      "id": "vv33:60.3",
      "pali": "Accharāsahassassāhaṁ,"
    },
    {
      "id": "vv33:60.4",
      "pali": "Pavarā passa puññānaṁ vipākaṁ."
    },
    {
      "id": "vv33:61.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv33:61.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:61.3",
      "pali": "vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:62.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv33:62.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:62.3",
      "pali": "vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:63.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv33:63.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:63.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv33:64.1",
      "pali": "“Parakammakarī āsiṁ,"
    },
    {
      "id": "vv33:64.2",
      "pali": "Atthenātanditā dāsī;"
    },
    {
      "id": "vv33:64.3",
      "pali": "Akkodhanānatimāninī,"
    },
    {
      "id": "vv33:64.4",
      "pali": "Saṁvibhāginī sakassa bhāgassa."
    },
    {
      "id": "vv33:65.1",
      "pali": "Tassā me passa vimānaṁ,"
    },
    {
      "id": "vv33:65.2",
      "pali": "Accharā kāmavaṇṇinīhamasmi;"
    },
    {
      "id": "vv33:65.3",
      "pali": "Accharāsahassassāhaṁ,"
    },
    {
      "id": "vv33:65.4",
      "pali": "Pavarā passa puññānaṁ vipākaṁ."
    },
    {
      "id": "vv33:66.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv33:66.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:66.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:67.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv33:67.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:67.3",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv33:68.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv33:68.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:68.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:69.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv33:69.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:69.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv33:70.1",
      "pali": "“Khīrodanaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:70.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:70.3",
      "pali": "Evaṁ karitvā kammaṁ,"
    },
    {
      "id": "vv33:70.4",
      "pali": "Sugatiṁ upapajja modāmi."
    },
    {
      "id": "vv33:71.1",
      "pali": "Tassā me passa vimānaṁ,"
    },
    {
      "id": "vv33:71.2",
      "pali": "Accharā kāmavaṇṇinīhamasmi;"
    },
    {
      "id": "vv33:71.3",
      "pali": "Accharāsahassassāhaṁ,"
    },
    {
      "id": "vv33:71.4",
      "pali": "Pavarā passa puññānaṁ vipākaṁ."
    },
    {
      "id": "vv33:72.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv33:72.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:72.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:73.1",
      "pali": "Anantaraṁ pañcavīsativimānaṁ yathā khīrodanadāyikāvimānaṁ tathā vitthāretabbaṁ."
    },
    {
      "id": "vv33:74.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv33:74.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:74.3",
      "pali": "sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:75.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv33:75.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:75.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv33:76.1",
      "pali": "“Phāṇitaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:76.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:76.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:77.1",
      "pali": "“Ucchukhaṇḍikaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:77.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:77.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:78.1",
      "pali": "“Timbarusakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:78.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:78.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:79.1",
      "pali": "“Kakkārikaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:79.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:79.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:80.1",
      "pali": "“Eḷālukaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:80.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:80.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:81.1",
      "pali": "“Valliphalaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:81.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:81.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:82.1",
      "pali": "“Phārusakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:82.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:82.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:83.1",
      "pali": "“Hatthappatāpakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:83.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:83.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:84.1",
      "pali": "“Sākamuṭṭhiṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:84.2",
      "pali": "Bhikkhuno panthapaṭipannassa;"
    },
    {
      "id": "vv33:84.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:85.1",
      "pali": "“Pupphakamuṭṭhiṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:85.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:85.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:86.1",
      "pali": "“Mūlakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:86.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:86.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:87.1",
      "pali": "“Nimbamuṭṭhiṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:87.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:87.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:88.1",
      "pali": "“Ambakañjikaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:88.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:88.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:89.1",
      "pali": "“Doṇinimmajjaniṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:89.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:89.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:90.1",
      "pali": "“Kāyabandhanaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:90.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:90.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:91.1",
      "pali": "“Aṁsabaddhakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:91.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:91.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:92.1",
      "pali": "“Āyogapaṭṭaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:92.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:92.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:93.1",
      "pali": "“Vidhūpanaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:93.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:93.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:94.1",
      "pali": "“Tālavaṇṭaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:94.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:94.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:95.1",
      "pali": "“Morahatthaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:95.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:95.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:96.1",
      "pali": "“Chattaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:96.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:96.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:97.1",
      "pali": "“Upāhanaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:97.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:97.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:98.1",
      "pali": "“Pūvaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:98.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:98.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:99.1",
      "pali": "“Modakaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:99.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:99.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:100.1",
      "pali": "“Sakkhalikaṁ ahamadāsiṁ,"
    },
    {
      "id": "vv33:100.2",
      "pali": "Bhikkhuno piṇḍāya carantassa;"
    },
    {
      "id": "vv33:100.3",
      "pali": "…pe…"
    },
    {
      "id": "vv33:101.1",
      "pali": "Tassā me passa vimānaṁ,"
    },
    {
      "id": "vv33:101.2",
      "pali": "Accharā kāmavaṇṇinīhamasmi;"
    },
    {
      "id": "vv33:101.3",
      "pali": "Accharāsahassassāhaṁ,"
    },
    {
      "id": "vv33:101.4",
      "pali": "Pavarā passa puññānaṁ vipākaṁ."
    },
    {
      "id": "vv33:102.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv33:102.2",
      "pali": "…pe…"
    },
    {
      "id": "vv33:102.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv33:103.1",
      "pali": "“Svāgataṁ vata me ajja,"
    },
    {
      "id": "vv33:103.2",
      "pali": "suppabhātaṁ suhuṭṭhitaṁ;"
    },
    {
      "id": "vv33:103.3",
      "pali": "Yaṁ addasāmi devatāyo,"
    },
    {
      "id": "vv33:103.4",
      "pali": "accharā kāmavaṇṇiniyo."
    },
    {
      "id": "vv33:104.1",
      "pali": "Imāsāhaṁ dhammaṁ sutvā,"
    },
    {
      "id": "vv33:104.2",
      "pali": "Kāhāmi kusalaṁ bahuṁ;"
    },
    {
      "id": "vv33:104.3",
      "pali": "Dānena samacariyāya,"
    },
    {
      "id": "vv33:104.4",
      "pali": "Saññamena damena ca;"
    },
    {
      "id": "vv33:104.5",
      "pali": "Svāhaṁ tattha gamissāmi,"
    },
    {
      "id": "vv33:104.6",
      "pali": "Yattha gantvā na socare”ti."
    },
    {
      "id": "vv33:105.1",
      "pali": "Guttilavimānaṁ pañcamaṁ."
    }
  ]
}
