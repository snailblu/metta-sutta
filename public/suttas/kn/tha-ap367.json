{
  "uid": "tha-ap367",
  "title": "Aṅkolapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap367:1.1",
      "pali": "“Padumo nāma sambuddho,"
    },
    {
      "id": "tha-ap367:1.2",
      "pali": "cittakūṭe vasī tadā;"
    },
    {
      "id": "tha-ap367:1.3",
      "pali": "Disvāna taṁ ahaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap367:1.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "tha-ap367:2.1",
      "pali": "Aṅkolaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap367:2.2",
      "pali": "ocinitvānahaṁ tadā;"
    },
    {
      "id": "tha-ap367:2.3",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap367:2.4",
      "pali": "pūjayiṁ padumaṁ jinaṁ."
    },
    {
      "id": "tha-ap367:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap367:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap367:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap367:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap367:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap367:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap367:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap367:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā aṅkolapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap367:6.1",
      "pali": "Aṅkolapupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
