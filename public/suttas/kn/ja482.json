{
  "uid": "ja482",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja482:1.1",
      "pali": "“Tassa gāmavaraṁ dammi,"
    },
    {
      "id": "ja482:1.2",
      "pali": "Nāriyo ca alaṅkatā;"
    },
    {
      "id": "ja482:1.3",
      "pali": "Yo metaṁ migamakkhāti,"
    },
    {
      "id": "ja482:1.4",
      "pali": "Migānaṁ migamuttamaṁ”."
    },
    {
      "id": "ja482:2.1",
      "pali": "“Mayhaṁ gāmavaraṁ dehi,"
    },
    {
      "id": "ja482:2.2",
      "pali": "nāriyo ca alaṅkatā;"
    },
    {
      "id": "ja482:2.3",
      "pali": "Ahaṁ te migamakkhissaṁ,"
    },
    {
      "id": "ja482:2.4",
      "pali": "migānaṁ migamuttamaṁ."
    },
    {
      "id": "ja482:3.1",
      "pali": "Etasmiṁ vanasaṇḍasmiṁ,"
    },
    {
      "id": "ja482:3.2",
      "pali": "ambā sālā ca pupphitā;"
    },
    {
      "id": "ja482:3.3",
      "pali": "Indagopakasañchannā,"
    },
    {
      "id": "ja482:3.4",
      "pali": "ettheso tiṭṭhate migo”."
    },
    {
      "id": "ja482:4.1",
      "pali": "“Dhanuṁ advejjhaṁ katvāna,"
    },
    {
      "id": "ja482:4.2",
      "pali": "usuṁ sannayhupāgami;"
    },
    {
      "id": "ja482:4.3",
      "pali": "Migo ca disvā rājānaṁ,"
    },
    {
      "id": "ja482:4.4",
      "pali": "dūrato ajjhabhāsatha."
    },
    {
      "id": "ja482:5.1",
      "pali": "Āgamehi mahārāja,"
    },
    {
      "id": "ja482:5.2",
      "pali": "mā maṁ vijjhi rathesabha;"
    },
    {
      "id": "ja482:5.3",
      "pali": "Ko nu te idamakkhāsi,"
    },
    {
      "id": "ja482:5.4",
      "pali": "ettheso tiṭṭhate migo”."
    },
    {
      "id": "ja482:6.1",
      "pali": "“Esa pāpacaro poso,"
    },
    {
      "id": "ja482:6.2",
      "pali": "samma tiṭṭhati ārakā;"
    },
    {
      "id": "ja482:6.3",
      "pali": "Soyaṁ me idamakkhāsi,"
    },
    {
      "id": "ja482:6.4",
      "pali": "ettheso tiṭṭhate migo”."
    },
    {
      "id": "ja482:7.1",
      "pali": "“Saccaṁ kireva māhaṁsu,"
    },
    {
      "id": "ja482:7.2",
      "pali": "narā ekacciyā idha;"
    },
    {
      "id": "ja482:7.3",
      "pali": "Kaṭṭhaṁ niplavitaṁ seyyo,"
    },
    {
      "id": "ja482:7.4",
      "pali": "na tvevekacciyo naro”."
    },
    {
      "id": "ja482:8.1",
      "pali": "“Kiṁ nu ruru garahasi migānaṁ,"
    },
    {
      "id": "ja482:8.2",
      "pali": "Kiṁ pakkhīnaṁ kiṁ pana mānusānaṁ;"
    },
    {
      "id": "ja482:8.3",
      "pali": "Bhayañhi maṁ vindatinapparūpaṁ,"
    },
    {
      "id": "ja482:8.4",
      "pali": "Sutvāna taṁ mānusiṁ bhāsamānaṁ”."
    },
    {
      "id": "ja482:9.1",
      "pali": "“Yamuddhariṁ vāhane vuyhamānaṁ,"
    },
    {
      "id": "ja482:9.2",
      "pali": "Mahodake salile sīghasote;"
    },
    {
      "id": "ja482:9.3",
      "pali": "Tatonidānaṁ bhayamāgataṁ mama,"
    },
    {
      "id": "ja482:9.4",
      "pali": "Dukkho have rāja asabbhi saṅgamo”."
    },
    {
      "id": "ja482:10.1",
      "pali": "“Sohaṁ catuppattamimaṁ vihaṅgamaṁ,"
    },
    {
      "id": "ja482:10.2",
      "pali": "Tanucchidaṁ hadaye ossajāmi;"
    },
    {
      "id": "ja482:10.3",
      "pali": "Hanāmi taṁ mittadubbhiṁ akiccakāriṁ,"
    },
    {
      "id": "ja482:10.4",
      "pali": "Yo tādisaṁ kammakataṁ na jāne”."
    },
    {
      "id": "ja482:11.1",
      "pali": "“Dhīrassa bālassa have janinda,"
    },
    {
      "id": "ja482:11.2",
      "pali": "Santo vadhaṁ nappasaṁsanti jātu;"
    },
    {
      "id": "ja482:11.3",
      "pali": "Kāmaṁ gharaṁ gacchatu pāpadhammo,"
    },
    {
      "id": "ja482:11.4",
      "pali": "Yañcassa bhaṭṭhaṁ tadetassa dehi;"
    },
    {
      "id": "ja482:11.5",
      "pali": "Ahañca te kāmakaro bhavāmi”."
    },
    {
      "id": "ja482:12.1",
      "pali": "“Addhā rurū aññataro sataṁ so,"
    },
    {
      "id": "ja482:12.2",
      "pali": "Yo dubbhato mānusassa na dubbhi;"
    },
    {
      "id": "ja482:12.3",
      "pali": "Kāmaṁ gharaṁ gacchatu pāpadhammo,"
    },
    {
      "id": "ja482:12.4",
      "pali": "Yañcassa bhaṭṭhaṁ tadetassa dammi;"
    },
    {
      "id": "ja482:12.5",
      "pali": "Ahañca te kāmacāraṁ dadāmi”."
    },
    {
      "id": "ja482:13.1",
      "pali": "“Suvijānaṁ siṅgālānaṁ,"
    },
    {
      "id": "ja482:13.2",
      "pali": "sakuṇānañca vassitaṁ;"
    },
    {
      "id": "ja482:13.3",
      "pali": "Manussavassitaṁ rāja,"
    },
    {
      "id": "ja482:13.4",
      "pali": "dubbijānataraṁ tato."
    },
    {
      "id": "ja482:14.1",
      "pali": "Api ce maññatī poso,"
    },
    {
      "id": "ja482:14.2",
      "pali": "ñāti mitto sakhāti vā;"
    },
    {
      "id": "ja482:14.3",
      "pali": "Yo pubbe sumano hutvā,"
    },
    {
      "id": "ja482:14.4",
      "pali": "pacchā sampajjate diso”."
    },
    {
      "id": "ja482:15.1",
      "pali": "“Samāgatā jānapadā,"
    },
    {
      "id": "ja482:15.2",
      "pali": "negamā ca samāgatā;"
    },
    {
      "id": "ja482:15.3",
      "pali": "Migā sassāni khādanti,"
    },
    {
      "id": "ja482:15.4",
      "pali": "taṁ devo paṭisedhatu”."
    },
    {
      "id": "ja482:16.1",
      "pali": "“Kāmaṁ janapado māsi,"
    },
    {
      "id": "ja482:16.2",
      "pali": "raṭṭhañcāpi vinassatu;"
    },
    {
      "id": "ja482:16.3",
      "pali": "Na tvevāhaṁ ruruṁ dubbhe,"
    },
    {
      "id": "ja482:16.4",
      "pali": "datvā abhayadakkhiṇaṁ."
    },
    {
      "id": "ja482:17.1",
      "pali": "Mā me janapado āsi,"
    },
    {
      "id": "ja482:17.2",
      "pali": "raṭṭhañcāpi vinassatu;"
    },
    {
      "id": "ja482:17.3",
      "pali": "Na tvevāhaṁ migarājassa,"
    },
    {
      "id": "ja482:17.4",
      "pali": "varaṁ datvā musā bhaṇe”ti."
    },
    {
      "id": "ja482:18.1",
      "pali": "Rurumigarājajātakaṁ navamaṁ."
    }
  ]
}
