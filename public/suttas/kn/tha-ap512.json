{
  "uid": "tha-ap512",
  "title": "10 Nāḷikeraphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap512:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap512:1.2",
      "pali": "ārāmiko ahaṁ tadā;"
    },
    {
      "id": "tha-ap512:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap512:1.4",
      "pali": "gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap512:2.1",
      "pali": "Nāḷikeraphalaṁ gayha,"
    },
    {
      "id": "tha-ap512:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap512:2.3",
      "pali": "Ākāse ṭhitako santo,"
    },
    {
      "id": "tha-ap512:2.4",
      "pali": "paṭiggaṇhi mahāyaso."
    },
    {
      "id": "tha-ap512:3.1",
      "pali": "Vittisañjanano mayhaṁ,"
    },
    {
      "id": "tha-ap512:3.2",
      "pali": "diṭṭhadhammasukhāvaho;"
    },
    {
      "id": "tha-ap512:3.3",
      "pali": "Phalaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap512:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap512:4.1",
      "pali": "Adhigacchiṁ tadā pītiṁ,"
    },
    {
      "id": "tha-ap512:4.2",
      "pali": "vipulañca sukhuttamaṁ;"
    },
    {
      "id": "tha-ap512:4.3",
      "pali": "Uppajjateva ratanaṁ,"
    },
    {
      "id": "tha-ap512:4.4",
      "pali": "nibbattassa tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap512:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap512:5.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap512:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap512:5.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap512:6.1",
      "pali": "Dibbacakkhu visuddhaṁ me,"
    },
    {
      "id": "tha-ap512:6.2",
      "pali": "samādhikusalo ahaṁ;"
    },
    {
      "id": "tha-ap512:6.3",
      "pali": "Abhiññāpāramippatto,"
    },
    {
      "id": "tha-ap512:6.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap512:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap512:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap512:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap512:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap512:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap512:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap512:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap512:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap512:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap512:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāḷikeraphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap512:11.1",
      "pali": "Nāḷikeraphaladāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap512:12.1",
      "pali": "Kaṇikāravaggo ekapaññāsamo."
    },
    {
      "id": "tha-ap512:13.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap512:14.1",
      "pali": "Kaṇikārekapattā ca,"
    },
    {
      "id": "tha-ap512:14.2",
      "pali": "kāsumārī tathāvaṭā;"
    },
    {
      "id": "tha-ap512:14.3",
      "pali": "Pādañca mātuluṅgañca,"
    },
    {
      "id": "tha-ap512:14.4",
      "pali": "ajelīmodameva ca."
    },
    {
      "id": "tha-ap512:15.1",
      "pali": "Tālaṁ tathā nāḷikeraṁ,"
    },
    {
      "id": "tha-ap512:15.2",
      "pali": "gāthāyo gaṇitā viha;"
    },
    {
      "id": "tha-ap512:15.3",
      "pali": "Ekaṁ gāthāsataṁ hoti,"
    },
    {
      "id": "tha-ap512:15.4",
      "pali": "ūnādhikavivajjitaṁ."
    }
  ]
}
