{
  "uid": "thag6.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.2:1.1",
      "pali": "“Atihitā vīhi,"
    },
    {
      "id": "thag6.2:1.2",
      "pali": "khalagatā sālī;"
    },
    {
      "id": "thag6.2:1.3",
      "pali": "Na ca labhe piṇḍaṁ,"
    },
    {
      "id": "thag6.2:1.4",
      "pali": "kathamahaṁ kassaṁ”."
    },
    {
      "id": "thag6.2:2.1",
      "pali": "“Buddhamappameyyaṁ anussara pasanno,"
    },
    {
      "id": "thag6.2:2.2",
      "pali": "Pītiyā phuṭasarīro hohisi satatamudaggo."
    },
    {
      "id": "thag6.2:3.1",
      "pali": "Dhammamappameyyaṁ anussara pasanno,"
    },
    {
      "id": "thag6.2:3.2",
      "pali": "Pītiyā phuṭasarīro hohisi satatamudaggo."
    },
    {
      "id": "thag6.2:4.1",
      "pali": "Saṅghamappameyyaṁ anussara pasanno,"
    },
    {
      "id": "thag6.2:4.2",
      "pali": "Pītiyā phuṭasarīro hohisi satatamudaggo”."
    },
    {
      "id": "thag6.2:5.1",
      "pali": "“Abbhokāse viharasi,"
    },
    {
      "id": "thag6.2:5.2",
      "pali": "Sītā hemantikā imā ratyo;"
    },
    {
      "id": "thag6.2:5.3",
      "pali": "Mā sītena pareto vihaññittho,"
    },
    {
      "id": "thag6.2:5.4",
      "pali": "Pavisa tvaṁ vihāraṁ phusitaggaḷaṁ”."
    },
    {
      "id": "thag6.2:6.1",
      "pali": "“Phusissaṁ catasso appamaññāyo,"
    },
    {
      "id": "thag6.2:6.2",
      "pali": "Tāhi ca sukhito viharissaṁ;"
    },
    {
      "id": "thag6.2:6.3",
      "pali": "Nāhaṁ sītena vihaññissaṁ,"
    },
    {
      "id": "thag6.2:6.4",
      "pali": "Aniñjito viharanto”ti."
    },
    {
      "id": "thag6.2:6.5",
      "pali": "… Tekicchakārī thero …."
    }
  ]
}
