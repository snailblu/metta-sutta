{
  "uid": "ja233",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja233:1.1",
      "pali": "“Kāmaṁ yahiṁ icchasi tena gaccha,"
    },
    {
      "id": "ja233:1.2",
      "pali": "Viddhosi mammamhi vikaṇṇakena;"
    },
    {
      "id": "ja233:1.3",
      "pali": "Hatosi bhattena suvāditena,"
    },
    {
      "id": "ja233:1.4",
      "pali": "Lolo ca macche anubandhamāno”."
    },
    {
      "id": "ja233:2.1",
      "pali": "“Evampi lokāmisaṁ opatanto,"
    },
    {
      "id": "ja233:2.2",
      "pali": "Vihaññatī cittavasānuvattī;"
    },
    {
      "id": "ja233:2.3",
      "pali": "So haññatī ñātisakhāna majjhe,"
    },
    {
      "id": "ja233:2.4",
      "pali": "Macchānugo soriva suṁsumāro”ti."
    },
    {
      "id": "ja233:3.1",
      "pali": "Vikaṇṇajātakaṁ tatiyaṁ."
    }
  ]
}
