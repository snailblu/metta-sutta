{
  "uid": "tha-ap201",
  "title": "9 Kiṅkaṇikapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap201:1.1",
      "pali": "“Sumaṅgaloti nāmena,"
    },
    {
      "id": "tha-ap201:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap201:1.3",
      "pali": "Pavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap201:1.4",
      "pali": "nagaraṁ pāvisī jino."
    },
    {
      "id": "tha-ap201:2.1",
      "pali": "Piṇḍacāraṁ caritvāna,"
    },
    {
      "id": "tha-ap201:2.2",
      "pali": "nikkhamma nagarā muni;"
    },
    {
      "id": "tha-ap201:2.3",
      "pali": "Katakiccova sambuddho,"
    },
    {
      "id": "tha-ap201:2.4",
      "pali": "so vasī vanamantare."
    },
    {
      "id": "tha-ap201:3.1",
      "pali": "Kiṅkaṇipupphaṁ paggayha,"
    },
    {
      "id": "tha-ap201:3.2",
      "pali": "buddhassa abhiropayiṁ;"
    },
    {
      "id": "tha-ap201:3.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap201:3.4",
      "pali": "sayambhussa mahesino."
    },
    {
      "id": "tha-ap201:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap201:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap201:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap201:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap201:5.1",
      "pali": "Chaḷāsītimhito kappe,"
    },
    {
      "id": "tha-ap201:5.2",
      "pali": "apilāsisanāmako;"
    },
    {
      "id": "tha-ap201:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap201:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap201:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap201:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap201:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap201:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kiṅkaṇikapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap201:8.1",
      "pali": "Kiṅkaṇikapupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
