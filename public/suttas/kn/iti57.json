{
  "uid": "iti57",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti57:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti57:2.1",
      "pali": "“Tayome, bhikkhave, āsavā."
    },
    {
      "id": "iti57:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti57:2.3",
      "pali": "Kāmāsavo, bhavāsavo, avijjāsavo—"
    },
    {
      "id": "iti57:2.4",
      "pali": "ime kho, bhikkhave, tayo āsavā”ti."
    },
    {
      "id": "iti57:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti57:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti57:3.1",
      "pali": "“Yassa kāmāsavo khīṇo,"
    },
    {
      "id": "iti57:3.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "iti57:3.3",
      "pali": "Bhavāsavo parikkhīṇo,"
    },
    {
      "id": "iti57:3.4",
      "pali": "vippamutto nirūpadhi;"
    },
    {
      "id": "iti57:3.5",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "iti57:3.6",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "iti57:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti57:4.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
