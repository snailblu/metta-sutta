{
  "uid": "thig2.2",
  "title": "Jentātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.2:1.1",
      "pali": "“Ye ime satta bojjhaṅgā,"
    },
    {
      "id": "thig2.2:1.2",
      "pali": "maggā nibbānapattiyā;"
    },
    {
      "id": "thig2.2:1.3",
      "pali": "Bhāvitā te mayā sabbe,"
    },
    {
      "id": "thig2.2:1.4",
      "pali": "yathā buddhena desitā."
    },
    {
      "id": "thig2.2:2.1",
      "pali": "Diṭṭho hi me so bhagavā,"
    },
    {
      "id": "thig2.2:2.2",
      "pali": "antimoyaṁ samussayo;"
    },
    {
      "id": "thig2.2:2.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thig2.2:2.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thig2.2:3.1",
      "pali": "Itthaṁ sudaṁ jentā therī gāthāyo abhāsitthāti."
    }
  ]
}
