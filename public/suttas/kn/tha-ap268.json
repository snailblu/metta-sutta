{
  "uid": "tha-ap268",
  "title": "Macchadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap268:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap268:1.2",
      "pali": "ukkuso āsahaṁ tadā;"
    },
    {
      "id": "tha-ap268:1.3",
      "pali": "Mahantaṁ macchaṁ paggayha,"
    },
    {
      "id": "tha-ap268:1.4",
      "pali": "siddhatthamunino adaṁ."
    },
    {
      "id": "tha-ap268:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap268:2.2",
      "pali": "yaṁ macchamadadiṁ tadā;"
    },
    {
      "id": "tha-ap268:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap268:2.4",
      "pali": "macchadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap268:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap268:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap268:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap268:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā macchadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap268:5.1",
      "pali": "Macchadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
