{
  "uid": "mil3.7.13",
  "title": "13. Samuddaekarasapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.7.13:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.7.13:1.2",
      "pali": "“bhante nāgasena, kena kāraṇena samuddo ekaraso loṇaraso”ti?"
    },
    {
      "id": "mil3.7.13:1.3",
      "pali": "“Cirasaṇṭhitattā kho, mahārāja, udakassa samuddo ekaraso loṇaraso”ti."
    },
    {
      "id": "mil3.7.13:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.7.13:3.1",
      "pali": "Samuddaekarasapañho terasamo."
    }
  ]
}
