{
  "uid": "thag1.115",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.115:1.1",
      "pali": "“Esāvahiyyase pabbatena,"
    },
    {
      "id": "thag1.115:1.2",
      "pali": "Bahukuṭajasallakikena;"
    },
    {
      "id": "thag1.115:1.3",
      "pali": "Nesādakena girinā,"
    },
    {
      "id": "thag1.115:1.4",
      "pali": "Yasassinā paricchadenā”ti."
    },
    {
      "id": "thag1.115:1.5",
      "pali": "… Mahānāmo thero …."
    }
  ]
}
