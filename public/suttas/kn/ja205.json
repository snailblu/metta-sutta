{
  "uid": "ja205",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja205:1.1",
      "pali": "“Sobhati maccho gaṅgeyyo,"
    },
    {
      "id": "ja205:1.2",
      "pali": "atho sobhati yāmuno;"
    },
    {
      "id": "ja205:1.3",
      "pali": "Catuppadoyaṁ puriso,"
    },
    {
      "id": "ja205:1.4",
      "pali": "nigrodhaparimaṇḍalo;"
    },
    {
      "id": "ja205:1.5",
      "pali": "Īsakāyatagīvo ca,"
    },
    {
      "id": "ja205:1.6",
      "pali": "sabbeva atirocati”."
    },
    {
      "id": "ja205:2.1",
      "pali": "“Yaṁ pucchito na taṁ akkhāsi,"
    },
    {
      "id": "ja205:2.2",
      "pali": "Aññaṁ akkhāsi pucchito;"
    },
    {
      "id": "ja205:2.3",
      "pali": "Attappasaṁsako poso,"
    },
    {
      "id": "ja205:2.4",
      "pali": "Nāyaṁ asmāka ruccatī”ti."
    },
    {
      "id": "ja205:3.1",
      "pali": "Gaṅgeyyajātakaṁ pañcamaṁ."
    }
  ]
}
