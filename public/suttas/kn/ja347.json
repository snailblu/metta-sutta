{
  "uid": "ja347",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja347:1.1",
      "pali": "“Sabbāyasaṁ kūṭamatippamāṇaṁ,"
    },
    {
      "id": "ja347:1.2",
      "pali": "Paggayha yo tiṭṭhasi antalikkhe;"
    },
    {
      "id": "ja347:1.3",
      "pali": "Rakkhāya me tvaṁ vihito nusajja,"
    },
    {
      "id": "ja347:1.4",
      "pali": "Udāhu me cetayase vadhāya”."
    },
    {
      "id": "ja347:2.1",
      "pali": "“Dūto ahaṁ rājidha rakkhasānaṁ,"
    },
    {
      "id": "ja347:2.2",
      "pali": "Vadhāya tuyhaṁ pahitohamasmi;"
    },
    {
      "id": "ja347:2.3",
      "pali": "Indo ca taṁ rakkhati devarājā,"
    },
    {
      "id": "ja347:2.4",
      "pali": "Tenuttamaṅgaṁ na te phālayāmi”."
    },
    {
      "id": "ja347:3.1",
      "pali": "“Sace ca maṁ rakkhati devarājā,"
    },
    {
      "id": "ja347:3.2",
      "pali": "Devānamindo maghavā sujampati;"
    },
    {
      "id": "ja347:3.3",
      "pali": "Kāmaṁ pisācā vinadantu sabbe,"
    },
    {
      "id": "ja347:3.4",
      "pali": "Na santase rakkhasiyā pajāya."
    },
    {
      "id": "ja347:4.1",
      "pali": "Kāmaṁ kandantu kumbhaṇḍā,"
    },
    {
      "id": "ja347:4.2",
      "pali": "Sabbe paṁsupisācakā;"
    },
    {
      "id": "ja347:4.3",
      "pali": "Nālaṁ pisācā yuddhāya,"
    },
    {
      "id": "ja347:4.4",
      "pali": "Mahatī sā vibhiṁsikā”ti."
    },
    {
      "id": "ja347:5.1",
      "pali": "Ayakūṭajātakaṁ sattamaṁ."
    }
  ]
}
