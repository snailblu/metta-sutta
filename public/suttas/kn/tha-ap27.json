{
  "uid": "tha-ap27",
  "title": "Annasaṁsāvakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap27:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap27:1.2",
      "pali": "Gacchantaṁ antarāpaṇe;"
    },
    {
      "id": "tha-ap27:1.3",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap27:1.4",
      "pali": "Bāttiṁsavaralakkhaṇaṁ."
    },
    {
      "id": "tha-ap27:2.1",
      "pali": "Siddhatthaṁ lokapajjotaṁ,"
    },
    {
      "id": "tha-ap27:2.2",
      "pali": "appameyyaṁ anopamaṁ;"
    },
    {
      "id": "tha-ap27:2.3",
      "pali": "Alatthaṁ paramaṁ pītiṁ,"
    },
    {
      "id": "tha-ap27:2.4",
      "pali": "disvā dantaṁ jutindharaṁ."
    },
    {
      "id": "tha-ap27:3.1",
      "pali": "Sambuddhaṁ abhināmetvā,"
    },
    {
      "id": "tha-ap27:3.2",
      "pali": "bhojayiṁ taṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap27:3.3",
      "pali": "Mahākāruṇiko loke,"
    },
    {
      "id": "tha-ap27:3.4",
      "pali": "anumodi mamaṁ tadā."
    },
    {
      "id": "tha-ap27:4.1",
      "pali": "Tasmiṁ mahākāruṇike,"
    },
    {
      "id": "tha-ap27:4.2",
      "pali": "paramassāsakārake;"
    },
    {
      "id": "tha-ap27:4.3",
      "pali": "Buddhe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap27:4.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap27:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap27:5.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap27:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap27:5.4",
      "pali": "bhikkhādānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap27:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap27:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap27:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap27:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap27:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā annasaṁsāvako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap27:8.1",
      "pali": "Annasaṁsāvakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
