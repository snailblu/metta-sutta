{
  "uid": "ja299",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja299:1.1",
      "pali": "“Pure tuvaṁ sīlavataṁ sakāse,"
    },
    {
      "id": "ja299:1.2",
      "pali": "Okkantikaṁ kīḷasi assamamhi;"
    },
    {
      "id": "ja299:1.3",
      "pali": "Karohare makkaṭiyāni makkaṭa,"
    },
    {
      "id": "ja299:1.4",
      "pali": "Na taṁ mayaṁ sīlavataṁ ramāma”."
    },
    {
      "id": "ja299:2.1",
      "pali": "“Sutā hi mayhaṁ paramā visuddhi,"
    },
    {
      "id": "ja299:2.2",
      "pali": "Komāraputtassa bahussutassa;"
    },
    {
      "id": "ja299:2.3",
      "pali": "Mā dāni maṁ maññi tuvaṁ yathā pure,"
    },
    {
      "id": "ja299:2.4",
      "pali": "Jhānānuyutto viharāmi āvuso”."
    },
    {
      "id": "ja299:3.1",
      "pali": "“Sacepi selasmi vapeyya bījaṁ,"
    },
    {
      "id": "ja299:3.2",
      "pali": "Devo ca vasse na hi taṁ virūḷhe;"
    },
    {
      "id": "ja299:3.3",
      "pali": "Sutā hi te sā paramā visuddhi,"
    },
    {
      "id": "ja299:3.4",
      "pali": "Ārā tuvaṁ makkaṭa jhānabhūmiyā”ti."
    },
    {
      "id": "ja299:4.1",
      "pali": "Komāraputtajātakaṁ navamaṁ."
    }
  ]
}
