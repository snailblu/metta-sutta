{
  "uid": "pv23",
  "title": "11. Suttapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv23:1.1",
      "pali": "“Ahaṁ pure pabbajitassa bhikkhuno,"
    },
    {
      "id": "pv23:1.2",
      "pali": "Suttaṁ adāsiṁ upasaṅkamma yācitā;"
    },
    {
      "id": "pv23:1.3",
      "pali": "Tassa vipāko vipulaphalūpalabbhati,"
    },
    {
      "id": "pv23:1.4",
      "pali": "Bahukā ca me uppajjare vatthakoṭiyo."
    },
    {
      "id": "pv23:2.1",
      "pali": "Pupphābhikiṇṇaṁ ramitaṁ vimānaṁ,"
    },
    {
      "id": "pv23:2.2",
      "pali": "Anekacittaṁ naranārisevitaṁ;"
    },
    {
      "id": "pv23:2.3",
      "pali": "Sāhaṁ bhuñjāmi ca pārupāmi ca,"
    },
    {
      "id": "pv23:2.4",
      "pali": "Pahūtavittā na ca tāva khīyati."
    },
    {
      "id": "pv23:3.1",
      "pali": "Tasseva kammassa vipākamanvayā,"
    },
    {
      "id": "pv23:3.2",
      "pali": "Sukhañca sātañca idhūpalabbhati;"
    },
    {
      "id": "pv23:3.3",
      "pali": "Sāhaṁ gantvā punadeva mānusaṁ,"
    },
    {
      "id": "pv23:3.4",
      "pali": "Kāhāmi puññāni nayayyaputta man”ti."
    },
    {
      "id": "pv23:4.1",
      "pali": "“Satta tuvaṁ vassasatā idhāgatā,"
    },
    {
      "id": "pv23:4.2",
      "pali": "Jiṇṇā ca vuḍḍhā ca tahiṁ bhavissasi;"
    },
    {
      "id": "pv23:4.3",
      "pali": "Sabbeva te kālakatā ca ñātakā,"
    },
    {
      "id": "pv23:4.4",
      "pali": "Kiṁ tattha gantvāna ito karissasī”ti."
    },
    {
      "id": "pv23:5.1",
      "pali": "“Satteva vassāni idhāgatāya me,"
    },
    {
      "id": "pv23:5.2",
      "pali": "Dibbañca sukhañca samappitāya;"
    },
    {
      "id": "pv23:5.3",
      "pali": "Sāhaṁ gantvāna punadeva mānusaṁ,"
    },
    {
      "id": "pv23:5.4",
      "pali": "Kāhāmi puññāni nayayyaputta man”ti."
    },
    {
      "id": "pv23:6.1",
      "pali": "So taṁ gahetvāna pasayha bāhāyaṁ,"
    },
    {
      "id": "pv23:6.2",
      "pali": "Paccānayitvāna theriṁ sudubbalaṁ;"
    },
    {
      "id": "pv23:6.3",
      "pali": "“Vajjesi aññampi janaṁ idhāgataṁ,"
    },
    {
      "id": "pv23:6.4",
      "pali": "‘Karotha puññāni sukhūpalabbhati’."
    },
    {
      "id": "pv23:7.1",
      "pali": "Diṭṭhā mayā akatena sādhunā,"
    },
    {
      "id": "pv23:7.2",
      "pali": "Petā vihaññanti tatheva manussā;"
    },
    {
      "id": "pv23:7.3",
      "pali": "Kammañca katvā sukhavedanīyaṁ,"
    },
    {
      "id": "pv23:7.4",
      "pali": "Devā manussā ca sukhe ṭhitā pajā”ti."
    },
    {
      "id": "pv23:8.1",
      "pali": "Suttapetavatthu ekādasamaṁ."
    }
  ]
}
