{
  "uid": "ja148",
  "title": "Kakaṇṭakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja148:1.1",
      "pali": "“Nāhaṁ punaṁ na ca punaṁ,"
    },
    {
      "id": "ja148:1.2",
      "pali": "na cāpi apunappunaṁ;"
    },
    {
      "id": "ja148:1.3",
      "pali": "Hatthibondiṁ pavekkhāmi,"
    },
    {
      "id": "ja148:1.4",
      "pali": "tathā hi bhayatajjito”ti."
    },
    {
      "id": "ja148:2.1",
      "pali": "Siṅgālajātakaṁ aṭṭhamaṁ."
    }
  ]
}
