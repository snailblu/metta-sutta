{
  "uid": "iti47",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti47:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti47:2.1",
      "pali": "“Jāgaro cassa, bhikkhave, bhikkhu vihareyya sato sampajāno samāhito pamudito vippasanno ca tattha kālavipassī ca kusalesu dhammesu."
    },
    {
      "id": "iti47:2.2",
      "pali": "Jāgarassa, bhikkhave, bhikkhuno viharato satassa sampajānassa samāhitassa pamuditassa vippasannassa tattha kālavipassino kusalesu dhammesu dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "iti47:2.3",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "iti47:2.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti47:2.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti47:3.1",
      "pali": "“Jāgarantā suṇāthetaṁ,"
    },
    {
      "id": "iti47:3.2",
      "pali": "ye suttā te pabujjhatha;"
    },
    {
      "id": "iti47:3.3",
      "pali": "Suttā jāgaritaṁ seyyo,"
    },
    {
      "id": "iti47:3.4",
      "pali": "natthi jāgarato bhayaṁ."
    },
    {
      "id": "iti47:4.1",
      "pali": "Yo jāgaro ca satimā sampajāno,"
    },
    {
      "id": "iti47:4.2",
      "pali": "Samāhito mudito vippasanno ca;"
    },
    {
      "id": "iti47:4.3",
      "pali": "Kālena so sammā dhammaṁ parivīmaṁsamāno,"
    },
    {
      "id": "iti47:4.4",
      "pali": "Ekodibhūto vihane tamaṁ so."
    },
    {
      "id": "iti47:5.1",
      "pali": "Tasmā have jāgariyaṁ bhajetha,"
    },
    {
      "id": "iti47:5.2",
      "pali": "Ātāpī bhikkhu nipako jhānalābhī;"
    },
    {
      "id": "iti47:5.3",
      "pali": "Saṁyojanaṁ jātijarāya chetvā,"
    },
    {
      "id": "iti47:5.4",
      "pali": "Idheva sambodhimanuttaraṁ phuse”ti."
    },
    {
      "id": "iti47:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti47:6.2",
      "pali": "Dasamaṁ."
    }
  ]
}
