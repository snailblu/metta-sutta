{
  "uid": "ja113",
  "title": "Haṁcivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja113:1.1",
      "pali": "“Saddahāsi siṅgālassa,"
    },
    {
      "id": "ja113:1.2",
      "pali": "surāpītassa brāhmaṇa;"
    },
    {
      "id": "ja113:1.3",
      "pali": "Sippikānaṁ sataṁ natthi,"
    },
    {
      "id": "ja113:1.4",
      "pali": "kuto kaṁsasatā duve”ti."
    },
    {
      "id": "ja113:2.1",
      "pali": "Siṅgālajātakaṁ tatiyaṁ."
    }
  ]
}
