{
  "uid": "tha-ap447",
  "title": "5 Uttalipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap447:1.1",
      "pali": "“Nigrodhe haritobhāse,"
    },
    {
      "id": "tha-ap447:1.2",
      "pali": "saṁviruḷhamhi pādape;"
    },
    {
      "id": "tha-ap447:1.3",
      "pali": "Uttalimālaṁ paggayha,"
    },
    {
      "id": "tha-ap447:1.4",
      "pali": "bodhiyā abhiropayiṁ."
    },
    {
      "id": "tha-ap447:2.1",
      "pali": "Imasmiṁyeva kappamhi,"
    },
    {
      "id": "tha-ap447:2.2",
      "pali": "yaṁ bodhimabhipūjayiṁ;"
    },
    {
      "id": "tha-ap447:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap447:2.4",
      "pali": "bodhipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap447:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap447:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap447:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap447:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap447:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap447:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap447:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap447:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap447:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap447:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā uttalipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap447:7.1",
      "pali": "Uttalipupphiyattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
