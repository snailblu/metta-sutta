{
  "uid": "iti52",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti52:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti52:2.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "iti52:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti52:2.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "iti52:2.4",
      "pali": "imā kho, bhikkhave, tisso vedanā”ti."
    },
    {
      "id": "iti52:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti52:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti52:3.1",
      "pali": "“Samāhito sampajāno,"
    },
    {
      "id": "iti52:3.2",
      "pali": "sato buddhassa sāvako;"
    },
    {
      "id": "iti52:3.3",
      "pali": "Vedanā ca pajānāti,"
    },
    {
      "id": "iti52:3.4",
      "pali": "vedanānañca sambhavaṁ."
    },
    {
      "id": "iti52:4.1",
      "pali": "Yattha cetā nirujjhanti,"
    },
    {
      "id": "iti52:4.2",
      "pali": "maggañca khayagāminaṁ;"
    },
    {
      "id": "iti52:4.3",
      "pali": "Vedanānaṁ khayā bhikkhu,"
    },
    {
      "id": "iti52:4.4",
      "pali": "nicchāto parinibbuto”ti."
    },
    {
      "id": "iti52:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti52:5.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
