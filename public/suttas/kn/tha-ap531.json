{
  "uid": "tha-ap531",
  "title": "Āmaṇḍaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap531:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap531:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap531:1.3",
      "pali": "Vuṭṭhahitvā samādhimhā,"
    },
    {
      "id": "tha-ap531:1.4",
      "pali": "caṅkamī lokanāyako."
    },
    {
      "id": "tha-ap531:2.1",
      "pali": "Khāribhāraṁ gahetvāna,"
    },
    {
      "id": "tha-ap531:2.2",
      "pali": "āharanto phalaṁ tadā;"
    },
    {
      "id": "tha-ap531:2.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap531:2.4",
      "pali": "caṅkamantaṁ mahāmuniṁ."
    },
    {
      "id": "tha-ap531:3.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap531:3.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap531:3.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap531:3.4",
      "pali": "āmaṇḍamadadiṁ phalaṁ."
    },
    {
      "id": "tha-ap531:4.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap531:4.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap531:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap531:4.4",
      "pali": "āmaṇḍassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap531:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap531:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap531:5.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap531:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap531:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap531:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap531:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap531:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap531:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap531:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā āmaṇḍaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap531:9.1",
      "pali": "Āmaṇḍaphaladāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
