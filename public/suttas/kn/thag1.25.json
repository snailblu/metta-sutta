{
  "uid": "thag1.25",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.25:1.1",
      "pali": "“Obhāsajātaṁ phalagaṁ,"
    },
    {
      "id": "thag1.25:1.2",
      "pali": "cittaṁ yassa abhiṇhaso;"
    },
    {
      "id": "thag1.25:1.3",
      "pali": "Tādisaṁ bhikkhumāsajja,"
    },
    {
      "id": "thag1.25:1.4",
      "pali": "kaṇha dukkhaṁ nigacchasī”ti."
    },
    {
      "id": "thag1.25:1.5",
      "pali": "… Nandiyo thero …."
    }
  ]
}
