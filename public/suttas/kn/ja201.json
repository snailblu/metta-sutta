{
  "uid": "ja201",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja201:1.1",
      "pali": "“Na taṁ daḷhaṁ bandhanamāhu dhīrā,"
    },
    {
      "id": "ja201:1.2",
      "pali": "Yadāyasaṁ dārujapabbajañca;"
    },
    {
      "id": "ja201:1.3",
      "pali": "Sārattarattā maṇikuṇḍalesu,"
    },
    {
      "id": "ja201:1.4",
      "pali": "Puttesu dāresu ca yā apekkhā."
    },
    {
      "id": "ja201:2.1",
      "pali": "Etaṁ daḷhaṁ bandhanamāhu dhīrā,"
    },
    {
      "id": "ja201:2.2",
      "pali": "Ohārinaṁ sīthilaṁ duppamuñcaṁ;"
    },
    {
      "id": "ja201:2.3",
      "pali": "Etampi chetvāna vajanti dhīrā,"
    },
    {
      "id": "ja201:2.4",
      "pali": "Anapekkhino kāmasukhaṁ pahāyā”ti."
    },
    {
      "id": "ja201:3.1",
      "pali": "Bandhanāgārajātakaṁ paṭhamaṁ."
    }
  ]
}
