{
  "uid": "thag1.47",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.47:1.1",
      "pali": "“Namo te buddha vīratthu,"
    },
    {
      "id": "thag1.47:1.2",
      "pali": "vippamuttosi sabbadhi;"
    },
    {
      "id": "thag1.47:1.3",
      "pali": "Tuyhāpadāne viharaṁ,"
    },
    {
      "id": "thag1.47:1.4",
      "pali": "viharāmi anāsavo”ti."
    },
    {
      "id": "thag1.47:1.5",
      "pali": "… Ujjayo thero …."
    }
  ]
}
