{
  "uid": "bv11",
  "title": "11. Nāradabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv11:1.1",
      "pali": "“Padumassa aparena,"
    },
    {
      "id": "bv11:1.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "bv11:1.3",
      "pali": "Nārado nāma nāmena,"
    },
    {
      "id": "bv11:1.4",
      "pali": "asamo appaṭipuggalo."
    },
    {
      "id": "bv11:2.1",
      "pali": "So buddho cakkavattissa,"
    },
    {
      "id": "bv11:2.2",
      "pali": "jeṭṭho dayitaoraso;"
    },
    {
      "id": "bv11:2.3",
      "pali": "Āmukkamālābharaṇo,"
    },
    {
      "id": "bv11:2.4",
      "pali": "uyyānaṁ upasaṅkami."
    },
    {
      "id": "bv11:3.1",
      "pali": "Tatthāsi rukkho yasavipulo,"
    },
    {
      "id": "bv11:3.2",
      "pali": "Abhirūpo brahā suci;"
    },
    {
      "id": "bv11:3.3",
      "pali": "Tamajjhapatvā upanisīdi,"
    },
    {
      "id": "bv11:3.4",
      "pali": "Mahāsoṇassa heṭṭhato."
    },
    {
      "id": "bv11:4.1",
      "pali": "Tattha ñāṇavaruppajji,"
    },
    {
      "id": "bv11:4.2",
      "pali": "anantaṁ vajirūpamaṁ;"
    },
    {
      "id": "bv11:4.3",
      "pali": "Tena vicini saṅkhāre,"
    },
    {
      "id": "bv11:4.4",
      "pali": "ukkujjamavakujjakaṁ."
    },
    {
      "id": "bv11:5.1",
      "pali": "Tattha sabbakilesāni,"
    },
    {
      "id": "bv11:5.2",
      "pali": "asesamabhivāhayi;"
    },
    {
      "id": "bv11:5.3",
      "pali": "Pāpuṇī kevalaṁ bodhiṁ,"
    },
    {
      "id": "bv11:5.4",
      "pali": "buddhañāṇe ca cuddasa."
    },
    {
      "id": "bv11:6.1",
      "pali": "Pāpuṇitvāna sambodhiṁ,"
    },
    {
      "id": "bv11:6.2",
      "pali": "dhammacakkaṁ pavattayi;"
    },
    {
      "id": "bv11:6.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv11:6.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv11:7.1",
      "pali": "Mahādoṇaṁ nāgarājaṁ,"
    },
    {
      "id": "bv11:7.2",
      "pali": "vinayanto mahāmuni;"
    },
    {
      "id": "bv11:7.3",
      "pali": "Pāṭiheraṁ tadākāsi,"
    },
    {
      "id": "bv11:7.4",
      "pali": "dassayanto sadevake."
    },
    {
      "id": "bv11:8.1",
      "pali": "Tadā devamanussānaṁ,"
    },
    {
      "id": "bv11:8.2",
      "pali": "tamhi dhammappakāsane;"
    },
    {
      "id": "bv11:8.3",
      "pali": "Navutikoṭisahassāni,"
    },
    {
      "id": "bv11:8.4",
      "pali": "tariṁsu sabbasaṁsayaṁ."
    },
    {
      "id": "bv11:9.1",
      "pali": "Yamhi kāle mahāvīro,"
    },
    {
      "id": "bv11:9.2",
      "pali": "ovadī sakamatrajaṁ;"
    },
    {
      "id": "bv11:9.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv11:9.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv11:10.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv11:10.2",
      "pali": "nāradassa mahesino;"
    },
    {
      "id": "bv11:10.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv11:10.4",
      "pali": "paṭhamo āsi samāgamo."
    },
    {
      "id": "bv11:11.1",
      "pali": "Yadā buddho buddhaguṇaṁ,"
    },
    {
      "id": "bv11:11.2",
      "pali": "sanidānaṁ pakāsayi;"
    },
    {
      "id": "bv11:11.3",
      "pali": "Navutikoṭisahassāni,"
    },
    {
      "id": "bv11:11.4",
      "pali": "samiṁsu vimalā tadā."
    },
    {
      "id": "bv11:12.1",
      "pali": "Yadā verocano nāgo,"
    },
    {
      "id": "bv11:12.2",
      "pali": "dānaṁ dadāti satthuno;"
    },
    {
      "id": "bv11:12.3",
      "pali": "Tadā samiṁsu jinaputtā,"
    },
    {
      "id": "bv11:12.4",
      "pali": "asītisatasahassiyo."
    },
    {
      "id": "bv11:13.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv11:13.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "bv11:13.3",
      "pali": "Antalikkhacaro āsiṁ,"
    },
    {
      "id": "bv11:13.4",
      "pali": "pañcābhiññāsu pāragū."
    },
    {
      "id": "bv11:14.1",
      "pali": "Tadāpāhaṁ asamasamaṁ,"
    },
    {
      "id": "bv11:14.2",
      "pali": "sasaṅghaṁ saparijjanaṁ;"
    },
    {
      "id": "bv11:14.3",
      "pali": "Annapānena tappetvā,"
    },
    {
      "id": "bv11:14.4",
      "pali": "candanenābhipūjayiṁ."
    },
    {
      "id": "bv11:15.1",
      "pali": "Sopi maṁ tadā byākāsi,"
    },
    {
      "id": "bv11:15.2",
      "pali": "nārado lokanāyako;"
    },
    {
      "id": "bv11:15.3",
      "pali": "‘Aparimeyyito kappe,"
    },
    {
      "id": "bv11:15.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv11:16.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv11:16.2",
      "pali": "…pe…"
    },
    {
      "id": "bv11:16.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv11:17.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv11:17.2",
      "pali": "bhiyyo hāsetva mānasaṁ;"
    },
    {
      "id": "bv11:17.3",
      "pali": "Adhiṭṭhahiṁ vataṁ uggaṁ,"
    },
    {
      "id": "bv11:17.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv11:18.1",
      "pali": "Nagaraṁ dhaññavatī nāma,"
    },
    {
      "id": "bv11:18.2",
      "pali": "sudevo nāma khattiyo;"
    },
    {
      "id": "bv11:18.3",
      "pali": "Anomā nāma janikā,"
    },
    {
      "id": "bv11:18.4",
      "pali": "nāradassa mahesino."
    },
    {
      "id": "bv11:19.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv11:19.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv11:19.3",
      "pali": "Jito vijitābhirāmo,"
    },
    {
      "id": "bv11:19.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv11:20.1",
      "pali": "Ticattārīsasahassāni,"
    },
    {
      "id": "bv11:20.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv11:20.3",
      "pali": "Vijitasenā nāma nārī,"
    },
    {
      "id": "bv11:20.4",
      "pali": "nanduttaro nāma atrajo."
    },
    {
      "id": "bv11:21.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv11:21.2",
      "pali": "Padasā gamanena nikkhami;"
    },
    {
      "id": "bv11:21.3",
      "pali": "Sattāhaṁ padhānacāraṁ,"
    },
    {
      "id": "bv11:21.4",
      "pali": "Acarī purisuttamo."
    },
    {
      "id": "bv11:22.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv11:22.2",
      "pali": "nārado lokanāyako;"
    },
    {
      "id": "bv11:22.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv11:22.4",
      "pali": "dhanañcuyyānamuttame."
    },
    {
      "id": "bv11:23.1",
      "pali": "Bhaddasālo jitamitto,"
    },
    {
      "id": "bv11:23.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv11:23.3",
      "pali": "Vāseṭṭho nāmupaṭṭhāko,"
    },
    {
      "id": "bv11:23.4",
      "pali": "nāradassa mahesino."
    },
    {
      "id": "bv11:24.1",
      "pali": "Uttarā phaggunī ceva,"
    },
    {
      "id": "bv11:24.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv11:24.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv11:24.4",
      "pali": "mahāsoṇoti vuccati."
    },
    {
      "id": "bv11:25.1",
      "pali": "Uggarindo vasabho ca,"
    },
    {
      "id": "bv11:25.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv11:25.3",
      "pali": "Indāvarī ca vaṇḍī ca,"
    },
    {
      "id": "bv11:25.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv11:26.1",
      "pali": "Aṭṭhāsītiratanāni,"
    },
    {
      "id": "bv11:26.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv11:26.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "bv11:26.4",
      "pali": "dasasahassī virocati."
    },
    {
      "id": "bv11:27.1",
      "pali": "Tassa byāmappabhā kāyā,"
    },
    {
      "id": "bv11:27.2",
      "pali": "niddhāvati disodisaṁ;"
    },
    {
      "id": "bv11:27.3",
      "pali": "Nirantaraṁ divārattiṁ,"
    },
    {
      "id": "bv11:27.4",
      "pali": "yojanaṁ pharate sadā."
    },
    {
      "id": "bv11:28.1",
      "pali": "Na keci tena samayena,"
    },
    {
      "id": "bv11:28.2",
      "pali": "samantā yojane janā;"
    },
    {
      "id": "bv11:28.3",
      "pali": "Ukkāpadīpe ujjālenti,"
    },
    {
      "id": "bv11:28.4",
      "pali": "buddharaṁsīhi otthaṭā."
    },
    {
      "id": "bv11:29.1",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv11:29.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv11:29.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv11:29.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv11:30.1",
      "pali": "Yathā uḷūhi gaganaṁ,"
    },
    {
      "id": "bv11:30.2",
      "pali": "vicittaṁ upasobhati;"
    },
    {
      "id": "bv11:30.3",
      "pali": "Tatheva sāsanaṁ tassa,"
    },
    {
      "id": "bv11:30.4",
      "pali": "arahantehi sobhati."
    },
    {
      "id": "bv11:31.1",
      "pali": "Saṁsārasotaṁ taraṇāya,"
    },
    {
      "id": "bv11:31.2",
      "pali": "sesake paṭipannake;"
    },
    {
      "id": "bv11:31.3",
      "pali": "Dhammasetuṁ daḷhaṁ katvā,"
    },
    {
      "id": "bv11:31.4",
      "pali": "nibbuto so narāsabho."
    },
    {
      "id": "bv11:32.1",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv11:32.2",
      "pali": "Tepi khīṇāsavā atulatejā;"
    },
    {
      "id": "bv11:32.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv11:32.4",
      "pali": "Nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv11:33.1",
      "pali": "Nārado jinavasabho,"
    },
    {
      "id": "bv11:33.2",
      "pali": "Nibbuto sudassane pure;"
    },
    {
      "id": "bv11:33.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv11:33.4",
      "pali": "Catuyojanamuggato”ti."
    },
    {
      "id": "bv11:34.1",
      "pali": "Nāradassa bhagavato vaṁso navamo."
    }
  ]
}
