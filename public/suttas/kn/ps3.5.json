{
  "uid": "ps3.5",
  "title": "3.5. Cariyākathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps3.5:1.1",
      "pali": "<b>Cariyā</b>ti, aṭṭha cariyāyo—"
    },
    {
      "id": "ps3.5:1.2",
      "pali": "iriyāpathacariyā, āyatanacariyā, saticariyā, samādhicariyā, ñāṇacariyā, maggacariyā, patticariyā, lokatthacariyāti."
    },
    {
      "id": "ps3.5:2.1",
      "pali": "<b>Iriyāpathacariyā</b>ti catūsu iriyāpathesu."
    },
    {
      "id": "ps3.5:2.2",
      "pali": "<b>Āyatanacariyā</b>ti chasu ajjhattikabāhiresu āyatanesu."
    },
    {
      "id": "ps3.5:2.3",
      "pali": "<b>Saticariyā</b>ti catūsu satipaṭṭhānesu."
    },
    {
      "id": "ps3.5:2.4",
      "pali": "<b>Samādhicariyā</b>ti catūsu jhānesu."
    },
    {
      "id": "ps3.5:2.5",
      "pali": "<b>Ñāṇacariyā</b>ti catūsu ariyasaccesu."
    },
    {
      "id": "ps3.5:2.6",
      "pali": "<b>Maggacariyā</b>ti catūsu ariyamaggesu."
    },
    {
      "id": "ps3.5:2.7",
      "pali": "<b>Patticariyā</b>ti catūsu sāmaññaphalesu."
    },
    {
      "id": "ps3.5:2.8",
      "pali": "<b>Lokatthacariyā</b>ti tathāgatesu arahantesu sammāsambuddhesu padese paccekabuddhesu padese sāvakesu."
    },
    {
      "id": "ps3.5:3.1",
      "pali": "Iriyāpathacariyā ca paṇidhisampannānaṁ."
    },
    {
      "id": "ps3.5:3.2",
      "pali": "Āyatanacariyā ca indriyesu guttadvārānaṁ."
    },
    {
      "id": "ps3.5:3.3",
      "pali": "Saticariyā ca appamādavihārīnaṁ."
    },
    {
      "id": "ps3.5:3.4",
      "pali": "Samādhicariyā ca adhicittamanuyuttānaṁ."
    },
    {
      "id": "ps3.5:3.5",
      "pali": "Ñāṇacariyā ca buddhisampannānaṁ."
    },
    {
      "id": "ps3.5:3.6",
      "pali": "Maggacariyā ca sammāpaṭipannānaṁ."
    },
    {
      "id": "ps3.5:3.7",
      "pali": "Patticariyā ca adhigataphalānaṁ."
    },
    {
      "id": "ps3.5:3.8",
      "pali": "Lokatthacariyā ca tathāgatānaṁ arahantānaṁ sammāsambuddhānaṁ padese paccekabuddhānaṁ padese sāvakānaṁ."
    },
    {
      "id": "ps3.5:3.9",
      "pali": "Imā aṭṭha cariyāyo."
    },
    {
      "id": "ps3.5:4.1",
      "pali": "Aparāpi aṭṭha cariyāyo."
    },
    {
      "id": "ps3.5:4.2",
      "pali": "Adhimuccanto saddhāya carati, paggaṇhanto vīriyena carati, upaṭṭhāpento satiyā carati, avikkhepaṁ karonto samādhinā carati, pajānanto paññāya carati, vijānanto viññāṇacariyāya carati, evaṁ paṭipannassa kusalā dhammā āyāpentīti āyatanacariyāya carati, evaṁ paṭipanno visesamadhigacchatīti visesacariyāya carati."
    },
    {
      "id": "ps3.5:4.3",
      "pali": "Imā aṭṭha cariyāyo."
    },
    {
      "id": "ps3.5:5.1",
      "pali": "Aparāpi aṭṭha cariyāyo."
    },
    {
      "id": "ps3.5:5.2",
      "pali": "Dassanacariyā ca sammādiṭṭhiyā, abhiniropanacariyā ca sammāsaṅkappassa, pariggahacariyā ca sammāvācāya, samuṭṭhānacariyā ca sammākammantassa, vodānacariyā ca sammāājīvassa, paggahacariyā ca sammāvāyāmassa, upaṭṭhānacariyā ca sammāsatiyā, avikkhepacariyā ca sammāsamādhissa."
    },
    {
      "id": "ps3.5:5.3",
      "pali": "Imā aṭṭha cariyāyoti."
    },
    {
      "id": "ps3.5:5.4",
      "pali": "Cariyākathā niṭṭhitā."
    }
  ]
}
