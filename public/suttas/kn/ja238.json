{
  "uid": "ja238",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja238:1.1",
      "pali": "“Iṅgha ekapadaṁ tāta,"
    },
    {
      "id": "ja238:1.2",
      "pali": "anekatthapadassitaṁ;"
    },
    {
      "id": "ja238:1.3",
      "pali": "Kiñci saṅgāhikaṁ brūsi,"
    },
    {
      "id": "ja238:1.4",
      "pali": "yenatthe sādhayemase”."
    },
    {
      "id": "ja238:2.1",
      "pali": "“Dakkheyyekapadaṁ tāta,"
    },
    {
      "id": "ja238:2.2",
      "pali": "anekatthapadassitaṁ;"
    },
    {
      "id": "ja238:2.3",
      "pali": "Tañca sīlena saññuttaṁ,"
    },
    {
      "id": "ja238:2.4",
      "pali": "khantiyā upapāditaṁ;"
    },
    {
      "id": "ja238:2.5",
      "pali": "Alaṁ mitte sukhāpetuṁ,"
    },
    {
      "id": "ja238:2.6",
      "pali": "amittānaṁ dukhāya cā”ti."
    },
    {
      "id": "ja238:3.1",
      "pali": "Ekapadajātakaṁ aṭṭhamaṁ."
    }
  ]
}
