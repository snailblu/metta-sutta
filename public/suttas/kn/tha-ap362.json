{
  "uid": "tha-ap362",
  "title": "Piṇḍapātikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap362:1.1",
      "pali": "“Tisso nāmāsi sambuddho,"
    },
    {
      "id": "tha-ap362:1.2",
      "pali": "vihāsi vipine tadā;"
    },
    {
      "id": "tha-ap362:1.3",
      "pali": "Tusitā hi idhāgantvā,"
    },
    {
      "id": "tha-ap362:1.4",
      "pali": "piṇḍapātaṁ adāsahaṁ."
    },
    {
      "id": "tha-ap362:2.1",
      "pali": "Sambuddhamabhivādetvā,"
    },
    {
      "id": "tha-ap362:2.2",
      "pali": "tissaṁ nāma mahāyasaṁ;"
    },
    {
      "id": "tha-ap362:2.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap362:2.4",
      "pali": "tusitaṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap362:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap362:3.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap362:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap362:3.4",
      "pali": "piṇḍapātassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap362:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap362:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap362:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap362:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā piṇḍapātiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap362:6.1",
      "pali": "Piṇḍapātikattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap362:7.1",
      "pali": "Saddasaññakavaggo chattiṁsatimo."
    },
    {
      "id": "tha-ap362:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap362:9.1",
      "pali": "Saddasaññī yavasiko,"
    },
    {
      "id": "tha-ap362:9.2",
      "pali": "kiṁsukoraṇḍapupphiyo;"
    },
    {
      "id": "tha-ap362:9.3",
      "pali": "Ālambano ambayāgu,"
    },
    {
      "id": "tha-ap362:9.4",
      "pali": "supuṭī mañcadāyako;"
    },
    {
      "id": "tha-ap362:9.5",
      "pali": "Saraṇaṁ piṇḍapāto ca,"
    },
    {
      "id": "tha-ap362:9.6",
      "pali": "gāthā tālīsameva ca."
    }
  ]
}
