{
  "uid": "thag1.61",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.61:1.1",
      "pali": "“Passati passo passantaṁ,"
    },
    {
      "id": "thag1.61:1.2",
      "pali": "apassantañca passati;"
    },
    {
      "id": "thag1.61:1.3",
      "pali": "Apassanto apassantaṁ,"
    },
    {
      "id": "thag1.61:1.4",
      "pali": "passantañca na passatī”ti."
    },
    {
      "id": "thag1.61:1.5",
      "pali": "… Vappo thero …."
    }
  ]
}
