{
  "uid": "ja391",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja391:1.1",
      "pali": "“Dubbaṇṇarūpaṁ tuvamariyavaṇṇī,"
    },
    {
      "id": "ja391:1.2",
      "pali": "Purakkhatvā pañjaliko namassasi;"
    },
    {
      "id": "ja391:1.3",
      "pali": "Seyyo nu te so udavā sarikkho,"
    },
    {
      "id": "ja391:1.4",
      "pali": "Nāmaṁ parassattano cāpi brūhi”."
    },
    {
      "id": "ja391:2.1",
      "pali": "“Na nāmagottaṁ gaṇhanti rāja,"
    },
    {
      "id": "ja391:2.2",
      "pali": "Sammaggatānujjugatāna devā;"
    },
    {
      "id": "ja391:2.3",
      "pali": "Ahañca te nāmadheyyaṁ vadāmi,"
    },
    {
      "id": "ja391:2.4",
      "pali": "Sakkohamasmī tidasānamindo”."
    },
    {
      "id": "ja391:3.1",
      "pali": "“Yo disvā bhikkhuṁ caraṇūpapannaṁ,"
    },
    {
      "id": "ja391:3.2",
      "pali": "Purakkhatvā pañjaliko namassati;"
    },
    {
      "id": "ja391:3.3",
      "pali": "Pucchāmi taṁ devarājetamatthaṁ,"
    },
    {
      "id": "ja391:3.4",
      "pali": "Ito cuto kiṁ labhate sukhaṁ so”."
    },
    {
      "id": "ja391:4.1",
      "pali": "“Yo disvā bhikkhuṁ caraṇūpapannaṁ,"
    },
    {
      "id": "ja391:4.2",
      "pali": "Purakkhatvā pañjaliko namassati;"
    },
    {
      "id": "ja391:4.3",
      "pali": "Diṭṭheva dhamme labhate pasaṁsaṁ,"
    },
    {
      "id": "ja391:4.4",
      "pali": "Saggañca so yāti sarīrabhedā”."
    },
    {
      "id": "ja391:5.1",
      "pali": "“Lakkhī vata me udapādi ajja,"
    },
    {
      "id": "ja391:5.2",
      "pali": "Yaṁ vāsavaṁ bhūtapatiddasāma;"
    },
    {
      "id": "ja391:5.3",
      "pali": "Bhikkhuñca disvāna tuvañca sakka,"
    },
    {
      "id": "ja391:5.4",
      "pali": "Kāhāmi puññāni anappakāni”."
    },
    {
      "id": "ja391:6.1",
      "pali": "“Addhā have sevitabbā sapaññā,"
    },
    {
      "id": "ja391:6.2",
      "pali": "Bahussutā ye bahuṭhānacintino;"
    },
    {
      "id": "ja391:6.3",
      "pali": "Bhikkhuñca disvāna mamañca rāja,"
    },
    {
      "id": "ja391:6.4",
      "pali": "Karohi puññāni anappakāni”."
    },
    {
      "id": "ja391:7.1",
      "pali": "“Akkodhano niccapasannacitto,"
    },
    {
      "id": "ja391:7.2",
      "pali": "Sabbātithīyācayogo bhavitvā;"
    },
    {
      "id": "ja391:7.3",
      "pali": "Nihacca mānaṁ abhivādayissaṁ,"
    },
    {
      "id": "ja391:7.4",
      "pali": "Sutvāna devinda subhāsitānī”ti."
    },
    {
      "id": "ja391:8.1",
      "pali": "Vijjādharajātakaṁ chaṭṭhaṁ."
    }
  ]
}
