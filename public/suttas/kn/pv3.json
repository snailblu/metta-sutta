{
  "uid": "pv3",
  "title": "3. Pūtimukhapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv3:1.1",
      "pali": "“Dibbaṁ subhaṁ dhāresi vaṇṇadhātuṁ,"
    },
    {
      "id": "pv3:1.2",
      "pali": "Vehāyasaṁ tiṭṭhasi antalikkhe;"
    },
    {
      "id": "pv3:1.3",
      "pali": "Mukhañca te kimayo pūtigandhaṁ,"
    },
    {
      "id": "pv3:1.4",
      "pali": "Khādanti kiṁ kammamakāsi pubbe”."
    },
    {
      "id": "pv3:2.1",
      "pali": "“Samaṇo ahaṁ pāpotiduṭṭhavāco,"
    },
    {
      "id": "pv3:2.2",
      "pali": "Tapassirūpo mukhasā asaññato;"
    },
    {
      "id": "pv3:2.3",
      "pali": "Laddhā ca me tapasā vaṇṇadhātu,"
    },
    {
      "id": "pv3:2.4",
      "pali": "Mukhañca me pesuṇiyena pūti."
    },
    {
      "id": "pv3:3.1",
      "pali": "Tayidaṁ tayā nārada sāmaṁ diṭṭhaṁ,"
    },
    {
      "id": "pv3:3.2",
      "pali": "Anukampakā ye kusalā vadeyyuṁ;"
    },
    {
      "id": "pv3:3.3",
      "pali": "‘Mā pesuṇaṁ mā ca musā abhāṇi,"
    },
    {
      "id": "pv3:3.4",
      "pali": "Yakkho tuvaṁ hohisi kāmakāmī’”ti."
    },
    {
      "id": "pv3:4.1",
      "pali": "Pūtimukhapetavatthu tatiyaṁ."
    }
  ]
}
