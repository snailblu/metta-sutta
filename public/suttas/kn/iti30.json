{
  "uid": "iti30",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti30:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti30:2.1",
      "pali": "“Dveme, bhikkhave, dhammā tapanīyā."
    },
    {
      "id": "iti30:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "iti30:2.3",
      "pali": "Idha, bhikkhave, ekacco akatakalyāṇo hoti, akatakusalo, akatabhīruttāṇo, katapāpo, kataluddo, katakibbiso."
    },
    {
      "id": "iti30:2.4",
      "pali": "So ‘akataṁ me kalyāṇan’tipi tappati, ‘kataṁ me pāpan’tipi tappati."
    },
    {
      "id": "iti30:2.5",
      "pali": "Ime kho, bhikkhave, dve dhammā tapanīyā”ti."
    },
    {
      "id": "iti30:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti30:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti30:3.1",
      "pali": "“Kāyaduccaritaṁ katvā,"
    },
    {
      "id": "iti30:3.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "iti30:3.3",
      "pali": "Manoduccaritaṁ katvā,"
    },
    {
      "id": "iti30:3.4",
      "pali": "yañcaññaṁ dosasañhitaṁ."
    },
    {
      "id": "iti30:4.1",
      "pali": "Akatvā kusalaṁ kammaṁ,"
    },
    {
      "id": "iti30:4.2",
      "pali": "katvānākusalaṁ bahuṁ;"
    },
    {
      "id": "iti30:4.3",
      "pali": "Kāyassa bhedā duppañño,"
    },
    {
      "id": "iti30:4.4",
      "pali": "nirayaṁ sopapajjatī”ti."
    },
    {
      "id": "iti30:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti30:5.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
