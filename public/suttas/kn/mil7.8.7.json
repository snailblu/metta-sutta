    {
      "id": "mil7.8.7:3.41",
      "pali": "evaṁ kho, mahārāja, yoginā yogāvacarena imasmiṁ kāye upāsitabbaṁ."
    },
    {
      "id": "mil7.8.7:3.42",
      "pali": "Idaṁ, mahārāja, issāsassa tatiyaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.8.7:4.1",
      "pali": "Puna caparaṁ, mahārāja, issāso sāyaṁ pātaṁ upāsati;"
    },
    {
      "id": "mil7.8.7:4.2",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena sāyaṁ pātaṁ ārammaṇe upāsitabbaṁ."
    },
    {
      "id": "mil7.8.7:4.3",
      "pali": "Idaṁ, mahārāja, issāsassa catutthaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.8.7:4.4",
      "pali": "Bhāsitampetaṁ, mahārāja, therena sāriputtena dhammasenāpatinā—"
    },
    {
      "id": "mil7.8.7:5.1",
      "pali": "‘Yathā issāsako nāma,"
    },
    {
      "id": "mil7.8.7:5.2",
      "pali": "sāyaṁ pātaṁ upāsati;"
    },
    {
      "id": "mil7.8.7:5.3",
      "pali": "Upāsanaṁ ariñcanto,"
    },
    {
      "id": "mil7.8.7:5.4",
      "pali": "labhate bhattavetanaṁ."
    },
    {
      "id": "mil7.8.7:6.1",
      "pali": "Tatheva buddhaputtopi,"
    },
    {
      "id": "mil7.8.7:6.2",
      "pali": "Karoti kāyupāsanaṁ;"
    },
    {
      "id": "mil7.8.7:6.3",
      "pali": "Kāyupāsanaṁ ariñcanto,"
    },
    {
      "id": "mil7.8.7:6.4",
      "pali": "Arahattamadhigacchatī’”ti."
    },
    {
      "id": "mil7.8.7:7.1",
      "pali": "Issāsaṅgapañho sattamo."
    },
    {
      "id": "mil7.8.7:8.1",
      "pali": "Kumbhavaggo sattamo."
    },
    {
      "id": "mil7.8.7:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "mil7.8.7:10.1",
      "pali": "Kumbho ca kāḷāyaso ca,"
    },
    {
      "id": "mil7.8.7:10.2",
      "pali": "chattaṁ khettañca agado;"
    },
    {
      "id": "mil7.8.7:10.3",
      "pali": "Bhojanena ca issāso,"
    },
    {
      "id": "mil7.8.7:10.4",
      "pali": "vuttaṁ dāni vidūhīti."
    },
    {
      "id": "mil7.8.7:11.1",
      "pali": "Opammakathāpañho niṭṭhito."
    }
  ]
}
