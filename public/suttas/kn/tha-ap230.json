{
  "uid": "tha-ap230",
  "title": "Miñjavaṭaṁsakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap230:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap230:1.2",
      "pali": "sikhimhi vadataṁ vare;"
    },
    {
      "id": "tha-ap230:1.3",
      "pali": "Vaṭaṁsakehi ākiṇṇaṁ,"
    },
    {
      "id": "tha-ap230:1.4",
      "pali": "bodhipūjaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap230:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap230:2.2",
      "pali": "yaṁ pūjamakariṁ tadā;"
    },
    {
      "id": "tha-ap230:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap230:2.4",
      "pali": "bodhipūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap230:3.1",
      "pali": "Ito chabbīsatikappe,"
    },
    {
      "id": "tha-ap230:3.2",
      "pali": "ahuṁ meghabbhanāmako;"
    },
    {
      "id": "tha-ap230:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap230:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap230:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap230:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap230:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap230:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā miñjavaṭaṁsakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap230:6.1",
      "pali": "Miñjavaṭaṁsakiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
