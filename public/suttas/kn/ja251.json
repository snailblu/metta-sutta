{
  "uid": "ja251",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja251:1.1",
      "pali": "“Saṅkapparāgadhotena,"
    },
    {
      "id": "ja251:1.2",
      "pali": "vitakkanisitena ca;"
    },
    {
      "id": "ja251:1.3",
      "pali": "Nālaṅkatena bhadrena,"
    },
    {
      "id": "ja251:1.4",
      "pali": "usukārākatena ca."
    },
    {
      "id": "ja251:2.1",
      "pali": "Na kaṇṇāyatamuttena,"
    },
    {
      "id": "ja251:2.2",
      "pali": "nāpi morūpasevinā;"
    },
    {
      "id": "ja251:2.3",
      "pali": "Tenamhi hadaye viddho,"
    },
    {
      "id": "ja251:2.4",
      "pali": "sabbaṅgaparidāhinā."
    },
    {
      "id": "ja251:3.1",
      "pali": "Āvedhañca na passāmi,"
    },
    {
      "id": "ja251:3.2",
      "pali": "Yato ruhiramassave;"
    },
    {
      "id": "ja251:3.3",
      "pali": "Yāva ayoniso cittaṁ,"
    },
    {
      "id": "ja251:3.4",
      "pali": "Sayaṁ me dukkhamābhatan”ti."
    },
    {
      "id": "ja251:4.1",
      "pali": "Saṅkapparāgajātakaṁ paṭhamaṁ."
    }
  ]
}
