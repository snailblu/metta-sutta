{
  "uid": "tha-ap424",
  "title": "Ekadussadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap424:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap424:1.2",
      "pali": "ahosiṁ tiṇahārako;"
    },
    {
      "id": "tha-ap424:1.3",
      "pali": "Tiṇahārena jīvāmi,"
    },
    {
      "id": "tha-ap424:1.4",
      "pali": "tena posemi dārake."
    },
    {
      "id": "tha-ap424:2.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap424:2.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap424:2.3",
      "pali": "Tamandhakāraṁ nāsetvā,"
    },
    {
      "id": "tha-ap424:2.4",
      "pali": "uppajji lokanāyako."
    },
    {
      "id": "tha-ap424:3.1",
      "pali": "Sake ghare nisīditvā,"
    },
    {
      "id": "tha-ap424:3.2",
      "pali": "evaṁ cintesi tāvade;"
    },
    {
      "id": "tha-ap424:3.3",
      "pali": "‘Buddho loke samuppanno,"
    },
    {
      "id": "tha-ap424:3.4",
      "pali": "deyyadhammo na vijjati."
    },
    {
      "id": "tha-ap424:4.1",
      "pali": "Idaṁ me sāṭakaṁ ekaṁ,"
    },
    {
      "id": "tha-ap424:4.2",
      "pali": "natthi me koci dāyako;"
    },
    {
      "id": "tha-ap424:4.3",
      "pali": "Dukkho nirayasamphasso,"
    },
    {
      "id": "tha-ap424:4.4",
      "pali": "ropayissāmi dakkhiṇaṁ’."
    },
    {
      "id": "tha-ap424:5.1",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "tha-ap424:5.2",
      "pali": "sakaṁ cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap424:5.3",
      "pali": "Ekaṁ dussaṁ gahetvāna,"
    },
    {
      "id": "tha-ap424:5.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap424:6.1",
      "pali": "Ekaṁ dussaṁ daditvāna,"
    },
    {
      "id": "tha-ap424:6.2",
      "pali": "ukkuṭṭhiṁ sampavattayiṁ;"
    },
    {
      "id": "tha-ap424:6.3",
      "pali": "‘Yadi buddho tuvaṁ vīra,"
    },
    {
      "id": "tha-ap424:6.4",
      "pali": "tārehi maṁ mahāmuni’."
    },
    {
      "id": "tha-ap424:7.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap424:7.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap424:7.3",
      "pali": "Mama dānaṁ pakittento,"
    },
    {
      "id": "tha-ap424:7.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap424:8.1",
      "pali": "‘Iminā ekadussena,"
    },
    {
      "id": "tha-ap424:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap424:8.3",
      "pali": "Kappasatasahassāni,"
    },
    {
      "id": "tha-ap424:8.4",
      "pali": "vinipātaṁ na gacchasi."
    },
    {
      "id": "tha-ap424:9.1",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap424:9.2",
      "pali": "devarajjaṁ karissasi;"
    },
    {
      "id": "tha-ap424:9.3",
      "pali": "Tettiṁsakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap424:9.4",
      "pali": "cakkavattī bhavissasi."
    },
    {
      "id": "tha-ap424:10.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap424:10.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap424:10.3",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap424:10.4",
      "pali": "saṁsaranto tuvaṁ bhave."
    },
    {
      "id": "tha-ap424:11.1",
      "pali": "Rūpavā guṇasampanno,"
    },
    {
      "id": "tha-ap424:11.2",
      "pali": "anavakkantadehavā;"
    },
    {
      "id": "tha-ap424:11.3",
      "pali": "Akkhobhaṁ amitaṁ dussaṁ,"
    },
    {
      "id": "tha-ap424:11.4",
      "pali": "labhissasi yadicchakaṁ’."
    },
    {
      "id": "tha-ap424:12.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap424:12.2",
      "pali": "jalajuttamanāmako;"
    },
    {
      "id": "tha-ap424:12.3",
      "pali": "Nabhaṁ abbhuggamī vīro,"
    },
    {
      "id": "tha-ap424:12.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap424:13.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap424:13.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap424:13.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap424:13.4",
      "pali": "ekadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap424:14.1",
      "pali": "Paduddhāre paduddhāre,"
    },
    {
      "id": "tha-ap424:14.2",
      "pali": "dussaṁ nibbattate mamaṁ;"
    },
    {
      "id": "tha-ap424:14.3",
      "pali": "Heṭṭhā dussamhi tiṭṭhāmi,"
    },
    {
      "id": "tha-ap424:14.4",
      "pali": "uparicchadanaṁ mama."
    },
    {
      "id": "tha-ap424:15.1",
      "pali": "Cakkavāḷaṁ upādāya,"
    },
    {
      "id": "tha-ap424:15.2",
      "pali": "sakānanaṁ sapabbataṁ;"
    },
    {
      "id": "tha-ap424:15.3",
      "pali": "Icchamāno cahaṁ ajja,"
    },
    {
      "id": "tha-ap424:15.4",
      "pali": "dussehacchādayeyya taṁ."
    },
    {
      "id": "tha-ap424:16.1",
      "pali": "Teneva ekadussena,"
    },
    {
      "id": "tha-ap424:16.2",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "tha-ap424:16.3",
      "pali": "Suvaṇṇavaṇṇo hutvāna,"
    },
    {
      "id": "tha-ap424:16.4",
      "pali": "saṁsarāmi bhavābhave."
    },
    {
      "id": "tha-ap424:17.1",
      "pali": "Vipākaṁ ekadussassa,"
    },
    {
      "id": "tha-ap424:17.2",
      "pali": "nājjhagaṁ katthacikkhayaṁ;"
    },
    {
      "id": "tha-ap424:17.3",
      "pali": "Ayaṁ me antimā jāti,"
    },
    {
      "id": "tha-ap424:17.4",
      "pali": "vipaccati idhāpi me."
    },
    {
      "id": "tha-ap424:18.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap424:18.2",
      "pali": "yaṁ dussamadadiṁ tadā;"
    },
    {
      "id": "tha-ap424:18.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap424:18.4",
      "pali": "ekadussassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap424:19.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap424:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap424:19.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap424:20.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap424:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap424:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap424:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap424:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap424:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap424:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekadussadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap424:23.1",
      "pali": "Ekadussadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
