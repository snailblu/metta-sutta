{
  "uid": "thag1.84",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.84:1.1",
      "pali": "“Sabbarattiṁ supitvāna,"
    },
    {
      "id": "thag1.84:1.2",
      "pali": "divā saṅgaṇike rato;"
    },
    {
      "id": "thag1.84:1.3",
      "pali": "Kudāssu nāma dummedho,"
    },
    {
      "id": "thag1.84:1.4",
      "pali": "dukkhassantaṁ karissatī”ti."
    },
    {
      "id": "thag1.84:1.5",
      "pali": "… Nīto thero …."
    }
  ]
}
