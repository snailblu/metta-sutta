{
  "uid": "ja339",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja339:1.1",
      "pali": "“Adassanena morassa,"
    },
    {
      "id": "ja339:1.2",
      "pali": "sikhino mañjubhāṇino;"
    },
    {
      "id": "ja339:1.3",
      "pali": "Kākaṁ tattha apūjesuṁ,"
    },
    {
      "id": "ja339:1.4",
      "pali": "maṁsena ca phalena ca."
    },
    {
      "id": "ja339:2.1",
      "pali": "Yadā ca sarasampanno,"
    },
    {
      "id": "ja339:2.2",
      "pali": "moro bāverumāgamā;"
    },
    {
      "id": "ja339:2.3",
      "pali": "Atha lābho ca sakkāro,"
    },
    {
      "id": "ja339:2.4",
      "pali": "vāyasassa ahāyatha."
    },
    {
      "id": "ja339:3.1",
      "pali": "Yāva nuppajjatī buddho,"
    },
    {
      "id": "ja339:3.2",
      "pali": "dhammarājā pabhaṅkaro;"
    },
    {
      "id": "ja339:3.3",
      "pali": "Tāva aññe apūjesuṁ,"
    },
    {
      "id": "ja339:3.4",
      "pali": "puthū samaṇabrāhmaṇe."
    },
    {
      "id": "ja339:4.1",
      "pali": "Yadā ca sarasampanno,"
    },
    {
      "id": "ja339:4.2",
      "pali": "buddho dhammaṁ adesayi;"
    },
    {
      "id": "ja339:4.3",
      "pali": "Atha lābho ca sakkāro,"
    },
    {
      "id": "ja339:4.4",
      "pali": "titthiyānaṁ ahāyathā”ti."
    },
    {
      "id": "ja339:5.1",
      "pali": "Bāverujātakaṁ navamaṁ."
    }
  ]
}
