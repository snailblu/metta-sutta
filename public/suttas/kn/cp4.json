{
  "uid": "cp4",
  "title": "Dānapāramī 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp4:1.1",
      "pali": "“Kusāvatimhi nagare,"
    },
    {
      "id": "cp4:1.2",
      "pali": "yadā āsiṁ mahīpati;"
    },
    {
      "id": "cp4:1.3",
      "pali": "Mahāsudassano nāma,"
    },
    {
      "id": "cp4:1.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "cp4:2.1",
      "pali": "Tatthāhaṁ divase tikkhattuṁ,"
    },
    {
      "id": "cp4:2.2",
      "pali": "ghosāpemi tahiṁ tahiṁ;"
    },
    {
      "id": "cp4:2.3",
      "pali": "‘Ko kiṁ icchati pattheti,"
    },
    {
      "id": "cp4:2.4",
      "pali": "kassa kiṁ dīyatū dhanaṁ."
    },
    {
      "id": "cp4:3.1",
      "pali": "Ko chātako ko tasito,"
    },
    {
      "id": "cp4:3.2",
      "pali": "ko mālaṁ ko vilepanaṁ;"
    },
    {
      "id": "cp4:3.3",
      "pali": "Nānārattāni vatthāni,"
    },
    {
      "id": "cp4:3.4",
      "pali": "ko naggo paridahissati."
    },
    {
      "id": "cp4:4.1",
      "pali": "Ko pathe chattamādeti,"
    },
    {
      "id": "cp4:4.2",
      "pali": "kopāhanā mudū subhā’;"
    },
    {
      "id": "cp4:4.3",
      "pali": "Iti sāyañca pāto ca,"
    },
    {
      "id": "cp4:4.4",
      "pali": "ghosāpemi tahiṁ tahiṁ."
    },
    {
      "id": "cp4:5.1",
      "pali": "Na taṁ dasasu ṭhānesu,"
    },
    {
      "id": "cp4:5.2",
      "pali": "napi ṭhānasatesu vā;"
    },
    {
      "id": "cp4:5.3",
      "pali": "Anekasataṭhānesu,"
    },
    {
      "id": "cp4:5.4",
      "pali": "paṭiyattaṁ yācake dhanaṁ."
    },
    {
      "id": "cp4:6.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "cp4:6.2",
      "pali": "yadi eti vanibbako;"
    },
    {
      "id": "cp4:6.3",
      "pali": "Laddhā yadicchakaṁ bhogaṁ,"
    },
    {
      "id": "cp4:6.4",
      "pali": "pūrahatthova gacchati."
    },
    {
      "id": "cp4:7.1",
      "pali": "Evarūpaṁ mahādānaṁ,"
    },
    {
      "id": "cp4:7.2",
      "pali": "Adāsiṁ yāvajīvikaṁ;"
    },
    {
      "id": "cp4:7.3",
      "pali": "Napāhaṁ dessaṁ dhanaṁ dammi,"
    },
    {
      "id": "cp4:7.4",
      "pali": "Napi natthi nicayo mayi."
    },
    {
      "id": "cp4:8.1",
      "pali": "Yathāpi āturo nāma,"
    },
    {
      "id": "cp4:8.2",
      "pali": "rogato parimuttiyā;"
    },
    {
      "id": "cp4:8.3",
      "pali": "Dhanena vejjaṁ tappetvā,"
    },
    {
      "id": "cp4:8.4",
      "pali": "rogato parimuccati."
    },
    {
      "id": "cp4:9.1",
      "pali": "Tathevāhaṁ jānamāno,"
    },
    {
      "id": "cp4:9.2",
      "pali": "paripūretumasesato;"
    },
    {
      "id": "cp4:9.3",
      "pali": "Ūnamanaṁ pūrayituṁ,"
    },
    {
      "id": "cp4:9.4",
      "pali": "demi dānaṁ vanibbake;"
    },
    {
      "id": "cp4:9.5",
      "pali": "Nirālayo apaccāso,"
    },
    {
      "id": "cp4:9.6",
      "pali": "sambodhimanupattiyā”ti."
    },
    {
      "id": "cp4:10.1",
      "pali": "Mahāsudassanacariyaṁ catutthaṁ."
    }
  ]
}
