{
  "uid": "ja338",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja338:1.1",
      "pali": "“Viditaṁ thusaṁ undurānaṁ,"
    },
    {
      "id": "ja338:1.2",
      "pali": "Viditaṁ pana taṇḍulaṁ;"
    },
    {
      "id": "ja338:1.3",
      "pali": "Thusaṁ thusaṁ vivajjetvā,"
    },
    {
      "id": "ja338:1.4",
      "pali": "Taṇḍulaṁ pana khādare."
    },
    {
      "id": "ja338:2.1",
      "pali": "Yā mantanā araññasmiṁ,"
    },
    {
      "id": "ja338:2.2",
      "pali": "yā ca gāme nikaṇṇikā;"
    },
    {
      "id": "ja338:2.3",
      "pali": "Yañcetaṁ iti cīti ca,"
    },
    {
      "id": "ja338:2.4",
      "pali": "etampi viditaṁ mayā."
    },
    {
      "id": "ja338:3.1",
      "pali": "Dhammena kira jātassa,"
    },
    {
      "id": "ja338:3.2",
      "pali": "pitā puttassa makkaṭo;"
    },
    {
      "id": "ja338:3.3",
      "pali": "Daharasseva santassa,"
    },
    {
      "id": "ja338:3.4",
      "pali": "dantehi phalamacchidā."
    },
    {
      "id": "ja338:4.1",
      "pali": "Yametaṁ parisappasi,"
    },
    {
      "id": "ja338:4.2",
      "pali": "ajakāṇova sāsape;"
    },
    {
      "id": "ja338:4.3",
      "pali": "Yopāyaṁ heṭṭhato seti,"
    },
    {
      "id": "ja338:4.4",
      "pali": "etampi viditaṁ mayā”ti."
    },
    {
      "id": "ja338:5.1",
      "pali": "Thusajātakaṁ aṭṭhamaṁ."
    }
  ]
}
