{
  "uid": "ja498",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja498:1.1",
      "pali": "“Sabbaṁ narānaṁ saphalaṁ suciṇṇaṁ,"
    },
    {
      "id": "ja498:1.2",
      "pali": "Na kammunā kiñcana moghamatthi;"
    },
    {
      "id": "ja498:1.3",
      "pali": "Passāmi sambhūtaṁ mahānubhāvaṁ,"
    },
    {
      "id": "ja498:1.4",
      "pali": "Sakammunā puññaphalūpapannaṁ."
    },
    {
      "id": "ja498:2.1",
      "pali": "Sabbaṁ narānaṁ saphalaṁ suciṇṇaṁ,"
    },
    {
      "id": "ja498:2.2",
      "pali": "Na kammunā kiñcana moghamatthi;"
    },
    {
      "id": "ja498:2.3",
      "pali": "Kaccinnu cittassapi evamevaṁ,"
    },
    {
      "id": "ja498:2.4",
      "pali": "Iddho mano tassa yathāpi mayhaṁ”."
    },
    {
      "id": "ja498:3.1",
      "pali": "“Sabbaṁ narānaṁ saphalaṁ suciṇṇaṁ,"
    },
    {
      "id": "ja498:3.2",
      "pali": "Na kammunā kiñcana moghamatthi;"
    },
    {
      "id": "ja498:3.3",
      "pali": "Cittampi jānāhi tatheva deva,"
    },
    {
      "id": "ja498:3.4",
      "pali": "Iddho mano tassa yathāpi tuyhaṁ”."
    },
    {
      "id": "ja498:4.1",
      "pali": "“Bhavaṁ nu citto sutamaññato te,"
    },
    {
      "id": "ja498:4.2",
      "pali": "Udāhu te koci naṁ etadakkhā;"
    },
    {
      "id": "ja498:4.3",
      "pali": "Gāthā sugītā na mamatthi kaṅkhā,"
    },
    {
      "id": "ja498:4.4",
      "pali": "Dadāmi te gāmavaraṁ satañca”."
    },
    {
      "id": "ja498:5.1",
      "pali": "“Na cāhaṁ citto sutamaññato me,"
    },
    {
      "id": "ja498:5.2",
      "pali": "Isī ca me etamatthaṁ asaṁsi;"
    },
    {
      "id": "ja498:5.3",
      "pali": "‘Gantvāna rañño paṭigāhi gāthaṁ,"
    },
    {
      "id": "ja498:5.4",
      "pali": "Api te varaṁ attamano dadeyya’”."
    },
    {
      "id": "ja498:6.1",
      "pali": "“Yojentu ve rājarathe,"
    },
    {
      "id": "ja498:6.2",
      "pali": "sukate cittasibbane;"
    },
    {
      "id": "ja498:6.3",
      "pali": "Kacchaṁ nāgānaṁ bandhatha,"
    },
    {
      "id": "ja498:6.4",
      "pali": "gīveyyaṁ paṭimuñcatha."
    },
    {
      "id": "ja498:7.1",
      "pali": "Āhaññantu bherimudiṅgasaṅkhe,"
    },
    {
      "id": "ja498:7.2",
      "pali": "Sīghāni yānāni ca yojayantu;"
    },
    {
      "id": "ja498:7.3",
      "pali": "Ajjevahaṁ assamaṁ taṁ gamissaṁ,"
    },
    {
      "id": "ja498:7.4",
      "pali": "Yattheva dakkhissamisiṁ nisinnaṁ”."
    },
    {
      "id": "ja498:8.1",
      "pali": "“Suladdhalābho vata me ahosi,"
    },
    {
      "id": "ja498:8.2",
      "pali": "Gāthā sugītā parisāya majjhe;"
    },
    {
      "id": "ja498:8.3",
      "pali": "Svāhaṁ isiṁ sīlavatūpapannaṁ,"
    },
    {
      "id": "ja498:8.4",
      "pali": "Disvā patīto sumanohamasmi”."
    },
    {
      "id": "ja498:9.1",
      "pali": "“Āsanaṁ udakaṁ pajjaṁ,"
    },
    {
      "id": "ja498:9.2",
      "pali": "paṭiggaṇhātu no bhavaṁ;"
    },
    {
      "id": "ja498:9.3",
      "pali": "Agghe bhavantaṁ pucchāma,"
    },
    {
      "id": "ja498:9.4",
      "pali": "agghaṁ kurutu no bhavaṁ”."
    },
    {
      "id": "ja498:10.1",
      "pali": "“Rammañca te āvasathaṁ karontu,"
    },
    {
      "id": "ja498:10.2",
      "pali": "Nārīgaṇehi paricārayassu;"
    },
    {
      "id": "ja498:10.3",
      "pali": "Karohi okāsamanuggahāya,"
    },
    {
      "id": "ja498:10.4",
      "pali": "Ubhopimaṁ issariyaṁ karoma”."
    },
    {
      "id": "ja498:11.1",
      "pali": "“Disvā phalaṁ duccaritassa rāja,"
    },
    {
      "id": "ja498:11.2",
      "pali": "Atho suciṇṇassa mahāvipākaṁ;"
    },
    {
      "id": "ja498:11.3",
      "pali": "Attānameva paṭisaṁyamissaṁ,"
    },
    {
      "id": "ja498:11.4",
      "pali": "Na patthaye putta pasuṁ dhanaṁ vā."
    },
    {
      "id": "ja498:12.1",
      "pali": "Dasevimā vassadasā,"
    },
    {
      "id": "ja498:12.2",
      "pali": "maccānaṁ idha jīvitaṁ;"
    },
    {
      "id": "ja498:12.3",
      "pali": "Apattaññeva taṁ odhiṁ,"
    },
    {
      "id": "ja498:12.4",
      "pali": "naḷo chinnova sussati."
    },
    {
      "id": "ja498:13.1",
      "pali": "Tattha kā nandi kā khiḍḍā,"
    },
    {
      "id": "ja498:13.2",
      "pali": "kā ratī kā dhanesanā;"
    },
    {
      "id": "ja498:13.3",
      "pali": "Kiṁ me puttehi dārehi,"
    },
    {
      "id": "ja498:13.4",
      "pali": "rāja muttosmi bandhanā."
    },
    {
      "id": "ja498:14.1",
      "pali": "Sohaṁ evaṁ pajānāmi,"
    },
    {
      "id": "ja498:14.2",
      "pali": "maccu me nappamajjati;"
    },
    {
      "id": "ja498:14.3",
      "pali": "Antakenādhipannassa,"
    },
    {
      "id": "ja498:14.4",
      "pali": "kā ratī kā dhanesanā."
    },
    {
      "id": "ja498:15.1",
      "pali": "Jāti narānaṁ adhamā janinda,"
    },
    {
      "id": "ja498:15.2",
      "pali": "Caṇḍālayoni dvipadākaniṭṭhā;"
    },
    {
      "id": "ja498:15.3",
      "pali": "Sakehi kammehi supāpakehi,"
    },
    {
      "id": "ja498:15.4",
      "pali": "Caṇḍālagabbhe avasimha pubbe."
    },
    {
      "id": "ja498:16.1",
      "pali": "Caṇḍālāhumha avantīsu,"
    },
    {
      "id": "ja498:16.2",
      "pali": "migā nerañjaraṁ pati;"
    },
    {
      "id": "ja498:16.3",
      "pali": "Ukkusā nammadātīre,"
    },
    {
      "id": "ja498:16.4",
      "pali": "tyajja brāhmaṇakhattiyā."
    },
    {
      "id": "ja498:17.1",
      "pali": "Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "ja498:17.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "ja498:17.3",
      "pali": "Karohi pañcāla mameta vākyaṁ,"
    },
    {
      "id": "ja498:17.4",
      "pali": "Mākāsi kammāni dukkhudrayāni."
    },
    {
      "id": "ja498:18.1",
      "pali": "Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "ja498:18.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "ja498:18.3",
      "pali": "Karohi pañcāla mameta vākyaṁ,"
    },
    {
      "id": "ja498:18.4",
      "pali": "Mākāsi kammāni dukkhapphalāni."
    },
    {
      "id": "ja498:19.1",
      "pali": "Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "ja498:19.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "ja498:19.3",
      "pali": "Karohi pañcāla mameta vākyaṁ,"
    },
    {
      "id": "ja498:19.4",
      "pali": "Mākāsi kammāni rajassirāni."
    },
    {
      "id": "ja498:20.1",
      "pali": "Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "ja498:20.2",
      "pali": "Vaṇṇaṁ jarā hanti narassa jiyyato;"
    },
    {
      "id": "ja498:20.3",
      "pali": "Karohi pañcāla mameta vākyaṁ,"
    },
    {
      "id": "ja498:20.4",
      "pali": "Mākāsi kammaṁ nirayūpapattiyā”."
    },
    {
      "id": "ja498:21.1",
      "pali": "“Addhā hi saccaṁ vacanaṁ tavetaṁ,"
    },
    {
      "id": "ja498:21.2",
      "pali": "Yathā isī bhāsasi evametaṁ;"
    },
    {
      "id": "ja498:21.3",
      "pali": "Kāmā ca me santi anapparūpā,"
    },
    {
      "id": "ja498:21.4",
      "pali": "Te duccajā mādisakena bhikkhu."
    },
    {
      "id": "ja498:22.1",
      "pali": "Nāgo yathā paṅkamajjhe byasanno,"
    },
    {
      "id": "ja498:22.2",
      "pali": "Passaṁ thalaṁ nābhisambhoti gantuṁ;"
    },
    {
      "id": "ja498:22.3",
      "pali": "Evampahaṁ kāmapaṅke byasanno,"
    },
    {
      "id": "ja498:22.4",
      "pali": "Na bhikkhuno maggamanubbajāmi."
    },
    {
      "id": "ja498:23.1",
      "pali": "Yathāpi mātā ca pitā ca puttaṁ,"
    },
    {
      "id": "ja498:23.2",
      "pali": "Anusāsare kinti sukhī bhaveyya;"
    },
    {
      "id": "ja498:23.3",
      "pali": "Evampi maṁ tvaṁ anusāsa bhante,"
    },
    {
      "id": "ja498:23.4",
      "pali": "Yathā ciraṁ pecca sukhī bhaveyyaṁ”."
    },
    {
      "id": "ja498:24.1",
      "pali": "“No ce tuvaṁ ussahase janinda,"
    },
    {
      "id": "ja498:24.2",
      "pali": "Kāme ime mānusake pahātuṁ;"
    },
    {
      "id": "ja498:24.3",
      "pali": "Dhammiṁ baliṁ paṭṭhapayassu rāja,"
    },
    {
      "id": "ja498:24.4",
      "pali": "Adhammakāro tava māhu raṭṭhe."
    },
    {
      "id": "ja498:25.1",
      "pali": "Dūtā vidhāvantu disā catasso,"
    },
    {
      "id": "ja498:25.2",
      "pali": "Nimantakā samaṇabrāhmaṇānaṁ;"
    },
    {
      "id": "ja498:25.3",
      "pali": "Te annapānena upaṭṭhahassu,"
    },
    {
      "id": "ja498:25.4",
      "pali": "Vatthena senāsanapaccayena ca."
    },
    {
      "id": "ja498:26.1",
      "pali": "Annena pānena pasannacitto,"
    },
    {
      "id": "ja498:26.2",
      "pali": "Santappaya samaṇabrāhmaṇe ca;"
    },
    {
      "id": "ja498:26.3",
      "pali": "Datvā ca bhutvā ca yathānubhāvaṁ,"
    },
    {
      "id": "ja498:26.4",
      "pali": "Anindito saggamupehi ṭhānaṁ."
    },
    {
      "id": "ja498:27.1",
      "pali": "Sace ca taṁ rāja mado saheyya,"
    },
    {
      "id": "ja498:27.2",
      "pali": "Nārīgaṇehi paricārayantaṁ;"
    },
    {
      "id": "ja498:27.3",
      "pali": "Imameva gāthaṁ manasī karohi,"
    },
    {
      "id": "ja498:27.4",
      "pali": "Bhāsesi cenaṁ parisāya majjhe."
    },
    {
      "id": "ja498:28.1",
      "pali": "Abbhokāsasayo jantu,"
    },
    {
      "id": "ja498:28.2",
      "pali": "vajantyā khīrapāyito;"
    },
    {
      "id": "ja498:28.3",
      "pali": "Parikiṇṇo suvānehi,"
    },
    {
      "id": "ja498:28.4",
      "pali": "svājja rājāti vuccatī”ti."
    },
    {
      "id": "ja498:29.1",
      "pali": "Cittasambhūtajātakaṁ dutiyaṁ."
    }
  ]
}
