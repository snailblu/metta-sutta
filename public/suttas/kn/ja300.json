{
  "uid": "ja300",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja300:1.1",
      "pali": "“Parapāṇarodhā jīvanto,"
    },
    {
      "id": "ja300:1.2",
      "pali": "maṁsalohitabhojano;"
    },
    {
      "id": "ja300:1.3",
      "pali": "Vako vataṁ samādāya,"
    },
    {
      "id": "ja300:1.4",
      "pali": "upapajji uposathaṁ."
    },
    {
      "id": "ja300:2.1",
      "pali": "Tassa sakko vataññāya,"
    },
    {
      "id": "ja300:2.2",
      "pali": "ajarūpenupāgami;"
    },
    {
      "id": "ja300:2.3",
      "pali": "Vītatapo ajjhappatto,"
    },
    {
      "id": "ja300:2.4",
      "pali": "bhañji lohitapo tapaṁ."
    },
    {
      "id": "ja300:3.1",
      "pali": "Evameva idhekacce,"
    },
    {
      "id": "ja300:3.2",
      "pali": "Samādānamhi dubbalā;"
    },
    {
      "id": "ja300:3.3",
      "pali": "Lahuṁ karonti attānaṁ,"
    },
    {
      "id": "ja300:3.4",
      "pali": "Vakova ajakāraṇā”ti."
    },
    {
      "id": "ja300:4.1",
      "pali": "Vakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja300:4.2",
      "pali": "Kumbhavaggo pañcamo."
    },
    {
      "id": "ja300:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja300:6.1",
      "pali": "Varakumbha supattasirivhayano,"
    },
    {
      "id": "ja300:6.2",
      "pali": "Sucisammata bindusaro cusabho;"
    },
    {
      "id": "ja300:6.3",
      "pali": "Saritaṁpati caṇḍi jarākapinā,"
    },
    {
      "id": "ja300:6.4",
      "pali": "Atha makkaṭiyā vakakena dasāti."
    },
    {
      "id": "ja300:7.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja300:8.1",
      "pali": "Saṅkappo padumo ceva,"
    },
    {
      "id": "ja300:8.2",
      "pali": "Udapānena tatiyaṁ;"
    },
    {
      "id": "ja300:8.3",
      "pali": "Abbhantaraṁ ghaṭabhedaṁ,"
    },
    {
      "id": "ja300:8.4",
      "pali": "Tikanipātamhilaṅkatanti."
    },
    {
      "id": "ja300:9.1",
      "pali": "Tikanipātaṁ niṭṭhitaṁ."
    }
  ]
}
