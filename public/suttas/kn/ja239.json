{
  "uid": "ja239",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja239:1.1",
      "pali": "“Āsīvisampi maṁ santaṁ,"
    },
    {
      "id": "ja239:1.2",
      "pali": "Paviṭṭhaṁ kumināmukhaṁ;"
    },
    {
      "id": "ja239:1.3",
      "pali": "Ruccate haritāmātā,"
    },
    {
      "id": "ja239:1.4",
      "pali": "Yaṁ maṁ khādanti macchakā”."
    },
    {
      "id": "ja239:2.1",
      "pali": "“Vilumpateva puriso,"
    },
    {
      "id": "ja239:2.2",
      "pali": "yāvassa upakappati;"
    },
    {
      "id": "ja239:2.3",
      "pali": "Yadā caññe vilumpanti,"
    },
    {
      "id": "ja239:2.4",
      "pali": "so vilutto vilumpatī”ti."
    },
    {
      "id": "ja239:3.1",
      "pali": "Haritamaṇḍūkajātakaṁ navamaṁ."
    }
  ]
}
