{
  "uid": "pv1",
  "title": "1. Khettūpamapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "pv1:2.1",
      "pali": "“Khettūpamā arahanto,"
    },
    {
      "id": "pv1:2.2",
      "pali": "dāyakā kassakūpamā;"
    },
    {
      "id": "pv1:2.3",
      "pali": "Bījūpamaṁ deyyadhammaṁ,"
    },
    {
      "id": "pv1:2.4",
      "pali": "etto nibbattate phalaṁ."
    },
    {
      "id": "pv1:3.1",
      "pali": "Etaṁ bījaṁ kasi khettaṁ,"
    },
    {
      "id": "pv1:3.2",
      "pali": "petānaṁ dāyakassa ca;"
    },
    {
      "id": "pv1:3.3",
      "pali": "Taṁ petā paribhuñjanti,"
    },
    {
      "id": "pv1:3.4",
      "pali": "dātā puññena vaḍḍhati."
    },
    {
      "id": "pv1:4.1",
      "pali": "Idheva kusalaṁ katvā,"
    },
    {
      "id": "pv1:4.2",
      "pali": "Pete ca paṭipūjiya;"
    },
    {
      "id": "pv1:4.3",
      "pali": "Saggañca kamatiṭṭhānaṁ,"
    },
    {
      "id": "pv1:4.4",
      "pali": "Kammaṁ katvāna bhaddakan”ti."
    },
    {
      "id": "pv1:5.1",
      "pali": "Khettūpamapetavatthu paṭhamaṁ."
    }
  ]
}
