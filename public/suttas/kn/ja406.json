{
  "uid": "ja406",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja406:1.1",
      "pali": "“Hitvā gāmasahassāni,"
    },
    {
      "id": "ja406:1.2",
      "pali": "paripuṇṇāni soḷasa;"
    },
    {
      "id": "ja406:1.3",
      "pali": "Koṭṭhāgārāni phītāni,"
    },
    {
      "id": "ja406:1.4",
      "pali": "sannidhiṁ dāni kubbasi”."
    },
    {
      "id": "ja406:2.1",
      "pali": "“Hitvā gandhāravisayaṁ,"
    },
    {
      "id": "ja406:2.2",
      "pali": "pahūtadhanadhāriyaṁ;"
    },
    {
      "id": "ja406:2.3",
      "pali": "Pasāsanato nikkhanto,"
    },
    {
      "id": "ja406:2.4",
      "pali": "idha dāni pasāsasi”."
    },
    {
      "id": "ja406:3.1",
      "pali": "“Dhammaṁ bhaṇāmi vedeha,"
    },
    {
      "id": "ja406:3.2",
      "pali": "adhammo me na ruccati;"
    },
    {
      "id": "ja406:3.3",
      "pali": "Dhammaṁ me bhaṇamānassa,"
    },
    {
      "id": "ja406:3.4",
      "pali": "na pāpamupalimpati”."
    },
    {
      "id": "ja406:4.1",
      "pali": "“Yena kenaci vaṇṇena,"
    },
    {
      "id": "ja406:4.2",
      "pali": "paro labhati ruppanaṁ;"
    },
    {
      "id": "ja406:4.3",
      "pali": "Mahatthiyampi ce vācaṁ,"
    },
    {
      "id": "ja406:4.4",
      "pali": "na taṁ bhāseyya paṇḍito”."
    },
    {
      "id": "ja406:5.1",
      "pali": "“Kāmaṁ ruppatu vā mā vā,"
    },
    {
      "id": "ja406:5.2",
      "pali": "bhusaṁva vikirīyatu;"
    },
    {
      "id": "ja406:5.3",
      "pali": "Dhammaṁ me bhaṇamānassa,"
    },
    {
      "id": "ja406:5.4",
      "pali": "na pāpamupalimpati”."
    },
    {
      "id": "ja406:6.1",
      "pali": "“No ce assa sakā buddhi,"
    },
    {
      "id": "ja406:6.2",
      "pali": "vinayo vā susikkhito;"
    },
    {
      "id": "ja406:6.3",
      "pali": "Vane andhamahiṁsova,"
    },
    {
      "id": "ja406:6.4",
      "pali": "careyya bahuko jano."
    },
    {
      "id": "ja406:7.1",
      "pali": "Yasmā ca panidhekacce,"
    },
    {
      "id": "ja406:7.2",
      "pali": "āceramhi susikkhitā;"
    },
    {
      "id": "ja406:7.3",
      "pali": "Tasmā vinītavinayā,"
    },
    {
      "id": "ja406:7.4",
      "pali": "caranti susamāhitā”ti."
    },
    {
      "id": "ja406:8.1",
      "pali": "Gandhārajātakaṁ paṭhamaṁ."
    }
  ]
}
