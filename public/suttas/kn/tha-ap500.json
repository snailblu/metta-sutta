{
  "uid": "tha-ap500",
  "title": "8 Pulinathūpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap500:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap500:1.2",
      "pali": "yamako nāma pabbato;"
    },
    {
      "id": "tha-ap500:1.3",
      "pali": "Assamo sukato mayhaṁ,"
    },
    {
      "id": "tha-ap500:1.4",
      "pali": "paṇṇasālā sumāpitā."
    },
    {
      "id": "tha-ap500:2.1",
      "pali": "Nārado nāma nāmena,"
    },
    {
      "id": "tha-ap500:2.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "tha-ap500:2.3",
      "pali": "Catuddasasahassāni,"
    },
    {
      "id": "tha-ap500:2.4",
      "pali": "sissā paricaranti maṁ."
    },
    {
      "id": "tha-ap500:3.1",
      "pali": "Paṭisallīnako santo,"
    },
    {
      "id": "tha-ap500:3.2",
      "pali": "evaṁ cintesahaṁ tadā;"
    },
    {
      "id": "tha-ap500:3.3",
      "pali": "‘Sabbo jano maṁ pūjeti,"
    },
    {
      "id": "tha-ap500:3.4",
      "pali": "nāhaṁ pūjemi kiñcanaṁ."
    },
    {
      "id": "tha-ap500:4.1",
      "pali": "Na me ovādako atthi,"
    },
    {
      "id": "tha-ap500:4.2",
      "pali": "vattā koci na vijjati;"
    },
    {
      "id": "tha-ap500:4.3",
      "pali": "Anācariyupajjhāyo,"
    },
    {
      "id": "tha-ap500:4.4",
      "pali": "vane vāsaṁ upemahaṁ."
    },
    {
      "id": "tha-ap500:5.1",
      "pali": "Upāsamāno yamahaṁ,"
    },
    {
      "id": "tha-ap500:5.2",
      "pali": "garucittaṁ upaṭṭhahe;"
    },
    {
      "id": "tha-ap500:5.3",
      "pali": "So me ācariyo natthi,"
    },
    {
      "id": "tha-ap500:5.4",
      "pali": "vanavāso niratthako."
    },
    {
      "id": "tha-ap500:6.1",
      "pali": "Āyāgaṁ me gavesissaṁ,"
    },
    {
      "id": "tha-ap500:6.2",
      "pali": "garuṁ bhāvaniyaṁ tathā;"
    },
    {
      "id": "tha-ap500:6.3",
      "pali": "Sāvassayo vasissāmi,"
    },
    {
      "id": "tha-ap500:6.4",
      "pali": "na koci garahissati’."
    },
    {
      "id": "tha-ap500:7.1",
      "pali": "Uttānakūlā nadikā,"
    },
    {
      "id": "tha-ap500:7.2",
      "pali": "supatitthā manoramā;"
    },
    {
      "id": "tha-ap500:7.3",
      "pali": "Saṁsuddhapulinākiṇṇā,"
    },
    {
      "id": "tha-ap500:7.4",
      "pali": "avidūre mamassamaṁ."
    },
    {
      "id": "tha-ap500:8.1",
      "pali": "Nadiṁ amarikaṁ nāma,"
    },
    {
      "id": "tha-ap500:8.2",
      "pali": "upagantvānahaṁ tadā;"
    },
    {
      "id": "tha-ap500:8.3",
      "pali": "Saṁvaḍḍhayitvā pulinaṁ,"
    },
    {
      "id": "tha-ap500:8.4",
      "pali": "akaṁ pulinacetiyaṁ."
    },
    {
      "id": "tha-ap500:9.1",
      "pali": "Ye te ahesuṁ sambuddhā,"
    },
    {
      "id": "tha-ap500:9.2",
      "pali": "bhavantakaraṇā munī;"
    },
    {
      "id": "tha-ap500:9.3",
      "pali": "Tesaṁ etādiso thūpo,"
    },
    {
      "id": "tha-ap500:9.4",
      "pali": "taṁ nimittaṁ karomahaṁ."
    },
    {
      "id": "tha-ap500:10.1",
      "pali": "Karitvā pulinaṁ thūpaṁ,"
    },
    {
      "id": "tha-ap500:10.2",
      "pali": "sovaṇṇaṁ māpayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap500:10.3",
      "pali": "Soṇṇakiṅkaṇipupphāni,"
    },
    {
      "id": "tha-ap500:10.4",
      "pali": "sahasse tīṇi pūjayiṁ."
    },
    {
      "id": "tha-ap500:11.1",
      "pali": "Sāyaṁ pātaṁ namassāmi,"
    },
    {
      "id": "tha-ap500:11.2",
      "pali": "vedajāto katañjalī;"
    },
    {
      "id": "tha-ap500:11.3",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap500:11.4",
      "pali": "vandiṁ pulinacetiyaṁ."
    },
    {
      "id": "tha-ap500:12.1",
      "pali": "Yadā kilesā jāyanti,"
    },
    {
      "id": "tha-ap500:12.2",
      "pali": "vitakkā gehanissitā;"
    },
    {
      "id": "tha-ap500:12.3",
      "pali": "Sarāmi sukataṁ thūpaṁ,"
    },
    {
      "id": "tha-ap500:12.4",
      "pali": "paccavekkhāmi tāvade."
    },
    {
      "id": "tha-ap500:13.1",
      "pali": "Upanissāya viharaṁ,"
    },
    {
      "id": "tha-ap500:13.2",
      "pali": "satthavāhaṁ vināyakaṁ;"
    },
    {
      "id": "tha-ap500:13.3",
      "pali": "Kilese saṁvaseyyāsi,"
    },
    {
      "id": "tha-ap500:13.4",
      "pali": "na yuttaṁ tava mārisa."
    },
    {
      "id": "tha-ap500:14.1",
      "pali": "Saha āvajjite thūpe,"
    },
    {
      "id": "tha-ap500:14.2",
      "pali": "gāravaṁ hoti me tadā;"
    },
    {
      "id": "tha-ap500:14.3",
      "pali": "Kuvitakke vinodesiṁ,"
    },
    {
      "id": "tha-ap500:14.4",
      "pali": "nāgo tuttaṭṭito yathā."
    },
    {
      "id": "tha-ap500:15.1",
      "pali": "Evaṁ viharamānaṁ maṁ,"
    },
    {
      "id": "tha-ap500:15.2",
      "pali": "maccurājābhimaddatha;"
    },
    {
      "id": "tha-ap500:15.3",
      "pali": "Tattha kālaṅkato santo,"
    },
    {
      "id": "tha-ap500:15.4",
      "pali": "brahmalokamagacchahaṁ."
    },
    {
      "id": "tha-ap500:16.1",
      "pali": "Yāvatāyuṁ vasitvāna,"
    },
    {
      "id": "tha-ap500:16.2",
      "pali": "tidive upapajjahaṁ;"
    },
    {
      "id": "tha-ap500:16.3",
      "pali": "Asītikkhattuṁ devindo,"
    },
    {
      "id": "tha-ap500:16.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap500:17.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap500:17.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap500:17.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap500:17.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap500:18.1",
      "pali": "Soṇṇakiṅkaṇipupphānaṁ,"
    },
    {
      "id": "tha-ap500:18.2",
      "pali": "vipākaṁ anubhomahaṁ;"
    },
    {
      "id": "tha-ap500:18.3",
      "pali": "Dhātīsatasahassāni,"
    },
    {
      "id": "tha-ap500:18.4",
      "pali": "parivārenti maṁ bhave."
    },
    {
      "id": "tha-ap500:19.1",
      "pali": "Thūpassa pariciṇṇattā,"
    },
    {
      "id": "tha-ap500:19.2",
      "pali": "rajojallaṁ na limpati;"
    },
    {
      "id": "tha-ap500:19.3",
      "pali": "Gatte sedā na muccanti,"
    },
    {
      "id": "tha-ap500:19.4",
      "pali": "suppabhāso bhavāmahaṁ."
    },
    {
      "id": "tha-ap500:20.1",
      "pali": "Aho me sukato thūpo,"
    },
    {
      "id": "tha-ap500:20.2",
      "pali": "sudiṭṭhā marikā nadī;"
    },
    {
      "id": "tha-ap500:20.3",
      "pali": "Thūpaṁ katvāna pulinaṁ,"
    },
    {
      "id": "tha-ap500:20.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap500:21.1",
      "pali": "Kusalaṁ kattukāmena,"
    },
    {
      "id": "tha-ap500:21.2",
      "pali": "jantunā sāragāhinā;"
    },
    {
      "id": "tha-ap500:21.3",
      "pali": "Natthi khettaṁ akhettaṁ vā,"
    },
    {
      "id": "tha-ap500:21.4",
      "pali": "paṭipattīva sādhakā."
    },
    {
      "id": "tha-ap500:22.1",
      "pali": "Yathāpi balavā poso,"
    },
    {
      "id": "tha-ap500:22.2",
      "pali": "aṇṇavaṁ taritussahe;"
    },
    {
      "id": "tha-ap500:22.3",
      "pali": "Parittaṁ kaṭṭhamādāya,"
    },
    {
      "id": "tha-ap500:22.4",
      "pali": "pakkhandeyya mahāsaraṁ."
    },
    {
      "id": "tha-ap500:23.1",
      "pali": "Imāhaṁ kaṭṭhaṁ nissāya,"
    },
    {
      "id": "tha-ap500:23.2",
      "pali": "tarissāmi mahodadhiṁ;"
    },
    {
      "id": "tha-ap500:23.3",
      "pali": "Ussāhena vīriyena,"
    },
    {
      "id": "tha-ap500:23.4",
      "pali": "tareyya udadhiṁ naro."
    },
    {
      "id": "tha-ap500:24.1",
      "pali": "Tatheva me kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap500:24.2",
      "pali": "parittaṁ thokakañca yaṁ;"
    },
    {
      "id": "tha-ap500:24.3",
      "pali": "Taṁ kammaṁ upanissāya,"
    },
    {
      "id": "tha-ap500:24.4",
      "pali": "saṁsāraṁ samatikkamiṁ."
    },
    {
      "id": "tha-ap500:25.1",
      "pali": "Pacchime bhave sampatte,"
    },
    {
      "id": "tha-ap500:25.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap500:25.3",
      "pali": "Sāvatthiyaṁ pure jāto,"
    },
    {
      "id": "tha-ap500:25.4",
      "pali": "mahāsāle suaḍḍhake."
    },
    {
      "id": "tha-ap500:26.1",
      "pali": "Saddhā mātā pitā mayhaṁ,"
    },
    {
      "id": "tha-ap500:26.2",
      "pali": "buddhassa saraṇaṁ gatā;"
    },
    {
      "id": "tha-ap500:26.3",
      "pali": "Ubho diṭṭhapadā ete,"
    },
    {
      "id": "tha-ap500:26.4",
      "pali": "anuvattanti sāsanaṁ."
    },
    {
      "id": "tha-ap500:27.1",
      "pali": "Bodhipapaṭikaṁ gayha,"
    },
    {
      "id": "tha-ap500:27.2",
      "pali": "soṇṇathūpamakārayuṁ;"
    },
    {
      "id": "tha-ap500:27.3",
      "pali": "Sāyaṁ pātaṁ namassanti,"
    },
    {
      "id": "tha-ap500:27.4",
      "pali": "sakyaputtassa sammukhā."
    },
    {
      "id": "tha-ap500:28.1",
      "pali": "Uposathamhi divase,"
    },
    {
      "id": "tha-ap500:28.2",
      "pali": "soṇṇathūpaṁ vinīharuṁ;"
    },
    {
      "id": "tha-ap500:28.3",
      "pali": "Buddhassa vaṇṇaṁ kittentā,"
    },
    {
      "id": "tha-ap500:28.4",
      "pali": "tiyāmaṁ vītināmayuṁ."
    },
    {
      "id": "tha-ap500:29.1",
      "pali": "Saha disvānahaṁ thūpaṁ,"
    },
    {
      "id": "tha-ap500:29.2",
      "pali": "sariṁ pulinacetiyaṁ;"
    },
    {
      "id": "tha-ap500:29.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap500:29.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap500:30.1",
      "pali": "Dvāvīsatimaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap500:31.1",
      "pali": "Gavesamāno taṁ vīraṁ,"
    },
    {
      "id": "tha-ap500:31.2",
      "pali": "dhammasenāpatiddasaṁ;"
    },
    {
      "id": "tha-ap500:31.3",
      "pali": "Agārā nikkhamitvāna,"
    },
    {
      "id": "tha-ap500:31.4",
      "pali": "pabbajiṁ tassa santike."
    },
    {
      "id": "tha-ap500:32.1",
      "pali": "Jātiyā sattavassena,"
    },
    {
      "id": "tha-ap500:32.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap500:32.3",
      "pali": "Upasampādayī buddho,"
    },
    {
      "id": "tha-ap500:32.4",
      "pali": "guṇamaññāya cakkhumā."
    },
    {
      "id": "tha-ap500:33.1",
      "pali": "Dārakeneva santena,"
    },
    {
      "id": "tha-ap500:33.2",
      "pali": "kiriyaṁ niṭṭhitaṁ mayā;"
    },
    {
      "id": "tha-ap500:33.3",
      "pali": "Kataṁ me karaṇīyajja,"
    },
    {
      "id": "tha-ap500:33.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "tha-ap500:34.1",
      "pali": "Sabbaverabhayātīto,"
    },
    {
      "id": "tha-ap500:34.2",
      "pali": "sabbasaṅgātigo isi;"
    },
    {
      "id": "tha-ap500:34.3",
      "pali": "Sāvako te mahāvīra,"
    },
    {
      "id": "tha-ap500:34.4",
      "pali": "soṇṇathūpassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap500:35.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap500:35.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap500:35.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap500:36.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap500:36.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap500:36.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap500:37.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap500:37.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap500:37.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap500:38.1",
      "pali": "Itthaṁ sudaṁ āyasmā pulinathūpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap500:39.1",
      "pali": "Pulinathūpiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
