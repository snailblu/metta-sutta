{
  "uid": "thag1.113",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.113:1.1",
      "pali": "“Acchodikā puthusilā,"
    },
    {
      "id": "thag1.113:1.2",
      "pali": "gonaṅgulamigāyutā;"
    },
    {
      "id": "thag1.113:1.3",
      "pali": "Ambusevālasañchannā,"
    },
    {
      "id": "thag1.113:1.4",
      "pali": "te selā ramayanti man”ti."
    },
    {
      "id": "thag1.113:1.5",
      "pali": "… Vanavaccho thero …."
    }
  ]
}
