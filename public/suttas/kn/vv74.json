{
  "uid": "vv74",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv74:1.1",
      "pali": "“Yā devarājassa sabhā sudhammā,"
    },
    {
      "id": "vv74:1.2",
      "pali": "Yatthacchati devasaṅgho samaggo;"
    },
    {
      "id": "vv74:1.3",
      "pali": "Tathūpamaṁ tuyhamidaṁ vimānaṁ,"
    },
    {
      "id": "vv74:1.4",
      "pali": "Obhāsayaṁ tiṭṭhati antalikkhe."
    },
    {
      "id": "vv74:2.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv74:2.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv74:2.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv74:2.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv74:3.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv74:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv74:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv74:4.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv74:4.2",
      "pali": "Rañño pāyāsissa ahosiṁ māṇavo;"
    },
    {
      "id": "vv74:4.3",
      "pali": "Laddhā dhanaṁ saṁvibhāgaṁ akāsiṁ,"
    },
    {
      "id": "vv74:4.4",
      "pali": "Piyā ca me sīlavanto ahesuṁ;"
    },
    {
      "id": "vv74:4.5",
      "pali": "Annañca pānañca pasannacitto,"
    },
    {
      "id": "vv74:4.6",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv74:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv74:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv74:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv74:6.1",
      "pali": "Pāyāsivimānaṁ dasamaṁ."
    },
    {
      "id": "vv74:7.1",
      "pali": "Pāyāsivaggo chaṭṭho."
    },
    {
      "id": "vv74:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv74:9.1",
      "pali": "Dve agārino phaladāyī,"
    },
    {
      "id": "vv74:9.2",
      "pali": "Dve upassayadāyī bhikkhāya dāyī;"
    },
    {
      "id": "vv74:9.3",
      "pali": "Yavapālako ceva dve,"
    },
    {
      "id": "vv74:9.4",
      "pali": "Kuṇḍalino pāyāsīti."
    },
    {
      "id": "vv74:10.1",
      "pali": "Purisānaṁ dutiyo vaggo pavuccatīti."
    }
  ]
}
