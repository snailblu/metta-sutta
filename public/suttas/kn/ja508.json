{
  "uid": "ja508",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja508:1.1",
      "pali": "“Pañca paṇḍitā samāgatāttha,"
    },
    {
      "id": "ja508:1.2",
      "pali": "Pañhā me paṭibhāti taṁ suṇātha;"
    },
    {
      "id": "ja508:1.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:1.4",
      "pali": "Kassevāvikareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:2.1",
      "pali": "“Tvaṁ āvikarohi bhūmipāla,"
    },
    {
      "id": "ja508:2.2",
      "pali": "Bhattā bhārasaho tuvaṁ vade taṁ;"
    },
    {
      "id": "ja508:2.3",
      "pali": "Tava chandarucīni sammasitvā,"
    },
    {
      "id": "ja508:2.4",
      "pali": "Atha vakkhanti janinda pañca dhīrā”."
    },
    {
      "id": "ja508:3.1",
      "pali": "“Yā sīlavatī anaññatheyyā,"
    },
    {
      "id": "ja508:3.2",
      "pali": "Bhattucchandavasānugā manāpā;"
    },
    {
      "id": "ja508:3.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:3.4",
      "pali": "Bhariyāyāvikareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:4.1",
      "pali": "“Yo kicchagatassa āturassa,"
    },
    {
      "id": "ja508:4.2",
      "pali": "Saraṇaṁ hoti gatī parāyanañca;"
    },
    {
      "id": "ja508:4.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:4.4",
      "pali": "Sakhino vāvikareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:5.1",
      "pali": "“Jeṭṭho atha majjhimo kaniṭṭho,"
    },
    {
      "id": "ja508:5.2",
      "pali": "Yo ce sīlasamāhito ṭhitatto;"
    },
    {
      "id": "ja508:5.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:5.4",
      "pali": "Bhātu vāvīkareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:6.1",
      "pali": "“Yo ve pituhadayassa paddhagū,"
    },
    {
      "id": "ja508:6.2",
      "pali": "Anujāto pitaraṁ anomapañño;"
    },
    {
      "id": "ja508:6.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:6.4",
      "pali": "Puttassāvikareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:7.1",
      "pali": "“Mātā dvipadājanindaseṭṭha,"
    },
    {
      "id": "ja508:7.2",
      "pali": "Yā naṁ poseti chandasā piyena;"
    },
    {
      "id": "ja508:7.3",
      "pali": "Nindiyamatthaṁ pasaṁsiyaṁ vā,"
    },
    {
      "id": "ja508:7.4",
      "pali": "Mātuyāvīkareyya guyhamatthaṁ”."
    },
    {
      "id": "ja508:8.1",
      "pali": "“Guyhassa hi guyhameva sādhu,"
    },
    {
      "id": "ja508:8.2",
      "pali": "Na hi guyhassa pasatthamāvikammaṁ;"
    },
    {
      "id": "ja508:8.3",
      "pali": "Anipphannatā saheyya dhīro,"
    },
    {
      "id": "ja508:8.4",
      "pali": "Nipphannova yathāsukhaṁ bhaṇeyya”."
    },
    {
      "id": "ja508:9.1",
      "pali": "“Kiṁ tvaṁ vimanosi rājaseṭṭha,"
    },
    {
      "id": "ja508:9.2",
      "pali": "Dvipadajaninda vacanaṁ suṇoma metaṁ;"
    },
    {
      "id": "ja508:9.3",
      "pali": "Kiṁ cintayamāno dummanosi,"
    },
    {
      "id": "ja508:9.4",
      "pali": "Nūna deva aparādho atthi mayhaṁ”."
    },
    {
      "id": "ja508:10.1",
      "pali": "“‘Paṇhe vajjho mahosadho’ti,"
    },
    {
      "id": "ja508:10.2",
      "pali": "Āṇatto me vadhāya bhūripañño;"
    },
    {
      "id": "ja508:10.3",
      "pali": "Taṁ cintayamāno dummanosmi,"
    },
    {
      "id": "ja508:10.4",
      "pali": "Na hi devī aparādho atthi tuyhaṁ”."
    },
    {
      "id": "ja508:11.1",
      "pali": "“Abhidosagato dāni ehisi,"
    },
    {
      "id": "ja508:11.2",
      "pali": "Kiṁ sutvā kiṁ saṅkate mano te;"
    },
    {
      "id": "ja508:11.3",
      "pali": "Ko te kimavoca bhūripañña,"
    },
    {
      "id": "ja508:11.4",
      "pali": "Iṅgha vacanaṁ suṇoma brūhi metaṁ”."
    },
    {
      "id": "ja508:12.1",
      "pali": "“‘Paṇhe vajjho mahosadho’ti,"
    },
    {
      "id": "ja508:12.2",
      "pali": "Yadi te mantayitaṁ janinda dosaṁ;"
    },
    {
      "id": "ja508:12.3",
      "pali": "Bhariyāya rahogato asaṁsi,"
    },
    {
      "id": "ja508:12.4",
      "pali": "Guyhaṁ pātukataṁ sutaṁ mametaṁ”."
    },
    {
      "id": "ja508:13.1",
      "pali": "“Yaṁ sālavanasmiṁ senako,"
    },
    {
      "id": "ja508:13.2",
      "pali": "Pāpakammaṁ akāsi asabbhirūpaṁ;"
    },
    {
      "id": "ja508:13.3",
      "pali": "Sakhinova rahogato asaṁsi,"
    },
    {
      "id": "ja508:13.4",
      "pali": "Guyhaṁ pātukataṁ sutaṁ mametaṁ."
    },
    {
      "id": "ja508:14.1",
      "pali": "Pukkusa purisassa te janinda,"
    },
    {
      "id": "ja508:14.2",
      "pali": "Uppanno rogo arājayutto;"
    },
    {
      "id": "ja508:14.3",
      "pali": "Bhātuñca rahogato asaṁsi,"
    },
    {
      "id": "ja508:14.4",
      "pali": "Guyhaṁ pātukataṁ sutaṁ mametaṁ."
    },
    {
      "id": "ja508:15.1",
      "pali": "Ābādhoyaṁ asabbhirūpo,"
    },
    {
      "id": "ja508:15.2",
      "pali": "Kāmindo naradevena phuṭṭho;"
    },
    {
      "id": "ja508:15.3",
      "pali": "Puttassa rahogato asaṁsi,"
    },
    {
      "id": "ja508:15.4",
      "pali": "Guyhaṁ pātukataṁ sutaṁ mametaṁ."
    },
    {
      "id": "ja508:16.1",
      "pali": "Aṭṭhavaṅkaṁ maṇiratanaṁ uḷāraṁ,"
    },
    {
      "id": "ja508:16.2",
      "pali": "Sakko te adadā pitāmahassa;"
    },
    {
      "id": "ja508:16.3",
      "pali": "Devindassa gataṁ tadajja hatthaṁ,"
    },
    {
      "id": "ja508:16.4",
      "pali": "Mātuñca rahogato asaṁsi;"
    },
    {
      "id": "ja508:16.5",
      "pali": "Guyhaṁ pātukataṁ sutaṁ mametaṁ."
    },
    {
      "id": "ja508:17.1",
      "pali": "Guyhassa hi guyhameva sādhu,"
    },
    {
      "id": "ja508:17.2",
      "pali": "Na hi guyhassa pasatthamāvikammaṁ;"
    },
    {
      "id": "ja508:17.3",
      "pali": "Anipphannatā saheyya dhīro,"
    },
    {
      "id": "ja508:17.4",
      "pali": "Nipphannova yathāsukhaṁ bhaṇeyya."
    },
    {
      "id": "ja508:18.1",
      "pali": "Na guyhamatthaṁ vivareyya,"
    },
    {
      "id": "ja508:18.2",
      "pali": "rakkheyya naṁ yathā nidhiṁ;"
    },
    {
      "id": "ja508:18.3",
      "pali": "Na hi pātukato sādhu,"
    },
    {
      "id": "ja508:18.4",
      "pali": "guyho attho pajānatā."
    },
    {
      "id": "ja508:19.1",
      "pali": "Thiyā guyhaṁ na saṁseyya,"
    },
    {
      "id": "ja508:19.2",
      "pali": "amittassa ca paṇḍito;"
    },
    {
      "id": "ja508:19.3",
      "pali": "Yo cāmisena saṁhīro,"
    },
    {
      "id": "ja508:19.4",
      "pali": "hadayattheno ca yo naro."
    },
    {
      "id": "ja508:20.1",
      "pali": "Guyhamatthaṁ asambuddhaṁ,"
    },
    {
      "id": "ja508:20.2",
      "pali": "sambodhayati yo naro;"
    },
    {
      "id": "ja508:20.3",
      "pali": "Mantabhedabhayā tassa,"
    },
    {
      "id": "ja508:20.4",
      "pali": "dāsabhūto titikkhati."
    },
    {
      "id": "ja508:21.1",
      "pali": "Yāvanto purisassatthaṁ,"
    },
    {
      "id": "ja508:21.2",
      "pali": "guyhaṁ jānanti mantinaṁ;"
    },
    {
      "id": "ja508:21.3",
      "pali": "Tāvanto tassa ubbegā,"
    },
    {
      "id": "ja508:21.4",
      "pali": "tasmā guyhaṁ na vissaje."
    },
    {
      "id": "ja508:22.1",
      "pali": "Vivicca bhāseyya divā rahassaṁ,"
    },
    {
      "id": "ja508:22.2",
      "pali": "Rattiṁ giraṁ nātivelaṁ pamuñce;"
    },
    {
      "id": "ja508:22.3",
      "pali": "Upassutikā hi suṇanti mantaṁ,"
    },
    {
      "id": "ja508:22.4",
      "pali": "Tasmā manto khippamupeti bhedan”ti."
    },
    {
      "id": "ja508:23.1",
      "pali": "Pañcapaṇḍitajātakaṁ dvādasamaṁ."
    }
  ]
}
