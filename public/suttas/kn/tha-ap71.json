{
  "uid": "tha-ap71",
  "title": "Sumanattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap71:1.1",
      "pali": "“Sumano nāma nāmena,"
    },
    {
      "id": "tha-ap71:1.2",
      "pali": "mālākāro ahaṁ tadā;"
    },
    {
      "id": "tha-ap71:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap71:1.4",
      "pali": "lokāhutipaṭiggahaṁ."
    },
    {
      "id": "tha-ap71:2.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap71:2.2",
      "pali": "sumanaṁ pupphamuttamaṁ;"
    },
    {
      "id": "tha-ap71:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap71:2.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap71:3.1",
      "pali": "Imāya pupphapūjāya,"
    },
    {
      "id": "tha-ap71:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap71:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap71:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap71:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap71:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap71:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap71:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap71:5.1",
      "pali": "Chabbīsatimhi kappamhi,"
    },
    {
      "id": "tha-ap71:5.2",
      "pali": "cattārosuṁ mahāyasā;"
    },
    {
      "id": "tha-ap71:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap71:5.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap71:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap71:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap71:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap71:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumano thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap71:8.1",
      "pali": "Sumanattherassāpadānaṁ navamaṁ."
    }
  ]
}
