{
  "uid": "pv48",
  "title": "13. Akkharukkhapetavatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv48:1.1",
      "pali": "“Yaṁ dadāti na taṁ hoti,"
    },
    {
      "id": "pv48:1.2",
      "pali": "Detheva dānaṁ datvā ubhayaṁ tarati;"
    },
    {
      "id": "pv48:1.3",
      "pali": "Ubhayaṁ tena dānena gacchati,"
    },
    {
      "id": "pv48:1.4",
      "pali": "Jāgaratha māpamajjathā”ti."
    },
    {
      "id": "pv48:2.1",
      "pali": "Akkharukkhapetavatthu terasamaṁ."
    }
  ]
}
