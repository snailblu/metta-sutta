{
  "uid": "ja484",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja484:1.1",
      "pali": "“Sampannaṁ sālikedāraṁ,"
    },
    {
      "id": "ja484:1.2",
      "pali": "suvā bhuñjanti kosiya;"
    },
    {
      "id": "ja484:1.3",
      "pali": "Paṭivedemi te brahme,"
    },
    {
      "id": "ja484:1.4",
      "pali": "na ne vāretumussahe."
    },
    {
      "id": "ja484:2.1",
      "pali": "Eko ca tattha sakuṇo,"
    },
    {
      "id": "ja484:2.2",
      "pali": "yo nesaṁ sabbasundaro;"
    },
    {
      "id": "ja484:2.3",
      "pali": "Bhutvā sāliṁ yathākāmaṁ,"
    },
    {
      "id": "ja484:2.4",
      "pali": "tuṇḍenādāya gacchati”."
    },
    {
      "id": "ja484:3.1",
      "pali": "“Oḍḍentu vāḷapāsāni,"
    },
    {
      "id": "ja484:3.2",
      "pali": "yathā bajjhetha so dijo;"
    },
    {
      "id": "ja484:3.3",
      "pali": "Jīvañca naṁ gahetvāna,"
    },
    {
      "id": "ja484:3.4",
      "pali": "ānayehi mamantike”."
    },
    {
      "id": "ja484:4.1",
      "pali": "“Ete bhutvā pivitvā ca,"
    },
    {
      "id": "ja484:4.2",
      "pali": "pakkamanti vihaṅgamā;"
    },
    {
      "id": "ja484:4.3",
      "pali": "Eko baddhosmi pāsena,"
    },
    {
      "id": "ja484:4.4",
      "pali": "kiṁ pāpaṁ pakataṁ mayā”."
    },
    {
      "id": "ja484:5.1",
      "pali": "“Udaraṁ nūna aññesaṁ,"
    },
    {
      "id": "ja484:5.2",
      "pali": "suva accodaraṁ tava;"
    },
    {
      "id": "ja484:5.3",
      "pali": "Bhutvā sāliṁ yathākāmaṁ,"
    },
    {
      "id": "ja484:5.4",
      "pali": "tuṇḍenādāya gacchasi."
    },
    {
      "id": "ja484:6.1",
      "pali": "Koṭṭhaṁ nu tattha pūresi,"
    },
    {
      "id": "ja484:6.2",
      "pali": "suva veraṁ nu te mayā;"
    },
    {
      "id": "ja484:6.3",
      "pali": "Puṭṭho me samma akkhāhi,"
    },
    {
      "id": "ja484:6.4",
      "pali": "kuhiṁ sāliṁ nidāhasi”."
    },
    {
      "id": "ja484:7.1",
      "pali": "“Na me veraṁ tayā saddhiṁ,"
    },
    {
      "id": "ja484:7.2",
      "pali": "koṭṭho mayhaṁ na vijjati;"
    },
    {
      "id": "ja484:7.3",
      "pali": "Iṇaṁ muñcāmiṇaṁ dammi,"
    },
    {
      "id": "ja484:7.4",
      "pali": "sampatto koṭasimbaliṁ;"
    },
    {
      "id": "ja484:7.5",
      "pali": "Nidhimpi tattha nidahāmi,"
    },
    {
      "id": "ja484:7.6",
      "pali": "evaṁ jānāhi kosiya”."
    },
    {
      "id": "ja484:8.1",
      "pali": "“Kīdisaṁ te iṇadānaṁ,"
    },
    {
      "id": "ja484:8.2",
      "pali": "iṇamokkho ca kīdiso;"
    },
    {
      "id": "ja484:8.3",
      "pali": "Nidhinidhānamakkhāhi,"
    },
    {
      "id": "ja484:8.4",
      "pali": "atha pāsā pamokkhasi”."
    },
    {
      "id": "ja484:9.1",
      "pali": "“Ajātapakkhā taruṇā,"
    },
    {
      "id": "ja484:9.2",
      "pali": "puttakā mayha kosiya;"
    },
    {
      "id": "ja484:9.3",
      "pali": "Te maṁ bhatā bharissanti,"
    },
    {
      "id": "ja484:9.4",
      "pali": "tasmā tesaṁ iṇaṁ dade."
    },
    {
      "id": "ja484:10.1",
      "pali": "Mātā pitā ca me vuddhā,"
    },
    {
      "id": "ja484:10.2",
      "pali": "jiṇṇakā gatayobbanā;"
    },
    {
      "id": "ja484:10.3",
      "pali": "Tesaṁ tuṇḍena hātūna,"
    },
    {
      "id": "ja484:10.4",
      "pali": "muñce pubbakataṁ iṇaṁ."
    },
    {
      "id": "ja484:11.1",
      "pali": "Aññepi tattha sakuṇā,"
    },
    {
      "id": "ja484:11.2",
      "pali": "khīṇapakkhā sudubbalā;"
    },
    {
      "id": "ja484:11.3",
      "pali": "Tesaṁ puññatthiko dammi,"
    },
    {
      "id": "ja484:11.4",
      "pali": "taṁ nidhiṁ āhu paṇḍitā."
    },
    {
      "id": "ja484:12.1",
      "pali": "Īdisaṁ me iṇadānaṁ,"
    },
    {
      "id": "ja484:12.2",
      "pali": "iṇamokkho ca īdiso;"
    },
    {
      "id": "ja484:12.3",
      "pali": "Nidhinidhānamakkhāmi,"
    },
    {
      "id": "ja484:12.4",
      "pali": "evaṁ jānāhi kosiya”."
    },
    {
      "id": "ja484:13.1",
      "pali": "“Bhaddako vatayaṁ pakkhī,"
    },
    {
      "id": "ja484:13.2",
      "pali": "dijo paramadhammiko;"
    },
    {
      "id": "ja484:13.3",
      "pali": "Ekaccesu manussesu,"
    },
    {
      "id": "ja484:13.4",
      "pali": "ayaṁ dhammo na vijjati."
    },
    {
      "id": "ja484:14.1",
      "pali": "Bhuñja sāliṁ yathākāmaṁ,"
    },
    {
      "id": "ja484:14.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja484:14.3",
      "pali": "Punāpi suva passemu,"
    },
    {
      "id": "ja484:14.4",
      "pali": "piyaṁ me tava dassanaṁ”."
    },
    {
      "id": "ja484:15.1",
      "pali": "“Bhuttañca pītañca tavassamamhi,"
    },
    {
      "id": "ja484:15.2",
      "pali": "Ratī ca no kosiya te sakāse;"
    },
    {
      "id": "ja484:15.3",
      "pali": "Nikkhittadaṇḍesu dadāhi dānaṁ,"
    },
    {
      "id": "ja484:15.4",
      "pali": "Jiṇṇe ca mātāpitaro bharassu”."
    },
    {
      "id": "ja484:16.1",
      "pali": "“Lakkhī vata me udapādi ajja,"
    },
    {
      "id": "ja484:16.2",
      "pali": "Yo addasāsiṁ pavaraṁ dijānaṁ;"
    },
    {
      "id": "ja484:16.3",
      "pali": "Suvassa sutvāna subhāsitāni,"
    },
    {
      "id": "ja484:16.4",
      "pali": "Kāhāmi puññāni anappakāni”."
    },
    {
      "id": "ja484:17.1",
      "pali": "So kosiyo attamano udaggo,"
    },
    {
      "id": "ja484:17.2",
      "pali": "Annañca pānañcabhisaṅkharitvā;"
    },
    {
      "id": "ja484:17.3",
      "pali": "Annena pānena pasannacitto,"
    },
    {
      "id": "ja484:17.4",
      "pali": "Santappayi samaṇabrāhmaṇe cāti."
    },
    {
      "id": "ja484:18.1",
      "pali": "Sālikedārajātakaṁ paṭhamaṁ."
    }
  ]
}
