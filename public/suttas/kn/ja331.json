{
  "uid": "ja331",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja331:1.1",
      "pali": "“Yo ve kāle asampatte,"
    },
    {
      "id": "ja331:1.2",
      "pali": "ativelaṁ pabhāsati;"
    },
    {
      "id": "ja331:1.3",
      "pali": "Evaṁ so nihato seti,"
    },
    {
      "id": "ja331:1.4",
      "pali": "kokilāyiva atrajo."
    },
    {
      "id": "ja331:2.1",
      "pali": "Na hi satthaṁ sunisitaṁ,"
    },
    {
      "id": "ja331:2.2",
      "pali": "visaṁ halāhalāmiva;"
    },
    {
      "id": "ja331:2.3",
      "pali": "Evaṁ nikaṭṭhe pāteti,"
    },
    {
      "id": "ja331:2.4",
      "pali": "vācā dubbhāsitā yathā."
    },
    {
      "id": "ja331:3.1",
      "pali": "Tasmā kāle akāle vā,"
    },
    {
      "id": "ja331:3.2",
      "pali": "vācaṁ rakkheyya paṇḍito;"
    },
    {
      "id": "ja331:3.3",
      "pali": "Nātivelaṁ pabhāseyya,"
    },
    {
      "id": "ja331:3.4",
      "pali": "api attasamamhi vā."
    },
    {
      "id": "ja331:4.1",
      "pali": "Yo ca kāle mitaṁ bhāse,"
    },
    {
      "id": "ja331:4.2",
      "pali": "matipubbo vicakkhaṇo;"
    },
    {
      "id": "ja331:4.3",
      "pali": "Sabbe amitte ādeti,"
    },
    {
      "id": "ja331:4.4",
      "pali": "supaṇṇo uragāmivā”ti."
    },
    {
      "id": "ja331:5.1",
      "pali": "Kokilajātakaṁ paṭhamaṁ."
    }
  ]
}
