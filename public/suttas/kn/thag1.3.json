{
  "uid": "thag1.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.3:1.1",
      "pali": "“Paññaṁ imaṁ passa tathāgatānaṁ,"
    },
    {
      "id": "thag1.3:1.2",
      "pali": "Aggi yathā pajjalito nisīthe;"
    },
    {
      "id": "thag1.3:1.3",
      "pali": "Ālokadā cakkhudadā bhavanti,"
    },
    {
      "id": "thag1.3:1.4",
      "pali": "Ye āgatānaṁ vinayanti kaṅkhan”ti."
    },
    {
      "id": "thag1.3:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā kaṅkhārevato thero gāthaṁ abhāsitthāti."
    }
  ]
}
