{
  "uid": "thag2.48",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.48:1.1",
      "pali": "“Saṁsaraṁ dīghamaddhānaṁ,"
    },
    {
      "id": "thag2.48:1.2",
      "pali": "gatīsu parivattisaṁ;"
    },
    {
      "id": "thag2.48:1.3",
      "pali": "Apassaṁ ariyasaccāni,"
    },
    {
      "id": "thag2.48:1.4",
      "pali": "andhabhūto puthujjano."
    },
    {
      "id": "thag2.48:2.1",
      "pali": "Tassa me appamattassa,"
    },
    {
      "id": "thag2.48:2.2",
      "pali": "saṁsārā vinaḷīkatā;"
    },
    {
      "id": "thag2.48:2.3",
      "pali": "Sabbā gatī samucchinnā,"
    },
    {
      "id": "thag2.48:2.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag2.48:2.5",
      "pali": "… Vajjito thero …."
    }
  ]
}
