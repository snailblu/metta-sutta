{
  "uid": "vv43",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv43:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv43:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv43:1.3",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv43:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv43:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv43:2.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv43:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv43:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv43:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv43:4.1",
      "pali": "“Ahaṁ andhakavindamhi,"
    },
    {
      "id": "vv43:4.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "vv43:4.3",
      "pali": "Adāsiṁ kolasampākaṁ,"
    },
    {
      "id": "vv43:4.4",
      "pali": "kañjikaṁ teladhūpitaṁ."
    },
    {
      "id": "vv43:5.1",
      "pali": "Pipphalyā lasuṇena ca,"
    },
    {
      "id": "vv43:5.2",
      "pali": "missaṁ lāmañjakena ca;"
    },
    {
      "id": "vv43:5.3",
      "pali": "Adāsiṁ ujubhūtasmiṁ,"
    },
    {
      "id": "vv43:5.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "vv43:6.1",
      "pali": "Yā mahesittaṁ kāreyya,"
    },
    {
      "id": "vv43:6.2",
      "pali": "cakkavattissa rājino;"
    },
    {
      "id": "vv43:6.3",
      "pali": "Nārī sabbaṅgakalyāṇī,"
    },
    {
      "id": "vv43:6.4",
      "pali": "bhattu cānomadassikā;"
    },
    {
      "id": "vv43:6.5",
      "pali": "Ekassa kañjikadānassa,"
    },
    {
      "id": "vv43:6.6",
      "pali": "kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "vv43:7.1",
      "pali": "Sataṁ nikkhā sataṁ assā,"
    },
    {
      "id": "vv43:7.2",
      "pali": "sataṁ assatarīrathā;"
    },
    {
      "id": "vv43:7.3",
      "pali": "Sataṁ kaññāsahassāni,"
    },
    {
      "id": "vv43:7.4",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "vv43:7.5",
      "pali": "Ekassa kañjikadānassa,"
    },
    {
      "id": "vv43:7.6",
      "pali": "kalaṁ nāgghanti soḷasiṁ."
    },
    {
      "id": "vv43:8.1",
      "pali": "Sataṁ hemavatā nāgā,"
    },
    {
      "id": "vv43:8.2",
      "pali": "īsādantā urūḷhavā;"
    },
    {
      "id": "vv43:8.3",
      "pali": "Suvaṇṇakacchā mātaṅgā,"
    },
    {
      "id": "vv43:8.4",
      "pali": "hemakappanavāsasā;"
    },
    {
      "id": "vv43:8.5",
      "pali": "Ekassa kañjikadānassa,"
    },
    {
      "id": "vv43:8.6",
      "pali": "kalaṁ nāgghanti soḷasiṁ."
    },
    {
      "id": "vv43:9.1",
      "pali": "Catunnamapi dīpānaṁ,"
    },
    {
      "id": "vv43:9.2",
      "pali": "issaraṁ yodha kāraye;"
    },
    {
      "id": "vv43:9.3",
      "pali": "Ekassa kañjikadānassa,"
    },
    {
      "id": "vv43:9.4",
      "pali": "kalaṁ nāgghati soḷasin”ti."
    },
    {
      "id": "vv43:10.1",
      "pali": "Kañjikadāyikāvimānaṁ pañcamaṁ."
    }
  ]
}
