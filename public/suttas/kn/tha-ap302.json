{
  "uid": "tha-ap302",
  "title": "Anusaṁsāvakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap302:1.1",
      "pali": "“Piṇḍāya caramānāhaṁ,"
    },
    {
      "id": "tha-ap302:1.2",
      "pali": "vipassimaddasaṁ jinaṁ;"
    },
    {
      "id": "tha-ap302:1.3",
      "pali": "Uḷuṅgabhikkhaṁ pādāsiṁ,"
    },
    {
      "id": "tha-ap302:1.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap302:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap302:2.2",
      "pali": "abhivādesahaṁ tadā;"
    },
    {
      "id": "tha-ap302:2.3",
      "pali": "Anusaṁsāvayiṁ buddhaṁ,"
    },
    {
      "id": "tha-ap302:2.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "tha-ap302:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap302:3.2",
      "pali": "anusaṁsāvayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap302:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap302:3.4",
      "pali": "anusaṁsāvanā phalaṁ."
    },
    {
      "id": "tha-ap302:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap302:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap302:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap302:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā anusaṁsāvako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap302:6.1",
      "pali": "Anusaṁsāvakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap302:6.2",
      "pali": "Citakapūjakavaggo tiṁsatimo."
    },
    {
      "id": "tha-ap302:7.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap302:8.1",
      "pali": "Citakaṁ pārichatto ca,"
    },
    {
      "id": "tha-ap302:8.2",
      "pali": "saddagosīsasantharaṁ;"
    },
    {
      "id": "tha-ap302:8.3",
      "pali": "Pādo padesaṁ saraṇaṁ,"
    },
    {
      "id": "tha-ap302:8.4",
      "pali": "ambo saṁsāvakopi ca;"
    },
    {
      "id": "tha-ap302:8.5",
      "pali": "Aṭṭhatālīsa gāthāyo,"
    },
    {
      "id": "tha-ap302:8.6",
      "pali": "gaṇitāyo vibhāvibhi."
    },
    {
      "id": "tha-ap302:9.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap302:10.1",
      "pali": "Kaṇikāro hatthidado,"
    },
    {
      "id": "tha-ap302:10.2",
      "pali": "ālambaṇudakāsanaṁ;"
    },
    {
      "id": "tha-ap302:10.3",
      "pali": "Tuvaraṁ thomako ceva,"
    },
    {
      "id": "tha-ap302:10.4",
      "pali": "ukkhepaṁ sīsupadhānaṁ."
    },
    {
      "id": "tha-ap302:11.1",
      "pali": "Paṇṇado citapūjī ca,"
    },
    {
      "id": "tha-ap302:11.2",
      "pali": "gāthāyo ceva sabbaso;"
    },
    {
      "id": "tha-ap302:11.3",
      "pali": "Cattāri ca satānīha,"
    },
    {
      "id": "tha-ap302:11.4",
      "pali": "ekapaññāsameva ca."
    },
    {
      "id": "tha-ap302:12.1",
      "pali": "Pañcavīsasatā sabbā,"
    },
    {
      "id": "tha-ap302:12.2",
      "pali": "dvāsattati taduttari;"
    },
    {
      "id": "tha-ap302:12.3",
      "pali": "Tisataṁ apadānānaṁ,"
    },
    {
      "id": "tha-ap302:12.4",
      "pali": "gaṇitā atthadassibhi."
    },
    {
      "id": "tha-ap302:13.1",
      "pali": "Kaṇikāravaggadasakaṁ."
    },
    {
      "id": "tha-ap302:14.1",
      "pali": "Tatiyasatakaṁ samattaṁ."
    }
  ]
}
