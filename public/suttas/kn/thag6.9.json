{
  "uid": "thag6.9",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.9:1.1",
      "pali": "“Jātimadena mattohaṁ,"
    },
    {
      "id": "thag6.9:1.2",
      "pali": "bhogaissariyena ca;"
    },
    {
      "id": "thag6.9:1.3",
      "pali": "Saṇṭhānavaṇṇarūpena,"
    },
    {
      "id": "thag6.9:1.4",
      "pali": "madamatto acārihaṁ."
    },
    {
      "id": "thag6.9:2.1",
      "pali": "Nāttano samakaṁ kañci,"
    },
    {
      "id": "thag6.9:2.2",
      "pali": "atirekaṁ ca maññisaṁ;"
    },
    {
      "id": "thag6.9:2.3",
      "pali": "Atimānahato bālo,"
    },
    {
      "id": "thag6.9:2.4",
      "pali": "patthaddho ussitaddhajo."
    },
    {
      "id": "thag6.9:3.1",
      "pali": "Mātaraṁ pitarañcāpi,"
    },
    {
      "id": "thag6.9:3.2",
      "pali": "aññepi garusammate;"
    },
    {
      "id": "thag6.9:3.3",
      "pali": "Na kañci abhivādesiṁ,"
    },
    {
      "id": "thag6.9:3.4",
      "pali": "mānatthaddho anādaro."
    },
    {
      "id": "thag6.9:4.1",
      "pali": "Disvā vināyakaṁ aggaṁ,"
    },
    {
      "id": "thag6.9:4.2",
      "pali": "sārathīnaṁ varuttamaṁ;"
    },
    {
      "id": "thag6.9:4.3",
      "pali": "Tapantamiva ādiccaṁ,"
    },
    {
      "id": "thag6.9:4.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "thag6.9:5.1",
      "pali": "Mānaṁ madañca chaḍḍetvā,"
    },
    {
      "id": "thag6.9:5.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "thag6.9:5.3",
      "pali": "Sirasā abhivādesiṁ,"
    },
    {
      "id": "thag6.9:5.4",
      "pali": "sabbasattānamuttamaṁ."
    },
    {
      "id": "thag6.9:6.1",
      "pali": "Atimāno ca omāno,"
    },
    {
      "id": "thag6.9:6.2",
      "pali": "pahīnā susamūhatā;"
    },
    {
      "id": "thag6.9:6.3",
      "pali": "Asmimāno samucchinno,"
    },
    {
      "id": "thag6.9:6.4",
      "pali": "sabbe mānavidhā hatā”ti."
    },
    {
      "id": "thag6.9:6.5",
      "pali": "… Jento purohitaputto thero …."
    }
  ]
}
