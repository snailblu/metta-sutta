{
  "uid": "ja303",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja303:1.1",
      "pali": "“Anuttare kāmaguṇe samiddhe,"
    },
    {
      "id": "ja303:1.2",
      "pali": "Bhutvāna pubbe vasī ekarāja;"
    },
    {
      "id": "ja303:1.3",
      "pali": "So dāni dugge narakamhi khitto,"
    },
    {
      "id": "ja303:1.4",
      "pali": "Nappajjahe vaṇṇabalaṁ purāṇaṁ”."
    },
    {
      "id": "ja303:2.1",
      "pali": "“Pubbeva khantī ca tapo ca mayhaṁ,"
    },
    {
      "id": "ja303:2.2",
      "pali": "Sampatthitā dubbhisena ahosi;"
    },
    {
      "id": "ja303:2.3",
      "pali": "Taṁ dāni laddhāna kathaṁ nu rāja,"
    },
    {
      "id": "ja303:2.4",
      "pali": "Jahe ahaṁ vaṇṇabalaṁ purāṇaṁ."
    },
    {
      "id": "ja303:3.1",
      "pali": "Sabbā kirevaṁ pariniṭṭhitāni,"
    },
    {
      "id": "ja303:3.2",
      "pali": "Yasassinaṁ paññavantaṁ visayha;"
    },
    {
      "id": "ja303:3.3",
      "pali": "Yaso ca laddhā purimaṁ uḷāraṁ,"
    },
    {
      "id": "ja303:3.4",
      "pali": "Nappajjahe vaṇṇabalaṁ purāṇaṁ."
    },
    {
      "id": "ja303:4.1",
      "pali": "Panujja dukkhena sukhaṁ janinda,"
    },
    {
      "id": "ja303:4.2",
      "pali": "Sukhena vā dukkhamasayhasāhi;"
    },
    {
      "id": "ja303:4.3",
      "pali": "Ubhayattha santo abhinibbutattā,"
    },
    {
      "id": "ja303:4.4",
      "pali": "Sukhe ca dukkhe ca bhavanti tulyā”ti."
    },
    {
      "id": "ja303:5.1",
      "pali": "Ekarājajātakaṁ tatiyaṁ."
    }
  ]
}
