{
  "uid": "ja190",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja190:1.1",
      "pali": "“Passa saddhāya sīlassa,"
    },
    {
      "id": "ja190:1.2",
      "pali": "cāgassa ca ayaṁ phalaṁ;"
    },
    {
      "id": "ja190:1.3",
      "pali": "Nāgo nāvāya vaṇṇena,"
    },
    {
      "id": "ja190:1.4",
      "pali": "saddhaṁ vahatupāsakaṁ."
    },
    {
      "id": "ja190:2.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "ja190:2.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "ja190:2.3",
      "pali": "Satañhi sannivāsena,"
    },
    {
      "id": "ja190:2.4",
      "pali": "sotthiṁ gacchati nhāpito”ti."
    },
    {
      "id": "ja190:3.1",
      "pali": "Sīlānisaṁsajātakaṁ dasamaṁ."
    },
    {
      "id": "ja190:3.2",
      "pali": "Asadisavaggo catuttho."
    },
    {
      "id": "ja190:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja190:5.1",
      "pali": "Dhanuggaha kuñjara apparaso,"
    },
    {
      "id": "ja190:5.2",
      "pali": "Giridattamanāvilacittavaraṁ;"
    },
    {
      "id": "ja190:5.3",
      "pali": "Dadhivāhana jambūka sīhanakho,"
    },
    {
      "id": "ja190:5.4",
      "pali": "Haritayava nāgavarena dasāti."
    }
  ]
}
