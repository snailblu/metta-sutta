{
  "uid": "ja136",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja136:1.1",
      "pali": "“Yaṁ laddhaṁ tena tuṭṭhabbaṁ,"
    },
    {
      "id": "ja136:1.2",
      "pali": "Atilobho hi pāpako;"
    },
    {
      "id": "ja136:1.3",
      "pali": "Haṁsarājaṁ gahetvāna,"
    },
    {
      "id": "ja136:1.4",
      "pali": "Suvaṇṇā parihāyathā”ti."
    },
    {
      "id": "ja136:2.1",
      "pali": "Suvaṇṇahaṁsajātakaṁ chaṭṭhaṁ."
    }
  ]
}
