{
  "uid": "tha-ap91",
  "title": "Bodhisiñcakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap91:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap91:1.2",
      "pali": "mahābodhimaho ahu;"
    },
    {
      "id": "tha-ap91:1.3",
      "pali": "Pabbajjupagato santo,"
    },
    {
      "id": "tha-ap91:1.4",
      "pali": "upagacchiṁ ahaṁ tadā."
    },
    {
      "id": "tha-ap91:2.1",
      "pali": "Kusumodakamādāya,"
    },
    {
      "id": "tha-ap91:2.2",
      "pali": "bodhiyā okiriṁ ahaṁ;"
    },
    {
      "id": "tha-ap91:2.3",
      "pali": "Mocayissati no mutto,"
    },
    {
      "id": "tha-ap91:2.4",
      "pali": "nibbāpessati nibbuto."
    },
    {
      "id": "tha-ap91:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap91:3.2",
      "pali": "yaṁ bodhimabhisiñcayiṁ;"
    },
    {
      "id": "tha-ap91:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap91:3.4",
      "pali": "bodhisiñcāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap91:4.1",
      "pali": "Tettiṁse vattamānamhi,"
    },
    {
      "id": "tha-ap91:4.2",
      "pali": "kappe āsuṁ janādhipā;"
    },
    {
      "id": "tha-ap91:4.3",
      "pali": "Udakasecanā nāma,"
    },
    {
      "id": "tha-ap91:4.4",
      "pali": "aṭṭhete cakkavattino."
    },
    {
      "id": "tha-ap91:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap91:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap91:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap91:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā bodhisiñcako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap91:7.1",
      "pali": "Bodhisiñcakattherassāpadānaṁ navamaṁ."
    }
  ]
}
