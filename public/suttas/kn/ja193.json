{
  "uid": "ja193",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja193:1.1",
      "pali": "“Ayameva sā ahamapi so anañño,"
    },
    {
      "id": "ja193:1.2",
      "pali": "Ayameva so hatthacchinno anañño;"
    },
    {
      "id": "ja193:1.3",
      "pali": "Yamāha ‘komārapatī maman’ti,"
    },
    {
      "id": "ja193:1.4",
      "pali": "Vajjhitthiyo natthi itthīsu saccaṁ."
    },
    {
      "id": "ja193:2.1",
      "pali": "Imañca jammaṁ musalena hantvā,"
    },
    {
      "id": "ja193:2.2",
      "pali": "Luddaṁ chavaṁ paradārūpaseviṁ;"
    },
    {
      "id": "ja193:2.3",
      "pali": "Imissā ca naṁ pāpapatibbatāya,"
    },
    {
      "id": "ja193:2.4",
      "pali": "Jīvantiyā chindatha kaṇṇanāsan”ti."
    },
    {
      "id": "ja193:3.1",
      "pali": "Cūḷapadumajātakaṁ tatiyaṁ."
    }
  ]
}
