{
  "uid": "ja200",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja200:1.1",
      "pali": "“Sarīradabyaṁ vuḍḍhabyaṁ,"
    },
    {
      "id": "ja200:1.2",
      "pali": "sojaccaṁ sādhusīliyaṁ;"
    },
    {
      "id": "ja200:1.3",
      "pali": "Brāhmaṇaṁ teva pucchāma,"
    },
    {
      "id": "ja200:1.4",
      "pali": "kaṁ nu tesaṁ vanimhase”."
    },
    {
      "id": "ja200:2.1",
      "pali": "“Attho atthi sarīrasmiṁ,"
    },
    {
      "id": "ja200:2.2",
      "pali": "vuḍḍhabyassa namo kare;"
    },
    {
      "id": "ja200:2.3",
      "pali": "Attho atthi sujātasmiṁ,"
    },
    {
      "id": "ja200:2.4",
      "pali": "sīlaṁ asmāka ruccatī”ti."
    },
    {
      "id": "ja200:3.1",
      "pali": "Sādhusīlajātakaṁ dasamaṁ."
    },
    {
      "id": "ja200:3.2",
      "pali": "Ruhakavaggo pañcamo."
    },
    {
      "id": "ja200:4.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja200:5.1",
      "pali": "Apiruhaka rūpavatī musalo,"
    },
    {
      "id": "ja200:5.2",
      "pali": "Pavasanti sapañcamapokkharaṇī;"
    },
    {
      "id": "ja200:5.3",
      "pali": "Atha muttimavāṇija umhayate,"
    },
    {
      "id": "ja200:5.4",
      "pali": "Ciraāgata koṭṭha sarīra dasāti."
    }
  ]
}
