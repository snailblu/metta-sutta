{
  "uid": "tha-ap126",
  "title": "Gandhodakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap126:1.1",
      "pali": "“Nisajja pāsādavare,"
    },
    {
      "id": "tha-ap126:1.2",
      "pali": "vipassiṁ addasaṁ jinaṁ;"
    },
    {
      "id": "tha-ap126:1.3",
      "pali": "Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap126:1.4",
      "pali": "sabbaññuṁ tamanāsakaṁ."
    },
    {
      "id": "tha-ap126:2.1",
      "pali": "Pāsādassāvidūre ca,"
    },
    {
      "id": "tha-ap126:2.2",
      "pali": "gacchati lokanāyako;"
    },
    {
      "id": "tha-ap126:2.3",
      "pali": "Pabhā niddhāvate tassa,"
    },
    {
      "id": "tha-ap126:2.4",
      "pali": "yathā ca sataraṁsino."
    },
    {
      "id": "tha-ap126:3.1",
      "pali": "Gandhodakañca paggayha,"
    },
    {
      "id": "tha-ap126:3.2",
      "pali": "buddhaseṭṭhaṁ samokiriṁ;"
    },
    {
      "id": "tha-ap126:3.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap126:3.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap126:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap126:4.2",
      "pali": "yaṁ gandhodakamākiriṁ;"
    },
    {
      "id": "tha-ap126:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap126:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap126:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap126:5.2",
      "pali": "sugandho nāma khattiyo;"
    },
    {
      "id": "tha-ap126:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap126:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap126:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap126:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap126:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap126:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhodakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap126:8.1",
      "pali": "Gandhodakiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
