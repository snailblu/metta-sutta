{
  "uid": "ja328",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja328:1.1",
      "pali": "“Bahūnaṁ vijjatī bhotī,"
    },
    {
      "id": "ja328:1.2",
      "pali": "tehi me kiṁ bhavissati;"
    },
    {
      "id": "ja328:1.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja328:1.4",
      "pali": "piyaṁ sammillahāsiniṁ."
    },
    {
      "id": "ja328:2.1",
      "pali": "Taṁ tañce anusoceyya,"
    },
    {
      "id": "ja328:2.2",
      "pali": "yaṁ yaṁ tassa na vijjati;"
    },
    {
      "id": "ja328:2.3",
      "pali": "Attānamanusoceyya,"
    },
    {
      "id": "ja328:2.4",
      "pali": "sadā maccuvasaṁ pataṁ."
    },
    {
      "id": "ja328:3.1",
      "pali": "Na heva ṭhitaṁ nāsīnaṁ,"
    },
    {
      "id": "ja328:3.2",
      "pali": "Na sayānaṁ na paddhaguṁ;"
    },
    {
      "id": "ja328:3.3",
      "pali": "Yāva byāti nimisati,"
    },
    {
      "id": "ja328:3.4",
      "pali": "Tatrāpi rasatī vayo."
    },
    {
      "id": "ja328:4.1",
      "pali": "Tatthattani vatappaddhe,"
    },
    {
      "id": "ja328:4.2",
      "pali": "vinābhāve asaṁsaye;"
    },
    {
      "id": "ja328:4.3",
      "pali": "Bhūtaṁ sesaṁ dayitabbaṁ,"
    },
    {
      "id": "ja328:4.4",
      "pali": "vītaṁ ananusociyan”ti."
    },
    {
      "id": "ja328:5.1",
      "pali": "Ananusociyajātakaṁ aṭṭhamaṁ."
    }
  ]
}
