{
  "uid": "ne1",
  "title": "Namo tassa Bhagavato Arahato Sammāsambuddhassa.",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ne1:1.1",
      "pali": "Yaṁ loko pūjayate,"
    },
    {
      "id": "ne1:1.2",
      "pali": "Salokapālo sadā namassati ca;"
    },
    {
      "id": "ne1:1.3",
      "pali": "Tasseta sāsanavaraṁ,"
    },
    {
      "id": "ne1:1.4",
      "pali": "Vidūhi ñeyyaṁ naravarassa."
    },
    {
      "id": "ne1:2.1",
      "pali": "Dvādasa padāni suttaṁ,"
    },
    {
      "id": "ne1:2.2",
      "pali": "Taṁ sabbaṁ byañjanañca attho ca;"
    },
    {
      "id": "ne1:2.3",
      "pali": "Taṁ viññeyyaṁ ubhayaṁ,"
    },
    {
      "id": "ne1:2.4",
      "pali": "Ko attho byañjanaṁ katamaṁ."
    },
    {
      "id": "ne1:3.1",
      "pali": "Soḷasahārā netti,"
    },
    {
      "id": "ne1:3.2",
      "pali": "Pañcanayā sāsanassa pariyeṭṭhi;"
    },
    {
      "id": "ne1:3.3",
      "pali": "Aṭṭhārasamūlapadā,"
    },
    {
      "id": "ne1:3.4",
      "pali": "Mahakaccānena niddiṭṭhā."
    },
    {
      "id": "ne1:4.1",
      "pali": "Hārā byañjanavicayo,"
    },
    {
      "id": "ne1:4.2",
      "pali": "Suttassa nayā tayo ca suttattho;"
    },
    {
      "id": "ne1:4.3",
      "pali": "Ubhayaṁ pariggahītaṁ,"
    },
    {
      "id": "ne1:4.4",
      "pali": "Vuccati suttaṁ yathāsuttaṁ."
    },
    {
      "id": "ne1:5.1",
      "pali": "Yā ceva desanā yañca,"
    },
    {
      "id": "ne1:5.2",
      "pali": "Desitaṁ ubhayameva viññeyyaṁ;"
    },
    {
      "id": "ne1:5.3",
      "pali": "Tatrāyamānupubbī,"
    },
    {
      "id": "ne1:5.4",
      "pali": "Navavidhasuttantapariyeṭṭhīti."
    },
    {
      "id": "ne1:5.5",
      "pali": "Saṅgahavāro."
    }
  ]
}
