{
  "uid": "tha-ap130",
  "title": "8 Ñāṇasaññikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap130:1.1",
      "pali": "“Pabbate himavantamhi,"
    },
    {
      "id": "tha-ap130:1.2",
      "pali": "vasāmi pabbatantare;"
    },
    {
      "id": "tha-ap130:1.3",
      "pali": "Pulinaṁ sobhanaṁ disvā,"
    },
    {
      "id": "tha-ap130:1.4",
      "pali": "buddhaseṭṭhaṁ anussariṁ."
    },
    {
      "id": "tha-ap130:2.1",
      "pali": "Ñāṇe upanidhā natthi,"
    },
    {
      "id": "tha-ap130:2.2",
      "pali": "saṅkhāraṁ natthi satthuno;"
    },
    {
      "id": "tha-ap130:2.3",
      "pali": "Sabbadhammaṁ abhiññāya,"
    },
    {
      "id": "tha-ap130:2.4",
      "pali": "ñāṇena adhimuccati."
    },
    {
      "id": "tha-ap130:3.1",
      "pali": "Namo te purisājañña,"
    },
    {
      "id": "tha-ap130:3.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap130:3.3",
      "pali": "Ñāṇena te samo natthi,"
    },
    {
      "id": "tha-ap130:3.4",
      "pali": "yāvatā ñāṇamuttamaṁ."
    },
    {
      "id": "tha-ap130:4.1",
      "pali": "Ñāṇe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap130:4.2",
      "pali": "kappaṁ saggamhi modahaṁ;"
    },
    {
      "id": "tha-ap130:4.3",
      "pali": "Avasesesu kappesu,"
    },
    {
      "id": "tha-ap130:4.4",
      "pali": "kusalaṁ caritaṁ mayā."
    },
    {
      "id": "tha-ap130:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap130:5.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap130:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap130:5.4",
      "pali": "ñāṇasaññāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap130:6.1",
      "pali": "Ito sattatikappamhi,"
    },
    {
      "id": "tha-ap130:6.2",
      "pali": "eko pulinapupphiyo;"
    },
    {
      "id": "tha-ap130:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap130:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap130:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap130:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap130:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap130:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā ñāṇasaññiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap130:9.1",
      "pali": "Ñāṇasaññikattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
