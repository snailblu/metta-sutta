{
  "uid": "cp30",
  "title": "Saccapāramī 4",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp30:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp30:1.2",
      "pali": "maccharājā mahāsare;"
    },
    {
      "id": "cp30:1.3",
      "pali": "Uṇhe sūriyasantāpe,"
    },
    {
      "id": "cp30:1.4",
      "pali": "sare udaka khīyatha."
    },
    {
      "id": "cp30:2.1",
      "pali": "Tato kākā ca gijjhā ca,"
    },
    {
      "id": "cp30:2.2",
      "pali": "kaṅkā kulalasenakā;"
    },
    {
      "id": "cp30:2.3",
      "pali": "Bhakkhayanti divārattiṁ,"
    },
    {
      "id": "cp30:2.4",
      "pali": "macche upanisīdiya."
    },
    {
      "id": "cp30:3.1",
      "pali": "Evaṁ cintesahaṁ tattha,"
    },
    {
      "id": "cp30:3.2",
      "pali": "saha ñātīhi pīḷito;"
    },
    {
      "id": "cp30:3.3",
      "pali": "‘Kena nu kho upāyena,"
    },
    {
      "id": "cp30:3.4",
      "pali": "ñātī dukkhā pamocaye’."
    },
    {
      "id": "cp30:4.1",
      "pali": "Vicintayitvā dhammatthaṁ,"
    },
    {
      "id": "cp30:4.2",
      "pali": "saccaṁ addasa passayaṁ;"
    },
    {
      "id": "cp30:4.3",
      "pali": "Sacce ṭhatvā pamocesiṁ,"
    },
    {
      "id": "cp30:4.4",
      "pali": "ñātīnaṁ taṁ atikkhayaṁ."
    },
    {
      "id": "cp30:5.1",
      "pali": "Anussaritvā sataṁ dhammaṁ,"
    },
    {
      "id": "cp30:5.2",
      "pali": "paramatthaṁ vicintayaṁ;"
    },
    {
      "id": "cp30:5.3",
      "pali": "Akāsiṁ saccakiriyaṁ,"
    },
    {
      "id": "cp30:5.4",
      "pali": "yaṁ loke dhuvasassataṁ."
    },
    {
      "id": "cp30:6.1",
      "pali": "‘Yato sarāmi attānaṁ,"
    },
    {
      "id": "cp30:6.2",
      "pali": "yato pattosmi viññutaṁ;"
    },
    {
      "id": "cp30:6.3",
      "pali": "Nābhijānāmi sañcicca,"
    },
    {
      "id": "cp30:6.4",
      "pali": "ekapāṇampi hiṁsitaṁ."
    },
    {
      "id": "cp30:7.1",
      "pali": "Etena saccavajjena,"
    },
    {
      "id": "cp30:7.2",
      "pali": "pajjunno abhivassatu;"
    },
    {
      "id": "cp30:7.3",
      "pali": "Abhitthanaya pajjunna,"
    },
    {
      "id": "cp30:7.4",
      "pali": "nidhiṁ kākassa nāsaya;"
    },
    {
      "id": "cp30:7.5",
      "pali": "Kākaṁ sokāya randhehi,"
    },
    {
      "id": "cp30:7.6",
      "pali": "macche sokā pamocaya’."
    },
    {
      "id": "cp30:8.1",
      "pali": "Saha kate saccavare,"
    },
    {
      "id": "cp30:8.2",
      "pali": "pajjunno abhigajjiya;"
    },
    {
      "id": "cp30:8.3",
      "pali": "Thalaṁ ninnañca pūrento,"
    },
    {
      "id": "cp30:8.4",
      "pali": "khaṇena abhivassatha."
    },
    {
      "id": "cp30:9.1",
      "pali": "Evarūpaṁ saccavaraṁ,"
    },
    {
      "id": "cp30:9.2",
      "pali": "katvā vīriyamuttamaṁ;"
    },
    {
      "id": "cp30:9.3",
      "pali": "Vassāpesiṁ mahāmeghaṁ,"
    },
    {
      "id": "cp30:9.4",
      "pali": "saccatejabalassito;"
    },
    {
      "id": "cp30:9.5",
      "pali": "Saccena me samo natthi,"
    },
    {
      "id": "cp30:9.6",
      "pali": "esā me saccapāramī”ti."
    },
    {
      "id": "cp30:10.1",
      "pali": "Maccharājacariyaṁ dasamaṁ."
    }
  ]
}
