{
  "uid": "ja450",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja450:1.1",
      "pali": "“Apacantāpi dicchanti,"
    },
    {
      "id": "ja450:1.2",
      "pali": "santo laddhāna bhojanaṁ;"
    },
    {
      "id": "ja450:1.3",
      "pali": "Kimeva tvaṁ pacamāno,"
    },
    {
      "id": "ja450:1.4",
      "pali": "yaṁ na dajjā na taṁ samaṁ."
    },
    {
      "id": "ja450:2.1",
      "pali": "Maccherā ca pamādā ca,"
    },
    {
      "id": "ja450:2.2",
      "pali": "evaṁ dānaṁ na diyyati;"
    },
    {
      "id": "ja450:2.3",
      "pali": "Puññaṁ ākaṅkhamānena,"
    },
    {
      "id": "ja450:2.4",
      "pali": "deyyaṁ hoti vijānatā."
    },
    {
      "id": "ja450:3.1",
      "pali": "Yasseva bhīto na dadāti maccharī,"
    },
    {
      "id": "ja450:3.2",
      "pali": "Tadevādadato bhayaṁ;"
    },
    {
      "id": "ja450:3.3",
      "pali": "Jighacchā ca pipāsā ca,"
    },
    {
      "id": "ja450:3.4",
      "pali": "Yassa bhāyati maccharī;"
    },
    {
      "id": "ja450:3.5",
      "pali": "Tameva bālaṁ phusati,"
    },
    {
      "id": "ja450:3.6",
      "pali": "Asmiṁ loke paramhi ca."
    },
    {
      "id": "ja450:4.1",
      "pali": "Tasmā vineyya maccheraṁ,"
    },
    {
      "id": "ja450:4.2",
      "pali": "dajjā dānaṁ malābhibhū;"
    },
    {
      "id": "ja450:4.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "ja450:4.4",
      "pali": "patiṭṭhā honti pāṇinaṁ”."
    },
    {
      "id": "ja450:5.1",
      "pali": "“Duddadaṁ dadamānānaṁ,"
    },
    {
      "id": "ja450:5.2",
      "pali": "dukkaraṁ kamma kubbataṁ;"
    },
    {
      "id": "ja450:5.3",
      "pali": "Asanto nānukubbanti,"
    },
    {
      "id": "ja450:5.4",
      "pali": "sataṁ dhammo durannayo."
    },
    {
      "id": "ja450:6.1",
      "pali": "Tasmā satañca asataṁ,"
    },
    {
      "id": "ja450:6.2",
      "pali": "nānā hoti ito gati;"
    },
    {
      "id": "ja450:6.3",
      "pali": "Asanto nirayaṁ yanti,"
    },
    {
      "id": "ja450:6.4",
      "pali": "santo saggaparāyaṇā”."
    },
    {
      "id": "ja450:7.1",
      "pali": "“Appasmeke pavecchanti,"
    },
    {
      "id": "ja450:7.2",
      "pali": "bahuneke na dicchare;"
    },
    {
      "id": "ja450:7.3",
      "pali": "Appasmā dakkhiṇā dinnā,"
    },
    {
      "id": "ja450:7.4",
      "pali": "sahassena samaṁ mitā”."
    },
    {
      "id": "ja450:8.1",
      "pali": "“Dhammaṁ care yopi samuñchakaṁ care,"
    },
    {
      "id": "ja450:8.2",
      "pali": "Dārañca posaṁ dadamappakasmiṁ;"
    },
    {
      "id": "ja450:8.3",
      "pali": "Sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "ja450:8.4",
      "pali": "Kalampi nāgghanti tathāvidhassa te”."
    },
    {
      "id": "ja450:9.1",
      "pali": "“Kenesa yañño vipulo mahagghato,"
    },
    {
      "id": "ja450:9.2",
      "pali": "Samena dinnassa na agghameti;"
    },
    {
      "id": "ja450:9.3",
      "pali": "Kathaṁ sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "ja450:9.4",
      "pali": "Kalampi nāgghanti tathāvidhassa te”."
    },
    {
      "id": "ja450:10.1",
      "pali": "“Dadanti heke visame niviṭṭhā,"
    },
    {
      "id": "ja450:10.2",
      "pali": "Chetvā vadhitvā atha socayitvā;"
    },
    {
      "id": "ja450:10.3",
      "pali": "Sā dakkhiṇā assumukhā sadaṇḍā,"
    },
    {
      "id": "ja450:10.4",
      "pali": "Samena dinnassa na agghameti;"
    },
    {
      "id": "ja450:10.5",
      "pali": "Evaṁ sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "ja450:10.6",
      "pali": "Kalampi nāgghanti tathāvidhassa te”ti."
    },
    {
      "id": "ja450:11.1",
      "pali": "Bilārakosiyajātakaṁ dvādasamaṁ."
    }
  ]
}
