{
  "uid": "tha-ap188",
  "title": "6 Bodhiupaṭṭhākattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap188:1.1",
      "pali": "“Nagare rammavatiyā,"
    },
    {
      "id": "tha-ap188:1.2",
      "pali": "āsiṁ murajavādako;"
    },
    {
      "id": "tha-ap188:1.3",
      "pali": "Niccupaṭṭhānayuttomhi,"
    },
    {
      "id": "tha-ap188:1.4",
      "pali": "gatohaṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap188:2.1",
      "pali": "Sāyaṁ pātaṁ upaṭṭhitvā,"
    },
    {
      "id": "tha-ap188:2.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap188:2.3",
      "pali": "Aṭṭhārasakappasate,"
    },
    {
      "id": "tha-ap188:2.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap188:3.1",
      "pali": "Pannarase kappasate,"
    },
    {
      "id": "tha-ap188:3.2",
      "pali": "ito āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap188:3.3",
      "pali": "Murajo nāma nāmena,"
    },
    {
      "id": "tha-ap188:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap188:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap188:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap188:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap188:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā bodhiupaṭṭhāko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap188:6.1",
      "pali": "Bodhiupaṭṭhākattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
