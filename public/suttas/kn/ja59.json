{
  "uid": "ja59",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja59:1.1",
      "pali": "“Dhame dhame nātidhame,"
    },
    {
      "id": "ja59:1.2",
      "pali": "atidhantañhi pāpakaṁ;"
    },
    {
      "id": "ja59:1.3",
      "pali": "Dhantena hi sataṁ laddhaṁ,"
    },
    {
      "id": "ja59:1.4",
      "pali": "atidhantena nāsitan”ti."
    },
    {
      "id": "ja59:2.1",
      "pali": "Bherivādakajātakaṁ navamaṁ."
    }
  ]
}
