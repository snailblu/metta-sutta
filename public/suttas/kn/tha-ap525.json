{
  "uid": "tha-ap525",
  "title": "Saraṇagamaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap525:1.1",
      "pali": "“Āruhimha tadā nāvaṁ,"
    },
    {
      "id": "tha-ap525:1.2",
      "pali": "bhikkhu cājīviko cahaṁ;"
    },
    {
      "id": "tha-ap525:1.3",
      "pali": "Nāvāya bhijjamānāya,"
    },
    {
      "id": "tha-ap525:1.4",
      "pali": "bhikkhu me saraṇaṁ adā."
    },
    {
      "id": "tha-ap525:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap525:2.2",
      "pali": "yaṁ so me saraṇaṁ adā;"
    },
    {
      "id": "tha-ap525:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap525:2.4",
      "pali": "saraṇagamane phalaṁ."
    },
    {
      "id": "tha-ap525:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap525:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap525:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap525:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap525:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap525:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap525:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap525:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap525:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap525:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā saraṇagamaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap525:7.1",
      "pali": "Saraṇagamaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
