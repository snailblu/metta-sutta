{
  "uid": "vv50",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv50:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv50:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv50:1.3",
      "pali": "Hatthapāde ca viggayha,"
    },
    {
      "id": "vv50:1.4",
      "pali": "naccasi suppavādite."
    },
    {
      "id": "vv50:2.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv50:2.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv50:2.3",
      "pali": "Dibbā saddā niccharanti,"
    },
    {
      "id": "vv50:2.4",
      "pali": "savanīyā manoramā."
    },
    {
      "id": "vv50:3.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv50:3.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv50:3.3",
      "pali": "Dibbā gandhā pavāyanti,"
    },
    {
      "id": "vv50:3.4",
      "pali": "sucigandhā manoramā."
    },
    {
      "id": "vv50:4.1",
      "pali": "Vivattamānā kāyena,"
    },
    {
      "id": "vv50:4.2",
      "pali": "yā veṇīsu piḷandhanā;"
    },
    {
      "id": "vv50:4.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv50:4.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv50:5.1",
      "pali": "Vaṭaṁsakā vātadhutā,"
    },
    {
      "id": "vv50:5.2",
      "pali": "vātena sampakampitā;"
    },
    {
      "id": "vv50:5.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv50:5.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv50:6.1",
      "pali": "Yāpi te sirasmiṁ mālā,"
    },
    {
      "id": "vv50:6.2",
      "pali": "sucigandhā manoramā;"
    },
    {
      "id": "vv50:6.3",
      "pali": "Vāti gandho disā sabbā,"
    },
    {
      "id": "vv50:6.4",
      "pali": "rukkho mañjūsako yathā."
    },
    {
      "id": "vv50:7.1",
      "pali": "Ghāyase taṁ sucigandhaṁ,"
    },
    {
      "id": "vv50:7.2",
      "pali": "rūpaṁ passasi amānusaṁ;"
    },
    {
      "id": "vv50:7.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv50:7.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv50:8.1",
      "pali": "“Dāsī ahaṁ pure āsiṁ,"
    },
    {
      "id": "vv50:8.2",
      "pali": "gayāyaṁ brāhmaṇassahaṁ;"
    },
    {
      "id": "vv50:8.3",
      "pali": "Appapuññā alakkhikā,"
    },
    {
      "id": "vv50:8.4",
      "pali": "rajjumālāti maṁ viduṁ."
    },
    {
      "id": "vv50:9.1",
      "pali": "Akkosānaṁ vadhānañca,"
    },
    {
      "id": "vv50:9.2",
      "pali": "tajjanāya ca uggatā;"
    },
    {
      "id": "vv50:9.3",
      "pali": "Kuṭaṁ gahetvā nikkhamma,"
    },
    {
      "id": "vv50:9.4",
      "pali": "agañchiṁ udahāriyā."
    },
    {
      "id": "vv50:10.1",
      "pali": "Vipathe kuṭaṁ nikkhipitvā,"
    },
    {
      "id": "vv50:10.2",
      "pali": "vanasaṇḍaṁ upāgamiṁ;"
    },
    {
      "id": "vv50:10.3",
      "pali": "Idhevāhaṁ marissāmi,"
    },
    {
      "id": "vv50:10.4",
      "pali": "ko attho jīvitena me."
    },
    {
      "id": "vv50:11.1",
      "pali": "Daḷhaṁ pāsaṁ karitvāna,"
    },
    {
      "id": "vv50:11.2",
      "pali": "āsumbhitvāna pādape;"
    },
    {
      "id": "vv50:11.3",
      "pali": "Tato disā vilokesiṁ,"
    },
    {
      "id": "vv50:11.4",
      "pali": "‘ko nu kho vanamassito’."
    },
    {
      "id": "vv50:12.1",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "vv50:12.2",
      "pali": "sabbalokahitaṁ muniṁ;"
    },
    {
      "id": "vv50:12.3",
      "pali": "Nisinnaṁ rukkhamūlasmiṁ,"
    },
    {
      "id": "vv50:12.4",
      "pali": "jhāyantaṁ akutobhayaṁ."
    },
    {
      "id": "vv50:13.1",
      "pali": "Tassā me ahu saṁvego,"
    },
    {
      "id": "vv50:13.2",
      "pali": "abbhuto lomahaṁsano;"
    },
    {
      "id": "vv50:13.3",
      "pali": "Ko nu kho vanamassito,"
    },
    {
      "id": "vv50:13.4",
      "pali": "manusso udāhu devatā."
    },
    {
      "id": "vv50:14.1",
      "pali": "Pāsādikaṁ pasādanīyaṁ,"
    },
    {
      "id": "vv50:14.2",
      "pali": "vanā nibbanamāgataṁ;"
    },
    {
      "id": "vv50:14.3",
      "pali": "Disvā mano me pasīdi,"
    },
    {
      "id": "vv50:14.4",
      "pali": "nāyaṁ yādisakīdiso."
    },
    {
      "id": "vv50:15.1",
      "pali": "Guttindriyo jhānarato,"
    },
    {
      "id": "vv50:15.2",
      "pali": "abahiggatamānaso;"
    },
    {
      "id": "vv50:15.3",
      "pali": "Hito sabbassa lokassa,"
    },
    {
      "id": "vv50:15.4",
      "pali": "buddho ayaṁ bhavissati."
    },
    {
      "id": "vv50:16.1",
      "pali": "Bhayabheravo durāsado,"
    },
    {
      "id": "vv50:16.2",
      "pali": "sīhova guhamassito;"
    },
    {
      "id": "vv50:16.3",
      "pali": "Dullabhāyaṁ dassanāya,"
    },
    {
      "id": "vv50:16.4",
      "pali": "pupphaṁ odumbaraṁ yathā."
    },
    {
      "id": "vv50:17.1",
      "pali": "So maṁ mudūhi vācāhi,"
    },
    {
      "id": "vv50:17.2",
      "pali": "ālapitvā tathāgato;"
    },
    {
      "id": "vv50:17.3",
      "pali": "Rajjumāleti maṁvoca,"
    },
    {
      "id": "vv50:17.4",
      "pali": "saraṇaṁ gaccha tathāgataṁ."
    },
    {
      "id": "vv50:18.1",
      "pali": "Tāhaṁ giraṁ suṇitvāna,"
    },
    {
      "id": "vv50:18.2",
      "pali": "nelaṁ atthavatiṁ suciṁ;"
    },
    {
      "id": "vv50:18.3",
      "pali": "Saṇhaṁ muduñca vagguñca,"
    },
    {
      "id": "vv50:18.4",
      "pali": "sabbasokāpanūdanaṁ."
    },
    {
      "id": "vv50:19.1",
      "pali": "Kallacittañca maṁ ñatvā,"
    },
    {
      "id": "vv50:19.2",
      "pali": "pasannaṁ suddhamānasaṁ;"
    },
    {
      "id": "vv50:19.3",
      "pali": "Hito sabbassa lokassa,"
    },
    {
      "id": "vv50:19.4",
      "pali": "anusāsi tathāgato."
    },
    {
      "id": "vv50:20.1",
      "pali": "Idaṁ dukkhanti maṁvoca,"
    },
    {
      "id": "vv50:20.2",
      "pali": "Ayaṁ dukkhassa sambhavo;"
    },
    {
      "id": "vv50:20.3",
      "pali": "Dukkha nirodho maggo ca,"
    },
    {
      "id": "vv50:20.4",
      "pali": "Añjaso amatogadho."
    },
    {
      "id": "vv50:21.1",
      "pali": "Anukampakassa kusalassa,"
    },
    {
      "id": "vv50:21.2",
      "pali": "Ovādamhi ahaṁ ṭhitā;"
    },
    {
      "id": "vv50:21.3",
      "pali": "Ajjhagā amataṁ santiṁ,"
    },
    {
      "id": "vv50:21.4",
      "pali": "Nibbānaṁ padamaccutaṁ."
    },
    {
      "id": "vv50:22.1",
      "pali": "Sāhaṁ avaṭṭhitāpemā,"
    },
    {
      "id": "vv50:22.2",
      "pali": "dassane avikampinī;"
    },
    {
      "id": "vv50:22.3",
      "pali": "Mūlajātāya saddhāya,"
    },
    {
      "id": "vv50:22.4",
      "pali": "dhītā buddhassa orasā."
    },
    {
      "id": "vv50:23.1",
      "pali": "Sāhaṁ ramāmi kīḷāmi,"
    },
    {
      "id": "vv50:23.2",
      "pali": "modāmi akutobhayā;"
    },
    {
      "id": "vv50:23.3",
      "pali": "Dibbamālaṁ dhārayāmi,"
    },
    {
      "id": "vv50:23.4",
      "pali": "pivāmi madhumaddavaṁ."
    },
    {
      "id": "vv50:24.1",
      "pali": "Saṭṭhitūriyasahassāni,"
    },
    {
      "id": "vv50:24.2",
      "pali": "paṭibodhaṁ karonti me;"
    },
    {
      "id": "vv50:24.3",
      "pali": "Āḷambo gaggaro bhīmo,"
    },
    {
      "id": "vv50:24.4",
      "pali": "sādhuvādī ca saṁsayo."
    },
    {
      "id": "vv50:25.1",
      "pali": "Pokkharo ca suphasso ca,"
    },
    {
      "id": "vv50:25.2",
      "pali": "vīṇāmokkhā ca nāriyo;"
    },
    {
      "id": "vv50:25.3",
      "pali": "Nandā ceva sunandā ca,"
    },
    {
      "id": "vv50:25.4",
      "pali": "soṇadinnā sucimhitā."
    },
    {
      "id": "vv50:26.1",
      "pali": "Alambusā missakesī ca,"
    },
    {
      "id": "vv50:26.2",
      "pali": "puṇḍarīkātidāruṇī;"
    },
    {
      "id": "vv50:26.3",
      "pali": "Eṇīphassā suphassā ca,"
    },
    {
      "id": "vv50:26.4",
      "pali": "subhaddā muduvādinī."
    },
    {
      "id": "vv50:27.1",
      "pali": "Etā caññā ca seyyāse,"
    },
    {
      "id": "vv50:27.2",
      "pali": "accharānaṁ pabodhikā;"
    },
    {
      "id": "vv50:27.3",
      "pali": "Tā maṁ kālenupāgantvā,"
    },
    {
      "id": "vv50:27.4",
      "pali": "abhibhāsanti devatā."
    },
    {
      "id": "vv50:28.1",
      "pali": "Handa naccāma gāyāma,"
    },
    {
      "id": "vv50:28.2",
      "pali": "handa taṁ ramayāmase;"
    },
    {
      "id": "vv50:28.3",
      "pali": "Nayidaṁ akatapuññānaṁ,"
    },
    {
      "id": "vv50:28.4",
      "pali": "katapuññānamevidaṁ."
    },
    {
      "id": "vv50:29.1",
      "pali": "Asokaṁ nandanaṁ rammaṁ,"
    },
    {
      "id": "vv50:29.2",
      "pali": "tidasānaṁ mahāvanaṁ;"
    },
    {
      "id": "vv50:29.3",
      "pali": "Sukhaṁ akatapuññānaṁ,"
    },
    {
      "id": "vv50:29.4",
      "pali": "idha natthi parattha ca."
    },
    {
      "id": "vv50:30.1",
      "pali": "Sukhañca katapuññānaṁ,"
    },
    {
      "id": "vv50:30.2",
      "pali": "idha ceva parattha ca;"
    },
    {
      "id": "vv50:30.3",
      "pali": "Tesaṁ sahabyakāmānaṁ,"
    },
    {
      "id": "vv50:30.4",
      "pali": "kattabbaṁ kusalaṁ bahuṁ;"
    },
    {
      "id": "vv50:30.5",
      "pali": "Katapuññā hi modanti,"
    },
    {
      "id": "vv50:30.6",
      "pali": "sagge bhogasamaṅgino."
    },
    {
      "id": "vv50:31.1",
      "pali": "Bahūnaṁ vata atthāya,"
    },
    {
      "id": "vv50:31.2",
      "pali": "uppajjanti tathāgatā;"
    },
    {
      "id": "vv50:31.3",
      "pali": "Dakkhiṇeyyā manussānaṁ,"
    },
    {
      "id": "vv50:31.4",
      "pali": "puññakhettānamākarā;"
    },
    {
      "id": "vv50:31.5",
      "pali": "Yattha kāraṁ karitvāna,"
    },
    {
      "id": "vv50:31.6",
      "pali": "sagge modanti dāyakā”ti."
    },
    {
      "id": "vv50:32.1",
      "pali": "Rajjumālāvimānaṁ dvādasamaṁ."
    },
    {
      "id": "vv50:33.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "vv50:34.1",
      "pali": "Mañjiṭṭhā pabhassarā nāgā,"
    },
    {
      "id": "vv50:34.2",
      "pali": "Alomākañjikadāyikā;"
    },
    {
      "id": "vv50:34.3",
      "pali": "Vihāracaturitthambā,"
    },
    {
      "id": "vv50:34.4",
      "pali": "Pītā ucchuvandanarajjumālā ca;"
    },
    {
      "id": "vv50:34.5",
      "pali": "Vaggo tena pavuccatīti."
    },
    {
      "id": "vv50:35.1",
      "pali": "Mañjiṭṭhakavaggo catuttho."
    },
    {
      "id": "vv50:36.1",
      "pali": "Itthivimānaṁ samattaṁ."
    }
  ]
}
