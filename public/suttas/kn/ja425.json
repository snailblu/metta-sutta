{
  "uid": "ja425",
  "title": "Kaccānivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja425:1.1",
      "pali": "“Gaṅgā kumudinī santā,"
    },
    {
      "id": "ja425:1.2",
      "pali": "saṅkhavaṇṇā ca kokilā;"
    },
    {
      "id": "ja425:1.3",
      "pali": "Jambu tālaphalaṁ dajjā,"
    },
    {
      "id": "ja425:1.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:2.1",
      "pali": "Yadā kacchapalomānaṁ,"
    },
    {
      "id": "ja425:2.2",
      "pali": "pāvāro tividho siyā;"
    },
    {
      "id": "ja425:2.3",
      "pali": "Hemantikaṁ pāvuraṇaṁ,"
    },
    {
      "id": "ja425:2.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:3.1",
      "pali": "Yadā makasapādānaṁ,"
    },
    {
      "id": "ja425:3.2",
      "pali": "aṭṭālo sukato siyā;"
    },
    {
      "id": "ja425:3.3",
      "pali": "Daḷho ca avikampī ca,"
    },
    {
      "id": "ja425:3.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:4.1",
      "pali": "Yadā sasavisāṇānaṁ,"
    },
    {
      "id": "ja425:4.2",
      "pali": "nisseṇī sukatā siyā;"
    },
    {
      "id": "ja425:4.3",
      "pali": "Saggassārohaṇatthāya,"
    },
    {
      "id": "ja425:4.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:5.1",
      "pali": "Yadā nisseṇimāruyha,"
    },
    {
      "id": "ja425:5.2",
      "pali": "candaṁ khādeyyu mūsikā;"
    },
    {
      "id": "ja425:5.3",
      "pali": "Rāhuñca paripāteyyuṁ,"
    },
    {
      "id": "ja425:5.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:6.1",
      "pali": "Yadā surāghaṭaṁ pitvā,"
    },
    {
      "id": "ja425:6.2",
      "pali": "makkhikā gaṇacāriṇī;"
    },
    {
      "id": "ja425:6.3",
      "pali": "Aṅgāre vāsaṁ kappeyyuṁ,"
    },
    {
      "id": "ja425:6.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:7.1",
      "pali": "Yadā bimboṭṭhasampanno,"
    },
    {
      "id": "ja425:7.2",
      "pali": "gadrabho sumukho siyā;"
    },
    {
      "id": "ja425:7.3",
      "pali": "Kusalo naccagītassa,"
    },
    {
      "id": "ja425:7.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:8.1",
      "pali": "Yadā kākā ulūkā ca,"
    },
    {
      "id": "ja425:8.2",
      "pali": "mantayeyyuṁ rahogatā;"
    },
    {
      "id": "ja425:8.3",
      "pali": "Aññamaññaṁ pihayeyyuṁ,"
    },
    {
      "id": "ja425:8.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:9.1",
      "pali": "Yadā muḷāla pattānaṁ,"
    },
    {
      "id": "ja425:9.2",
      "pali": "chattaṁ thirataraṁ siyā;"
    },
    {
      "id": "ja425:9.3",
      "pali": "Vassassa paṭighātāya,"
    },
    {
      "id": "ja425:9.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:10.1",
      "pali": "Yadā kulako sakuṇo,"
    },
    {
      "id": "ja425:10.2",
      "pali": "pabbataṁ gandhamādanaṁ;"
    },
    {
      "id": "ja425:10.3",
      "pali": "Tuṇḍenādāya gaccheyya,"
    },
    {
      "id": "ja425:10.4",
      "pali": "atha nūna tadā siyā."
    },
    {
      "id": "ja425:11.1",
      "pali": "Yadā sāmuddikaṁ nāvaṁ,"
    },
    {
      "id": "ja425:11.2",
      "pali": "sayantaṁ savaṭākaraṁ;"
    },
    {
      "id": "ja425:11.3",
      "pali": "Ceṭo ādāya gaccheyya,"
    },
    {
      "id": "ja425:11.4",
      "pali": "atha nūna tadā siyā”ti."
    },
    {
      "id": "ja425:12.1",
      "pali": "Aṭṭhānajātakaṁ navamaṁ."
    }
  ]
}
