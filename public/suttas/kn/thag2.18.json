{
  "uid": "thag2.18",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.18:1.1",
      "pali": "“Pācīnavaṁsadāyamhi,"
    },
    {
      "id": "thag2.18:1.2",
      "pali": "sakyaputtā sahāyakā;"
    },
    {
      "id": "thag2.18:1.3",
      "pali": "Pahāyānappake bhoge,"
    },
    {
      "id": "thag2.18:1.4",
      "pali": "uñchāpattāgate ratā."
    },
    {
      "id": "thag2.18:2.1",
      "pali": "Āraddhavīriyā pahitattā,"
    },
    {
      "id": "thag2.18:2.2",
      "pali": "Niccaṁ daḷhaparakkamā;"
    },
    {
      "id": "thag2.18:2.3",
      "pali": "Ramanti dhammaratiyā,"
    },
    {
      "id": "thag2.18:2.4",
      "pali": "Hitvāna lokiyaṁ ratin”ti."
    },
    {
      "id": "thag2.18:2.5",
      "pali": "… Kimilo thero …."
    }
  ]
}
