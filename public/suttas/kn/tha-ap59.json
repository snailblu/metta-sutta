{
  "uid": "tha-ap59",
  "title": "Pañcadīpakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap59:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap59:1.2",
      "pali": "sabbabhūtānukampino;"
    },
    {
      "id": "tha-ap59:1.3",
      "pali": "Saddahitvāna saddhamme,"
    },
    {
      "id": "tha-ap59:1.4",
      "pali": "ujudiṭṭhi ahosahaṁ."
    },
    {
      "id": "tha-ap59:2.1",
      "pali": "Padīpadānaṁ pādāsiṁ,"
    },
    {
      "id": "tha-ap59:2.2",
      "pali": "parivāretvāna bodhiyaṁ;"
    },
    {
      "id": "tha-ap59:2.3",
      "pali": "Saddahanto padīpāni,"
    },
    {
      "id": "tha-ap59:2.4",
      "pali": "akariṁ tāvade ahaṁ."
    },
    {
      "id": "tha-ap59:3.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap59:3.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap59:3.3",
      "pali": "Ākāse ukkaṁ dhārenti,"
    },
    {
      "id": "tha-ap59:3.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap59:4.1",
      "pali": "Tirokuṭṭaṁ tiroselaṁ,"
    },
    {
      "id": "tha-ap59:4.2",
      "pali": "samatiggayha pabbataṁ;"
    },
    {
      "id": "tha-ap59:4.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap59:4.4",
      "pali": "dassanaṁ anubhomahaṁ."
    },
    {
      "id": "tha-ap59:5.1",
      "pali": "Tena kammāvasesena,"
    },
    {
      "id": "tha-ap59:5.2",
      "pali": "pattomhi āsavakkhayaṁ;"
    },
    {
      "id": "tha-ap59:5.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap59:5.4",
      "pali": "dvipadindassa sāsane."
    },
    {
      "id": "tha-ap59:6.1",
      "pali": "Catuttiṁse kappasate,"
    },
    {
      "id": "tha-ap59:6.2",
      "pali": "satacakkhusanāmakā;"
    },
    {
      "id": "tha-ap59:6.3",
      "pali": "Rājāhesuṁ mahātejā,"
    },
    {
      "id": "tha-ap59:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap59:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap59:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap59:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap59:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā pañcadīpako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap59:9.1",
      "pali": "Pañcadīpakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
