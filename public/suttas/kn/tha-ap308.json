{
  "uid": "tha-ap308",
  "title": "6 Sampasādakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap308:1.1",
      "pali": "“‘Namo te buddha vīratthu,"
    },
    {
      "id": "tha-ap308:1.2",
      "pali": "vippamuttosi sabbadhi;"
    },
    {
      "id": "tha-ap308:1.3",
      "pali": "Byasanamhi anuppatto,"
    },
    {
      "id": "tha-ap308:1.4",
      "pali": "tassa me saraṇaṁ bhava’."
    },
    {
      "id": "tha-ap308:2.1",
      "pali": "Siddhattho tassa byākāsi,"
    },
    {
      "id": "tha-ap308:2.2",
      "pali": "loke appaṭipuggalo;"
    },
    {
      "id": "tha-ap308:2.3",
      "pali": "‘Mahodadhisamo saṅgho,"
    },
    {
      "id": "tha-ap308:2.4",
      "pali": "appameyyo anuttaro."
    },
    {
      "id": "tha-ap308:3.1",
      "pali": "Tattha tvaṁ viraje khette,"
    },
    {
      "id": "tha-ap308:3.2",
      "pali": "anantaphaladāyake;"
    },
    {
      "id": "tha-ap308:3.3",
      "pali": "Saṅghe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap308:3.4",
      "pali": "subījaṁ vāpa ropaya’."
    },
    {
      "id": "tha-ap308:4.1",
      "pali": "Idaṁ vatvāna sabbaññū,"
    },
    {
      "id": "tha-ap308:4.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap308:4.3",
      "pali": "Mameva anusāsitvā,"
    },
    {
      "id": "tha-ap308:4.4",
      "pali": "vehāsaṁ nabhamuggami."
    },
    {
      "id": "tha-ap308:5.1",
      "pali": "Aciraṁ gatamattamhi,"
    },
    {
      "id": "tha-ap308:5.2",
      "pali": "sabbaññumhi narāsabhe;"
    },
    {
      "id": "tha-ap308:5.3",
      "pali": "Maraṇaṁ samanuppatto,"
    },
    {
      "id": "tha-ap308:5.4",
      "pali": "tusitaṁ upapajjahaṁ."
    },
    {
      "id": "tha-ap308:6.1",
      "pali": "Tadāhaṁ viraje khette,"
    },
    {
      "id": "tha-ap308:6.2",
      "pali": "anantaphaladāyake;"
    },
    {
      "id": "tha-ap308:6.3",
      "pali": "Saṅghe cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap308:6.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap308:7.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap308:7.2",
      "pali": "pasādamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap308:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap308:7.4",
      "pali": "pasādassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap308:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap308:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap308:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap308:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā sampasādako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap308:10.1",
      "pali": "Sampasādakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
