{
  "uid": "thag7.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag7.3:1.1",
      "pali": "“Ekaputto ahaṁ āsiṁ,"
    },
    {
      "id": "thag7.3:1.2",
      "pali": "piyo mātu piyo pitu;"
    },
    {
      "id": "thag7.3:1.3",
      "pali": "Bahūhi vatacariyāhi,"
    },
    {
      "id": "thag7.3:1.4",
      "pali": "laddho āyācanāhi ca."
    },
    {
      "id": "thag7.3:2.1",
      "pali": "Te ca maṁ anukampāya,"
    },
    {
      "id": "thag7.3:2.2",
      "pali": "atthakāmā hitesino;"
    },
    {
      "id": "thag7.3:2.3",
      "pali": "Ubho pitā ca mātā ca,"
    },
    {
      "id": "thag7.3:2.4",
      "pali": "buddhassa upanāmayuṁ."
    },
    {
      "id": "thag7.3:3.1",
      "pali": "‘Kicchā laddho ayaṁ putto,"
    },
    {
      "id": "thag7.3:3.2",
      "pali": "sukhumālo sukhedhito;"
    },
    {
      "id": "thag7.3:3.3",
      "pali": "Imaṁ dadāma te nātha,"
    },
    {
      "id": "thag7.3:3.4",
      "pali": "jinassa paricārakaṁ’."
    },
    {
      "id": "thag7.3:4.1",
      "pali": "Satthā ca maṁ paṭiggayha,"
    },
    {
      "id": "thag7.3:4.2",
      "pali": "ānandaṁ etadabravi;"
    },
    {
      "id": "thag7.3:4.3",
      "pali": "‘Pabbājehi imaṁ khippaṁ,"
    },
    {
      "id": "thag7.3:4.4",
      "pali": "hessatyājāniyo ayaṁ’."
    },
    {
      "id": "thag7.3:5.1",
      "pali": "Pabbājetvāna maṁ satthā,"
    },
    {
      "id": "thag7.3:5.2",
      "pali": "vihāraṁ pāvisī jino;"
    },
    {
      "id": "thag7.3:5.3",
      "pali": "Anoggatasmiṁ sūriyasmiṁ,"
    },
    {
      "id": "thag7.3:5.4",
      "pali": "tato cittaṁ vimucci me."
    },
    {
      "id": "thag7.3:6.1",
      "pali": "Tato satthā nirākatvā,"
    },
    {
      "id": "thag7.3:6.2",
      "pali": "paṭisallānavuṭṭhito;"
    },
    {
      "id": "thag7.3:6.3",
      "pali": "‘Ehi bhaddā’ti maṁ āha,"
    },
    {
      "id": "thag7.3:6.4",
      "pali": "sā me āsūpasampadā."
    },
    {
      "id": "thag7.3:7.1",
      "pali": "Jātiyā sattavassena,"
    },
    {
      "id": "thag7.3:7.2",
      "pali": "laddhā me upasampadā;"
    },
    {
      "id": "thag7.3:7.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag7.3:7.4",
      "pali": "aho dhammasudhammatā”ti."
    },
    {
      "id": "thag7.3:7.5",
      "pali": "… Bhaddo thero …."
    }
  ]
}
