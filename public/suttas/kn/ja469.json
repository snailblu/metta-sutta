{
  "uid": "ja469",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja469:1.1",
      "pali": "“Kaṇho kaṇho ca ghoro ca,"
    },
    {
      "id": "ja469:1.2",
      "pali": "sukkadāṭho pabhāsavā;"
    },
    {
      "id": "ja469:1.3",
      "pali": "Baddho pañcahi rajjūhi,"
    },
    {
      "id": "ja469:1.4",
      "pali": "kiṁ ravi sunakho tava”."
    },
    {
      "id": "ja469:2.1",
      "pali": "“Nāyaṁ migānamatthāya,"
    },
    {
      "id": "ja469:2.2",
      "pali": "usīnaka bhavissati;"
    },
    {
      "id": "ja469:2.3",
      "pali": "Manussānaṁ anayo hutvā,"
    },
    {
      "id": "ja469:2.4",
      "pali": "tadā kaṇho pamokkhati”."
    },
    {
      "id": "ja469:3.1",
      "pali": "“Pattahatthā samaṇakā,"
    },
    {
      "id": "ja469:3.2",
      "pali": "muṇḍā saṅghāṭipārutā;"
    },
    {
      "id": "ja469:3.3",
      "pali": "Naṅgalehi kasissanti,"
    },
    {
      "id": "ja469:3.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:4.1",
      "pali": "Tapassiniyo pabbajitā,"
    },
    {
      "id": "ja469:4.2",
      "pali": "muṇḍā saṅghāṭipārutā;"
    },
    {
      "id": "ja469:4.3",
      "pali": "Yadā loke gamissanti,"
    },
    {
      "id": "ja469:4.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:5.1",
      "pali": "Dīghottaroṭṭhā jaṭilā,"
    },
    {
      "id": "ja469:5.2",
      "pali": "paṅkadantā rajassirā;"
    },
    {
      "id": "ja469:5.3",
      "pali": "Iṇaṁ codāya gacchanti,"
    },
    {
      "id": "ja469:5.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:6.1",
      "pali": "Adhicca vede sāvittiṁ,"
    },
    {
      "id": "ja469:6.2",
      "pali": "yaññatantañca brāhmaṇā;"
    },
    {
      "id": "ja469:6.3",
      "pali": "Bhatikāya yajissanti,"
    },
    {
      "id": "ja469:6.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:7.1",
      "pali": "Mātaraṁ pitarañcāpi,"
    },
    {
      "id": "ja469:7.2",
      "pali": "jiṇṇakaṁ gatayobbanaṁ;"
    },
    {
      "id": "ja469:7.3",
      "pali": "Pahū santo na bharanti,"
    },
    {
      "id": "ja469:7.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:8.1",
      "pali": "Mātaraṁ pitarañcāpi,"
    },
    {
      "id": "ja469:8.2",
      "pali": "jiṇṇakaṁ gatayobbanaṁ;"
    },
    {
      "id": "ja469:8.3",
      "pali": "Bālā tumheti vakkhanti,"
    },
    {
      "id": "ja469:8.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:9.1",
      "pali": "Ācariyabhariyaṁ sakhiṁ,"
    },
    {
      "id": "ja469:9.2",
      "pali": "mātulāniṁ pitucchakiṁ;"
    },
    {
      "id": "ja469:9.3",
      "pali": "Yadā loke gamissanti,"
    },
    {
      "id": "ja469:9.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:10.1",
      "pali": "Asicammaṁ gahetvāna,"
    },
    {
      "id": "ja469:10.2",
      "pali": "khaggaṁ paggayha brāhmaṇā;"
    },
    {
      "id": "ja469:10.3",
      "pali": "Panthaghātaṁ karissanti,"
    },
    {
      "id": "ja469:10.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:11.1",
      "pali": "Sukkacchavī vedhaverā,"
    },
    {
      "id": "ja469:11.2",
      "pali": "thūlabāhū apātubhā;"
    },
    {
      "id": "ja469:11.3",
      "pali": "Mittabhedaṁ karissanti,"
    },
    {
      "id": "ja469:11.4",
      "pali": "tadā kaṇho pamokkhati."
    },
    {
      "id": "ja469:12.1",
      "pali": "Māyāvino nekatikā,"
    },
    {
      "id": "ja469:12.2",
      "pali": "asappurisacintakā;"
    },
    {
      "id": "ja469:12.3",
      "pali": "Yadā loke bhavissanti,"
    },
    {
      "id": "ja469:12.4",
      "pali": "tadā kaṇho pamokkhatī”ti."
    },
    {
      "id": "ja469:13.1",
      "pali": "Mahākaṇhajātakaṁ chaṭṭhaṁ."
    }
  ]
}
