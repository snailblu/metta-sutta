{
  "uid": "tha-ap216",
  "title": "Ekasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap216:1.1",
      "pali": "“Dumagge paṁsukūlikaṁ,"
    },
    {
      "id": "tha-ap216:1.2",
      "pali": "laggaṁ disvāna satthuno;"
    },
    {
      "id": "tha-ap216:1.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap216:1.4",
      "pali": "paṁsukūlaṁ avandahaṁ."
    },
    {
      "id": "tha-ap216:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap216:2.2",
      "pali": "yaṁ saññamalabhiṁ tadā;"
    },
    {
      "id": "tha-ap216:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap216:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap216:3.1",
      "pali": "Pañcavīse ito kappe,"
    },
    {
      "id": "tha-ap216:3.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap216:3.3",
      "pali": "Amitābhoti nāmena,"
    },
    {
      "id": "tha-ap216:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap216:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap216:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap216:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap216:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap216:6.1",
      "pali": "Ekasaññakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
