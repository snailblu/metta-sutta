{
  "uid": "ja207",
  "title": "Nataṁdaḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja207:1.1",
      "pali": "“Ayamassakarājena,"
    },
    {
      "id": "ja207:1.2",
      "pali": "deso vicarito mayā;"
    },
    {
      "id": "ja207:1.3",
      "pali": "Anukāmayakāmena,"
    },
    {
      "id": "ja207:1.4",
      "pali": "piyena patinā saha."
    },
    {
      "id": "ja207:2.1",
      "pali": "Navena sukhadukkhena,"
    },
    {
      "id": "ja207:2.2",
      "pali": "porāṇaṁ apidhīyati;"
    },
    {
      "id": "ja207:2.3",
      "pali": "Tasmā assakaraññāva,"
    },
    {
      "id": "ja207:2.4",
      "pali": "kīṭo piyataro mamā”ti."
    },
    {
      "id": "ja207:3.1",
      "pali": "Assakajātakaṁ sattamaṁ."
    }
  ]
}
