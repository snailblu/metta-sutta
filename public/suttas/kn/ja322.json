{
  "uid": "ja322",
  "title": "Kuṭidūsakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja322:1.1",
      "pali": "“Duddubhāyati bhaddante,"
    },
    {
      "id": "ja322:1.2",
      "pali": "yasmiṁ dese vasāmahaṁ;"
    },
    {
      "id": "ja322:1.3",
      "pali": "Ahampetaṁ na jānāmi,"
    },
    {
      "id": "ja322:1.4",
      "pali": "kimetaṁ duddubhāyati”."
    },
    {
      "id": "ja322:2.1",
      "pali": "“Beluvaṁ patitaṁ sutvā,"
    },
    {
      "id": "ja322:2.2",
      "pali": "duddubhanti saso javi;"
    },
    {
      "id": "ja322:2.3",
      "pali": "Sasassa vacanaṁ sutvā,"
    },
    {
      "id": "ja322:2.4",
      "pali": "santattā migavāhinī."
    },
    {
      "id": "ja322:3.1",
      "pali": "Appatvā padaviññāṇaṁ,"
    },
    {
      "id": "ja322:3.2",
      "pali": "paraghosānusārino;"
    },
    {
      "id": "ja322:3.3",
      "pali": "Panādaparamā bālā,"
    },
    {
      "id": "ja322:3.4",
      "pali": "te honti parapattiyā."
    },
    {
      "id": "ja322:4.1",
      "pali": "Ye ca sīlena sampannā,"
    },
    {
      "id": "ja322:4.2",
      "pali": "paññāyūpasame ratā;"
    },
    {
      "id": "ja322:4.3",
      "pali": "Ārakā viratā dhīrā,"
    },
    {
      "id": "ja322:4.4",
      "pali": "na honti parapattiyā”ti."
    },
    {
      "id": "ja322:5.1",
      "pali": "Duddubhajātakaṁ dutiyaṁ."
    }
  ]
}
