{
  "uid": "tha-ap333",
  "title": "Gandhadhūpiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap333:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap333:1.2",
      "pali": "gandhadhūpaṁ adāsahaṁ;"
    },
    {
      "id": "tha-ap333:1.3",
      "pali": "Sumanehi paṭicchannaṁ,"
    },
    {
      "id": "tha-ap333:1.4",
      "pali": "buddhānucchavikañca taṁ."
    },
    {
      "id": "tha-ap333:2.1",
      "pali": "Kañcanagghiyasaṅkāsaṁ,"
    },
    {
      "id": "tha-ap333:2.2",
      "pali": "buddhaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap333:2.3",
      "pali": "Indīvaraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap333:2.4",
      "pali": "ādittaṁva hutāsanaṁ."
    },
    {
      "id": "tha-ap333:3.1",
      "pali": "Byagghusabhaṁva pavaraṁ,"
    },
    {
      "id": "tha-ap333:3.2",
      "pali": "abhijātaṁva kesariṁ;"
    },
    {
      "id": "tha-ap333:3.3",
      "pali": "Nisinnaṁ samaṇānaggaṁ,"
    },
    {
      "id": "tha-ap333:3.4",
      "pali": "bhikkhusaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap333:4.1",
      "pali": "Disvā cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap333:4.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap333:4.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap333:4.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap333:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap333:5.2",
      "pali": "yaṁ gandhamadadiṁ tadā;"
    },
    {
      "id": "tha-ap333:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap333:5.4",
      "pali": "gandhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap333:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap333:6.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap333:6.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap333:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap333:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā gandhadhūpiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap333:8.1",
      "pali": "Gandhadhūpiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
