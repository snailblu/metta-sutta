{
  "uid": "thag1.111",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.111:1.1",
      "pali": "“Duppabbajjaṁ ve duradhivāsā gehā,"
    },
    {
      "id": "thag1.111:1.2",
      "pali": "Dhammo gambhīro duradhigamā bhogā;"
    },
    {
      "id": "thag1.111:1.3",
      "pali": "Kicchā vutti no itarītareneva,"
    },
    {
      "id": "thag1.111:1.4",
      "pali": "Yuttaṁ cintetuṁ satatamaniccatan”ti."
    },
    {
      "id": "thag1.111:1.5",
      "pali": "… Jento thero …."
    }
  ]
}
