{
  "uid": "tha-ap17",
  "title": "5 Pilindavacchattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap17:1.1",
      "pali": "“Nibbute lokanāthamhi,"
    },
    {
      "id": "tha-ap17:1.2",
      "pali": "sumedhe aggapuggale;"
    },
    {
      "id": "tha-ap17:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap17:1.4",
      "pali": "thūpapūjaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap17:2.1",
      "pali": "Ye ca khīṇāsavā tattha,"
    },
    {
      "id": "tha-ap17:2.2",
      "pali": "chaḷabhiññā mahiddhikā;"
    },
    {
      "id": "tha-ap17:2.3",
      "pali": "Tehaṁ tattha samānetvā,"
    },
    {
      "id": "tha-ap17:2.4",
      "pali": "saṅghabhattaṁ akāsahaṁ."
    },
    {
      "id": "tha-ap17:3.1",
      "pali": "Sumedhassa bhagavato,"
    },
    {
      "id": "tha-ap17:3.2",
      "pali": "upaṭṭhāko tadā ahu;"
    },
    {
      "id": "tha-ap17:3.3",
      "pali": "Sumedho nāma nāmena,"
    },
    {
      "id": "tha-ap17:3.4",
      "pali": "anumodittha so tadā."
    },
    {
      "id": "tha-ap17:4.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap17:4.2",
      "pali": "vimānaṁ upapajjahaṁ;"
    },
    {
      "id": "tha-ap17:4.3",
      "pali": "Chaḷāsītisahassāni,"
    },
    {
      "id": "tha-ap17:4.4",
      "pali": "accharāyo ramiṁsu me."
    },
    {
      "id": "tha-ap17:5.1",
      "pali": "Mameva anuvattanti,"
    },
    {
      "id": "tha-ap17:5.2",
      "pali": "sabbakāmehi tā sadā;"
    },
    {
      "id": "tha-ap17:5.3",
      "pali": "Aññe deve abhibhomi,"
    },
    {
      "id": "tha-ap17:5.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap17:6.1",
      "pali": "Pañcavīsatikappamhi,"
    },
    {
      "id": "tha-ap17:6.2",
      "pali": "varuṇo nāma khattiyo;"
    },
    {
      "id": "tha-ap17:6.3",
      "pali": "Visuddhabhojano āsiṁ,"
    },
    {
      "id": "tha-ap17:6.4",
      "pali": "cakkavattī ahaṁ tadā."
    },
    {
      "id": "tha-ap17:7.1",
      "pali": "Na te bījaṁ pavapanti,"
    },
    {
      "id": "tha-ap17:7.2",
      "pali": "napi nīyanti naṅgalā;"
    },
    {
      "id": "tha-ap17:7.3",
      "pali": "Akaṭṭhapākimaṁ sāliṁ,"
    },
    {
      "id": "tha-ap17:7.4",
      "pali": "paribhuñjanti mānusā."
    },
    {
      "id": "tha-ap17:8.1",
      "pali": "Tattha rajjaṁ karitvāna,"
    },
    {
      "id": "tha-ap17:8.2",
      "pali": "devattaṁ puna gacchahaṁ;"
    },
    {
      "id": "tha-ap17:8.3",
      "pali": "Tadāpi edisā mayhaṁ,"
    },
    {
      "id": "tha-ap17:8.4",
      "pali": "nibbattā bhogasampadā."
    },
    {
      "id": "tha-ap17:9.1",
      "pali": "Na maṁ mittā amittā vā,"
    },
    {
      "id": "tha-ap17:9.2",
      "pali": "hiṁsanti sabbapāṇino;"
    },
    {
      "id": "tha-ap17:9.3",
      "pali": "Sabbesampi piyo homi,"
    },
    {
      "id": "tha-ap17:9.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap17:10.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap17:10.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap17:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap17:10.4",
      "pali": "gandhālepassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap17:11.1",
      "pali": "Imasmiṁ bhaddake kappe,"
    },
    {
      "id": "tha-ap17:11.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap17:11.3",
      "pali": "Mahānubhāvo rājāhaṁ,"
    },
    {
      "id": "tha-ap17:11.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap17:12.1",
      "pali": "Sohaṁ pañcasu sīlesu,"
    },
    {
      "id": "tha-ap17:12.2",
      "pali": "ṭhapetvā janataṁ bahuṁ;"
    },
    {
      "id": "tha-ap17:12.3",
      "pali": "Pāpetvā sugatiṁyeva,"
    },
    {
      "id": "tha-ap17:12.4",
      "pali": "devatānaṁ piyo ahuṁ."
    },
    {
      "id": "tha-ap17:13.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap17:13.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap17:13.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap17:13.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap17:14.1",
      "pali": "Itthaṁ sudaṁ āyasmā pilindavaccho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap17:15.1",
      "pali": "Pilindavacchattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
