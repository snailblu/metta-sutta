{
  "uid": "ja445",
  "title": "Catudvāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja445:1.1",
      "pali": "“Na vāhametaṁ jānāmi,"
    },
    {
      "id": "ja445:1.2",
      "pali": "ko vāyaṁ kassa vāti vā;"
    },
    {
      "id": "ja445:1.3",
      "pali": "Yathā sākho cari evaṁ,"
    },
    {
      "id": "ja445:1.4",
      "pali": "nigrodha kinti maññasi."
    },
    {
      "id": "ja445:2.1",
      "pali": "Tato galavinītena,"
    },
    {
      "id": "ja445:2.2",
      "pali": "purisā nīhariṁsu maṁ;"
    },
    {
      "id": "ja445:2.3",
      "pali": "Datvā mukhapahārāni,"
    },
    {
      "id": "ja445:2.4",
      "pali": "sākhassa vacanaṅkarā."
    },
    {
      "id": "ja445:3.1",
      "pali": "Etādisaṁ dummatinā,"
    },
    {
      "id": "ja445:3.2",
      "pali": "akataññuna dubbhinā;"
    },
    {
      "id": "ja445:3.3",
      "pali": "Kataṁ anariyaṁ sākhena,"
    },
    {
      "id": "ja445:3.4",
      "pali": "sakhinā te janādhipa”."
    },
    {
      "id": "ja445:4.1",
      "pali": "“Na vāhametaṁ jānāmi,"
    },
    {
      "id": "ja445:4.2",
      "pali": "napi me koci saṁsati;"
    },
    {
      "id": "ja445:4.3",
      "pali": "Yaṁ me tvaṁ samma akkhāsi,"
    },
    {
      "id": "ja445:4.4",
      "pali": "sākhena kāraṇaṁ kataṁ."
    },
    {
      "id": "ja445:5.1",
      "pali": "Sakhīnaṁ sājīvakaro,"
    },
    {
      "id": "ja445:5.2",
      "pali": "mama sākhassa cūbhayaṁ;"
    },
    {
      "id": "ja445:5.3",
      "pali": "Tvaṁ nosissariyaṁ dātā,"
    },
    {
      "id": "ja445:5.4",
      "pali": "manussesu mahantataṁ;"
    },
    {
      "id": "ja445:5.5",
      "pali": "Tayāmā labbhitā iddhī,"
    },
    {
      "id": "ja445:5.6",
      "pali": "ettha me natthi saṁsayo."
    },
    {
      "id": "ja445:6.1",
      "pali": "Yathāpi bījamaggimhi,"
    },
    {
      "id": "ja445:6.2",
      "pali": "ḍayhati na virūhati;"
    },
    {
      "id": "ja445:6.3",
      "pali": "Evaṁ kataṁ asappurise,"
    },
    {
      "id": "ja445:6.4",
      "pali": "nassati na virūhati."
    },
    {
      "id": "ja445:7.1",
      "pali": "Kataññumhi ca posamhi,"
    },
    {
      "id": "ja445:7.2",
      "pali": "Sīlavante ariyavuttine;"
    },
    {
      "id": "ja445:7.3",
      "pali": "Sukhette viya bījāni,"
    },
    {
      "id": "ja445:7.4",
      "pali": "Kataṁ tamhi na nassati”."
    },
    {
      "id": "ja445:8.1",
      "pali": "“Imaṁ jammaṁ nekatikaṁ,"
    },
    {
      "id": "ja445:8.2",
      "pali": "asappurisacintakaṁ;"
    },
    {
      "id": "ja445:8.3",
      "pali": "Hanantu sākhaṁ sattīhi,"
    },
    {
      "id": "ja445:8.4",
      "pali": "nāssa icchāmi jīvitaṁ”."
    },
    {
      "id": "ja445:9.1",
      "pali": "“Khamatassa mahārāja,"
    },
    {
      "id": "ja445:9.2",
      "pali": "Pāṇā na paṭiānayā;"
    },
    {
      "id": "ja445:9.3",
      "pali": "Khama deva asappurisassa,"
    },
    {
      "id": "ja445:9.4",
      "pali": "Nāssa icchāmahaṁ vadhaṁ”."
    },
    {
      "id": "ja445:10.1",
      "pali": "“Nigrodhameva seveyya,"
    },
    {
      "id": "ja445:10.2",
      "pali": "na sākhamupasaṁvase;"
    },
    {
      "id": "ja445:10.3",
      "pali": "Nigrodhasmiṁ mataṁ seyyo,"
    },
    {
      "id": "ja445:10.4",
      "pali": "yañce sākhasmi jīvitan”ti."
    },
    {
      "id": "ja445:11.1",
      "pali": "Nigrodhajātakaṁ sattamaṁ."
    }
  ]
}
