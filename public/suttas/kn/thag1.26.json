{
  "uid": "thag1.26",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.26:1.1",
      "pali": "“Sutvā subhāsitaṁ vācaṁ,"
    },
    {
      "id": "thag1.26:1.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "thag1.26:1.3",
      "pali": "Paccabyadhiṁ hi nipuṇaṁ,"
    },
    {
      "id": "thag1.26:1.4",
      "pali": "vālaggaṁ usunā yathā”ti."
    },
    {
      "id": "thag1.26:1.5",
      "pali": "… Abhayo thero …."
    }
  ]
}
