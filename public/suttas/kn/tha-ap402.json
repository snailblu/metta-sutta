{
  "uid": "tha-ap402",
  "title": "Ajitattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap402:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap402:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap402:1.3",
      "pali": "Ajjhogāhetvā himavantaṁ,"
    },
    {
      "id": "tha-ap402:1.4",
      "pali": "nisīdi lokanāyako."
    },
    {
      "id": "tha-ap402:2.1",
      "pali": "Nāhaṁ addakkhiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap402:2.2",
      "pali": "Napi saddaṁ suṇomahaṁ;"
    },
    {
      "id": "tha-ap402:2.3",
      "pali": "Mama bhakkhaṁ gavesanto,"
    },
    {
      "id": "tha-ap402:2.4",
      "pali": "Āhiṇḍāmi vane ahaṁ."
    },
    {
      "id": "tha-ap402:3.1",
      "pali": "Tatthaddassāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap402:3.2",
      "pali": "dvattiṁsavaralakkhaṇaṁ;"
    },
    {
      "id": "tha-ap402:3.3",
      "pali": "Disvāna vittimāpajjiṁ,"
    },
    {
      "id": "tha-ap402:3.4",
      "pali": "satto ko nāmayaṁ bhave."
    },
    {
      "id": "tha-ap402:4.1",
      "pali": "Lakkhaṇāni viloketvā,"
    },
    {
      "id": "tha-ap402:4.2",
      "pali": "mama vijjaṁ anussariṁ;"
    },
    {
      "id": "tha-ap402:4.3",
      "pali": "Sutañhi metaṁ vuḍḍhānaṁ,"
    },
    {
      "id": "tha-ap402:4.4",
      "pali": "paṇḍitānaṁ subhāsitaṁ."
    },
    {
      "id": "tha-ap402:5.1",
      "pali": "Tesaṁ yathā taṁ vacanaṁ,"
    },
    {
      "id": "tha-ap402:5.2",
      "pali": "ayaṁ buddho bhavissati;"
    },
    {
      "id": "tha-ap402:5.3",
      "pali": "Yannūnāhaṁ sakkareyyaṁ,"
    },
    {
      "id": "tha-ap402:5.4",
      "pali": "gatiṁ me sodhayissati."
    },
    {
      "id": "tha-ap402:6.1",
      "pali": "Khippaṁ assamamāgantvā,"
    },
    {
      "id": "tha-ap402:6.2",
      "pali": "madhutelaṁ gahiṁ ahaṁ;"
    },
    {
      "id": "tha-ap402:6.3",
      "pali": "Kolambakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap402:6.4",
      "pali": "upagacchiṁ vināyakaṁ."
    },
    {
      "id": "tha-ap402:7.1",
      "pali": "Tidaṇḍake gahetvāna,"
    },
    {
      "id": "tha-ap402:7.2",
      "pali": "abbhokāse ṭhapesahaṁ;"
    },
    {
      "id": "tha-ap402:7.3",
      "pali": "Padīpaṁ pajjalitvāna,"
    },
    {
      "id": "tha-ap402:7.4",
      "pali": "aṭṭhakkhattuṁ avandahaṁ."
    },
    {
      "id": "tha-ap402:8.1",
      "pali": "Sattarattindivaṁ buddho,"
    },
    {
      "id": "tha-ap402:8.2",
      "pali": "nisīdi purisuttamo;"
    },
    {
      "id": "tha-ap402:8.3",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "tha-ap402:8.4",
      "pali": "vuṭṭhāsi lokanāyako."
    },
    {
      "id": "tha-ap402:9.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap402:9.2",
      "pali": "sabbarattindivaṁ ahaṁ;"
    },
    {
      "id": "tha-ap402:9.3",
      "pali": "Dīpaṁ buddhassa pādāsiṁ,"
    },
    {
      "id": "tha-ap402:9.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap402:10.1",
      "pali": "Sabbe vanā gandhamayā,"
    },
    {
      "id": "tha-ap402:10.2",
      "pali": "Pabbate gandhamādane;"
    },
    {
      "id": "tha-ap402:10.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap402:10.4",
      "pali": "Āgacchuṁ buddhasantikaṁ."
    },
    {
      "id": "tha-ap402:11.1",
      "pali": "Ye keci pupphagandhāse,"
    },
    {
      "id": "tha-ap402:11.2",
      "pali": "pupphitā dharaṇīruhā;"
    },
    {
      "id": "tha-ap402:11.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap402:11.4",
      "pali": "sabbe sannipatuṁ tadā."
    },
    {
      "id": "tha-ap402:12.1",
      "pali": "Yāvatā himavantamhi,"
    },
    {
      "id": "tha-ap402:12.2",
      "pali": "nāgā ca garuḷā ubho;"
    },
    {
      "id": "tha-ap402:12.3",
      "pali": "Dhammañca sotukāmā te,"
    },
    {
      "id": "tha-ap402:12.4",
      "pali": "āgacchuṁ buddhasantikaṁ."
    },
    {
      "id": "tha-ap402:13.1",
      "pali": "Devalo nāma samaṇo,"
    },
    {
      "id": "tha-ap402:13.2",
      "pali": "buddhassa aggasāvako;"
    },
    {
      "id": "tha-ap402:13.3",
      "pali": "Vasīsatasahassehi,"
    },
    {
      "id": "tha-ap402:13.4",
      "pali": "buddhasantikupāgami."
    },
    {
      "id": "tha-ap402:14.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap402:14.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap402:14.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap402:14.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap402:15.1",
      "pali": "‘Yo me dīpaṁ padīpesi,"
    },
    {
      "id": "tha-ap402:15.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap402:15.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap402:15.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap402:16.1",
      "pali": "Saṭṭhi kappasahassāni,"
    },
    {
      "id": "tha-ap402:16.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap402:16.3",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap402:16.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap402:17.1",
      "pali": "Soḷasamaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap402:18.1",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap402:18.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap402:18.3",
      "pali": "Pathaviyaṁ sattasataṁ,"
    },
    {
      "id": "tha-ap402:18.4",
      "pali": "vipulaṁ rajjaṁ karissati."
    },
    {
      "id": "tha-ap402:19.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap402:19.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap402:19.3",
      "pali": "Iminā dīpadānena,"
    },
    {
      "id": "tha-ap402:19.4",
      "pali": "dibbacakkhu bhavissati."
    },
    {
      "id": "tha-ap402:20.1",
      "pali": "Samantato aṭṭhakosaṁ,"
    },
    {
      "id": "tha-ap402:20.2",
      "pali": "passissati ayaṁ sadā;"
    },
    {
      "id": "tha-ap402:20.3",
      "pali": "Devalokā cavantassa,"
    },
    {
      "id": "tha-ap402:20.4",
      "pali": "nibbattantassa jantuno."
    },
    {
      "id": "tha-ap402:21.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "tha-ap402:21.2",
      "pali": "padīpaṁ dhārayissati;"
    },
    {
      "id": "tha-ap402:21.3",
      "pali": "Jāyamānassa sattassa,"
    },
    {
      "id": "tha-ap402:21.4",
      "pali": "puññakammasamaṅgino."
    },
    {
      "id": "tha-ap402:22.1",
      "pali": "Yāvatā nagaraṁ āsi,"
    },
    {
      "id": "tha-ap402:22.2",
      "pali": "tāvatā jotayissati;"
    },
    {
      "id": "tha-ap402:22.3",
      "pali": "Upapajjati yaṁ yoniṁ,"
    },
    {
      "id": "tha-ap402:22.4",
      "pali": "devattaṁ atha mānusaṁ."
    },
    {
      "id": "tha-ap402:23.1",
      "pali": "Asseva dīpadānassa,"
    },
    {
      "id": "tha-ap402:23.2",
      "pali": "aṭṭhadīpaphalena hi;"
    },
    {
      "id": "tha-ap402:23.3",
      "pali": "Na jayissantimaṁ jantū,"
    },
    {
      "id": "tha-ap402:23.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap402:24.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap402:24.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap402:24.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap402:24.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap402:25.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap402:25.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap402:25.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap402:25.4",
      "pali": "nibbāyissatināsavo."
    },
    {
      "id": "tha-ap402:26.1",
      "pali": "Tosayitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap402:26.2",
      "pali": "gotamaṁ sakyapuṅgavaṁ;"
    },
    {
      "id": "tha-ap402:26.3",
      "pali": "Ajito nāma nāmena,"
    },
    {
      "id": "tha-ap402:26.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap402:27.1",
      "pali": "Saṭṭhi kappasahassāni,"
    },
    {
      "id": "tha-ap402:27.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap402:27.3",
      "pali": "Tatrāpi me dīpasataṁ,"
    },
    {
      "id": "tha-ap402:27.4",
      "pali": "jotate niccakālikaṁ."
    },
    {
      "id": "tha-ap402:28.1",
      "pali": "Devaloke manusse vā,"
    },
    {
      "id": "tha-ap402:28.2",
      "pali": "niddhāvanti pabhā mama;"
    },
    {
      "id": "tha-ap402:28.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap402:28.4",
      "pali": "bhiyyo hāsaṁ janesahaṁ."
    },
    {
      "id": "tha-ap402:29.1",
      "pali": "Tusitāhaṁ cavitvāna,"
    },
    {
      "id": "tha-ap402:29.2",
      "pali": "okkamiṁ mātukucchiyaṁ;"
    },
    {
      "id": "tha-ap402:29.3",
      "pali": "Jāyamānassa santassa,"
    },
    {
      "id": "tha-ap402:29.4",
      "pali": "āloko vipulo ahu."
    },
    {
      "id": "tha-ap402:30.1",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap402:30.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap402:30.3",
      "pali": "Bāvariṁ upasaṅkamma,"
    },
    {
      "id": "tha-ap402:30.4",
      "pali": "sissattaṁ ajjhupāgamiṁ."
    },
    {
      "id": "tha-ap402:31.1",
      "pali": "Himavante vasantohaṁ,"
    },
    {
      "id": "tha-ap402:31.2",
      "pali": "assosiṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap402:31.3",
      "pali": "Uttamatthaṁ gavesanto,"
    },
    {
      "id": "tha-ap402:31.4",
      "pali": "upagacchiṁ vināyakaṁ."
    },
    {
      "id": "tha-ap402:32.1",
      "pali": "Danto buddho dametāvī,"
    },
    {
      "id": "tha-ap402:32.2",
      "pali": "oghatiṇṇo nirūpadhi;"
    },
    {
      "id": "tha-ap402:32.3",
      "pali": "Nibbānaṁ kathayī buddho,"
    },
    {
      "id": "tha-ap402:32.4",
      "pali": "sabbadukkhappamocanaṁ."
    },
    {
      "id": "tha-ap402:33.1",
      "pali": "Taṁ me āgamanaṁ siddhaṁ,"
    },
    {
      "id": "tha-ap402:33.2",
      "pali": "tositohaṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap402:33.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap402:33.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap402:34.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap402:34.2",
      "pali": "yaṁ dīpamadadiṁ tadā;"
    },
    {
      "id": "tha-ap402:34.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap402:34.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap402:35.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap402:35.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap402:35.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap402:36.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap402:36.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap402:36.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap402:37.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap402:37.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap402:37.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap402:38.1",
      "pali": "Itthaṁ sudaṁ āyasmā ajito thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap402:39.1",
      "pali": "Ajitattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap402:39.2",
      "pali": "Pilindavacchavaggo cattālīsamo."
    },
    {
      "id": "tha-ap402:40.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap402:41.1",
      "pali": "Pilindavaccho selo ca,"
    },
    {
      "id": "tha-ap402:41.2",
      "pali": "sabbakittī madhundado;"
    },
    {
      "id": "tha-ap402:41.3",
      "pali": "Kūṭāgārī bākulo ca,"
    },
    {
      "id": "tha-ap402:41.4",
      "pali": "giri saḷalasavhayo."
    },
    {
      "id": "tha-ap402:42.1",
      "pali": "Sabbado ajito ceva,"
    },
    {
      "id": "tha-ap402:42.2",
      "pali": "gāthāyo gaṇitā iha;"
    },
    {
      "id": "tha-ap402:42.3",
      "pali": "Satāni pañca gāthānaṁ,"
    },
    {
      "id": "tha-ap402:42.4",
      "pali": "vīsati ca taduttarīti."
    },
    {
      "id": "tha-ap402:43.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap402:44.1",
      "pali": "Padumārakkhado ceva,"
    },
    {
      "id": "tha-ap402:44.2",
      "pali": "umā gandhodakena ca;"
    },
    {
      "id": "tha-ap402:44.3",
      "pali": "Ekapadma saddasaññī,"
    },
    {
      "id": "tha-ap402:44.4",
      "pali": "mandāraṁ bodhivandako."
    },
    {
      "id": "tha-ap402:45.1",
      "pali": "Avaṭañca pilindi ca,"
    },
    {
      "id": "tha-ap402:45.2",
      "pali": "gāthāyo gaṇitā iha;"
    },
    {
      "id": "tha-ap402:45.3",
      "pali": "Catusattati gāthāyo,"
    },
    {
      "id": "tha-ap402:45.4",
      "pali": "ekādasa satāni ca."
    },
    {
      "id": "tha-ap402:46.1",
      "pali": "Padumavaggadasakaṁ."
    },
    {
      "id": "tha-ap402:47.1",
      "pali": "Catutthasatakaṁ samattaṁ."
    }
  ]
}
