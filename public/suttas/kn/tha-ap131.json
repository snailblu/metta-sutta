{
  "uid": "tha-ap131",
  "title": "9 Gaṇṭhipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap131:1.1",
      "pali": "“Suvaṇṇavaṇṇo sambuddho,"
    },
    {
      "id": "tha-ap131:1.2",
      "pali": "vipassī dakkhiṇāraho;"
    },
    {
      "id": "tha-ap131:1.3",
      "pali": "Purakkhato sāvakehi,"
    },
    {
      "id": "tha-ap131:1.4",
      "pali": "ārāmā abhinikkhami."
    },
    {
      "id": "tha-ap131:2.1",
      "pali": "Disvānahaṁ buddhaseṭṭhaṁ,"
    },
    {
      "id": "tha-ap131:2.2",
      "pali": "sabbaññuṁ tamanāsakaṁ;"
    },
    {
      "id": "tha-ap131:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap131:2.4",
      "pali": "gaṇṭhipupphaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap131:3.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap131:3.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap131:3.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap131:3.4",
      "pali": "puna vandiṁ tathāgataṁ."
    },
    {
      "id": "tha-ap131:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap131:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap131:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap131:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap131:5.1",
      "pali": "Ekatālīsito kappe,"
    },
    {
      "id": "tha-ap131:5.2",
      "pali": "caraṇo nāma khattiyo;"
    },
    {
      "id": "tha-ap131:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap131:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap131:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap131:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap131:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap131:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā gaṇṭhipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap131:8.1",
      "pali": "Gaṇṭhipupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
