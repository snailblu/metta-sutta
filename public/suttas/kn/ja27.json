{
  "uid": "ja27",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja27:1.1",
      "pali": "“Nālaṁ kabaḷaṁ padātave,"
    },
    {
      "id": "ja27:1.2",
      "pali": "Na ca piṇḍaṁ na kuse na ghaṁsituṁ;"
    },
    {
      "id": "ja27:1.3",
      "pali": "Maññāmi abhiṇhadassanā,"
    },
    {
      "id": "ja27:1.4",
      "pali": "Nāgo snehamakāsi kukkure”ti."
    },
    {
      "id": "ja27:2.1",
      "pali": "Abhiṇhajātakaṁ sattamaṁ."
    }
  ]
}
