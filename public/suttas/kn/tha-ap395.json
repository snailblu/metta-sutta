{
  "uid": "tha-ap395",
  "title": "Sabbakittikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap395:1.1",
      "pali": "“Kaṇikāraṁva jalitaṁ,"
    },
    {
      "id": "tha-ap395:1.2",
      "pali": "dīparukkhaṁva ujjalaṁ;"
    },
    {
      "id": "tha-ap395:1.3",
      "pali": "Osadhiṁva virocantaṁ,"
    },
    {
      "id": "tha-ap395:1.4",
      "pali": "vijjutaṁ gagane yathā."
    },
    {
      "id": "tha-ap395:2.1",
      "pali": "Asambhītaṁ anuttāsiṁ,"
    },
    {
      "id": "tha-ap395:2.2",
      "pali": "migarājaṁva kesariṁ;"
    },
    {
      "id": "tha-ap395:2.3",
      "pali": "Ñāṇālokaṁ pakāsentaṁ,"
    },
    {
      "id": "tha-ap395:2.4",
      "pali": "maddantaṁ titthiye gaṇe."
    },
    {
      "id": "tha-ap395:3.1",
      "pali": "Uddharantaṁ imaṁ lokaṁ,"
    },
    {
      "id": "tha-ap395:3.2",
      "pali": "chindantaṁ sabbasaṁsayaṁ;"
    },
    {
      "id": "tha-ap395:3.3",
      "pali": "Gajjantaṁ migarājaṁva,"
    },
    {
      "id": "tha-ap395:3.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap395:4.1",
      "pali": "Jaṭājinadharo āsiṁ,"
    },
    {
      "id": "tha-ap395:4.2",
      "pali": "brahā uju patāpavā;"
    },
    {
      "id": "tha-ap395:4.3",
      "pali": "Vākacīraṁ gahetvāna,"
    },
    {
      "id": "tha-ap395:4.4",
      "pali": "pādamūle apatthariṁ."
    },
    {
      "id": "tha-ap395:5.1",
      "pali": "Kāḷānusāriyaṁ gayha,"
    },
    {
      "id": "tha-ap395:5.2",
      "pali": "anulimpiṁ tathāgataṁ;"
    },
    {
      "id": "tha-ap395:5.3",
      "pali": "Sambuddhamanulimpetvā,"
    },
    {
      "id": "tha-ap395:5.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap395:6.1",
      "pali": "‘Samuddharasimaṁ lokaṁ,"
    },
    {
      "id": "tha-ap395:6.2",
      "pali": "oghatiṇṇamahāmuni;"
    },
    {
      "id": "tha-ap395:6.3",
      "pali": "Ñāṇālokena jotesi,"
    },
    {
      "id": "tha-ap395:6.4",
      "pali": "nāvaṭaṁ ñāṇamuttamaṁ."
    },
    {
      "id": "tha-ap395:7.1",
      "pali": "Dhammacakkaṁ pavattesi,"
    },
    {
      "id": "tha-ap395:7.2",
      "pali": "maddase paratitthiye;"
    },
    {
      "id": "tha-ap395:7.3",
      "pali": "Usabho jitasaṅgāmo,"
    },
    {
      "id": "tha-ap395:7.4",
      "pali": "sampakampesi medaniṁ."
    },
    {
      "id": "tha-ap395:8.1",
      "pali": "Mahāsamudde ūmiyo,"
    },
    {
      "id": "tha-ap395:8.2",
      "pali": "velantamhi pabhijjare;"
    },
    {
      "id": "tha-ap395:8.3",
      "pali": "Tatheva tava ñāṇamhi,"
    },
    {
      "id": "tha-ap395:8.4",
      "pali": "sabbadiṭṭhī pabhijjare."
    },
    {
      "id": "tha-ap395:9.1",
      "pali": "Sukhumacchikajālena,"
    },
    {
      "id": "tha-ap395:9.2",
      "pali": "saramhi sampatānite;"
    },
    {
      "id": "tha-ap395:9.3",
      "pali": "Antojālikatā pāṇā,"
    },
    {
      "id": "tha-ap395:9.4",
      "pali": "pīḷitā honti tāvade."
    },
    {
      "id": "tha-ap395:10.1",
      "pali": "Tatheva titthiyā loke,"
    },
    {
      "id": "tha-ap395:10.2",
      "pali": "puthupāsaṇḍanissitā;"
    },
    {
      "id": "tha-ap395:10.3",
      "pali": "Antoñāṇavare tuyhaṁ,"
    },
    {
      "id": "tha-ap395:10.4",
      "pali": "parivattanti mārisa."
    },
    {
      "id": "tha-ap395:11.1",
      "pali": "Patiṭṭhā vuyhataṁ oghe,"
    },
    {
      "id": "tha-ap395:11.2",
      "pali": "tvañhi nātho abandhunaṁ;"
    },
    {
      "id": "tha-ap395:11.3",
      "pali": "Bhayaṭṭitānaṁ saraṇaṁ,"
    },
    {
      "id": "tha-ap395:11.4",
      "pali": "muttitthīnaṁ parāyaṇaṁ."
    },
    {
      "id": "tha-ap395:12.1",
      "pali": "Ekavīro asadiso,"
    },
    {
      "id": "tha-ap395:12.2",
      "pali": "mettākaruṇasañcayo;"
    },
    {
      "id": "tha-ap395:12.3",
      "pali": "Asamo susamo santo,"
    },
    {
      "id": "tha-ap395:12.4",
      "pali": "vasī tādī jitañjayo."
    },
    {
      "id": "tha-ap395:13.1",
      "pali": "Dhīro vigatasammoho,"
    },
    {
      "id": "tha-ap395:13.2",
      "pali": "anejo akathaṅkathī;"
    },
    {
      "id": "tha-ap395:13.3",
      "pali": "Tusito vantadososi,"
    },
    {
      "id": "tha-ap395:13.4",
      "pali": "nimmalo saṁyato suci."
    },
    {
      "id": "tha-ap395:14.1",
      "pali": "Saṅgātigo hatamado,"
    },
    {
      "id": "tha-ap395:14.2",
      "pali": "tevijjo tibhavantago;"
    },
    {
      "id": "tha-ap395:14.3",
      "pali": "Sīmātigo dhammagaru,"
    },
    {
      "id": "tha-ap395:14.4",
      "pali": "gatattho hitavabbhuto."
    },
    {
      "id": "tha-ap395:15.1",
      "pali": "Tārako tvaṁ yathā nāvā,"
    },
    {
      "id": "tha-ap395:15.2",
      "pali": "nidhīvassāsakārako;"
    },
    {
      "id": "tha-ap395:15.3",
      "pali": "Asambhīto yathā sīho,"
    },
    {
      "id": "tha-ap395:15.4",
      "pali": "gajarājāva dappito’."
    },
    {
      "id": "tha-ap395:16.1",
      "pali": "Thometvā dasagāthāhi,"
    },
    {
      "id": "tha-ap395:16.2",
      "pali": "padumuttaraṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap395:16.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap395:16.4",
      "pali": "tuṇhī aṭṭhāsahaṁ tadā."
    },
    {
      "id": "tha-ap395:17.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap395:17.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap395:17.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap395:17.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap395:18.1",
      "pali": "‘Yo me sīlañca ñāṇañca,"
    },
    {
      "id": "tha-ap395:18.2",
      "pali": "saddhammañcāpi vaṇṇayi;"
    },
    {
      "id": "tha-ap395:18.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap395:18.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap395:19.1",
      "pali": "Saṭṭhi kappasahassāni,"
    },
    {
      "id": "tha-ap395:19.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap395:19.3",
      "pali": "Aññe devebhibhavitvā,"
    },
    {
      "id": "tha-ap395:19.4",
      "pali": "issaraṁ kārayissati."
    },
    {
      "id": "tha-ap395:20.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap395:20.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap395:20.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap395:20.4",
      "pali": "sāsane pabbajissati."
    },
    {
      "id": "tha-ap395:21.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "tha-ap395:21.2",
      "pali": "pāpakammaṁ vivajjiya;"
    },
    {
      "id": "tha-ap395:21.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap395:21.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap395:22.1",
      "pali": "Yathāpi megho thanayaṁ,"
    },
    {
      "id": "tha-ap395:22.2",
      "pali": "tappeti mediniṁ imaṁ;"
    },
    {
      "id": "tha-ap395:22.3",
      "pali": "Tatheva tvaṁ mahāvīra,"
    },
    {
      "id": "tha-ap395:22.4",
      "pali": "dhammena tappayī mamaṁ."
    },
    {
      "id": "tha-ap395:23.1",
      "pali": "Sīlaṁ paññañca dhammañca,"
    },
    {
      "id": "tha-ap395:23.2",
      "pali": "thavitvā lokanāyakaṁ;"
    },
    {
      "id": "tha-ap395:23.3",
      "pali": "Pattomhi paramaṁ santiṁ,"
    },
    {
      "id": "tha-ap395:23.4",
      "pali": "nibbānaṁ padamaccutaṁ."
    },
    {
      "id": "tha-ap395:24.1",
      "pali": "Aho nūna sa bhagavā,"
    },
    {
      "id": "tha-ap395:24.2",
      "pali": "Ciraṁ tiṭṭheyya cakkhumā;"
    },
    {
      "id": "tha-ap395:24.3",
      "pali": "Aññātañca vijāneyyuṁ,"
    },
    {
      "id": "tha-ap395:24.4",
      "pali": "Phuseyyuṁ amataṁ padaṁ."
    },
    {
      "id": "tha-ap395:25.1",
      "pali": "Ayaṁ me pacchimā jāti,"
    },
    {
      "id": "tha-ap395:25.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap395:25.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap395:25.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap395:26.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap395:26.2",
      "pali": "yaṁ buddhamabhithomayiṁ;"
    },
    {
      "id": "tha-ap395:26.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap395:26.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap395:27.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap395:27.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap395:27.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap395:27.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap395:28.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap395:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap395:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap395:29.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap395:29.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap395:29.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap395:30.1",
      "pali": "Itthaṁ sudaṁ āyasmā sabbakittiko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap395:31.1",
      "pali": "Sabbakittikattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
