{
  "uid": "thag1.48",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.48:1.1",
      "pali": "“Yato ahaṁ pabbajito,"
    },
    {
      "id": "thag1.48:1.2",
      "pali": "Agārasmānagāriyaṁ;"
    },
    {
      "id": "thag1.48:1.3",
      "pali": "Nābhijānāmi saṅkappaṁ,"
    },
    {
      "id": "thag1.48:1.4",
      "pali": "Anariyaṁ dosasaṁhitan”ti."
    },
    {
      "id": "thag1.48:1.5",
      "pali": "… Sañjayo thero …."
    }
  ]
}
