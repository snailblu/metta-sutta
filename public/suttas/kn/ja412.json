{
  "uid": "ja412",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja412:1.1",
      "pali": "“Ahaṁ dasasataṁbyāmaṁ,"
    },
    {
      "id": "ja412:1.2",
      "pali": "uragamādāya āgato;"
    },
    {
      "id": "ja412:1.3",
      "pali": "Tañca mañca mahākāyaṁ,"
    },
    {
      "id": "ja412:1.4",
      "pali": "dhārayaṁ nappavedhasi."
    },
    {
      "id": "ja412:2.1",
      "pali": "Athimaṁ khuddakaṁ pakkhiṁ,"
    },
    {
      "id": "ja412:2.2",
      "pali": "Appamaṁsataraṁ mayā;"
    },
    {
      "id": "ja412:2.3",
      "pali": "Dhārayaṁ byathasi bhītā,"
    },
    {
      "id": "ja412:2.4",
      "pali": "Kamatthaṁ koṭasimbali”."
    },
    {
      "id": "ja412:3.1",
      "pali": "“Maṁsabhakkho tuvaṁ rāja,"
    },
    {
      "id": "ja412:3.2",
      "pali": "phalabhakkho ayaṁ dijo;"
    },
    {
      "id": "ja412:3.3",
      "pali": "Ayaṁ nigrodhabījāni,"
    },
    {
      "id": "ja412:3.4",
      "pali": "pilakkhudumbarāni ca;"
    },
    {
      "id": "ja412:3.5",
      "pali": "Assatthāni ca bhakkhitvā,"
    },
    {
      "id": "ja412:3.6",
      "pali": "khandhe me ohadissati."
    },
    {
      "id": "ja412:4.1",
      "pali": "Te rukkhā saṁvirūhanti,"
    },
    {
      "id": "ja412:4.2",
      "pali": "mama passe nivātajā;"
    },
    {
      "id": "ja412:4.3",
      "pali": "Te maṁ pariyonandhissanti,"
    },
    {
      "id": "ja412:4.4",
      "pali": "arukkhaṁ maṁ karissare."
    },
    {
      "id": "ja412:5.1",
      "pali": "Santi aññepi rukkhā se,"
    },
    {
      "id": "ja412:5.2",
      "pali": "mūlino khandhino dumā;"
    },
    {
      "id": "ja412:5.3",
      "pali": "Iminā sakuṇajātena,"
    },
    {
      "id": "ja412:5.4",
      "pali": "bījamāharitā hatā."
    },
    {
      "id": "ja412:6.1",
      "pali": "Ajjhārūhābhivaḍḍhanti,"
    },
    {
      "id": "ja412:6.2",
      "pali": "brahantampi vanappatiṁ;"
    },
    {
      "id": "ja412:6.3",
      "pali": "Tasmā rāja pavedhāmi,"
    },
    {
      "id": "ja412:6.4",
      "pali": "sampassaṁnāgataṁ bhayaṁ”."
    },
    {
      "id": "ja412:7.1",
      "pali": "“Saṅkeyya saṅkitabbāni,"
    },
    {
      "id": "ja412:7.2",
      "pali": "rakkheyyānāgataṁ bhayaṁ;"
    },
    {
      "id": "ja412:7.3",
      "pali": "Anāgatabhayā dhīro,"
    },
    {
      "id": "ja412:7.4",
      "pali": "ubho loke avekkhatī”ti."
    },
    {
      "id": "ja412:8.1",
      "pali": "Koṭasimbalijātakaṁ sattamaṁ."
    }
  ]
}
