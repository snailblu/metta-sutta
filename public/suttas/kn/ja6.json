{
  "uid": "ja6",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja6:1.1",
      "pali": "“Hiriottappasampannā,"
    },
    {
      "id": "ja6:1.2",
      "pali": "sukkadhammasamāhitā;"
    },
    {
      "id": "ja6:1.3",
      "pali": "Santo sappurisā loke,"
    },
    {
      "id": "ja6:1.4",
      "pali": "devadhammāti vuccare”ti."
    },
    {
      "id": "ja6:2.1",
      "pali": "Devadhammajātakaṁ chaṭṭhaṁ."
    }
  ]
}
