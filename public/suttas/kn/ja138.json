{
  "uid": "ja138",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja138:1.1",
      "pali": "“Kiṁ te jaṭāhi dummedha,"
    },
    {
      "id": "ja138:1.2",
      "pali": "kiṁ te ajinasāṭiyā;"
    },
    {
      "id": "ja138:1.3",
      "pali": "Abbhantaraṁ te gahanaṁ,"
    },
    {
      "id": "ja138:1.4",
      "pali": "bāhiraṁ parimajjasī”ti."
    },
    {
      "id": "ja138:2.1",
      "pali": "Godhajātakaṁ aṭṭhamaṁ."
    }
  ]
}
