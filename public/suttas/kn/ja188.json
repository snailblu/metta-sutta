{
  "uid": "ja188",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja188:1.1",
      "pali": "“Sīhaṅgulī sīhanakho,"
    },
    {
      "id": "ja188:1.2",
      "pali": "sīhapādapatiṭṭhito;"
    },
    {
      "id": "ja188:1.3",
      "pali": "So sīho sīhasaṅghamhi,"
    },
    {
      "id": "ja188:1.4",
      "pali": "eko nadati aññathā”."
    },
    {
      "id": "ja188:2.1",
      "pali": "“Mā tvaṁ nadi rājaputta,"
    },
    {
      "id": "ja188:2.2",
      "pali": "appasaddo vane vasa;"
    },
    {
      "id": "ja188:2.3",
      "pali": "Sarena kho taṁ jāneyyuṁ,"
    },
    {
      "id": "ja188:2.4",
      "pali": "na hi te pettiko saro”ti."
    },
    {
      "id": "ja188:3.1",
      "pali": "Sīhakotthujātakaṁ aṭṭhamaṁ."
    }
  ]
}
