{
  "uid": "ja308",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja308:1.1",
      "pali": "“Akaramhasa te kiccaṁ,"
    },
    {
      "id": "ja308:1.2",
      "pali": "yaṁ balaṁ ahuvamhase;"
    },
    {
      "id": "ja308:1.3",
      "pali": "Migarāja namo tyatthu,"
    },
    {
      "id": "ja308:1.4",
      "pali": "api kiñci labhāmase”."
    },
    {
      "id": "ja308:2.1",
      "pali": "“Mama lohitabhakkhassa,"
    },
    {
      "id": "ja308:2.2",
      "pali": "niccaṁ luddāni kubbato;"
    },
    {
      "id": "ja308:2.3",
      "pali": "Dantantaragato santo,"
    },
    {
      "id": "ja308:2.4",
      "pali": "taṁ bahuṁ yampi jīvasi”."
    },
    {
      "id": "ja308:3.1",
      "pali": "“Akataññumakattāraṁ,"
    },
    {
      "id": "ja308:3.2",
      "pali": "katassa appaṭikārakaṁ;"
    },
    {
      "id": "ja308:3.3",
      "pali": "Yasmiṁ kataññutā natthi,"
    },
    {
      "id": "ja308:3.4",
      "pali": "niratthā tassa sevanā."
    },
    {
      "id": "ja308:4.1",
      "pali": "Yassa sammukhaciṇṇena,"
    },
    {
      "id": "ja308:4.2",
      "pali": "Mittadhammo na labbhati;"
    },
    {
      "id": "ja308:4.3",
      "pali": "Anusūyamanakkosaṁ,"
    },
    {
      "id": "ja308:4.4",
      "pali": "Saṇikaṁ tamhā apakkame”ti."
    },
    {
      "id": "ja308:5.1",
      "pali": "Sakuṇajātakaṁ aṭṭhamaṁ."
    }
  ]
}
