{
  "uid": "ja86",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja86:1.1",
      "pali": "“Sīlaṁ kireva kalyāṇaṁ,"
    },
    {
      "id": "ja86:1.2",
      "pali": "sīlaṁ loke anuttaraṁ;"
    },
    {
      "id": "ja86:1.3",
      "pali": "Passa ghoraviso nāgo,"
    },
    {
      "id": "ja86:1.4",
      "pali": "sīlavāti na haññatī”ti."
    },
    {
      "id": "ja86:2.1",
      "pali": "Sīlavīmaṁsakajātakaṁ chaṭṭhaṁ."
    }
  ]
}
