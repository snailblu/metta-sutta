{
  "uid": "thig5.10",
  "title": "Paṭācārātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.10:1.1",
      "pali": "“Naṅgalehi kasaṁ khettaṁ,"
    },
    {
      "id": "thig5.10:1.2",
      "pali": "bījāni pavapaṁ chamā;"
    },
    {
      "id": "thig5.10:1.3",
      "pali": "Puttadārāni posentā,"
    },
    {
      "id": "thig5.10:1.4",
      "pali": "dhanaṁ vindanti māṇavā."
    },
    {
      "id": "thig5.10:2.1",
      "pali": "Kimahaṁ sīlasampannā,"
    },
    {
      "id": "thig5.10:2.2",
      "pali": "satthusāsanakārikā;"
    },
    {
      "id": "thig5.10:2.3",
      "pali": "Nibbānaṁ nādhigacchāmi,"
    },
    {
      "id": "thig5.10:2.4",
      "pali": "akusītā anuddhatā."
    },
    {
      "id": "thig5.10:3.1",
      "pali": "Pāde pakkhālayitvāna,"
    },
    {
      "id": "thig5.10:3.2",
      "pali": "udakesu karomahaṁ;"
    },
    {
      "id": "thig5.10:3.3",
      "pali": "Pādodakañca disvāna,"
    },
    {
      "id": "thig5.10:3.4",
      "pali": "thalato ninnamāgataṁ."
    },
    {
      "id": "thig5.10:4.1",
      "pali": "Tato cittaṁ samādhesiṁ,"
    },
    {
      "id": "thig5.10:4.2",
      "pali": "assaṁ bhadraṁvajāniyaṁ;"
    },
    {
      "id": "thig5.10:4.3",
      "pali": "Tato dīpaṁ gahetvāna,"
    },
    {
      "id": "thig5.10:4.4",
      "pali": "vihāraṁ pāvisiṁ ahaṁ;"
    },
    {
      "id": "thig5.10:4.5",
      "pali": "Seyyaṁ olokayitvāna,"
    },
    {
      "id": "thig5.10:4.6",
      "pali": "mañcakamhi upāvisiṁ."
    },
    {
      "id": "thig5.10:5.1",
      "pali": "Tato sūciṁ gahetvāna,"
    },
    {
      "id": "thig5.10:5.2",
      "pali": "vaṭṭiṁ okassayāmahaṁ;"
    },
    {
      "id": "thig5.10:5.3",
      "pali": "Padīpasseva nibbānaṁ,"
    },
    {
      "id": "thig5.10:5.4",
      "pali": "vimokkho ahu cetaso”ti."
    },
    {
      "id": "thig5.10:6.1",
      "pali": "… Paṭācārā therī …."
    }
  ]
}
