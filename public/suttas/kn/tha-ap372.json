{
  "uid": "tha-ap372",
  "title": "10 Saḷalapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap372:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap372:1.2",
      "pali": "ahosiṁ kinnaro tadā;"
    },
    {
      "id": "tha-ap372:1.3",
      "pali": "Tatthaddasaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap372:1.4",
      "pali": "caṅkamantaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap372:2.1",
      "pali": "Ocinitvāna saḷalaṁ,"
    },
    {
      "id": "tha-ap372:2.2",
      "pali": "pupphaṁ buddhassadāsahaṁ;"
    },
    {
      "id": "tha-ap372:2.3",
      "pali": "Upasiṅghi mahāvīro,"
    },
    {
      "id": "tha-ap372:2.4",
      "pali": "saḷalaṁ devagandhikaṁ."
    },
    {
      "id": "tha-ap372:3.1",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "tha-ap372:3.2",
      "pali": "vipassī lokanāyako;"
    },
    {
      "id": "tha-ap372:3.3",
      "pali": "Upasiṅghi mahāvīro,"
    },
    {
      "id": "tha-ap372:3.4",
      "pali": "pekkhamānassa me sato."
    },
    {
      "id": "tha-ap372:4.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap372:4.2",
      "pali": "vanditvā dvipaduttamaṁ;"
    },
    {
      "id": "tha-ap372:4.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap372:4.4",
      "pali": "puna pabbatamāruhiṁ."
    },
    {
      "id": "tha-ap372:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap372:5.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap372:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap372:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap372:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap372:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap372:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap372:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā saḷalapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap372:8.1",
      "pali": "Saḷalapupphiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap372:9.1",
      "pali": "Mandāravapupphiyavaggo sattatiṁsatimo."
    },
    {
      "id": "tha-ap372:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap372:11.1",
      "pali": "Mandāravañca kakkāru,"
    },
    {
      "id": "tha-ap372:11.2",
      "pali": "bhisakesarapupphiyo;"
    },
    {
      "id": "tha-ap372:11.3",
      "pali": "Aṅkolako kadambī ca,"
    },
    {
      "id": "tha-ap372:11.4",
      "pali": "uddālī ekacampako;"
    },
    {
      "id": "tha-ap372:11.5",
      "pali": "Timiraṁ saḷalañceva,"
    },
    {
      "id": "tha-ap372:11.6",
      "pali": "gāthā tālīsameva ca."
    }
  ]
}
