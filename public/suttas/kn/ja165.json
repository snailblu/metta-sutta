{
  "uid": "ja165",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja165:1.1",
      "pali": "“Sandhiṁ katvā amittena,"
    },
    {
      "id": "ja165:1.2",
      "pali": "aṇḍajena jalābuja;"
    },
    {
      "id": "ja165:1.3",
      "pali": "Vivariya dāṭhaṁ sesi,"
    },
    {
      "id": "ja165:1.4",
      "pali": "kuto te bhayamāgataṁ”."
    },
    {
      "id": "ja165:2.1",
      "pali": "“Saṅketheva amittasmiṁ,"
    },
    {
      "id": "ja165:2.2",
      "pali": "mittasmimpi na vissase;"
    },
    {
      "id": "ja165:2.3",
      "pali": "Abhayā bhayamuppannaṁ,"
    },
    {
      "id": "ja165:2.4",
      "pali": "api mūlāni kantatī”ti."
    },
    {
      "id": "ja165:3.1",
      "pali": "Nakulajātakaṁ pañcamaṁ."
    }
  ]
}
