{
  "uid": "bv18",
  "title": "18. Siddhatthabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv18:1.1",
      "pali": "“Dhammadassissa aparena,"
    },
    {
      "id": "bv18:1.2",
      "pali": "siddhattho nāma nāyako;"
    },
    {
      "id": "bv18:1.3",
      "pali": "Nihanitvā tamaṁ sabbaṁ,"
    },
    {
      "id": "bv18:1.4",
      "pali": "sūriyo abbhuggato yathā."
    },
    {
      "id": "bv18:2.1",
      "pali": "Sopi patvāna sambodhiṁ,"
    },
    {
      "id": "bv18:2.2",
      "pali": "santārento sadevakaṁ;"
    },
    {
      "id": "bv18:2.3",
      "pali": "Abhivassi dhammameghena,"
    },
    {
      "id": "bv18:2.4",
      "pali": "nibbāpento sadevakaṁ."
    },
    {
      "id": "bv18:3.1",
      "pali": "Tassāpi atulatejassa,"
    },
    {
      "id": "bv18:3.2",
      "pali": "Ahesuṁ abhisamayā tayo;"
    },
    {
      "id": "bv18:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv18:3.4",
      "pali": "Paṭhamābhisamayo ahu."
    },
    {
      "id": "bv18:4.1",
      "pali": "Punāparaṁ bhīmarathe,"
    },
    {
      "id": "bv18:4.2",
      "pali": "yadā āhani dundubhiṁ;"
    },
    {
      "id": "bv18:4.3",
      "pali": "Tadā navutikoṭīnaṁ,"
    },
    {
      "id": "bv18:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv18:5.1",
      "pali": "Yadā buddho dhammaṁ desesi,"
    },
    {
      "id": "bv18:5.2",
      "pali": "vebhāre so puruttame;"
    },
    {
      "id": "bv18:5.3",
      "pali": "Tadā navutikoṭīnaṁ,"
    },
    {
      "id": "bv18:5.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv18:6.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv18:6.2",
      "pali": "tasmimpi dvipaduttame;"
    },
    {
      "id": "bv18:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv18:6.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv18:7.1",
      "pali": "Koṭisatānaṁ navutīnaṁ,"
    },
    {
      "id": "bv18:7.2",
      "pali": "asītiyāpi ca koṭinaṁ;"
    },
    {
      "id": "bv18:7.3",
      "pali": "Ete āsuṁ tayo ṭhānā,"
    },
    {
      "id": "bv18:7.4",
      "pali": "vimalānaṁ samāgame."
    },
    {
      "id": "bv18:8.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv18:8.2",
      "pali": "maṅgalo nāma tāpaso;"
    },
    {
      "id": "bv18:8.3",
      "pali": "Uggatejo duppasaho,"
    },
    {
      "id": "bv18:8.4",
      "pali": "abhiññābalasamāhito."
    },
    {
      "id": "bv18:9.1",
      "pali": "Jambuto phalamānetvā,"
    },
    {
      "id": "bv18:9.2",
      "pali": "siddhatthassa adāsahaṁ;"
    },
    {
      "id": "bv18:9.3",
      "pali": "Paṭiggahetvā sambuddho,"
    },
    {
      "id": "bv18:9.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "bv18:10.1",
      "pali": "‘Passatha imaṁ tāpasaṁ,"
    },
    {
      "id": "bv18:10.2",
      "pali": "jaṭilaṁ uggatāpanaṁ;"
    },
    {
      "id": "bv18:10.3",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "bv18:10.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv18:11.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv18:11.2",
      "pali": "…pe…"
    },
    {
      "id": "bv18:11.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv18:12.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv18:12.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv18:12.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv18:12.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv18:13.1",
      "pali": "Vebhāraṁ nāma nagaraṁ,"
    },
    {
      "id": "bv18:13.2",
      "pali": "udeno nāma khattiyo;"
    },
    {
      "id": "bv18:13.3",
      "pali": "Suphassā nāma janikā,"
    },
    {
      "id": "bv18:13.4",
      "pali": "siddhatthassa mahesino."
    },
    {
      "id": "bv18:14.1",
      "pali": "Dasavassasahassāni,"
    },
    {
      "id": "bv18:14.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv18:14.3",
      "pali": "Kokāsuppalakokanadā,"
    },
    {
      "id": "bv18:14.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv18:15.1",
      "pali": "Tisoḷasasahassāni,"
    },
    {
      "id": "bv18:15.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv18:15.3",
      "pali": "Somanassā nāma sā nārī,"
    },
    {
      "id": "bv18:15.4",
      "pali": "anūpamo nāma atrajo."
    },
    {
      "id": "bv18:16.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv18:16.2",
      "pali": "sivikāyābhinikkhami;"
    },
    {
      "id": "bv18:16.3",
      "pali": "Anūnadasamāsāni,"
    },
    {
      "id": "bv18:16.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv18:17.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv18:17.2",
      "pali": "siddhattho lokanāyako;"
    },
    {
      "id": "bv18:17.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv18:17.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv18:18.1",
      "pali": "Sambalo ca sumitto ca,"
    },
    {
      "id": "bv18:18.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv18:18.3",
      "pali": "Revato nāmupaṭṭhāko,"
    },
    {
      "id": "bv18:18.4",
      "pali": "siddhatthassa mahesino."
    },
    {
      "id": "bv18:19.1",
      "pali": "Sīvalā ca surāmā ca,"
    },
    {
      "id": "bv18:19.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv18:19.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv18:19.4",
      "pali": "kaṇikāroti vuccati."
    },
    {
      "id": "bv18:20.1",
      "pali": "Suppiyo ca samuddo ca,"
    },
    {
      "id": "bv18:20.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv18:20.3",
      "pali": "Rammā ceva surammā ca,"
    },
    {
      "id": "bv18:20.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv18:21.1",
      "pali": "So buddho saṭṭhiratanaṁ,"
    },
    {
      "id": "bv18:21.2",
      "pali": "ahosi nabhamuggato;"
    },
    {
      "id": "bv18:21.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "bv18:21.4",
      "pali": "dasasahassī virocati."
    },
    {
      "id": "bv18:22.1",
      "pali": "Sopi buddho asamasamo,"
    },
    {
      "id": "bv18:22.2",
      "pali": "atulo appaṭipuggalo;"
    },
    {
      "id": "bv18:22.3",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv18:22.4",
      "pali": "loke aṭṭhāsi cakkhumā."
    },
    {
      "id": "bv18:23.1",
      "pali": "Vipulaṁ pabhaṁ dassayitvā,"
    },
    {
      "id": "bv18:23.2",
      "pali": "pupphāpetvāna sāvake;"
    },
    {
      "id": "bv18:23.3",
      "pali": "Vilāsetvā samāpatyā,"
    },
    {
      "id": "bv18:23.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv18:24.1",
      "pali": "Siddhattho munivaro buddho,"
    },
    {
      "id": "bv18:24.2",
      "pali": "Anomārāmamhi nibbuto;"
    },
    {
      "id": "bv18:24.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv18:24.4",
      "pali": "Catuyojanamuggato”ti."
    },
    {
      "id": "bv18:25.1",
      "pali": "Siddhatthassa bhagavato vaṁso soḷasamo."
    }
  ]
}
