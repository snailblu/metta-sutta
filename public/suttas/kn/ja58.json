{
  "uid": "ja58",
  "title": "Āsīsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja58:1.1",
      "pali": "“Yassa ete tayo dhammā,"
    },
    {
      "id": "ja58:1.2",
      "pali": "vānarinda yathā tava;"
    },
    {
      "id": "ja58:1.3",
      "pali": "Dakkhiyaṁ sūriyaṁ paññā,"
    },
    {
      "id": "ja58:1.4",
      "pali": "diṭṭhaṁ so ativattatī”ti."
    },
    {
      "id": "ja58:2.1",
      "pali": "Tayodhammajātakaṁ aṭṭhamaṁ."
    }
  ]
}
