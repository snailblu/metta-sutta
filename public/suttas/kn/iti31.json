{
  "uid": "iti31",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti31:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti31:2.1",
      "pali": "“Dveme, bhikkhave, dhammā atapanīyā."
    },
    {
      "id": "iti31:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "iti31:2.3",
      "pali": "Idha, bhikkhave, ekacco katakalyāṇo hoti, katakusalo, katabhīruttāṇo, akatapāpo, akataluddo, akatakibbiso."
    },
    {
      "id": "iti31:2.4",
      "pali": "So ‘kataṁ me kalyāṇan’tipi na tappati, ‘akataṁ me pāpan’tipi na tappati."
    },
    {
      "id": "iti31:2.5",
      "pali": "Ime kho, bhikkhave, dve dhammā atapanīyā”ti."
    },
    {
      "id": "iti31:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti31:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti31:3.1",
      "pali": "“Kāyaduccaritaṁ hitvā,"
    },
    {
      "id": "iti31:3.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "iti31:3.3",
      "pali": "Manoduccaritaṁ hitvā,"
    },
    {
      "id": "iti31:3.4",
      "pali": "yañcaññaṁ dosasañhitaṁ."
    },
    {
      "id": "iti31:4.1",
      "pali": "Akatvākusalaṁ kammaṁ,"
    },
    {
      "id": "iti31:4.2",
      "pali": "katvāna kusalaṁ bahuṁ;"
    },
    {
      "id": "iti31:4.3",
      "pali": "Kāyassa bhedā sappañño,"
    },
    {
      "id": "iti31:4.4",
      "pali": "saggaṁ so upapajjatī”ti."
    },
    {
      "id": "iti31:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti31:5.2",
      "pali": "Catutthaṁ."
    }
  ]
}
