{
  "uid": "thi-ap11",
  "title": "1 Ekūposathikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap11:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "thi-ap11:1.2",
      "pali": "bandhumā nāma khattiyo;"
    },
    {
      "id": "thi-ap11:1.3",
      "pali": "Divase puṇṇamāya so,"
    },
    {
      "id": "thi-ap11:1.4",
      "pali": "upavasi uposathaṁ."
    },
    {
      "id": "thi-ap11:2.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "thi-ap11:2.2",
      "pali": "kumbhadāsī ahaṁ tahiṁ;"
    },
    {
      "id": "thi-ap11:2.3",
      "pali": "Disvā sarājakaṁ senaṁ,"
    },
    {
      "id": "thi-ap11:2.4",
      "pali": "evāhaṁ cintayiṁ tadā."
    },
    {
      "id": "thi-ap11:3.1",
      "pali": "‘Rājāpi rajjaṁ chaḍḍetvā,"
    },
    {
      "id": "thi-ap11:3.2",
      "pali": "upavasi uposathaṁ;"
    },
    {
      "id": "thi-ap11:3.3",
      "pali": "Saphalaṁ nūna taṁ kammaṁ,"
    },
    {
      "id": "thi-ap11:3.4",
      "pali": "janakāyo pamodito’."
    },
    {
      "id": "thi-ap11:4.1",
      "pali": "Yoniso paccavekkhitvā,"
    },
    {
      "id": "thi-ap11:4.2",
      "pali": "duggaccañca daliddataṁ;"
    },
    {
      "id": "thi-ap11:4.3",
      "pali": "Mānasaṁ sampahaṁsitvā,"
    },
    {
      "id": "thi-ap11:4.4",
      "pali": "upavasiṁ uposathaṁ."
    },
    {
      "id": "thi-ap11:5.1",
      "pali": "Ahaṁ uposathaṁ katvā,"
    },
    {
      "id": "thi-ap11:5.2",
      "pali": "sammāsambuddhasāsane;"
    },
    {
      "id": "thi-ap11:5.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap11:5.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap11:6.1",
      "pali": "Tattha me sukataṁ byamhaṁ,"
    },
    {
      "id": "thi-ap11:6.2",
      "pali": "ubbhayojanamuggataṁ;"
    },
    {
      "id": "thi-ap11:6.3",
      "pali": "Kūṭāgāravarūpetaṁ,"
    },
    {
      "id": "thi-ap11:6.4",
      "pali": "mahāsanasubhūsitaṁ."
    },
    {
      "id": "thi-ap11:7.1",
      "pali": "Accharā satasahassā,"
    },
    {
      "id": "thi-ap11:7.2",
      "pali": "upatiṭṭhanti maṁ sadā;"
    },
    {
      "id": "thi-ap11:7.3",
      "pali": "Aññe deve atikkamma,"
    },
    {
      "id": "thi-ap11:7.4",
      "pali": "atirocāmi sabbadā."
    },
    {
      "id": "thi-ap11:8.1",
      "pali": "Catusaṭṭhi devarājūnaṁ,"
    },
    {
      "id": "thi-ap11:8.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap11:8.3",
      "pali": "Tesaṭṭhi cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap11:8.4",
      "pali": "mahesittamakārayiṁ."
    },
    {
      "id": "thi-ap11:9.1",
      "pali": "Suvaṇṇavaṇṇā hutvāna,"
    },
    {
      "id": "thi-ap11:9.2",
      "pali": "bhavesu saṁsarāmahaṁ;"
    },
    {
      "id": "thi-ap11:9.3",
      "pali": "Sabbattha pavarā homi,"
    },
    {
      "id": "thi-ap11:9.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:10.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "thi-ap11:10.2",
      "pali": "rathayānañca sīvikaṁ;"
    },
    {
      "id": "thi-ap11:10.3",
      "pali": "Labhāmi sabbamevetaṁ,"
    },
    {
      "id": "thi-ap11:10.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:11.1",
      "pali": "Soṇṇamayaṁ rūpimayaṁ,"
    },
    {
      "id": "thi-ap11:11.2",
      "pali": "athopi phalikāmayaṁ;"
    },
    {
      "id": "thi-ap11:11.3",
      "pali": "Lohitaṅgamayañceva,"
    },
    {
      "id": "thi-ap11:11.4",
      "pali": "sabbaṁ paṭilabhāmahaṁ."
    },
    {
      "id": "thi-ap11:12.1",
      "pali": "Koseyyakambaliyāni,"
    },
    {
      "id": "thi-ap11:12.2",
      "pali": "khomakappāsikāni ca;"
    },
    {
      "id": "thi-ap11:12.3",
      "pali": "Mahagghāni ca vatthāni,"
    },
    {
      "id": "thi-ap11:12.4",
      "pali": "sabbaṁ paṭilabhāmahaṁ."
    },
    {
      "id": "thi-ap11:13.1",
      "pali": "Annaṁ pānaṁ khādanīyaṁ,"
    },
    {
      "id": "thi-ap11:13.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "thi-ap11:13.3",
      "pali": "Sabbametaṁ paṭilabhe,"
    },
    {
      "id": "thi-ap11:13.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:14.1",
      "pali": "Varagandhañca mālañca,"
    },
    {
      "id": "thi-ap11:14.2",
      "pali": "cuṇṇakañca vilepanaṁ;"
    },
    {
      "id": "thi-ap11:14.3",
      "pali": "Sabbametaṁ paṭilabhe,"
    },
    {
      "id": "thi-ap11:14.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:15.1",
      "pali": "Kūṭāgārañca pāsādaṁ,"
    },
    {
      "id": "thi-ap11:15.2",
      "pali": "maṇḍapaṁ hammiyaṁ guhaṁ;"
    },
    {
      "id": "thi-ap11:15.3",
      "pali": "Sabbametaṁ paṭilabhe,"
    },
    {
      "id": "thi-ap11:15.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:16.1",
      "pali": "Jātiyā sattavassāhaṁ,"
    },
    {
      "id": "thi-ap11:16.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap11:16.3",
      "pali": "Aḍḍhamāse asampatte,"
    },
    {
      "id": "thi-ap11:16.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap11:17.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap11:17.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap11:17.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap11:17.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap11:18.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "thi-ap11:18.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "thi-ap11:18.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap11:18.4",
      "pali": "uposathassidaṁ phalaṁ."
    },
    {
      "id": "thi-ap11:19.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap11:19.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap11:19.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap11:20.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap11:20.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap11:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap11:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap11:21.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap11:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap11:22.1",
      "pali": "Itthaṁ sudaṁ ekūposathikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap11:23.1",
      "pali": "Ekūposathikātheriyāpadānaṁ paṭhamaṁ."
    }
  ]
}
