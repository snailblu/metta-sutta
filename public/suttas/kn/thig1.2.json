{
  "uid": "thig1.2",
  "title": "Muttātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.2:1.1",
      "pali": "“Mutte muccassu yogehi,"
    },
    {
      "id": "thig1.2:1.2",
      "pali": "cando rāhuggahā iva;"
    },
    {
      "id": "thig1.2:1.3",
      "pali": "Vippamuttena cittena,"
    },
    {
      "id": "thig1.2:1.4",
      "pali": "anaṇā bhuñja piṇḍakan”ti."
    },
    {
      "id": "thig1.2:2.1",
      "pali": "Itthaṁ sudaṁ bhagavā muttaṁ sikkhamānaṁ imāya gāthāya abhiṇhaṁ ovadatīti."
    }
  ]
}
