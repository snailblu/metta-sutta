{
  "uid": "bv22",
  "title": "22. Sikhībuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv22:1.1",
      "pali": "“Vipassissa aparena,"
    },
    {
      "id": "bv22:1.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "bv22:1.3",
      "pali": "Sikhivhayo āsi jino,"
    },
    {
      "id": "bv22:1.4",
      "pali": "asamo appaṭipuggalo."
    },
    {
      "id": "bv22:2.1",
      "pali": "Mārasenaṁ pamadditvā,"
    },
    {
      "id": "bv22:2.2",
      "pali": "patto sambodhimuttamaṁ;"
    },
    {
      "id": "bv22:2.3",
      "pali": "Dhammacakkaṁ pavattesi,"
    },
    {
      "id": "bv22:2.4",
      "pali": "anukampāya pāṇinaṁ."
    },
    {
      "id": "bv22:3.1",
      "pali": "Dhammacakkaṁ pavattente,"
    },
    {
      "id": "bv22:3.2",
      "pali": "sikhimhi jinapuṅgave;"
    },
    {
      "id": "bv22:3.3",
      "pali": "Koṭisatasahassānaṁ,"
    },
    {
      "id": "bv22:3.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv22:4.1",
      "pali": "Aparampi dhammaṁ desente,"
    },
    {
      "id": "bv22:4.2",
      "pali": "gaṇaseṭṭhe naruttame;"
    },
    {
      "id": "bv22:4.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv22:4.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv22:5.1",
      "pali": "Yamakapāṭihāriyañca,"
    },
    {
      "id": "bv22:5.2",
      "pali": "dassayante sadevake;"
    },
    {
      "id": "bv22:5.3",
      "pali": "Asītikoṭisahassānaṁ,"
    },
    {
      "id": "bv22:5.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv22:6.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv22:6.2",
      "pali": "sikhissāpi mahesino;"
    },
    {
      "id": "bv22:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv22:6.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv22:7.1",
      "pali": "Bhikkhusatasahassānaṁ,"
    },
    {
      "id": "bv22:7.2",
      "pali": "paṭhamo āsi samāgamo;"
    },
    {
      "id": "bv22:7.3",
      "pali": "Asītibhikkhusahassānaṁ,"
    },
    {
      "id": "bv22:7.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv22:8.1",
      "pali": "Sattatibhikkhusahassānaṁ,"
    },
    {
      "id": "bv22:8.2",
      "pali": "tatiyo āsi samāgamo;"
    },
    {
      "id": "bv22:8.3",
      "pali": "Anupalitto padumaṁva,"
    },
    {
      "id": "bv22:8.4",
      "pali": "toyamhi sampavaḍḍhitaṁ."
    },
    {
      "id": "bv22:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv22:9.2",
      "pali": "Arindamo nāma khattiyo;"
    },
    {
      "id": "bv22:9.3",
      "pali": "Sambuddhappamukhaṁ saṅghaṁ,"
    },
    {
      "id": "bv22:9.4",
      "pali": "Annapānena tappayiṁ."
    },
    {
      "id": "bv22:10.1",
      "pali": "Bahuṁ dussavaraṁ datvā,"
    },
    {
      "id": "bv22:10.2",
      "pali": "dussakoṭiṁ anappakaṁ;"
    },
    {
      "id": "bv22:10.3",
      "pali": "Alaṅkataṁ hatthiyānaṁ,"
    },
    {
      "id": "bv22:10.4",
      "pali": "sambuddhassa adāsahaṁ."
    },
    {
      "id": "bv22:11.1",
      "pali": "Hatthiyānaṁ nimminitvā,"
    },
    {
      "id": "bv22:11.2",
      "pali": "kappiyaṁ upanāmayiṁ;"
    },
    {
      "id": "bv22:11.3",
      "pali": "Pūrayiṁ mānasaṁ mayhaṁ,"
    },
    {
      "id": "bv22:11.4",
      "pali": "niccaṁ daḷhamupaṭṭhitaṁ."
    },
    {
      "id": "bv22:12.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv22:12.2",
      "pali": "sikhī lokagganāyako;"
    },
    {
      "id": "bv22:12.3",
      "pali": "‘Ekatiṁse ito kappe,"
    },
    {
      "id": "bv22:12.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv22:13.1",
      "pali": "Ahu kapilavhayā rammā,"
    },
    {
      "id": "bv22:13.2",
      "pali": "…pe…"
    },
    {
      "id": "bv22:13.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv22:14.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "bv22:14.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv22:14.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv22:14.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv22:15.1",
      "pali": "Nagaraṁ aruṇavatī nāma,"
    },
    {
      "id": "bv22:15.2",
      "pali": "Aruṇo nāma khattiyo;"
    },
    {
      "id": "bv22:15.3",
      "pali": "Pabhāvatī nāma janikā,"
    },
    {
      "id": "bv22:15.4",
      "pali": "Sikhissāpi mahesino."
    },
    {
      "id": "bv22:16.1",
      "pali": "Sattavassasahassāni,"
    },
    {
      "id": "bv22:16.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv22:16.3",
      "pali": "Sucandako giri vasabho,"
    },
    {
      "id": "bv22:16.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv22:17.1",
      "pali": "Catuvīsasahassāni,"
    },
    {
      "id": "bv22:17.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv22:17.3",
      "pali": "Sabbakāmā nāma nārī,"
    },
    {
      "id": "bv22:17.4",
      "pali": "atulo nāma atrajo."
    },
    {
      "id": "bv22:18.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv22:18.2",
      "pali": "hatthiyānena nikkhami;"
    },
    {
      "id": "bv22:18.3",
      "pali": "Aṭṭhamāsaṁ padhānacāraṁ,"
    },
    {
      "id": "bv22:18.4",
      "pali": "acarī purisuttamo."
    },
    {
      "id": "bv22:19.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv22:19.2",
      "pali": "sikhī lokagganāyako;"
    },
    {
      "id": "bv22:19.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv22:19.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv22:20.1",
      "pali": "Abhibhū sambhavo ceva,"
    },
    {
      "id": "bv22:20.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv22:20.3",
      "pali": "Khemaṅkaro nāmupaṭṭhāko,"
    },
    {
      "id": "bv22:20.4",
      "pali": "sikhissāpi mahesino."
    },
    {
      "id": "bv22:21.1",
      "pali": "Sakhilā ca padumā ca,"
    },
    {
      "id": "bv22:21.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv22:21.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv22:21.4",
      "pali": "puṇḍarīkoti vuccati."
    },
    {
      "id": "bv22:22.1",
      "pali": "Sirivaḍḍho ca nando ca,"
    },
    {
      "id": "bv22:22.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv22:22.3",
      "pali": "Cittā ceva suguttā ca,"
    },
    {
      "id": "bv22:22.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv22:23.1",
      "pali": "Uccattanena so buddho,"
    },
    {
      "id": "bv22:23.2",
      "pali": "sattatihatthamuggato;"
    },
    {
      "id": "bv22:23.3",
      "pali": "Kañcanagghiyasaṅkāso,"
    },
    {
      "id": "bv22:23.4",
      "pali": "dvattiṁsavaralakkhaṇo."
    },
    {
      "id": "bv22:24.1",
      "pali": "Tassāpi byāmappabhā kāyā,"
    },
    {
      "id": "bv22:24.2",
      "pali": "divārattiṁ nirantaraṁ;"
    },
    {
      "id": "bv22:24.3",
      "pali": "Disodisaṁ niccharanti,"
    },
    {
      "id": "bv22:24.4",
      "pali": "tīṇiyojanaso pabhā."
    },
    {
      "id": "bv22:25.1",
      "pali": "Sattativassasahassāni,"
    },
    {
      "id": "bv22:25.2",
      "pali": "āyu tassa mahesino;"
    },
    {
      "id": "bv22:25.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv22:25.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv22:26.1",
      "pali": "Dhammameghaṁ pavassetvā,"
    },
    {
      "id": "bv22:26.2",
      "pali": "temayitvā sadevake;"
    },
    {
      "id": "bv22:26.3",
      "pali": "Khemantaṁ pāpayitvāna,"
    },
    {
      "id": "bv22:26.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv22:27.1",
      "pali": "Anubyañjanasampannaṁ,"
    },
    {
      "id": "bv22:27.2",
      "pali": "dvattiṁsavaralakkhaṇaṁ;"
    },
    {
      "id": "bv22:27.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv22:27.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv22:28.1",
      "pali": "Sikhī munivaro buddho,"
    },
    {
      "id": "bv22:28.2",
      "pali": "Assārāmamhi nibbuto;"
    },
    {
      "id": "bv22:28.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv22:28.4",
      "pali": "Tīṇiyojanamuggato”ti."
    },
    {
      "id": "bv22:29.1",
      "pali": "Sikhissa bhagavato vaṁso vīsatimo."
    }
  ]
}
