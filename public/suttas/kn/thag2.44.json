{
  "uid": "thag2.44",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.44:1.1",
      "pali": "“Chavipāpaka cittabhaddaka,"
    },
    {
      "id": "thag2.44:1.2",
      "pali": "Mogharāja satataṁ samāhito;"
    },
    {
      "id": "thag2.44:1.3",
      "pali": "Hemantikasītakālarattiyo,"
    },
    {
      "id": "thag2.44:1.4",
      "pali": "Bhikkhu tvaṁsi kathaṁ karissasi”."
    },
    {
      "id": "thag2.44:2.1",
      "pali": "“Sampannasassā magadhā,"
    },
    {
      "id": "thag2.44:2.2",
      "pali": "kevalā iti me sutaṁ;"
    },
    {
      "id": "thag2.44:2.3",
      "pali": "Palālacchannako seyyaṁ,"
    },
    {
      "id": "thag2.44:2.4",
      "pali": "yathaññe sukhajīvino”ti."
    },
    {
      "id": "thag2.44:2.5",
      "pali": "… Mogharājā thero …."
    }
  ]
}
