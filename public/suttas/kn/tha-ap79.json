{
  "uid": "tha-ap79",
  "title": "Sūcidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap79:1.1",
      "pali": "“Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap79:1.2",
      "pali": "sambuddho lokanāyako;"
    },
    {
      "id": "tha-ap79:1.3",
      "pali": "Sumedho nāma nāmena,"
    },
    {
      "id": "tha-ap79:1.4",
      "pali": "bāttiṁsavaralakkhaṇo."
    },
    {
      "id": "tha-ap79:2.1",
      "pali": "Tassa kañcanavaṇṇassa,"
    },
    {
      "id": "tha-ap79:2.2",
      "pali": "dvipadindassa tādino;"
    },
    {
      "id": "tha-ap79:2.3",
      "pali": "Pañca sūcī mayā dinnā,"
    },
    {
      "id": "tha-ap79:2.4",
      "pali": "sibbanatthāya cīvaraṁ."
    },
    {
      "id": "tha-ap79:3.1",
      "pali": "Teneva sūcidānena,"
    },
    {
      "id": "tha-ap79:3.2",
      "pali": "nipuṇatthavipassakaṁ;"
    },
    {
      "id": "tha-ap79:3.3",
      "pali": "Tikkhaṁ lahuñca phāsuñca,"
    },
    {
      "id": "tha-ap79:3.4",
      "pali": "ñāṇaṁ me udapajjatha."
    },
    {
      "id": "tha-ap79:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap79:4.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap79:4.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap79:4.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap79:5.1",
      "pali": "Dvipadādhipatī nāma,"
    },
    {
      "id": "tha-ap79:5.2",
      "pali": "rājāno caturo ahuṁ;"
    },
    {
      "id": "tha-ap79:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap79:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap79:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap79:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap79:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap79:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sūcidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap79:8.1",
      "pali": "Sūcidāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
