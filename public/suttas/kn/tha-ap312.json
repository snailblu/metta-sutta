{
  "uid": "tha-ap312",
  "title": "Pabbhāradāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap312:1.1",
      "pali": "“Piyadassino bhagavato,"
    },
    {
      "id": "tha-ap312:1.2",
      "pali": "pabbhāro sodhito mayā;"
    },
    {
      "id": "tha-ap312:1.3",
      "pali": "Ghaṭakañca upaṭṭhāsiṁ,"
    },
    {
      "id": "tha-ap312:1.4",
      "pali": "paribhogāya tādino."
    },
    {
      "id": "tha-ap312:2.1",
      "pali": "Taṁ me buddho viyākāsi,"
    },
    {
      "id": "tha-ap312:2.2",
      "pali": "piyadassī mahāmuni;"
    },
    {
      "id": "tha-ap312:2.3",
      "pali": "Sahassakaṇḍo satabheṇḍu,"
    },
    {
      "id": "tha-ap312:2.4",
      "pali": "dhajālu haritāmayo."
    },
    {
      "id": "tha-ap312:3.1",
      "pali": "Nibbattissati so yūpo,"
    },
    {
      "id": "tha-ap312:3.2",
      "pali": "ratanañca anappakaṁ;"
    },
    {
      "id": "tha-ap312:3.3",
      "pali": "Pabbhāradānaṁ datvāna,"
    },
    {
      "id": "tha-ap312:3.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap312:4.1",
      "pali": "Ito bāttiṁsakappamhi,"
    },
    {
      "id": "tha-ap312:4.2",
      "pali": "susuddho nāma khattiyo;"
    },
    {
      "id": "tha-ap312:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap312:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap312:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap312:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap312:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap312:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pabbhāradāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap312:7.1",
      "pali": "Pabbhāradāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap312:8.1",
      "pali": "Padumakesaravaggo ekatiṁsatimo."
    },
    {
      "id": "tha-ap312:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap312:10.1",
      "pali": "Kesaraṁ gandhamannañca,"
    },
    {
      "id": "tha-ap312:10.2",
      "pali": "dhammasaññī phalena ca;"
    },
    {
      "id": "tha-ap312:10.3",
      "pali": "Pasādārāmadāyī ca,"
    },
    {
      "id": "tha-ap312:10.4",
      "pali": "lepako buddhasaññako;"
    },
    {
      "id": "tha-ap312:10.5",
      "pali": "Pabbhārado ca gāthāyo,"
    },
    {
      "id": "tha-ap312:10.6",
      "pali": "ekapaññāsa kittitā."
    }
  ]
}
