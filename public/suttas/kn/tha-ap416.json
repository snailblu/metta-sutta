{
  "uid": "tha-ap416",
  "title": "Madhumaṁsadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap416:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap416:1.2",
      "pali": "sūkariko ahosahaṁ;"
    },
    {
      "id": "tha-ap416:1.3",
      "pali": "Ukkoṭakaṁ randhayitvā,"
    },
    {
      "id": "tha-ap416:1.4",
      "pali": "madhumaṁsamhi okiriṁ."
    },
    {
      "id": "tha-ap416:2.1",
      "pali": "Sannipātaṁ ahaṁ gantvā,"
    },
    {
      "id": "tha-ap416:2.2",
      "pali": "ekaṁ pattaṁ gahesahaṁ;"
    },
    {
      "id": "tha-ap416:2.3",
      "pali": "Pūrayitvāna taṁ pattaṁ,"
    },
    {
      "id": "tha-ap416:2.4",
      "pali": "bhikkhusaṅghassadāsahaṁ."
    },
    {
      "id": "tha-ap416:3.1",
      "pali": "Yottha therataro bhikkhu,"
    },
    {
      "id": "tha-ap416:3.2",
      "pali": "niyyādesi mamaṁ tadā;"
    },
    {
      "id": "tha-ap416:3.3",
      "pali": "Iminā pattapūrena,"
    },
    {
      "id": "tha-ap416:3.4",
      "pali": "labhassu vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap416:4.1",
      "pali": "Duve sampattiyo bhutvā,"
    },
    {
      "id": "tha-ap416:4.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap416:4.3",
      "pali": "Pacchime vattamānamhi,"
    },
    {
      "id": "tha-ap416:4.4",
      "pali": "kilese jhāpayissati."
    },
    {
      "id": "tha-ap416:5.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap416:5.2",
      "pali": "tāvatiṁsamagacchahaṁ;"
    },
    {
      "id": "tha-ap416:5.3",
      "pali": "Tattha bhutvā pivitvā ca,"
    },
    {
      "id": "tha-ap416:5.4",
      "pali": "labhāmi vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap416:6.1",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "tha-ap416:6.2",
      "pali": "pubbakammaṁ anussariṁ;"
    },
    {
      "id": "tha-ap416:6.3",
      "pali": "Annapānābhivasso me,"
    },
    {
      "id": "tha-ap416:6.4",
      "pali": "abhivassati tāvade."
    },
    {
      "id": "tha-ap416:7.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap416:7.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap416:7.3",
      "pali": "Idhāpi annapānaṁ me,"
    },
    {
      "id": "tha-ap416:7.4",
      "pali": "vassate sabbakālikaṁ."
    },
    {
      "id": "tha-ap416:8.1",
      "pali": "Teneva madhudānena,"
    },
    {
      "id": "tha-ap416:8.2",
      "pali": "sandhāvitvā bhave ahaṁ;"
    },
    {
      "id": "tha-ap416:8.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap416:8.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap416:9.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap416:9.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap416:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap416:9.4",
      "pali": "madhudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap416:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap416:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap416:10.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap416:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap416:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap416:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap416:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap416:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap416:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap416:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā madhumaṁsadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap416:14.1",
      "pali": "Madhumaṁsadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
