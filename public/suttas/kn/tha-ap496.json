{
  "uid": "tha-ap496",
  "title": "Kiṁsukapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap496:1.1",
      "pali": "“Kiṁsukaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap496:1.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap496:1.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap496:1.4",
      "pali": "ākāse abhipūjayiṁ."
    },
    {
      "id": "tha-ap496:2.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap496:2.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap496:2.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap496:2.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap496:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap496:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap496:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap496:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap496:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap496:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap496:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap496:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap496:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap496:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap496:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap496:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap496:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap496:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kiṁsukapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap496:8.1",
      "pali": "Kiṁsukapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
