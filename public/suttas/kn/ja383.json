{
  "uid": "ja383",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja383:1.1",
      "pali": "“Sucittapattachadana,"
    },
    {
      "id": "ja383:1.2",
      "pali": "tambacūḷa vihaṅgama;"
    },
    {
      "id": "ja383:1.3",
      "pali": "Oroha dumasākhāya,"
    },
    {
      "id": "ja383:1.4",
      "pali": "mudhā bhariyā bhavāmi te”."
    },
    {
      "id": "ja383:2.1",
      "pali": "“Catuppadī tvaṁ kalyāṇi,"
    },
    {
      "id": "ja383:2.2",
      "pali": "dvipadāhaṁ manorame;"
    },
    {
      "id": "ja383:2.3",
      "pali": "Migī pakkhī asaññuttā,"
    },
    {
      "id": "ja383:2.4",
      "pali": "aññaṁ pariyesa sāmikaṁ”."
    },
    {
      "id": "ja383:3.1",
      "pali": "“Komārikā te hessāmi,"
    },
    {
      "id": "ja383:3.2",
      "pali": "Mañjukā piyabhāṇinī;"
    },
    {
      "id": "ja383:3.3",
      "pali": "Vinda maṁ ariyena vedena,"
    },
    {
      "id": "ja383:3.4",
      "pali": "Sāvaya maṁ yadicchasi”."
    },
    {
      "id": "ja383:4.1",
      "pali": "“Kuṇapādini lohitape,"
    },
    {
      "id": "ja383:4.2",
      "pali": "cori kukkuṭapothini;"
    },
    {
      "id": "ja383:4.3",
      "pali": "Na tvaṁ ariyena vedena,"
    },
    {
      "id": "ja383:4.4",
      "pali": "mamaṁ bhattāramicchasi”."
    },
    {
      "id": "ja383:5.1",
      "pali": "“Evampi caturā nārī,"
    },
    {
      "id": "ja383:5.2",
      "pali": "disvāna sadhanaṁ naraṁ;"
    },
    {
      "id": "ja383:5.3",
      "pali": "Nenti saṇhāhi vācāhi,"
    },
    {
      "id": "ja383:5.4",
      "pali": "biḷārī viya kukkuṭaṁ."
    },
    {
      "id": "ja383:6.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja383:6.2",
      "pali": "na khippamanubujjhati;"
    },
    {
      "id": "ja383:6.3",
      "pali": "Amittavasamanveti,"
    },
    {
      "id": "ja383:6.4",
      "pali": "pacchā ca anutappati."
    },
    {
      "id": "ja383:7.1",
      "pali": "Yo ca uppatitaṁ atthaṁ,"
    },
    {
      "id": "ja383:7.2",
      "pali": "khippameva nibodhati;"
    },
    {
      "id": "ja383:7.3",
      "pali": "Muccate sattusambādhā,"
    },
    {
      "id": "ja383:7.4",
      "pali": "kukkuṭova biḷāriyā”ti."
    },
    {
      "id": "ja383:8.1",
      "pali": "Kukkuṭajātakaṁ aṭṭhamaṁ."
    }
  ]
}
