{
  "uid": "ja172",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja172:1.1",
      "pali": "“Ko nu saddena mahatā,"
    },
    {
      "id": "ja172:1.2",
      "pali": "abhinādeti daddaraṁ;"
    },
    {
      "id": "ja172:1.3",
      "pali": "Taṁ sīhā nappaṭinadanti,"
    },
    {
      "id": "ja172:1.4",
      "pali": "ko nāmeso migādhibhū”."
    },
    {
      "id": "ja172:2.1",
      "pali": "“Adhamo migajātānaṁ,"
    },
    {
      "id": "ja172:2.2",
      "pali": "siṅgālo tāta vassati;"
    },
    {
      "id": "ja172:2.3",
      "pali": "Jātimassa jigucchantā,"
    },
    {
      "id": "ja172:2.4",
      "pali": "tuṇhī sīhā samacchare”ti."
    },
    {
      "id": "ja172:3.1",
      "pali": "Daddarajātakaṁ dutiyaṁ."
    }
  ]
}
