{
  "uid": "ja215",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja215:1.1",
      "pali": "“Avadhī vata attānaṁ,"
    },
    {
      "id": "ja215:1.2",
      "pali": "kacchapo byāharaṁ giraṁ;"
    },
    {
      "id": "ja215:1.3",
      "pali": "Suggahītasmiṁ kaṭṭhasmiṁ,"
    },
    {
      "id": "ja215:1.4",
      "pali": "vācāya sakiyāvadhi."
    },
    {
      "id": "ja215:2.1",
      "pali": "Etampi disvā naravīriyaseṭṭha,"
    },
    {
      "id": "ja215:2.2",
      "pali": "Vācaṁ pamuñce kusalaṁ nātivelaṁ;"
    },
    {
      "id": "ja215:2.3",
      "pali": "Passasi bahubhāṇena,"
    },
    {
      "id": "ja215:2.4",
      "pali": "Kacchapaṁ byasanaṁ gatan”ti."
    },
    {
      "id": "ja215:3.1",
      "pali": "Kacchapajātakaṁ pañcamaṁ."
    }
  ]
}
