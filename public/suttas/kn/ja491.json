{
  "uid": "ja491",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja491:1.1",
      "pali": "“Sace hi tyāhaṁ dhanahetu gāhito,"
    },
    {
      "id": "ja491:1.2",
      "pali": "Mā maṁ vadhī jīvagāhaṁ gahetvā;"
    },
    {
      "id": "ja491:1.3",
      "pali": "Rañño ca maṁ samma upantikaṁ nehi,"
    },
    {
      "id": "ja491:1.4",
      "pali": "Maññe dhanaṁ lacchasinapparūpaṁ”."
    },
    {
      "id": "ja491:2.1",
      "pali": "“Na me ayaṁ tuyha vadhāya ajja,"
    },
    {
      "id": "ja491:2.2",
      "pali": "Samāhito cāpadhure khurappo;"
    },
    {
      "id": "ja491:2.3",
      "pali": "Pāsañca tyāhaṁ adhipātayissaṁ,"
    },
    {
      "id": "ja491:2.4",
      "pali": "Yathāsukhaṁ gacchatu morarājā”."
    },
    {
      "id": "ja491:3.1",
      "pali": "“Yaṁ satta vassāni mamānubandhi,"
    },
    {
      "id": "ja491:3.2",
      "pali": "Rattindivaṁ khuppipāsaṁ sahanto;"
    },
    {
      "id": "ja491:3.3",
      "pali": "Atha kissa maṁ pāsavasūpanītaṁ,"
    },
    {
      "id": "ja491:3.4",
      "pali": "Pamuttave icchasi bandhanasmā."
    },
    {
      "id": "ja491:4.1",
      "pali": "Pāṇātipātā virato nusajja,"
    },
    {
      "id": "ja491:4.2",
      "pali": "Abhayaṁ nu te sabbabhūtesu dinnaṁ;"
    },
    {
      "id": "ja491:4.3",
      "pali": "Yaṁ maṁ tuvaṁ pāsavasūpanītaṁ,"
    },
    {
      "id": "ja491:4.4",
      "pali": "Pamuttave icchasi bandhanasmā”."
    },
    {
      "id": "ja491:5.1",
      "pali": "“Pāṇātipātā viratassa brūhi,"
    },
    {
      "id": "ja491:5.2",
      "pali": "Abhayañca yo sabbabhūtesu deti;"
    },
    {
      "id": "ja491:5.3",
      "pali": "Pucchāmi taṁ morarājetamatthaṁ,"
    },
    {
      "id": "ja491:5.4",
      "pali": "Ito cuto kiṁ labhate sukhaṁ so”."
    },
    {
      "id": "ja491:6.1",
      "pali": "“Pāṇātipātā viratassa brūmi,"
    },
    {
      "id": "ja491:6.2",
      "pali": "Abhayañca yo sabbabhūtesu deti;"
    },
    {
      "id": "ja491:6.3",
      "pali": "Diṭṭheva dhamme labhate pasaṁsaṁ,"
    },
    {
      "id": "ja491:6.4",
      "pali": "Saggañca so yāti sarīrabhedā”."
    },
    {
      "id": "ja491:7.1",
      "pali": "“Na santi devā iti āhu eke,"
    },
    {
      "id": "ja491:7.2",
      "pali": "Idheva jīvo vibhavaṁ upeti;"
    },
    {
      "id": "ja491:7.3",
      "pali": "Tathā phalaṁ sukatadukkaṭānaṁ,"
    },
    {
      "id": "ja491:7.4",
      "pali": "Dattupaññattañca vadanti dānaṁ;"
    },
    {
      "id": "ja491:7.5",
      "pali": "Tesaṁ vaco arahataṁ saddahāno,"
    },
    {
      "id": "ja491:7.6",
      "pali": "Tasmā ahaṁ sakuṇe bādhayāmi”."
    },
    {
      "id": "ja491:8.1",
      "pali": "“Cando ca suriyo ca ubho sudassanā,"
    },
    {
      "id": "ja491:8.2",
      "pali": "Gacchanti obhāsayamantalikkhe;"
    },
    {
      "id": "ja491:8.3",
      "pali": "Imassa lokassa parassa vā te,"
    },
    {
      "id": "ja491:8.4",
      "pali": "Kathaṁ nu te āhu manussaloke”."
    },
    {
      "id": "ja491:9.1",
      "pali": "“Cando ca suriyo ca ubho sudassanā,"
    },
    {
      "id": "ja491:9.2",
      "pali": "Gacchanti obhāsayamantalikkhe;"
    },
    {
      "id": "ja491:9.3",
      "pali": "Parassa lokassa na te imassa,"
    },
    {
      "id": "ja491:9.4",
      "pali": "Devāti te āhu manussaloke”."
    },
    {
      "id": "ja491:10.1",
      "pali": "“Ettheva te nīhatā hīnavādā,"
    },
    {
      "id": "ja491:10.2",
      "pali": "Ahetukā ye na vadanti kammaṁ;"
    },
    {
      "id": "ja491:10.3",
      "pali": "Tathā phalaṁ sukatadukkaṭānaṁ,"
    },
    {
      "id": "ja491:10.4",
      "pali": "Dattupaññattaṁ ye ca vadanti dānaṁ”."
    },
    {
      "id": "ja491:11.1",
      "pali": "“Addhā hi saccaṁ vacanaṁ tavedaṁ,"
    },
    {
      "id": "ja491:11.2",
      "pali": "Kathañhi dānaṁ aphalaṁ bhaveyya;"
    },
    {
      "id": "ja491:11.3",
      "pali": "Tathā phalaṁ sukatadukkaṭānaṁ,"
    },
    {
      "id": "ja491:11.4",
      "pali": "Dattupaññattañca kathaṁ bhaveyya."
    },
    {
      "id": "ja491:12.1",
      "pali": "Kathaṅkaro kintikaro kimācaraṁ,"
    },
    {
      "id": "ja491:12.2",
      "pali": "Kiṁ sevamāno kena tapoguṇena;"
    },
    {
      "id": "ja491:12.3",
      "pali": "Akkhāhi me morarājetamatthaṁ,"
    },
    {
      "id": "ja491:12.4",
      "pali": "Yathā ahaṁ no nirayaṁ pateyyaṁ”."
    },
    {
      "id": "ja491:13.1",
      "pali": "“Ye keci atthi samaṇā pathabyā,"
    },
    {
      "id": "ja491:13.2",
      "pali": "Kāsāyavatthā anagāriyā te;"
    },
    {
      "id": "ja491:13.3",
      "pali": "Pātova piṇḍāya caranti kāle,"
    },
    {
      "id": "ja491:13.4",
      "pali": "Vikālacariyā viratā hi santo."
    },
    {
      "id": "ja491:14.1",
      "pali": "Te tattha kālenupasaṅkamitvā,"
    },
    {
      "id": "ja491:14.2",
      "pali": "Pucchāhi yaṁ te manaso piyaṁ siyā;"
    },
    {
      "id": "ja491:14.3",
      "pali": "Te te pavakkhanti yathāpajānaṁ,"
    },
    {
      "id": "ja491:14.4",
      "pali": "Imassa lokassa parassa catthaṁ”."
    },
    {
      "id": "ja491:15.1",
      "pali": "“Tacaṁva jiṇṇaṁ urago purāṇaṁ,"
    },
    {
      "id": "ja491:15.2",
      "pali": "Paṇḍūpalāsaṁ harito dumova;"
    },
    {
      "id": "ja491:15.3",
      "pali": "Esappahīno mama luddabhāvo,"
    },
    {
      "id": "ja491:15.4",
      "pali": "Jahāmahaṁ luddakabhāvamajja."
    },
    {
      "id": "ja491:16.1",
      "pali": "Ye cāpi me sakuṇā atthi baddhā,"
    },
    {
      "id": "ja491:16.2",
      "pali": "Satāninekāni nivesanasmiṁ;"
    },
    {
      "id": "ja491:16.3",
      "pali": "Tesampahaṁ jīvitamajja dammi,"
    },
    {
      "id": "ja491:16.4",
      "pali": "Mokkhañca te pattā sakaṁ niketaṁ”."
    },
    {
      "id": "ja491:17.1",
      "pali": "“Luddo carī pāsahattho araññe,"
    },
    {
      "id": "ja491:17.2",
      "pali": "Bādhetu morādhipatiṁ yasassiṁ;"
    },
    {
      "id": "ja491:17.3",
      "pali": "Bandhitvā morādhipatiṁ yasassiṁ,"
    },
    {
      "id": "ja491:17.4",
      "pali": "Dukkhā sa pamucci yathāhaṁ pamutto”ti."
    },
    {
      "id": "ja491:18.1",
      "pali": "Mahāmorajātakaṁ aṭṭhamaṁ."
    }
  ]
}
