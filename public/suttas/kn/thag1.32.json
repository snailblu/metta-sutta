{
  "uid": "thag1.32",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.32:1.1",
      "pali": "“Ajaraṁ jīramānena,"
    },
    {
      "id": "thag1.32:1.2",
      "pali": "tappamānena nibbutiṁ;"
    },
    {
      "id": "thag1.32:1.3",
      "pali": "Nimiyaṁ paramaṁ santiṁ,"
    },
    {
      "id": "thag1.32:1.4",
      "pali": "yogakkhemaṁ anuttaran”ti."
    },
    {
      "id": "thag1.32:1.5",
      "pali": "… Suppiyo thero …."
    }
  ]
}
