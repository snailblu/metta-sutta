{
  "uid": "vv61",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv61:1.1",
      "pali": "“Mahantaṁ nāgaṁ abhiruyha,"
    },
    {
      "id": "vv61:1.2",
      "pali": "Sabbasetaṁ gajuttamaṁ;"
    },
    {
      "id": "vv61:1.3",
      "pali": "Vanā vanaṁ anupariyāsi,"
    },
    {
      "id": "vv61:1.4",
      "pali": "Nārīgaṇapurakkhato;"
    },
    {
      "id": "vv61:1.5",
      "pali": "Obhāsento disā sabbā,"
    },
    {
      "id": "vv61:1.6",
      "pali": "Osadhī viya tārakā."
    },
    {
      "id": "vv61:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv61:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv61:2.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv61:3.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv61:3.2",
      "pali": "vaṅgīseneva pucchito;"
    },
    {
      "id": "vv61:3.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv61:3.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv61:4.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv61:4.2",
      "pali": "Upāsako cakkhumato ahosiṁ;"
    },
    {
      "id": "vv61:4.3",
      "pali": "Pāṇātipātā virato ahosiṁ,"
    },
    {
      "id": "vv61:4.4",
      "pali": "Loke adinnaṁ parivajjayissaṁ."
    },
    {
      "id": "vv61:5.1",
      "pali": "Amajjapo no ca musā abhāṇiṁ,"
    },
    {
      "id": "vv61:5.2",
      "pali": "Sakena dārena ca tuṭṭho ahosiṁ;"
    },
    {
      "id": "vv61:5.3",
      "pali": "Annañca pānañca pasannacitto,"
    },
    {
      "id": "vv61:5.4",
      "pali": "Sakkacca dānaṁ vipulaṁ adāsiṁ."
    },
    {
      "id": "vv61:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv61:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv61:6.3",
      "pali": "vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv61:7.1",
      "pali": "Dutiyanāgavimānaṁ ekādasamaṁ."
    }
  ]
}
