{
  "uid": "tha-ap123",
  "title": "Sereyyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap123:1.1",
      "pali": "“Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap123:1.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap123:1.3",
      "pali": "Abbhokāse ṭhito santo,"
    },
    {
      "id": "tha-ap123:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap123:2.1",
      "pali": "Sīhaṁ yathā vanacaraṁ,"
    },
    {
      "id": "tha-ap123:2.2",
      "pali": "byaggharājaṁva nittasaṁ;"
    },
    {
      "id": "tha-ap123:2.3",
      "pali": "Tidhāpabhinnamātaṅgaṁ,"
    },
    {
      "id": "tha-ap123:2.4",
      "pali": "kuñjaraṁva mahesinaṁ."
    },
    {
      "id": "tha-ap123:3.1",
      "pali": "Sereyyakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap123:3.2",
      "pali": "ākāse ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap123:3.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap123:3.4",
      "pali": "parivārenti sabbaso."
    },
    {
      "id": "tha-ap123:4.1",
      "pali": "Adhiṭṭhahi mahāvīro,"
    },
    {
      "id": "tha-ap123:4.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap123:4.3",
      "pali": "Samantā pupphacchadanā,"
    },
    {
      "id": "tha-ap123:4.4",
      "pali": "okiriṁsu narāsabhaṁ."
    },
    {
      "id": "tha-ap123:5.1",
      "pali": "Tato sā pupphakañcukā,"
    },
    {
      "id": "tha-ap123:5.2",
      "pali": "antovaṇṭā bahimukhā;"
    },
    {
      "id": "tha-ap123:5.3",
      "pali": "Sattāhaṁ chadanaṁ katvā,"
    },
    {
      "id": "tha-ap123:5.4",
      "pali": "tato antaradhāyatha."
    },
    {
      "id": "tha-ap123:6.1",
      "pali": "Tañca acchariyaṁ disvā,"
    },
    {
      "id": "tha-ap123:6.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "tha-ap123:6.3",
      "pali": "Buddhe cittaṁ pasādesiṁ,"
    },
    {
      "id": "tha-ap123:6.4",
      "pali": "sugate lokanāyake."
    },
    {
      "id": "tha-ap123:7.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap123:7.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap123:7.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap123:7.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap123:8.1",
      "pali": "Pannarasasahassamhi,"
    },
    {
      "id": "tha-ap123:8.2",
      "pali": "kappānaṁ pañcavīsati;"
    },
    {
      "id": "tha-ap123:8.3",
      "pali": "Vītamalā samānā ca,"
    },
    {
      "id": "tha-ap123:8.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap123:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap123:9.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap123:9.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap123:9.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap123:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā sereyyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap123:11.1",
      "pali": "Sereyyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
