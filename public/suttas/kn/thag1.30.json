{
  "uid": "thag1.30",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.30:1.1",
      "pali": "“Ābādhe me samuppanne,"
    },
    {
      "id": "thag1.30:1.2",
      "pali": "sati me udapajjatha;"
    },
    {
      "id": "thag1.30:1.3",
      "pali": "Ābādho me samuppanno,"
    },
    {
      "id": "thag1.30:1.4",
      "pali": "kālo me nappamajjitun”ti."
    },
    {
      "id": "thag1.30:1.5",
      "pali": "… Uttiyo thero …"
    },
    {
      "id": "thag1.30:1.6",
      "pali": "vaggo tatiyo."
    },
    {
      "id": "thag1.30:2.1",
      "pali": "Nigrodho cittako thero,"
    },
    {
      "id": "thag1.30:2.2",
      "pali": "gosālathero sugandho;"
    },
    {
      "id": "thag1.30:2.3",
      "pali": "Nandiyo abhayo thero,"
    },
    {
      "id": "thag1.30:2.4",
      "pali": "thero lomasakaṅgiyo;"
    },
    {
      "id": "thag1.30:2.5",
      "pali": "Jambugāmikaputto ca,"
    },
    {
      "id": "thag1.30:2.6",
      "pali": "hārito uttiyo isīti."
    }
  ]
}
