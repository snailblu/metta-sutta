{
  "uid": "thag1.69",
  "title": "Sattamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.69:1.1",
      "pali": "“Sutvāna dhammaṁ mahato mahārasaṁ,"
    },
    {
      "id": "thag1.69:1.2",
      "pali": "Sabbaññutaññāṇavarena desitaṁ;"
    },
    {
      "id": "thag1.69:1.3",
      "pali": "Maggaṁ papajjiṁ amatassa pattiyā,"
    },
    {
      "id": "thag1.69:1.4",
      "pali": "So yogakkhemassa pathassa kovido”ti."
    },
    {
      "id": "thag1.69:1.5",
      "pali": "… Channo thero …."
    }
  ]
}
