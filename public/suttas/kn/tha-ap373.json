{
  "uid": "tha-ap373",
  "title": "Bodhivandakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap373:1.1",
      "pali": "“Pāṭaliṁ haritaṁ disvā,"
    },
    {
      "id": "tha-ap373:1.2",
      "pali": "pādapaṁ dharaṇīruhaṁ;"
    },
    {
      "id": "tha-ap373:1.3",
      "pali": "Ekaṁsaṁ añjaliṁ katvā,"
    },
    {
      "id": "tha-ap373:1.4",
      "pali": "avandiṁ pāṭaliṁ ahaṁ."
    },
    {
      "id": "tha-ap373:2.1",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap373:2.2",
      "pali": "garuṁ katvāna mānasaṁ;"
    },
    {
      "id": "tha-ap373:2.3",
      "pali": "Antosuddhaṁ bahisuddhaṁ,"
    },
    {
      "id": "tha-ap373:2.4",
      "pali": "suvimuttamanāsavaṁ."
    },
    {
      "id": "tha-ap373:3.1",
      "pali": "Vipassiṁ lokamahitaṁ,"
    },
    {
      "id": "tha-ap373:3.2",
      "pali": "karuṇāñāṇasāgaraṁ;"
    },
    {
      "id": "tha-ap373:3.3",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap373:3.4",
      "pali": "avandiṁ pāṭaliṁ ahaṁ."
    },
    {
      "id": "tha-ap373:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap373:4.2",
      "pali": "yaṁ bodhimabhivandahaṁ;"
    },
    {
      "id": "tha-ap373:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap373:4.4",
      "pali": "vandanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap373:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap373:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap373:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap373:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap373:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā bodhivandako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap373:7.1",
      "pali": "Bodhivandakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
