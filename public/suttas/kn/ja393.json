{
  "uid": "ja393",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja393:1.1",
      "pali": "“Susukhaṁ vata jīvanti,"
    },
    {
      "id": "ja393:1.2",
      "pali": "ye janā vighāsādino;"
    },
    {
      "id": "ja393:1.3",
      "pali": "Diṭṭheva dhamme pāsaṁsā,"
    },
    {
      "id": "ja393:1.4",
      "pali": "samparāye ca suggatī”."
    },
    {
      "id": "ja393:2.1",
      "pali": "“Sukassa bhāsamānassa,"
    },
    {
      "id": "ja393:2.2",
      "pali": "na nisāmetha paṇḍitā;"
    },
    {
      "id": "ja393:2.3",
      "pali": "Idaṁ suṇātha sodariyā,"
    },
    {
      "id": "ja393:2.4",
      "pali": "amhevāyaṁ pasaṁsati”."
    },
    {
      "id": "ja393:3.1",
      "pali": "“Nāhaṁ tumhe pasaṁsāmi,"
    },
    {
      "id": "ja393:3.2",
      "pali": "kuṇapādā suṇātha me;"
    },
    {
      "id": "ja393:3.3",
      "pali": "Ucchiṭṭhabhojino tumhe,"
    },
    {
      "id": "ja393:3.4",
      "pali": "na tumhe vighāsādino”."
    },
    {
      "id": "ja393:4.1",
      "pali": "“Sattavassā pabbajitā,"
    },
    {
      "id": "ja393:4.2",
      "pali": "mejjhāraññe sikhaṇḍino;"
    },
    {
      "id": "ja393:4.3",
      "pali": "Vighāseneva yāpentā,"
    },
    {
      "id": "ja393:4.4",
      "pali": "mayañce bhoto gārayhā;"
    },
    {
      "id": "ja393:4.5",
      "pali": "Ke nu bhoto pasaṁsiyā”."
    },
    {
      "id": "ja393:5.1",
      "pali": "“Tumhe sīhānaṁ byagghānaṁ,"
    },
    {
      "id": "ja393:5.2",
      "pali": "vāḷānañcāvasiṭṭhakaṁ;"
    },
    {
      "id": "ja393:5.3",
      "pali": "Ucchiṭṭheneva yāpentā,"
    },
    {
      "id": "ja393:5.4",
      "pali": "maññivho vighāsādino."
    },
    {
      "id": "ja393:6.1",
      "pali": "Ye brāhmaṇassa samaṇassa,"
    },
    {
      "id": "ja393:6.2",
      "pali": "aññassa vā vanibbino;"
    },
    {
      "id": "ja393:6.3",
      "pali": "Datvāva sesaṁ bhuñjanti,"
    },
    {
      "id": "ja393:6.4",
      "pali": "te janā vighāsādino”ti."
    },
    {
      "id": "ja393:7.1",
      "pali": "Vighāsādajātakaṁ aṭṭhamaṁ."
    }
  ]
}
