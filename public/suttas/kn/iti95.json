{
  "uid": "iti95",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti95:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti95:2.1",
      "pali": "“Tisso imā, bhikkhave, kāmūpapattiyo."
    },
    {
      "id": "iti95:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti95:2.3",
      "pali": "Paccupaṭṭhitakāmā, nimmānaratino, paranimmitavasavattino—"
    },
    {
      "id": "iti95:2.4",
      "pali": "imā kho, bhikkhave, tisso kāmūpapattiyo”ti."
    },
    {
      "id": "iti95:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti95:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti95:3.1",
      "pali": "“Paccupaṭṭhitakāmā ca,"
    },
    {
      "id": "iti95:3.2",
      "pali": "ye devā vasavattino;"
    },
    {
      "id": "iti95:3.3",
      "pali": "Nimmānaratino devā,"
    },
    {
      "id": "iti95:3.4",
      "pali": "ye caññe kāmabhogino;"
    },
    {
      "id": "iti95:3.5",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "iti95:3.6",
      "pali": "saṁsāraṁ nātivattare."
    },
    {
      "id": "iti95:4.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "iti95:4.2",
      "pali": "kāmabhogesu paṇḍito;"
    },
    {
      "id": "iti95:4.3",
      "pali": "Sabbe pariccaje kāme,"
    },
    {
      "id": "iti95:4.4",
      "pali": "ye dibbā ye ca mānusā."
    },
    {
      "id": "iti95:5.1",
      "pali": "Piyarūpasātagadhitaṁ,"
    },
    {
      "id": "iti95:5.2",
      "pali": "chetvā sotaṁ duraccayaṁ;"
    },
    {
      "id": "iti95:5.3",
      "pali": "Asesaṁ parinibbanti,"
    },
    {
      "id": "iti95:5.4",
      "pali": "asesaṁ dukkhamaccaguṁ."
    },
    {
      "id": "iti95:6.1",
      "pali": "Ariyaddasā vedaguno,"
    },
    {
      "id": "iti95:6.2",
      "pali": "sammadaññāya paṇḍitā;"
    },
    {
      "id": "iti95:6.3",
      "pali": "Jātikkhayamabhiññāya,"
    },
    {
      "id": "iti95:6.4",
      "pali": "nāgacchanti punabbhavan”ti."
    },
    {
      "id": "iti95:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti95:7.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
