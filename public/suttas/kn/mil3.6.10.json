{
  "uid": "mil3.6.10",
  "title": "10. Cirakatasaraṇapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.6.10:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.6.10:1.2",
      "pali": "“bhante nāgasena, kena atītaṁ cirakataṁ saratī”ti?"
    },
    {
      "id": "mil3.6.10:1.3",
      "pali": "“Satiyā, mahārājā”ti."
    },
    {
      "id": "mil3.6.10:1.4",
      "pali": "“Nanu, bhante nāgasena, cittena sarati no satiyā”ti?"
    },
    {
      "id": "mil3.6.10:1.5",
      "pali": "“Abhijānāsi nu tvaṁ, mahārāja, kiñcideva karaṇīyaṁ katvā pamuṭṭhan”ti?"
    },
    {
      "id": "mil3.6.10:1.6",
      "pali": "“Āma, bhante”ti."
    },
    {
      "id": "mil3.6.10:1.7",
      "pali": "“Kiṁ nu kho tvaṁ, mahārāja, tasmiṁ samaye acittako ahosī”ti?"
    },
    {
      "id": "mil3.6.10:1.8",
      "pali": "“Na hi, bhante, sati tasmiṁ samaye nāhosī”ti."
    },
    {
      "id": "mil3.6.10:1.9",
      "pali": "“Atha kasmā tvaṁ, mahārāja, evamāha—"
    },
    {
      "id": "mil3.6.10:1.10",
      "pali": "‘cittena sarati, no satiyā’”ti?"
    },
    {
      "id": "mil3.6.10:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.6.10:3.1",
      "pali": "Cirakatasaraṇapañho dasamo."
    }
  ]
}
