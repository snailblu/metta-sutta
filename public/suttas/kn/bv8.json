{
  "uid": "bv8",
  "title": "8. Sobhitabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv8:1.1",
      "pali": "“Revatassa aparena,"
    },
    {
      "id": "bv8:1.2",
      "pali": "sobhito nāma nāyako;"
    },
    {
      "id": "bv8:1.3",
      "pali": "Samāhito santacitto,"
    },
    {
      "id": "bv8:1.4",
      "pali": "asamo appaṭipuggalo."
    },
    {
      "id": "bv8:2.1",
      "pali": "So jino sakagehamhi,"
    },
    {
      "id": "bv8:2.2",
      "pali": "mānasaṁ vinivattayi;"
    },
    {
      "id": "bv8:2.3",
      "pali": "Patvāna kevalaṁ bodhiṁ,"
    },
    {
      "id": "bv8:2.4",
      "pali": "dhammacakkaṁ pavattayi."
    },
    {
      "id": "bv8:3.1",
      "pali": "Yāva heṭṭhā avīcito,"
    },
    {
      "id": "bv8:3.2",
      "pali": "bhavaggā cāpi uddhato;"
    },
    {
      "id": "bv8:3.3",
      "pali": "Etthantare ekaparisā,"
    },
    {
      "id": "bv8:3.4",
      "pali": "ahosi dhammadesane."
    },
    {
      "id": "bv8:4.1",
      "pali": "Tāya parisāya sambuddho,"
    },
    {
      "id": "bv8:4.2",
      "pali": "dhammacakkaṁ pavattayi;"
    },
    {
      "id": "bv8:4.3",
      "pali": "Gaṇanāya na vattabbo,"
    },
    {
      "id": "bv8:4.4",
      "pali": "paṭhamābhisamayo ahu."
    },
    {
      "id": "bv8:5.1",
      "pali": "Tato parampi desente,"
    },
    {
      "id": "bv8:5.2",
      "pali": "marūnañca samāgame;"
    },
    {
      "id": "bv8:5.3",
      "pali": "Navutikoṭisahassānaṁ,"
    },
    {
      "id": "bv8:5.4",
      "pali": "dutiyābhisamayo ahu."
    },
    {
      "id": "bv8:6.1",
      "pali": "Punāparaṁ rājaputto,"
    },
    {
      "id": "bv8:6.2",
      "pali": "jayaseno nāma khattiyo;"
    },
    {
      "id": "bv8:6.3",
      "pali": "Ārāmaṁ ropayitvāna,"
    },
    {
      "id": "bv8:6.4",
      "pali": "buddhe niyyādayī tadā."
    },
    {
      "id": "bv8:7.1",
      "pali": "Tassa yāgaṁ pakittento,"
    },
    {
      "id": "bv8:7.2",
      "pali": "dhammaṁ desesi cakkhumā;"
    },
    {
      "id": "bv8:7.3",
      "pali": "Tadā koṭisahassānaṁ,"
    },
    {
      "id": "bv8:7.4",
      "pali": "tatiyābhisamayo ahu."
    },
    {
      "id": "bv8:8.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv8:8.2",
      "pali": "sobhitassa mahesino;"
    },
    {
      "id": "bv8:8.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv8:8.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv8:9.1",
      "pali": "Uggato nāma so rājā,"
    },
    {
      "id": "bv8:9.2",
      "pali": "dānaṁ deti naruttame;"
    },
    {
      "id": "bv8:9.3",
      "pali": "Tamhi dāne samāgañchuṁ,"
    },
    {
      "id": "bv8:9.4",
      "pali": "arahantā satakoṭiyo."
    },
    {
      "id": "bv8:10.1",
      "pali": "Punāparaṁ puragaṇo,"
    },
    {
      "id": "bv8:10.2",
      "pali": "deti dānaṁ naruttame;"
    },
    {
      "id": "bv8:10.3",
      "pali": "Tadā navutikoṭīnaṁ,"
    },
    {
      "id": "bv8:10.4",
      "pali": "dutiyo āsi samāgamo."
    },
    {
      "id": "bv8:11.1",
      "pali": "Devaloke vasitvāna,"
    },
    {
      "id": "bv8:11.2",
      "pali": "yadā orohatī jino;"
    },
    {
      "id": "bv8:11.3",
      "pali": "Tadā asītikoṭīnaṁ,"
    },
    {
      "id": "bv8:11.4",
      "pali": "tatiyo āsi samāgamo."
    },
    {
      "id": "bv8:12.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv8:12.2",
      "pali": "sujāto nāma brāhmaṇo;"
    },
    {
      "id": "bv8:12.3",
      "pali": "Tadā sasāvakaṁ buddhaṁ,"
    },
    {
      "id": "bv8:12.4",
      "pali": "annapānena tappayiṁ."
    },
    {
      "id": "bv8:13.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv8:13.2",
      "pali": "sobhito lokanāyako;"
    },
    {
      "id": "bv8:13.3",
      "pali": "‘Aparimeyyito kappe,"
    },
    {
      "id": "bv8:13.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv8:14.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv8:14.2",
      "pali": "…pe…"
    },
    {
      "id": "bv8:14.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv8:15.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv8:15.2",
      "pali": "haṭṭho saṁviggamānaso;"
    },
    {
      "id": "bv8:15.3",
      "pali": "Tamevatthamanuppattiyā,"
    },
    {
      "id": "bv8:15.4",
      "pali": "uggaṁ dhitimakāsahaṁ."
    },
    {
      "id": "bv8:16.1",
      "pali": "Sudhammaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv8:16.2",
      "pali": "sudhammo nāma khattiyo;"
    },
    {
      "id": "bv8:16.3",
      "pali": "Sudhammā nāma janikā,"
    },
    {
      "id": "bv8:16.4",
      "pali": "sobhitassa mahesino."
    },
    {
      "id": "bv8:17.1",
      "pali": "Navavassasahassāni,"
    },
    {
      "id": "bv8:17.2",
      "pali": "agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv8:17.3",
      "pali": "Kumudo nāḷino padumo,"
    },
    {
      "id": "bv8:17.4",
      "pali": "tayo pāsādamuttamā."
    },
    {
      "id": "bv8:18.1",
      "pali": "Sattatiṁsasahassāni,"
    },
    {
      "id": "bv8:18.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv8:18.3",
      "pali": "Maṇilā nāma sā nārī,"
    },
    {
      "id": "bv8:18.4",
      "pali": "sīho nāmāsi atrajo."
    },
    {
      "id": "bv8:19.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv8:19.2",
      "pali": "pāsādenābhinikkhami;"
    },
    {
      "id": "bv8:19.3",
      "pali": "Sattāhaṁ padhānacāraṁ,"
    },
    {
      "id": "bv8:19.4",
      "pali": "caritvā purisuttamo."
    },
    {
      "id": "bv8:20.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv8:20.2",
      "pali": "sobhito lokanāyako;"
    },
    {
      "id": "bv8:20.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv8:20.4",
      "pali": "sudhammuyyānamuttame."
    },
    {
      "id": "bv8:21.1",
      "pali": "Asamo ca sunetto ca,"
    },
    {
      "id": "bv8:21.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv8:21.3",
      "pali": "Anomo nāmupaṭṭhāko,"
    },
    {
      "id": "bv8:21.4",
      "pali": "sobhitassa mahesino."
    },
    {
      "id": "bv8:22.1",
      "pali": "Nakulā ca sujātā ca,"
    },
    {
      "id": "bv8:22.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv8:22.3",
      "pali": "Bujjhamāno ca so buddho,"
    },
    {
      "id": "bv8:22.4",
      "pali": "nāgamūle abujjhatha."
    },
    {
      "id": "bv8:23.1",
      "pali": "Rammo ceva sudatto ca,"
    },
    {
      "id": "bv8:23.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv8:23.3",
      "pali": "Nakulā ceva cittā ca,"
    },
    {
      "id": "bv8:23.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv8:24.1",
      "pali": "Aṭṭhapaṇṇāsaratanaṁ,"
    },
    {
      "id": "bv8:24.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv8:24.3",
      "pali": "Obhāseti disā sabbā,"
    },
    {
      "id": "bv8:24.4",
      "pali": "sataraṁsīva uggato."
    },
    {
      "id": "bv8:25.1",
      "pali": "Yathā suphullaṁ pavanaṁ,"
    },
    {
      "id": "bv8:25.2",
      "pali": "nānāgandhehi dhūpitaṁ;"
    },
    {
      "id": "bv8:25.3",
      "pali": "Tatheva tassa pāvacanaṁ,"
    },
    {
      "id": "bv8:25.4",
      "pali": "sīlagandhehi dhūpitaṁ."
    },
    {
      "id": "bv8:26.1",
      "pali": "Yathāpi sāgaro nāma,"
    },
    {
      "id": "bv8:26.2",
      "pali": "dassanena atappiyo;"
    },
    {
      "id": "bv8:26.3",
      "pali": "Tatheva tassa pāvacanaṁ,"
    },
    {
      "id": "bv8:26.4",
      "pali": "savanena atappiyaṁ."
    },
    {
      "id": "bv8:27.1",
      "pali": "Navutivassasahassāni,"
    },
    {
      "id": "bv8:27.2",
      "pali": "āyu vijjati tāvade;"
    },
    {
      "id": "bv8:27.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv8:27.4",
      "pali": "tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv8:28.1",
      "pali": "Ovādaṁ anusiṭṭhiñca,"
    },
    {
      "id": "bv8:28.2",
      "pali": "datvāna sesake jane;"
    },
    {
      "id": "bv8:28.3",
      "pali": "Hutāsanova tāpetvā,"
    },
    {
      "id": "bv8:28.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv8:29.1",
      "pali": "So ca buddho asamasamo,"
    },
    {
      "id": "bv8:29.2",
      "pali": "tepi sāvakā balappattā;"
    },
    {
      "id": "bv8:29.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv8:29.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv8:30.1",
      "pali": "Sobhito varasambuddho,"
    },
    {
      "id": "bv8:30.2",
      "pali": "Sīhārāmamhi nibbuto;"
    },
    {
      "id": "bv8:30.3",
      "pali": "Dhātuvitthārikaṁ āsi,"
    },
    {
      "id": "bv8:30.4",
      "pali": "Tesu tesu padesato”ti."
    },
    {
      "id": "bv8:31.1",
      "pali": "Sobhitassa bhagavato vaṁso chaṭṭho."
    }
  ]
}
