{
  "uid": "ja471",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja471:1.1",
      "pali": "“Yesaṁ na kadāci bhūtapubbaṁ,"
    },
    {
      "id": "ja471:1.2",
      "pali": "Sakhyaṁ sattapadampimasmi loke;"
    },
    {
      "id": "ja471:1.3",
      "pali": "Jātā amittā duve sahāyā,"
    },
    {
      "id": "ja471:1.4",
      "pali": "Paṭisandhāya caranti kissa hetu”."
    },
    {
      "id": "ja471:2.1",
      "pali": "“Yadi me ajja pātarāsakāle,"
    },
    {
      "id": "ja471:2.2",
      "pali": "Pañhaṁ na sakkuṇeyyātha vattumetaṁ;"
    },
    {
      "id": "ja471:2.3",
      "pali": "Raṭṭhā pabbājayissāmi vo sabbe,"
    },
    {
      "id": "ja471:2.4",
      "pali": "Na hi mattho duppaññajātikehi”."
    },
    {
      "id": "ja471:3.1",
      "pali": "“Mahājanasamāgamamhi ghore,"
    },
    {
      "id": "ja471:3.2",
      "pali": "Janakolāhalasaṅgamamhi jāte;"
    },
    {
      "id": "ja471:3.3",
      "pali": "Vikkhittamanā anekacittā,"
    },
    {
      "id": "ja471:3.4",
      "pali": "Pañhaṁ na sakkuṇoma vattumetaṁ."
    },
    {
      "id": "ja471:4.1",
      "pali": "Ekaggacittāva ekamekā,"
    },
    {
      "id": "ja471:4.2",
      "pali": "Rahasi gatā atthaṁ nicintayitvā;"
    },
    {
      "id": "ja471:4.3",
      "pali": "Paviveke sammasitvāna dhīrā,"
    },
    {
      "id": "ja471:4.4",
      "pali": "Atha vakkhanti janinda etamatthaṁ”."
    },
    {
      "id": "ja471:5.1",
      "pali": "“Uggaputtarājaputtiyānaṁ,"
    },
    {
      "id": "ja471:5.2",
      "pali": "Urabbhassa maṁsaṁ piyaṁ manāpaṁ;"
    },
    {
      "id": "ja471:5.3",
      "pali": "Na sunakhassa te adenti maṁsaṁ,"
    },
    {
      "id": "ja471:5.4",
      "pali": "Atha meṇḍassa suṇena sakhyamassa”."
    },
    {
      "id": "ja471:6.1",
      "pali": "“Cammaṁ vihananti eḷakassa,"
    },
    {
      "id": "ja471:6.2",
      "pali": "Assapiṭṭhattharassukhassa hetu;"
    },
    {
      "id": "ja471:6.3",
      "pali": "Na ca te sunakhassa attharanti,"
    },
    {
      "id": "ja471:6.4",
      "pali": "Atha meṇḍassa suṇena sakhyamassa”."
    },
    {
      "id": "ja471:7.1",
      "pali": "“Āvellitasiṅgiko hi meṇḍo,"
    },
    {
      "id": "ja471:7.2",
      "pali": "Na ca sunakhassa visāṇakāni atthi;"
    },
    {
      "id": "ja471:7.3",
      "pali": "Tiṇabhakkho maṁsabhojano ca,"
    },
    {
      "id": "ja471:7.4",
      "pali": "Atha meṇḍassa suṇena sakhyamassa”."
    },
    {
      "id": "ja471:8.1",
      "pali": "“Tiṇamāsi palāsamāsi meṇḍo,"
    },
    {
      "id": "ja471:8.2",
      "pali": "Na ca sunakho tiṇamāsi no palāsaṁ;"
    },
    {
      "id": "ja471:8.3",
      "pali": "Gaṇheyya suṇo sasaṁ biḷāraṁ,"
    },
    {
      "id": "ja471:8.4",
      "pali": "Atha meṇḍassa suṇena sakhyamassa”."
    },
    {
      "id": "ja471:9.1",
      "pali": "“Aṭṭhaḍḍhapado catuppadassa,"
    },
    {
      "id": "ja471:9.2",
      "pali": "Meṇḍo aṭṭhanakho adissamāno;"
    },
    {
      "id": "ja471:9.3",
      "pali": "Chādiyamāharatī ayaṁ imassa,"
    },
    {
      "id": "ja471:9.4",
      "pali": "Maṁsaṁ āharatī ayaṁ amussa."
    },
    {
      "id": "ja471:10.1",
      "pali": "Pāsādavaragato videhaseṭṭho,"
    },
    {
      "id": "ja471:10.2",
      "pali": "Vitihāraṁ aññamaññabhojanānaṁ;"
    },
    {
      "id": "ja471:10.3",
      "pali": "Addakkhi kira sakkhikaṁ janindo,"
    },
    {
      "id": "ja471:10.4",
      "pali": "Bubhukkassa puṇṇaṁmukhassa cetaṁ”."
    },
    {
      "id": "ja471:11.1",
      "pali": "“Lābhā vata me anapparūpā,"
    },
    {
      "id": "ja471:11.2",
      "pali": "Yassa medisā paṇḍitā kulamhi;"
    },
    {
      "id": "ja471:11.3",
      "pali": "Pañhassa gambhīragataṁ nipuṇamatthaṁ,"
    },
    {
      "id": "ja471:11.4",
      "pali": "Paṭivijjhanti subhāsitena dhīrā."
    },
    {
      "id": "ja471:12.1",
      "pali": "Assatarirathañca ekamekaṁ,"
    },
    {
      "id": "ja471:12.2",
      "pali": "Phītaṁ gāmavarañca ekamekaṁ;"
    },
    {
      "id": "ja471:12.3",
      "pali": "Sabbesaṁ vo dammi paṇḍitānaṁ,"
    },
    {
      "id": "ja471:12.4",
      "pali": "Paramappatītamano subhāsitenā”ti."
    },
    {
      "id": "ja471:13.1",
      "pali": "Meṇḍakapañhajātakaṁ aṭṭhamaṁ."
    }
  ]
}
