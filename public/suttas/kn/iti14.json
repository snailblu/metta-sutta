{
  "uid": "iti14",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti14:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti14:2.1",
      "pali": "“Nāhaṁ, bhikkhave, aññaṁ ekanīvaraṇampi samanupassāmi yena nīvaraṇena nivutā pajā dīgharattaṁ sandhāvanti saṁsaranti yathayidaṁ, bhikkhave, avijjānīvaraṇaṁ."
    },
    {
      "id": "iti14:2.2",
      "pali": "Avijjānīvaraṇena hi, bhikkhave, nivutā pajā dīgharattaṁ sandhāvanti saṁsarantī”ti."
    },
    {
      "id": "iti14:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti14:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti14:3.1",
      "pali": "“Natthañño ekadhammopi,"
    },
    {
      "id": "iti14:3.2",
      "pali": "yenevaṁ nivutā pajā;"
    },
    {
      "id": "iti14:3.3",
      "pali": "Saṁsaranti ahorattaṁ,"
    },
    {
      "id": "iti14:3.4",
      "pali": "yathā mohena āvutā."
    },
    {
      "id": "iti14:4.1",
      "pali": "Ye ca mohaṁ pahantvāna,"
    },
    {
      "id": "iti14:4.2",
      "pali": "tamokhandhaṁ padālayuṁ;"
    },
    {
      "id": "iti14:4.3",
      "pali": "Na te puna saṁsaranti,"
    },
    {
      "id": "iti14:4.4",
      "pali": "hetu tesaṁ na vijjatī”ti."
    },
    {
      "id": "iti14:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti14:5.2",
      "pali": "Catutthaṁ."
    }
  ]
}
