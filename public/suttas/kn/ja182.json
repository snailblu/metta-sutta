{
  "uid": "ja182",
  "title": "Asadisavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja182:1.1",
      "pali": "“Saṅgāmāvacaro sūro,"
    },
    {
      "id": "ja182:1.2",
      "pali": "balavā iti vissuto;"
    },
    {
      "id": "ja182:1.3",
      "pali": "Kiṁ nu toraṇamāsajja,"
    },
    {
      "id": "ja182:1.4",
      "pali": "paṭikkamasi kuñjara."
    },
    {
      "id": "ja182:2.1",
      "pali": "Omadda khippaṁ palighaṁ,"
    },
    {
      "id": "ja182:2.2",
      "pali": "esikāni ca abbaha;"
    },
    {
      "id": "ja182:2.3",
      "pali": "Toraṇāni ca madditvā,"
    },
    {
      "id": "ja182:2.4",
      "pali": "khippaṁ pavisa kuñjarā”ti."
    },
    {
      "id": "ja182:3.1",
      "pali": "Saṅgāmāvacarajātakaṁ dutiyaṁ."
    }
  ]
}
