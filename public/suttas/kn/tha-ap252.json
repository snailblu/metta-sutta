{
  "uid": "tha-ap252",
  "title": "10 Uddālakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap252:1.1",
      "pali": "“Kakudho nāma nāmena,"
    },
    {
      "id": "tha-ap252:1.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap252:1.3",
      "pali": "Pavanā nikkhamitvāna,"
    },
    {
      "id": "tha-ap252:1.4",
      "pali": "anuppatto mahānadiṁ."
    },
    {
      "id": "tha-ap252:2.1",
      "pali": "Uddālakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap252:2.2",
      "pali": "sayambhussa adāsahaṁ;"
    },
    {
      "id": "tha-ap252:2.3",
      "pali": "Saṁyatassujubhūtassa,"
    },
    {
      "id": "tha-ap252:2.4",
      "pali": "pasannamānaso ahaṁ."
    },
    {
      "id": "tha-ap252:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap252:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap252:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap252:3.4",
      "pali": "pupphadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap252:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap252:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap252:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap252:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā uddālakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap252:6.1",
      "pali": "Uddālakadāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap252:7.1",
      "pali": "Tuvaradāyakavaggo pañcavīsatimo."
    },
    {
      "id": "tha-ap252:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap252:9.1",
      "pali": "Tuvaranāganaḷinā,"
    },
    {
      "id": "tha-ap252:9.2",
      "pali": "viravī kuṭidhūpako;"
    },
    {
      "id": "tha-ap252:9.3",
      "pali": "Patto dhātusattaliyo,"
    },
    {
      "id": "tha-ap252:9.4",
      "pali": "bimbi uddālakena ca;"
    },
    {
      "id": "tha-ap252:9.5",
      "pali": "Sattatiṁsati gāthāyo,"
    },
    {
      "id": "tha-ap252:9.6",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
