{
  "uid": "thag2.39",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.39:1.1",
      "pali": "“Ambapallavasaṅkāsaṁ,"
    },
    {
      "id": "thag2.39:1.2",
      "pali": "aṁse katvāna cīvaraṁ;"
    },
    {
      "id": "thag2.39:1.3",
      "pali": "Nisinno hatthigīvāyaṁ,"
    },
    {
      "id": "thag2.39:1.4",
      "pali": "gāmaṁ piṇḍāya pāvisiṁ."
    },
    {
      "id": "thag2.39:2.1",
      "pali": "Hatthikkhandhato oruyha,"
    },
    {
      "id": "thag2.39:2.2",
      "pali": "saṁvegaṁ alabhiṁ tadā;"
    },
    {
      "id": "thag2.39:2.3",
      "pali": "Sohaṁ ditto tadā santo,"
    },
    {
      "id": "thag2.39:2.4",
      "pali": "patto me āsavakkhayo”ti."
    },
    {
      "id": "thag2.39:2.5",
      "pali": "… Usabho thero …."
    }
  ]
}
