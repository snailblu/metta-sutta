{
  "uid": "ja73",
  "title": "Varuṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja73:1.1",
      "pali": "“Saccaṁ kirevamāhaṁsu,"
    },
    {
      "id": "ja73:1.2",
      "pali": "narā ekacciyā idha;"
    },
    {
      "id": "ja73:1.3",
      "pali": "Kaṭṭhaṁ niplavitaṁ seyyo,"
    },
    {
      "id": "ja73:1.4",
      "pali": "na tvevekacciyo naro”ti."
    },
    {
      "id": "ja73:2.1",
      "pali": "Saccaṅkirajātakaṁ tatiyaṁ."
    }
  ]
}
