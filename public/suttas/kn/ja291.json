{
  "uid": "ja291",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja291:1.1",
      "pali": "“Sabbakāmadadaṁ kumbhaṁ,"
    },
    {
      "id": "ja291:1.2",
      "pali": "kuṭaṁ laddhāna dhuttako;"
    },
    {
      "id": "ja291:1.3",
      "pali": "Yāva naṁ anupāleti,"
    },
    {
      "id": "ja291:1.4",
      "pali": "tāva so sukhamedhati."
    },
    {
      "id": "ja291:2.1",
      "pali": "Yadā matto ca ditto ca,"
    },
    {
      "id": "ja291:2.2",
      "pali": "pamādā kumbhamabbhidā;"
    },
    {
      "id": "ja291:2.3",
      "pali": "Tadā naggo ca pottho ca,"
    },
    {
      "id": "ja291:2.4",
      "pali": "pacchā bālo vihaññati."
    },
    {
      "id": "ja291:3.1",
      "pali": "Evameva yo dhanaṁ laddhā,"
    },
    {
      "id": "ja291:3.2",
      "pali": "Pamatto paribhuñjati;"
    },
    {
      "id": "ja291:3.3",
      "pali": "Pacchā tappati dummedho,"
    },
    {
      "id": "ja291:3.4",
      "pali": "Kuṭaṁ bhitvāva dhuttako”ti."
    },
    {
      "id": "ja291:4.1",
      "pali": "Surāghaṭajātakaṁ paṭhamaṁ."
    }
  ]
}
