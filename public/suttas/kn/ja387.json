{
  "uid": "ja387",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja387:1.1",
      "pali": "“Akakkasaṁ apharusaṁ,"
    },
    {
      "id": "ja387:1.2",
      "pali": "kharadhotaṁ supāsiyaṁ;"
    },
    {
      "id": "ja387:1.3",
      "pali": "Sukhumaṁ tikhiṇaggañca,"
    },
    {
      "id": "ja387:1.4",
      "pali": "ko sūciṁ ketumicchati."
    },
    {
      "id": "ja387:2.1",
      "pali": "Sumajjañca supāsañca,"
    },
    {
      "id": "ja387:2.2",
      "pali": "anupubbaṁ suvaṭṭitaṁ;"
    },
    {
      "id": "ja387:2.3",
      "pali": "Ghanaghātimaṁ paṭithaddhaṁ,"
    },
    {
      "id": "ja387:2.4",
      "pali": "ko sūciṁ ketumicchati”."
    },
    {
      "id": "ja387:3.1",
      "pali": "“Ito dāni patāyanti,"
    },
    {
      "id": "ja387:3.2",
      "pali": "sūciyo baḷisāni ca;"
    },
    {
      "id": "ja387:3.3",
      "pali": "Koyaṁ kammāragāmasmiṁ,"
    },
    {
      "id": "ja387:3.4",
      "pali": "sūciṁ vikketumicchati."
    },
    {
      "id": "ja387:4.1",
      "pali": "Ito satthāni gacchanti,"
    },
    {
      "id": "ja387:4.2",
      "pali": "Kammantā vividhā puthū;"
    },
    {
      "id": "ja387:4.3",
      "pali": "Koyaṁ kammāragāmasmiṁ,"
    },
    {
      "id": "ja387:4.4",
      "pali": "Sūciṁ vikketumicchati”."
    },
    {
      "id": "ja387:5.1",
      "pali": "“Sūciṁ kammāragāmasmiṁ,"
    },
    {
      "id": "ja387:5.2",
      "pali": "vikketabbā pajānatā;"
    },
    {
      "id": "ja387:5.3",
      "pali": "Ācariyāva jānanti,"
    },
    {
      "id": "ja387:5.4",
      "pali": "kammaṁ sukatadukkaṭaṁ."
    },
    {
      "id": "ja387:6.1",
      "pali": "Imañce te pitā bhadde,"
    },
    {
      "id": "ja387:6.2",
      "pali": "Sūciṁ jaññā mayā kataṁ;"
    },
    {
      "id": "ja387:6.3",
      "pali": "Tayā ca maṁ nimanteyya,"
    },
    {
      "id": "ja387:6.4",
      "pali": "Yañcatthaññaṁ ghare dhanan”ti."
    },
    {
      "id": "ja387:7.1",
      "pali": "Sūcijātakaṁ dutiyaṁ."
    }
  ]
}
