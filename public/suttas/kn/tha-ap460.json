{
  "uid": "tha-ap460",
  "title": "Jātipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap460:1.1",
      "pali": "“Parinibbute bhagavati,"
    },
    {
      "id": "tha-ap460:1.2",
      "pali": "padumuttare mahāyase;"
    },
    {
      "id": "tha-ap460:1.3",
      "pali": "Pupphavaṭaṁsake katvā,"
    },
    {
      "id": "tha-ap460:1.4",
      "pali": "sarīramabhiropayiṁ."
    },
    {
      "id": "tha-ap460:2.1",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap460:2.2",
      "pali": "nimmānaṁ agamāsahaṁ;"
    },
    {
      "id": "tha-ap460:2.3",
      "pali": "Devalokagato santo,"
    },
    {
      "id": "tha-ap460:2.4",
      "pali": "puññakammaṁ sarāmahaṁ."
    },
    {
      "id": "tha-ap460:3.1",
      "pali": "Ambarā pupphavasso me,"
    },
    {
      "id": "tha-ap460:3.2",
      "pali": "sabbakālaṁ pavassati;"
    },
    {
      "id": "tha-ap460:3.3",
      "pali": "Saṁsarāmi manusse ce,"
    },
    {
      "id": "tha-ap460:3.4",
      "pali": "rājā homi mahāyaso."
    },
    {
      "id": "tha-ap460:4.1",
      "pali": "Tahiṁ kusumavasso me,"
    },
    {
      "id": "tha-ap460:4.2",
      "pali": "abhivassati sabbadā;"
    },
    {
      "id": "tha-ap460:4.3",
      "pali": "Tasseva pupphapūjāya,"
    },
    {
      "id": "tha-ap460:4.4",
      "pali": "vāhasā sabbadassino."
    },
    {
      "id": "tha-ap460:5.1",
      "pali": "Ayaṁ pacchimako mayhaṁ,"
    },
    {
      "id": "tha-ap460:5.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap460:5.3",
      "pali": "Ajjāpi pupphavasso me,"
    },
    {
      "id": "tha-ap460:5.4",
      "pali": "abhivassati sabbadā."
    },
    {
      "id": "tha-ap460:6.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap460:6.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap460:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap460:6.4",
      "pali": "dehapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap460:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap460:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap460:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap460:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap460:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap460:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap460:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap460:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap460:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap460:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā jātipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap460:11.1",
      "pali": "Jātipupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
