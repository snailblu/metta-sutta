{
  "uid": "tha-ap458",
  "title": "Vanakoraṇḍiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap458:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap458:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap458:1.3",
      "pali": "Vanakoraṇḍamādāya,"
    },
    {
      "id": "tha-ap458:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap458:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap458:2.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap458:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap458:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap458:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap458:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap458:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap458:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap458:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap458:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap458:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap458:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap458:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap458:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā vanakoraṇḍiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap458:7.1",
      "pali": "Vanakoraṇḍiyattherassāpadānaṁ chaṭṭhaṁ."
    },
    {
      "id": "tha-ap458:7.2",
      "pali": "Vīsatimaṁ bhāṇavāraṁ."
    }
  ]
}
