{
  "uid": "ja92",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja92:1.1",
      "pali": "“Ukkaṭṭhe sūramicchanti,"
    },
    {
      "id": "ja92:1.2",
      "pali": "mantīsu akutūhalaṁ;"
    },
    {
      "id": "ja92:1.3",
      "pali": "Piyañca annapānamhi,"
    },
    {
      "id": "ja92:1.4",
      "pali": "atthe jāte ca paṇḍitan”ti."
    },
    {
      "id": "ja92:2.1",
      "pali": "Mahāsārajātakaṁ dutiyaṁ."
    }
  ]
}
