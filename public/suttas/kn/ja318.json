{
  "uid": "ja318",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja318:1.1",
      "pali": "“Yaṁ taṁ vasantasamaye,"
    },
    {
      "id": "ja318:1.2",
      "pali": "kaṇaveresu bhāṇusu;"
    },
    {
      "id": "ja318:1.3",
      "pali": "Sāmaṁ bāhāya pīḷesi,"
    },
    {
      "id": "ja318:1.4",
      "pali": "sā taṁ ārogyamabravi”."
    },
    {
      "id": "ja318:2.1",
      "pali": "“Ambho na kira saddheyyaṁ,"
    },
    {
      "id": "ja318:2.2",
      "pali": "yaṁ vāto pabbataṁ vahe;"
    },
    {
      "id": "ja318:2.3",
      "pali": "Pabbatañce vahe vāto,"
    },
    {
      "id": "ja318:2.4",
      "pali": "sabbampi pathaviṁ vahe;"
    },
    {
      "id": "ja318:2.5",
      "pali": "Yattha sāmā kālakatā,"
    },
    {
      "id": "ja318:2.6",
      "pali": "sā maṁ ārogyamabravi”."
    },
    {
      "id": "ja318:3.1",
      "pali": "“Na ceva sā kālakatā,"
    },
    {
      "id": "ja318:3.2",
      "pali": "na ca sā aññamicchati;"
    },
    {
      "id": "ja318:3.3",
      "pali": "Ekabhattikinī sāmā,"
    },
    {
      "id": "ja318:3.4",
      "pali": "tameva abhikaṅkhati”."
    },
    {
      "id": "ja318:4.1",
      "pali": "“Asanthutaṁ maṁ cirasanthutena,"
    },
    {
      "id": "ja318:4.2",
      "pali": "Nimīni sāmā adhuvaṁ dhuvena;"
    },
    {
      "id": "ja318:4.3",
      "pali": "Mayāpi sāmā nimineyya aññaṁ,"
    },
    {
      "id": "ja318:4.4",
      "pali": "Ito ahaṁ dūrataraṁ gamissan”ti."
    },
    {
      "id": "ja318:5.1",
      "pali": "Kaṇaverajātakaṁ aṭṭhamaṁ."
    }
  ]
}
