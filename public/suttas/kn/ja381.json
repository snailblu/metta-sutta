{
  "uid": "ja381",
  "title": "Avāriyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja381:1.1",
      "pali": "“Na me rucci migālopa,"
    },
    {
      "id": "ja381:1.2",
      "pali": "yassa te tādisī gatī;"
    },
    {
      "id": "ja381:1.3",
      "pali": "Atuccaṁ tāta patasi,"
    },
    {
      "id": "ja381:1.4",
      "pali": "abhūmiṁ tāta sevasi."
    },
    {
      "id": "ja381:2.1",
      "pali": "Catukkaṇṇaṁva kedāraṁ,"
    },
    {
      "id": "ja381:2.2",
      "pali": "yadā te pathavī siyā;"
    },
    {
      "id": "ja381:2.3",
      "pali": "Tato tāta nivattassu,"
    },
    {
      "id": "ja381:2.4",
      "pali": "māssu etto paraṁ gami”."
    },
    {
      "id": "ja381:3.1",
      "pali": "“Santi aññepi sakuṇā,"
    },
    {
      "id": "ja381:3.2",
      "pali": "pattayānā vihaṅgamā;"
    },
    {
      "id": "ja381:3.3",
      "pali": "Akkhittā vātavegena,"
    },
    {
      "id": "ja381:3.4",
      "pali": "naṭṭhā te sassatīsamā."
    },
    {
      "id": "ja381:4.1",
      "pali": "Akatvā apanandassa,"
    },
    {
      "id": "ja381:4.2",
      "pali": "pitu vuddhassa sāsanaṁ;"
    },
    {
      "id": "ja381:4.3",
      "pali": "Kālavāte atikkamma,"
    },
    {
      "id": "ja381:4.4",
      "pali": "verambhānaṁ vasaṁ agā."
    },
    {
      "id": "ja381:5.1",
      "pali": "Tassa puttā ca dārā ca,"
    },
    {
      "id": "ja381:5.2",
      "pali": "ye caññe anujīvino;"
    },
    {
      "id": "ja381:5.3",
      "pali": "Sabbe byasanamāpāduṁ,"
    },
    {
      "id": "ja381:5.4",
      "pali": "anovādakare dije."
    },
    {
      "id": "ja381:6.1",
      "pali": "Evampi idha vuddhānaṁ,"
    },
    {
      "id": "ja381:6.2",
      "pali": "yo vākyaṁ nāvabujjhati;"
    },
    {
      "id": "ja381:6.3",
      "pali": "Atisīmacaro ditto,"
    },
    {
      "id": "ja381:6.4",
      "pali": "gijjhovātītasāsano;"
    },
    {
      "id": "ja381:6.5",
      "pali": "Sabbe byasanaṁ papponti,"
    },
    {
      "id": "ja381:6.6",
      "pali": "akatvā vuddhasāsanan”ti."
    },
    {
      "id": "ja381:7.1",
      "pali": "Migālopajātakaṁ chaṭṭhaṁ."
    }
  ]
}
