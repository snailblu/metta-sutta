{
  "uid": "vv80",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv80:1.1",
      "pali": "“Disvāna devaṁ paṭipucchi bhikkhu,"
    },
    {
      "id": "vv80:1.2",
      "pali": "Ucce vimānamhi ciraṭṭhitike;"
    },
    {
      "id": "vv80:1.3",
      "pali": "Āmuttahatthābharaṇaṁ yasassiṁ,"
    },
    {
      "id": "vv80:1.4",
      "pali": "Dibbe vimānamhi yathāpi candimā."
    },
    {
      "id": "vv80:2.1",
      "pali": "Alaṅkato malyadharo suvattho,"
    },
    {
      "id": "vv80:2.2",
      "pali": "Sukuṇḍalī kappitakesamassu;"
    },
    {
      "id": "vv80:2.3",
      "pali": "Āmuttahatthābharaṇo yasassī,"
    },
    {
      "id": "vv80:2.4",
      "pali": "Dibbe vimānamhi yathāpi candimā."
    },
    {
      "id": "vv80:3.1",
      "pali": "Dibbā ca vīṇā pavadanti vagguṁ,"
    },
    {
      "id": "vv80:3.2",
      "pali": "Aṭṭhaṭṭhakā sikkhitā sādhurūpā;"
    },
    {
      "id": "vv80:3.3",
      "pali": "Dibbā ca kaññā tidasacarā uḷārā,"
    },
    {
      "id": "vv80:3.4",
      "pali": "Naccanti gāyanti pamodayanti."
    },
    {
      "id": "vv80:4.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv80:4.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv80:4.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv80:4.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv80:5.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv80:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv80:5.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv80:6.1",
      "pali": "“Ahaṁ manussesu manussabhūto,"
    },
    {
      "id": "vv80:6.2",
      "pali": "Saṅgamma rakkhissaṁ paresaṁ dhenuyo;"
    },
    {
      "id": "vv80:6.3",
      "pali": "Tato ca āgā samaṇo mamantike,"
    },
    {
      "id": "vv80:6.4",
      "pali": "Gāvo ca māse agamaṁsu khādituṁ."
    },
    {
      "id": "vv80:7.1",
      "pali": "Dvayajja kiccaṁ ubhayañca kāriyaṁ,"
    },
    {
      "id": "vv80:7.2",
      "pali": "Iccevahaṁ bhante tadā vicintayiṁ;"
    },
    {
      "id": "vv80:7.3",
      "pali": "Tato ca saññaṁ paṭiladdha yoniso,"
    },
    {
      "id": "vv80:7.4",
      "pali": "Dadāmi bhanteti khipiṁ anantakaṁ."
    },
    {
      "id": "vv80:8.1",
      "pali": "So māsakhettaṁ turito avāsariṁ,"
    },
    {
      "id": "vv80:8.2",
      "pali": "Purā ayaṁ bhañjati yassidaṁ dhanaṁ;"
    },
    {
      "id": "vv80:8.3",
      "pali": "Tato ca kaṇho urago mahāviso,"
    },
    {
      "id": "vv80:8.4",
      "pali": "Aḍaṁsi pāde turitassa me sato."
    },
    {
      "id": "vv80:9.1",
      "pali": "Svāhaṁ aṭṭomhi dukkhena pīḷito,"
    },
    {
      "id": "vv80:9.2",
      "pali": "Bhikkhu ca taṁ sāmaṁ muñcitvānantakaṁ;"
    },
    {
      "id": "vv80:9.3",
      "pali": "Ahāsi kummāsaṁ mamānukampayā,"
    },
    {
      "id": "vv80:9.4",
      "pali": "Tato cuto kālakatomhi devatā."
    },
    {
      "id": "vv80:10.1",
      "pali": "Tadeva kammaṁ kusalaṁ kataṁ mayā,"
    },
    {
      "id": "vv80:10.2",
      "pali": "Sukhañca kammaṁ anubhomi attanā;"
    },
    {
      "id": "vv80:10.3",
      "pali": "Tayā hi bhante anukampito bhusaṁ,"
    },
    {
      "id": "vv80:10.4",
      "pali": "Kataññutāya abhivādayāmi taṁ."
    },
    {
      "id": "vv80:11.1",
      "pali": "Sadevake loke samārake ca,"
    },
    {
      "id": "vv80:11.2",
      "pali": "Añño muni natthi tayānukampako;"
    },
    {
      "id": "vv80:11.3",
      "pali": "Tayā hi bhante anukampito bhusaṁ,"
    },
    {
      "id": "vv80:11.4",
      "pali": "Kataññutāya abhivādayāmi taṁ."
    },
    {
      "id": "vv80:12.1",
      "pali": "Imasmiṁ loke parasmiṁ vā pana,"
    },
    {
      "id": "vv80:12.2",
      "pali": "Añño munī natthi tayānukampako;"
    },
    {
      "id": "vv80:12.3",
      "pali": "Tayā hi bhante anukampito bhusaṁ,"
    },
    {
      "id": "vv80:12.4",
      "pali": "Kataññutāya abhivādayāmi tan”ti."
    },
    {
      "id": "vv80:13.1",
      "pali": "Gopālavimānaṁ chaṭṭhaṁ."
    }
  ]
}
