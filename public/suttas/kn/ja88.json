{
  "uid": "ja88",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja88:1.1",
      "pali": "“Kalyāṇimeva muñceyya,"
    },
    {
      "id": "ja88:1.2",
      "pali": "na hi muñceyya pāpikaṁ;"
    },
    {
      "id": "ja88:1.3",
      "pali": "Mokkho kalyāṇiyā sādhu,"
    },
    {
      "id": "ja88:1.4",
      "pali": "mutvā tappati pāpikan”ti."
    },
    {
      "id": "ja88:2.1",
      "pali": "Sārambhajātakaṁ aṭṭhamaṁ."
    }
  ]
}
