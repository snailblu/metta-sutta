{
  "uid": "vv83",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv83:1.1",
      "pali": "“Alaṅkato maṭṭhakuṇḍalī,"
    },
    {
      "id": "vv83:1.2",
      "pali": "Māladhārī haricandanussado;"
    },
    {
      "id": "vv83:1.3",
      "pali": "Bāhā paggayha kandasi,"
    },
    {
      "id": "vv83:1.4",
      "pali": "Vanamajjhe kiṁ dukkhito tuvan”ti."
    },
    {
      "id": "vv83:2.1",
      "pali": "“Sovaṇṇamayo pabhassaro,"
    },
    {
      "id": "vv83:2.2",
      "pali": "Uppanno rathapañjaro mama;"
    },
    {
      "id": "vv83:2.3",
      "pali": "Tassa cakkayugaṁ na vindāmi,"
    },
    {
      "id": "vv83:2.4",
      "pali": "Tena dukkhena jahāmi jīvitan”ti."
    },
    {
      "id": "vv83:3.1",
      "pali": "“Sovaṇṇamayaṁ maṇimayaṁ,"
    },
    {
      "id": "vv83:3.2",
      "pali": "Lohitakamayaṁ atha rūpiyamayaṁ;"
    },
    {
      "id": "vv83:3.3",
      "pali": "Ācikkha me bhaddamāṇava,"
    },
    {
      "id": "vv83:3.4",
      "pali": "Cakkayugaṁ paṭipādayāmi te”ti."
    },
    {
      "id": "vv83:4.1",
      "pali": "So māṇavo tassa pāvadi,"
    },
    {
      "id": "vv83:4.2",
      "pali": "“Candasūriyā ubhayettha dissare;"
    },
    {
      "id": "vv83:4.3",
      "pali": "Sovaṇṇamayo ratho mama,"
    },
    {
      "id": "vv83:4.4",
      "pali": "Tena cakkayugena sobhatī”ti."
    },
    {
      "id": "vv83:5.1",
      "pali": "“Bālo kho tvaṁ asi māṇava,"
    },
    {
      "id": "vv83:5.2",
      "pali": "Yo tvaṁ patthayase apatthiyaṁ;"
    },
    {
      "id": "vv83:5.3",
      "pali": "Maññāmi tuvaṁ marissasi,"
    },
    {
      "id": "vv83:5.4",
      "pali": "Na hi tvaṁ lacchasi candasūriye”ti."
    },
    {
      "id": "vv83:6.1",
      "pali": "“Gamanāgamanampi dissati,"
    },
    {
      "id": "vv83:6.2",
      "pali": "Vaṇṇadhātu ubhayattha vīthiyā;"
    },
    {
      "id": "vv83:6.3",
      "pali": "Peto kālakato na dissati,"
    },
    {
      "id": "vv83:6.4",
      "pali": "Ko nidha kandataṁ bālyataro”ti."
    },
    {
      "id": "vv83:7.1",
      "pali": "“Saccaṁ kho vadesi māṇava,"
    },
    {
      "id": "vv83:7.2",
      "pali": "Ahameva kandataṁ bālyataro;"
    },
    {
      "id": "vv83:7.3",
      "pali": "Candaṁ viya dārako rudaṁ,"
    },
    {
      "id": "vv83:7.4",
      "pali": "Petaṁ kālakatābhipatthayinti."
    },
    {
      "id": "vv83:8.1",
      "pali": "Ādittaṁ vata maṁ santaṁ,"
    },
    {
      "id": "vv83:8.2",
      "pali": "ghatasittaṁva pāvakaṁ;"
    },
    {
      "id": "vv83:8.3",
      "pali": "Vārinā viya osiñcaṁ,"
    },
    {
      "id": "vv83:8.4",
      "pali": "sabbaṁ nibbāpaye daraṁ."
    },
    {
      "id": "vv83:9.1",
      "pali": "Abbahī vata me sallaṁ,"
    },
    {
      "id": "vv83:9.2",
      "pali": "sokaṁ hadayanissitaṁ;"
    },
    {
      "id": "vv83:9.3",
      "pali": "Yo me sokaparetassa,"
    },
    {
      "id": "vv83:9.4",
      "pali": "puttasokaṁ apānudi."
    },
    {
      "id": "vv83:10.1",
      "pali": "Svāhaṁ abbūḷhasallosmi,"
    },
    {
      "id": "vv83:10.2",
      "pali": "sītibhūtosmi nibbuto;"
    },
    {
      "id": "vv83:10.3",
      "pali": "Na socāmi na rodāmi,"
    },
    {
      "id": "vv83:10.4",
      "pali": "tava sutvāna māṇavā”ti."
    },
    {
      "id": "vv83:11.1",
      "pali": "“Devatā nusi gandhabbo,"
    },
    {
      "id": "vv83:11.2",
      "pali": "adu sakko purindado;"
    },
    {
      "id": "vv83:11.3",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "vv83:11.4",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "vv83:12.1",
      "pali": "“Yañca kandasi yañca rodasi,"
    },
    {
      "id": "vv83:12.2",
      "pali": "Puttaṁ āḷāhane sayaṁ dahitvā;"
    },
    {
      "id": "vv83:12.3",
      "pali": "Svāhaṁ kusalaṁ karitvā kammaṁ,"
    },
    {
      "id": "vv83:12.4",
      "pali": "Tidasānaṁ sahabyataṁ gato”ti."
    },
    {
      "id": "vv83:13.1",
      "pali": "“Appaṁ vā bahuṁ vā nāddasāma,"
    },
    {
      "id": "vv83:13.2",
      "pali": "Dānaṁ dadantassa sake agāre;"
    },
    {
      "id": "vv83:13.3",
      "pali": "Uposathakammaṁ vā tādisaṁ,"
    },
    {
      "id": "vv83:13.4",
      "pali": "Kena kammena gatosi devalokan”ti."
    },
    {
      "id": "vv83:14.1",
      "pali": "“Ābādhikohaṁ dukkhito gilāno,"
    },
    {
      "id": "vv83:14.2",
      "pali": "Āturarūpomhi sake nivesane;"
    },
    {
      "id": "vv83:14.3",
      "pali": "Buddhaṁ vigatarajaṁ vitiṇṇakaṅkhaṁ,"
    },
    {
      "id": "vv83:14.4",
      "pali": "Addakkhiṁ sugataṁ anomapaññaṁ."
    },
    {
      "id": "vv83:15.1",
      "pali": "Svāhaṁ muditamano pasannacitto,"
    },
    {
      "id": "vv83:15.2",
      "pali": "Añjaliṁ akariṁ tathāgatassa;"
    },
    {
      "id": "vv83:15.3",
      "pali": "Tāhaṁ kusalaṁ karitvāna kammaṁ,"
    },
    {
      "id": "vv83:15.4",
      "pali": "Tidasānaṁ sahabyataṁ gato”ti."
    },
    {
      "id": "vv83:16.1",
      "pali": "“Acchariyaṁ vata abbhutaṁ vata,"
    },
    {
      "id": "vv83:16.2",
      "pali": "Añjalikammassa ayamīdiso vipāko;"
    },
    {
      "id": "vv83:16.3",
      "pali": "Ahampi muditamano pasannacitto,"
    },
    {
      "id": "vv83:16.4",
      "pali": "Ajjeva buddhaṁ saraṇaṁ vajāmī”ti."
    },
    {
      "id": "vv83:17.1",
      "pali": "“Ajjeva buddhaṁ saraṇaṁ vajāhi,"
    },
    {
      "id": "vv83:17.2",
      "pali": "Dhammañca saṅghañca pasannacitto;"
    },
    {
      "id": "vv83:17.3",
      "pali": "Tatheva sikkhāya padāni pañca,"
    },
    {
      "id": "vv83:17.4",
      "pali": "Akhaṇḍaphullāni samādiyassu."
    },
    {
      "id": "vv83:18.1",
      "pali": "Pāṇātipātā viramassu khippaṁ,"
    },
    {
      "id": "vv83:18.2",
      "pali": "Loke adinnaṁ parivajjayassu;"
    },
    {
      "id": "vv83:18.3",
      "pali": "Amajjapo mā ca musā bhaṇāhi,"
    },
    {
      "id": "vv83:18.4",
      "pali": "Sakena dārena ca hohi tuṭṭho”ti."
    },
    {
      "id": "vv83:19.1",
      "pali": "“Atthakāmosi me yakkha,"
    },
    {
      "id": "vv83:19.2",
      "pali": "hitakāmosi devate;"
    },
    {
      "id": "vv83:19.3",
      "pali": "Karomi tuyhaṁ vacanaṁ,"
    },
    {
      "id": "vv83:19.4",
      "pali": "tvaṁsi ācariyo mamāti."
    },
    {
      "id": "vv83:20.1",
      "pali": "Upemi saraṇaṁ buddhaṁ,"
    },
    {
      "id": "vv83:20.2",
      "pali": "dhammañcāpi anuttaraṁ;"
    },
    {
      "id": "vv83:20.3",
      "pali": "Saṅghañca naradevassa,"
    },
    {
      "id": "vv83:20.4",
      "pali": "gacchāmi saraṇaṁ ahaṁ."
    },
    {
      "id": "vv83:21.1",
      "pali": "Pāṇātipātā viramāmi khippaṁ,"
    },
    {
      "id": "vv83:21.2",
      "pali": "Loke adinnaṁ parivajjayāmi;"
    },
    {
      "id": "vv83:21.3",
      "pali": "Amajjapo no ca musā bhaṇāmi,"
    },
    {
      "id": "vv83:21.4",
      "pali": "Sakena dārena ca homi tuṭṭho”ti."
    },
    {
      "id": "vv83:22.1",
      "pali": "Maṭṭhakuṇḍalīvimānaṁ navamaṁ."
    }
  ]
}
