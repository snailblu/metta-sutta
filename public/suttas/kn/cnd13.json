{
  "uid": "cnd13",
  "title": "Pucchāniddesa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cnd13:1.1",
      "pali": "<b>Yasmiṁ kāmā na vasanti,</b>"
    },
    {
      "id": "cnd13:1.2",
      "pali": "(iccāyasmā todeyyo)"
    },
    {
      "id": "cnd13:1.3",
      "pali": "<b>Taṇhā yassa na vijjati;</b>"
    },
    {
      "id": "cnd13:1.4",
      "pali": "<b>Kathaṅkathā ca yo tiṇṇo,</b>"
    },
    {
      "id": "cnd13:1.5",
      "pali": "<b>Vimokkho tassa kīdiso. </b>"
    },
    {
      "id": "cnd13:2.1",
      "pali": "<b>Yasmiṁ kāmā na vasantī</b>ti yasmiṁ kāmā na vasanti na saṁvasanti na āvasanti na parivasantīti—"
    },
    {
      "id": "cnd13:2.2",
      "pali": "yasmiṁ kāmā na vasanti."
    },
    {
      "id": "cnd13:2.3",
      "pali": "<b>Iccāyasmā todeyyo</b>ti."
    },
    {
      "id": "cnd13:2.4",
      "pali": "<b>Iccā</b>ti padasandhi …pe… padānupubbatāpetaṁ—"
    },
    {
      "id": "cnd13:2.5",
      "pali": "iccāti."
    },
    {
      "id": "cnd13:2.6",
      "pali": "<b>Āyasmā</b>ti piyavacanaṁ …pe…."
    },
    {
      "id": "cnd13:2.7",
      "pali": "<b>Todeyyo</b>ti tassa brāhmaṇassa nāmaṁ …pe… abhilāpoti—"
    },
    {
      "id": "cnd13:2.8",
      "pali": "iccāyasmā todeyyo."
    },
    {
      "id": "cnd13:3.1",
      "pali": "<b>Taṇhā yassa na vijjatī</b>ti taṇhā yassa natthi na atthi na saṁvijjati nupalabbhati ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "cnd13:3.2",
      "pali": "taṇhā yassa na vijjati."
    },
    {
      "id": "cnd13:4.1",
      "pali": "<b>Kathaṅkathā ca yo tiṇṇo</b>ti kathaṅkathā ca yo tiṇṇo uttiṇṇo nitthiṇṇo atikkanto samatikkanto vītivattoti—"
    },
    {
      "id": "cnd13:4.2",
      "pali": "kathaṅkathā ca yo tiṇṇo."
    },
    {
      "id": "cnd13:5.1",
      "pali": "<b>Vimokkho tassa kīdiso</b>ti vimokkho tassa kīdiso kiṁsaṇṭhito kiṁpakāro kiṁpaṭibhāgo icchitabboti vimokkhaṁ pucchatīti—"
    },
    {
      "id": "cnd13:5.2",
      "pali": "vimokkho tassa kīdiso."
    },
    {
      "id": "cnd13:5.3",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd13:6.1",
      "pali": "“Yasmiṁ kāmā na vasanti,"
    },
    {
      "id": "cnd13:6.2",
      "pali": "(iccāyasmā todeyyo)"
    },
    {
      "id": "cnd13:6.3",
      "pali": "Taṇhā yassa na vijjati;"
    },
    {
      "id": "cnd13:6.4",
      "pali": "Kathaṅkathā ca yo tiṇṇo,"
    },
    {
      "id": "cnd13:6.5",
      "pali": "Vimokkho tassa kīdiso”ti."
    },
    {
      "id": "cnd13:7.1",
      "pali": "<b>Yasmiṁ kāmā na vasanti,</b>"
    },
    {
      "id": "cnd13:7.2",
      "pali": "(todeyyāti bhagavā)"
    },
    {
      "id": "cnd13:7.3",
      "pali": "<b>Taṇhā yassa na vijjati;</b>"
    },
    {
      "id": "cnd13:7.4",
      "pali": "<b>Kathaṅkathā ca yo tiṇṇo,</b>"
    },
    {
      "id": "cnd13:7.5",
      "pali": "<b>Vimokkho tassa nāparo. </b>"
    },
    {
      "id": "cnd13:8.1",
      "pali": "<b>Yasmiṁ kāmā na vasantī</b>ti."
    },
    {
      "id": "cnd13:8.2",
      "pali": "<b>Yasmin</b>ti yasmiṁ puggale arahante khīṇāsave."
    },
    {
      "id": "cnd13:8.3",
      "pali": "<b>Kāmā</b>ti uddānato dve kāmā—"
    },
    {
      "id": "cnd13:8.4",
      "pali": "vatthukāmā ca kilesakāmā ca …pe…"
    },
    {
      "id": "cnd13:8.5",
      "pali": "ime vuccanti vatthukāmā …pe…"
    },
    {
      "id": "cnd13:8.6",
      "pali": "ime vuccanti kilesakāmā."
    },
    {
      "id": "cnd13:8.7",
      "pali": "<b>Yasmiṁ kāmā na vasantī</b>ti yasmiṁ kāmā na vasanti na saṁvasanti na āvasanti na parivasantīti—"
    },
    {
      "id": "cnd13:8.8",
      "pali": "yasmiṁ kāmā na vasanti."
    },
    {
      "id": "cnd13:9.1",
      "pali": "<b>Todeyyāti bhagavā</b>ti."
    },
    {
      "id": "cnd13:9.2",
      "pali": "<b>Todeyyā</b>ti bhagavā taṁ brāhmaṇaṁ nāmena ālapati."
    },
    {
      "id": "cnd13:9.3",
      "pali": "<b>Bhagavā</b>ti gāravādhivacanametaṁ …pe… sacchikā paññatti, yadidaṁ bhagavāti—"
    },
    {
      "id": "cnd13:9.4",
      "pali": "todeyyāti bhagavā."
    },
    {
      "id": "cnd13:10.1",
      "pali": "<b>Taṇhā yassa na vijjatī</b>ti."
    },
    {
      "id": "cnd13:10.2",
      "pali": "<b>Taṇhā</b>ti rūpataṇhā saddataṇhā gandhataṇhā rasataṇhā phoṭṭhabbataṇhā dhammataṇhā."
    },
    {
      "id": "cnd13:10.3",
      "pali": "<b>Yassā</b>ti arahato khīṇāsavassa."
    },
    {
      "id": "cnd13:10.4",
      "pali": "<b>Taṇhā yassa na vijjatī</b>ti taṇhā yassa natthi na atthi na saṁvijjati nupalabbhati, pahīnā samucchinnā vūpasantā paṭippassaddhā abhabbuppattikā ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "cnd13:10.5",
      "pali": "taṇhā yassa na vijjati."
    },
    {
      "id": "cnd13:11.1",
      "pali": "<b>Kathaṅkathā ca yo tiṇṇo</b>ti kathaṅkathā vuccati vicikicchā."
    },
    {
      "id": "cnd13:11.2",
      "pali": "Dukkhe kaṅkhā …pe… chambhitattaṁ cittassa manovilekho."
    },
    {
      "id": "cnd13:11.3",
      "pali": "<b>Yo</b>ti yo so arahaṁ khīṇāsavo."
    },
    {
      "id": "cnd13:11.4",
      "pali": "<b>Kathaṅkathā ca yo tiṇṇo</b>ti kathaṅkathā ca yo tiṇṇo uttiṇṇo nitthiṇṇo atikkanto samatikkanto vītivattoti—"
    },
    {
      "id": "cnd13:11.5",
      "pali": "kathaṅkathā ca yo tiṇṇo."
    },
    {
      "id": "cnd13:12.1",
      "pali": "<b>Vimokkho tassa nāparo</b>ti natthi tassa aparo vimokkho."
    },
    {
      "id": "cnd13:12.2",
      "pali": "Yena vimokkhena vimucceyya vimutto so."
    },
    {
      "id": "cnd13:12.3",
      "pali": "Kataṁ tassa vimokkhena karaṇīyanti—"
    },
    {
      "id": "cnd13:12.4",
      "pali": "vimokkho tassa nāparo."
    },
    {
      "id": "cnd13:12.5",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd13:13.1",
      "pali": "“Yasmiṁ kāmā na vasanti,"
    },
    {
      "id": "cnd13:13.2",
      "pali": "(todeyyāti bhagavā)"
    },
    {
      "id": "cnd13:13.3",
      "pali": "Taṇhā yassa na vijjati;"
    },
    {
      "id": "cnd13:13.4",
      "pali": "Kathaṅkathā ca yo tiṇṇo,"
    },
    {
      "id": "cnd13:13.5",
      "pali": "Vimokkho tassa nāparo”ti."
    },
    {
      "id": "cnd13:14.1",
      "pali": "<b>Nirāsaso so uda āsasāno,</b>"
    },
    {
      "id": "cnd13:14.2",
      "pali": "<b>Paññāṇavā so uda paññakappī;</b>"
    },
    {
      "id": "cnd13:14.3",
      "pali": "<b>Muniṁ ahaṁ sakka yathā vijaññaṁ,</b>"
    },
    {
      "id": "cnd13:14.4",
      "pali": "<b>Taṁ me viyācikkha samantacakkhu. </b>"
    },
    {
      "id": "cnd13:15.1",
      "pali": "<b>Nirāsaso so uda āsasāno</b>ti nittaṇho so, udāhu sataṇho rūpe āsīsati, sadde …pe…"
    },
    {
      "id": "cnd13:15.2",
      "pali": "gandhe …"
    },
