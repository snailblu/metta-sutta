    },
    {
      "id": "cnd13:15.24",
      "pali": "nevasaññānāsaññābhavaṁ …"
    },
    {
      "id": "cnd13:15.25",
      "pali": "ekavokārabhavaṁ …"
    },
    {
      "id": "cnd13:15.26",
      "pali": "catuvokārabhavaṁ …"
    },
    {
      "id": "cnd13:15.27",
      "pali": "pañcavokārabhavaṁ …"
    },
    {
      "id": "cnd13:15.28",
      "pali": "atītaṁ …"
    },
    {
      "id": "cnd13:15.29",
      "pali": "anāgataṁ …"
    },
    {
      "id": "cnd13:15.30",
      "pali": "paccuppannaṁ …"
    },
    {
      "id": "cnd13:15.31",
      "pali": "diṭṭhasutamutaviññātabbe dhamme āsīsati sādiyati pattheti piheti abhijappatīti—"
    },
    {
      "id": "cnd13:15.32",
      "pali": "nirāsaso so uda āsasāno."
    },
    {
      "id": "cnd13:16.1",
      "pali": "<b>Paññāṇavā so uda paññakappī</b>ti."
    },
    {
      "id": "cnd13:16.2",
      "pali": "<b>Paññāṇavā so</b>ti paṇḍito paññavā buddhimā ñāṇī vibhāvī medhāvī."
    },
    {
      "id": "cnd13:16.3",
      "pali": "<b>Uda paññakappī</b>ti udāhu aṭṭhasamāpattiñāṇena vā pañcābhiññāñāṇena vā micchāñāṇena vā taṇhākappaṁ vā diṭṭhikappaṁ vā kappeti janeti sañjaneti nibbatteti abhinibbattetīti—"
    },
    {
      "id": "cnd13:16.4",
      "pali": "paññāṇavā so uda paññakappī."
    },
    {
      "id": "cnd13:17.1",
      "pali": "<b>Muniṁ ahaṁ sakka yathā vijaññan</b>ti."
    },
    {
      "id": "cnd13:17.2",
      "pali": "<b>Sakkā</b>ti sakko bhagavā."
    },
    {
      "id": "cnd13:17.3",
      "pali": "Sakyakulā pabbajitotipi sakko."
    },
    {
      "id": "cnd13:17.4",
      "pali": "Atha vā aḍḍho mahaddhano dhanavātipi sakko."
    },
    {
      "id": "cnd13:17.5",
      "pali": "Tassimāni dhanāni, seyyathidaṁ—"
    },
    {
      "id": "cnd13:17.6",
      "pali": "saddhādhanaṁ sīladhanaṁ hiridhanaṁ ottappadhanaṁ sutadhanaṁ cāgadhanaṁ paññādhanaṁ satipaṭṭhānadhanaṁ sammappadhānadhanaṁ iddhipādadhanaṁ indriyadhanaṁ baladhanaṁ bojjhaṅgadhanaṁ maggadhanaṁ phaladhanaṁ nibbānadhananti."
    },
    {
      "id": "cnd13:17.7",
      "pali": "Tehi anekavidhehi dhanaratanehi aḍḍho mahaddhano dhanavātipi sakko."
    },
    {
      "id": "cnd13:17.8",
      "pali": "Atha vā sakko pahu visavī alamatto sūro vīro vikkanto abhīrū acchambhī anutrāsī apalāyī pahīnabhayabheravo vigatalomahaṁsotipi sakko."
    },
    {
      "id": "cnd13:17.9",
      "pali": "<b>Muniṁ ahaṁ sakka yathā vijaññan</b>ti sakka yathāhaṁ muniṁ jāneyyaṁ ājāneyyaṁ vijāneyyaṁ paṭivijāneyyaṁ paṭivijjheyyanti—"
    },
    {
      "id": "cnd13:17.10",
      "pali": "muniṁ ahaṁ sakka yathā vijaññaṁ."
    },
    {
      "id": "cnd13:18.1",
      "pali": "<b>Taṁ me viyācikkha samantacakkhū</b>ti."
    },
    {
      "id": "cnd13:18.2",
      "pali": "<b>Tan</b>ti yaṁ pucchāmi yaṁ yācāmi yaṁ ajjhesāmi yaṁ pasādemi."
    },
    {
      "id": "cnd13:18.3",
      "pali": "<b>Viyācikkhā</b>ti ācikkhāhi desehi paññapehi paṭṭhapehi vivarāhi vibhajāhi uttānīkarohi pakāsehi."
    },
    {
      "id": "cnd13:18.4",
      "pali": "<b>Samantacakkhū</b>ti samantacakkhu vuccati sabbaññutañāṇaṁ …pe…"
    },
    {
      "id": "cnd13:18.5",
      "pali": "tathāgato tena samantacakkhūti—"
    },
    {
      "id": "cnd13:18.6",
      "pali": "taṁ me viyācikkha samantacakkhu."
    },
    {
      "id": "cnd13:18.7",
      "pali": "Tenāha so brāhmaṇo—"
    },
    {
      "id": "cnd13:19.1",
      "pali": "“Nirāsaso so uda āsasāno,"
    },
    {
      "id": "cnd13:19.2",
      "pali": "Paññāṇavā so uda paññakappī;"
    },
    {
      "id": "cnd13:19.3",
      "pali": "Muniṁ ahaṁ sakka yathā vijaññaṁ,"
    },
    {
      "id": "cnd13:19.4",
      "pali": "Taṁ me viyācikkha samantacakkhū”ti."
    },
    {
      "id": "cnd13:20.1",
      "pali": "<b>Nirāsaso so na ca āsasāno,</b>"
    },
    {
      "id": "cnd13:20.2",
      "pali": "<b>Paññāṇavā so na ca paññakappī;</b>"
    },
    {
      "id": "cnd13:20.3",
      "pali": "<b>Evampi todeyya muniṁ vijāna,</b>"
    },
    {
      "id": "cnd13:20.4",
      "pali": "<b>Akiñcanaṁ kāmabhave asattaṁ. </b>"
    },
    {
      "id": "cnd13:21.1",
      "pali": "<b>Nirāsaso so na ca āsasāno</b>ti nittaṇho so."
    },
    {
      "id": "cnd13:21.2",
      "pali": "Na so sataṇho rūpe nāsīsati."
    },
    {
      "id": "cnd13:21.3",
      "pali": "Sadde …pe…"
    },
    {
      "id": "cnd13:21.4",
      "pali": "gandhe …"
    },
    {
      "id": "cnd13:21.5",
      "pali": "diṭṭhasutamutaviññātabbe dhamme nāsīsati na icchati na sādiyati na pattheti na piheti nābhijappatīti—"
    },
    {
      "id": "cnd13:21.6",
      "pali": "nirāsaso so na ca āsasāno."
    },
    {
      "id": "cnd13:22.1",
      "pali": "<b>Paññāṇavā so na ca paññakappī</b>ti."
    },
    {
      "id": "cnd13:22.2",
      "pali": "<b>Paññāṇavā</b>ti paṇḍito paññavā buddhimā ñāṇī vibhāvī medhāvī."
    },
    {
      "id": "cnd13:22.3",
      "pali": "<b>Na ca paññakappī</b>ti aṭṭhasamāpattiñāṇena vā pañcābhiññāñāṇena vā micchāñāṇena vā taṇhākappaṁ vā na kappeti diṭṭhikappaṁ vā na kappeti na janeti na sañjaneti na nibbatteti nābhinibbattetīti—"
    },
    {
      "id": "cnd13:22.4",
      "pali": "paññāṇavā so na ca paññakappī."
    },
    {
      "id": "cnd13:23.1",
      "pali": "<b>Evampi todeyya muniṁ vijānā</b>ti."
    },
    {
      "id": "cnd13:23.2",
      "pali": "<b>Munī</b>ti monaṁ vuccati ñāṇaṁ …pe… saṅgajālamaticca so muni."
    },
    {
      "id": "cnd13:23.3",
      "pali": "<b>Evampi todeyya muniṁ vijānā</b>ti todeyya, evaṁ muniṁ jāna paṭijāna paṭivijāna paṭivijjhāti—"
    },
    {
      "id": "cnd13:23.4",
      "pali": "evampi todeyya muniṁ vijāna."
    },
    {
      "id": "cnd13:24.1",
      "pali": "<b>Akiñcanaṁ kāmabhave asattan</b>ti."
    },
    {
      "id": "cnd13:24.2",
      "pali": "<b>Akiñcanan</b>ti rāgakiñcanaṁ dosakiñcanaṁ mohakiñcanaṁ mānakiñcanaṁ diṭṭhikiñcanaṁ kilesakiñcanaṁ duccaritakiñcanaṁ."
    },
    {
      "id": "cnd13:24.3",
      "pali": "Yassetāni kiñcanāni pahīnāni samucchinnāni vūpasantāni paṭippassaddhāni abhabbuppattikāni ñāṇagginā daḍḍhāni, so vuccati akiñcano."
    },
    {
      "id": "cnd13:24.4",
      "pali": "<b>Kāmā</b>ti uddānato dve kāmā—"
    },
    {
      "id": "cnd13:24.5",
      "pali": "vatthukāmā ca kilesakāmā ca …pe…"
    },
    {
      "id": "cnd13:24.6",
      "pali": "ime vuccanti vatthukāmā …pe…"
    },
    {
      "id": "cnd13:24.7",
      "pali": "ime vuccanti kilesakāmā."
    },
    {
      "id": "cnd13:24.8",
      "pali": "<b>Bhavā</b>ti dve bhavā—"
    },
    {
      "id": "cnd13:24.9",
      "pali": "kammabhavo ca paṭisandhiko ca punabbhavo …pe…"
    },
    {
      "id": "cnd13:24.10",
      "pali": "ayaṁ paṭisandhiko punabbhavo."
    },
    {
      "id": "cnd13:25.1",
      "pali": "<b>Akiñcanaṁ kāmabhave asattan</b>ti akiñcanaṁ puggalaṁ kāme ca bhave ca asattaṁ alaggaṁ alaggitaṁ apalibuddhaṁ nikkhantaṁ nissaṭaṁ vippamuttaṁ visaññuttaṁ vimariyādikatena cetasā viharantanti—"
    },
    {
      "id": "cnd13:25.2",
      "pali": "akiñcanaṁ kāmabhave asattaṁ."
    },
    {
      "id": "cnd13:25.3",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "cnd13:26.1",
      "pali": "“Nirāsaso so na ca āsasāno,"
    },
    {
      "id": "cnd13:26.2",
      "pali": "Paññāṇavā so na ca paññakappī;"
    },
    {
      "id": "cnd13:26.3",
      "pali": "Evampi todeyya muniṁ vijāna,"
    },
    {
      "id": "cnd13:26.4",
      "pali": "Akiñcanaṁ kāmabhave asattan”ti."
    },
    {
      "id": "cnd13:27.1",
      "pali": "Saha gāthāpariyosānā …pe…"
    },
    {
      "id": "cnd13:27.2",
      "pali": "satthā me bhante bhagavā, sāvakohamasmīti."
    },
    {
      "id": "cnd13:27.3",
      "pali": "Todeyyamāṇavapucchāniddeso navamo."
    }
  ]
}
