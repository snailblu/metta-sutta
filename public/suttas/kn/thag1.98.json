{
  "uid": "thag1.98",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.98:1.1",
      "pali": "“Rūpaṁ disvā sati muṭṭhā,"
    },
    {
      "id": "thag1.98:1.2",
      "pali": "Piyaṁ nimittaṁ manasikaroto;"
    },
    {
      "id": "thag1.98:1.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag1.98:1.4",
      "pali": "Tañca ajjhosa tiṭṭhati;"
    },
    {
      "id": "thag1.98:1.5",
      "pali": "Tassa vaḍḍhanti āsavā,"
    },
    {
      "id": "thag1.98:1.6",
      "pali": "Bhavamūlopagāmino”ti."
    },
    {
      "id": "thag1.98:1.7",
      "pali": "… Abhayo thero …."
    }
  ]
}
