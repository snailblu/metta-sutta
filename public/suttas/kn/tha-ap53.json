{
  "uid": "tha-ap53",
  "title": "Vidhūpanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap53:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap53:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap53:1.3",
      "pali": "Bījanikā mayā dinnā,"
    },
    {
      "id": "tha-ap53:1.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap53:2.1",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap53:2.2",
      "pali": "paggahetvāna añjaliṁ;"
    },
    {
      "id": "tha-ap53:2.3",
      "pali": "Sambuddhamabhivādetvā,"
    },
    {
      "id": "tha-ap53:2.4",
      "pali": "pakkamiṁ uttarāmukho."
    },
    {
      "id": "tha-ap53:3.1",
      "pali": "Bījaniṁ paggahetvāna,"
    },
    {
      "id": "tha-ap53:3.2",
      "pali": "satthā lokagganāyako;"
    },
    {
      "id": "tha-ap53:3.3",
      "pali": "Bhikkhusaṅghe ṭhito santo,"
    },
    {
      "id": "tha-ap53:3.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap53:4.1",
      "pali": "‘Iminā bījanidānena,"
    },
    {
      "id": "tha-ap53:4.2",
      "pali": "cittassa paṇidhīhi ca;"
    },
    {
      "id": "tha-ap53:4.3",
      "pali": "Kappānaṁ satasahassaṁ,"
    },
    {
      "id": "tha-ap53:4.4",
      "pali": "vinipātaṁ na gacchati’."
    },
    {
      "id": "tha-ap53:5.1",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "tha-ap53:5.2",
      "pali": "Cetoguṇasamāhito;"
    },
    {
      "id": "tha-ap53:5.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap53:5.4",
      "pali": "Arahattaṁ apāpuṇiṁ."
    },
    {
      "id": "tha-ap53:6.1",
      "pali": "Saṭṭhikappasahassamhi,"
    },
    {
      "id": "tha-ap53:6.2",
      "pali": "bījamānasanāmakā;"
    },
    {
      "id": "tha-ap53:6.3",
      "pali": "Soḷasāsiṁsu rājāno,"
    },
    {
      "id": "tha-ap53:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap53:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap53:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap53:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap53:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap53:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā vidhūpanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap53:9.1",
      "pali": "Vidhūpanadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
