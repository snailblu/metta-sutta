{
  "uid": "ja262",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja262:1.1",
      "pali": "“Pāṇi ce muduko cassa,"
    },
    {
      "id": "ja262:1.2",
      "pali": "nāgo cassa sukārito;"
    },
    {
      "id": "ja262:1.3",
      "pali": "Andhakāro ca vasseyya,"
    },
    {
      "id": "ja262:1.4",
      "pali": "atha nūna tadā siyā”."
    },
    {
      "id": "ja262:2.1",
      "pali": "“Analā mudusambhāsā,"
    },
    {
      "id": "ja262:2.2",
      "pali": "duppūrā tā nadīsamā;"
    },
    {
      "id": "ja262:2.3",
      "pali": "Sīdanti naṁ viditvāna,"
    },
    {
      "id": "ja262:2.4",
      "pali": "ārakā parivajjaye."
    },
    {
      "id": "ja262:3.1",
      "pali": "Yaṁ etā upasevanti,"
    },
    {
      "id": "ja262:3.2",
      "pali": "chandasā vā dhanena vā;"
    },
    {
      "id": "ja262:3.3",
      "pali": "Jātavedova saṁ ṭhānaṁ,"
    },
    {
      "id": "ja262:3.4",
      "pali": "khippaṁ anudahanti nan”ti."
    },
    {
      "id": "ja262:4.1",
      "pali": "Mudupāṇijātakaṁ dutiyaṁ."
    }
  ]
}
