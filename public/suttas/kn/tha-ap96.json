{
  "uid": "tha-ap96",
  "title": "Sūcidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap96:1.1",
      "pali": "“Kammārohaṁ pure āsiṁ,"
    },
    {
      "id": "tha-ap96:1.2",
      "pali": "bandhumāyaṁ puruttame;"
    },
    {
      "id": "tha-ap96:1.3",
      "pali": "Sūcidānaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap96:1.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap96:2.1",
      "pali": "Vajiraggasamaṁ ñāṇaṁ,"
    },
    {
      "id": "tha-ap96:2.2",
      "pali": "hoti kammena tādisaṁ;"
    },
    {
      "id": "tha-ap96:2.3",
      "pali": "Virāgomhi vimuttomhi,"
    },
    {
      "id": "tha-ap96:2.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap96:3.1",
      "pali": "Atīte ca bhave sabbe,"
    },
    {
      "id": "tha-ap96:3.2",
      "pali": "vattamāne canāgate;"
    },
    {
      "id": "tha-ap96:3.3",
      "pali": "Ñāṇena viciniṁ sabbaṁ,"
    },
    {
      "id": "tha-ap96:3.4",
      "pali": "sūcidānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap96:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap96:4.2",
      "pali": "sattāsuṁ vajiravhayā;"
    },
    {
      "id": "tha-ap96:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap96:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap96:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap96:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap96:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap96:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sūcidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap96:7.1",
      "pali": "Sūcidāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
