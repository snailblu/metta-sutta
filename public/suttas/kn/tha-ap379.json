{
  "uid": "tha-ap379",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap379:1.1",
      "pali": "“Parinibbute bhagavati,"
    },
    {
      "id": "tha-ap379:1.2",
      "pali": "jalajuttamanāmake;"
    },
    {
      "id": "tha-ap379:1.3",
      "pali": "Āropitamhi citake,"
    },
    {
      "id": "tha-ap379:1.4",
      "pali": "sālapupphamapūjayiṁ."
    },
    {
      "id": "tha-ap379:2.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap379:2.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap379:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap379:2.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap379:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap379:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap379:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap379:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap379:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap379:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap379:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap379:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap379:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap379:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap379:7.1",
      "pali": "Citakapūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
