{
  "uid": "tha-ap243",
  "title": "1 Tuvaradāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap243:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap243:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap243:1.3",
      "pali": "Bharitvā tuvaramādāya,"
    },
    {
      "id": "tha-ap243:1.4",
      "pali": "saṅghassa adadiṁ ahaṁ."
    },
    {
      "id": "tha-ap243:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap243:2.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap243:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap243:2.4",
      "pali": "tuvarassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap243:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap243:3.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap243:3.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap243:3.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap243:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā tuvaradāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap243:5.1",
      "pali": "Tuvaradāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
