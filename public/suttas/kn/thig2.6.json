{
  "uid": "thig2.6",
  "title": "Mettikātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.6:1.1",
      "pali": "“Kiñcāpi khomhi dukkhitā,"
    },
    {
      "id": "thig2.6:1.2",
      "pali": "dubbalā gatayobbanā;"
    },
    {
      "id": "thig2.6:1.3",
      "pali": "Daṇḍamolubbha gacchāmi,"
    },
    {
      "id": "thig2.6:1.4",
      "pali": "pabbataṁ abhirūhiya."
    },
    {
      "id": "thig2.6:2.1",
      "pali": "Nikkhipitvāna saṅghāṭiṁ,"
    },
    {
      "id": "thig2.6:2.2",
      "pali": "pattakañca nikujjiya;"
    },
    {
      "id": "thig2.6:2.3",
      "pali": "Nisinnā camhi selamhi,"
    },
    {
      "id": "thig2.6:2.4",
      "pali": "atha cittaṁ vimucci me;"
    },
    {
      "id": "thig2.6:2.5",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig2.6:2.6",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thig2.6:3.1",
      "pali": "… Mettikā therī …."
    }
  ]
}
