{
  "uid": "thig1.5",
  "title": "Aññatarātissātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.5:1.1",
      "pali": "“Tisse yuñjassu dhammehi,"
    },
    {
      "id": "thig1.5:1.2",
      "pali": "khaṇo taṁ mā upaccagā;"
    },
    {
      "id": "thig1.5:1.3",
      "pali": "Khaṇātītā hi socanti,"
    },
    {
      "id": "thig1.5:1.4",
      "pali": "nirayamhi samappitā”ti."
    },
    {
      "id": "thig1.5:2.1",
      "pali": "… Aññatarā tissā therī …."
    }
  ]
}
