{
  "uid": "mil7.1",
  "title": "Mātikā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.1:1.1",
      "pali": "“Bhante nāgasena, katihaṅgehi samannāgato bhikkhu arahattaṁ sacchikarotī”ti?"
    },
    {
      "id": "mil7.1:2.1",
      "pali": "“Idha, mahārāja, arahattaṁ sacchikātukāmena bhikkhunā—"
    },
    {
      "id": "mil7.1:3.1",
      "pali": "Gadrabhassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:4.1",
      "pali": "Kukkuṭassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:5.1",
      "pali": "Kalandakassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:6.1",
      "pali": "Dīpiniyā ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:7.1",
      "pali": "Dīpikassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:8.1",
      "pali": "Kummassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:9.1",
      "pali": "Vaṁsassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:10.1",
      "pali": "Cāpassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:11.1",
      "pali": "Vāyasassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:12.1",
      "pali": "Makkaṭassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:13.1",
      "pali": "Gadrabhavaggo paṭhamo."
    },
    {
      "id": "mil7.1:14.1",
      "pali": "Lābulatāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:15.1",
      "pali": "Padumassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:16.1",
      "pali": "Bījassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:17.1",
      "pali": "Sālakalyāṇikāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:18.1",
      "pali": "Nāvāya tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:19.1",
      "pali": "Nāvālagganakassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:20.1",
      "pali": "Kūpassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:21.1",
      "pali": "Niyāmakassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:22.1",
      "pali": "Kammakārassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:23.1",
      "pali": "Samuddassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:24.1",
      "pali": "Samuddavaggo dutiyo."
    },
    {
      "id": "mil7.1:25.1",
      "pali": "Pathaviyā pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:26.1",
      "pali": "Āpassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:27.1",
      "pali": "Tejassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:28.1",
      "pali": "Vāyussa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:29.1",
      "pali": "Pabbatassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:30.1",
      "pali": "Ākāsassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:31.1",
      "pali": "Candassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:32.1",
      "pali": "Sūriyassa satta aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:33.1",
      "pali": "Sakkassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:34.1",
      "pali": "Cakkavattissa cattāri aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:35.1",
      "pali": "Pathavīvaggo tatiyo."
    },
    {
      "id": "mil7.1:36.1",
      "pali": "Upacikāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:37.1",
      "pali": "Biḷārassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:38.1",
      "pali": "Undūrassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:39.1",
      "pali": "Vicchikassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:40.1",
      "pali": "Nakulassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:41.1",
      "pali": "Jarasiṅgālassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:42.1",
      "pali": "Migassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:43.1",
      "pali": "Gorūpassa cattāri aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:44.1",
      "pali": "Varāhassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:45.1",
      "pali": "Hatthissa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:46.1",
      "pali": "Upacikāvaggo catuttho."
    },
    {
      "id": "mil7.1:47.1",
      "pali": "Sīhassa satta aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:48.1",
      "pali": "Cakkavākassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:49.1",
      "pali": "Peṇāhikāya dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:50.1",
      "pali": "Gharakapotassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:51.1",
      "pali": "Ulūkassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:52.1",
      "pali": "Satapattassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:53.1",
      "pali": "Vaggulissa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:54.1",
      "pali": "Jalūkāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:55.1",
      "pali": "Sappassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:56.1",
      "pali": "Ajagarassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:57.1",
      "pali": "Sīhavaggo pañcamo."
    },
    {
      "id": "mil7.1:58.1",
      "pali": "Panthamakkaṭakassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:59.1",
      "pali": "Thanasitadārakassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:60.1",
      "pali": "Cittakadharakummassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:61.1",
      "pali": "Pavanassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:62.1",
      "pali": "Rukkhassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:63.1",
      "pali": "Meghassa pañca aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:64.1",
      "pali": "Maṇiratanassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:65.1",
      "pali": "Māgavikassa cattāri aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:66.1",
      "pali": "Bāḷisikassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:67.1",
      "pali": "Tacchakassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:68.1",
      "pali": "Makkaṭavaggo chaṭṭho."
    },
    {
      "id": "mil7.1:69.1",
      "pali": "Kumbhassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:70.1",
      "pali": "Kāḷāyasassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:71.1",
      "pali": "Chattassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:72.1",
      "pali": "Khettassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:73.1",
      "pali": "Agadassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:74.1",
      "pali": "Bhojanassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:75.1",
      "pali": "Issāsassa cattāri aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:76.1",
      "pali": "Kumbhavaggo sattamo."
    },
    {
      "id": "mil7.1:77.1",
      "pali": "Rañño cattāri aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:78.1",
      "pali": "Dovārikassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:79.1",
      "pali": "Nisadāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:80.1",
      "pali": "Padīpassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:81.1",
      "pali": "Mayūrassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:82.1",
      "pali": "Turaṅgassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:83.1",
      "pali": "Soṇḍikassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:84.1",
      "pali": "Indakhīlassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:85.1",
      "pali": "Tulāya ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:86.1",
      "pali": "Khaggassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:87.1",
      "pali": "Macchassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:88.1",
      "pali": "Iṇaggāhakassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:89.1",
      "pali": "Byādhitassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:90.1",
      "pali": "Matassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:91.1",
      "pali": "Nadiyā dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:92.1",
      "pali": "Usabhassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:93.1",
      "pali": "Maggassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:94.1",
      "pali": "Suṅkasāyikassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:95.1",
      "pali": "Corassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:96.1",
      "pali": "Sakuṇagghiyā ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:97.1",
      "pali": "Sunakhassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:98.1",
      "pali": "Tikicchakassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:99.1",
      "pali": "Gabbhiniyā dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:100.1",
      "pali": "Camariyā ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:101.1",
      "pali": "Kikiyā dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:102.1",
      "pali": "Kapotikāya tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:103.1",
      "pali": "Ekanayanassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:104.1",
      "pali": "Kassakassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:105.1",
      "pali": "Jambukasiṅgāliyā ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:106.1",
      "pali": "Caṅgavārakassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:107.1",
      "pali": "Dabbiyā ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:108.1",
      "pali": "Iṇasādhakassa tīṇi aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:109.1",
      "pali": "Anuvicinakassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:110.1",
      "pali": "Sārathissa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:111.1",
      "pali": "Bhojakassa dve aṅgāni gahetabbāni."
    },
    {
      "id": "mil7.1:112.1",
      "pali": "Tunnavāyassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:113.1",
      "pali": "Nāvikassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.1:114.1",
      "pali": "Bhamarassa dve aṅgāni gahetabbānī”ti."
    },
    {
      "id": "mil7.1:115.1",
      "pali": "Mātikā niṭṭhitā."
    }
  ]
}
