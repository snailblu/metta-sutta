{
  "uid": "tha-ap493",
  "title": "Tikiṅkaṇipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap493:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap493:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap493:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap493:1.4",
      "pali": "vipassiṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap493:2.1",
      "pali": "Tīṇi kiṅkaṇipupphāni,"
    },
    {
      "id": "tha-ap493:2.2",
      "pali": "paggayha abhiropayiṁ;"
    },
    {
      "id": "tha-ap493:2.3",
      "pali": "Sambuddhamabhipūjetvā,"
    },
    {
      "id": "tha-ap493:2.4",
      "pali": "gacchāmi dakkhiṇāmukho."
    },
    {
      "id": "tha-ap493:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap493:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap493:3.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap493:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap493:4.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap493:4.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap493:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap493:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap493:5.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap493:5.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap493:5.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap493:5.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap493:6.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap493:6.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap493:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap493:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap493:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap493:7.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap493:7.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap493:7.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap493:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā tikiṅkaṇipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap493:9.1",
      "pali": "Tikiṅkaṇipupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
