{
  "uid": "ja335",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja335:1.1",
      "pali": "“Brahā pavaḍḍhakāyo so,"
    },
    {
      "id": "ja335:1.2",
      "pali": "dīghadāṭho ca jambuka;"
    },
    {
      "id": "ja335:1.3",
      "pali": "Na tvaṁ tattha kule jāto,"
    },
    {
      "id": "ja335:1.4",
      "pali": "yattha gaṇhanti kuñjaraṁ”."
    },
    {
      "id": "ja335:2.1",
      "pali": "“Asīho sīhamānena,"
    },
    {
      "id": "ja335:2.2",
      "pali": "yo attānaṁ vikubbati;"
    },
    {
      "id": "ja335:2.3",
      "pali": "Kotthūva gajamāsajja,"
    },
    {
      "id": "ja335:2.4",
      "pali": "seti bhūmyā anutthunaṁ."
    },
    {
      "id": "ja335:3.1",
      "pali": "Yasassino uttamapuggalassa,"
    },
    {
      "id": "ja335:3.2",
      "pali": "Sañjātakhandhassa mahabbalassa;"
    },
    {
      "id": "ja335:3.3",
      "pali": "Asamekkhiya thāmabalūpapattiṁ,"
    },
    {
      "id": "ja335:3.4",
      "pali": "Sa seti nāgena hatoyaṁ jambuko."
    },
    {
      "id": "ja335:4.1",
      "pali": "Yo cīdha kammaṁ kurute pamāya,"
    },
    {
      "id": "ja335:4.2",
      "pali": "Thāmabbalaṁ attani saṁviditvā;"
    },
    {
      "id": "ja335:4.3",
      "pali": "Jappena mantena subhāsitena,"
    },
    {
      "id": "ja335:4.4",
      "pali": "Parikkhavā so vipulaṁ jinātī”ti."
    },
    {
      "id": "ja335:5.1",
      "pali": "Jambukajātakaṁ pañcamaṁ."
    }
  ]
}
