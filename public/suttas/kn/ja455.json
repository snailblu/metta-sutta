{
  "uid": "ja455",
  "title": "Mātuposakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja455:1.1",
      "pali": "“Tassa nāgassa vippavāsena,"
    },
    {
      "id": "ja455:1.2",
      "pali": "Virūḷhā sallakī ca kuṭajā ca;"
    },
    {
      "id": "ja455:1.3",
      "pali": "Kuruvindakaravīrā bhisasāmā ca,"
    },
    {
      "id": "ja455:1.4",
      "pali": "Nivāte pupphitā ca kaṇikārā."
    },
    {
      "id": "ja455:2.1",
      "pali": "Kocideva suvaṇṇakāyurā,"
    },
    {
      "id": "ja455:2.2",
      "pali": "Nāgarājaṁ bharanti piṇḍena;"
    },
    {
      "id": "ja455:2.3",
      "pali": "Yattha rājā rājakumāro vā,"
    },
    {
      "id": "ja455:2.4",
      "pali": "Kavacamabhihessati achambhito”."
    },
    {
      "id": "ja455:3.1",
      "pali": "“Gaṇhāhi nāga kabaḷaṁ,"
    },
    {
      "id": "ja455:3.2",
      "pali": "mā nāga kisako bhava;"
    },
    {
      "id": "ja455:3.3",
      "pali": "Bahūni rājakiccāni,"
    },
    {
      "id": "ja455:3.4",
      "pali": "tāni nāga karissasi”."
    },
    {
      "id": "ja455:4.1",
      "pali": "“Sā nūnasā kapaṇikā,"
    },
    {
      "id": "ja455:4.2",
      "pali": "andhā apariṇāyikā;"
    },
    {
      "id": "ja455:4.3",
      "pali": "Khāṇuṁ pādena ghaṭṭeti,"
    },
    {
      "id": "ja455:4.4",
      "pali": "giriṁ caṇḍoraṇaṁ pati”."
    },
    {
      "id": "ja455:5.1",
      "pali": "“Kā nu te sā mahānāga,"
    },
    {
      "id": "ja455:5.2",
      "pali": "andhā apariṇāyikā;"
    },
    {
      "id": "ja455:5.3",
      "pali": "Khāṇuṁ pādena ghaṭṭeti,"
    },
    {
      "id": "ja455:5.4",
      "pali": "giriṁ caṇḍoraṇaṁ pati”."
    },
    {
      "id": "ja455:6.1",
      "pali": "“Mātā me sā mahārāja,"
    },
    {
      "id": "ja455:6.2",
      "pali": "andhā apariṇāyikā;"
    },
    {
      "id": "ja455:6.3",
      "pali": "Khāṇuṁ pādena ghaṭṭeti,"
    },
    {
      "id": "ja455:6.4",
      "pali": "giriṁ caṇḍoraṇaṁ pati”."
    },
    {
      "id": "ja455:7.1",
      "pali": "“Muñcathetaṁ mahānāgaṁ,"
    },
    {
      "id": "ja455:7.2",
      "pali": "yoyaṁ bharati mātaraṁ;"
    },
    {
      "id": "ja455:7.3",
      "pali": "Sametu mātarā nāgo,"
    },
    {
      "id": "ja455:7.4",
      "pali": "saha sabbehi ñātibhi”."
    },
    {
      "id": "ja455:8.1",
      "pali": "“Mutto ca bandhanā nāgo,"
    },
    {
      "id": "ja455:8.2",
      "pali": "muttamādāya kuñjaro;"
    },
    {
      "id": "ja455:8.3",
      "pali": "Muhuttaṁ assāsayitvā,"
    },
    {
      "id": "ja455:8.4",
      "pali": "agamā yena pabbato."
    },
    {
      "id": "ja455:9.1",
      "pali": "Tato so naḷiniṁ gantvā,"
    },
    {
      "id": "ja455:9.2",
      "pali": "sītaṁ kuñjarasevitaṁ;"
    },
    {
      "id": "ja455:9.3",
      "pali": "Soṇḍāyūdakamāhatvā,"
    },
    {
      "id": "ja455:9.4",
      "pali": "mātaraṁ abhisiñcatha”."
    },
    {
      "id": "ja455:10.1",
      "pali": "“Koyaṁ anariyo devo,"
    },
    {
      "id": "ja455:10.2",
      "pali": "akālenapi vassati;"
    },
    {
      "id": "ja455:10.3",
      "pali": "Gato me atrajo putto,"
    },
    {
      "id": "ja455:10.4",
      "pali": "yo mayhaṁ paricārako”."
    },
    {
      "id": "ja455:11.1",
      "pali": "“Uṭṭhehi amma kiṁ sesi,"
    },
    {
      "id": "ja455:11.2",
      "pali": "āgato tyāhamatrajo;"
    },
    {
      "id": "ja455:11.3",
      "pali": "Muttomhi kāsirājena,"
    },
    {
      "id": "ja455:11.4",
      "pali": "vedehena yasassinā”."
    },
    {
      "id": "ja455:12.1",
      "pali": "“Ciraṁ jīvatu so rājā,"
    },
    {
      "id": "ja455:12.2",
      "pali": "kāsīnaṁ raṭṭhavaḍḍhano;"
    },
    {
      "id": "ja455:12.3",
      "pali": "Yo me puttaṁ pamocesi,"
    },
    {
      "id": "ja455:12.4",
      "pali": "sadā vuddhāpacāyikan”ti."
    },
    {
      "id": "ja455:13.1",
      "pali": "Mātuposakajātakaṁ paṭhamaṁ."
    }
  ]
}
