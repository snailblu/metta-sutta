{
  "uid": "tha-ap340",
  "title": "Uttareyyadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap340:1.1",
      "pali": "“Nagare haṁsavatiyā,"
    },
    {
      "id": "tha-ap340:1.2",
      "pali": "ahosiṁ brāhmaṇo tadā;"
    },
    {
      "id": "tha-ap340:1.3",
      "pali": "Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap340:1.4",
      "pali": "tiṇṇaṁ vedāna pāragū."
    },
    {
      "id": "tha-ap340:2.1",
      "pali": "Purakkhato sasissehi,"
    },
    {
      "id": "tha-ap340:2.2",
      "pali": "jātimā ca susikkhito;"
    },
    {
      "id": "tha-ap340:2.3",
      "pali": "Toyābhisecanatthāya,"
    },
    {
      "id": "tha-ap340:2.4",
      "pali": "nagarā nikkhamiṁ tadā."
    },
    {
      "id": "tha-ap340:3.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap340:3.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap340:3.3",
      "pali": "Khīṇāsavasahassehi,"
    },
    {
      "id": "tha-ap340:3.4",
      "pali": "pāvisī nagaraṁ jino."
    },
    {
      "id": "tha-ap340:4.1",
      "pali": "Sucārurūpaṁ disvāna,"
    },
    {
      "id": "tha-ap340:4.2",
      "pali": "āneñjakāritaṁ viya;"
    },
    {
      "id": "tha-ap340:4.3",
      "pali": "Parivutaṁ arahantehi,"
    },
    {
      "id": "tha-ap340:4.4",
      "pali": "disvā cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap340:5.1",
      "pali": "Sirasmiṁ añjaliṁ katvā,"
    },
    {
      "id": "tha-ap340:5.2",
      "pali": "namassitvāna subbataṁ;"
    },
    {
      "id": "tha-ap340:5.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap340:5.4",
      "pali": "uttarīyamadāsahaṁ."
    },
    {
      "id": "tha-ap340:6.1",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap340:6.2",
      "pali": "sāṭakaṁ ukkhipiṁ ahaṁ;"
    },
    {
      "id": "tha-ap340:6.3",
      "pali": "Yāvatā buddhaparisā,"
    },
    {
      "id": "tha-ap340:6.4",
      "pali": "tāva chādesi sāṭako."
    },
    {
      "id": "tha-ap340:7.1",
      "pali": "Piṇḍacāraṁ carantassa,"
    },
    {
      "id": "tha-ap340:7.2",
      "pali": "mahābhikkhugaṇādino;"
    },
    {
      "id": "tha-ap340:7.3",
      "pali": "Chadaṁ karonto aṭṭhāsi,"
    },
    {
      "id": "tha-ap340:7.4",
      "pali": "hāsayanto mamaṁ tadā."
    },
    {
      "id": "tha-ap340:8.1",
      "pali": "Gharato nikkhamantassa,"
    },
    {
      "id": "tha-ap340:8.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap340:8.3",
      "pali": "Vīthiyaṁva ṭhito satthā,"
    },
    {
      "id": "tha-ap340:8.4",
      "pali": "akā me anumodanaṁ."
    },
    {
      "id": "tha-ap340:9.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap340:9.2",
      "pali": "yo me adāsi sāṭakaṁ;"
    },
    {
      "id": "tha-ap340:9.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap340:9.4",
      "pali": "suṇotha mama bhāsato."
    },
    {
      "id": "tha-ap340:10.1",
      "pali": "‘Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap340:10.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap340:10.3",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap340:10.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap340:11.1",
      "pali": "Devaloke vasantassa,"
    },
    {
      "id": "tha-ap340:11.2",
      "pali": "puññakammasamaṅgino;"
    },
    {
      "id": "tha-ap340:11.3",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap340:11.4",
      "pali": "dussacchannaṁ bhavissati."
    },
    {
      "id": "tha-ap340:12.1",
      "pali": "Chattiṁsakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap340:12.2",
      "pali": "cakkavattī bhavissati;"
    },
    {
      "id": "tha-ap340:12.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap340:12.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap340:13.1",
      "pali": "Bhave saṁsaramānassa,"
    },
    {
      "id": "tha-ap340:13.2",
      "pali": "puññakammasamaṅgino;"
    },
    {
      "id": "tha-ap340:13.3",
      "pali": "Manasā patthitaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap340:13.4",
      "pali": "nibbattissati tāvade."
    },
    {
      "id": "tha-ap340:14.1",
      "pali": "Koseyyakambaliyāni,"
    },
    {
      "id": "tha-ap340:14.2",
      "pali": "khomakappāsikāni ca;"
    },
    {
      "id": "tha-ap340:14.3",
      "pali": "Mahagghāni ca dussāni,"
    },
    {
      "id": "tha-ap340:14.4",
      "pali": "paṭilacchatiyaṁ naro."
    },
    {
      "id": "tha-ap340:15.1",
      "pali": "Manasā patthitaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap340:15.2",
      "pali": "paṭilacchatiyaṁ naro;"
    },
    {
      "id": "tha-ap340:15.3",
      "pali": "Ekadussassa vipākaṁ,"
    },
    {
      "id": "tha-ap340:15.4",
      "pali": "anubhossati sabbadā."
    },
    {
      "id": "tha-ap340:16.1",
      "pali": "So pacchā pabbajitvāna,"
    },
    {
      "id": "tha-ap340:16.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap340:16.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap340:16.4",
      "pali": "dhammaṁ sacchikarissati’."
    },
    {
      "id": "tha-ap340:17.1",
      "pali": "Aho me sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap340:17.2",
      "pali": "sabbaññussa mahesino;"
    },
    {
      "id": "tha-ap340:17.3",
      "pali": "Ekāhaṁ sāṭakaṁ datvā,"
    },
    {
      "id": "tha-ap340:17.4",
      "pali": "pattomhi amataṁ padaṁ."
    },
    {
      "id": "tha-ap340:18.1",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "tha-ap340:18.2",
      "pali": "vasato suññake ghare;"
    },
    {
      "id": "tha-ap340:18.3",
      "pali": "Dhāreti dussachadanaṁ,"
    },
    {
      "id": "tha-ap340:18.4",
      "pali": "samantā byāmato mama."
    },
    {
      "id": "tha-ap340:19.1",
      "pali": "Aviññattaṁ nivāsemi,"
    },
    {
      "id": "tha-ap340:19.2",
      "pali": "cīvaraṁ paccayañcahaṁ;"
    },
    {
      "id": "tha-ap340:19.3",
      "pali": "Lābhī annassa pānassa,"
    },
    {
      "id": "tha-ap340:19.4",
      "pali": "uttareyyassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap340:20.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap340:20.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap340:20.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap340:20.4",
      "pali": "vatthadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap340:21.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap340:21.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap340:21.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap340:22.1",
      "pali": "Itthaṁ sudaṁ āyasmā uttareyyadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap340:23.1",
      "pali": "Uttareyyadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
