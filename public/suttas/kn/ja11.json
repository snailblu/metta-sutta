{
  "uid": "ja11",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja11:1.1",
      "pali": "“Hoti sīlavataṁ attho,"
    },
    {
      "id": "ja11:1.2",
      "pali": "paṭisanthāravuttinaṁ;"
    },
    {
      "id": "ja11:1.3",
      "pali": "Lakkhaṇaṁ passa āyantaṁ,"
    },
    {
      "id": "ja11:1.4",
      "pali": "ñātisaṅghapurakkhataṁ;"
    },
    {
      "id": "ja11:1.5",
      "pali": "Atha passasimaṁ kāḷaṁ,"
    },
    {
      "id": "ja11:1.6",
      "pali": "suvihīnaṁva ñātibhī”ti."
    },
    {
      "id": "ja11:2.1",
      "pali": "Lakkhaṇamigajātakaṁ paṭhamaṁ."
    }
  ]
}
