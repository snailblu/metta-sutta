{
  "uid": "tha-ap353",
  "title": "Saddasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap353:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap353:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap353:1.3",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap353:1.4",
      "pali": "devasaṅghapurakkhataṁ."
    },
    {
      "id": "tha-ap353:2.1",
      "pali": "Catusaccaṁ pakāsentaṁ,"
    },
    {
      "id": "tha-ap353:2.2",
      "pali": "uddharantaṁ mahājanaṁ;"
    },
    {
      "id": "tha-ap353:2.3",
      "pali": "Assosiṁ madhuraṁ vācaṁ,"
    },
    {
      "id": "tha-ap353:2.4",
      "pali": "karavīkarudopamaṁ."
    },
    {
      "id": "tha-ap353:3.1",
      "pali": "Brahmasarassa munino,"
    },
    {
      "id": "tha-ap353:3.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap353:3.3",
      "pali": "Ghose cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap353:3.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap353:4.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap353:4.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap353:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap353:4.4",
      "pali": "pasādassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap353:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap353:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap353:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap353:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap353:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā saddasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap353:7.1",
      "pali": "Saddasaññakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
