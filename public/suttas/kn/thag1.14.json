{
  "uid": "thag1.14",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.14:1.1",
      "pali": "“Upajjhāyo maṁ avaca,"
    },
    {
      "id": "thag1.14:1.2",
      "pali": "ito gacchāma sīvaka;"
    },
    {
      "id": "thag1.14:1.3",
      "pali": "Gāme me vasati kāyo,"
    },
    {
      "id": "thag1.14:1.4",
      "pali": "araññaṁ me gato mano;"
    },
    {
      "id": "thag1.14:1.5",
      "pali": "Semānakopi gacchāmi,"
    },
    {
      "id": "thag1.14:1.6",
      "pali": "natthi saṅgo vijānatan”ti."
    },
    {
      "id": "thag1.14:1.7",
      "pali": "… Vanavacchassa therassa (siviko) sāmaṇero …."
    }
  ]
}
