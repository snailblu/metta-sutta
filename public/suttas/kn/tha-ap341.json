{
  "uid": "tha-ap341",
  "title": "9 Dhammasavaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap341:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap341:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "tha-ap341:1.3",
      "pali": "Catusaccaṁ pakāsento,"
    },
    {
      "id": "tha-ap341:1.4",
      "pali": "santāresi bahuṁ janaṁ."
    },
    {
      "id": "tha-ap341:2.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "tha-ap341:2.2",
      "pali": "jaṭilo uggatāpano;"
    },
    {
      "id": "tha-ap341:2.3",
      "pali": "Dhunanto vākacīrāni,"
    },
    {
      "id": "tha-ap341:2.4",
      "pali": "gacchāmi ambare tadā."
    },
    {
      "id": "tha-ap341:3.1",
      "pali": "Buddhaseṭṭhassa upari,"
    },
    {
      "id": "tha-ap341:3.2",
      "pali": "gantuṁ na visahāmahaṁ;"
    },
    {
      "id": "tha-ap341:3.3",
      "pali": "Pakkhīva selamāsajja,"
    },
    {
      "id": "tha-ap341:3.4",
      "pali": "gamanaṁ na labhāmahaṁ."
    },
    {
      "id": "tha-ap341:4.1",
      "pali": "Na me idaṁ bhūtapubbaṁ,"
    },
    {
      "id": "tha-ap341:4.2",
      "pali": "iriyassa vikopanaṁ;"
    },
    {
      "id": "tha-ap341:4.3",
      "pali": "Dake yathā ummujjitvā,"
    },
    {
      "id": "tha-ap341:4.4",
      "pali": "evaṁ gacchāmi ambare."
    },
    {
      "id": "tha-ap341:5.1",
      "pali": "Uḷārabhūto manujo,"
    },
    {
      "id": "tha-ap341:5.2",
      "pali": "heṭṭhāsīno bhavissati;"
    },
    {
      "id": "tha-ap341:5.3",
      "pali": "Handa menaṁ gavesissaṁ,"
    },
    {
      "id": "tha-ap341:5.4",
      "pali": "api atthaṁ labheyyahaṁ."
    },
    {
      "id": "tha-ap341:6.1",
      "pali": "Orohanto antalikkhā,"
    },
    {
      "id": "tha-ap341:6.2",
      "pali": "saddamassosi satthuno;"
    },
    {
      "id": "tha-ap341:6.3",
      "pali": "Aniccataṁ kathentassa,"
    },
    {
      "id": "tha-ap341:6.4",
      "pali": "tamahaṁ uggahiṁ tadā."
    },
    {
      "id": "tha-ap341:7.1",
      "pali": "Aniccasaññamuggayha,"
    },
    {
      "id": "tha-ap341:7.2",
      "pali": "agamāsiṁ mamassamaṁ;"
    },
    {
      "id": "tha-ap341:7.3",
      "pali": "Yāvatāyuṁ vasitvāna,"
    },
    {
      "id": "tha-ap341:7.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap341:8.1",
      "pali": "Carime vattamānamhi,"
    },
    {
      "id": "tha-ap341:8.2",
      "pali": "Taṁ dhammasavanaṁ sariṁ;"
    },
    {
      "id": "tha-ap341:8.3",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap341:8.4",
      "pali": "Tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap341:9.1",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap341:9.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap341:9.3",
      "pali": "Ekapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap341:9.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap341:10.1",
      "pali": "Ekasattatikkhattuñca,"
    },
    {
      "id": "tha-ap341:10.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap341:10.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap341:10.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap341:11.1",
      "pali": "Pitugehe nisīditvā,"
    },
    {
      "id": "tha-ap341:11.2",
      "pali": "samaṇo bhāvitindriyo;"
    },
    {
      "id": "tha-ap341:11.3",
      "pali": "Gāthāya paridīpento,"
    },
    {
      "id": "tha-ap341:11.4",
      "pali": "aniccatamudāhari."
    },
    {
      "id": "tha-ap341:12.1",
      "pali": "Anussarāmi taṁ saññaṁ,"
    },
    {
      "id": "tha-ap341:12.2",
      "pali": "saṁsaranto bhavābhave;"
    },
    {
      "id": "tha-ap341:12.3",
      "pali": "Na koṭiṁ paṭivijjhāmi,"
    },
    {
      "id": "tha-ap341:12.4",
      "pali": "nibbānaṁ accutaṁ padaṁ."
    },
    {
      "id": "tha-ap341:13.1",
      "pali": "Aniccā vata saṅkhārā,"
    },
    {
      "id": "tha-ap341:13.2",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "tha-ap341:13.3",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "tha-ap341:13.4",
      "pali": "tesaṁ vūpasamo sukho."
    },
    {
      "id": "tha-ap341:14.1",
      "pali": "Saha gāthaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap341:14.2",
      "pali": "pubbakammaṁ anussariṁ;"
    },
    {
      "id": "tha-ap341:14.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap341:14.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap341:15.1",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap341:15.2",
      "pali": "arahattamapāpuṇiṁ;"
    },
    {
      "id": "tha-ap341:15.3",
      "pali": "Upasampādayi buddho,"
    },
    {
      "id": "tha-ap341:15.4",
      "pali": "guṇamaññāya cakkhumā."
    },
    {
      "id": "tha-ap341:16.1",
      "pali": "Dārakova ahaṁ santo,"
    },
    {
      "id": "tha-ap341:16.2",
      "pali": "karaṇīyaṁ samāpayiṁ;"
    },
    {
      "id": "tha-ap341:16.3",
      "pali": "Kiṁ me karaṇīyaṁ ajja,"
    },
    {
      "id": "tha-ap341:16.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "tha-ap341:17.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap341:17.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap341:17.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap341:17.4",
      "pali": "saddhammasavane phalaṁ."
    },
    {
      "id": "tha-ap341:18.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap341:18.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap341:18.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap341:19.1",
      "pali": "Itthaṁ sudaṁ āyasmā dhammasavaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap341:20.1",
      "pali": "Dhammasavaniyattherassāpadānaṁ navamaṁ."
    }
  ]
}
