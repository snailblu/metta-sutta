{
  "uid": "iti92",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti92:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti92:2.1",
      "pali": "“Saṅghāṭikaṇṇe cepi, bhikkhave, bhikkhu gahetvā piṭṭhito piṭṭhito anubandho assa pāde pādaṁ nikkhipanto,"
    },
    {
      "id": "iti92:2.2",
      "pali": "so ca hoti abhijjhālu kāmesu tibbasārāgo byāpannacitto paduṭṭhamanasaṅkappo muṭṭhassati asampajāno asamāhito vibbhantacitto pākatindriyo;"
    },
    {
      "id": "iti92:2.3",
      "pali": "atha kho so ārakāva mayhaṁ, ahañca tassa."
    },
    {
      "id": "iti92:2.4",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "iti92:2.5",
      "pali": "Dhammañhi so, bhikkhave, bhikkhu na passati."
    },
    {
      "id": "iti92:2.6",
      "pali": "Dhammaṁ apassanto na maṁ passati."
    },
    {
      "id": "iti92:3.1",
      "pali": "Yojanasate cepi so, bhikkhave, bhikkhu vihareyya."
    },
    {
      "id": "iti92:3.2",
      "pali": "So ca hoti anabhijjhālu kāmesu na tibbasārāgo abyāpannacitto apaduṭṭhamanasaṅkappo upaṭṭhitassati sampajāno samāhito ekaggacitto saṁvutindriyo;"
    },
    {
      "id": "iti92:3.3",
      "pali": "atha kho so santikeva mayhaṁ, ahañca tassa."
    },
    {
      "id": "iti92:3.4",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "iti92:3.5",
      "pali": "Dhammañhi so, bhikkhave, bhikkhu passati;"
    },
    {
      "id": "iti92:3.6",
      "pali": "dhammaṁ passanto maṁ passatī”ti."
    },
    {
      "id": "iti92:3.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti92:3.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti92:4.1",
      "pali": "“Anubandhopi ce assa,"
    },
    {
      "id": "iti92:4.2",
      "pali": "mahiccho ca vighātavā;"
    },
    {
      "id": "iti92:4.3",
      "pali": "Ejānugo anejassa,"
    },
    {
      "id": "iti92:4.4",
      "pali": "nibbutassa anibbuto;"
    },
    {
      "id": "iti92:4.5",
      "pali": "Giddho so vītagedhassa,"
    },
    {
      "id": "iti92:4.6",
      "pali": "passa yāvañca ārakā."
    },
    {
      "id": "iti92:5.1",
      "pali": "Yo ca dhammamabhiññāya,"
    },
    {
      "id": "iti92:5.2",
      "pali": "dhammamaññāya paṇḍito;"
    },
    {
      "id": "iti92:5.3",
      "pali": "Rahadova nivāte ca,"
    },
    {
      "id": "iti92:5.4",
      "pali": "anejo vūpasammati."
    },
    {
      "id": "iti92:6.1",
      "pali": "Anejo so anejassa,"
    },
    {
      "id": "iti92:6.2",
      "pali": "nibbutassa ca nibbuto;"
    },
    {
      "id": "iti92:6.3",
      "pali": "Agiddho vītagedhassa,"
    },
    {
      "id": "iti92:6.4",
      "pali": "passa yāvañca santike”ti."
    },
    {
      "id": "iti92:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti92:7.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
