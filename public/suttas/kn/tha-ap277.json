{
  "uid": "tha-ap277",
  "title": "5 Ekañjalikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap277:1.1",
      "pali": "“Udumbare vasantassa,"
    },
    {
      "id": "tha-ap277:1.2",
      "pali": "niyate paṇṇasanthare;"
    },
    {
      "id": "tha-ap277:1.3",
      "pali": "Vutthokāso mayā dinno,"
    },
    {
      "id": "tha-ap277:1.4",
      "pali": "samaṇassa mahesino."
    },
    {
      "id": "tha-ap277:2.1",
      "pali": "Tissassa dvipadindassa,"
    },
    {
      "id": "tha-ap277:2.2",
      "pali": "lokanāthassa tādino;"
    },
    {
      "id": "tha-ap277:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap277:2.4",
      "pali": "santhariṁ pupphasantharaṁ."
    },
    {
      "id": "tha-ap277:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap277:3.2",
      "pali": "yaṁ kariṁ pupphasantharaṁ;"
    },
    {
      "id": "tha-ap277:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap277:3.4",
      "pali": "santharassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap277:4.1",
      "pali": "Ito cuddasakappamhi,"
    },
    {
      "id": "tha-ap277:4.2",
      "pali": "ahosiṁ manujādhipo;"
    },
    {
      "id": "tha-ap277:4.3",
      "pali": "Ekaañjaliko nāma,"
    },
    {
      "id": "tha-ap277:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap277:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap277:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap277:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap277:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekañjaliko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap277:7.1",
      "pali": "Ekañjalikattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
