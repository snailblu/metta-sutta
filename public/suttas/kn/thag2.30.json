{
  "uid": "thag2.30",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.30:1.1",
      "pali": "“Upāsitā sappurisā,"
    },
    {
      "id": "thag2.30:1.2",
      "pali": "sutā dhammā abhiṇhaso;"
    },
    {
      "id": "thag2.30:1.3",
      "pali": "Sutvāna paṭipajjissaṁ,"
    },
    {
      "id": "thag2.30:1.4",
      "pali": "añjasaṁ amatogadhaṁ."
    },
    {
      "id": "thag2.30:2.1",
      "pali": "Bhavarāgahatassa me sato,"
    },
    {
      "id": "thag2.30:2.2",
      "pali": "Bhavarāgo puna me na vijjati;"
    },
    {
      "id": "thag2.30:2.3",
      "pali": "Na cāhu na ca me bhavissati,"
    },
    {
      "id": "thag2.30:2.4",
      "pali": "Na ca me etarahi vijjatī”ti."
    },
    {
      "id": "thag2.30:2.5",
      "pali": "… Kaṇhadinno thero …"
    },
    {
      "id": "thag2.30:2.6",
      "pali": "vaggo tatiyo."
    },
    {
      "id": "thag2.30:3.1",
      "pali": "Uttaro bhaddajitthero,"
    },
    {
      "id": "thag2.30:3.2",
      "pali": "sobhito valliyo isi;"
    },
    {
      "id": "thag2.30:3.3",
      "pali": "Vītasoko ca yo thero,"
    },
    {
      "id": "thag2.30:3.4",
      "pali": "puṇṇamāso ca nandako;"
    },
    {
      "id": "thag2.30:3.5",
      "pali": "Bharato bhāradvājo ca,"
    },
    {
      "id": "thag2.30:3.6",
      "pali": "kaṇhadinno mahāmunīti."
    }
  ]
}
