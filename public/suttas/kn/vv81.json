{
  "uid": "vv81",
  "title": "Sunikkhittavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv81:1.1",
      "pali": "“Puṇṇamāse yathā cando,"
    },
    {
      "id": "vv81:1.2",
      "pali": "nakkhattaparivārito;"
    },
    {
      "id": "vv81:1.3",
      "pali": "Samantā anupariyāti,"
    },
    {
      "id": "vv81:1.4",
      "pali": "tārakādhipatī sasī."
    },
    {
      "id": "vv81:2.1",
      "pali": "Tathūpamaṁ idaṁ byamhaṁ,"
    },
    {
      "id": "vv81:2.2",
      "pali": "dibbaṁ devapuramhi ca;"
    },
    {
      "id": "vv81:2.3",
      "pali": "Atirocati vaṇṇena,"
    },
    {
      "id": "vv81:2.4",
      "pali": "udayantova raṁsimā."
    },
    {
      "id": "vv81:3.1",
      "pali": "Veḷuriyasuvaṇṇassa,"
    },
    {
      "id": "vv81:3.2",
      "pali": "phalikā rūpiyassa ca;"
    },
    {
      "id": "vv81:3.3",
      "pali": "Masāragallamuttāhi,"
    },
    {
      "id": "vv81:3.4",
      "pali": "lohitaṅgamaṇīhi ca."
    },
    {
      "id": "vv81:4.1",
      "pali": "Citrā manoramā bhūmi,"
    },
    {
      "id": "vv81:4.2",
      "pali": "veḷūriyassa santhatā;"
    },
    {
      "id": "vv81:4.3",
      "pali": "Kūṭāgārā subhā rammā,"
    },
    {
      "id": "vv81:4.4",
      "pali": "pāsādo te sumāpito."
    },
    {
      "id": "vv81:5.1",
      "pali": "Rammā ca te pokkharaṇī,"
    },
    {
      "id": "vv81:5.2",
      "pali": "puthulomanisevitā;"
    },
    {
      "id": "vv81:5.3",
      "pali": "Acchodakā vippasannā,"
    },
    {
      "id": "vv81:5.4",
      "pali": "sovaṇṇavālukasanthatā."
    },
    {
      "id": "vv81:6.1",
      "pali": "Nānāpadumasañchannā,"
    },
    {
      "id": "vv81:6.2",
      "pali": "puṇḍarīkasamotatā;"
    },
    {
      "id": "vv81:6.3",
      "pali": "Surabhiṁ sampavāyanti,"
    },
    {
      "id": "vv81:6.4",
      "pali": "manuññā māluteritā."
    },
    {
      "id": "vv81:7.1",
      "pali": "Tassā te ubhato passe,"
    },
    {
      "id": "vv81:7.2",
      "pali": "vanagumbā sumāpitā;"
    },
    {
      "id": "vv81:7.3",
      "pali": "Upetā puppharukkhehi,"
    },
    {
      "id": "vv81:7.4",
      "pali": "phalarukkhehi cūbhayaṁ."
    },
    {
      "id": "vv81:8.1",
      "pali": "Sovaṇṇapāde pallaṅke,"
    },
    {
      "id": "vv81:8.2",
      "pali": "muduke gonakatthate;"
    },
    {
      "id": "vv81:8.3",
      "pali": "Nisinnaṁ devarājaṁva,"
    },
    {
      "id": "vv81:8.4",
      "pali": "upatiṭṭhanti accharā."
    },
    {
      "id": "vv81:9.1",
      "pali": "Sabbābharaṇasañchannā,"
    },
    {
      "id": "vv81:9.2",
      "pali": "nānāmālāvibhūsitā;"
    },
    {
      "id": "vv81:9.3",
      "pali": "Ramenti taṁ mahiddhikaṁ,"
    },
    {
      "id": "vv81:9.4",
      "pali": "vasavattīva modasi."
    },
    {
      "id": "vv81:10.1",
      "pali": "Bherisaṅkhamudiṅgāhi,"
    },
    {
      "id": "vv81:10.2",
      "pali": "vīṇāhi paṇavehi ca;"
    },
    {
      "id": "vv81:10.3",
      "pali": "Ramasi ratisampanno,"
    },
    {
      "id": "vv81:10.4",
      "pali": "naccagīte suvādite."
    },
    {
      "id": "vv81:11.1",
      "pali": "Dibbā te vividhā rūpā,"
    },
    {
      "id": "vv81:11.2",
      "pali": "dibbā saddā atho rasā;"
    },
    {
      "id": "vv81:11.3",
      "pali": "Gandhā ca te adhippetā,"
    },
    {
      "id": "vv81:11.4",
      "pali": "phoṭṭhabbā ca manoramā."
    },
    {
      "id": "vv81:12.1",
      "pali": "Tasmiṁ vimāne pavare,"
    },
    {
      "id": "vv81:12.2",
      "pali": "devaputta mahappabho;"
    },
    {
      "id": "vv81:12.3",
      "pali": "Atirocasi vaṇṇena,"
    },
    {
      "id": "vv81:12.4",
      "pali": "udayantova bhāṇumā."
    },
    {
      "id": "vv81:13.1",
      "pali": "Dānassa te idaṁ phalaṁ,"
    },
    {
      "id": "vv81:13.2",
      "pali": "atho sīlassa vā pana;"
    },
    {
      "id": "vv81:13.3",
      "pali": "Atho añjalikammassa,"
    },
    {
      "id": "vv81:13.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "vv81:14.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv81:14.2",
      "pali": "…pe…"
    },
    {
      "id": "vv81:14.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv81:15.1",
      "pali": "“Ahaṁ kapilavatthusmiṁ,"
    },
    {
      "id": "vv81:15.2",
      "pali": "sākiyānaṁ puruttame;"
    },
    {
      "id": "vv81:15.3",
      "pali": "Suddhodanassa puttassa,"
    },
    {
      "id": "vv81:15.4",
      "pali": "kaṇḍako sahajo ahaṁ."
    },
    {
      "id": "vv81:16.1",
      "pali": "Yadā so aḍḍharattāyaṁ,"
    },
    {
      "id": "vv81:16.2",
      "pali": "bodhāya mabhinikkhami;"
    },
    {
      "id": "vv81:16.3",
      "pali": "So maṁ mudūhi pāṇīhi,"
    },
    {
      "id": "vv81:16.4",
      "pali": "jāli tambanakhehi ca."
    },
    {
      "id": "vv81:17.1",
      "pali": "Satthiṁ ākoṭayitvāna,"
    },
    {
      "id": "vv81:17.2",
      "pali": "vaha sammāti cabravi;"
    },
    {
      "id": "vv81:17.3",
      "pali": "Ahaṁ lokaṁ tārayissaṁ,"
    },
    {
      "id": "vv81:17.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "vv81:18.1",
      "pali": "Taṁ me giraṁ suṇantassa,"
    },
    {
      "id": "vv81:18.2",
      "pali": "hāso me vipulo ahu;"
    },
    {
      "id": "vv81:18.3",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "vv81:18.4",
      "pali": "abhisīsiṁ tadā ahaṁ."
    },
    {
      "id": "vv81:19.1",
      "pali": "Abhirūḷhañca maṁ ñatvā,"
    },
    {
      "id": "vv81:19.2",
      "pali": "sakyaputtaṁ mahāyasaṁ;"
    },
    {
      "id": "vv81:19.3",
      "pali": "Udaggacitto mudito,"
    },
    {
      "id": "vv81:19.4",
      "pali": "vahissaṁ purisuttamaṁ."
    },
    {
      "id": "vv81:20.1",
      "pali": "Paresaṁ vijitaṁ gantvā,"
    },
    {
      "id": "vv81:20.2",
      "pali": "uggatasmiṁ divākare;"
    },
    {
      "id": "vv81:20.3",
      "pali": "Mamaṁ channañca ohāya,"
    },
    {
      "id": "vv81:20.4",
      "pali": "anapekkho so apakkami."
    },
    {
      "id": "vv81:21.1",
      "pali": "Tassa tambanakhe pāde,"
    },
    {
      "id": "vv81:21.2",
      "pali": "jivhāya parilehisaṁ;"
    },
    {
      "id": "vv81:21.3",
      "pali": "Gacchantañca mahāvīraṁ,"
    },
    {
      "id": "vv81:21.4",
      "pali": "rudamāno udikkhisaṁ."
    },
    {
      "id": "vv81:22.1",
      "pali": "Adassanenahaṁ tassa,"
    },
    {
      "id": "vv81:22.2",
      "pali": "sakyaputtassa sirīmato;"
    },
    {
      "id": "vv81:22.3",
      "pali": "Alatthaṁ garukābādhaṁ,"
    },
    {
      "id": "vv81:22.4",
      "pali": "khippaṁ me maraṇaṁ ahu."
    },
    {
      "id": "vv81:23.1",
      "pali": "Tasseva ānubhāvena,"
    },
    {
      "id": "vv81:23.2",
      "pali": "vimānaṁ āvasāmidaṁ;"
    },
    {
      "id": "vv81:23.3",
      "pali": "Sabbakāmaguṇopetaṁ,"
    },
    {
      "id": "vv81:23.4",
      "pali": "dibbaṁ devapuramhi ca."
    },
    {
      "id": "vv81:24.1",
      "pali": "Yañca me ahuvā hāso,"
    },
    {
      "id": "vv81:24.2",
      "pali": "saddaṁ sutvāna bodhiyā;"
    },
    {
      "id": "vv81:24.3",
      "pali": "Teneva kusalamūlena,"
    },
    {
      "id": "vv81:24.4",
      "pali": "phusissaṁ āsavakkhayaṁ."
    },
    {
      "id": "vv81:25.1",
      "pali": "Sace hi bhante gaccheyyāsi,"
    },
    {
      "id": "vv81:25.2",
      "pali": "satthu buddhassa santike;"
    },
    {
      "id": "vv81:25.3",
      "pali": "Mamāpi naṁ vacanena,"
    },
    {
      "id": "vv81:25.4",
      "pali": "sirasā vajjāsi vandanaṁ."
    },
    {
      "id": "vv81:26.1",
      "pali": "Ahampi daṭṭhuṁ gacchissaṁ,"
    },
    {
      "id": "vv81:26.2",
      "pali": "jinaṁ appaṭipuggalaṁ;"
    },
    {
      "id": "vv81:26.3",
      "pali": "Dullabhaṁ dassanaṁ hoti,"
    },
    {
      "id": "vv81:26.4",
      "pali": "lokanāthāna tādinan”ti."
    },
    {
      "id": "vv81:27.1",
      "pali": "So kataññū katavedī,"
    },
    {
      "id": "vv81:27.2",
      "pali": "satthāraṁ upasaṅkami;"
    },
    {
      "id": "vv81:27.3",
      "pali": "Sutvā giraṁ cakkhumato,"
    },
    {
      "id": "vv81:27.4",
      "pali": "dhammacakkhuṁ visodhayi."
    },
    {
      "id": "vv81:28.1",
      "pali": "Visodhetvā diṭṭhigataṁ,"
    },
    {
      "id": "vv81:28.2",
      "pali": "vicikicchaṁ vatāni ca;"
    },
    {
      "id": "vv81:28.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "vv81:28.4",
      "pali": "tatthevantaradhāyathāti."
    },
    {
      "id": "vv81:29.1",
      "pali": "Kaṇḍakavimānaṁ sattamaṁ."
    }
  ]
}
