{
  "uid": "pe3",
  "title": "3. Suttādhiṭṭhānatatiyabhūmi",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pe3:1.1",
      "pali": "Tattha katamaṁ suttādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:2.1",
      "pali": "Lobhādhiṭṭhānaṁ dosādhiṭṭhānaṁ mohādhiṭṭhānaṁ alobhādhiṭṭhānaṁ adosādhiṭṭhānaṁ amohādhiṭṭhānaṁ kāyakammādhiṭṭhānaṁ vācākammādhiṭṭhānaṁ manokammādhiṭṭhānaṁ saddhindriyādhiṭṭhānaṁ vīriyindriyādhiṭṭhānaṁ satindriyādhiṭṭhānaṁ samādhindriyādhiṭṭhānaṁ paññindriyādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:3.1",
      "pali": "Tattha katamaṁ lobhādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:4.1",
      "pali": "“Vitakkamathitassa jantuno,"
    },
    {
      "id": "pe3:4.2",
      "pali": "Tibbarāgassa subhānupassino;"
    },
    {
      "id": "pe3:4.3",
      "pali": "Bhiyyo taṇhā pavaḍḍhati,"
    },
    {
      "id": "pe3:4.4",
      "pali": "Esa kho gāḷhaṁ karoti bandhanaṁ”."
    },
    {
      "id": "pe3:5.1",
      "pali": "Vitakkamathitassāti kāmarāgo."
    },
    {
      "id": "pe3:5.2",
      "pali": "Subhānupassinoti kāmarāgavatthu."
    },
    {
      "id": "pe3:5.3",
      "pali": "Bhiyyo taṇhā pavaḍḍhatīti kāmataṇhā."
    },
    {
      "id": "pe3:5.4",
      "pali": "Esa gāḷhaṁ karoti bandhananti rāgaṁ, iti yo yo dhammo mūlanikkhitto, so yevettha dhammo uggāvahitabbo."
    },
    {
      "id": "pe3:5.5",
      "pali": "Na bhagavā ekaṁ dhammaṁ ārabbha aññaṁ dhammaṁ deseti."
    },
    {
      "id": "pe3:5.6",
      "pali": "Yassa vitakketi kāmavitakko tameva vitakkaṁ kāmavitakkena niddisīyati."
    },
    {
      "id": "pe3:5.7",
      "pali": "Tibbarāgassāti tasseva vitakkassa vatthuṁ niddisati."
    },
    {
      "id": "pe3:5.8",
      "pali": "Subhānupassino bhiyyo taṇhā pavaḍḍhatīti tameva rāgaṁ kāmataṇhāti niddisati."
    },
    {
      "id": "pe3:5.9",
      "pali": "Esa gāḷhaṁ karoti bandhananti tameva taṇhāsaṁyojanaṁ niddisati."
    },
    {
      "id": "pe3:5.10",
      "pali": "Evaṁ gāthāsu anuminitabbaṁ."
    },
    {
      "id": "pe3:5.11",
      "pali": "Evaṁ saveyyākaraṇesu."
    },
    {
      "id": "pe3:6.1",
      "pali": "Tattha bhagavā ekaṁ dhammaṁ tividhaṁ niddisati, nissandato hetuto phalato."
    },
    {
      "id": "pe3:7.1",
      "pali": "“Dadaṁ piyo hoti bhajanti naṁ bahū,"
    },
    {
      "id": "pe3:7.2",
      "pali": "Kittiñca pappoti yaso ca vaḍḍhati;"
    },
    {
      "id": "pe3:7.3",
      "pali": "Amaṅkubhūto parisaṁ vigāhati,"
    },
    {
      "id": "pe3:7.4",
      "pali": "Visārado hoti naro amaccharī”."
    },
    {
      "id": "pe3:8.1",
      "pali": "Dadanti yaṁ yaṁ dānaṁ, idaṁ dānamayikaṁ puññakriyaṁ."
    },
    {
      "id": "pe3:8.2",
      "pali": "Tattha hetu."
    },
    {
      "id": "pe3:8.3",
      "pali": "Yañcetaṁ."
    },
    {
      "id": "pe3:8.4",
      "pali": "Bhajanti naṁ bahū, kittinti yo ca kalyāṇo kittisaddo loke abbhuggacchati, yaṁ bahukassa janassa piyo bhavati manāpo ca."
    },
    {
      "id": "pe3:8.5",
      "pali": "Yañca avippaṭisārī kālaṁ karoti ayaṁ nissando."
    },
    {
      "id": "pe3:8.6",
      "pali": "Yaṁ kāyassa bhedā devesu upapajjatīti idaṁ phalaṁ."
    },
    {
      "id": "pe3:8.7",
      "pali": "Idaṁ lobhādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:9.1",
      "pali": "Tattha katamaṁ dosādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:10.1",
      "pali": "“Yo pāṇamatipāteti,"
    },
    {
      "id": "pe3:10.2",
      "pali": "musāvādañca bhāsati;"
    },
    {
      "id": "pe3:10.3",
      "pali": "Loke adinnaṁ ādiyati,"
    },
    {
      "id": "pe3:10.4",
      "pali": "paradārañca gacchati;"
    },
    {
      "id": "pe3:10.5",
      "pali": "Surāmerayapānañca,"
    },
    {
      "id": "pe3:10.6",
      "pali": "yo naro anuyuñjati."
    },
    {
      "id": "pe3:11.1",
      "pali": "Appahāya pañca verāni,"
    },
    {
      "id": "pe3:11.2",
      "pali": "dussīlo iti vuccati;"
    },
    {
      "id": "pe3:11.3",
      "pali": "Kāyassa bhedā duppañño,"
    },
    {
      "id": "pe3:11.4",
      "pali": "nirayaṁ sopapajjati”."
    },
    {
      "id": "pe3:12.1",
      "pali": "Yo pāṇamatipātetīti duṭṭho pāṇamatipāteti."
    },
    {
      "id": "pe3:12.2",
      "pali": "Musāvādañca bhāsatīti dosopaghātāya musāvādañca bhāsati."
    },
    {
      "id": "pe3:12.3",
      "pali": "Surāmerayapānañca, yo naro anuyuñjatīti doso nidānaṁ."
    },
    {
      "id": "pe3:12.4",
      "pali": "Yo ca surāmerayapānaṁ anuyuñjati yathāparadāravihārī amittā janayanti."
    },
    {
      "id": "pe3:13.1",
      "pali": "Pañca verāni appahāyāti pañcannaṁ bhikkhāpadānaṁ samatikkamanaṁ sabbesaṁ dosajānaṁ sā paṇṇatti, teneva dosajanitena kammena dussīlo iti vuccati sopi dhammo hetunā niddisitabbo, nissandena phalena ca."
    },
    {
      "id": "pe3:14.1",
      "pali": "Tīṇi bālassa bālalakkhaṇāni—"
    },
    {
      "id": "pe3:14.2",
      "pali": "dubbhāsitabhāsī ca hoti, duccintitacintī ca dukkaṭakammakārī ca."
    },
    {
      "id": "pe3:14.3",
      "pali": "Tattha yaṁ kāyena ca vācāya ca parakkamati, idamassa dukkaṭakammakārī."
    },
    {
      "id": "pe3:14.4",
      "pali": "Tāyaṁ yathā ca musāvādaṁ bhāsati yathā pubbaniddiṭṭhaṁ, idamassa dubbhāsitā."
    },
    {
      "id": "pe3:14.5",
      "pali": "Yañca saṅkappeti manoduccaritaṁ byāpādaṁ, idamassa duccintitacintitā."
    },
    {
      "id": "pe3:14.6",
      "pali": "Yaṁ so imehi tīhi bālalakkhaṇehi samannāgato tīṇi tajjāni dukkhāni domanassāni anubhavati, so ca hoti sabhaggato vā parisaggato vā tajjaṁ kathaṁ kathanti."
    },
    {
      "id": "pe3:14.7",
      "pali": "Yadā bhavati so ca pāṇātipātādidasaakusalakammapatho, so tatonidānaṁ dukkhaṁ domanassaṁ paṭisaṁvedetīti."
    },
    {
      "id": "pe3:14.8",
      "pali": "Puna caparaṁ yadā passati coraṁ rājāparādhikaṁ raññā gahitaṁ jīvitā voropetaṁ, tassevaṁ bhavati sace mamampi rājā jāneyya mamampi rājā gāhāpetvā jīvitā voropeyyāti, so tatonidānaṁ dukkhaṁ domanassaṁ paṭisaṁvedeti."
    },
    {
      "id": "pe3:14.9",
      "pali": "Puna caparaṁ bālo yadā bhavati āsanā samārūḷho yāva yā me gati bhavissati ito pecca paraṁ maraṇāti so tatonidānaṁ dukkhaṁ domanassaṁ paṭisaṁvedeti iti bālalakkhaṇaṁ hetu."
    },
    {
      "id": "pe3:14.10",
      "pali": "Tīṇi tajjāni dukkhāni nissando."
    },
    {
      "id": "pe3:14.11",
      "pali": "Kāyassa bhedā nirayesu upapajjati, idaṁ phalaṁ."
    },
    {
      "id": "pe3:14.12",
      "pali": "Idaṁ dosādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:15.1",
      "pali": "Tattha katamaṁ mohādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:16.1",
      "pali": "“Satañceva sahassānaṁ,"
    },
    {
      "id": "pe3:16.2",
      "pali": "kappānaṁ saṁsarissati;"
    },
    {
      "id": "pe3:16.3",
      "pali": "Atha vāpi tato bhiyyo,"
    },
    {
      "id": "pe3:16.4",
      "pali": "gabbhā gabbhaṁ gamissatha."
    },
    {
      "id": "pe3:17.1",
      "pali": "Anupādāya buddhavacanaṁ,"
    },
    {
      "id": "pe3:17.2",
      "pali": "Saṅkhāre attato upādāya;"
    },
    {
      "id": "pe3:17.3",
      "pali": "Dukkhassantaṁ karissanti,"
    },
    {
      "id": "pe3:17.4",
      "pali": "Ṭhānametaṁ na vijjati”."
    },
    {
      "id": "pe3:18.1",
      "pali": "Yo yaṁ anamataggasaṁsāraṁ samāpanno jāyate ca mīyate ca, ayaṁ avijjāhetukā."
    },
    {
      "id": "pe3:18.2",
      "pali": "Yānipi ca saṅkhārānaṁ payojanāni, tānipi avijjāpaccayāni, yaṁ adassanaṁ buddhavacanassa, ayaṁ avijjāsutteyeva niddiṭṭhaṁ."
    },
    {
      "id": "pe3:18.3",
      "pali": "Yo ca saṅkhāre attato harati pañcakkhandhe pañca diṭṭhiyo upagacchati."
    },
    {
      "id": "pe3:18.4",
      "pali": "“Etaṁ mama, esohamasmi, eso me attā”ti idaṁ suttaṁ avijjāya nikkhittaṁ, avijjāya nikkhipitaṁ."
    },
    {
      "id": "pe3:18.5",
      "pali": "Evaṁ satthā sutte nayena dhammena niddisati."
    },
    {
      "id": "pe3:18.6",
      "pali": "Asādhāraṇena taṁyeva tattha niddisitabbaṁ."
    },
    {
      "id": "pe3:18.7",
      "pali": "Na aññaṁ."
    },
    {
      "id": "pe3:19.1",
      "pali": "Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā “idaṁ dukkhan”ti nappajānanti cattāri saccāni vitthārena, yaṁ tattha appajānanā, idaṁ dukkhaṁ, ayaṁ hetu."
    },
    {
      "id": "pe3:19.2",
      "pali": "Appajānanto vividhe saṅkhāre abhisaṅkharoti, ayaṁ nissando."
    },
    {
      "id": "pe3:19.3",
      "pali": "Yañca diṭṭhigatāni parāmasati “idameva saccaṁ moghamaññan”ti ayaṁ nissando."
    },
    {
      "id": "pe3:19.4",
      "pali": "Yaṁ punabbhavaṁ nibbatteti, idaṁ phalaṁ."
    },
    {
      "id": "pe3:19.5",
      "pali": "Ayampi dhammo saniddiṭṭho hetuto ca phalato ca nissandato ca."
    },
    {
      "id": "pe3:20.1",
      "pali": "Ettha pana keci dhammā sādhāraṇā bhavanti."
    },
    {
      "id": "pe3:20.2",
      "pali": "Hetu khalu āditoyeva sutte nikkhipissanti."
    },
    {
      "id": "pe3:20.3",
      "pali": "Yathā kiṁ bhave cattārimāni, bhikkhave, agatigamanāni."
    },
    {
      "id": "pe3:20.4",
      "pali": "Tattha yañca chandāgatiṁ gacchati yañca bhayāgatiṁ gacchati, ayaṁ lobho akusalamūlaṁ."
    },
    {
      "id": "pe3:20.5",
      "pali": "Yaṁ dosā, ayaṁ dosoyeva."
    },
    {
      "id": "pe3:20.6",
      "pali": "Yaṁ mohā, ayaṁ mohoyeva."
    },
    {
      "id": "pe3:20.7",
      "pali": "Evaṁ imāni tīṇi akusalamūlāni āditoyeva upaparikkhitabbāni."
    },
    {
      "id": "pe3:20.8",
      "pali": "Yattha ekaṁ niddisitabbaṁ, tattha ekaṁ niddisīyati."
    },
    {
      "id": "pe3:20.9",
      "pali": "Tathā dve yathā tīṇi, na hi ādīhi anikkhitte hetu vā nissando vā phalaṁ vā niddisitabbaṁ."
    },
    {
      "id": "pe3:21.1",
      "pali": "Ayañcettha gāthā—"
    },
    {
      "id": "pe3:22.1",
      "pali": "“Chandā dosā bhayā mohā,"
    },
    {
      "id": "pe3:22.2",
      "pali": "yo dhammaṁ ativattati;"
    },
    {
      "id": "pe3:22.3",
      "pali": "Nihīyati tassa yaso,"
    },
    {
      "id": "pe3:22.4",
      "pali": "kāḷapakkheva candimā”."
    },
    {
      "id": "pe3:23.1",
      "pali": "Kattha chandā ca ayaṁ lobho yathā niddiṭṭhaṁ pubbe."
    },
    {
      "id": "pe3:23.2",
      "pali": "Idaṁ mohādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:24.1",
      "pali": "Tattha katamaṁ alobhādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:25.1",
      "pali": "“Asubhānupassiṁ viharantaṁ,"
    },
    {
      "id": "pe3:25.2",
      "pali": "Indriyesu susaṁvutaṁ;"
    },
    {
      "id": "pe3:25.3",
      "pali": "Bhojanamhi ca mattaññuṁ,"
    },
    {
      "id": "pe3:25.4",
      "pali": "Saddhaṁ āraddhavīriyaṁ;"
    },
    {
      "id": "pe3:25.5",
      "pali": "Taṁ ve nappasahati māro,"
    },
    {
      "id": "pe3:25.6",
      "pali": "Vāto selaṁva pabbatan”ti."
    },
    {
      "id": "pe3:26.1",
      "pali": "Tattha yā asubhāya upaparikkhā, ayaṁ kāmesu ādīnavadassanena pariccāgo."
    },
    {
      "id": "pe3:26.2",
      "pali": "Indriyesu susaṁvuto tasseva alobhassa pāripūriyaṁ mama āyatanasocitaṁ anupādāya."
    },
    {
      "id": "pe3:26.3",
      "pali": "Bhojanamhi ca mattaññunti rasataṇhāpahānaṁ."
    },
    {
      "id": "pe3:26.4",
      "pali": "Iti ayaṁ alobho asubhānupassitāya vatthuto dhārayati, so alobho hetu."
    },
    {
      "id": "pe3:26.5",
      "pali": "Indriyesu guttadvāratāya gocarato dhārayati, bhojanemattaññutāya parato dhārayati, ayaṁ nissando."
    },
    {
      "id": "pe3:26.6",
      "pali": "Taṁ ve nappasahati māro, vāto selaṁ va pabbatanti, idaṁ phalaṁ."
    },
    {
      "id": "pe3:26.7",
      "pali": "Iti yoyeva dhammo ādimhi nikkhitto, soyeva majjhe ceva avasāne ca."
    },
    {
      "id": "pe3:27.1",
      "pali": "Nāhaṁ, bhikkhave, aññaṁ ekadhammampi samanupassāmi asamuppannassa kāmacchandassa anuppādāya uppannassa vā pahānāya, yathayidaṁ asubhanimittaṁ."
    },
    {
      "id": "pe3:27.2",
      "pali": "Tattha asubhanimittaṁ manasikarontassa anuppanno ceva kāmacchando na uppajjati, uppanno ca kāmacchando pahīyati."
    },
    {
      "id": "pe3:27.3",
      "pali": "Idaṁ alobhassa vatthu."
    },
    {
      "id": "pe3:27.4",
      "pali": "Yaṁ puna anuppanno kāmarāgo pariyādiyati rūparāgaṁ arūparāgaṁ, iti phalaṁ."
    },
    {
      "id": "pe3:27.5",
      "pali": "Iti ayampi ca dhammo niddiṭṭho hetuto ca nissandato ca phalato ca."
    },
    {
      "id": "pe3:27.6",
      "pali": "Idaṁ alobhādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:28.1",
      "pali": "Tattha katamaṁ adosādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:29.1",
      "pali": "“Ekampi ce pāṇamaduṭṭhacitto,"
    },
    {
      "id": "pe3:29.2",
      "pali": "Mettāyati kusalo tena hoti;"
    },
    {
      "id": "pe3:29.3",
      "pali": "Sabbe ca pāṇe manasānukampaṁ,"
    },
    {
      "id": "pe3:29.4",
      "pali": "Pahūtamariyo pakaroti puññaṁ”."
    },
    {
      "id": "pe3:30.1",
      "pali": "Ekampi ce pāṇamaduṭṭhacitto mettāyatīti ayaṁ adoso."
    },
    {
      "id": "pe3:30.2",
      "pali": "Nigghātena assādo, kusalo tena hotīti tena kusalena dhammena saṁyutto dhammapaññattiṁ gacchati."
    },
    {
      "id": "pe3:30.3",
      "pali": "Kusaloti yathā paññāya pañño paṇḍiccena paṇḍito."
    },
    {
      "id": "pe3:30.4",
      "pali": "Pahūtamariyo pakaroti puññanti tassāyeva vipāko ayaṁ lokiyassa, na hi lokuttarassa."
    },
    {
      "id": "pe3:30.5",
      "pali": "Tattha yā mettāyanā, ayaṁ hetu."
    },
    {
      "id": "pe3:30.6",
      "pali": "Yaṁ kusalo bhavati ayaṁ nissando."
    },
    {
      "id": "pe3:30.7",
      "pali": "Yāva abyāpajjo bhūmiyaṁ bahupuññaṁ pasavati, idaṁ phalaṁ."
    },
    {
      "id": "pe3:30.8",
      "pali": "Iti adoso niddiṭṭho hetuto ca nissandato ca phalato ca."
    },
    {
      "id": "pe3:31.1",
      "pali": "Ekādasānisaṁsā mettāya cetovimuttiyā."
    },
    {
      "id": "pe3:31.2",
      "pali": "Tattha yā mettācetovimutti, ayaṁ ariyadhammesu rāgavirāgā cetovimutti, lokikāya bhūmikā hetu, yaṁ sukhaṁ āyatiṁ manāpo hoti manussānaṁ, ime ekādasa dhammā nissando."
    },
    {
      "id": "pe3:31.3",
      "pali": "Yañca akatāvī brahmakāye upapajjati."
    },
    {
      "id": "pe3:31.4",
      "pali": "Idaṁ phalaṁ."
    },
    {
      "id": "pe3:31.5",
      "pali": "Idaṁ adosādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:32.1",
      "pali": "Tattha katamaṁ amohādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:33.1",
      "pali": "“Paññā hi seṭṭhā lokasmiṁ,"
    },
    {
      "id": "pe3:33.2",
      "pali": "yāyaṁ nibbedhagāminī;"
    },
    {
      "id": "pe3:33.3",
      "pali": "Yāya sammā pajānāti,"
    },
    {
      "id": "pe3:33.4",
      "pali": "jātimaraṇasaṅkhayaṁ”."
    },
    {
      "id": "pe3:34.1",
      "pali": "Paññā hi seṭṭhāti vatthuṁ."
    },
    {
      "id": "pe3:34.2",
      "pali": "Nibbedhagāminīti nibbānagāminiyaṁ yathābhūtaṁ paṭivijjhati."
    },
    {
      "id": "pe3:34.3",
      "pali": "Sammā pajānāti, jātimaraṇasaṅkhayanti amoho."
    },
    {
      "id": "pe3:34.4",
      "pali": "Paññāti hetu."
    },
    {
      "id": "pe3:34.5",
      "pali": "Yaṁ pajānāti ayaṁ nissando."
    },
    {
      "id": "pe3:34.6",
      "pali": "Yo jātimaraṇasaṅkhayo, idaṁ phalaṁ."
    },
    {
      "id": "pe3:34.7",
      "pali": "Iti amoho niddiṭṭho hetunā ca nissandena ca phalena ca."
    },
    {
      "id": "pe3:35.1",
      "pali": "Tīṇimāni, bhikkhave, indriyāni anaññātaññassāmītindriyaṁ aññindriyaṁ aññātāvindriyaṁ."
    },
    {
      "id": "pe3:35.2",
      "pali": "Tattha katamaṁ anaññātaññassāmītindriyaṁ?"
    },
    {
      "id": "pe3:35.3",
      "pali": "Idha, bhikkhave, bhikkhu anabhisametassa dukkhassa ariyasaccassa abhisamayāya chandaṁ janeti vāyamati, vīriyaṁ ārabhati, cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "pe3:35.4",
      "pali": "Evaṁ catunnaṁ ariyasaccānaṁ kātabbaṁ."
    },
    {
      "id": "pe3:35.5",
      "pali": "Tattha katamaṁ aññindriyaṁ?"
    },
    {
      "id": "pe3:35.6",
      "pali": "Idha, bhikkhave, bhikkhu “idaṁ dukkhaṁ ariyasaccan”ti yathābhūtaṁ pajānāti, yā ca maggo, idaṁ aññindriyaṁ."
    },
    {
      "id": "pe3:35.7",
      "pali": "Āsavakkhayā anāsavo hoti, idaṁ vuccati aññātāvindriyaṁ."
    },
    {
      "id": "pe3:35.8",
      "pali": "Tathāyaṁ paññā, ayaṁ hetu."
    },
    {
      "id": "pe3:35.9",
      "pali": "Yaṁ chandaṁ janeti vāyamati, yā pajānāti, ayaṁ nissando."
    },
    {
      "id": "pe3:35.10",
      "pali": "Yena sabbaso āsavānaṁ khayā hetu, yaṁ khaye ñāṇamuppajjati, anuppāde ñāṇañca, ayaṁ nissando."
    },
    {
      "id": "pe3:35.11",
      "pali": "Yaṁ arahattaṁ, idaṁ phalaṁ."
    },
    {
      "id": "pe3:35.12",
      "pali": "Tattha khīṇā me jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyanti, idaṁ khaye ñāṇaṁ."
    },
    {
      "id": "pe3:35.13",
      "pali": "Nāparaṁ itthattāyāti pajānāmīti idaṁ anuppāde ñāṇaṁ."
    },
    {
      "id": "pe3:35.14",
      "pali": "Iti imāni indriyāni amoho niddiṭṭho hetunā ca nissandena ca phalena ca."
    },
    {
      "id": "pe3:35.15",
      "pali": "Imāni asādhāraṇāni niddiṭṭhāni."
    },
    {
      "id": "pe3:36.1",
      "pali": "Tattha katamāni kusalamūlāni sādhāraṇāni?"
    },
    {
      "id": "pe3:36.2",
      "pali": "Kusalañca vo, bhikkhave, desessāmi kusalamūlañceva."
    },
    {
      "id": "pe3:36.3",
      "pali": "Tattha katamaṁ kusalamūlaṁ?"
    },
    {
      "id": "pe3:36.4",
      "pali": "Alobho adoso amoho."
    },
    {
      "id": "pe3:36.5",
      "pali": "Tattha katamaṁ kusalaṁ?"
    },
    {
      "id": "pe3:36.6",
      "pali": "Aṭṭha sammattāni sammādiṭṭhi yāva sammāsamādhi."
    },
    {
      "id": "pe3:36.7",
      "pali": "Tattha yāni kusalamūlāni, ayaṁ hetu."
    },
    {
      "id": "pe3:36.8",
      "pali": "Yañca alobho tīṇi kammāni samuṭṭhāpeti saṅkappaṁ vāyāmaṁ samādhiñca, ayaṁ alobhassa nissando."
    },
    {
      "id": "pe3:36.9",
      "pali": "Tattha yo adoso, ayaṁ hetu."
    },
    {
      "id": "pe3:36.10",
      "pali": "Yaṁ tayo dhamme paṭṭhapeti sammāvācaṁ sammākammantaṁ sammāājīvañca, ayaṁ nissando."
    },
    {
      "id": "pe3:36.11",
      "pali": "Tattha yo amoho hetu, yaṁ dve dhamme upaṭṭhapeti aviparītadassanampi ca anabhilāpanaṁ, ayaṁ nissando."
    },
    {
      "id": "pe3:36.12",
      "pali": "Imassa brahmacariyassa yaṁ phalaṁ, tā dve vimuttiyo rāgavirāgā cetovimutti avijjā virāgā ca paññāvimutti, idaṁ phalaṁ."
    },
    {
      "id": "pe3:36.13",
      "pali": "Iti imāni tīṇi kusalamūlāni niddiṭṭhāni hetuto ca nissandato ca phalato ca."
    },
    {
      "id": "pe3:36.14",
      "pali": "Evaṁ sādhāraṇāni kusalāni paṭivijjhitabbāni."
    },
    {
      "id": "pe3:37.1",
      "pali": "Yattha duve yattha tīṇi."
    },
    {
      "id": "pe3:37.2",
      "pali": "Ayañcettha gāthā."
    },
    {
      "id": "pe3:38.1",
      "pali": "“Tulamatulañca sambhavaṁ,"
    },
    {
      "id": "pe3:38.2",
      "pali": "Bhavasaṅkhāramavassaji muni;"
    },
    {
      "id": "pe3:38.3",
      "pali": "Ajjhattarato samāhito,"
    },
    {
      "id": "pe3:38.4",
      "pali": "Abhindi kavacamivattasambhavan”ti."
    },
    {
      "id": "pe3:39.1",
      "pali": "Tulamatulañca sambhavanti tulasaṅkhataṁ atulasaṅkhataṁ."
    },
    {
      "id": "pe3:39.2",
      "pali": "Tattha ye saṅkhatā tulaṁ, te dve dhammā assādo ca ādīnavo ca tulitā bhavanti."
    },
    {
      "id": "pe3:39.3",
      "pali": "Ettako kāmesu assādo."
    },
    {
      "id": "pe3:39.4",
      "pali": "Ettako ādīnavo imassa, idaṁ nissaraṇanti iti nibbānaṁ pajānāti."
    },
    {
      "id": "pe3:39.5",
      "pali": "Dvīhi kāraṇehi atulaṁ na ca sakkā tulayituṁ."
    },
    {
      "id": "pe3:39.6",
      "pali": "Ettakaṁ etaṁ netaṁ paramatthīti tena atulaṁ."
    },
    {
      "id": "pe3:39.7",
      "pali": "Atha pāpuṇā ratanaṁ karitvā acchariyabhāvena atulaṁ."
    },
    {
      "id": "pe3:39.8",
      "pali": "Tattha kusalassa ca abhisambhavā jānanā passanā, ayaṁ amoho."
    },
    {
      "id": "pe3:39.9",
      "pali": "Yaṁ tattha ñātā osiraṇā bhavasaṅkhārānaṁ, ayaṁ alobho."
    },
    {
      "id": "pe3:39.10",
      "pali": "Yaṁ ajjhattarato samāhitoti vikkhepapaṭisaṁharaṇā, ayaṁ adoso."
    },
    {
      "id": "pe3:39.11",
      "pali": "Iti imāni tīṇi kusalamūlāni."
    },
    {
      "id": "pe3:39.12",
      "pali": "Tulamatulasambhavanti ayaṁ amoho."
    },
    {
      "id": "pe3:39.13",
      "pali": "Yo bhavasaṅkhārānaṁ samosaraṇaṁ lobho sammāsamādhīnaṁ assādo, ayaṁ hetu."
    },
    {
      "id": "pe3:39.14",
      "pali": "Yaṁ ajjhattarato avijjaṇḍakosaṁ sambhedo, ayaṁ nissando."
    },
    {
      "id": "pe3:39.15",
      "pali": "Sā pavatti imāni tīṇi niddiṭṭhāni kusalamūlāni hetuto ca nissandato ca phalato ca."
    },
    {
      "id": "pe3:40.1",
      "pali": "Ettāvatā esā pavatti ca nivatti ca akusalamūlehi pavattati, kusalamūlehi nivattatīti imehi ca tīhi sabbaṁ akusalamūlaṁ samosaraṇaṁ gacchati."
    },
    {
      "id": "pe3:40.2",
      "pali": "So dhamme vā vacanato niddiṭṭho taṇhāti vā kodhoti vā asampajaññanti vā anusayoti vā makkhoti vā paḷāsoti vā assatīti vā issāti vā macchariyanti vā aññāṇanti vā, tehi ye ca vatthūhi niddisitabbaṁ."
    },
    {
      "id": "pe3:40.3",
      "pali": "Yassimāni dve vacanāni dhammapadāni niddiṭṭhāni na so atthi kilesā, yo imesu navasu padesu samodhānaṁ samosaraṇaṁ gacchati."
    },
    {
      "id": "pe3:40.4",
      "pali": "Ayaṁ kileso, na ca lobho, na ca doso, na ca moho."
    },
    {
      "id": "pe3:41.1",
      "pali": "Yathā akusalamūlāni, evaṁ kusalāni paṭikkhepena niddisitabbāni."
    },
    {
      "id": "pe3:41.2",
      "pali": "Idaṁ amohādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:42.1",
      "pali": "Tattha katamaṁ kāyakammādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:43.1",
      "pali": "“Kāyena kusalaṁ kare,"
    },
    {
      "id": "pe3:43.2",
      "pali": "assa kāyena saṁvuto;"
    },
    {
      "id": "pe3:43.3",
      "pali": "Kāyaduccaritaṁ hitvā,"
    },
    {
      "id": "pe3:43.4",
      "pali": "kāyena sucaritaṁ care”."
    },
    {
      "id": "pe3:44.1",
      "pali": "Tīṇimāni, bhikkhave, sucaritāni."
    },
    {
      "id": "pe3:44.2",
      "pali": "Pāṇātipātā veramaṇī, adinnādānā veramaṇī, kāmesumicchācārā veramaṇī, idaṁ kāyakammādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:45.1",
      "pali": "Tattha katamaṁ vācākammādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:46.1",
      "pali": "“Subhāsitaṁ uttamamāhu santo,"
    },
    {
      "id": "pe3:46.2",
      "pali": "Dhammaṁ bhaṇe nādhammaṁ taṁ dutiyaṁ;"
    },
    {
      "id": "pe3:46.3",
      "pali": "Piyaṁ bhaṇe nāppiyaṁ taṁ tatiyaṁ,"
    },
    {
      "id": "pe3:46.4",
      "pali": "Saccaṁ bhaṇe nālikaṁ taṁ catutthaṁ”."
    },
    {
      "id": "pe3:47.1",
      "pali": "Cattārimāni ca vacīsucaritāni idaṁ vācākammādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:48.1",
      "pali": "Tattha katamaṁ manokammādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:49.1",
      "pali": "“Manena kusalaṁ kammaṁ,"
    },
    {
      "id": "pe3:49.2",
      "pali": "manasā saṁvuto bhave;"
    },
    {
      "id": "pe3:49.3",
      "pali": "Manoduccaritaṁ hitvā,"
    },
    {
      "id": "pe3:49.4",
      "pali": "manasā sucaritaṁ care”."
    },
    {
      "id": "pe3:50.1",
      "pali": "Tīṇimāni manosucaritāni, anabhijjhā, abyāpādo, sammādiṭṭhi, idaṁ manokammādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:50.2",
      "pali": "Imāni asādhāraṇāni suttāni."
    },
    {
      "id": "pe3:51.1",
      "pali": "Tattha katamāni sādhāraṇāni suttāni?"
    },
    {
      "id": "pe3:52.1",
      "pali": "“Vācānurakkhī manasā susaṁvuto,"
    },
    {
      "id": "pe3:52.2",
      "pali": "Kāyena ca nākusalaṁ kayirā;"
    },
    {
      "id": "pe3:52.3",
      "pali": "Ete tayo kammapathe visodhaye,"
    },
    {
      "id": "pe3:52.4",
      "pali": "Ārādhaye maggamisippaveditaṁ”."
    },
    {
      "id": "pe3:53.1",
      "pali": "Tisso imā, bhikkhave, pārisuddhiyo—"
    },
    {
      "id": "pe3:53.2",
      "pali": "kāyakammapārisuddhi, vācākammapārisuddhi, manokammapārisuddhi."
    },
    {
      "id": "pe3:54.1",
      "pali": "Tattha katamā kāyakammapārisuddhi?"
    },
    {
      "id": "pe3:54.2",
      "pali": "Pāṇātipātā veramaṇī, adinnādānā veramaṇī, kāmesumicchācārā veramaṇī."
    },
    {
      "id": "pe3:54.3",
      "pali": "Tattha katamā vacīkammapārisuddhi?"
    },
    {
      "id": "pe3:54.4",
      "pali": "Musāvādā veramaṇī …pe…"
    },
    {
      "id": "pe3:54.5",
      "pali": "samphappalāpā veramaṇī."
    },
    {
      "id": "pe3:54.6",
      "pali": "Tattha katamā manokammapārisuddhi?"
    },
    {
      "id": "pe3:54.7",
      "pali": "Anabhijjhā abyāpādo sammādiṭṭhi."
    },
    {
      "id": "pe3:54.8",
      "pali": "Idaṁ sādhāraṇasuttaṁ."
    },
    {
      "id": "pe3:55.1",
      "pali": "Iti sādhāraṇāni ca suttāni asādhāraṇāni ca suttāni paṭivijjhitabbāni."
    },
    {
      "id": "pe3:55.2",
      "pali": "Paṭivijjhitvā vācāya kāyena ca suttassa attho niddisitabbo."
    },
    {
      "id": "pe3:56.1",
      "pali": "Tattha katamaṁ saddhindriyādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:57.1",
      "pali": "“Yassa saddhā tathāgate,"
    },
    {
      "id": "pe3:57.2",
      "pali": "acalā suppatiṭṭhitā;"
    },
    {
      "id": "pe3:57.3",
      "pali": "Sīlañca yassa kalyāṇaṁ,"
    },
    {
      "id": "pe3:57.4",
      "pali": "ariyakantaṁ pasaṁsitaṁ."
    },
    {
      "id": "pe3:58.1",
      "pali": "Saṅghe pasādo yassatthi,"
    },
    {
      "id": "pe3:58.2",
      "pali": "ujubhūtañca dassanaṁ;"
    },
    {
      "id": "pe3:58.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "pe3:58.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "pe3:59.1",
      "pali": "Saddhā ve nandikā ārādhiko,"
    },
    {
      "id": "pe3:59.2",
      "pali": "No tassa saddhoti;"
    },
    {
      "id": "pe3:59.3",
      "pali": "Sabbaṁ siyāti bhagavantaṁ,"
    },
    {
      "id": "pe3:59.4",
      "pali": "Tathārūpo dhammasampasādo”."
    },
    {
      "id": "pe3:60.1",
      "pali": "Idaṁ saddhindriyādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:61.1",
      "pali": "Tattha katamaṁ vīriyādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:62.1",
      "pali": "“Ārambhatha nikkamatha,"
    },
    {
      "id": "pe3:62.2",
      "pali": "yuñjatha buddhasāsane;"
    },
    {
      "id": "pe3:62.3",
      "pali": "Dhunātha maccuno senaṁ,"
    },
    {
      "id": "pe3:62.4",
      "pali": "naḷāgāraṁva kuñjaro”."
    },
    {
      "id": "pe3:63.1",
      "pali": "Cattārome, bhikkhave, sammappadhānā, idaṁ vīriyādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:64.1",
      "pali": "Tattha katamaṁ satindriyādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:65.1",
      "pali": "“Satīmato sadā bhaddaṁ,"
    },
    {
      "id": "pe3:65.2",
      "pali": "bhaddamatthu satīmato;"
    },
    {
      "id": "pe3:65.3",
      "pali": "Satīmato sadā seyyo,"
    },
    {
      "id": "pe3:65.4",
      "pali": "satīmā sukhamedhati”."
    },
    {
      "id": "pe3:66.1",
      "pali": "Cattāro satipaṭṭhānā vitthārena kātabbā, idaṁ satindriyādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:67.1",
      "pali": "Tattha katamaṁ samādhindriyādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:68.1",
      "pali": "“Ākaṅkhato te naradammasārathi,"
    },
    {
      "id": "pe3:68.2",
      "pali": "Devā manussā manasā vicintitaṁ;"
    },
    {
      "id": "pe3:68.3",
      "pali": "Sabbe na jaññā kasiṇāpi pāṇino,"
    },
    {
      "id": "pe3:68.4",
      "pali": "Santaṁ samādhiṁ araṇaṁ nisevato”."
    },
    {
      "id": "pe3:69.1",
      "pali": "Tayome, bhikkhave, samādhī—"
    },
    {
      "id": "pe3:69.2",
      "pali": "savitakko savicāro, avitakko vicāramatto, avitakko avicāro."
    },
    {
      "id": "pe3:69.3",
      "pali": "Idaṁ samādhindriyādhiṭṭhānaṁ."
    },
    {
      "id": "pe3:70.1",
      "pali": "Tattha katamaṁ paññindriyādhiṭṭhānaṁ?"
    },
    {
      "id": "pe3:71.1",
      "pali": "Paññā hi seṭṭhā lokasminti vitthārena."
    },
    {
      "id": "pe3:72.1",
      "pali": "Tisso imā, bhikkhave, paññā—"
    },
    {
      "id": "pe3:72.2",
      "pali": "sutamayī, cintāmayī, bhāvanāmayī, idaṁ paññindriyādhiṭṭhānaṁ suttaṁ, imāni indriyādhiṭṭhānāni asādhāraṇāni suttāni."
    },
    {
      "id": "pe3:73.1",
      "pali": "Tattha katamāni sādhāraṇāni indriyādhiṭṭhānāni suttāni?"
    },
    {
      "id": "pe3:74.1",
      "pali": "“Avītarāgo kāmesu,"
    },
    {
      "id": "pe3:74.2",
      "pali": "yassa pañcindriyā mudū;"
    },
    {
      "id": "pe3:74.3",
      "pali": "Saddhā sati ca vīriyaṁ,"
    },
    {
      "id": "pe3:74.4",
      "pali": "samatho ca vipassanā;"
    },
    {
      "id": "pe3:74.5",
      "pali": "Tādisaṁ bhikkhumāsajja,"
    },
    {
      "id": "pe3:74.6",
      "pali": "pubbeva upahaññati”."
    },
    {
      "id": "pe3:75.1",
      "pali": "Pañcimāni indriyāni."
    },
    {
      "id": "pe3:75.2",
      "pali": "Saddhindriyādiindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "pe3:75.3",
      "pali": "Tīsu aveccappasāde vitthārena suttaṁ kātabbaṁ."
    },
    {
      "id": "pe3:75.4",
      "pali": "Imāni sādhāraṇāni indriyādhiṭṭhānāni suttāni."
    },
    {
      "id": "pe3:75.5",
      "pali": "Yaṁ yassa sambandhaṁ kusalassa vā akusalassa vā tena tena adhiṭṭhānena taṁ suttaṁ niddisitabbaṁ, natthañño dhammo niddisitabbo."
    },
    {
      "id": "pe3:75.6",
      "pali": "Tattha sādhāraṇaṁ kusalaṁ nāpi kusalaṁ akusalaṁ yathā sādhāraṇāni ca kusalamūlāni sādhāraṇāni ca akusalamūlāni uppannaṁ kāmavitakkaṁ pajahati …pe…"
    },
    {
      "id": "pe3:75.7",
      "pali": "cattāro sammappadhānā kusalaṁ akusalañca."
    },
    {
      "id": "pe3:76.1",
      "pali": "Tatthimā uddānagāthā"
    },
    {
      "id": "pe3:77.1",
      "pali": "Vitakko hi mamatthiko,"
    },
    {
      "id": "pe3:77.2",
      "pali": "dadaṁ piyo naro iti;"
    },
    {
      "id": "pe3:77.3",
      "pali": "Yo pāṇamatipāteti,"
    },
    {
      "id": "pe3:77.4",
      "pali": "tīṇi tassa bālalakkhaṇaṁ."
    },
    {
      "id": "pe3:78.1",
      "pali": "Satañceva sahassānaṁ,"
    },
    {
      "id": "pe3:78.2",
      "pali": "ye ca samaṇabrāhmaṇā;"
    },
    {
      "id": "pe3:78.3",
      "pali": "Chandā dosā bhayā mohā,"
    },
    {
      "id": "pe3:78.4",
      "pali": "catūhi agatīhi ca."
    },
    {
      "id": "pe3:79.1",
      "pali": "Asubhānupassiṁ viharantaṁ,"
    },
    {
      "id": "pe3:79.2",
      "pali": "Nimittesu asubhā ca;"
    },
    {
      "id": "pe3:79.3",
      "pali": "Ekampi ce piyaṁ pāṇaṁ,"
    },
    {
      "id": "pe3:79.4",
      "pali": "Mittā sace subhāsitā."
    },
    {
      "id": "pe3:80.1",
      "pali": "Paññā hi seṭṭhā lokasmiṁ,"
    },
    {
      "id": "pe3:80.2",
      "pali": "Anuññā tīṇi indriyāni;"
    },
    {
      "id": "pe3:80.3",
      "pali": "Kusalākusalamūlāni ca,"
    },
    {
      "id": "pe3:80.4",
      "pali": "Tulamatulañca sambhavaṁ."
    },
    {
      "id": "pe3:81.1",
      "pali": "Kāyena kusalaṁ kare,"
    },
    {
      "id": "pe3:81.2",
      "pali": "Tīṇi sucaritāni ca;"
    },
    {
      "id": "pe3:81.3",
      "pali": "Subhāsitaṁ uttamamāhu,"
    },
    {
      "id": "pe3:81.4",
      "pali": "Santo vacīsucaritāni ca."
    },
    {
      "id": "pe3:82.1",
      "pali": "Kāyena ca kusalaṁ kayirā,"
    },
    {
      "id": "pe3:82.2",
      "pali": "Manoduccaritāni ca;"
    },
    {
      "id": "pe3:82.3",
      "pali": "Kāyānurakkhī ca sadā,"
    },
    {
      "id": "pe3:82.4",
      "pali": "Tisso ca pārisuddhiyo."
    },
    {
      "id": "pe3:83.1",
      "pali": "Yassa saddhā tathāgate,"
    },
    {
      "id": "pe3:83.2",
      "pali": "samuppāde ca desito;"
    },
    {
      "id": "pe3:83.3",
      "pali": "Ārambhatha nikkamatha,"
    },
    {
      "id": "pe3:83.4",
      "pali": "yā ca sammappadhānatā."
    },
    {
      "id": "pe3:84.1",
      "pali": "Satīmato sadā bhaddaṁ,"
    },
    {
      "id": "pe3:84.2",
      "pali": "satipaṭṭhānabhāvanā;"
    },
    {
      "id": "pe3:84.3",
      "pali": "Ākaṅkhato ca anaññāṇaṁ,"
    },
    {
      "id": "pe3:84.4",
      "pali": "ye ca tīṇi samādhayo."
    },
    {
      "id": "pe3:85.1",
      "pali": "Paññā hi seṭṭhā lokasmiṁ,"
    },
    {
      "id": "pe3:85.2",
      "pali": "tisso paññā pakāsitā;"
    },
    {
      "id": "pe3:85.3",
      "pali": "Avītarāgo kāmesu,"
    },
    {
      "id": "pe3:85.4",
      "pali": "tatheva pañcindriyā."
    },
    {
      "id": "pe3:86.1",
      "pali": "Iti therassa mahākaccāyanassa jambuvanavāsino peṭakopadese tatiyabhūmi suttādhiṭṭhānaṁ nāma."
    }
  ]
}
