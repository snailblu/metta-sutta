{
  "uid": "ja404",
  "title": "Kukkuvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja404:1.1",
      "pali": "“Yattha verī nivasati,"
    },
    {
      "id": "ja404:1.2",
      "pali": "na vase tattha paṇḍito;"
    },
    {
      "id": "ja404:1.3",
      "pali": "Ekarattaṁ dirattaṁ vā,"
    },
    {
      "id": "ja404:1.4",
      "pali": "dukkhaṁ vasati verisu."
    },
    {
      "id": "ja404:2.1",
      "pali": "Diso ve lahucittassa,"
    },
    {
      "id": "ja404:2.2",
      "pali": "posassānuvidhīyato;"
    },
    {
      "id": "ja404:2.3",
      "pali": "Ekassa kapino hetu,"
    },
    {
      "id": "ja404:2.4",
      "pali": "yūthassa anayo kato."
    },
    {
      "id": "ja404:3.1",
      "pali": "Bālova paṇḍitamānī,"
    },
    {
      "id": "ja404:3.2",
      "pali": "yūthassa parihārako;"
    },
    {
      "id": "ja404:3.3",
      "pali": "Sacittassa vasaṁ gantvā,"
    },
    {
      "id": "ja404:3.4",
      "pali": "sayethāyaṁ yathā kapi."
    },
    {
      "id": "ja404:4.1",
      "pali": "Na sādhu balavā bālo,"
    },
    {
      "id": "ja404:4.2",
      "pali": "yūthassa parihārako;"
    },
    {
      "id": "ja404:4.3",
      "pali": "Ahito bhavati ñātīnaṁ,"
    },
    {
      "id": "ja404:4.4",
      "pali": "sakuṇānaṁva cetako."
    },
    {
      "id": "ja404:5.1",
      "pali": "Dhīrova balavā sādhu,"
    },
    {
      "id": "ja404:5.2",
      "pali": "yūthassa parihārako;"
    },
    {
      "id": "ja404:5.3",
      "pali": "Hito bhavati ñātīnaṁ,"
    },
    {
      "id": "ja404:5.4",
      "pali": "tidasānaṁva vāsavo."
    },
    {
      "id": "ja404:6.1",
      "pali": "Yo ca sīlañca paññañca,"
    },
    {
      "id": "ja404:6.2",
      "pali": "sutañcattani passati;"
    },
    {
      "id": "ja404:6.3",
      "pali": "Ubhinnamatthaṁ carati,"
    },
    {
      "id": "ja404:6.4",
      "pali": "attano ca parassa ca."
    },
    {
      "id": "ja404:7.1",
      "pali": "Tasmā tuleyya mattānaṁ,"
    },
    {
      "id": "ja404:7.2",
      "pali": "sīlapaññāsutāmiva;"
    },
    {
      "id": "ja404:7.3",
      "pali": "Gaṇaṁ vā parihare dhīro,"
    },
    {
      "id": "ja404:7.4",
      "pali": "eko vāpi paribbaje”ti."
    },
    {
      "id": "ja404:8.1",
      "pali": "Kapijātakaṁ navamaṁ."
    }
  ]
}
