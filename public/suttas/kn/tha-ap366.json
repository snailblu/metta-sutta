{
  "uid": "tha-ap366",
  "title": "Kesarapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap366:1.1",
      "pali": "“Vijjādharo tadā āsiṁ,"
    },
    {
      "id": "tha-ap366:1.2",
      "pali": "himavantamhi pabbate;"
    },
    {
      "id": "tha-ap366:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap366:1.4",
      "pali": "caṅkamantaṁ mahāyasaṁ."
    },
    {
      "id": "tha-ap366:2.1",
      "pali": "Tīṇi kesarapupphāni,"
    },
    {
      "id": "tha-ap366:2.2",
      "pali": "sīse katvānahaṁ tadā;"
    },
    {
      "id": "tha-ap366:2.3",
      "pali": "Upasaṅkamma sambuddhaṁ,"
    },
    {
      "id": "tha-ap366:2.4",
      "pali": "vessabhuṁ abhipūjayiṁ."
    },
    {
      "id": "tha-ap366:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap366:3.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap366:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap366:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap366:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap366:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap366:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap366:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kesarapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap366:6.1",
      "pali": "Kesarapupphiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
