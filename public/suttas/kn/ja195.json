{
  "uid": "ja195",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja195:1.1",
      "pali": "“Pabbatūpatthare ramme,"
    },
    {
      "id": "ja195:1.2",
      "pali": "jātā pokkharaṇī sivā;"
    },
    {
      "id": "ja195:1.3",
      "pali": "Taṁ siṅgālo apāpāyi,"
    },
    {
      "id": "ja195:1.4",
      "pali": "jānaṁ sīhena rakkhitaṁ”."
    },
    {
      "id": "ja195:2.1",
      "pali": "“Pivanti ce mahārāja,"
    },
    {
      "id": "ja195:2.2",
      "pali": "sāpadāni mahānadiṁ;"
    },
    {
      "id": "ja195:2.3",
      "pali": "Na tena anadī hoti,"
    },
    {
      "id": "ja195:2.4",
      "pali": "khamassu yadi te piyā”ti."
    },
    {
      "id": "ja195:3.1",
      "pali": "Pabbatūpattharajātakaṁ pañcamaṁ."
    }
  ]
}
