{
  "uid": "ja102",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja102:1.1",
      "pali": "“Yo dukkhaphuṭṭhāya bhaveyya tāṇaṁ,"
    },
    {
      "id": "ja102:1.2",
      "pali": "So me pitā dubbhi vane karoti;"
    },
    {
      "id": "ja102:1.3",
      "pali": "Sā kassa kandāmi vanassa majjhe,"
    },
    {
      "id": "ja102:1.4",
      "pali": "Yo tāyitā so sahasaṁ karotī”ti."
    },
    {
      "id": "ja102:2.1",
      "pali": "Paṇṇikajātakaṁ dutiyaṁ."
    }
  ]
}
