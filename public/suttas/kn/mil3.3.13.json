{
  "uid": "mil3.3.13",
  "title": "13. Vitakkalakkhaṇapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.3.13:1.1",
      "pali": "“Bhante nāgasena, kiṁlakkhaṇo vitakko”ti?"
    },
    {
      "id": "mil3.3.13:1.2",
      "pali": "“Appanālakkhaṇo, mahārāja, vitakko”ti."
    },
    {
      "id": "mil3.3.13:2.1",
      "pali": "“Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.3.13:2.2",
      "pali": "“Yathā, mahārāja, vaḍḍhakī suparikammakataṁ dāruṁ sandhismiṁ appeti;"
    },
    {
      "id": "mil3.3.13:2.3",
      "pali": "evameva kho, mahārāja, appanālakkhaṇo vitakko”ti."
    },
    {
      "id": "mil3.3.13:3.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.3.13:4.1",
      "pali": "Vitakkalakkhaṇapañho terasamo."
    }
  ]
}
