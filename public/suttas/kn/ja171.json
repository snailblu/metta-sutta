{
  "uid": "ja171",
  "title": "Kalyāṇavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja171:1.1",
      "pali": "“Kalyāṇadhammoti yadā janinda,"
    },
    {
      "id": "ja171:1.2",
      "pali": "Loke samaññaṁ anupāpuṇāti;"
    },
    {
      "id": "ja171:1.3",
      "pali": "Tasmā na hiyyetha naro sapañño,"
    },
    {
      "id": "ja171:1.4",
      "pali": "Hiriyāpi santo dhuramādiyanti."
    },
    {
      "id": "ja171:2.1",
      "pali": "Sāyaṁ samaññā idha majja pattā,"
    },
    {
      "id": "ja171:2.2",
      "pali": "Kalyāṇadhammoti janinda loke;"
    },
    {
      "id": "ja171:2.3",
      "pali": "Tāhaṁ samekkhaṁ idha pabbajissaṁ,"
    },
    {
      "id": "ja171:2.4",
      "pali": "Na hi matthi chando idha kāmabhoge”ti."
    },
    {
      "id": "ja171:3.1",
      "pali": "Kalyāṇadhammajātakaṁ paṭhamaṁ."
    }
  ]
}
