{
  "uid": "ja8",
  "title": "Apaṇṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja8:1.1",
      "pali": "“Api ataramānānaṁ,"
    },
    {
      "id": "ja8:1.2",
      "pali": "phalāsāva samijjhati;"
    },
    {
      "id": "ja8:1.3",
      "pali": "Vipakkabrahmacariyosmi,"
    },
    {
      "id": "ja8:1.4",
      "pali": "evaṁ jānāhi gāmaṇī”ti."
    },
    {
      "id": "ja8:2.1",
      "pali": "Gāmaṇijātakaṁ aṭṭhamaṁ."
    }
  ]
}
