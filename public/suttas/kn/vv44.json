{
  "uid": "vv44",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv44:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv44:1.2",
      "pali": "…pe…"
    },
    {
      "id": "vv44:1.3",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv44:2.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv44:2.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv44:2.3",
      "pali": "Dibbā saddā niccharanti,"
    },
    {
      "id": "vv44:2.4",
      "pali": "savanīyā manoramā."
    },
    {
      "id": "vv44:3.1",
      "pali": "Tassā te naccamānāya,"
    },
    {
      "id": "vv44:3.2",
      "pali": "aṅgamaṅgehi sabbaso;"
    },
    {
      "id": "vv44:3.3",
      "pali": "Dibbā gandhā pavāyanti,"
    },
    {
      "id": "vv44:3.4",
      "pali": "sucigandhā manoramā."
    },
    {
      "id": "vv44:4.1",
      "pali": "Vivattamānā kāyena,"
    },
    {
      "id": "vv44:4.2",
      "pali": "yā veṇīsu piḷandhanā;"
    },
    {
      "id": "vv44:4.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv44:4.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv44:5.1",
      "pali": "Vaṭaṁsakā vātadhutā,"
    },
    {
      "id": "vv44:5.2",
      "pali": "vātena sampakampitā;"
    },
    {
      "id": "vv44:5.3",
      "pali": "Tesaṁ suyyati nigghoso,"
    },
    {
      "id": "vv44:5.4",
      "pali": "tūriye pañcaṅgike yathā."
    },
    {
      "id": "vv44:6.1",
      "pali": "Yāpi te sirasmiṁ mālā,"
    },
    {
      "id": "vv44:6.2",
      "pali": "sucigandhā manoramā;"
    },
    {
      "id": "vv44:6.3",
      "pali": "Vāti gandho disā sabbā,"
    },
    {
      "id": "vv44:6.4",
      "pali": "rukkho mañjūsako yathā."
    },
    {
      "id": "vv44:7.1",
      "pali": "Ghāyase taṁ sucigandhaṁ,"
    },
    {
      "id": "vv44:7.2",
      "pali": "rūpaṁ passasi amānusaṁ;"
    },
    {
      "id": "vv44:7.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv44:7.4",
      "pali": "kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv44:8.1",
      "pali": "“Sāvatthiyaṁ mayhaṁ sakhī bhadante,"
    },
    {
      "id": "vv44:8.2",
      "pali": "Saṅghassa kāresi mahāvihāraṁ;"
    },
    {
      "id": "vv44:8.3",
      "pali": "Tatthappasannā ahamānumodiṁ,"
    },
    {
      "id": "vv44:8.4",
      "pali": "Disvā agārañca piyañca metaṁ."
    },
    {
      "id": "vv44:9.1",
      "pali": "Tāyeva me suddhanumodanāya,"
    },
    {
      "id": "vv44:9.2",
      "pali": "Laddhaṁ vimānabbhutadassaneyyaṁ;"
    },
    {
      "id": "vv44:9.3",
      "pali": "Samantato soḷasayojanāni,"
    },
    {
      "id": "vv44:9.4",
      "pali": "Vehāyasaṁ gacchati iddhiyā mama."
    },
    {
      "id": "vv44:10.1",
      "pali": "Kūṭāgārā nivesā me,"
    },
    {
      "id": "vv44:10.2",
      "pali": "vibhattā bhāgaso mitā;"
    },
    {
      "id": "vv44:10.3",
      "pali": "Daddallamānā ābhanti,"
    },
    {
      "id": "vv44:10.4",
      "pali": "samantā satayojanaṁ."
    },
    {
      "id": "vv44:11.1",
      "pali": "Pokkharañño ca me ettha,"
    },
    {
      "id": "vv44:11.2",
      "pali": "puthulomanisevitā;"
    },
    {
      "id": "vv44:11.3",
      "pali": "Acchodakā vippasannā,"
    },
    {
      "id": "vv44:11.4",
      "pali": "soṇṇavālukasanthatā."
    },
    {
      "id": "vv44:12.1",
      "pali": "Nānāpadumasañchannā,"
    },
    {
      "id": "vv44:12.2",
      "pali": "puṇḍarīkasamotatā;"
    },
    {
      "id": "vv44:12.3",
      "pali": "Surabhī sampavāyanti,"
    },
    {
      "id": "vv44:12.4",
      "pali": "manuññā māluteritā."
    },
    {
      "id": "vv44:13.1",
      "pali": "Jambuyo panasā tālā,"
    },
    {
      "id": "vv44:13.2",
      "pali": "nāḷikeravanāni ca;"
    },
    {
      "id": "vv44:13.3",
      "pali": "Antonivesane jātā,"
    },
    {
      "id": "vv44:13.4",
      "pali": "nānārukkhā aropimā."
    },
    {
      "id": "vv44:14.1",
      "pali": "Nānātūriyasaṅghuṭṭhaṁ,"
    },
    {
      "id": "vv44:14.2",
      "pali": "accharāgaṇaghositaṁ;"
    },
    {
      "id": "vv44:14.3",
      "pali": "Yopi maṁ supine passe,"
    },
    {
      "id": "vv44:14.4",
      "pali": "sopi vitto siyā naro."
    },
    {
      "id": "vv44:15.1",
      "pali": "Etādisaṁ abbhutadassaneyyaṁ,"
    },
    {
      "id": "vv44:15.2",
      "pali": "Vimānaṁ sabbasopabhaṁ;"
    },
    {
      "id": "vv44:15.3",
      "pali": "Mama kammehi nibbattaṁ,"
    },
    {
      "id": "vv44:15.4",
      "pali": "Alaṁ puññāni kātave”ti."
    },
    {
      "id": "vv44:16.1",
      "pali": "“Tāyeva te suddhanumodanāya,"
    },
    {
      "id": "vv44:16.2",
      "pali": "Laddhaṁ vimānabbhutadassaneyyaṁ;"
    },
    {
      "id": "vv44:16.3",
      "pali": "Yā ceva sā dānamadāsi nārī,"
    },
    {
      "id": "vv44:16.4",
      "pali": "Tassā gatiṁ brūhi kuhiṁ uppannā sā”ti."
    },
    {
      "id": "vv44:17.1",
      "pali": "“Yā sā ahu mayhaṁ sakhī bhadante,"
    },
    {
      "id": "vv44:17.2",
      "pali": "Saṅghassa kāresi mahāvihāraṁ;"
    },
    {
      "id": "vv44:17.3",
      "pali": "Viññātadhammā sā adāsi dānaṁ,"
    },
    {
      "id": "vv44:17.4",
      "pali": "Uppannā nimmānaratīsu devesu."
    },
    {
      "id": "vv44:18.1",
      "pali": "Pajāpatī tassa sunimmitassa,"
    },
    {
      "id": "vv44:18.2",
      "pali": "Acintiyā kammavipākā tassā;"
    },
    {
      "id": "vv44:18.3",
      "pali": "Yametaṁ pucchasi kuhiṁ uppannā sāti,"
    },
    {
      "id": "vv44:18.4",
      "pali": "Taṁ te viyākāsiṁ anaññathā ahaṁ."
    },
    {
      "id": "vv44:19.1",
      "pali": "Tenahaññepi samādapetha,"
    },
    {
      "id": "vv44:19.2",
      "pali": "Saṅghassa dānāni dadātha vittā;"
    },
    {
      "id": "vv44:19.3",
      "pali": "Dhammañca suṇātha pasannamānasā,"
    },
    {
      "id": "vv44:19.4",
      "pali": "Sudullabho laddho manussalābho."
    },
    {
      "id": "vv44:20.1",
      "pali": "Yaṁ maggaṁ maggādhipatī adesayi,"
    },
    {
      "id": "vv44:20.2",
      "pali": "Brahmassaro kañcanasannibhattaco;"
    },
    {
      "id": "vv44:20.3",
      "pali": "Saṅghassa dānāni dadātha vittā,"
    },
    {
      "id": "vv44:20.4",
      "pali": "Mahapphalā yattha bhavanti dakkhiṇā."
    },
    {
      "id": "vv44:21.1",
      "pali": "Ye puggalā aṭṭha sataṁ pasatthā,"
    },
    {
      "id": "vv44:21.2",
      "pali": "Cattāri etāni yugāni honti;"
    },
    {
      "id": "vv44:21.3",
      "pali": "Te dakkhiṇeyyā sugatassa sāvakā,"
    },
    {
      "id": "vv44:21.4",
      "pali": "Etesu dinnāni mahapphalāni."
    },
    {
      "id": "vv44:22.1",
      "pali": "Cattāro ca paṭipannā,"
    },
    {
      "id": "vv44:22.2",
      "pali": "cattāro ca phale ṭhitā;"
    },
    {
      "id": "vv44:22.3",
      "pali": "Esa saṅgho ujubhūto,"
    },
    {
      "id": "vv44:22.4",
      "pali": "paññāsīlasamāhito."
    },
    {
      "id": "vv44:23.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "vv44:23.2",
      "pali": "puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "vv44:23.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "vv44:23.4",
      "pali": "saṅghe dinnaṁ mahapphalaṁ."
    },
    {
      "id": "vv44:24.1",
      "pali": "Eso hi saṅgho vipulo mahaggato,"
    },
    {
      "id": "vv44:24.2",
      "pali": "Esappameyyo udadhīva sāgaro;"
    },
    {
      "id": "vv44:24.3",
      "pali": "Etehi seṭṭhā naravīrasāvakā,"
    },
    {
      "id": "vv44:24.4",
      "pali": "Pabhaṅkarā dhammamudīrayanti."
    },
    {
      "id": "vv44:25.1",
      "pali": "Tesaṁ sudinnaṁ suhutaṁ suyiṭṭhaṁ,"
    },
    {
      "id": "vv44:25.2",
      "pali": "Ye saṅghamuddissa dadanti dānaṁ;"
    },
    {
      "id": "vv44:25.3",
      "pali": "Sā dakkhiṇā saṅghagatā patiṭṭhitā,"
    },
    {
      "id": "vv44:25.4",
      "pali": "Mahapphalā lokavidūna vaṇṇitā."
    },
    {
      "id": "vv44:26.1",
      "pali": "Etādisaṁ yaññamanussarantā,"
    },
    {
      "id": "vv44:26.2",
      "pali": "Ye vedajātā vicaranti loke;"
    },
    {
      "id": "vv44:26.3",
      "pali": "Vineyya maccheramalaṁ samūlaṁ,"
    },
    {
      "id": "vv44:26.4",
      "pali": "Aninditā saggamupenti ṭhānan”ti."
    },
    {
      "id": "vv44:27.1",
      "pali": "Vihāravimānaṁ chaṭṭhaṁ."
    },
    {
      "id": "vv44:27.2",
      "pali": "Bhāṇavāraṁ dutiyaṁ."
    }
  ]
}
