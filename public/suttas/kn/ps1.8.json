{
  "uid": "ps1.8",
  "title": "1.8. Vipallāsakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps1.8:1.1",
      "pali": "Purimanidānaṁ."
    },
    {
      "id": "ps1.8:1.2",
      "pali": "“Cattārome, bhikkhave, saññāvipallāsā cittavipallāsā diṭṭhivipallāsā."
    },
    {
      "id": "ps1.8:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "ps1.8:1.4",
      "pali": "Anicce, bhikkhave, niccanti saññāvipallāso cittavipallāso diṭṭhivipallāso."
    },
    {
      "id": "ps1.8:1.5",
      "pali": "Dukkhe, bhikkhave, sukhanti saññāvipallāso cittavipallāso diṭṭhivipallāso."
    },
    {
      "id": "ps1.8:1.6",
      "pali": "Anattani, bhikkhave, attāti saññāvipallāso cittavipallāso diṭṭhivipallāso."
    },
    {
      "id": "ps1.8:1.7",
      "pali": "Asubhe, bhikkhave, subhanti saññāvipallāso cittavipallāso diṭṭhivipallāso."
    },
    {
      "id": "ps1.8:1.8",
      "pali": "Ime kho, bhikkhave, cattāro saññāvipallāsā cittavipallāsā diṭṭhivipallāsā."
    },
    {
      "id": "ps1.8:2.1",
      "pali": "Cattārome, bhikkhave, nasaññāvipallāsā nacittavipallāsā nadiṭṭhivipallāsā."
    },
    {
      "id": "ps1.8:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "ps1.8:2.3",
      "pali": "Anicce, bhikkhave, aniccanti nasaññāvipallāso nacittavipallāso nadiṭṭhivipallāso."
    },
    {
      "id": "ps1.8:2.4",
      "pali": "Dukkhe, bhikkhave, dukkhanti nasaññāvipallāso nacittavipallāso nadiṭṭhivipallāso."
    },
    {
      "id": "ps1.8:2.5",
      "pali": "Anattani, bhikkhave, anattāti nasaññāvipallāso nacittavipallāso nadiṭṭhivipallāso."
    },
    {
      "id": "ps1.8:2.6",
      "pali": "Asubhe, bhikkhave, asubhanti nasaññāvipallāso nacittavipallāso nadiṭṭhivipallāso."
    },
    {
      "id": "ps1.8:2.7",
      "pali": "Ime kho, bhikkhave, cattāro nasaññāvipallāsā nacittavipallāsā nadiṭṭhivipallāsā”ti."
    },
    {
      "id": "ps1.8:3.1",
      "pali": "“Anicce niccasaññino,"
    },
    {
      "id": "ps1.8:3.2",
      "pali": "dukkhe ca sukhasaññino;"
    },
    {
      "id": "ps1.8:3.3",
      "pali": "Anattani ca attāti,"
    },
    {
      "id": "ps1.8:3.4",
      "pali": "asubhe subhasaññino;"
    },
    {
      "id": "ps1.8:3.5",
      "pali": "Micchādiṭṭhihatā sattā,"
    },
    {
      "id": "ps1.8:3.6",
      "pali": "khittacittā visaññino."
    },
    {
      "id": "ps1.8:4.1",
      "pali": "Te yogayuttā mārassa,"
    },
    {
      "id": "ps1.8:4.2",
      "pali": "ayogakkhemino janā;"
    },
    {
      "id": "ps1.8:4.3",
      "pali": "Sattā gacchanti saṁsāraṁ,"
    },
    {
      "id": "ps1.8:4.4",
      "pali": "jātimaraṇagāmino."
    },
    {
      "id": "ps1.8:5.1",
      "pali": "Yadā ca buddhā lokasmiṁ,"
    },
    {
      "id": "ps1.8:5.2",
      "pali": "uppajjanti pabhaṅkarā;"
    },
    {
      "id": "ps1.8:5.3",
      "pali": "Te imaṁ dhammaṁ pakāsenti,"
    },
    {
      "id": "ps1.8:5.4",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "ps1.8:6.1",
      "pali": "Tesaṁ sutvāna sappaññā,"
    },
    {
      "id": "ps1.8:6.2",
      "pali": "sacittaṁ paccaladdhu te;"
    },
    {
      "id": "ps1.8:6.3",
      "pali": "Aniccaṁ aniccato dakkhuṁ,"
    },
    {
      "id": "ps1.8:6.4",
      "pali": "dukkhamaddakkhu dukkhato."
    },
    {
      "id": "ps1.8:7.1",
      "pali": "Anattani anattāti,"
    },
    {
      "id": "ps1.8:7.2",
      "pali": "asubhaṁ asubhataddasuṁ;"
    },
    {
      "id": "ps1.8:7.3",
      "pali": "Sammādiṭṭhisamādānā,"
    },
    {
      "id": "ps1.8:7.4",
      "pali": "sabbaṁ dukkhaṁ upaccagun”ti."
    },
    {
      "id": "ps1.8:8.1",
      "pali": "Ime cattāro vipallāsā diṭṭhisampannassa puggalassa pahīnā, appahīnāti."
    },
    {
      "id": "ps1.8:8.2",
      "pali": "Keci pahīnā, keci appahīnā?"
    },
    {
      "id": "ps1.8:8.3",
      "pali": "Anicce niccanti saññāvipallāso cittavipallāso diṭṭhivipallāso pahīno."
    },
    {
      "id": "ps1.8:8.4",
      "pali": "Dukkhe sukhanti saññā uppajjati, cittaṁ uppajjati, diṭṭhivipallāso pahīno."
    },
    {
      "id": "ps1.8:8.5",
      "pali": "Anattani attāti saññāvipallāso cittavipallāso diṭṭhivipallāso pahīno."
    },
    {
      "id": "ps1.8:8.6",
      "pali": "Asubhe subhanti saññā uppajjati, cittaṁ uppajjati, diṭṭhivipallāso pahīno."
    },
    {
      "id": "ps1.8:8.7",
      "pali": "Dvīsu vatthūsu cha vipallāsā pahīnā."
    },
    {
      "id": "ps1.8:8.8",
      "pali": "Dvīsu vatthūsu dve vipallāsā pahīnā, cattāro vipallāsā appahīnā."
    },
    {
      "id": "ps1.8:8.9",
      "pali": "Catūsu vatthūsu aṭṭha vipallāsā pahīnā, cattāro vipallāsā appahīnāti."
    },
    {
      "id": "ps1.8:8.10",
      "pali": "Vipallāsakathā niṭṭhitā."
    }
  ]
}
