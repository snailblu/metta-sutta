{
  "uid": "bv24",
  "title": "24. Kakusandhabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv24:1.1",
      "pali": "“Vessabhussa aparena,"
    },
    {
      "id": "bv24:1.2",
      "pali": "sambuddho dvipaduttamo;"
    },
    {
      "id": "bv24:1.3",
      "pali": "Kakusandho nāma nāmena,"
    },
    {
      "id": "bv24:1.4",
      "pali": "appameyyo durāsado."
    },
    {
      "id": "bv24:2.1",
      "pali": "Ugghāṭetvā sabbabhavaṁ,"
    },
    {
      "id": "bv24:2.2",
      "pali": "cariyāya pāramiṁ gato;"
    },
    {
      "id": "bv24:2.3",
      "pali": "Sīhova pañjaraṁ bhetvā,"
    },
    {
      "id": "bv24:2.4",
      "pali": "patto sambodhimuttamaṁ."
    },
    {
      "id": "bv24:3.1",
      "pali": "Dhammacakkaṁ pavattente,"
    },
    {
      "id": "bv24:3.2",
      "pali": "Kakusandhe lokanāyake;"
    },
    {
      "id": "bv24:3.3",
      "pali": "Cattārīsakoṭisahassānaṁ,"
    },
    {
      "id": "bv24:3.4",
      "pali": "Dhammābhisamayo ahu."
    },
    {
      "id": "bv24:4.1",
      "pali": "Antalikkhamhi ākāse,"
    },
    {
      "id": "bv24:4.2",
      "pali": "yamakaṁ katvā vikubbanaṁ;"
    },
    {
      "id": "bv24:4.3",
      "pali": "Tiṁsakoṭisahassānaṁ,"
    },
    {
      "id": "bv24:4.4",
      "pali": "bodhesi devamānuse."
    },
    {
      "id": "bv24:5.1",
      "pali": "Naradevassa yakkhassa,"
    },
    {
      "id": "bv24:5.2",
      "pali": "catusaccappakāsane;"
    },
    {
      "id": "bv24:5.3",
      "pali": "Dhammābhisamayo tassa,"
    },
    {
      "id": "bv24:5.4",
      "pali": "gaṇanāto asaṅkhiyo."
    },
    {
      "id": "bv24:6.1",
      "pali": "Kakusandhassa bhagavato,"
    },
    {
      "id": "bv24:6.2",
      "pali": "eko āsi samāgamo;"
    },
    {
      "id": "bv24:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv24:6.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv24:7.1",
      "pali": "Cattālīsasahassānaṁ,"
    },
    {
      "id": "bv24:7.2",
      "pali": "tadā āsi samāgamo;"
    },
    {
      "id": "bv24:7.3",
      "pali": "Dantabhūmimanuppattānaṁ,"
    },
    {
      "id": "bv24:7.4",
      "pali": "āsavārigaṇakkhayā."
    },
    {
      "id": "bv24:8.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv24:8.2",
      "pali": "khemo nāmāsi khattiyo;"
    },
    {
      "id": "bv24:8.3",
      "pali": "Tathāgate jinaputte,"
    },
    {
      "id": "bv24:8.4",
      "pali": "dānaṁ datvā anappakaṁ."
    },
    {
      "id": "bv24:9.1",
      "pali": "Pattañca cīvaraṁ datvā,"
    },
    {
      "id": "bv24:9.2",
      "pali": "añjanaṁ madhulaṭṭhikaṁ;"
    },
    {
      "id": "bv24:9.3",
      "pali": "Imetaṁ patthitaṁ sabbaṁ,"
    },
    {
      "id": "bv24:9.4",
      "pali": "paṭiyādemi varaṁ varaṁ."
    },
    {
      "id": "bv24:10.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv24:10.2",
      "pali": "kakusandho vināyako;"
    },
    {
      "id": "bv24:10.3",
      "pali": "‘Imamhi bhaddake kappe,"
    },
    {
      "id": "bv24:10.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv24:11.1",
      "pali": "Ahu kapilavhayā rammā,"
    },
    {
      "id": "bv24:11.2",
      "pali": "…pe…"
    },
    {
      "id": "bv24:11.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv24:12.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv24:12.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv24:12.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv24:12.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv24:13.1",
      "pali": "Nagaraṁ khemāvatī nāma,"
    },
    {
      "id": "bv24:13.2",
      "pali": "khemo nāmāsahaṁ tadā;"
    },
    {
      "id": "bv24:13.3",
      "pali": "Sabbaññutaṁ gavesanto,"
    },
    {
      "id": "bv24:13.4",
      "pali": "pabbajiṁ tassa santike."
    },
    {
      "id": "bv24:14.1",
      "pali": "Brāhmaṇo aggidatto ca,"
    },
    {
      "id": "bv24:14.2",
      "pali": "āsi buddhassa so pitā;"
    },
    {
      "id": "bv24:14.3",
      "pali": "Visākhā nāma janikā,"
    },
    {
      "id": "bv24:14.4",
      "pali": "kakusandhassa satthuno."
    },
    {
      "id": "bv24:15.1",
      "pali": "Vasate tattha kheme pure,"
    },
    {
      "id": "bv24:15.2",
      "pali": "sambuddhassa mahākulaṁ;"
    },
    {
      "id": "bv24:15.3",
      "pali": "Narānaṁ pavaraṁ seṭṭhaṁ,"
    },
    {
      "id": "bv24:15.4",
      "pali": "jātimantaṁ mahāyasaṁ."
    },
    {
      "id": "bv24:16.1",
      "pali": "Catuvassasahassāni,"
    },
    {
      "id": "bv24:16.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv24:16.3",
      "pali": "Kāmakāmavaṇṇakāmasuddhināmā,"
    },
    {
      "id": "bv24:16.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv24:17.1",
      "pali": "Samattiṁsasahassāni,"
    },
    {
      "id": "bv24:17.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv24:17.3",
      "pali": "Rocinī nāma sā nārī,"
    },
    {
      "id": "bv24:17.4",
      "pali": "uttaro nāma atrajo."
    },
    {
      "id": "bv24:18.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv24:18.2",
      "pali": "rathayānena nikkhami;"
    },
    {
      "id": "bv24:18.3",
      "pali": "Anūnaaṭṭhamāsāni,"
    },
    {
      "id": "bv24:18.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv24:19.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv24:19.2",
      "pali": "kakusandho vināyako;"
    },
    {
      "id": "bv24:19.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv24:19.4",
      "pali": "migadāye naruttamo."
    },
    {
      "id": "bv24:20.1",
      "pali": "Vidhuro ca sañjīvo ca,"
    },
    {
      "id": "bv24:20.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv24:20.3",
      "pali": "Buddhijo nāmupaṭṭhāko,"
    },
    {
      "id": "bv24:20.4",
      "pali": "kakusandhassa satthuno."
    },
    {
      "id": "bv24:21.1",
      "pali": "Sāmā ca campānāmā ca,"
    },
    {
      "id": "bv24:21.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv24:21.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv24:21.4",
      "pali": "sirīsoti pavuccati."
    },
    {
      "id": "bv24:22.1",
      "pali": "Accuto ca sumano ca,"
    },
    {
      "id": "bv24:22.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv24:22.3",
      "pali": "Nandā ceva sunandā ca,"
    },
    {
      "id": "bv24:22.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv24:23.1",
      "pali": "Cattālīsaratanāni,"
    },
    {
      "id": "bv24:23.2",
      "pali": "accuggato mahāmuni;"
    },
    {
      "id": "bv24:23.3",
      "pali": "Kanakappabhā niccharati,"
    },
    {
      "id": "bv24:23.4",
      "pali": "samantā dasayojanaṁ."
    },
    {
      "id": "bv24:24.1",
      "pali": "Cattālīsavassasahassāni,"
    },
    {
      "id": "bv24:24.2",
      "pali": "Āyu tassa mahesino;"
    },
    {
      "id": "bv24:24.3",
      "pali": "Tāvatā tiṭṭhamāno so,"
    },
    {
      "id": "bv24:24.4",
      "pali": "Tāresi janataṁ bahuṁ."
    },
    {
      "id": "bv24:25.1",
      "pali": "Dhammāpaṇaṁ pasāretvā,"
    },
    {
      "id": "bv24:25.2",
      "pali": "naranārīnaṁ sadevake;"
    },
    {
      "id": "bv24:25.3",
      "pali": "Naditvā sīhanādaṁva,"
    },
    {
      "id": "bv24:25.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv24:26.1",
      "pali": "Aṭṭhaṅgavacanasampanno,"
    },
    {
      "id": "bv24:26.2",
      "pali": "acchiddāni nirantaraṁ;"
    },
    {
      "id": "bv24:26.3",
      "pali": "Sabbaṁ tamantarahitaṁ,"
    },
    {
      "id": "bv24:26.4",
      "pali": "nanu rittā sabbasaṅkhārā."
    },
    {
      "id": "bv24:27.1",
      "pali": "Kakusandho jinavaro,"
    },
    {
      "id": "bv24:27.2",
      "pali": "Khemārāmamhi nibbuto;"
    },
    {
      "id": "bv24:27.3",
      "pali": "Tatthevassa thūpavaro,"
    },
    {
      "id": "bv24:27.4",
      "pali": "Gāvutaṁ nabhamuggato”ti."
    },
    {
      "id": "bv24:28.1",
      "pali": "Kakusandhassa bhagavato vaṁso dvāvīsatimo."
    }
  ]
}
