{
  "uid": "ja488",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja488:1.1",
      "pali": "“Assaṁ gavaṁ rajataṁ jātarūpaṁ,"
    },
    {
      "id": "ja488:1.2",
      "pali": "Bhariyañca so idha labhataṁ manāpaṁ;"
    },
    {
      "id": "ja488:1.3",
      "pali": "Puttehi dārehi samaṅgi hotu,"
    },
    {
      "id": "ja488:1.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi”."
    },
    {
      "id": "ja488:2.1",
      "pali": "“Mālañca so kāsikacandanañca,"
    },
    {
      "id": "ja488:2.2",
      "pali": "Dhāretu puttassa bahū bhavantu;"
    },
    {
      "id": "ja488:2.3",
      "pali": "Kāmesu tibbaṁ kurutaṁ apekkhaṁ,"
    },
    {
      "id": "ja488:2.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi”."
    },
    {
      "id": "ja488:3.1",
      "pali": "“Pahūtadhañño kasimā yasassī,"
    },
    {
      "id": "ja488:3.2",
      "pali": "Putte gihī dhanimā sabbakāme;"
    },
    {
      "id": "ja488:3.3",
      "pali": "Vayaṁ apassaṁ gharamāvasātu,"
    },
    {
      "id": "ja488:3.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:4.1",
      "pali": "So khattiyo hotu pasayhakārī,"
    },
    {
      "id": "ja488:4.2",
      "pali": "Rājābhirājā balavā yasassī;"
    },
    {
      "id": "ja488:4.3",
      "pali": "Sa cāturantaṁ mahimāvasātu,"
    },
    {
      "id": "ja488:4.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:5.1",
      "pali": "So brāhmaṇo hotu avītarāgo,"
    },
    {
      "id": "ja488:5.2",
      "pali": "Muhuttanakkhattapathesu yutto;"
    },
    {
      "id": "ja488:5.3",
      "pali": "Pūjetu naṁ raṭṭhapatī yasassī,"
    },
    {
      "id": "ja488:5.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:6.1",
      "pali": "Ajjhāyakaṁ sabbasamantavedaṁ,"
    },
    {
      "id": "ja488:6.2",
      "pali": "Tapassīnaṁ maññatu sabbaloko;"
    },
    {
      "id": "ja488:6.3",
      "pali": "Pūjentu naṁ jānapadā samecca,"
    },
    {
      "id": "ja488:6.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:7.1",
      "pali": "Catussadaṁ gāmavaraṁ samiddhaṁ,"
    },
    {
      "id": "ja488:7.2",
      "pali": "Dinnañhi so bhuñjatu vāsavena;"
    },
    {
      "id": "ja488:7.3",
      "pali": "Avītarāgo maraṇaṁ upetu,"
    },
    {
      "id": "ja488:7.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:8.1",
      "pali": "So gāmaṇī hotu sahāyamajjhe,"
    },
    {
      "id": "ja488:8.2",
      "pali": "Naccehi gītehi pamodamāno;"
    },
    {
      "id": "ja488:8.3",
      "pali": "So rājato byasana mālattha kiñci,"
    },
    {
      "id": "ja488:8.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:9.1",
      "pali": "Yaṁ ekarājā pathaviṁ vijetvā,"
    },
    {
      "id": "ja488:9.2",
      "pali": "Itthīsahassāna ṭhapetu aggaṁ;"
    },
    {
      "id": "ja488:9.3",
      "pali": "Sīmantinīnaṁ pavarā bhavātu,"
    },
    {
      "id": "ja488:9.4",
      "pali": "Bhisāni te brāhmaṇa yā ahāsi."
    },
    {
      "id": "ja488:10.1",
      "pali": "Isīnañhi sā sabbasamāgatānaṁ,"
    },
    {
      "id": "ja488:10.2",
      "pali": "Bhuñjeyya sāduṁ avikampamānā;"
    },
    {
      "id": "ja488:10.3",
      "pali": "Carātu lābhena vikatthamānā,"
    },
    {
      "id": "ja488:10.4",
      "pali": "Bhisāni te brāhmaṇa yā ahāsi."
    },
    {
      "id": "ja488:11.1",
      "pali": "Āvāsiko hotu mahāvihāre,"
    },
    {
      "id": "ja488:11.2",
      "pali": "Navakammiko hotu gajaṅgalāyaṁ;"
    },
    {
      "id": "ja488:11.3",
      "pali": "Ālokasandhiṁ divasaṁ karotu,"
    },
    {
      "id": "ja488:11.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:12.1",
      "pali": "So bajjhatū pāsasatehi chabbhi,"
    },
    {
      "id": "ja488:12.2",
      "pali": "Rammā vanā niyyatu rājadhāniṁ;"
    },
    {
      "id": "ja488:12.3",
      "pali": "Tuttehi so haññatu pācanehi,"
    },
    {
      "id": "ja488:12.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi."
    },
    {
      "id": "ja488:13.1",
      "pali": "Alakkamālī tipukaṇṇaviddho,"
    },
    {
      "id": "ja488:13.2",
      "pali": "Laṭṭhīhato sappamukhaṁ upetu;"
    },
    {
      "id": "ja488:13.3",
      "pali": "Sakacchabandho visikhaṁ carātu,"
    },
    {
      "id": "ja488:13.4",
      "pali": "Bhisāni te brāhmaṇa yo ahāsi”."
    },
    {
      "id": "ja488:14.1",
      "pali": "“Yo ve anaṭṭhaṁva naṭṭhanti cāha,"
    },
    {
      "id": "ja488:14.2",
      "pali": "Kāmeva so labhataṁ bhuñjatañca;"
    },
    {
      "id": "ja488:14.3",
      "pali": "Agāramajjhe maraṇaṁ upetu,"
    },
    {
      "id": "ja488:14.4",
      "pali": "Yo vā bhonto saṅkati kañcideva”."
    },
    {
      "id": "ja488:15.1",
      "pali": "“Yadesamānā vicaranti loke,"
    },
    {
      "id": "ja488:15.2",
      "pali": "Iṭṭhañca kantañca bahūnametaṁ;"
    },
    {
      "id": "ja488:15.3",
      "pali": "Piyaṁ manuññaṁ cidha jīvaloke,"
    },
    {
      "id": "ja488:15.4",
      "pali": "Kasmā isayo nappasaṁsanti kāme”."
    },
    {
      "id": "ja488:16.1",
      "pali": "“Kāmesu ve haññare bajjhare ca,"
    },
    {
      "id": "ja488:16.2",
      "pali": "Kāmesu dukkhañca bhayañca jātaṁ;"
    },
    {
      "id": "ja488:16.3",
      "pali": "Kāmesu bhūtādhipatī pamattā,"
    },
    {
      "id": "ja488:16.4",
      "pali": "Pāpāni kammāni karonti mohā."
    },
    {
      "id": "ja488:17.1",
      "pali": "Te pāpadhammā pasavetva pāpaṁ,"
    },
    {
      "id": "ja488:17.2",
      "pali": "Kāyassa bhedā nirayaṁ vajanti;"
    },
    {
      "id": "ja488:17.3",
      "pali": "Ādīnavaṁ kāmaguṇesu disvā,"
    },
    {
      "id": "ja488:17.4",
      "pali": "Tasmā isayo nappasaṁsanti kāme”."
    },
    {
      "id": "ja488:18.1",
      "pali": "“Vīmaṁsamāno isino bhisāni,"
    },
    {
      "id": "ja488:18.2",
      "pali": "Tīre gahetvāna thale nidhesiṁ;"
    },
    {
      "id": "ja488:18.3",
      "pali": "Suddhā apāpā isayo vasanti,"
    },
    {
      "id": "ja488:18.4",
      "pali": "Etāni te brahmacārī bhisāni”."
    },
    {
      "id": "ja488:19.1",
      "pali": "“Na te naṭā no pana kīḷaneyyā,"
    },
    {
      "id": "ja488:19.2",
      "pali": "Na bandhavā no pana te sahāyā;"
    },
    {
      "id": "ja488:19.3",
      "pali": "Kismiṁ vupatthambha sahassanetta,"
    },
    {
      "id": "ja488:19.4",
      "pali": "Isīhi tvaṁ kīḷasi devarāja”."
    },
    {
      "id": "ja488:20.1",
      "pali": "“Ācariyo mesi pitā ca mayhaṁ,"
    },
    {
      "id": "ja488:20.2",
      "pali": "Esā patiṭṭhā khalitassa brahme;"
    },
    {
      "id": "ja488:20.3",
      "pali": "Ekāparādhaṁ khama bhūripañña,"
    },
    {
      "id": "ja488:20.4",
      "pali": "Na paṇḍitā kodhabalā bhavanti”."
    },
    {
      "id": "ja488:21.1",
      "pali": "“Suvāsitaṁ isinaṁ ekarattaṁ,"
    },
    {
      "id": "ja488:21.2",
      "pali": "Yaṁ vāsavaṁ bhūtapatiddasāma;"
    },
    {
      "id": "ja488:21.3",
      "pali": "Sabbeva bhonto sumanā bhavantu,"
    },
    {
      "id": "ja488:21.4",
      "pali": "Yaṁ brāhmaṇo paccupādī bhisāni”."
    },
    {
      "id": "ja488:22.1",
      "pali": "“Ahañca sāriputto ca,"
    },
    {
      "id": "ja488:22.2",
      "pali": "moggallāno ca kassapo;"
    },
    {
      "id": "ja488:22.3",
      "pali": "Anuruddho puṇṇo ānando,"
    },
    {
      "id": "ja488:22.4",
      "pali": "tadāsuṁ satta bhātaro."
    },
    {
      "id": "ja488:23.1",
      "pali": "Bhaginī uppalavaṇṇā ca,"
    },
    {
      "id": "ja488:23.2",
      "pali": "dāsī khujjuttarā tadā;"
    },
    {
      "id": "ja488:23.3",
      "pali": "Citto gahapati dāso,"
    },
    {
      "id": "ja488:23.4",
      "pali": "yakkho sātāgiro tadā."
    },
    {
      "id": "ja488:24.1",
      "pali": "Pālileyyo tadā nāgo,"
    },
    {
      "id": "ja488:24.2",
      "pali": "madhudo seṭṭhavānaro;"
    },
    {
      "id": "ja488:24.3",
      "pali": "Kāḷudāyī tadā sakko,"
    },
    {
      "id": "ja488:24.4",
      "pali": "evaṁ dhāretha jātakanti”."
    },
    {
      "id": "ja488:25.1",
      "pali": "Bhisajātakaṁ pañcamaṁ."
    }
  ]
}
