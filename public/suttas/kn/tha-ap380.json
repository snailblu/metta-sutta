{
  "uid": "tha-ap380",
  "title": "Sumanatālavaṇṭiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap380:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap380:1.2",
      "pali": "tālavaṇṭamadāsahaṁ;"
    },
    {
      "id": "tha-ap380:1.3",
      "pali": "Sumanehi paṭicchannaṁ,"
    },
    {
      "id": "tha-ap380:1.4",
      "pali": "dhārayāmi mahārahaṁ."
    },
    {
      "id": "tha-ap380:2.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap380:2.2",
      "pali": "tālavaṇṭamadāsahaṁ;"
    },
    {
      "id": "tha-ap380:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap380:2.4",
      "pali": "tālavaṇṭassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap380:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap380:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap380:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap380:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap380:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap380:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap380:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap380:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap380:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap380:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sumanatālavaṇṭiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap380:7.1",
      "pali": "Sumanatālavaṇṭiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
