{
  "uid": "mil7.5.4",
  "title": "Upacikāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil7.5.4:1.1",
      "pali": "“Bhante nāgasena, ‘vicchikassa ekaṁ aṅgaṁ gahetabban’ti yaṁ vadesi, katamaṁ taṁ ekaṁ aṅgaṁ gahetabban”ti?"
    },
    {
      "id": "mil7.5.4:1.2",
      "pali": "“Yathā, mahārāja, vicchiko naṅgulāvudho naṅgulaṁ ussāpetvā carati;"
    },
    {
      "id": "mil7.5.4:1.3",
      "pali": "evameva kho, mahārāja, yoginā yogāvacarena ñāṇāvudhena bhavitabbaṁ, ñāṇaṁ ussāpetvā viharitabbaṁ."
    },
    {
      "id": "mil7.5.4:1.4",
      "pali": "Idaṁ, mahārāja, vicchikassa ekaṁ aṅgaṁ gahetabbaṁ."
    },
    {
      "id": "mil7.5.4:1.5",
      "pali": "Bhāsitampetaṁ, mahārāja, therena upasenena vaṅgantaputtena—"
    },
    {
      "id": "mil7.5.4:2.1",
      "pali": "‘Ñāṇakhaggaṁ gahetvāna,"
    },
    {
      "id": "mil7.5.4:2.2",
      "pali": "viharanto vipassako;"
    },
    {
      "id": "mil7.5.4:2.3",
      "pali": "Parimuccati sabbabhayā,"
    },
    {
      "id": "mil7.5.4:2.4",
      "pali": "duppasaho ca so bhave’”ti."
    },
    {
      "id": "mil7.5.4:3.1",
      "pali": "Vicchikaṅgapañho catuttho."
    }
  ]
}
