{
  "uid": "thag1.99",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.99:1.1",
      "pali": "“Saddaṁ sutvā sati muṭṭhā,"
    },
    {
      "id": "thag1.99:1.2",
      "pali": "Piyaṁ nimittaṁ manasikaroto;"
    },
    {
      "id": "thag1.99:1.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "thag1.99:1.4",
      "pali": "Tañca ajjhosa tiṭṭhati;"
    },
    {
      "id": "thag1.99:1.5",
      "pali": "Tassa vaḍḍhanti āsavā,"
    },
    {
      "id": "thag1.99:1.6",
      "pali": "Saṁsāraṁ upagāmino”ti."
    },
    {
      "id": "thag1.99:1.7",
      "pali": "… Uttiyo thero …."
    }
  ]
}
