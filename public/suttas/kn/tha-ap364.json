{
  "uid": "tha-ap364",
  "title": "Kakkārupupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap364:1.1",
      "pali": "“Yāmā devā idhāgantvā,"
    },
    {
      "id": "tha-ap364:1.2",
      "pali": "gotamaṁ sirivacchasaṁ;"
    },
    {
      "id": "tha-ap364:1.3",
      "pali": "Kakkārumālaṁ paggayha,"
    },
    {
      "id": "tha-ap364:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap364:2.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap364:2.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap364:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap364:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap364:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap364:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap364:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap364:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā kakkārupupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap364:5.1",
      "pali": "Kakkārupupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
