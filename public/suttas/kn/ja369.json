{
  "uid": "ja369",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja369:1.1",
      "pali": "“Kyāhaṁ devānamakaraṁ,"
    },
    {
      "id": "ja369:1.2",
      "pali": "kiṁ pāpaṁ pakataṁ mayā;"
    },
    {
      "id": "ja369:1.3",
      "pali": "Yaṁ me sirasmiṁ ohacca,"
    },
    {
      "id": "ja369:1.4",
      "pali": "cakkaṁ bhamati matthake”."
    },
    {
      "id": "ja369:2.1",
      "pali": "“Atikkamma ramaṇakaṁ,"
    },
    {
      "id": "ja369:2.2",
      "pali": "sadāmattañca dūbhakaṁ;"
    },
    {
      "id": "ja369:2.3",
      "pali": "Brahmattarañca pāsādaṁ,"
    },
    {
      "id": "ja369:2.4",
      "pali": "kenatthena idhāgato”."
    },
    {
      "id": "ja369:3.1",
      "pali": "“Ito bahutarā bhogā,"
    },
    {
      "id": "ja369:3.2",
      "pali": "atra maññe bhavissare;"
    },
    {
      "id": "ja369:3.3",
      "pali": "Iti etāya saññāya,"
    },
    {
      "id": "ja369:3.4",
      "pali": "passa maṁ byasanaṁ gataṁ”."
    },
    {
      "id": "ja369:4.1",
      "pali": "“Catubbhi aṭṭhajjhagamā,"
    },
    {
      "id": "ja369:4.2",
      "pali": "aṭṭhāhipi ca soḷasa;"
    },
    {
      "id": "ja369:4.3",
      "pali": "Soḷasāhi ca bāttiṁsa,"
    },
    {
      "id": "ja369:4.4",
      "pali": "atricchaṁ cakkamāsado;"
    },
    {
      "id": "ja369:4.5",
      "pali": "Icchāhatassa posassa,"
    },
    {
      "id": "ja369:4.6",
      "pali": "cakkaṁ bhamati matthake."
    },
    {
      "id": "ja369:5.1",
      "pali": "Uparivisālā duppūrā,"
    },
    {
      "id": "ja369:5.2",
      "pali": "icchā visaṭagāminī;"
    },
    {
      "id": "ja369:5.3",
      "pali": "Ye ca taṁ anugijjhanti,"
    },
    {
      "id": "ja369:5.4",
      "pali": "te honti cakkadhārino”ti."
    },
    {
      "id": "ja369:6.1",
      "pali": "Mittavindakajātakaṁ navamaṁ."
    }
  ]
}
