{
  "uid": "ja287",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja287:1.1",
      "pali": "“Nānummatto nāpisuṇo,"
    },
    {
      "id": "ja287:1.2",
      "pali": "nānaṭo nākutūhalo;"
    },
    {
      "id": "ja287:1.3",
      "pali": "Mūḷhesu labhate lābhaṁ,"
    },
    {
      "id": "ja287:1.4",
      "pali": "esā te anusāsanī”."
    },
    {
      "id": "ja287:2.1",
      "pali": "“Dhiratthu taṁ yasalābhaṁ,"
    },
    {
      "id": "ja287:2.2",
      "pali": "dhanalābhañca brāhmaṇa;"
    },
    {
      "id": "ja287:2.3",
      "pali": "Yā vutti vinipātena,"
    },
    {
      "id": "ja287:2.4",
      "pali": "adhammacaraṇena vā."
    },
    {
      "id": "ja287:3.1",
      "pali": "Api ce pattamādāya,"
    },
    {
      "id": "ja287:3.2",
      "pali": "anagāro paribbaje;"
    },
    {
      "id": "ja287:3.3",
      "pali": "Esāva jīvikā seyyo,"
    },
    {
      "id": "ja287:3.4",
      "pali": "yā cādhammena esanā”ti."
    },
    {
      "id": "ja287:4.1",
      "pali": "Lābhagarahajātakaṁ sattamaṁ."
    }
  ]
}
