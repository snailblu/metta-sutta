{
  "uid": "ja163",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja163:1.1",
      "pali": "“Kāḷā migā setadantā tavīme,"
    },
    {
      "id": "ja163:1.2",
      "pali": "Parosataṁ hemajālābhichannā;"
    },
    {
      "id": "ja163:1.3",
      "pali": "Te te dadāmīti susīma brūsi,"
    },
    {
      "id": "ja163:1.4",
      "pali": "Anussaraṁ pettipitāmahānaṁ”."
    },
    {
      "id": "ja163:2.1",
      "pali": "“Kāḷā migā setadantā mamīme,"
    },
    {
      "id": "ja163:2.2",
      "pali": "Parosataṁ hemajālābhichannā;"
    },
    {
      "id": "ja163:2.3",
      "pali": "Te te dadāmīti vadāmi māṇava,"
    },
    {
      "id": "ja163:2.4",
      "pali": "Anussaraṁ pettipitāmahānan”ti."
    },
    {
      "id": "ja163:3.1",
      "pali": "Susīmajātakaṁ tatiyaṁ."
    }
  ]
}
