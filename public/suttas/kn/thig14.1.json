{
  "uid": "thig14.1",
  "title": "Subhājīvakambavanikātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig14.1:1.1",
      "pali": "Jīvakambavanaṁ rammaṁ,"
    },
    {
      "id": "thig14.1:1.2",
      "pali": "Gacchantiṁ bhikkhuniṁ subhaṁ;"
    },
    {
      "id": "thig14.1:1.3",
      "pali": "Dhuttako sannivāresi,"
    },
    {
      "id": "thig14.1:1.4",
      "pali": "Tamenaṁ abravī subhā."
    },
    {
      "id": "thig14.1:2.1",
      "pali": "“Kiṁ te aparādhitaṁ mayā,"
    },
    {
      "id": "thig14.1:2.2",
      "pali": "Yaṁ maṁ ovariyāna tiṭṭhasi;"
    },
    {
      "id": "thig14.1:2.3",
      "pali": "Na hi pabbajitāya āvuso,"
    },
    {
      "id": "thig14.1:2.4",
      "pali": "Puriso samphusanāya kappati."
    },
    {
      "id": "thig14.1:3.1",
      "pali": "Garuke mama satthusāsane,"
    },
    {
      "id": "thig14.1:3.2",
      "pali": "Yā sikkhā sugatena desitā;"
    },
    {
      "id": "thig14.1:3.3",
      "pali": "Parisuddhapadaṁ anaṅgaṇaṁ,"
    },
    {
      "id": "thig14.1:3.4",
      "pali": "Kiṁ maṁ ovariyāna tiṭṭhasi."
    },
    {
      "id": "thig14.1:4.1",
      "pali": "Āvilacitto anāvilaṁ,"
    },
    {
      "id": "thig14.1:4.2",
      "pali": "Sarajo vītarajaṁ anaṅgaṇaṁ;"
    },
    {
      "id": "thig14.1:4.3",
      "pali": "Sabbattha vimuttamānasaṁ,"
    },
    {
      "id": "thig14.1:4.4",
      "pali": "Kiṁ maṁ ovariyāna tiṭṭhasi”."
    },
    {
      "id": "thig14.1:5.1",
      "pali": "“Daharā ca apāpikā casi,"
    },
    {
      "id": "thig14.1:5.2",
      "pali": "Kiṁ te pabbajjā karissati;"
    },
    {
      "id": "thig14.1:5.3",
      "pali": "Nikkhipa kāsāyacīvaraṁ,"
    },
    {
      "id": "thig14.1:5.4",
      "pali": "Ehi ramāma supupphite vane."
    },
    {
      "id": "thig14.1:6.1",
      "pali": "Madhurañca pavanti sabbaso,"
    },
    {
      "id": "thig14.1:6.2",
      "pali": "Kusumarajena samuṭṭhitā dumā;"
    },
    {
      "id": "thig14.1:6.3",
      "pali": "Paṭhamavasanto sukho utu,"
    },
    {
      "id": "thig14.1:6.4",
      "pali": "Ehi ramāma supupphite vane."
    },
    {
      "id": "thig14.1:7.1",
      "pali": "Kusumitasikharā ca pādapā,"
    },
    {
      "id": "thig14.1:7.2",
      "pali": "Abhigajjantiva māluteritā;"
    },
    {
      "id": "thig14.1:7.3",
      "pali": "Kā tuyhaṁ rati bhavissati,"
    },
    {
      "id": "thig14.1:7.4",
      "pali": "Yadi ekā vanamogahissasi."
    },
    {
      "id": "thig14.1:8.1",
      "pali": "Vāḷamigasaṅghasevitaṁ,"
    },
    {
      "id": "thig14.1:8.2",
      "pali": "Kuñjaramattakareṇuloḷitaṁ;"
    },
    {
      "id": "thig14.1:8.3",
      "pali": "Asahāyikā gantumicchasi,"
    },
    {
      "id": "thig14.1:8.4",
      "pali": "Rahitaṁ bhiṁsanakaṁ mahāvanaṁ."
    },
    {
      "id": "thig14.1:9.1",
      "pali": "Tapanīyakatāva dhītikā,"
    },
    {
      "id": "thig14.1:9.2",
      "pali": "Vicarasi cittalateva accharā;"
    },
    {
      "id": "thig14.1:9.3",
      "pali": "Kāsikasukhumehi vaggubhi,"
    },
    {
      "id": "thig14.1:9.4",
      "pali": "Sobhasī suvasanehi nūpame."
    },
    {
      "id": "thig14.1:10.1",
      "pali": "Ahaṁ tava vasānugo siyaṁ,"
    },
    {
      "id": "thig14.1:10.2",
      "pali": "Yadi viharemase kānanantare;"
    },
    {
      "id": "thig14.1:10.3",
      "pali": "Na hi matthi tayā piyattaro,"
    },
    {
      "id": "thig14.1:10.4",
      "pali": "Pāṇo kinnarimandalocane."
    },
    {
      "id": "thig14.1:11.1",
      "pali": "Yadi me vacanaṁ karissasi,"
    },
    {
      "id": "thig14.1:11.2",
      "pali": "Sukhitā ehi agāramāvasa;"
    },
    {
      "id": "thig14.1:11.3",
      "pali": "Pāsādanivātavāsinī,"
    },
    {
      "id": "thig14.1:11.4",
      "pali": "Parikammaṁ te karontu nāriyo."
    },
    {
      "id": "thig14.1:12.1",
      "pali": "Kāsikasukhumāni dhāraya,"
    },
    {
      "id": "thig14.1:12.2",
      "pali": "Abhiropehi ca mālavaṇṇakaṁ;"
    },
    {
      "id": "thig14.1:12.3",
      "pali": "Kañcanamaṇimuttakaṁ bahuṁ,"
    },
    {
      "id": "thig14.1:12.4",
      "pali": "Vividhaṁ ābharaṇaṁ karomi te."
    },
    {
      "id": "thig14.1:13.1",
      "pali": "Sudhotarajapacchadaṁ subhaṁ,"
    },
    {
      "id": "thig14.1:13.2",
      "pali": "Gonakatūlikasanthataṁ navaṁ;"
    },
    {
      "id": "thig14.1:13.3",
      "pali": "Abhiruha sayanaṁ mahārahaṁ,"
    },
    {
      "id": "thig14.1:13.4",
      "pali": "Candanamaṇḍitasāragandhikaṁ."
    },
    {
      "id": "thig14.1:14.1",
      "pali": "Uppalaṁ cudakā samuggataṁ,"
    },
    {
      "id": "thig14.1:14.2",
      "pali": "Yathā taṁ amanussasevitaṁ;"
    },
    {
      "id": "thig14.1:14.3",
      "pali": "Evaṁ tvaṁ brahmacārinī,"
    },
    {
      "id": "thig14.1:14.4",
      "pali": "Sakesaṅgesu jaraṁ gamissasi”."
    },
    {
      "id": "thig14.1:15.1",
      "pali": "“Kiṁ te idha sārasammataṁ,"
    },
    {
      "id": "thig14.1:15.2",
      "pali": "Kuṇapapūramhi susānavaḍḍhane;"
    },
    {
      "id": "thig14.1:15.3",
      "pali": "Bhedanadhamme kaḷevare,"
    },
    {
      "id": "thig14.1:15.4",
      "pali": "Yaṁ disvā vimano udikkhasi”."
    },
    {
      "id": "thig14.1:16.1",
      "pali": "“Akkhīni ca tūriyāriva,"
    },
    {
      "id": "thig14.1:16.2",
      "pali": "Kinnariyāriva pabbatantare;"
    },
    {
      "id": "thig14.1:16.3",
      "pali": "Tava me nayanāni dakkhiya,"
    },
    {
      "id": "thig14.1:16.4",
      "pali": "Bhiyyo kāmaratī pavaḍḍhati."
    },
    {
      "id": "thig14.1:17.1",
      "pali": "Uppalasikharopamāni te,"
    },
    {
      "id": "thig14.1:17.2",
      "pali": "Vimale hāṭakasannibhe mukhe;"
    },
    {
      "id": "thig14.1:17.3",
      "pali": "Tava me nayanāni dakkhiya,"
    },
    {
      "id": "thig14.1:17.4",
      "pali": "Bhiyyo kāmaguṇo pavaḍḍhati."
    },
    {
      "id": "thig14.1:18.1",
      "pali": "Api dūragatā saramhase,"
    },
    {
      "id": "thig14.1:18.2",
      "pali": "Āyatapamhe visuddhadassane;"
    },
    {
      "id": "thig14.1:18.3",
      "pali": "Na hi matthi tayā piyattaro,"
    },
    {
      "id": "thig14.1:18.4",
      "pali": "Nayanā kinnarimandalocane”."
    },
    {
      "id": "thig14.1:19.1",
      "pali": "“Apathena payātumicchasi,"
    },
    {
      "id": "thig14.1:19.2",
      "pali": "Candaṁ kīḷanakaṁ gavesasi;"
    },
    {
      "id": "thig14.1:19.3",
      "pali": "Meruṁ laṅghetumicchasi,"
    },
    {
      "id": "thig14.1:19.4",
      "pali": "Yo tvaṁ buddhasutaṁ maggayasi."
    },
    {
      "id": "thig14.1:20.1",
      "pali": "Natthi hi loke sadevake,"
    },
    {
      "id": "thig14.1:20.2",
      "pali": "Rāgo yatthapi dāni me siyā;"
    },
    {
      "id": "thig14.1:20.3",
      "pali": "Napi naṁ jānāmi kīriso,"
    },
    {
      "id": "thig14.1:20.4",
      "pali": "Atha maggena hato samūlako."
    },
    {
      "id": "thig14.1:21.1",
      "pali": "Iṅgālakuyāva ujjhito,"
    },
    {
      "id": "thig14.1:21.2",
      "pali": "Visapattoriva aggito kato;"
    },
    {
      "id": "thig14.1:21.3",
      "pali": "Napi naṁ passāmi kīriso,"
    },
    {
      "id": "thig14.1:21.4",
      "pali": "Atha maggena hato samūlako."
    },
    {
      "id": "thig14.1:22.1",
      "pali": "Yassā siyā apaccavekkhitaṁ,"
    },
    {
      "id": "thig14.1:22.2",
      "pali": "Satthā vā anupāsito siyā;"
    },
    {
      "id": "thig14.1:22.3",
      "pali": "Tvaṁ tādisikaṁ palobhaya,"
    },
    {
      "id": "thig14.1:22.4",
      "pali": "Jānantiṁ so imaṁ vihaññasi."
    },
    {
      "id": "thig14.1:23.1",
      "pali": "Mayhañhi akkuṭṭhavandite,"
    },
    {
      "id": "thig14.1:23.2",
      "pali": "Sukhadukkhe ca satī upaṭṭhitā;"
    },
    {
      "id": "thig14.1:23.3",
      "pali": "Saṅkhatamasubhanti jāniya,"
    },
    {
      "id": "thig14.1:23.4",
      "pali": "Sabbattheva mano na limpati."
    },
    {
      "id": "thig14.1:24.1",
      "pali": "Sāhaṁ sugatassa sāvikā,"
    },
    {
      "id": "thig14.1:24.2",
      "pali": "Maggaṭṭhaṅgikayānayāyinī;"
    },
    {
      "id": "thig14.1:24.3",
      "pali": "Uddhaṭasallā anāsavā,"
    },
    {
      "id": "thig14.1:24.4",
      "pali": "Suññāgāragatā ramāmahaṁ."
    },
    {
      "id": "thig14.1:25.1",
      "pali": "Diṭṭhā hi mayā sucittitā,"
    },
    {
      "id": "thig14.1:25.2",
      "pali": "Sombhā dārukapillakāni vā;"
    },
    {
      "id": "thig14.1:25.3",
      "pali": "Tantīhi ca khīlakehi ca,"
    },
    {
      "id": "thig14.1:25.4",
      "pali": "Vinibaddhā vividhaṁ panaccakā."
    },
    {
      "id": "thig14.1:26.1",
      "pali": "Tamhuddhaṭe tantikhīlake,"
    },
    {
      "id": "thig14.1:26.2",
      "pali": "Vissaṭṭhe vikale parikrite;"
    },
    {
      "id": "thig14.1:26.3",
      "pali": "Na vindeyya khaṇḍaso kate,"
    },
    {
      "id": "thig14.1:26.4",
      "pali": "Kimhi tattha manaṁ nivesaye."
    },
    {
      "id": "thig14.1:27.1",
      "pali": "Tathūpamā dehakāni maṁ,"
    },
    {
      "id": "thig14.1:27.2",
      "pali": "Tehi dhammehi vinā na vattanti;"
    },
    {
      "id": "thig14.1:27.3",
      "pali": "Dhammehi vinā na vattati,"
    },
    {
      "id": "thig14.1:27.4",
      "pali": "Kimhi tattha manaṁ nivesaye."
    },
    {
      "id": "thig14.1:28.1",
      "pali": "Yathā haritālena makkhitaṁ,"
    },
    {
      "id": "thig14.1:28.2",
      "pali": "Addasa cittikaṁ bhittiyā kataṁ;"
    },
    {
      "id": "thig14.1:28.3",
      "pali": "Tamhi te viparītadassanaṁ,"
    },
    {
      "id": "thig14.1:28.4",
      "pali": "Saññā mānusikā niratthikā."
    },
    {
      "id": "thig14.1:29.1",
      "pali": "Māyaṁ viya aggato kataṁ,"
    },
    {
      "id": "thig14.1:29.2",
      "pali": "Supinanteva suvaṇṇapādapaṁ;"
    },
    {
      "id": "thig14.1:29.3",
      "pali": "Upagacchasi andha rittakaṁ,"
    },
    {
      "id": "thig14.1:29.4",
      "pali": "Janamajjheriva rupparūpakaṁ."
    },
    {
      "id": "thig14.1:30.1",
      "pali": "Vaṭṭaniriva koṭarohitā,"
    },
    {
      "id": "thig14.1:30.2",
      "pali": "Majjhe pubbuḷakā saassukā;"
    },
    {
      "id": "thig14.1:30.3",
      "pali": "Pīḷakoḷikā cettha jāyati,"
    },
    {
      "id": "thig14.1:30.4",
      "pali": "Vividhā cakkhuvidhā ca piṇḍitā”."
    },
    {
      "id": "thig14.1:31.1",
      "pali": "Uppāṭiya cārudassanā,"
    },
    {
      "id": "thig14.1:31.2",
      "pali": "Na ca pajjittha asaṅgamānasā;"
    },
    {
      "id": "thig14.1:31.3",
      "pali": "“Handa te cakkhuṁ harassu taṁ”,"
    },
    {
      "id": "thig14.1:31.4",
      "pali": "Tassa narassa adāsi tāvade."
    },
    {
      "id": "thig14.1:32.1",
      "pali": "Tassa ca viramāsi tāvade,"
    },
    {
      "id": "thig14.1:32.2",
      "pali": "Rāgo tattha khamāpayī ca naṁ;"
    },
    {
      "id": "thig14.1:32.3",
      "pali": "“Sotthi siyā brahmacārinī,"
    },
    {
      "id": "thig14.1:32.4",
      "pali": "Na puno edisakaṁ bhavissati”."
    },
    {
      "id": "thig14.1:33.1",
      "pali": "“Āsādiya edisaṁ janaṁ,"
    },
    {
      "id": "thig14.1:33.2",
      "pali": "Aggiṁ pajjalitaṁva liṅgiya;"
    },
    {
      "id": "thig14.1:33.3",
      "pali": "Gaṇhiya āsīvisaṁ viya,"
    },
    {
      "id": "thig14.1:33.4",
      "pali": "Api nu sotthi siyā khamehi no”."
    },
    {
      "id": "thig14.1:34.1",
      "pali": "Muttā ca tato sā bhikkhunī,"
    },
    {
      "id": "thig14.1:34.2",
      "pali": "Agamī buddhavarassa santikaṁ;"
    },
    {
      "id": "thig14.1:34.3",
      "pali": "Passiya varapuññalakkhaṇaṁ,"
    },
    {
      "id": "thig14.1:34.4",
      "pali": "Cakkhu āsi yathā purāṇakanti."
    },
    {
      "id": "thig14.1:35.1",
      "pali": "… Subhā jīvakambavanikā therī …."
    },
    {
      "id": "thig14.1:36.1",
      "pali": "Tiṁsanipāto niṭṭhito."
    }
  ]
}
