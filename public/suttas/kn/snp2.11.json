{
  "uid": "snp2.11",
  "title": "Rāhulasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.11:1.1",
      "pali": "“Kacci abhiṇhasaṁvāsā,"
    },
    {
      "id": "snp2.11:1.2",
      "pali": "nāvajānāsi paṇḍitaṁ;"
    },
    {
      "id": "snp2.11:1.3",
      "pali": "Ukkādhāro manussānaṁ,"
    },
    {
      "id": "snp2.11:1.4",
      "pali": "kacci apacito tayā”."
    },
    {
      "id": "snp2.11:2.1",
      "pali": "“Nāhaṁ abhiṇhasaṁvāsā,"
    },
    {
      "id": "snp2.11:2.2",
      "pali": "avajānāmi paṇḍitaṁ;"
    },
    {
      "id": "snp2.11:2.3",
      "pali": "Ukkādhāro manussānaṁ,"
    },
    {
      "id": "snp2.11:2.4",
      "pali": "niccaṁ apacito mayā”."
    },
    {
      "id": "snp2.11:3.1",
      "pali": "“Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "snp2.11:3.2",
      "pali": "piyarūpe manorame;"
    },
    {
      "id": "snp2.11:3.3",
      "pali": "Saddhāya gharā nikkhamma,"
    },
    {
      "id": "snp2.11:3.4",
      "pali": "dukkhassantakaro bhava."
    },
    {
      "id": "snp2.11:4.1",
      "pali": "Mitte bhajassu kalyāṇe,"
    },
    {
      "id": "snp2.11:4.2",
      "pali": "pantañca sayanāsanaṁ;"
    },
    {
      "id": "snp2.11:4.3",
      "pali": "Vivittaṁ appanigghosaṁ,"
    },
    {
      "id": "snp2.11:4.4",
      "pali": "mattaññū hohi bhojane."
    },
    {
      "id": "snp2.11:5.1",
      "pali": "Cīvare piṇḍapāte ca,"
    },
    {
      "id": "snp2.11:5.2",
      "pali": "paccaye sayanāsane;"
    },
    {
      "id": "snp2.11:5.3",
      "pali": "Etesu taṇhaṁ mākāsi,"
    },
    {
      "id": "snp2.11:5.4",
      "pali": "mā lokaṁ punarāgami."
    },
    {
      "id": "snp2.11:6.1",
      "pali": "Saṁvuto pātimokkhasmiṁ,"
    },
    {
      "id": "snp2.11:6.2",
      "pali": "indriyesu ca pañcasu;"
    },
    {
      "id": "snp2.11:6.3",
      "pali": "Sati kāyagatā tyatthu,"
    },
    {
      "id": "snp2.11:6.4",
      "pali": "nibbidābahulo bhava."
    },
    {
      "id": "snp2.11:7.1",
      "pali": "Nimittaṁ parivajjehi,"
    },
    {
      "id": "snp2.11:7.2",
      "pali": "subhaṁ rāgūpasañhitaṁ;"
    },
    {
      "id": "snp2.11:7.3",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "snp2.11:7.4",
      "pali": "ekaggaṁ susamāhitaṁ."
    },
    {
      "id": "snp2.11:8.1",
      "pali": "Animittañca bhāvehi,"
    },
    {
      "id": "snp2.11:8.2",
      "pali": "Mānānusayamujjaha;"
    },
    {
      "id": "snp2.11:8.3",
      "pali": "Tato mānābhisamayā,"
    },
    {
      "id": "snp2.11:8.4",
      "pali": "Upasanto carissatī”ti."
    },
    {
      "id": "snp2.11:9.1",
      "pali": "Itthaṁ sudaṁ bhagavā āyasmantaṁ rāhulaṁ imāhi gāthāhi abhiṇhaṁ ovadatīti."
    },
    {
      "id": "snp2.11:9.2",
      "pali": "Rāhulasuttaṁ ekādasamaṁ."
    }
  ]
}
