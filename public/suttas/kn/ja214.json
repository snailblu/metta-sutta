{
  "uid": "ja214",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja214:1.1",
      "pali": "“Puṇṇaṁ nadiṁ yena ca peyyamāhu,"
    },
    {
      "id": "ja214:1.2",
      "pali": "Jātaṁ yavaṁ yena ca guyhamāhu;"
    },
    {
      "id": "ja214:1.3",
      "pali": "Dūraṁ gataṁ yena ca avhayanti,"
    },
    {
      "id": "ja214:1.4",
      "pali": "So tyāgato handa ca bhuñja brāhmaṇa”."
    },
    {
      "id": "ja214:2.1",
      "pali": "“Yato maṁ saratī rājā,"
    },
    {
      "id": "ja214:2.2",
      "pali": "vāyasampi pahetave;"
    },
    {
      "id": "ja214:2.3",
      "pali": "Haṁsā koñcā mayūrā ca,"
    },
    {
      "id": "ja214:2.4",
      "pali": "asatīyeva pāpiyā”ti."
    },
    {
      "id": "ja214:3.1",
      "pali": "Puṇṇanadījātakaṁ catutthaṁ."
    }
  ]
}
