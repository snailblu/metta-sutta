{
  "uid": "ja84",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja84:1.1",
      "pali": "“Ārogyamicche paramañca lābhaṁ,"
    },
    {
      "id": "ja84:1.2",
      "pali": "Sīlañca vuddhānumataṁ sutañca;"
    },
    {
      "id": "ja84:1.3",
      "pali": "Dhammānuvattī ca alīnatā ca,"
    },
    {
      "id": "ja84:1.4",
      "pali": "Atthassa dvārā pamukhā chaḷete”ti."
    },
    {
      "id": "ja84:2.1",
      "pali": "Atthassadvārajātakaṁ catutthaṁ."
    }
  ]
}
