{
  "uid": "tha-ap440",
  "title": "Harītakadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap440:1.1",
      "pali": "“Harītakaṁ āmalakaṁ,"
    },
    {
      "id": "tha-ap440:1.2",
      "pali": "ambajambuvibhītakaṁ;"
    },
    {
      "id": "tha-ap440:1.3",
      "pali": "Kolaṁ bhallātakaṁ billaṁ,"
    },
    {
      "id": "tha-ap440:1.4",
      "pali": "sayameva harāmahaṁ."
    },
    {
      "id": "tha-ap440:2.1",
      "pali": "Disvāna pabbhāragataṁ,"
    },
    {
      "id": "tha-ap440:2.2",
      "pali": "jhāyiṁ jhānarataṁ muniṁ;"
    },
    {
      "id": "tha-ap440:2.3",
      "pali": "Ābādhena āpīḷentaṁ,"
    },
    {
      "id": "tha-ap440:2.4",
      "pali": "adutīyaṁ mahāmuniṁ."
    },
    {
      "id": "tha-ap440:3.1",
      "pali": "Harītakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap440:3.2",
      "pali": "sayambhussa adāsahaṁ;"
    },
    {
      "id": "tha-ap440:3.3",
      "pali": "Khādamattamhi bhesajje,"
    },
    {
      "id": "tha-ap440:3.4",
      "pali": "byādhi passambhi tāvade."
    },
    {
      "id": "tha-ap440:4.1",
      "pali": "Pahīnadaratho buddho,"
    },
    {
      "id": "tha-ap440:4.2",
      "pali": "anumodamakāsi me;"
    },
    {
      "id": "tha-ap440:4.3",
      "pali": "‘Bhesajjadāneniminā,"
    },
    {
      "id": "tha-ap440:4.4",
      "pali": "byādhivūpasamena ca."
    },
    {
      "id": "tha-ap440:5.1",
      "pali": "Devabhūto manusso vā,"
    },
    {
      "id": "tha-ap440:5.2",
      "pali": "jāto vā aññajātiyā;"
    },
    {
      "id": "tha-ap440:5.3",
      "pali": "Sabbattha sukhito hotu,"
    },
    {
      "id": "tha-ap440:5.4",
      "pali": "mā ca te byādhimāgamā’."
    },
    {
      "id": "tha-ap440:6.1",
      "pali": "Idaṁ vatvāna sambuddho,"
    },
    {
      "id": "tha-ap440:6.2",
      "pali": "sayambhū aparājito;"
    },
    {
      "id": "tha-ap440:6.3",
      "pali": "Nabhaṁ abbhuggamī dhīro,"
    },
    {
      "id": "tha-ap440:6.4",
      "pali": "haṁsarājāva ambare."
    },
    {
      "id": "tha-ap440:7.1",
      "pali": "Yato harītakaṁ dinnaṁ,"
    },
    {
      "id": "tha-ap440:7.2",
      "pali": "sayambhussa mahesino;"
    },
    {
      "id": "tha-ap440:7.3",
      "pali": "Imaṁ jātiṁ upādāya,"
    },
    {
      "id": "tha-ap440:7.4",
      "pali": "byādhi me nupapajjatha."
    },
    {
      "id": "tha-ap440:8.1",
      "pali": "Ayaṁ pacchimako mayhaṁ,"
    },
    {
      "id": "tha-ap440:8.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap440:8.3",
      "pali": "Tisso vijjā sacchikatā,"
    },
    {
      "id": "tha-ap440:8.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap440:9.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap440:9.2",
      "pali": "bhesajjamadadiṁ tadā;"
    },
    {
      "id": "tha-ap440:9.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap440:9.4",
      "pali": "bhesajjassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap440:10.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap440:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap440:10.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap440:11.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap440:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap440:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap440:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap440:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap440:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap440:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā harītakadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap440:14.1",
      "pali": "Harītakadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
