{
  "uid": "iti88",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti88:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti88:2.1",
      "pali": "“Tayome, bhikkhave, antarāmalā antarāamittā antarāsapattā antarāvadhakā antarāpaccatthikā."
    },
    {
      "id": "iti88:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti88:2.3",
      "pali": "Lobho, bhikkhave, antarāmalo antarāamitto antarāsapatto antarāvadhako antarāpaccatthiko."
    },
    {
      "id": "iti88:2.4",
      "pali": "Doso, bhikkhave, antarāmalo antarāamitto antarāsapatto antarāvadhako antarāpaccatthiko."
    },
    {
      "id": "iti88:2.5",
      "pali": "Moho, bhikkhave, antarāmalo antarāamitto antarāsapatto antarāvadhako antarāpaccatthiko."
    },
    {
      "id": "iti88:2.6",
      "pali": "Ime kho, bhikkhave, tayo antarāmalā antarāamittā antarāsapattā antarāvadhakā antarāpaccatthikā”ti."
    },
    {
      "id": "iti88:2.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti88:2.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti88:3.1",
      "pali": "“Anatthajanano lobho,"
    },
    {
      "id": "iti88:3.2",
      "pali": "lobho cittappakopano;"
    },
    {
      "id": "iti88:3.3",
      "pali": "Bhayamantarato jātaṁ,"
    },
    {
      "id": "iti88:3.4",
      "pali": "taṁ jano nāvabujjhati."
    },
    {
      "id": "iti88:4.1",
      "pali": "Luddho atthaṁ na jānāti,"
    },
    {
      "id": "iti88:4.2",
      "pali": "luddho dhammaṁ na passati;"
    },
    {
      "id": "iti88:4.3",
      "pali": "Andhatamaṁ tadā hoti,"
    },
    {
      "id": "iti88:4.4",
      "pali": "yaṁ lobho sahate naraṁ."
    },
    {
      "id": "iti88:5.1",
      "pali": "Yo ca lobhaṁ pahantvāna,"
    },
    {
      "id": "iti88:5.2",
      "pali": "lobhaneyye na lubbhati;"
    },
    {
      "id": "iti88:5.3",
      "pali": "Lobho pahīyate tamhā,"
    },
    {
      "id": "iti88:5.4",
      "pali": "udabindūva pokkharā."
    },
    {
      "id": "iti88:6.1",
      "pali": "Anatthajanano doso,"
    },
    {
      "id": "iti88:6.2",
      "pali": "doso cittappakopano;"
    },
    {
      "id": "iti88:6.3",
      "pali": "Bhayamantarato jātaṁ,"
    },
    {
      "id": "iti88:6.4",
      "pali": "taṁ jano nāvabujjhati."
    },
    {
      "id": "iti88:7.1",
      "pali": "Duṭṭho atthaṁ na jānāti,"
    },
    {
      "id": "iti88:7.2",
      "pali": "duṭṭho dhammaṁ na passati;"
    },
    {
      "id": "iti88:7.3",
      "pali": "Andhatamaṁ tadā hoti,"
    },
    {
      "id": "iti88:7.4",
      "pali": "yaṁ doso sahate naraṁ."
    },
    {
      "id": "iti88:8.1",
      "pali": "Yo ca dosaṁ pahantvāna,"
    },
    {
      "id": "iti88:8.2",
      "pali": "dosaneyye na dussati;"
    },
    {
      "id": "iti88:8.3",
      "pali": "Doso pahīyate tamhā,"
    },
    {
      "id": "iti88:8.4",
      "pali": "tālapakkaṁva bandhanā."
    },
    {
      "id": "iti88:9.1",
      "pali": "Anatthajanano moho,"
    },
    {
      "id": "iti88:9.2",
      "pali": "moho cittappakopano;"
    },
    {
      "id": "iti88:9.3",
      "pali": "Bhayamantarato jātaṁ,"
    },
    {
      "id": "iti88:9.4",
      "pali": "taṁ jano nāvabujjhati."
    },
    {
      "id": "iti88:10.1",
      "pali": "Mūḷho atthaṁ na jānāti,"
    },
    {
      "id": "iti88:10.2",
      "pali": "mūḷho dhammaṁ na passati;"
    },
    {
      "id": "iti88:10.3",
      "pali": "Andhatamaṁ tadā hoti,"
    },
    {
      "id": "iti88:10.4",
      "pali": "yaṁ moho sahate naraṁ."
    },
    {
      "id": "iti88:11.1",
      "pali": "Yo ca mohaṁ pahantvāna,"
    },
    {
      "id": "iti88:11.2",
      "pali": "mohaneyye na muyhati;"
    },
    {
      "id": "iti88:11.3",
      "pali": "Mohaṁ vihanti so sabbaṁ,"
    },
    {
      "id": "iti88:11.4",
      "pali": "ādiccovudayaṁ taman”ti."
    },
    {
      "id": "iti88:12.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti88:12.2",
      "pali": "Navamaṁ."
    }
  ]
}
