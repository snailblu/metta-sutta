{
  "uid": "snp5.13",
  "title": "Bhadrāvudhamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.13:1.1",
      "pali": "“Okañjahaṁ taṇhacchidaṁ anejaṁ,"
    },
    {
      "id": "snp5.13:1.2",
      "pali": "(iccāyasmā bhadrāvudho)"
    },
    {
      "id": "snp5.13:1.3",
      "pali": "Nandiñjahaṁ oghatiṇṇaṁ vimuttaṁ;"
    },
    {
      "id": "snp5.13:1.4",
      "pali": "Kappañjahaṁ abhiyāce sumedhaṁ,"
    },
    {
      "id": "snp5.13:1.5",
      "pali": "Sutvāna nāgassa apanamissanti ito."
    },
    {
      "id": "snp5.13:2.1",
      "pali": "Nānājanā janapadehi saṅgatā,"
    },
    {
      "id": "snp5.13:2.2",
      "pali": "Tava vīra vākyaṁ abhikaṅkhamānā;"
    },
    {
      "id": "snp5.13:2.3",
      "pali": "Tesaṁ tuvaṁ sādhu viyākarohi,"
    },
    {
      "id": "snp5.13:2.4",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "snp5.13:3.1",
      "pali": "“Ādānataṇhaṁ vinayetha sabbaṁ,"
    },
    {
      "id": "snp5.13:3.2",
      "pali": "(bhadrāvudhāti bhagavā"
    },
    {
      "id": "snp5.13:3.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "snp5.13:3.4",
      "pali": "Yaṁ yañhi lokasmimupādiyanti,"
    },
    {
      "id": "snp5.13:3.5",
      "pali": "Teneva māro anveti jantuṁ."
    },
    {
      "id": "snp5.13:4.1",
      "pali": "Tasmā pajānaṁ na upādiyetha,"
    },
    {
      "id": "snp5.13:4.2",
      "pali": "Bhikkhu sato kiñcanaṁ sabbaloke;"
    },
    {
      "id": "snp5.13:4.3",
      "pali": "Ādānasatte iti pekkhamāno,"
    },
    {
      "id": "snp5.13:4.4",
      "pali": "Pajaṁ imaṁ maccudheyye visattan”ti."
    },
    {
      "id": "snp5.13:4.5",
      "pali": "Bhadrāvudhamāṇavapucchā dvādasamā."
    }
  ]
}
