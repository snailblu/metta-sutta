{
  "uid": "tha-ap409",
  "title": "Hemakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap409:1.1",
      "pali": "“Pabbhārakūṭaṁ nissāya,"
    },
    {
      "id": "tha-ap409:1.2",
      "pali": "anomo nāma tāpaso;"
    },
    {
      "id": "tha-ap409:1.3",
      "pali": "Assamaṁ sukataṁ katvā,"
    },
    {
      "id": "tha-ap409:1.4",
      "pali": "paṇṇasāle vasī tadā."
    },
    {
      "id": "tha-ap409:2.1",
      "pali": "Siddhaṁ tassa tapo kammaṁ,"
    },
    {
      "id": "tha-ap409:2.2",
      "pali": "siddhipatto sake bale;"
    },
    {
      "id": "tha-ap409:2.3",
      "pali": "Sakasāmaññavikkanto,"
    },
    {
      "id": "tha-ap409:2.4",
      "pali": "ātāpī nipako muni."
    },
    {
      "id": "tha-ap409:3.1",
      "pali": "Visārado sasamaye,"
    },
    {
      "id": "tha-ap409:3.2",
      "pali": "paravāde ca kovido;"
    },
    {
      "id": "tha-ap409:3.3",
      "pali": "Paṭṭho bhūmantalikkhamhi,"
    },
    {
      "id": "tha-ap409:3.4",
      "pali": "uppātamhi ca kovido."
    },
    {
      "id": "tha-ap409:4.1",
      "pali": "Vītasoko nirārambho,"
    },
    {
      "id": "tha-ap409:4.2",
      "pali": "appāhāro alolupo;"
    },
    {
      "id": "tha-ap409:4.3",
      "pali": "Lābhālābhena santuṭṭho,"
    },
    {
      "id": "tha-ap409:4.4",
      "pali": "jhāyī jhānarato muni."
    },
    {
      "id": "tha-ap409:5.1",
      "pali": "Piyadassī nāma sambuddho,"
    },
    {
      "id": "tha-ap409:5.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap409:5.3",
      "pali": "Satte tāretukāmo so,"
    },
    {
      "id": "tha-ap409:5.4",
      "pali": "karuṇāya pharī tadā."
    },
    {
      "id": "tha-ap409:6.1",
      "pali": "Bodhaneyyaṁ janaṁ disvā,"
    },
    {
      "id": "tha-ap409:6.2",
      "pali": "piyadassī mahāmuni;"
    },
    {
      "id": "tha-ap409:6.3",
      "pali": "Cakkavāḷasahassampi,"
    },
    {
      "id": "tha-ap409:6.4",
      "pali": "gantvā ovadate muni."
    },
    {
      "id": "tha-ap409:7.1",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap409:7.2",
      "pali": "mamassamamupāgami;"
    },
    {
      "id": "tha-ap409:7.3",
      "pali": "Na diṭṭho me jino pubbe,"
    },
    {
      "id": "tha-ap409:7.4",
      "pali": "na sutopi ca kassaci."
    },
    {
      "id": "tha-ap409:8.1",
      "pali": "Uppātā supinā mayhaṁ,"
    },
    {
      "id": "tha-ap409:8.2",
      "pali": "lakkhaṇā suppakāsitā;"
    },
    {
      "id": "tha-ap409:8.3",
      "pali": "Paṭṭho bhūmantalikkhamhi,"
    },
    {
      "id": "tha-ap409:8.4",
      "pali": "nakkhattapadakovido."
    },
    {
      "id": "tha-ap409:9.1",
      "pali": "Sohaṁ buddhassa sutvāna,"
    },
    {
      "id": "tha-ap409:9.2",
      "pali": "tattha cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap409:9.3",
      "pali": "Tiṭṭhanto vā nisinno vā,"
    },
    {
      "id": "tha-ap409:9.4",
      "pali": "sarāmi niccakālikaṁ."
    },
    {
      "id": "tha-ap409:10.1",
      "pali": "Mayi evaṁ sarantamhi,"
    },
    {
      "id": "tha-ap409:10.2",
      "pali": "bhagavāpi anussari;"
    },
    {
      "id": "tha-ap409:10.3",
      "pali": "Buddhaṁ anussarantassa,"
    },
    {
      "id": "tha-ap409:10.4",
      "pali": "pīti me hoti tāvade."
    },
    {
      "id": "tha-ap409:11.1",
      "pali": "Kālañca punarāgamma,"
    },
    {
      "id": "tha-ap409:11.2",
      "pali": "upesi maṁ mahāmuni;"
    },
    {
      "id": "tha-ap409:11.3",
      "pali": "Sampattepi na jānāmi,"
    },
    {
      "id": "tha-ap409:11.4",
      "pali": "ayaṁ buddho mahāmuni."
    },
    {
      "id": "tha-ap409:12.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap409:12.2",
      "pali": "piyadassī mahāmuni;"
    },
    {
      "id": "tha-ap409:12.3",
      "pali": "Sañjānāpesi attānaṁ,"
    },
    {
      "id": "tha-ap409:12.4",
      "pali": "‘ahaṁ buddho sadevake’."
    },
    {
      "id": "tha-ap409:13.1",
      "pali": "Sañjānitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap409:13.2",
      "pali": "piyadassiṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap409:13.3",
      "pali": "Sakaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap409:13.4",
      "pali": "idaṁ vacanamabraviṁ."
    },
    {
      "id": "tha-ap409:14.1",
      "pali": "‘Aññe pīṭhe ca pallaṅke,"
    },
    {
      "id": "tha-ap409:14.2",
      "pali": "āsandīsu nisīdare;"
    },
    {
      "id": "tha-ap409:14.3",
      "pali": "Tuvampi sabbadassāvī,"
    },
    {
      "id": "tha-ap409:14.4",
      "pali": "nisīda ratanāsane’."
    },
    {
      "id": "tha-ap409:15.1",
      "pali": "Sabbaratanamayaṁ pīṭhaṁ,"
    },
    {
      "id": "tha-ap409:15.2",
      "pali": "nimminitvāna tāvade;"
    },
    {
      "id": "tha-ap409:15.3",
      "pali": "Piyadassissa munino,"
    },
    {
      "id": "tha-ap409:15.4",
      "pali": "adāsiṁ iddhinimmitaṁ."
    },
    {
      "id": "tha-ap409:16.1",
      "pali": "Ratane ca nisinnassa,"
    },
    {
      "id": "tha-ap409:16.2",
      "pali": "pīṭhake iddhinimmite;"
    },
    {
      "id": "tha-ap409:16.3",
      "pali": "Kumbhamattaṁ jambuphalaṁ,"
    },
    {
      "id": "tha-ap409:16.4",
      "pali": "adāsiṁ tāvade ahaṁ."
    },
    {
      "id": "tha-ap409:17.1",
      "pali": "Mama hāsaṁ janetvāna,"
    },
    {
      "id": "tha-ap409:17.2",
      "pali": "paribhuñji mahāmuni;"
    },
    {
      "id": "tha-ap409:17.3",
      "pali": "Tadā cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap409:17.4",
      "pali": "satthāraṁ abhivādayiṁ."
    },
    {
      "id": "tha-ap409:18.1",
      "pali": "Piyadassī tu bhagavā,"
    },
    {
      "id": "tha-ap409:18.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap409:18.3",
      "pali": "Ratanāsanamāsīno,"
    },
    {
      "id": "tha-ap409:18.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap409:19.1",
      "pali": "‘Yo me ratanamayaṁ pīṭhaṁ,"
    },
    {
      "id": "tha-ap409:19.2",
      "pali": "amatañca phalaṁ adā;"
    },
    {
      "id": "tha-ap409:19.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap409:19.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap409:20.1",
      "pali": "Sattasattati kappāni,"
    },
    {
      "id": "tha-ap409:20.2",
      "pali": "devaloke ramissati;"
    },
    {
      "id": "tha-ap409:20.3",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap409:20.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap409:21.1",
      "pali": "Dvattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap409:21.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap409:21.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap409:21.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap409:22.1",
      "pali": "Soṇṇamayaṁ rūpimayaṁ,"
    },
    {
      "id": "tha-ap409:22.2",
      "pali": "pallaṅkaṁ sukataṁ bahuṁ;"
    },
    {
      "id": "tha-ap409:22.3",
      "pali": "Lohitaṅgamayañceva,"
    },
    {
      "id": "tha-ap409:22.4",
      "pali": "lacchati ratanāmayaṁ."
    },
    {
      "id": "tha-ap409:23.1",
      "pali": "Caṅkamantampi manujaṁ,"
    },
    {
      "id": "tha-ap409:23.2",
      "pali": "puññakammasamaṅginaṁ;"
    },
    {
      "id": "tha-ap409:23.3",
      "pali": "Pallaṅkāni anekāni,"
    },
    {
      "id": "tha-ap409:23.4",
      "pali": "parivāressare tadā."
    },
    {
      "id": "tha-ap409:24.1",
      "pali": "Kūṭāgārā ca pāsādā,"
    },
    {
      "id": "tha-ap409:24.2",
      "pali": "sayanañca mahārahaṁ;"
    },
    {
      "id": "tha-ap409:24.3",
      "pali": "Imassa cittamaññāya,"
    },
    {
      "id": "tha-ap409:24.4",
      "pali": "nibbattissanti tāvade."
    },
    {
      "id": "tha-ap409:25.1",
      "pali": "Saṭṭhi nāgasahassāni,"
    },
    {
      "id": "tha-ap409:25.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap409:25.3",
      "pali": "Suvaṇṇakacchā mātaṅgā,"
    },
    {
      "id": "tha-ap409:25.4",
      "pali": "hemakappanavāsasā."
    },
    {
      "id": "tha-ap409:26.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap409:26.2",
      "pali": "tomaraṅkusapāṇibhi;"
    },
    {
      "id": "tha-ap409:26.3",
      "pali": "Imaṁ paricarissanti,"
    },
    {
      "id": "tha-ap409:26.4",
      "pali": "ratnapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap409:27.1",
      "pali": "Saṭṭhi assasahassāni,"
    },
    {
      "id": "tha-ap409:27.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap409:27.3",
      "pali": "Ājānīyāva jātiyā,"
    },
    {
      "id": "tha-ap409:27.4",
      "pali": "sindhavā sīghavāhino."
    },
    {
      "id": "tha-ap409:28.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap409:28.2",
      "pali": "illiyācāpadhāribhi;"
    },
    {
      "id": "tha-ap409:28.3",
      "pali": "Tepimaṁ paricarissanti,"
    },
    {
      "id": "tha-ap409:28.4",
      "pali": "ratnapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap409:29.1",
      "pali": "Saṭṭhi rathasahassāni,"
    },
    {
      "id": "tha-ap409:29.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap409:29.3",
      "pali": "Dīpā athopi veyagghā,"
    },
    {
      "id": "tha-ap409:29.4",
      "pali": "sannaddhā ussitaddhajā."
    },
    {
      "id": "tha-ap409:30.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "tha-ap409:30.2",
      "pali": "cāpahatthehi vammibhi;"
    },
    {
      "id": "tha-ap409:30.3",
      "pali": "Parivāressantimaṁ niccaṁ,"
    },
    {
      "id": "tha-ap409:30.4",
      "pali": "ratnapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap409:31.1",
      "pali": "Saṭṭhi dhenusahassāni,"
    },
    {
      "id": "tha-ap409:31.2",
      "pali": "dohaññā puṅgavūsabhe;"
    },
    {
      "id": "tha-ap409:31.3",
      "pali": "Vacchake janayissanti,"
    },
    {
      "id": "tha-ap409:31.4",
      "pali": "ratnapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap409:32.1",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "tha-ap409:32.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "tha-ap409:32.3",
      "pali": "Vicittavatthābharaṇā,"
    },
    {
      "id": "tha-ap409:32.4",
      "pali": "āmukkamaṇikuṇḍalā."
    },
    {
      "id": "tha-ap409:33.1",
      "pali": "Aḷārapamhā hasulā,"
    },
    {
      "id": "tha-ap409:33.2",
      "pali": "susaññā tanumajjhimā;"
    },
    {
      "id": "tha-ap409:33.3",
      "pali": "Parivāressantimaṁ niccaṁ,"
    },
    {
      "id": "tha-ap409:33.4",
      "pali": "ratnapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap409:34.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap409:34.2",
      "pali": "gotamo nāma cakkhumā;"
    },
    {
      "id": "tha-ap409:34.3",
      "pali": "Tamandhakāraṁ vidhamitvā,"
    },
    {
      "id": "tha-ap409:34.4",
      "pali": "buddho loke bhavissati."
    },
    {
      "id": "tha-ap409:35.1",
      "pali": "Tassa dassanamāgamma,"
    },
    {
      "id": "tha-ap409:35.2",
      "pali": "pabbajissatikiñcano;"
    },
    {
      "id": "tha-ap409:35.3",
      "pali": "Tosayitvāna satthāraṁ,"
    },
    {
      "id": "tha-ap409:35.4",
      "pali": "sāsanebhiramissati."
    },
    {
      "id": "tha-ap409:36.1",
      "pali": "Tassa dhammaṁ suṇitvāna,"
    },
    {
      "id": "tha-ap409:36.2",
      "pali": "kilese ghātayissati;"
    },
    {
      "id": "tha-ap409:36.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap409:36.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap409:37.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "tha-ap409:37.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "tha-ap409:37.3",
      "pali": "Uttamatthaṁ patthayanto,"
    },
    {
      "id": "tha-ap409:37.4",
      "pali": "sāsane viharāmahaṁ."
    },
    {
      "id": "tha-ap409:38.1",
      "pali": "Idaṁ pacchimakaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap409:38.2",
      "pali": "carimo vattate bhavo;"
    },
    {
      "id": "tha-ap409:38.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap409:38.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap409:39.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap409:39.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap409:39.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap409:40.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap409:40.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap409:40.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap409:41.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap409:41.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap409:41.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap409:42.1",
      "pali": "Itthaṁ sudaṁ āyasmā hemako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap409:43.1",
      "pali": "Hemakattherassāpadānaṁ sattamaṁ."
    },
    {
      "id": "tha-ap409:43.2",
      "pali": "Sattarasamaṁ bhāṇavāraṁ."
    }
  ]
}
