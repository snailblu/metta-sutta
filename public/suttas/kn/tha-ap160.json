{
  "uid": "tha-ap160",
  "title": "Nāgapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap160:1.1",
      "pali": "“Suvaccho nāma nāmena,"
    },
    {
      "id": "tha-ap160:1.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap160:1.3",
      "pali": "Purakkhato sasissehi,"
    },
    {
      "id": "tha-ap160:1.4",
      "pali": "vasate pabbatantare."
    },
    {
      "id": "tha-ap160:2.1",
      "pali": "Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap160:2.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap160:2.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap160:2.4",
      "pali": "āgacchi mama santikaṁ."
    },
    {
      "id": "tha-ap160:3.1",
      "pali": "Vehāsamhi caṅkamati,"
    },
    {
      "id": "tha-ap160:3.2",
      "pali": "dhūpāyati jalate tathā;"
    },
    {
      "id": "tha-ap160:3.3",
      "pali": "Hāsaṁ mamaṁ viditvāna,"
    },
    {
      "id": "tha-ap160:3.4",
      "pali": "pakkāmi pācināmukho."
    },
    {
      "id": "tha-ap160:4.1",
      "pali": "Tañca acchariyaṁ disvā,"
    },
    {
      "id": "tha-ap160:4.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "tha-ap160:4.3",
      "pali": "Nāgapupphaṁ gahetvāna,"
    },
    {
      "id": "tha-ap160:4.4",
      "pali": "gatamaggamhi okiriṁ."
    },
    {
      "id": "tha-ap160:5.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap160:5.2",
      "pali": "yaṁ pupphaṁ okiriṁ ahaṁ;"
    },
    {
      "id": "tha-ap160:5.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap160:5.4",
      "pali": "duggatiṁ nupapajjahaṁ."
    },
    {
      "id": "tha-ap160:6.1",
      "pali": "Ekattiṁse kappasate,"
    },
    {
      "id": "tha-ap160:6.2",
      "pali": "rājā āsi mahāraho;"
    },
    {
      "id": "tha-ap160:6.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap160:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap160:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap160:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap160:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap160:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā nāgapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap160:9.1",
      "pali": "Nāgapupphiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
