{
  "uid": "thi-ap16",
  "title": "6 Naḷamālikātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap16:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "thi-ap16:1.2",
      "pali": "ahosiṁ kinnarī tadā;"
    },
    {
      "id": "thi-ap16:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "thi-ap16:1.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "thi-ap16:2.1",
      "pali": "Pasannacittā sumanā,"
    },
    {
      "id": "thi-ap16:2.2",
      "pali": "vedajātā katañjalī;"
    },
    {
      "id": "thi-ap16:2.3",
      "pali": "Naḷamālaṁ gahetvāna,"
    },
    {
      "id": "thi-ap16:2.4",
      "pali": "sayambhuṁ abhipūjayiṁ."
    },
    {
      "id": "thi-ap16:3.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap16:3.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap16:3.3",
      "pali": "Jahitvā kinnarīdehaṁ,"
    },
    {
      "id": "thi-ap16:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap16:4.1",
      "pali": "Chattiṁsadevarājūnaṁ,"
    },
    {
      "id": "thi-ap16:4.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap16:4.3",
      "pali": "Manasā patthitaṁ mayhaṁ,"
    },
    {
      "id": "thi-ap16:4.4",
      "pali": "nibbattati yathicchitaṁ."
    },
    {
      "id": "thi-ap16:5.1",
      "pali": "Dasannaṁ cakkavattīnaṁ,"
    },
    {
      "id": "thi-ap16:5.2",
      "pali": "mahesittamakārayiṁ;"
    },
    {
      "id": "thi-ap16:5.3",
      "pali": "Ocitattāva hutvāna,"
    },
    {
      "id": "thi-ap16:5.4",
      "pali": "saṁsarāmi bhavesvahaṁ."
    },
    {
      "id": "thi-ap16:6.1",
      "pali": "Kusalaṁ vijjate mayhaṁ,"
    },
    {
      "id": "thi-ap16:6.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thi-ap16:6.3",
      "pali": "Pūjārahā ahaṁ ajja,"
    },
    {
      "id": "thi-ap16:6.4",
      "pali": "sakyaputtassa sāsane."
    },
    {
      "id": "thi-ap16:7.1",
      "pali": "Visuddhamanasā ajja,"
    },
    {
      "id": "thi-ap16:7.2",
      "pali": "apetamanapāpikā;"
    },
    {
      "id": "thi-ap16:7.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "thi-ap16:7.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "thi-ap16:8.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "thi-ap16:8.2",
      "pali": "yaṁ buddhamabhipūjayiṁ;"
    },
    {
      "id": "thi-ap16:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "thi-ap16:8.4",
      "pali": "naḷamālāyidaṁ phalaṁ."
    },
    {
      "id": "thi-ap16:9.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap16:9.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap16:9.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap16:10.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap16:10.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap16:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap16:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap16:11.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap16:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap16:12.1",
      "pali": "Itthaṁ sudaṁ naḷamālikā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap16:13.1",
      "pali": "Naḷamālikātheriyāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
