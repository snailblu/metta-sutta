{
  "uid": "ja104",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja104:1.1",
      "pali": "“Catubbhi aṭṭhajjhagamā,"
    },
    {
      "id": "ja104:1.2",
      "pali": "aṭṭhāhipi ca soḷasa;"
    },
    {
      "id": "ja104:1.3",
      "pali": "Soḷasāhi ca bāttiṁsa,"
    },
    {
      "id": "ja104:1.4",
      "pali": "atricchaṁ cakkamāsado;"
    },
    {
      "id": "ja104:1.5",
      "pali": "Icchāhatassa posassa,"
    },
    {
      "id": "ja104:1.6",
      "pali": "cakkaṁ bhamati matthake”ti."
    },
    {
      "id": "ja104:2.1",
      "pali": "Mittavindakajātakaṁ catutthaṁ."
    }
  ]
}
