{
  "uid": "ja273",
  "title": "Udapānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja273:1.1",
      "pali": "“Ko nu uddhitabhattova,"
    },
    {
      "id": "ja273:1.2",
      "pali": "pūrahatthova brāhmaṇo;"
    },
    {
      "id": "ja273:1.3",
      "pali": "Kahaṁ nu bhikkhaṁ acari,"
    },
    {
      "id": "ja273:1.4",
      "pali": "kaṁ saddhaṁ upasaṅkami”."
    },
    {
      "id": "ja273:2.1",
      "pali": "“Ahaṁ kapismi dummedho,"
    },
    {
      "id": "ja273:2.2",
      "pali": "anāmāsāni āmasiṁ;"
    },
    {
      "id": "ja273:2.3",
      "pali": "Tvaṁ maṁ mocaya bhaddaṁ te,"
    },
    {
      "id": "ja273:2.4",
      "pali": "mutto gaccheyya pabbataṁ”."
    },
    {
      "id": "ja273:3.1",
      "pali": "“Kacchapā kassapā honti,"
    },
    {
      "id": "ja273:3.2",
      "pali": "Koṇḍaññā honti makkaṭā;"
    },
    {
      "id": "ja273:3.3",
      "pali": "Muñca kassapa koṇḍaññaṁ,"
    },
    {
      "id": "ja273:3.4",
      "pali": "Kataṁ methunakaṁ tayā”ti."
    },
    {
      "id": "ja273:4.1",
      "pali": "Kacchapajātakaṁ tatiyaṁ."
    }
  ]
}
