{
  "uid": "tha-ap446",
  "title": "4 Bhallātadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap446:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap446:1.2",
      "pali": "Dvattiṁsavaralakkhaṇaṁ;"
    },
    {
      "id": "tha-ap446:1.3",
      "pali": "Vipinaggena gacchantaṁ,"
    },
    {
      "id": "tha-ap446:1.4",
      "pali": "Sālarājaṁva phullitaṁ."
    },
    {
      "id": "tha-ap446:2.1",
      "pali": "Tiṇattharaṁ paññāpetvā,"
    },
    {
      "id": "tha-ap446:2.2",
      "pali": "buddhaseṭṭhaṁ ayācahaṁ;"
    },
    {
      "id": "tha-ap446:2.3",
      "pali": "‘Anukampatu maṁ buddho,"
    },
    {
      "id": "tha-ap446:2.4",
      "pali": "bhikkhaṁ icchāmi dātave’."
    },
    {
      "id": "tha-ap446:3.1",
      "pali": "Anukampako kāruṇiko,"
    },
    {
      "id": "tha-ap446:3.2",
      "pali": "atthadassī mahāyaso;"
    },
    {
      "id": "tha-ap446:3.3",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap446:3.4",
      "pali": "orūhi mama assame."
    },
    {
      "id": "tha-ap446:4.1",
      "pali": "Orohitvāna sambuddho,"
    },
    {
      "id": "tha-ap446:4.2",
      "pali": "nisīdi paṇṇasanthare;"
    },
    {
      "id": "tha-ap446:4.3",
      "pali": "Bhallātakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap446:4.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap446:5.1",
      "pali": "Mama nijjhāyamānassa,"
    },
    {
      "id": "tha-ap446:5.2",
      "pali": "paribhuñji tadā jino;"
    },
    {
      "id": "tha-ap446:5.3",
      "pali": "Tattha cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap446:5.4",
      "pali": "abhivandiṁ tadā jinaṁ."
    },
    {
      "id": "tha-ap446:6.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap446:6.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap446:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap446:6.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap446:7.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap446:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap446:7.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap446:8.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap446:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap446:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap446:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap446:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap446:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap446:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhallātadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap446:11.1",
      "pali": "Bhallātadāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
