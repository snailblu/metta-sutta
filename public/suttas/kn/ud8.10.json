{
  "uid": "ud8.10",
  "title": "Dutiyadabbasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud8.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud8.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud8.10:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "ud8.10:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "ud8.10:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "ud8.10:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "ud8.10:2.1",
      "pali": "“Dabbassa, bhikkhave, mallaputtassa vehāsaṁ abbhuggantvā ākāse antalikkhe pallaṅkena nisīditvā tejodhātuṁ samāpajjitvā vuṭṭhahitvā parinibbutassa sarīrassa jhāyamānassa ḍayhamānassa neva chārikā paññāyittha na masi."
    },
    {
      "id": "ud8.10:2.2",
      "pali": "Seyyathāpi nāma sappissa vā telassa vā jhāyamānassa ḍayhamānassa neva chārikā paññāyati na masi;"
    },
    {
      "id": "ud8.10:2.3",
      "pali": "evamevaṁ kho, bhikkhave, dabbassa mallaputtassa vehāsaṁ abbhuggantvā ākāse antalikkhe pallaṅkena nisīditvā tejodhātuṁ samāpajjitvā vuṭṭhahitvā parinibbutassa sarīrassa jhāyamānassa ḍayhamānassa neva chārikā paññāyittha na masī”ti."
    },
    {
      "id": "ud8.10:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud8.10:4.1",
      "pali": "“Ayoghanahatasseva,"
    },
    {
      "id": "ud8.10:4.2",
      "pali": "jalato jātavedaso;"
    },
    {
      "id": "ud8.10:4.3",
      "pali": "Anupubbūpasantassa,"
    },
    {
      "id": "ud8.10:4.4",
      "pali": "yathā na ñāyate gati."
    },
    {
      "id": "ud8.10:5.1",
      "pali": "Evaṁ sammāvimuttānaṁ,"
    },
    {
      "id": "ud8.10:5.2",
      "pali": "kāmabandhoghatārinaṁ;"
    },
    {
      "id": "ud8.10:5.3",
      "pali": "Paññāpetuṁ gati natthi,"
    },
    {
      "id": "ud8.10:5.4",
      "pali": "pattānaṁ acalaṁ sukhan”ti."
    },
    {
      "id": "ud8.10:5.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "ud8.10:5.6",
      "pali": "Pāṭaligāmiyavaggo aṭṭhamo."
    },
    {
      "id": "ud8.10:6.1",
      "pali": "Nibbānā caturo vuttā,"
    },
    {
      "id": "ud8.10:6.2",
      "pali": "cundo pāṭaligāmiyā;"
    },
    {
      "id": "ud8.10:6.3",
      "pali": "Dvidhāpatho visākhā ca,"
    },
    {
      "id": "ud8.10:6.4",
      "pali": "dabbena saha te dasāti."
    },
    {
      "id": "ud8.10:7.1",
      "pali": "Vaggamidaṁ paṭhamaṁ varabodhi,"
    },
    {
      "id": "ud8.10:7.2",
      "pali": "Vaggamidaṁ dutiyaṁ mucalindo;"
    },
    {
      "id": "ud8.10:7.3",
      "pali": "Nandakavaggavaro tatiyo tu,"
    },
    {
      "id": "ud8.10:7.4",
      "pali": "Meghiyavaggavaro ca catuttho."
    },
    {
      "id": "ud8.10:8.1",
      "pali": "Pañcamavaggavarantidha soṇo,"
    },
    {
      "id": "ud8.10:8.2",
      "pali": "Chaṭṭhamavaggavaranti jaccandho;"
    },
    {
      "id": "ud8.10:8.3",
      "pali": "Sattamavaggavaranti ca cūḷo,"
    },
    {
      "id": "ud8.10:8.4",
      "pali": "Pāṭaligāmiyamaṭṭhamavaggo."
    },
    {
      "id": "ud8.10:9.1",
      "pali": "Asītimanūnakasuttavaraṁ,"
    },
    {
      "id": "ud8.10:9.2",
      "pali": "Vaggamidaṭṭhakaṁ suvibhattaṁ;"
    },
    {
      "id": "ud8.10:9.3",
      "pali": "Dassitaṁ cakkhumatā vimalena,"
    },
    {
      "id": "ud8.10:9.4",
      "pali": "Addhā hi taṁ udānamitīdamāhu."
    },
    {
      "id": "ud8.10:9.5",
      "pali": "Udānapāḷi niṭṭhitā."
    }
  ]
}
