{
  "uid": "tha-ap245",
  "title": "Naḷinakesariyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap245:1.1",
      "pali": "“Jātassarassa vemajjhe,"
    },
    {
      "id": "tha-ap245:1.2",
      "pali": "vasāmi jalakukkuṭo;"
    },
    {
      "id": "tha-ap245:1.3",
      "pali": "Addasāhaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap245:1.4",
      "pali": "gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap245:2.1",
      "pali": "Tuṇḍena kesariṁ gayha,"
    },
    {
      "id": "tha-ap245:2.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap245:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap245:2.4",
      "pali": "tissassa lokabandhuno."
    },
    {
      "id": "tha-ap245:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap245:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap245:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap245:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap245:4.1",
      "pali": "Tesattatimhi kappamhi,"
    },
    {
      "id": "tha-ap245:4.2",
      "pali": "satta kesaranāmakā;"
    },
    {
      "id": "tha-ap245:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap245:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap245:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap245:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap245:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap245:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā naḷinakesariyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap245:7.1",
      "pali": "Naḷinakesariyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
