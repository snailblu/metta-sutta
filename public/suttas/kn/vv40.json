{
  "uid": "vv40",
  "title": "Mañjiṭṭhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv40:1.1",
      "pali": "“Pabhassaravaravaṇṇanibhe,"
    },
    {
      "id": "vv40:1.2",
      "pali": "Surattavatthavasane;"
    },
    {
      "id": "vv40:1.3",
      "pali": "Mahiddhike candanaruciragatte,"
    },
    {
      "id": "vv40:1.4",
      "pali": "Kā tvaṁ subhe devate vandase mamaṁ."
    },
    {
      "id": "vv40:2.1",
      "pali": "Pallaṅko ca te mahaggho,"
    },
    {
      "id": "vv40:2.2",
      "pali": "Nānāratanacittito ruciro;"
    },
    {
      "id": "vv40:2.3",
      "pali": "Yattha tvaṁ nisinnā virocasi,"
    },
    {
      "id": "vv40:2.4",
      "pali": "Devarājāriva nandane vane."
    },
    {
      "id": "vv40:3.1",
      "pali": "Kiṁ tvaṁ pure sucaritamācarī bhadde,"
    },
    {
      "id": "vv40:3.2",
      "pali": "Kissa kammassa vipākaṁ;"
    },
    {
      "id": "vv40:3.3",
      "pali": "Anubhosi devalokasmiṁ,"
    },
    {
      "id": "vv40:3.4",
      "pali": "Devate pucchitācikkha;"
    },
    {
      "id": "vv40:3.5",
      "pali": "Kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv40:4.1",
      "pali": "“Piṇḍāya te carantassa,"
    },
    {
      "id": "vv40:4.2",
      "pali": "Mālaṁ phāṇitañca adadaṁ bhante;"
    },
    {
      "id": "vv40:4.3",
      "pali": "Tassa kammassidaṁ vipākaṁ,"
    },
    {
      "id": "vv40:4.4",
      "pali": "Anubhomi devalokasmiṁ."
    },
    {
      "id": "vv40:5.1",
      "pali": "Hoti ca me anutāpo,"
    },
    {
      "id": "vv40:5.2",
      "pali": "Aparaddhaṁ dukkhitañca me bhante;"
    },
    {
      "id": "vv40:5.3",
      "pali": "Sāhaṁ dhammaṁ nāssosiṁ,"
    },
    {
      "id": "vv40:5.4",
      "pali": "Sudesitaṁ dhammarājena."
    },
    {
      "id": "vv40:6.1",
      "pali": "Taṁ taṁ vadāmi bhaddante,"
    },
    {
      "id": "vv40:6.2",
      "pali": "‘Yassa me anukampiyo koci;"
    },
    {
      "id": "vv40:6.3",
      "pali": "Dhammesu taṁ samādapetha’,"
    },
    {
      "id": "vv40:6.4",
      "pali": "Sudesitaṁ dhammarājena."
    },
    {
      "id": "vv40:7.1",
      "pali": "Yesaṁ atthi saddhā buddhe,"
    },
    {
      "id": "vv40:7.2",
      "pali": "dhamme ca saṅgharatane;"
    },
    {
      "id": "vv40:7.3",
      "pali": "Te maṁ ativirocanti,"
    },
    {
      "id": "vv40:7.4",
      "pali": "āyunā yasasā siriyā."
    },
    {
      "id": "vv40:8.1",
      "pali": "Patāpena vaṇṇena uttaritarā,"
    },
    {
      "id": "vv40:8.2",
      "pali": "Aññe mahiddhikatarā mayā devā”ti."
    },
    {
      "id": "vv40:9.1",
      "pali": "Pabhassaravimānaṁ dutiyaṁ."
    }
  ]
}
