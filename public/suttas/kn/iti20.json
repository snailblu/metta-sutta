{
  "uid": "iti20",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti20:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti20:2.1",
      "pali": "“Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ paduṭṭhacittaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "iti20:2.2",
      "pali": "‘imamhi cāyaṁ samaye puggalo kālaṁ kareyya yathābhataṁ nikkhitto evaṁ niraye’."
    },
    {
      "id": "iti20:2.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "iti20:2.4",
      "pali": "Cittaṁ hissa, bhikkhave, paduṭṭhaṁ."
    },
    {
      "id": "iti20:2.5",
      "pali": "Cetopadosahetu kho pana, bhikkhave, evam’idhekacce sattā kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjantī”ti."
    },
    {
      "id": "iti20:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti20:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti20:3.1",
      "pali": "“Paduṭṭhacittaṁ ñatvāna,"
    },
    {
      "id": "iti20:3.2",
      "pali": "ekaccaṁ idha puggalaṁ;"
    },
    {
      "id": "iti20:3.3",
      "pali": "Etamatthañca byākāsi,"
    },
    {
      "id": "iti20:3.4",
      "pali": "buddho bhikkhūna santike."
    },
    {
      "id": "iti20:4.1",
      "pali": "Imamhi cāyaṁ samaye,"
    },
    {
      "id": "iti20:4.2",
      "pali": "kālaṁ kayirātha puggalo;"
    },
    {
      "id": "iti20:4.3",
      "pali": "Nirayaṁ upapajjeyya,"
    },
    {
      "id": "iti20:4.4",
      "pali": "cittaṁ hissa padūsitaṁ."
    },
    {
      "id": "iti20:5.1",
      "pali": "Yathā haritvā nikkhipeyya,"
    },
    {
      "id": "iti20:5.2",
      "pali": "evamevaṁ tathāvidho;"
    },
    {
      "id": "iti20:5.3",
      "pali": "Cetopadosahetu hi,"
    },
    {
      "id": "iti20:5.4",
      "pali": "sattā gacchanti duggatin”ti."
    },
    {
      "id": "iti20:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti20:6.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti20:6.3",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "iti20:7.1",
      "pali": "Moho kodho atha makkho,"
    },
    {
      "id": "iti20:7.2",
      "pali": "Vijjā taṇhā sekhaduve ca;"
    },
    {
      "id": "iti20:7.3",
      "pali": "Bhedo sāmaggipuggalo,"
    },
    {
      "id": "iti20:7.4",
      "pali": "Vaggamāhu dutiyanti vuccatīti."
    }
  ]
}
