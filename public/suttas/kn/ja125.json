{
  "uid": "ja125",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja125:1.1",
      "pali": "“Bahumpi so vikattheyya,"
    },
    {
      "id": "ja125:1.2",
      "pali": "aññaṁ janapadaṁ gato;"
    },
    {
      "id": "ja125:1.3",
      "pali": "Anvāgantvāna dūseyya,"
    },
    {
      "id": "ja125:1.4",
      "pali": "bhuñja bhoge kaṭāhakā”ti."
    },
    {
      "id": "ja125:2.1",
      "pali": "Kaṭāhakajātakaṁ pañcamaṁ."
    }
  ]
}
