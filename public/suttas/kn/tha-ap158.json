{
  "uid": "tha-ap158",
  "title": "Kadambapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap158:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap158:1.2",
      "pali": "kukkuṭo nāma pabbato;"
    },
    {
      "id": "tha-ap158:1.3",
      "pali": "Tamhi pabbatapādamhi,"
    },
    {
      "id": "tha-ap158:1.4",
      "pali": "satta buddhā vasanti te."
    },
    {
      "id": "tha-ap158:2.1",
      "pali": "Kadambaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap158:2.2",
      "pali": "dīparājaṁva uggataṁ;"
    },
    {
      "id": "tha-ap158:2.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "tha-ap158:2.4",
      "pali": "satta buddhe samokiriṁ."
    },
    {
      "id": "tha-ap158:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap158:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap158:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap158:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap158:4.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap158:4.2",
      "pali": "sattāsuṁ pupphanāmakā;"
    },
    {
      "id": "tha-ap158:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap158:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap158:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap158:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap158:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap158:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kadambapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap158:7.1",
      "pali": "Kadambapupphiyattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
