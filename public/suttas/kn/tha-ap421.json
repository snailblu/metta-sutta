{
  "uid": "tha-ap421",
  "title": "Patthodanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap421:1.1",
      "pali": "“Vanacārī pure āsiṁ,"
    },
    {
      "id": "tha-ap421:1.2",
      "pali": "satataṁ vanakammiko;"
    },
    {
      "id": "tha-ap421:1.3",
      "pali": "Patthodanaṁ gahetvāna,"
    },
    {
      "id": "tha-ap421:1.4",
      "pali": "kammantaṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap421:2.1",
      "pali": "Tatthaddasāsiṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap421:2.2",
      "pali": "sayambhuṁ aparājitaṁ;"
    },
    {
      "id": "tha-ap421:2.3",
      "pali": "Vanā piṇḍāya nikkhantaṁ,"
    },
    {
      "id": "tha-ap421:2.4",
      "pali": "disvā cittaṁ pasādayiṁ."
    },
    {
      "id": "tha-ap421:3.1",
      "pali": "Parakammāyane yutto,"
    },
    {
      "id": "tha-ap421:3.2",
      "pali": "puññañca me na vijjati;"
    },
    {
      "id": "tha-ap421:3.3",
      "pali": "Ayaṁ patthodano atthi,"
    },
    {
      "id": "tha-ap421:3.4",
      "pali": "bhojayissāmahaṁ muniṁ."
    },
    {
      "id": "tha-ap421:4.1",
      "pali": "Patthodanaṁ gahetvāna,"
    },
    {
      "id": "tha-ap421:4.2",
      "pali": "sayambhussa adāsahaṁ;"
    },
    {
      "id": "tha-ap421:4.3",
      "pali": "Mama nijjhāyamānassa,"
    },
    {
      "id": "tha-ap421:4.4",
      "pali": "paribhuñji tadā muni."
    },
    {
      "id": "tha-ap421:5.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap421:5.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap421:5.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap421:5.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap421:6.1",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap421:6.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap421:6.3",
      "pali": "Tettiṁsakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap421:6.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap421:7.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap421:7.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap421:7.3",
      "pali": "Sukhito yasavā homi,"
    },
    {
      "id": "tha-ap421:7.4",
      "pali": "patthodanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap421:8.1",
      "pali": "Bhavābhave saṁsaranto,"
    },
    {
      "id": "tha-ap421:8.2",
      "pali": "labhāmi amitaṁ dhanaṁ;"
    },
    {
      "id": "tha-ap421:8.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap421:8.4",
      "pali": "patthodanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap421:9.1",
      "pali": "Nadīsotapaṭibhāgā,"
    },
    {
      "id": "tha-ap421:9.2",
      "pali": "bhogā nibbattare mama;"
    },
    {
      "id": "tha-ap421:9.3",
      "pali": "Parimetuṁ na sakkomi,"
    },
    {
      "id": "tha-ap421:9.4",
      "pali": "patthodanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap421:10.1",
      "pali": "Imaṁ khāda imaṁ bhuñja,"
    },
    {
      "id": "tha-ap421:10.2",
      "pali": "imamhi sayane saya;"
    },
    {
      "id": "tha-ap421:10.3",
      "pali": "Tenāhaṁ sukhito homi,"
    },
    {
      "id": "tha-ap421:10.4",
      "pali": "patthodanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap421:11.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap421:11.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap421:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap421:11.4",
      "pali": "patthodanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap421:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap421:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap421:12.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap421:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap421:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap421:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap421:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap421:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap421:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap421:15.1",
      "pali": "Itthaṁ sudaṁ āyasmā patthodanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap421:16.1",
      "pali": "Patthodanadāyakattherassāpadānaṁ navamaṁ."
    }
  ]
}
