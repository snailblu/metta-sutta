{
  "uid": "tha-ap505",
  "title": "3 Kāsumāraphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap505:1.1",
      "pali": "“Kaṇikāraṁva jotantaṁ,"
    },
    {
      "id": "tha-ap505:1.2",
      "pali": "nisinnaṁ pabbatantare;"
    },
    {
      "id": "tha-ap505:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap505:1.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap505:2.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap505:2.2",
      "pali": "sire katvāna añjaliṁ;"
    },
    {
      "id": "tha-ap505:2.3",
      "pali": "Kāsumārikamādāya,"
    },
    {
      "id": "tha-ap505:2.4",
      "pali": "buddhaseṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap505:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap505:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap505:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap505:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap505:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap505:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap505:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap505:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap505:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap505:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap505:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap505:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap505:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap505:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kāsumāraphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap505:8.1",
      "pali": "Kāsumāraphaliyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
