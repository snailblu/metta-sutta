{
  "uid": "tha-ap502",
  "title": "Piyālaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap502:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap502:1.2",
      "pali": "vipine vicaraṁ tadā;"
    },
    {
      "id": "tha-ap502:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap502:1.4",
      "pali": "sabbadhammāna pāraguṁ."
    },
    {
      "id": "tha-ap502:2.1",
      "pali": "Piyālaphalamādāya,"
    },
    {
      "id": "tha-ap502:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap502:2.3",
      "pali": "Puññakkhettassa vīrassa,"
    },
    {
      "id": "tha-ap502:2.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "tha-ap502:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap502:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap502:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap502:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap502:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap502:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap502:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap502:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap502:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap502:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap502:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap502:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap502:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap502:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā piyālaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap502:8.1",
      "pali": "Piyālaphaladāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap502:8.2",
      "pali": "Kiṅkaṇipupphavaggo paññāsamo."
    },
    {
      "id": "tha-ap502:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap502:10.1",
      "pali": "Kiṅkaṇī paṁsukūlañca,"
    },
    {
      "id": "tha-ap502:10.2",
      "pali": "koraṇḍamatha kiṁsukaṁ;"
    },
    {
      "id": "tha-ap502:10.3",
      "pali": "Upaḍḍhadussī ghatado,"
    },
    {
      "id": "tha-ap502:10.4",
      "pali": "udakaṁ thūpakārako."
    },
    {
      "id": "tha-ap502:11.1",
      "pali": "Naḷakārī ca navamo,"
    },
    {
      "id": "tha-ap502:11.2",
      "pali": "piyālaphaladāyako;"
    },
    {
      "id": "tha-ap502:11.3",
      "pali": "Satamekañca gāthānaṁ,"
    },
    {
      "id": "tha-ap502:11.4",
      "pali": "navakañca taduttari."
    },
    {
      "id": "tha-ap502:12.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "tha-ap502:13.1",
      "pali": "Metteyyavaggo bhaddāli,"
    },
    {
      "id": "tha-ap502:13.2",
      "pali": "sakiṁsammajjakopi ca;"
    },
    {
      "id": "tha-ap502:13.3",
      "pali": "Ekavihārī vibhītakī,"
    },
    {
      "id": "tha-ap502:13.4",
      "pali": "jagatī sālapupphiyo."
    },
    {
      "id": "tha-ap502:14.1",
      "pali": "Naḷāgāraṁ paṁsukūlaṁ,"
    },
    {
      "id": "tha-ap502:14.2",
      "pali": "kiṅkaṇipupphiyo tathā;"
    },
    {
      "id": "tha-ap502:14.3",
      "pali": "Asīti dve ca gāthāyo,"
    },
    {
      "id": "tha-ap502:14.4",
      "pali": "catuddasasatāni ca."
    },
    {
      "id": "tha-ap502:15.1",
      "pali": "Metteyyavaggadasakaṁ."
    },
    {
      "id": "tha-ap502:16.1",
      "pali": "Pañcamasatakaṁ samattaṁ."
    }
  ]
}
