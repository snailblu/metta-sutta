{
  "uid": "thag2.36",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.36:1.1",
      "pali": "“Kassa selūpamaṁ cittaṁ,"
    },
    {
      "id": "thag2.36:1.2",
      "pali": "ṭhitaṁ nānupakampati;"
    },
    {
      "id": "thag2.36:1.3",
      "pali": "Virattaṁ rajanīyesu,"
    },
    {
      "id": "thag2.36:1.4",
      "pali": "kuppanīye na kuppati;"
    },
    {
      "id": "thag2.36:1.5",
      "pali": "Yassevaṁ bhāvitaṁ cittaṁ,"
    },
    {
      "id": "thag2.36:1.6",
      "pali": "kuto taṁ dukkhamessati."
    },
    {
      "id": "thag2.36:2.1",
      "pali": "Mama selūpamaṁ cittaṁ,"
    },
    {
      "id": "thag2.36:2.2",
      "pali": "ṭhitaṁ nānupakampati;"
    },
    {
      "id": "thag2.36:2.3",
      "pali": "Virattaṁ rajanīyesu,"
    },
    {
      "id": "thag2.36:2.4",
      "pali": "kuppanīye na kuppati;"
    },
    {
      "id": "thag2.36:2.5",
      "pali": "Mamevaṁ bhāvitaṁ cittaṁ,"
    },
    {
      "id": "thag2.36:2.6",
      "pali": "kuto maṁ dukkhamessatī”ti."
    },
    {
      "id": "thag2.36:2.7",
      "pali": "… Nitako thero …."
    }
  ]
}
