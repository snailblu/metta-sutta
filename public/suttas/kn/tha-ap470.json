{
  "uid": "tha-ap470",
  "title": "8 Pilakkhaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap470:1.1",
      "pali": "“Vanantare buddhaṁ disvā,"
    },
    {
      "id": "tha-ap470:1.2",
      "pali": "atthadassiṁ mahāyasaṁ;"
    },
    {
      "id": "tha-ap470:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap470:1.4",
      "pali": "pilakkhassa phalaṁ adā."
    },
    {
      "id": "tha-ap470:2.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap470:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap470:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap470:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap470:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap470:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap470:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap470:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap470:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap470:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap470:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap470:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap470:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap470:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pilakkhaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap470:7.1",
      "pali": "Pilakkhaphaladāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
