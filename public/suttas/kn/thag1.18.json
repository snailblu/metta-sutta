{
  "uid": "thag1.18",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.18:1.1",
      "pali": "“Ahu buddhassa dāyādo,"
    },
    {
      "id": "thag1.18:1.2",
      "pali": "bhikkhu bhesakaḷāvane;"
    },
    {
      "id": "thag1.18:1.3",
      "pali": "Kevalaṁ aṭṭhisaññāya,"
    },
    {
      "id": "thag1.18:1.4",
      "pali": "apharī pathaviṁ imaṁ;"
    },
    {
      "id": "thag1.18:1.5",
      "pali": "Maññehaṁ kāmarāgaṁ so,"
    },
    {
      "id": "thag1.18:1.6",
      "pali": "khippameva pahissatī”ti."
    },
    {
      "id": "thag1.18:1.7",
      "pali": "… Siṅgālapitā thero …."
    }
  ]
}
