{
  "uid": "thag16.3",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag16.3:1.1",
      "pali": "“Cirarattaṁ vatātāpī,"
    },
    {
      "id": "thag16.3:1.2",
      "pali": "dhammaṁ anuvicintayaṁ;"
    },
    {
      "id": "thag16.3:1.3",
      "pali": "Samaṁ cittassa nālatthaṁ,"
    },
    {
      "id": "thag16.3:1.4",
      "pali": "pucchaṁ samaṇabrāhmaṇe."
    },
    {
      "id": "thag16.3:2.1",
      "pali": "‘Ko so pāraṅgato loke,"
    },
    {
      "id": "thag16.3:2.2",
      "pali": "ko patto amatogadhaṁ;"
    },
    {
      "id": "thag16.3:2.3",
      "pali": "Kassa dhammaṁ paṭicchāmi,"
    },
    {
      "id": "thag16.3:2.4",
      "pali": "paramatthavijānanaṁ’."
    },
    {
      "id": "thag16.3:3.1",
      "pali": "Antovaṅkagato āsi,"
    },
    {
      "id": "thag16.3:3.2",
      "pali": "macchova ghasamāmisaṁ;"
    },
    {
      "id": "thag16.3:3.3",
      "pali": "Baddho mahindapāsena,"
    },
    {
      "id": "thag16.3:3.4",
      "pali": "vepacityasuro yathā."
    },
    {
      "id": "thag16.3:4.1",
      "pali": "Añchāmi naṁ na muñcāmi,"
    },
    {
      "id": "thag16.3:4.2",
      "pali": "asmā sokapariddavā;"
    },
    {
      "id": "thag16.3:4.3",
      "pali": "Ko me bandhaṁ muñcaṁ loke,"
    },
    {
      "id": "thag16.3:4.4",
      "pali": "sambodhiṁ vedayissati."
    },
    {
      "id": "thag16.3:5.1",
      "pali": "Samaṇaṁ brāhmaṇaṁ vā kaṁ,"
    },
    {
      "id": "thag16.3:5.2",
      "pali": "ādisantaṁ pabhaṅgunaṁ;"
    },
    {
      "id": "thag16.3:5.3",
      "pali": "Kassa dhammaṁ paṭicchāmi,"
    },
    {
      "id": "thag16.3:5.4",
      "pali": "jarāmaccupavāhanaṁ."
    },
    {
      "id": "thag16.3:6.1",
      "pali": "Vicikicchākaṅkhāganthitaṁ,"
    },
    {
      "id": "thag16.3:6.2",
      "pali": "sārambhabalasaññutaṁ;"
    },
    {
      "id": "thag16.3:6.3",
      "pali": "Kodhappattamanatthaddhaṁ,"
    },
    {
      "id": "thag16.3:6.4",
      "pali": "abhijappappadāraṇaṁ."
    },
    {
      "id": "thag16.3:7.1",
      "pali": "Taṇhādhanusamuṭṭhānaṁ,"
    },
    {
      "id": "thag16.3:7.2",
      "pali": "dve ca pannarasāyutaṁ;"
    },
    {
      "id": "thag16.3:7.3",
      "pali": "Passa orasikaṁ bāḷhaṁ,"
    },
    {
      "id": "thag16.3:7.4",
      "pali": "bhetvāna yadi tiṭṭhati."
    },
    {
      "id": "thag16.3:8.1",
      "pali": "Anudiṭṭhīnaṁ appahānaṁ,"
    },
    {
      "id": "thag16.3:8.2",
      "pali": "saṅkappaparatejitaṁ;"
    },
    {
      "id": "thag16.3:8.3",
      "pali": "Tena viddho pavedhāmi,"
    },
    {
      "id": "thag16.3:8.4",
      "pali": "pattaṁva māluteritaṁ."
    },
    {
      "id": "thag16.3:9.1",
      "pali": "Ajjhattaṁ me samuṭṭhāya,"
    },
    {
      "id": "thag16.3:9.2",
      "pali": "khippaṁ paccati māmakaṁ;"
    },
    {
      "id": "thag16.3:9.3",
      "pali": "Chaphassāyatanī kāyo,"
    },
    {
      "id": "thag16.3:9.4",
      "pali": "yattha sarati sabbadā."
    },
    {
      "id": "thag16.3:10.1",
      "pali": "Taṁ na passāmi tekicchaṁ,"
    },
    {
      "id": "thag16.3:10.2",
      "pali": "yo metaṁ sallamuddhare;"
    },
    {
      "id": "thag16.3:10.3",
      "pali": "Nānārajjena satthena,"
    },
    {
      "id": "thag16.3:10.4",
      "pali": "nāññena vicikicchitaṁ."
    },
    {
      "id": "thag16.3:11.1",
      "pali": "Ko me asattho avaṇo,"
    },
    {
      "id": "thag16.3:11.2",
      "pali": "Sallamabbhantarapassayaṁ;"
    },
    {
      "id": "thag16.3:11.3",
      "pali": "Ahiṁsaṁ sabbagattāni,"
    },
    {
      "id": "thag16.3:11.4",
      "pali": "Sallaṁ me uddharissati."
    },
    {
      "id": "thag16.3:12.1",
      "pali": "Dhammappati hi so seṭṭho,"
    },
    {
      "id": "thag16.3:12.2",
      "pali": "visadosappavāhako;"
    },
    {
      "id": "thag16.3:12.3",
      "pali": "Gambhīre patitassa me,"
    },
    {
      "id": "thag16.3:12.4",
      "pali": "thalaṁ pāṇiñca dassaye."
    },
    {
      "id": "thag16.3:13.1",
      "pali": "Rahadehamasmi ogāḷho,"
    },
    {
      "id": "thag16.3:13.2",
      "pali": "ahāriyarajamattike;"
    },
    {
      "id": "thag16.3:13.3",
      "pali": "Māyāusūyasārambha,"
    },
    {
      "id": "thag16.3:13.4",
      "pali": "thinamiddhamapatthaṭe."
    },
    {
      "id": "thag16.3:14.1",
      "pali": "Uddhaccameghathanitaṁ,"
    },
    {
      "id": "thag16.3:14.2",
      "pali": "saṁyojanavalāhakaṁ;"
    },
    {
      "id": "thag16.3:14.3",
      "pali": "Vāhā vahanti kuddiṭṭhiṁ,"
    },
    {
      "id": "thag16.3:14.4",
      "pali": "saṅkappā rāganissitā."
    },
    {
      "id": "thag16.3:15.1",
      "pali": "Savanti sabbadhi sotā,"
    },
    {
      "id": "thag16.3:15.2",
      "pali": "latā ubbhijja tiṭṭhati;"
    },
    {
      "id": "thag16.3:15.3",
      "pali": "Te sote ko nivāreyya,"
    },
    {
      "id": "thag16.3:15.4",
      "pali": "taṁ lataṁ ko hi checchati."
    },
    {
      "id": "thag16.3:16.1",
      "pali": "Velaṁ karotha bhaddante,"
    },
    {
      "id": "thag16.3:16.2",
      "pali": "sotānaṁ sannivāraṇaṁ;"
    },
    {
      "id": "thag16.3:16.3",
      "pali": "Mā te manomayo soto,"
    },
    {
      "id": "thag16.3:16.4",
      "pali": "rukkhaṁva sahasā luve."
    },
    {
      "id": "thag16.3:17.1",
      "pali": "Evaṁ me bhayajātassa,"
    },
    {
      "id": "thag16.3:17.2",
      "pali": "apārā pāramesato;"
    },
    {
      "id": "thag16.3:17.3",
      "pali": "Tāṇo paññāvudho satthā,"
    },
    {
      "id": "thag16.3:17.4",
      "pali": "isisaṅghanisevito."
    },
    {
      "id": "thag16.3:18.1",
      "pali": "Sopāṇaṁ sugataṁ suddhaṁ,"
    },
    {
      "id": "thag16.3:18.2",
      "pali": "dhammasāramayaṁ daḷhaṁ;"
    },
    {
      "id": "thag16.3:18.3",
      "pali": "Pādāsi vuyhamānassa,"
    },
    {
      "id": "thag16.3:18.4",
      "pali": "‘mā bhāyī’ti ca mabravi."
    },
    {
      "id": "thag16.3:19.1",
      "pali": "Satipaṭṭhānapāsādaṁ,"
    },
    {
      "id": "thag16.3:19.2",
      "pali": "āruyha paccavekkhisaṁ;"
    },
    {
      "id": "thag16.3:19.3",
      "pali": "Yaṁ taṁ pubbe amaññissaṁ,"
    },
    {
      "id": "thag16.3:19.4",
      "pali": "sakkāyābhirataṁ pajaṁ."
    },
    {
      "id": "thag16.3:20.1",
      "pali": "Yadā ca maggamaddakkhiṁ,"
    },
    {
      "id": "thag16.3:20.2",
      "pali": "nāvāya abhirūhanaṁ;"
    },
    {
      "id": "thag16.3:20.3",
      "pali": "Anadhiṭṭhāya attānaṁ,"
    },
    {
      "id": "thag16.3:20.4",
      "pali": "titthamaddakkhimuttamaṁ."
    },
    {
      "id": "thag16.3:21.1",
      "pali": "Sallaṁ attasamuṭṭhānaṁ,"
    },
    {
      "id": "thag16.3:21.2",
      "pali": "bhavanettippabhāvitaṁ;"
    },
    {
      "id": "thag16.3:21.3",
      "pali": "Etesaṁ appavattāya,"
    },
    {
      "id": "thag16.3:21.4",
      "pali": "desesi maggamuttamaṁ."
    },
    {
      "id": "thag16.3:22.1",
      "pali": "Dīgharattānusayitaṁ,"
    },
    {
      "id": "thag16.3:22.2",
      "pali": "cirarattamadhiṭṭhitaṁ;"
    },
    {
      "id": "thag16.3:22.3",
      "pali": "Buddho mepānudī ganthaṁ,"
    },
    {
      "id": "thag16.3:22.4",
      "pali": "visadosappavāhano”ti."
    },
    {
      "id": "thag16.3:22.5",
      "pali": "… Telakāni thero …."
    }
  ]
}
