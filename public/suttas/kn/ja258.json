{
  "uid": "ja258",
  "title": "Saṅkappavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja258:1.1",
      "pali": "“Yāvatā candimasūriyā,"
    },
    {
      "id": "ja258:1.2",
      "pali": "Pariharanti disā bhanti virocanā;"
    },
    {
      "id": "ja258:1.3",
      "pali": "Sabbeva dāsā mandhātu,"
    },
    {
      "id": "ja258:1.4",
      "pali": "Ye pāṇā pathavissitā."
    },
    {
      "id": "ja258:2.1",
      "pali": "Na kahāpaṇavassena,"
    },
    {
      "id": "ja258:2.2",
      "pali": "titti kāmesu vijjati;"
    },
    {
      "id": "ja258:2.3",
      "pali": "Appassādā dukhā kāmā,"
    },
    {
      "id": "ja258:2.4",
      "pali": "iti viññāya paṇḍito."
    },
    {
      "id": "ja258:3.1",
      "pali": "Api dibbesu kāmesu,"
    },
    {
      "id": "ja258:3.2",
      "pali": "ratiṁ so nādhigacchati;"
    },
    {
      "id": "ja258:3.3",
      "pali": "Taṇhakkhayarato hoti,"
    },
    {
      "id": "ja258:3.4",
      "pali": "sammāsambuddhasāvako”ti."
    },
    {
      "id": "ja258:4.1",
      "pali": "Mandhātujātakaṁ aṭṭhamaṁ."
    }
  ]
}
