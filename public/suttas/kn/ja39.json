{
  "uid": "ja39",
  "title": "Kulāvakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja39:1.1",
      "pali": "“Maññe sovaṇṇayo rāsi,"
    },
    {
      "id": "ja39:1.2",
      "pali": "soṇṇamālā ca nandako;"
    },
    {
      "id": "ja39:1.3",
      "pali": "Yattha dāso āmajāto,"
    },
    {
      "id": "ja39:1.4",
      "pali": "ṭhito thullāni gajjatī”ti."
    },
    {
      "id": "ja39:2.1",
      "pali": "Nandajātakaṁ navamaṁ."
    }
  ]
}
