{
  "uid": "tha-ap183",
  "title": "Kuṭajapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap183:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap183:1.2",
      "pali": "Sataraṁsiṁva uggataṁ;"
    },
    {
      "id": "tha-ap183:1.3",
      "pali": "Disaṁ anuvilokentaṁ,"
    },
    {
      "id": "tha-ap183:1.4",
      "pali": "Gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap183:2.1",
      "pali": "Kuṭajaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap183:2.2",
      "pali": "saṁvitthatasamotthataṁ;"
    },
    {
      "id": "tha-ap183:2.3",
      "pali": "Rukkhato ocinitvāna,"
    },
    {
      "id": "tha-ap183:2.4",
      "pali": "phussassa abhiropayiṁ."
    },
    {
      "id": "tha-ap183:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap183:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap183:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap183:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap183:4.1",
      "pali": "Ito sattarase kappe,"
    },
    {
      "id": "tha-ap183:4.2",
      "pali": "tayo āsuṁ supupphitā;"
    },
    {
      "id": "tha-ap183:4.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap183:4.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap183:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap183:5.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap183:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap183:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap183:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kuṭajapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap183:7.1",
      "pali": "Kuṭajapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
