{
  "uid": "tha-ap387",
  "title": "Phārusaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap387:1.1",
      "pali": "“Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap387:1.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap387:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap387:1.4",
      "pali": "Phārusaphalamadāsahaṁ."
    },
    {
      "id": "tha-ap387:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap387:2.2",
      "pali": "yaṁ phalamadadiṁ ahaṁ;"
    },
    {
      "id": "tha-ap387:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap387:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap387:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap387:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap387:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap387:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap387:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap387:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap387:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap387:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap387:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap387:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā phārusaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap387:7.1",
      "pali": "Phārusaphaladāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
