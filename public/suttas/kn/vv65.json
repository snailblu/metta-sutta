{
  "uid": "vv65",
  "title": "Pāyāsivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv65:1.1",
      "pali": "“Yathā vanaṁ cittalataṁ pabhāsati,"
    },
    {
      "id": "vv65:1.2",
      "pali": "Uyyānaseṭṭhaṁ tidasānamuttamaṁ;"
    },
    {
      "id": "vv65:1.3",
      "pali": "Tathūpamaṁ tuyhamidaṁ vimānaṁ,"
    },
    {
      "id": "vv65:1.4",
      "pali": "Obhāsayaṁ tiṭṭhati antalikkhe."
    },
    {
      "id": "vv65:2.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv65:2.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv65:2.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv65:2.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv65:3.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv65:3.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv65:3.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv65:3.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv65:4.1",
      "pali": "“Ahañca bhariyā ca manussaloke,"
    },
    {
      "id": "vv65:4.2",
      "pali": "Opānabhūtā gharamāvasimha;"
    },
    {
      "id": "vv65:4.3",
      "pali": "Annañca pānañca pasannacittā,"
    },
    {
      "id": "vv65:4.4",
      "pali": "Sakkacca dānaṁ vipulaṁ adamha."
    },
    {
      "id": "vv65:5.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv65:5.2",
      "pali": "…pe…"
    },
    {
      "id": "vv65:5.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv65:6.1",
      "pali": "Paṭhamaagāriyavimānaṁ paṭhamaṁ."
    }
  ]
}
