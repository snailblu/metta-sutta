{
  "uid": "tha-ap465",
  "title": "Citakanibbāpakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap465:1.1",
      "pali": "“Dayhamāne sarīramhi,"
    },
    {
      "id": "tha-ap465:1.2",
      "pali": "vessabhussa mahesino;"
    },
    {
      "id": "tha-ap465:1.3",
      "pali": "Gandhodakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap465:1.4",
      "pali": "citaṁ nibbāpayiṁ ahaṁ."
    },
    {
      "id": "tha-ap465:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap465:2.2",
      "pali": "citaṁ nibbāpayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap465:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap465:2.4",
      "pali": "gandhodakassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap465:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap465:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap465:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap465:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap465:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap465:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap465:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap465:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap465:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap465:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakanibbāpako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap465:7.1",
      "pali": "Citakanibbāpakattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
