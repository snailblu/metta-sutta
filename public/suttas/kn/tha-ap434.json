{
  "uid": "tha-ap434",
  "title": "Ekasaṅkhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap434:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap434:1.2",
      "pali": "mahābodhimaho ahu;"
    },
    {
      "id": "tha-ap434:1.3",
      "pali": "Mahājanā samāgamma,"
    },
    {
      "id": "tha-ap434:1.4",
      "pali": "pūjenti bodhimuttamaṁ."
    },
    {
      "id": "tha-ap434:2.1",
      "pali": "Na hi taṁ orakaṁ maññe,"
    },
    {
      "id": "tha-ap434:2.2",
      "pali": "buddhaseṭṭho bhavissati;"
    },
    {
      "id": "tha-ap434:2.3",
      "pali": "Yassāyaṁ īdisā bodhi,"
    },
    {
      "id": "tha-ap434:2.4",
      "pali": "pūjanīyā ca satthuno."
    },
    {
      "id": "tha-ap434:3.1",
      "pali": "Tato saṅkhaṁ gahetvāna,"
    },
    {
      "id": "tha-ap434:3.2",
      "pali": "bodhirukkhamupaṭṭhahiṁ;"
    },
    {
      "id": "tha-ap434:3.3",
      "pali": "Dhamanto sabbadivasaṁ,"
    },
    {
      "id": "tha-ap434:3.4",
      "pali": "avandiṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap434:4.1",
      "pali": "Āsannake kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap434:4.2",
      "pali": "devalokaṁ apāpayī;"
    },
    {
      "id": "tha-ap434:4.3",
      "pali": "Kaḷevaraṁ me patitaṁ,"
    },
    {
      "id": "tha-ap434:4.4",
      "pali": "devaloke ramāmahaṁ."
    },
    {
      "id": "tha-ap434:5.1",
      "pali": "Saṭṭhituriyasahassāni,"
    },
    {
      "id": "tha-ap434:5.2",
      "pali": "tuṭṭhahaṭṭhā pamoditā;"
    },
    {
      "id": "tha-ap434:5.3",
      "pali": "Sadā mayhaṁ upaṭṭhanti,"
    },
    {
      "id": "tha-ap434:5.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap434:6.1",
      "pali": "Ekasattatime kappe,"
    },
    {
      "id": "tha-ap434:6.2",
      "pali": "rājā āsiṁ sudassano;"
    },
    {
      "id": "tha-ap434:6.3",
      "pali": "Cāturanto vijitāvī,"
    },
    {
      "id": "tha-ap434:6.4",
      "pali": "jambumaṇḍassa issaro."
    },
    {
      "id": "tha-ap434:7.1",
      "pali": "Tato aṅgasatā turiyā,"
    },
    {
      "id": "tha-ap434:7.2",
      "pali": "parivārenti maṁ sadā;"
    },
    {
      "id": "tha-ap434:7.3",
      "pali": "Anubhomi sakaṁ kammaṁ,"
    },
    {
      "id": "tha-ap434:7.4",
      "pali": "upaṭṭhānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap434:8.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap434:8.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap434:8.3",
      "pali": "Mātukucchigatassāpi,"
    },
    {
      "id": "tha-ap434:8.4",
      "pali": "vajjare bheriyo sadā."
    },
    {
      "id": "tha-ap434:9.1",
      "pali": "Upaṭṭhitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap434:9.2",
      "pali": "anubhutvāna sampadā;"
    },
    {
      "id": "tha-ap434:9.3",
      "pali": "Sivaṁ sukhemaṁ amataṁ,"
    },
    {
      "id": "tha-ap434:9.4",
      "pali": "pattomhi acalaṁ padaṁ."
    },
    {
      "id": "tha-ap434:10.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap434:10.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap434:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap434:10.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap434:11.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap434:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap434:11.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap434:12.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap434:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap434:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap434:13.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap434:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap434:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap434:14.1",
      "pali": "Itthaṁ sudaṁ āyasmā ekasaṅkhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap434:15.1",
      "pali": "Ekasaṅkhiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
