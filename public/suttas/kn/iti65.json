{
  "uid": "iti65",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti65:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti65:2.1",
      "pali": "“Tīṇimāni, bhikkhave, sucaritāni."
    },
    {
      "id": "iti65:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti65:2.3",
      "pali": "Kāyasucaritaṁ, vacīsucaritaṁ, manosucaritaṁ—"
    },
    {
      "id": "iti65:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi sucaritānī”ti."
    },
    {
      "id": "iti65:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti65:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti65:3.1",
      "pali": "“Kāyaduccaritaṁ hitvā,"
    },
    {
      "id": "iti65:3.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "iti65:3.3",
      "pali": "Manoduccaritaṁ hitvā,"
    },
    {
      "id": "iti65:3.4",
      "pali": "yañcaññaṁ dosasaṁhitaṁ."
    },
    {
      "id": "iti65:4.1",
      "pali": "Akatvākusalaṁ kammaṁ,"
    },
    {
      "id": "iti65:4.2",
      "pali": "katvāna kusalaṁ bahuṁ;"
    },
    {
      "id": "iti65:4.3",
      "pali": "Kāyassa bhedā sappañño,"
    },
    {
      "id": "iti65:4.4",
      "pali": "saggaṁ so upapajjatī”ti."
    },
    {
      "id": "iti65:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti65:5.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
