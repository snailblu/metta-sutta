{
  "uid": "thag1.100",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.100:1.1",
      "pali": "“Sammappadhānasampanno,"
    },
    {
      "id": "thag1.100:1.2",
      "pali": "Satipaṭṭhānagocaro;"
    },
    {
      "id": "thag1.100:1.3",
      "pali": "Vimuttikusumasañchanno,"
    },
    {
      "id": "thag1.100:1.4",
      "pali": "Parinibbissatyanāsavo”ti."
    },
    {
      "id": "thag1.100:1.5",
      "pali": "… Devasabho thero …."
    },
    {
      "id": "thag1.100:1.6",
      "pali": "vaggo dasamo."
    },
    {
      "id": "thag1.100:2.1",
      "pali": "Paripuṇṇako ca vijayo,"
    },
    {
      "id": "thag1.100:2.2",
      "pali": "erako mettajī muni;"
    },
    {
      "id": "thag1.100:2.3",
      "pali": "Cakkhupālo khaṇḍasumano,"
    },
    {
      "id": "thag1.100:2.4",
      "pali": "tisso ca abhayo tathā;"
    },
    {
      "id": "thag1.100:2.5",
      "pali": "Uttiyo ca mahāpañño,"
    },
    {
      "id": "thag1.100:2.6",
      "pali": "thero devasabhopi cāti."
    }
  ]
}
