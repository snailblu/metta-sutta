{
  "uid": "thag1.12",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.12:1.1",
      "pali": "“Paññābalī sīlavatūpapanno,"
    },
    {
      "id": "thag1.12:1.2",
      "pali": "Samāhito jhānarato satīmā;"
    },
    {
      "id": "thag1.12:1.3",
      "pali": "Yadatthiyaṁ bhojanaṁ bhuñjamāno,"
    },
    {
      "id": "thag1.12:1.4",
      "pali": "Kaṅkhetha kālaṁ idha vītarāgo”ti."
    },
    {
      "id": "thag1.12:1.5",
      "pali": "… Mahāvaccho thero …."
    }
  ]
}
