{
  "uid": "ja161",
  "title": "Santhavavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja161:1.1",
      "pali": "“Na santhavaṁ kāpurisena kayirā,"
    },
    {
      "id": "ja161:1.2",
      "pali": "Ariyo anariyena pajānamatthaṁ;"
    },
    {
      "id": "ja161:1.3",
      "pali": "Cirānuvutthopi karoti pāpaṁ,"
    },
    {
      "id": "ja161:1.4",
      "pali": "Gajo yathā indasamānagottaṁ."
    },
    {
      "id": "ja161:2.1",
      "pali": "Yaṁ tveva jaññā sadiso mamanti,"
    },
    {
      "id": "ja161:2.2",
      "pali": "Sīlena paññāya sutena cāpi;"
    },
    {
      "id": "ja161:2.3",
      "pali": "Teneva mettiṁ kayirātha saddhiṁ,"
    },
    {
      "id": "ja161:2.4",
      "pali": "Sukho have sappurisena saṅgamo”ti."
    },
    {
      "id": "ja161:3.1",
      "pali": "Indasamānagottajātakaṁ paṭhamaṁ."
    }
  ]
}
