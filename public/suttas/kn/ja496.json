{
  "uid": "ja496",
  "title": "Sālikedāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja496:1.1",
      "pali": "“Sukhumālarūpaṁ disvā,"
    },
    {
      "id": "ja496:1.2",
      "pali": "raṭṭhā vivanamāgataṁ;"
    },
    {
      "id": "ja496:1.3",
      "pali": "Kūṭāgāravarūpetaṁ,"
    },
    {
      "id": "ja496:1.4",
      "pali": "mahāsayanamupāsitaṁ."
    },
    {
      "id": "ja496:2.1",
      "pali": "Tassa te pemakenāhaṁ,"
    },
    {
      "id": "ja496:2.2",
      "pali": "adāsiṁ vaḍḍhamodanaṁ;"
    },
    {
      "id": "ja496:2.3",
      "pali": "Sālīnaṁ vicitaṁ bhattaṁ,"
    },
    {
      "id": "ja496:2.4",
      "pali": "suciṁ maṁsūpasecanaṁ."
    },
    {
      "id": "ja496:3.1",
      "pali": "Taṁ tvaṁ bhattaṁ paṭiggayha,"
    },
    {
      "id": "ja496:3.2",
      "pali": "brāhmaṇassa adāsayi;"
    },
    {
      "id": "ja496:3.3",
      "pali": "Attānaṁ anasitvāna,"
    },
    {
      "id": "ja496:3.4",
      "pali": "koyaṁ dhammo namatthu te”."
    },
    {
      "id": "ja496:4.1",
      "pali": "“Ācariyo brāhmaṇo mayhaṁ,"
    },
    {
      "id": "ja496:4.2",
      "pali": "kiccākiccesu byāvaṭo;"
    },
    {
      "id": "ja496:4.3",
      "pali": "Garu ca āmantanīyo ca,"
    },
    {
      "id": "ja496:4.4",
      "pali": "dātumarahāmi bhojanaṁ”."
    },
    {
      "id": "ja496:5.1",
      "pali": "“Brāhmaṇaṁ dāni pucchāmi,"
    },
    {
      "id": "ja496:5.2",
      "pali": "gotamaṁ rājapūjitaṁ;"
    },
    {
      "id": "ja496:5.3",
      "pali": "Rājā te bhattaṁ pādāsi,"
    },
    {
      "id": "ja496:5.4",
      "pali": "suciṁ maṁsūpasecanaṁ."
    },
    {
      "id": "ja496:6.1",
      "pali": "Taṁ tvaṁ bhattaṁ paṭiggayha,"
    },
    {
      "id": "ja496:6.2",
      "pali": "isissa bhojanaṁ adā;"
    },
    {
      "id": "ja496:6.3",
      "pali": "Akhettaññūsi dānassa,"
    },
    {
      "id": "ja496:6.4",
      "pali": "koyaṁ dhammo namatthu te”."
    },
    {
      "id": "ja496:7.1",
      "pali": "“Bharāmi puttadāre ca,"
    },
    {
      "id": "ja496:7.2",
      "pali": "gharesu gadhito ahaṁ;"
    },
    {
      "id": "ja496:7.3",
      "pali": "Bhuñje mānusake kāme,"
    },
    {
      "id": "ja496:7.4",
      "pali": "anusāsāmi rājino."
    },
    {
      "id": "ja496:8.1",
      "pali": "Āraññikassa isino,"
    },
    {
      "id": "ja496:8.2",
      "pali": "cirarattaṁ tapassino;"
    },
    {
      "id": "ja496:8.3",
      "pali": "Vuḍḍhassa bhāvitattassa,"
    },
    {
      "id": "ja496:8.4",
      "pali": "dātumarahāmi bhojanaṁ”."
    },
    {
      "id": "ja496:9.1",
      "pali": "“Isiñca dāni pucchāmi,"
    },
    {
      "id": "ja496:9.2",
      "pali": "kisaṁ dhamanisanthataṁ;"
    },
    {
      "id": "ja496:9.3",
      "pali": "Parūḷhakacchanakhalomaṁ,"
    },
    {
      "id": "ja496:9.4",
      "pali": "paṅkadantaṁ rajassiraṁ."
    },
    {
      "id": "ja496:10.1",
      "pali": "Eko araññe viharasi,"
    },
    {
      "id": "ja496:10.2",
      "pali": "nāvakaṅkhasi jīvitaṁ;"
    },
    {
      "id": "ja496:10.3",
      "pali": "Bhikkhu kena tayā seyyo,"
    },
    {
      "id": "ja496:10.4",
      "pali": "yassa tvaṁ bhojanaṁ adā”."
    },
    {
      "id": "ja496:11.1",
      "pali": "“Khaṇantālukalambāni,"
    },
    {
      "id": "ja496:11.2",
      "pali": "bilālitakkalāni ca;"
    },
    {
      "id": "ja496:11.3",
      "pali": "Dhunaṁ sāmākanīvāraṁ,"
    },
    {
      "id": "ja496:11.4",
      "pali": "saṅghāriyaṁ pasāriyaṁ."
    },
    {
      "id": "ja496:12.1",
      "pali": "Sākaṁ bhisaṁ madhuṁ maṁsaṁ,"
    },
    {
      "id": "ja496:12.2",
      "pali": "Badarāmalakāni ca;"
    },
    {
      "id": "ja496:12.3",
      "pali": "Tāni āharitvā bhuñjāmi,"
    },
    {
      "id": "ja496:12.4",
      "pali": "Atthi me so pariggaho."
    },
    {
      "id": "ja496:13.1",
      "pali": "Pacanto apacantassa,"
    },
    {
      "id": "ja496:13.2",
      "pali": "amamassa sakiñcano;"
    },
    {
      "id": "ja496:13.3",
      "pali": "Anādānassa sādāno,"
    },
    {
      "id": "ja496:13.4",
      "pali": "dātumarahāmi bhojanaṁ”."
    },
    {
      "id": "ja496:14.1",
      "pali": "“Bhikkhuñca dāni pucchāmi,"
    },
    {
      "id": "ja496:14.2",
      "pali": "tuṇhīmāsīna subbataṁ;"
    },
    {
      "id": "ja496:14.3",
      "pali": "Isi te bhattaṁ pādāsi,"
    },
    {
      "id": "ja496:14.4",
      "pali": "suciṁ maṁsūpasecanaṁ."
    },
    {
      "id": "ja496:15.1",
      "pali": "Taṁ tvaṁ bhattaṁ paṭiggayha,"
    },
    {
      "id": "ja496:15.2",
      "pali": "tuṇhī bhuñjasi ekako;"
    },
    {
      "id": "ja496:15.3",
      "pali": "Nāññaṁ kañci nimantesi,"
    },
    {
      "id": "ja496:15.4",
      "pali": "koyaṁ dhammo namatthu te”."
    },
    {
      "id": "ja496:16.1",
      "pali": "“Na pacāmi na pācemi,"
    },
    {
      "id": "ja496:16.2",
      "pali": "na chindāmi na chedaye;"
    },
    {
      "id": "ja496:16.3",
      "pali": "Taṁ maṁ akiñcanaṁ ñatvā,"
    },
    {
      "id": "ja496:16.4",
      "pali": "sabbapāpehi ārataṁ."
    },
    {
      "id": "ja496:17.1",
      "pali": "Vāmena bhikkhamādāya,"
    },
    {
      "id": "ja496:17.2",
      "pali": "dakkhiṇena kamaṇḍaluṁ;"
    },
    {
      "id": "ja496:17.3",
      "pali": "Isi me bhattaṁ pādāsi,"
    },
    {
      "id": "ja496:17.4",
      "pali": "suciṁ maṁsūpasecanaṁ."
    },
    {
      "id": "ja496:18.1",
      "pali": "Ete hi dātumarahanti,"
    },
    {
      "id": "ja496:18.2",
      "pali": "samamā sapariggahā;"
    },
    {
      "id": "ja496:18.3",
      "pali": "Paccanīkamahaṁ maññe,"
    },
    {
      "id": "ja496:18.4",
      "pali": "yo dātāraṁ nimantaye”."
    },
    {
      "id": "ja496:19.1",
      "pali": "“Atthāya vata me ajja,"
    },
    {
      "id": "ja496:19.2",
      "pali": "idhāgacchi rathesabho;"
    },
    {
      "id": "ja496:19.3",
      "pali": "Sohaṁ ajja pajānāmi,"
    },
    {
      "id": "ja496:19.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "ja496:20.1",
      "pali": "Raṭṭhesu giddhā rājāno,"
    },
    {
      "id": "ja496:20.2",
      "pali": "Kiccākiccesu brāhmaṇā;"
    },
    {
      "id": "ja496:20.3",
      "pali": "Isī mūlaphale giddhā,"
    },
    {
      "id": "ja496:20.4",
      "pali": "Vippamuttā ca bhikkhavo”ti."
    },
    {
      "id": "ja496:21.1",
      "pali": "Bhikkhāparamparajātakaṁ terasamaṁ."
    },
    {
      "id": "ja496:22.1",
      "pali": "Pakiṇṇakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja496:23.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja496:24.1",
      "pali": "Suva kinnara mukka kharājinaso,"
    },
    {
      "id": "ja496:24.2",
      "pali": "Bhisajāta mahesi kapotavaro;"
    },
    {
      "id": "ja496:24.3",
      "pali": "Atha mora satacchaka vāṇijako,"
    },
    {
      "id": "ja496:24.4",
      "pali": "Atha rāja sabrāhmaṇa bhikkhaparanti."
    }
  ]
}
