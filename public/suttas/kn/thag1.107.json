{
  "uid": "thag1.107",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.107:1.1",
      "pali": "“Pabbajiṁ tulayitvāna,"
    },
    {
      "id": "thag1.107:1.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag1.107:1.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag1.107:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.107:1.5",
      "pali": "… Dhammasavo thero …."
    }
  ]
}
