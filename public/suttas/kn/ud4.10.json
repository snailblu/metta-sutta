{
  "uid": "ud4.10",
  "title": "Sāriputtaupasamasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ud4.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "ud4.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "ud4.10:1.3",
      "pali": "Tena kho pana samayena āyasmā sāriputto bhagavato avidūre nisinno hoti pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya attano upasamaṁ paccavekkhamāno."
    },
    {
      "id": "ud4.10:2.1",
      "pali": "Addasā kho bhagavā āyasmantaṁ sāriputtaṁ avidūre nisinnaṁ pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya attano upasamaṁ paccavekkhamānaṁ."
    },
    {
      "id": "ud4.10:3.1",
      "pali": "Atha kho bhagavā etamatthaṁ viditvā tāyaṁ velāyaṁ imaṁ udānaṁ udānesi:"
    },
    {
      "id": "ud4.10:4.1",
      "pali": "“Upasantasantacittassa,"
    },
    {
      "id": "ud4.10:4.2",
      "pali": "netticchinnassa bhikkhuno;"
    },
    {
      "id": "ud4.10:4.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "ud4.10:4.4",
      "pali": "mutto so mārabandhanā”ti."
    },
    {
      "id": "ud4.10:4.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "ud4.10:4.6",
      "pali": "Meghiyavaggo catuttho."
    },
    {
      "id": "ud4.10:5.1",
      "pali": "Meghiyo uddhatā gopālo,"
    },
    {
      "id": "ud4.10:5.2",
      "pali": "yakkho nāgena pañcamaṁ;"
    },
    {
      "id": "ud4.10:5.3",
      "pali": "Piṇḍolo sāriputto ca,"
    },
    {
      "id": "ud4.10:5.4",
      "pali": "sundarī bhavati aṭṭhamaṁ;"
    },
    {
      "id": "ud4.10:5.5",
      "pali": "Upaseno vaṅgantaputto,"
    },
    {
      "id": "ud4.10:5.6",
      "pali": "sāriputto ca te dasāti."
    }
  ]
}
