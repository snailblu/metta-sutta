{
  "uid": "tha-ap515",
  "title": "3 Kosambaphaliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap515:1.1",
      "pali": "“Kakudhaṁ vilasantaṁva,"
    },
    {
      "id": "tha-ap515:1.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap515:1.3",
      "pali": "Rathiyaṁ paṭipajjantaṁ,"
    },
    {
      "id": "tha-ap515:1.4",
      "pali": "kosambaṁ adadiṁ tadā."
    },
    {
      "id": "tha-ap515:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap515:2.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap515:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap515:2.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap515:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap515:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap515:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap515:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap515:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap515:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap515:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap515:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap515:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap515:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā kosambaphaliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap515:7.1",
      "pali": "Kosambaphaliyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
