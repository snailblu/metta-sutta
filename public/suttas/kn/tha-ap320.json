{
  "uid": "tha-ap320",
  "title": "Tiraṁsiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap320:1.1",
      "pali": "“Kesariṁ abhijātaṁva,"
    },
    {
      "id": "tha-ap320:1.2",
      "pali": "aggikkhandhaṁva pabbate;"
    },
    {
      "id": "tha-ap320:1.3",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap320:1.4",
      "pali": "siddhatthaṁ pabbatantare."
    },
    {
      "id": "tha-ap320:2.1",
      "pali": "Sūriyassa ca ālokaṁ,"
    },
    {
      "id": "tha-ap320:2.2",
      "pali": "candālokaṁ tatheva ca;"
    },
    {
      "id": "tha-ap320:2.3",
      "pali": "Buddhālokañca disvāna,"
    },
    {
      "id": "tha-ap320:2.4",
      "pali": "vitti me udapajjatha."
    },
    {
      "id": "tha-ap320:3.1",
      "pali": "Tayo āloke disvāna,"
    },
    {
      "id": "tha-ap320:3.2",
      "pali": "sambuddhaṁ sāvakuttamaṁ;"
    },
    {
      "id": "tha-ap320:3.3",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "tha-ap320:3.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap320:4.1",
      "pali": "Tayo hi ālokakarā,"
    },
    {
      "id": "tha-ap320:4.2",
      "pali": "loke lokatamonudā;"
    },
    {
      "id": "tha-ap320:4.3",
      "pali": "Cando ca sūriyo cāpi,"
    },
    {
      "id": "tha-ap320:4.4",
      "pali": "buddho ca lokanāyako."
    },
    {
      "id": "tha-ap320:5.1",
      "pali": "Opammaṁ upadassetvā,"
    },
    {
      "id": "tha-ap320:5.2",
      "pali": "kittito me mahāmuni;"
    },
    {
      "id": "tha-ap320:5.3",
      "pali": "Buddhassa vaṇṇaṁ kittetvā,"
    },
    {
      "id": "tha-ap320:5.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap320:6.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap320:6.2",
      "pali": "yaṁ buddhamabhikittayiṁ;"
    },
    {
      "id": "tha-ap320:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap320:6.4",
      "pali": "kittanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap320:7.1",
      "pali": "Ekasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap320:7.2",
      "pali": "eko ñāṇadharo ahu;"
    },
    {
      "id": "tha-ap320:7.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap320:7.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap320:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap320:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap320:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap320:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiraṁsiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap320:10.1",
      "pali": "Tiraṁsiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
