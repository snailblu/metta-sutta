{
  "uid": "ja89",
  "title": "Apāyimhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja89:1.1",
      "pali": "“Vācāva kira te āsi,"
    },
    {
      "id": "ja89:1.2",
      "pali": "saṇhā sakhilabhāṇino;"
    },
    {
      "id": "ja89:1.3",
      "pali": "Tiṇamatte asajjittho,"
    },
    {
      "id": "ja89:1.4",
      "pali": "no ca nikkhasataṁ haran”ti."
    },
    {
      "id": "ja89:2.1",
      "pali": "Kuhakajātakaṁ navamaṁ."
    }
  ]
}
