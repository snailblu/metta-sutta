{
  "uid": "tha-ap229",
  "title": "Sovaṇṇavaṭaṁsakiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap229:1.1",
      "pali": "“Uyyānabhūmiṁ niyyanto,"
    },
    {
      "id": "tha-ap229:1.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap229:1.3",
      "pali": "Vaṭaṁsakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap229:1.4",
      "pali": "sovaṇṇaṁ sādhunimmitaṁ."
    },
    {
      "id": "tha-ap229:2.1",
      "pali": "Sīghaṁ tato samāruyha,"
    },
    {
      "id": "tha-ap229:2.2",
      "pali": "hatthikkhandhagato ahaṁ;"
    },
    {
      "id": "tha-ap229:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap229:2.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap229:3.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap229:3.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap229:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap229:3.4",
      "pali": "pupphapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap229:4.1",
      "pali": "Sattavīse ito kappe,"
    },
    {
      "id": "tha-ap229:4.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap229:4.3",
      "pali": "Mahāpatāpanāmena,"
    },
    {
      "id": "tha-ap229:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap229:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap229:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap229:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap229:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sovaṇṇavaṭaṁsakiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap229:7.1",
      "pali": "Sovaṇṇavaṭaṁsakiyattherassāpadānaṁ sattamaṁ."
    }
  ]
}
