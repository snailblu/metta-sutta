{
  "uid": "ja130",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja130:1.1",
      "pali": "“Yathā vācā ca bhuñjassu,"
    },
    {
      "id": "ja130:1.2",
      "pali": "yathā bhuttañca byāhara;"
    },
    {
      "id": "ja130:1.3",
      "pali": "Ubhayaṁ te na sameti,"
    },
    {
      "id": "ja130:1.4",
      "pali": "vācā bhuttañca kosiye”ti."
    },
    {
      "id": "ja130:2.1",
      "pali": "Kosiyajātakaṁ dasamaṁ."
    },
    {
      "id": "ja130:2.2",
      "pali": "Kusanāḷivaggo terasamo."
    },
    {
      "id": "ja130:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja130:4.1",
      "pali": "Kusanāḷisirivhayano ca yasaṁ,"
    },
    {
      "id": "ja130:4.2",
      "pali": "Dadhi mamba kaṭāhakapañcamako;"
    },
    {
      "id": "ja130:4.3",
      "pali": "Atha pāpaka khīra biḷāravataṁ,"
    },
    {
      "id": "ja130:4.4",
      "pali": "Sikhi kosiyasavhayanena dasāti."
    }
  ]
}
