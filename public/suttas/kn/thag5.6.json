{
  "uid": "thag5.6",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag5.6:1.1",
      "pali": "“Atthāya vata me buddho,"
    },
    {
      "id": "thag5.6:1.2",
      "pali": "nadiṁ nerañjaraṁ agā;"
    },
    {
      "id": "thag5.6:1.3",
      "pali": "Yassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "thag5.6:1.4",
      "pali": "micchādiṭṭhiṁ vivajjayiṁ."
    },
    {
      "id": "thag5.6:2.1",
      "pali": "Yajiṁ uccāvace yaññe,"
    },
    {
      "id": "thag5.6:2.2",
      "pali": "aggihuttaṁ juhiṁ ahaṁ;"
    },
    {
      "id": "thag5.6:2.3",
      "pali": "‘Esā suddhī’ti maññanto,"
    },
    {
      "id": "thag5.6:2.4",
      "pali": "andhabhūto puthujjano."
    },
    {
      "id": "thag5.6:3.1",
      "pali": "Diṭṭhigahanapakkhando,"
    },
    {
      "id": "thag5.6:3.2",
      "pali": "parāmāsena mohito;"
    },
    {
      "id": "thag5.6:3.3",
      "pali": "Asuddhiṁ maññisaṁ suddhiṁ,"
    },
    {
      "id": "thag5.6:3.4",
      "pali": "andhabhūto aviddasu."
    },
    {
      "id": "thag5.6:4.1",
      "pali": "Micchādiṭṭhi pahīnā me,"
    },
    {
      "id": "thag5.6:4.2",
      "pali": "bhavā sabbe padālitā;"
    },
    {
      "id": "thag5.6:4.3",
      "pali": "Juhāmi dakkhiṇeyyaggiṁ,"
    },
    {
      "id": "thag5.6:4.4",
      "pali": "namassāmi tathāgataṁ."
    },
    {
      "id": "thag5.6:5.1",
      "pali": "Mohā sabbe pahīnā me,"
    },
    {
      "id": "thag5.6:5.2",
      "pali": "bhavataṇhā padālitā;"
    },
    {
      "id": "thag5.6:5.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag5.6:5.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag5.6:5.5",
      "pali": "… Nadīkassapo thero …."
    }
  ]
}
