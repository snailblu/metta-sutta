{
  "uid": "thag6.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.1:1.1",
      "pali": "“Disvāna pāṭihīrāni,"
    },
    {
      "id": "thag6.1:1.2",
      "pali": "gotamassa yasassino;"
    },
    {
      "id": "thag6.1:1.3",
      "pali": "Na tāvāhaṁ paṇipatiṁ,"
    },
    {
      "id": "thag6.1:1.4",
      "pali": "issāmānena vañcito."
    },
    {
      "id": "thag6.1:2.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "thag6.1:2.2",
      "pali": "codesi narasārathi;"
    },
    {
      "id": "thag6.1:2.3",
      "pali": "Tato me āsi saṁvego,"
    },
    {
      "id": "thag6.1:2.4",
      "pali": "abbhuto lomahaṁsano."
    },
    {
      "id": "thag6.1:3.1",
      "pali": "Pubbe jaṭilabhūtassa,"
    },
    {
      "id": "thag6.1:3.2",
      "pali": "yā me siddhi parittikā;"
    },
    {
      "id": "thag6.1:3.3",
      "pali": "Tāhaṁ tadā nirākatvā,"
    },
    {
      "id": "thag6.1:3.4",
      "pali": "pabbajiṁ jinasāsane."
    },
    {
      "id": "thag6.1:4.1",
      "pali": "Pubbe yaññena santuṭṭho,"
    },
    {
      "id": "thag6.1:4.2",
      "pali": "kāmadhātupurakkhato;"
    },
    {
      "id": "thag6.1:4.3",
      "pali": "Pacchā rāgañca dosañca,"
    },
    {
      "id": "thag6.1:4.4",
      "pali": "mohañcāpi samūhaniṁ."
    },
    {
      "id": "thag6.1:5.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thag6.1:5.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thag6.1:5.3",
      "pali": "Iddhimā paracittaññū,"
    },
    {
      "id": "thag6.1:5.4",
      "pali": "dibbasotañca pāpuṇiṁ."
    },
    {
      "id": "thag6.1:6.1",
      "pali": "Yassa catthāya pabbajito,"
    },
    {
      "id": "thag6.1:6.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "thag6.1:6.3",
      "pali": "So me attho anuppatto,"
    },
    {
      "id": "thag6.1:6.4",
      "pali": "sabbasaṁyojanakkhayo”ti."
    },
    {
      "id": "thag6.1:6.5",
      "pali": "… Uruveḷakassapo thero …."
    }
  ]
}
