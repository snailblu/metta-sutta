{
  "uid": "tha-ap76",
  "title": "Bhisāluvadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap76:1.1",
      "pali": "“Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap76:1.2",
      "pali": "vasāmi vipine ahaṁ;"
    },
    {
      "id": "tha-ap76:1.3",
      "pali": "Vipassiṁ addasaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap76:1.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap76:2.1",
      "pali": "Bhisāluvañca pādāsiṁ,"
    },
    {
      "id": "tha-ap76:2.2",
      "pali": "udakaṁ hatthadhovanaṁ;"
    },
    {
      "id": "tha-ap76:2.3",
      "pali": "Vanditvā sirasā pāde,"
    },
    {
      "id": "tha-ap76:2.4",
      "pali": "pakkāmi uttarāmukho."
    },
    {
      "id": "tha-ap76:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap76:3.2",
      "pali": "bhisāluvamadaṁ tadā;"
    },
    {
      "id": "tha-ap76:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap76:3.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap76:4.1",
      "pali": "Ito tatiyake kappe,"
    },
    {
      "id": "tha-ap76:4.2",
      "pali": "bhisasammatakhattiyo;"
    },
    {
      "id": "tha-ap76:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap76:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap76:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap76:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap76:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap76:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā bhisāluvadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap76:7.1",
      "pali": "Bhisāluvadāyakattherassāpadānaṁ catutthaṁ."
    },
    {
      "id": "tha-ap76:7.2",
      "pali": "Chaṭṭhabhāṇavāraṁ."
    }
  ]
}
