{
  "uid": "vv30",
  "title": "Pāricchattakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv30:1.1",
      "pali": "“Obhāsayitvā pathaviṁ sadevakaṁ,"
    },
    {
      "id": "vv30:1.2",
      "pali": "Atirocasi candimasūriyā viya;"
    },
    {
      "id": "vv30:1.3",
      "pali": "Siriyā ca vaṇṇena yasena tejasā,"
    },
    {
      "id": "vv30:1.4",
      "pali": "Brahmāva deve tidase sahindake."
    },
    {
      "id": "vv30:2.1",
      "pali": "Pucchāmi taṁ uppalamāladhārinī,"
    },
    {
      "id": "vv30:2.2",
      "pali": "Āveḷinī kañcanasannibhattace;"
    },
    {
      "id": "vv30:2.3",
      "pali": "Alaṅkate uttamavatthadhārinī,"
    },
    {
      "id": "vv30:2.4",
      "pali": "Kā tvaṁ subhe devate vandase mamaṁ."
    },
    {
      "id": "vv30:3.1",
      "pali": "Kiṁ tvaṁ pure kammamakāsi attanā,"
    },
    {
      "id": "vv30:3.2",
      "pali": "Manussabhūtā purimāya jātiyā;"
    },
    {
      "id": "vv30:3.3",
      "pali": "Dānaṁ suciṇṇaṁ atha sīlasaṁyamaṁ,"
    },
    {
      "id": "vv30:3.4",
      "pali": "Kenūpapannā sugatiṁ yasassinī;"
    },
    {
      "id": "vv30:3.5",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv30:3.6",
      "pali": "Kissa kammassidaṁ phalan”ti."
    },
    {
      "id": "vv30:4.1",
      "pali": "“Idāni bhante imameva gāmaṁ,"
    },
    {
      "id": "vv30:4.2",
      "pali": "Piṇḍāya amhākaṁ gharaṁ upāgami;"
    },
    {
      "id": "vv30:4.3",
      "pali": "Tato te ucchussa adāsi khaṇḍikaṁ,"
    },
    {
      "id": "vv30:4.4",
      "pali": "Pasannacittā atulāya pītiyā."
    },
    {
      "id": "vv30:5.1",
      "pali": "Sassu ca pacchā anuyuñjate mamaṁ,"
    },
    {
      "id": "vv30:5.2",
      "pali": "Kahaṁ nu ucchuṁ vadhuke avākiri;"
    },
    {
      "id": "vv30:5.3",
      "pali": "Na chaḍḍitaṁ no pana khāditaṁ mayā,"
    },
    {
      "id": "vv30:5.4",
      "pali": "Santassa bhikkhussa sayaṁ adāsahaṁ."
    },
    {
      "id": "vv30:6.1",
      "pali": "Tuyhaṁ nvidaṁ issariyaṁ atho mama,"
    },
    {
      "id": "vv30:6.2",
      "pali": "Itissā sassu paribhāsate mamaṁ;"
    },
    {
      "id": "vv30:6.3",
      "pali": "Pīṭhaṁ gahetvā pahāraṁ adāsi me,"
    },
    {
      "id": "vv30:6.4",
      "pali": "Tato cutā kālakatāmhi devatā."
    },
    {
      "id": "vv30:7.1",
      "pali": "Tadeva kammaṁ kusalaṁ kataṁ mayā,"
    },
    {
      "id": "vv30:7.2",
      "pali": "Sukhañca kammaṁ anubhomi attanā;"
    },
    {
      "id": "vv30:7.3",
      "pali": "Devehi saddhiṁ paricārayāmahaṁ,"
    },
    {
      "id": "vv30:7.4",
      "pali": "Modāmahaṁ kāmaguṇehi pañcahi."
    },
    {
      "id": "vv30:8.1",
      "pali": "Tadeva kammaṁ kusalaṁ kataṁ mayā,"
    },
    {
      "id": "vv30:8.2",
      "pali": "Sukhañca kammaṁ anubhomi attanā;"
    },
    {
      "id": "vv30:8.3",
      "pali": "Devindaguttā tidasehi rakkhitā,"
    },
    {
      "id": "vv30:8.4",
      "pali": "Samappitā kāmaguṇehi pañcahi."
    },
    {
      "id": "vv30:9.1",
      "pali": "Etādisaṁ puññaphalaṁ anappakaṁ,"
    },
    {
      "id": "vv30:9.2",
      "pali": "Mahāvipākā mama ucchudakkhiṇā;"
    },
    {
      "id": "vv30:9.3",
      "pali": "Devehi saddhiṁ paricārayāmahaṁ,"
    },
    {
      "id": "vv30:9.4",
      "pali": "Modāmahaṁ kāmaguṇehi pañcahi."
    },
    {
      "id": "vv30:10.1",
      "pali": "Etādisaṁ puññaphalaṁ anappakaṁ,"
    },
    {
      "id": "vv30:10.2",
      "pali": "Mahājutikā mama ucchudakkhiṇā;"
    },
    {
      "id": "vv30:10.3",
      "pali": "Devindaguttā tidasehi rakkhitā,"
    },
    {
      "id": "vv30:10.4",
      "pali": "Sahassanettoriva nandane vane."
    },
    {
      "id": "vv30:11.1",
      "pali": "Tuvañca bhante anukampakaṁ viduṁ,"
    },
    {
      "id": "vv30:11.2",
      "pali": "Upecca vandiṁ kusalañca pucchisaṁ;"
    },
    {
      "id": "vv30:11.3",
      "pali": "Tato te ucchussa adāsi khaṇḍikaṁ,"
    },
    {
      "id": "vv30:11.4",
      "pali": "Pasannacittā atulāya pītiyā”ti."
    },
    {
      "id": "vv30:12.1",
      "pali": "Ucchudāyikāvimānaṁ dutiyaṁ."
    }
  ]
}
