{
  "uid": "ja313",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja313:1.1",
      "pali": "“Yo te hatthe ca pāde ca,"
    },
    {
      "id": "ja313:1.2",
      "pali": "kaṇṇanāsañca chedayi;"
    },
    {
      "id": "ja313:1.3",
      "pali": "Tassa kujjha mahāvīra,"
    },
    {
      "id": "ja313:1.4",
      "pali": "mā raṭṭhaṁ vinasā idaṁ”."
    },
    {
      "id": "ja313:2.1",
      "pali": "“Yo me hatthe ca pāde ca,"
    },
    {
      "id": "ja313:2.2",
      "pali": "kaṇṇanāsañca chedayi;"
    },
    {
      "id": "ja313:2.3",
      "pali": "Ciraṁ jīvatu so rājā,"
    },
    {
      "id": "ja313:2.4",
      "pali": "na hi kujjhanti mādisā”."
    },
    {
      "id": "ja313:3.1",
      "pali": "Ahū atītamaddhānaṁ,"
    },
    {
      "id": "ja313:3.2",
      "pali": "samaṇo khantidīpano;"
    },
    {
      "id": "ja313:3.3",
      "pali": "Taṁ khantiyāyeva ṭhitaṁ,"
    },
    {
      "id": "ja313:3.4",
      "pali": "kāsirājā achedayi."
    },
    {
      "id": "ja313:4.1",
      "pali": "Tassa kammapharusassa,"
    },
    {
      "id": "ja313:4.2",
      "pali": "vipāko kaṭuko ahu;"
    },
    {
      "id": "ja313:4.3",
      "pali": "Yaṁ kāsirājā vedesi,"
    },
    {
      "id": "ja313:4.4",
      "pali": "nirayamhi samappitoti."
    },
    {
      "id": "ja313:5.1",
      "pali": "Khantīvādījātakaṁ tatiyaṁ."
    }
  ]
}
