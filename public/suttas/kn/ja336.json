{
  "uid": "ja336",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja336:1.1",
      "pali": "“Tiṇaṁ tiṇanti lapasi,"
    },
    {
      "id": "ja336:1.2",
      "pali": "ko nu te tiṇamāhari;"
    },
    {
      "id": "ja336:1.3",
      "pali": "Kiṁ nu te tiṇakiccatthi,"
    },
    {
      "id": "ja336:1.4",
      "pali": "tiṇameva pabhāsasi”."
    },
    {
      "id": "ja336:2.1",
      "pali": "“Idhāgamā brahmacārī,"
    },
    {
      "id": "ja336:2.2",
      "pali": "brahā chatto bahussuto;"
    },
    {
      "id": "ja336:2.3",
      "pali": "So me sabbaṁ samādāya,"
    },
    {
      "id": "ja336:2.4",
      "pali": "tiṇaṁ nikkhippa gacchati”."
    },
    {
      "id": "ja336:3.1",
      "pali": "“Evetaṁ hoti kattabbaṁ,"
    },
    {
      "id": "ja336:3.2",
      "pali": "appena bahumicchatā;"
    },
    {
      "id": "ja336:3.3",
      "pali": "Sabbaṁ sakassa ādānaṁ,"
    },
    {
      "id": "ja336:3.4",
      "pali": "anādānaṁ tiṇassa ca”."
    },
    {
      "id": "ja336:3.5",
      "pali": "(…)"
    },
    {
      "id": "ja336:4.1",
      "pali": "“Sīlavanto na kubbanti,"
    },
    {
      "id": "ja336:4.2",
      "pali": "bālo sīlāni kubbati;"
    },
    {
      "id": "ja336:4.3",
      "pali": "Aniccasīlaṁ dussīlyaṁ,"
    },
    {
      "id": "ja336:4.4",
      "pali": "kiṁ paṇḍiccaṁ karissatī”ti."
    },
    {
      "id": "ja336:5.1",
      "pali": "Brahāchattajātakaṁ chaṭṭhaṁ."
    }
  ]
}
