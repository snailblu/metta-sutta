{
  "uid": "tha-ap415",
  "title": "3 Tiṇasūlakachādaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap415:1.1",
      "pali": "“Jātiṁ jarañca maraṇaṁ,"
    },
    {
      "id": "tha-ap415:1.2",
      "pali": "paccavekkhiṁ ahaṁ tadā;"
    },
    {
      "id": "tha-ap415:1.3",
      "pali": "Ekako abhinikkhamma,"
    },
    {
      "id": "tha-ap415:1.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "tha-ap415:2.1",
      "pali": "Caramānonupubbena,"
    },
    {
      "id": "tha-ap415:2.2",
      "pali": "gaṅgātīraṁ upāgamiṁ;"
    },
    {
      "id": "tha-ap415:2.3",
      "pali": "Tatthaddasāsiṁ pathaviṁ,"
    },
    {
      "id": "tha-ap415:2.4",
      "pali": "gaṅgātīre samunnataṁ."
    },
    {
      "id": "tha-ap415:3.1",
      "pali": "Assamaṁ tattha māpetvā,"
    },
    {
      "id": "tha-ap415:3.2",
      "pali": "vasāmi assame ahaṁ;"
    },
    {
      "id": "tha-ap415:3.3",
      "pali": "Sukato caṅkamo mayhaṁ,"
    },
    {
      "id": "tha-ap415:3.4",
      "pali": "nānādijagaṇāyuto."
    },
    {
      "id": "tha-ap415:4.1",
      "pali": "Mamupenti ca vissatthā,"
    },
    {
      "id": "tha-ap415:4.2",
      "pali": "kūjanti ca manoharaṁ;"
    },
    {
      "id": "tha-ap415:4.3",
      "pali": "Ramamāno saha tehi,"
    },
    {
      "id": "tha-ap415:4.4",
      "pali": "vasāmi assame ahaṁ."
    },
    {
      "id": "tha-ap415:5.1",
      "pali": "Mama assamasāmantā,"
    },
    {
      "id": "tha-ap415:5.2",
      "pali": "migarājā catukkamo;"
    },
    {
      "id": "tha-ap415:5.3",
      "pali": "Āsayā abhinikkhamma,"
    },
    {
      "id": "tha-ap415:5.4",
      "pali": "gajji so asanī viya."
    },
    {
      "id": "tha-ap415:6.1",
      "pali": "Nadite migarāje ca,"
    },
    {
      "id": "tha-ap415:6.2",
      "pali": "hāso me udapajjatha;"
    },
    {
      "id": "tha-ap415:6.3",
      "pali": "Migarājaṁ gavesanto,"
    },
    {
      "id": "tha-ap415:6.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap415:7.1",
      "pali": "Disvānāhaṁ devadevaṁ,"
    },
    {
      "id": "tha-ap415:7.2",
      "pali": "tissaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap415:7.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap415:7.4",
      "pali": "pūjayiṁ nāgakesaraṁ."
    },
    {
      "id": "tha-ap415:8.1",
      "pali": "Uggacchantaṁva sūriyaṁ,"
    },
    {
      "id": "tha-ap415:8.2",
      "pali": "sālarājaṁva pupphitaṁ;"
    },
    {
      "id": "tha-ap415:8.3",
      "pali": "Osadhiṁva virocantaṁ,"
    },
    {
      "id": "tha-ap415:8.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap415:9.1",
      "pali": "‘Tava ñāṇena sabbaññu,"
    },
    {
      "id": "tha-ap415:9.2",
      "pali": "mocesimaṁ sadevakaṁ;"
    },
    {
      "id": "tha-ap415:9.3",
      "pali": "Tavaṁ ārādhayitvāna,"
    },
    {
      "id": "tha-ap415:9.4",
      "pali": "jātiyā parimuccare."
    },
    {
      "id": "tha-ap415:10.1",
      "pali": "Adassanena sabbaññu,"
    },
    {
      "id": "tha-ap415:10.2",
      "pali": "buddhānaṁ sabbadassinaṁ;"
    },
    {
      "id": "tha-ap415:10.3",
      "pali": "Patantivīcinirayaṁ,"
    },
    {
      "id": "tha-ap415:10.4",
      "pali": "rāgadosehi ophuṭā."
    },
    {
      "id": "tha-ap415:11.1",
      "pali": "Tava dassanamāgamma,"
    },
    {
      "id": "tha-ap415:11.2",
      "pali": "sabbaññu lokanāyaka;"
    },
    {
      "id": "tha-ap415:11.3",
      "pali": "Pamuccanti bhavā sabbā,"
    },
    {
      "id": "tha-ap415:11.4",
      "pali": "phusanti amataṁ padaṁ."
    },
    {
      "id": "tha-ap415:12.1",
      "pali": "Yadā buddhā cakkhumanto,"
    },
    {
      "id": "tha-ap415:12.2",
      "pali": "uppajjanti pabhaṅkarā;"
    },
    {
      "id": "tha-ap415:12.3",
      "pali": "Kilese jhāpayitvāna,"
    },
    {
      "id": "tha-ap415:12.4",
      "pali": "ālokaṁ dassayanti te’."
    },
    {
      "id": "tha-ap415:13.1",
      "pali": "Kittayitvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap415:13.2",
      "pali": "tissaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap415:13.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap415:13.4",
      "pali": "tiṇasūlaṁ apūjayiṁ."
    },
    {
      "id": "tha-ap415:14.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap415:14.2",
      "pali": "tisso lokagganāyako;"
    },
    {
      "id": "tha-ap415:14.3",
      "pali": "Sakāsane nisīditvā,"
    },
    {
      "id": "tha-ap415:14.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap415:15.1",
      "pali": "‘Yo maṁ pupphehi chādesi,"
    },
    {
      "id": "tha-ap415:15.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap415:15.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap415:15.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap415:16.1",
      "pali": "Pañcavīsatikkhattuṁ so,"
    },
    {
      "id": "tha-ap415:16.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap415:16.3",
      "pali": "Pañcasattatikkhattuñca,"
    },
    {
      "id": "tha-ap415:16.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap415:17.1",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap415:17.2",
      "pali": "gaṇanāto asaṅkhiyaṁ;"
    },
    {
      "id": "tha-ap415:17.3",
      "pali": "Tassa kammanissandena,"
    },
    {
      "id": "tha-ap415:17.4",
      "pali": "pupphānaṁ pūjanāya ca."
    },
    {
      "id": "tha-ap415:18.1",
      "pali": "Sīsaṁnhāto cayaṁ poso,"
    },
    {
      "id": "tha-ap415:18.2",
      "pali": "pupphamākaṅkhate yadi;"
    },
    {
      "id": "tha-ap415:18.3",
      "pali": "Puññakammena saṁyuttaṁ,"
    },
    {
      "id": "tha-ap415:18.4",
      "pali": "purato pātubhavissati."
    },
    {
      "id": "tha-ap415:19.1",
      "pali": "Yaṁ yaṁ icchati kāmehi,"
    },
    {
      "id": "tha-ap415:19.2",
      "pali": "taṁ taṁ pātubhavissati;"
    },
    {
      "id": "tha-ap415:19.3",
      "pali": "Saṅkappaṁ paripūretvā,"
    },
    {
      "id": "tha-ap415:19.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap415:20.1",
      "pali": "Aṭṭhārasamaṁ bhāṇavāraṁ."
    },
    {
      "id": "tha-ap415:21.1",
      "pali": "Kilese jhāpayitvāna,"
    },
    {
      "id": "tha-ap415:21.2",
      "pali": "sampajāno patissato;"
    },
    {
      "id": "tha-ap415:21.3",
      "pali": "Ekāsane nisīditvā,"
    },
    {
      "id": "tha-ap415:21.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap415:22.1",
      "pali": "Caṅkamanto nipajjanto,"
    },
    {
      "id": "tha-ap415:22.2",
      "pali": "nisinno uda vā ṭhito;"
    },
    {
      "id": "tha-ap415:22.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap415:22.4",
      "pali": "viharāmi ahaṁ sadā."
    },
    {
      "id": "tha-ap415:23.1",
      "pali": "Cīvare piṇḍapāte ca,"
    },
    {
      "id": "tha-ap415:23.2",
      "pali": "paccaye sayanāsane;"
    },
    {
      "id": "tha-ap415:23.3",
      "pali": "Tattha me ūnatā natthi,"
    },
    {
      "id": "tha-ap415:23.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap415:24.1",
      "pali": "So dāni patto amataṁ,"
    },
    {
      "id": "tha-ap415:24.2",
      "pali": "santaṁ padamanuttaraṁ;"
    },
    {
      "id": "tha-ap415:24.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap415:24.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap415:25.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap415:25.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap415:25.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap415:25.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap415:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap415:26.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap415:26.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap415:27.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap415:27.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap415:27.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap415:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap415:28.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap415:28.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap415:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇasūlakachādaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap415:30.1",
      "pali": "Tiṇasūlakachādaniyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
