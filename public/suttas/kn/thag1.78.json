{
  "uid": "thag1.78",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.78:1.1",
      "pali": "“Anekajātisaṁsāraṁ,"
    },
    {
      "id": "thag1.78:1.2",
      "pali": "sandhāvissaṁ anibbisaṁ;"
    },
    {
      "id": "thag1.78:1.3",
      "pali": "Tassa me dukkhajātassa,"
    },
    {
      "id": "thag1.78:1.4",
      "pali": "dukkhakkhandho aparaddho”ti."
    },
    {
      "id": "thag1.78:1.5",
      "pali": "… Meṇḍasiro thero …."
    }
  ]
}
