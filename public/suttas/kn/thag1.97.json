{
  "uid": "thag1.97",
  "title": "Dasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.97:1.1",
      "pali": "“Hitvā satapalaṁ kaṁsaṁ,"
    },
    {
      "id": "thag1.97:1.2",
      "pali": "Sovaṇṇaṁ satarājikaṁ;"
    },
    {
      "id": "thag1.97:1.3",
      "pali": "Aggahiṁ mattikāpattaṁ,"
    },
    {
      "id": "thag1.97:1.4",
      "pali": "Idaṁ dutiyābhisecanan”ti."
    },
    {
      "id": "thag1.97:1.5",
      "pali": "… Tisso thero …."
    }
  ]
}
