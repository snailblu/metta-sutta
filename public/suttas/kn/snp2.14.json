{
  "uid": "snp2.14",
  "title": "Dhammikasutta",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp2.14:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp2.14:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "snp2.14:1.3",
      "pali": "Atha kho dhammiko upāsako pañcahi upāsakasatehi saddhiṁ yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho dhammiko upāsako bhagavantaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "snp2.14:2.1",
      "pali": "“Pucchāmi taṁ gotama bhūripañña,"
    },
    {
      "id": "snp2.14:2.2",
      "pali": "Kathaṅkaro sāvako sādhu hoti;"
    },
    {
      "id": "snp2.14:2.3",
      "pali": "Yo vā agārā anagārameti,"
    },
    {
      "id": "snp2.14:2.4",
      "pali": "Agārino vā panupāsakāse."
    },
    {
      "id": "snp2.14:3.1",
      "pali": "Tuvañhi lokassa sadevakassa,"
    },
    {
      "id": "snp2.14:3.2",
      "pali": "Gatiṁ pajānāsi parāyaṇañca;"
    },
    {
      "id": "snp2.14:3.3",
      "pali": "Na catthi tulyo nipuṇatthadassī,"
    },
    {
      "id": "snp2.14:3.4",
      "pali": "Tuvañhi buddhaṁ pavaraṁ vadanti."
    },
    {
      "id": "snp2.14:4.1",
      "pali": "Sabbaṁ tuvaṁ ñāṇamavecca dhammaṁ,"
    },
    {
      "id": "snp2.14:4.2",
      "pali": "Pakāsesi satte anukampamāno;"
    },
    {
      "id": "snp2.14:4.3",
      "pali": "Vivaṭṭacchadosi samantacakkhu,"
    },
    {
      "id": "snp2.14:4.4",
      "pali": "Virocasi vimalo sabbaloke."
    },
    {
      "id": "snp2.14:5.1",
      "pali": "Āgañchi te santike nāgarājā,"
    },
    {
      "id": "snp2.14:5.2",
      "pali": "Erāvaṇo nāma jinoti sutvā;"
    },
    {
      "id": "snp2.14:5.3",
      "pali": "Sopi tayā mantayitvājjhagamā,"
    },
    {
      "id": "snp2.14:5.4",
      "pali": "Sādhūti sutvāna patītarūpo."
    },
    {
      "id": "snp2.14:6.1",
      "pali": "Rājāpi taṁ vessavaṇo kuvero,"
    },
    {
      "id": "snp2.14:6.2",
      "pali": "Upeti dhammaṁ paripucchamāno;"
    },
    {
      "id": "snp2.14:6.3",
      "pali": "Tassāpi tvaṁ pucchito brūsi dhīra,"
    },
    {
      "id": "snp2.14:6.4",
      "pali": "So cāpi sutvāna patītarūpo."
    },
    {
      "id": "snp2.14:7.1",
      "pali": "Ye kecime titthiyā vādasīlā,"
    },
    {
      "id": "snp2.14:7.2",
      "pali": "Ājīvakā vā yadi vā nigaṇṭhā;"
    },
    {
      "id": "snp2.14:7.3",
      "pali": "Paññāya taṁ nātitaranti sabbe,"
    },
    {
      "id": "snp2.14:7.4",
      "pali": "Ṭhito vajantaṁ viya sīghagāmiṁ."
    },
    {
      "id": "snp2.14:8.1",
      "pali": "Ye kecime brāhmaṇā vādasīlā,"
    },
    {
      "id": "snp2.14:8.2",
      "pali": "Vuddhā cāpi brāhmaṇā santi keci;"
    },
    {
      "id": "snp2.14:8.3",
      "pali": "Sabbe tayi atthabaddhā bhavanti,"
    },
    {
      "id": "snp2.14:8.4",
      "pali": "Ye cāpi aññe vādino maññamānā."
    },
    {
      "id": "snp2.14:9.1",
      "pali": "Ayañhi dhammo nipuṇo sukho ca,"
    },
    {
      "id": "snp2.14:9.2",
      "pali": "Yoyaṁ tayā bhagavā suppavutto;"
    },
    {
      "id": "snp2.14:9.3",
      "pali": "Tameva sabbepi sussūsamānā,"
    },
    {
      "id": "snp2.14:9.4",
      "pali": "Taṁ no vada pucchito buddhaseṭṭha."
    },
    {
      "id": "snp2.14:10.1",
      "pali": "Sabbepime bhikkhavo sannisinnā,"
    },
    {
      "id": "snp2.14:10.2",
      "pali": "Upāsakā cāpi tatheva sotuṁ;"
    },
    {
      "id": "snp2.14:10.3",
      "pali": "Suṇantu dhammaṁ vimalenānubuddhaṁ,"
    },
    {
      "id": "snp2.14:10.4",
      "pali": "Subhāsitaṁ vāsavasseva devā”."
    },
    {
      "id": "snp2.14:11.1",
      "pali": "“Suṇātha me bhikkhavo sāvayāmi vo,"
    },
    {
      "id": "snp2.14:11.2",
      "pali": "Dhammaṁ dhutaṁ tañca carātha sabbe;"
    },
    {
      "id": "snp2.14:11.3",
      "pali": "Iriyāpathaṁ pabbajitānulomikaṁ,"
    },
    {
      "id": "snp2.14:11.4",
      "pali": "Sevetha naṁ atthadaso mutīmā."
    },
    {
      "id": "snp2.14:12.1",
      "pali": "No ve vikāle vicareyya bhikkhu,"
    },
    {
      "id": "snp2.14:12.2",
      "pali": "Gāme ca piṇḍāya careyya kāle;"
    },
    {
      "id": "snp2.14:12.3",
      "pali": "Akālacāriñhi sajanti saṅgā,"
    },
    {
      "id": "snp2.14:12.4",
      "pali": "Tasmā vikāle na caranti buddhā."
    },
    {
      "id": "snp2.14:13.1",
      "pali": "Rūpā ca saddā ca rasā ca gandhā,"
    },
    {
      "id": "snp2.14:13.2",
      "pali": "Phassā ca ye sammadayanti satte;"
    },
    {
      "id": "snp2.14:13.3",
      "pali": "Etesu dhammesu vineyya chandaṁ,"
    },
    {
      "id": "snp2.14:13.4",
      "pali": "Kālena so pavise pātarāsaṁ."
    },
    {
      "id": "snp2.14:14.1",
      "pali": "Piṇḍañca bhikkhu samayena laddhā,"
    },
    {
      "id": "snp2.14:14.2",
      "pali": "Eko paṭikkamma raho nisīde;"
    },
    {
      "id": "snp2.14:14.3",
      "pali": "Ajjhattacintī na mano bahiddhā,"
    },
    {
      "id": "snp2.14:14.4",
      "pali": "Nicchāraye saṅgahitattabhāvo."
    },
    {
      "id": "snp2.14:15.1",
      "pali": "Sacepi so sallape sāvakena,"
    },
    {
      "id": "snp2.14:15.2",
      "pali": "Aññena vā kenaci bhikkhunā vā;"
    },
    {
      "id": "snp2.14:15.3",
      "pali": "Dhammaṁ paṇītaṁ tamudāhareyya,"
    },
    {
      "id": "snp2.14:15.4",
      "pali": "Na pesuṇaṁ nopi parūpavādaṁ."
    },
    {
      "id": "snp2.14:16.1",
      "pali": "Vādañhi eke paṭiseniyanti,"
    },
    {
      "id": "snp2.14:16.2",
      "pali": "Na te pasaṁsāma parittapaññe;"
    },
    {
      "id": "snp2.14:16.3",
      "pali": "Tato tato ne pasajanti saṅgā,"
    },
    {
      "id": "snp2.14:16.4",
      "pali": "Cittañhi te tattha gamenti dūre."
    },
    {
      "id": "snp2.14:17.1",
      "pali": "Piṇḍaṁ vihāraṁ sayanāsanañca,"
    },
    {
      "id": "snp2.14:17.2",
      "pali": "Āpañca saṅghāṭirajūpavāhanaṁ;"
    },
    {
      "id": "snp2.14:17.3",
      "pali": "Sutvāna dhammaṁ sugatena desitaṁ,"
    },
    {
      "id": "snp2.14:17.4",
      "pali": "Saṅkhāya seve varapaññasāvako."
    },
    {
      "id": "snp2.14:18.1",
      "pali": "Tasmā hi piṇḍe sayanāsane ca,"
    },
    {
      "id": "snp2.14:18.2",
      "pali": "Āpe ca saṅghāṭirajūpavāhane;"
    },
    {
      "id": "snp2.14:18.3",
      "pali": "Etesu dhammesu anūpalitto,"
    },
    {
      "id": "snp2.14:18.4",
      "pali": "Bhikkhu yathā pokkhare vāribindu."
    },
    {
      "id": "snp2.14:19.1",
      "pali": "Gahaṭṭhavattaṁ pana vo vadāmi,"
    },
    {
      "id": "snp2.14:19.2",
      "pali": "Yathākaro sāvako sādhu hoti;"
    },
    {
      "id": "snp2.14:19.3",
      "pali": "Na hesa labbhā sapariggahena,"
    },
    {
      "id": "snp2.14:19.4",
      "pali": "Phassetuṁ yo kevalo bhikkhudhammo."
    },
    {
      "id": "snp2.14:20.1",
      "pali": "Pāṇaṁ na hane na ca ghātayeyya,"
    },
    {
      "id": "snp2.14:20.2",
      "pali": "Na cānujaññā hanataṁ paresaṁ;"
    },
    {
      "id": "snp2.14:20.3",
      "pali": "Sabbesu bhūtesu nidhāya daṇḍaṁ,"
    },
    {
      "id": "snp2.14:20.4",
      "pali": "Ye thāvarā ye ca tasā santi loke."
    },
    {
      "id": "snp2.14:21.1",
      "pali": "Tato adinnaṁ parivajjayeyya,"
    },
    {
      "id": "snp2.14:21.2",
      "pali": "Kiñci kvaci sāvako bujjhamāno;"
    },
    {
      "id": "snp2.14:21.3",
      "pali": "Na hāraye harataṁ nānujaññā,"
    },
    {
      "id": "snp2.14:21.4",
      "pali": "Sabbaṁ adinnaṁ parivajjayeyya."
    },
    {
      "id": "snp2.14:22.1",
      "pali": "Abrahmacariyaṁ parivajjayeyya,"
    },
    {
      "id": "snp2.14:22.2",
      "pali": "Aṅgārakāsuṁ jalitaṁva viññū;"
    },
    {
      "id": "snp2.14:22.3",
      "pali": "Asambhuṇanto pana brahmacariyaṁ,"
    },
    {
      "id": "snp2.14:22.4",
      "pali": "Parassa dāraṁ na atikkameyya."
    },
    {
      "id": "snp2.14:23.1",
      "pali": "Sabhaggato vā parisaggato vā,"
    },
    {
      "id": "snp2.14:23.2",
      "pali": "Ekassa veko na musā bhaṇeyya;"
    },
    {
      "id": "snp2.14:23.3",
      "pali": "Na bhāṇaye bhaṇataṁ nānujaññā,"
    },
    {
      "id": "snp2.14:23.4",
      "pali": "Sabbaṁ abhūtaṁ parivajjayeyya."
    },
    {
      "id": "snp2.14:24.1",
      "pali": "Majjañca pānaṁ na samācareyya,"
    },
    {
      "id": "snp2.14:24.2",
      "pali": "Dhammaṁ imaṁ rocaye yo gahaṭṭho;"
    },
    {
      "id": "snp2.14:24.3",
      "pali": "Na pāyaye pivataṁ nānujaññā,"
    },
    {
      "id": "snp2.14:24.4",
      "pali": "Ummādanantaṁ iti naṁ viditvā."
    },
    {
      "id": "snp2.14:25.1",
      "pali": "Madā hi pāpāni karonti bālā,"
    },
    {
      "id": "snp2.14:25.2",
      "pali": "Kārenti caññepi jane pamatte;"
    },
    {
      "id": "snp2.14:25.3",
      "pali": "Etaṁ apuññāyatanaṁ vivajjaye,"
    },
    {
      "id": "snp2.14:25.4",
      "pali": "Ummādanaṁ mohanaṁ bālakantaṁ."
    },
    {
      "id": "snp2.14:26.1",
      "pali": "Pāṇaṁ na hane na cādinnamādiye,"
    },
    {
      "id": "snp2.14:26.2",
      "pali": "Musā na bhāse na ca majjapo siyā;"
    },
    {
      "id": "snp2.14:26.3",
      "pali": "Abrahmacariyā virameyya methunā,"
    },
    {
      "id": "snp2.14:26.4",
      "pali": "Rattiṁ na bhuñjeyya vikālabhojanaṁ."
    },
    {
      "id": "snp2.14:27.1",
      "pali": "Mālaṁ na dhāre na ca gandhamācare,"
    },
    {
      "id": "snp2.14:27.2",
      "pali": "Mañce chamāyaṁ va sayetha santhate;"
    },
    {
      "id": "snp2.14:27.3",
      "pali": "Etañhi aṭṭhaṅgikamāhuposathaṁ,"
    },
    {
      "id": "snp2.14:27.4",
      "pali": "Buddhena dukkhantagunā pakāsitaṁ."
    },
    {
      "id": "snp2.14:28.1",
      "pali": "Tato ca pakkhassupavassuposathaṁ,"
    },
    {
      "id": "snp2.14:28.2",
      "pali": "Cātuddasiṁ pañcadasiñca aṭṭhamiṁ;"
    },
    {
      "id": "snp2.14:28.3",
      "pali": "Pāṭihāriyapakkhañca pasannamānaso,"
    },
    {
      "id": "snp2.14:28.4",
      "pali": "Aṭṭhaṅgupetaṁ susamattarūpaṁ."
    },
    {
      "id": "snp2.14:29.1",
      "pali": "Tato ca pāto upavutthuposatho,"
    },
    {
      "id": "snp2.14:29.2",
      "pali": "Annena pānena ca bhikkhusaṅghaṁ;"
    },
    {
      "id": "snp2.14:29.3",
      "pali": "Pasannacitto anumodamāno,"
    },
    {
      "id": "snp2.14:29.4",
      "pali": "Yathārahaṁ saṁvibhajetha viññū."
    },
    {
      "id": "snp2.14:30.1",
      "pali": "Dhammena mātāpitaro bhareyya,"
    },
    {
      "id": "snp2.14:30.2",
      "pali": "Payojaye dhammikaṁ so vaṇijjaṁ;"
    },
    {
      "id": "snp2.14:30.3",
      "pali": "Etaṁ gihī vattayamappamatto,"
    },
    {
      "id": "snp2.14:30.4",
      "pali": "Sayampabhe nāma upeti deve”ti."
    },
    {
      "id": "snp2.14:30.5",
      "pali": "Dhammikasuttaṁ cuddasamaṁ."
    },
    {
      "id": "snp2.14:30.6",
      "pali": "Cūḷavaggo dutiyo."
    },
    {
      "id": "snp2.14:31.1",
      "pali": "Ratanāmagandho hiri ca,"
    },
    {
      "id": "snp2.14:31.2",
      "pali": "maṅgalaṁ sūcilomena;"
    },
    {
      "id": "snp2.14:31.3",
      "pali": "Dhammacariyañca brāhmaṇo,"
    },
    {
      "id": "snp2.14:31.4",
      "pali": "nāvā kiṁsīlamuṭṭhānaṁ."
    },
    {
      "id": "snp2.14:32.1",
      "pali": "Rāhulo puna kappo ca,"
    },
    {
      "id": "snp2.14:32.2",
      "pali": "paribbājaniyaṁ tathā;"
    },
    {
      "id": "snp2.14:32.3",
      "pali": "Dhammikañca viduno āhu,"
    },
    {
      "id": "snp2.14:32.4",
      "pali": "cūḷavagganti cuddasāti."
    }
  ]
}
