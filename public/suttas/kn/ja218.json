{
  "uid": "ja218",
  "title": "Bīraṇathambhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja218:1.1",
      "pali": "“Saṭhassa sāṭheyyamidaṁ sucintitaṁ,"
    },
    {
      "id": "ja218:1.2",
      "pali": "Paccoḍḍitaṁ paṭikūṭassa kūṭaṁ;"
    },
    {
      "id": "ja218:1.3",
      "pali": "Phālañce khādeyyuṁ mūsikā,"
    },
    {
      "id": "ja218:1.4",
      "pali": "Kasmā kumāraṁ kulalā na hareyyuṁ."
    },
    {
      "id": "ja218:2.1",
      "pali": "Kūṭassa hi santi kūṭakūṭā,"
    },
    {
      "id": "ja218:2.2",
      "pali": "Bhavati cāpi nikatino nikatyā;"
    },
    {
      "id": "ja218:2.3",
      "pali": "Dehi puttanaṭṭha phālanaṭṭhassa phālaṁ,"
    },
    {
      "id": "ja218:2.4",
      "pali": "Mā te puttamahāsi phālanaṭṭho”ti."
    },
    {
      "id": "ja218:3.1",
      "pali": "Kūṭavāṇijajātakaṁ aṭṭhamaṁ."
    }
  ]
}
