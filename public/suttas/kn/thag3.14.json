{
  "uid": "thag3.14",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.14:1.1",
      "pali": "“Saṁsaraṁ hi nirayaṁ agacchissaṁ,"
    },
    {
      "id": "thag3.14:1.2",
      "pali": "Petalokamagamaṁ punappunaṁ;"
    },
    {
      "id": "thag3.14:1.3",
      "pali": "Dukkhamamhipi tiracchānayoniyaṁ,"
    },
    {
      "id": "thag3.14:1.4",
      "pali": "Nekadhā hi vusitaṁ ciraṁ mayā."
    },
    {
      "id": "thag3.14:2.1",
      "pali": "Mānusopi ca bhavobhirādhito,"
    },
    {
      "id": "thag3.14:2.2",
      "pali": "Saggakāyamagamaṁ sakiṁ sakiṁ;"
    },
    {
      "id": "thag3.14:2.3",
      "pali": "Rūpadhātusu arūpadhātusu,"
    },
    {
      "id": "thag3.14:2.4",
      "pali": "Nevasaññisu asaññisuṭṭhitaṁ."
    },
    {
      "id": "thag3.14:3.1",
      "pali": "Sambhavā suviditā asārakā,"
    },
    {
      "id": "thag3.14:3.2",
      "pali": "Saṅkhatā pacalitā saderitā;"
    },
    {
      "id": "thag3.14:3.3",
      "pali": "Taṁ viditvā mahamattasambhavaṁ,"
    },
    {
      "id": "thag3.14:3.4",
      "pali": "Santimeva satimā samajjhagan”ti."
    },
    {
      "id": "thag3.14:3.5",
      "pali": "… Gotamo thero …."
    }
  ]
}
