{
  "uid": "ja310",
  "title": "Kāliṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja310:1.1",
      "pali": "“Sasamuddapariyāyaṁ,"
    },
    {
      "id": "ja310:1.2",
      "pali": "mahiṁ sāgarakuṇḍalaṁ;"
    },
    {
      "id": "ja310:1.3",
      "pali": "Na icche saha nindāya,"
    },
    {
      "id": "ja310:1.4",
      "pali": "evaṁ seyya vijānahi."
    },
    {
      "id": "ja310:2.1",
      "pali": "Dhiratthu taṁ yasalābhaṁ,"
    },
    {
      "id": "ja310:2.2",
      "pali": "dhanalābhañca brāhmaṇa;"
    },
    {
      "id": "ja310:2.3",
      "pali": "Yā vutti vinipātena,"
    },
    {
      "id": "ja310:2.4",
      "pali": "adhammacaraṇena vā."
    },
    {
      "id": "ja310:3.1",
      "pali": "Api ce pattamādāya,"
    },
    {
      "id": "ja310:3.2",
      "pali": "anagāro paribbaje;"
    },
    {
      "id": "ja310:3.3",
      "pali": "Sāyeva jīvikā seyyo,"
    },
    {
      "id": "ja310:3.4",
      "pali": "yā cādhammena esanā."
    },
    {
      "id": "ja310:4.1",
      "pali": "Api ce pattamādāya,"
    },
    {
      "id": "ja310:4.2",
      "pali": "anagāro paribbaje;"
    },
    {
      "id": "ja310:4.3",
      "pali": "Aññaṁ ahiṁsayaṁ loke,"
    },
    {
      "id": "ja310:4.4",
      "pali": "api rajjena taṁ varan”ti."
    },
    {
      "id": "ja310:5.1",
      "pali": "Seyyajātakaṁ dasamaṁ."
    },
    {
      "id": "ja310:5.2",
      "pali": "Kāliṅgavaggo paṭhamo."
    },
    {
      "id": "ja310:6.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja310:7.1",
      "pali": "Vivarañca adeyya samiddhavaraṁ,"
    },
    {
      "id": "ja310:7.2",
      "pali": "Atha daddara pāpamahātiraho;"
    },
    {
      "id": "ja310:7.3",
      "pali": "Atha koli palāsavarañca kara,"
    },
    {
      "id": "ja310:7.4",
      "pali": "Carimaṁ sasamuddavarena dasāti."
    }
  ]
}
