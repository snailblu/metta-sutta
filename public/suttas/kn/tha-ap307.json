{
  "uid": "tha-ap307",
  "title": "Phaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap307:1.1",
      "pali": "“Bhāgīrathīnadītīre,"
    },
    {
      "id": "tha-ap307:1.2",
      "pali": "ahosi assamo tadā;"
    },
    {
      "id": "tha-ap307:1.3",
      "pali": "Tamahaṁ assamaṁ gacchiṁ,"
    },
    {
      "id": "tha-ap307:1.4",
      "pali": "phalahattho apekkhavā."
    },
    {
      "id": "tha-ap307:2.1",
      "pali": "Vipassiṁ tattha addakkhiṁ,"
    },
    {
      "id": "tha-ap307:2.2",
      "pali": "pītaraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "tha-ap307:2.3",
      "pali": "Yaṁ me atthi phalaṁ sabbaṁ,"
    },
    {
      "id": "tha-ap307:2.4",
      "pali": "adāsiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap307:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap307:3.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap307:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap307:3.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap307:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap307:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap307:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap307:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap307:6.1",
      "pali": "Phaladāyakattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
