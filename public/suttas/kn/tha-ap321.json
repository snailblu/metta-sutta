{
  "uid": "tha-ap321",
  "title": "9 Kandalipupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap321:1.1",
      "pali": "“Sindhuyā nadiyā tīre,"
    },
    {
      "id": "tha-ap321:1.2",
      "pali": "ahosiṁ kassako tadā;"
    },
    {
      "id": "tha-ap321:1.3",
      "pali": "Parakammāyane yutto,"
    },
    {
      "id": "tha-ap321:1.4",
      "pali": "parabhattaṁ apassito."
    },
    {
      "id": "tha-ap321:2.1",
      "pali": "Sindhuṁ anucarantohaṁ,"
    },
    {
      "id": "tha-ap321:2.2",
      "pali": "siddhatthaṁ jinamaddasaṁ;"
    },
    {
      "id": "tha-ap321:2.3",
      "pali": "Samādhinā nisinnaṁva,"
    },
    {
      "id": "tha-ap321:2.4",
      "pali": "satapattaṁva pupphitaṁ."
    },
    {
      "id": "tha-ap321:3.1",
      "pali": "Satta kandalipupphāni,"
    },
    {
      "id": "tha-ap321:3.2",
      "pali": "vaṇṭe chetvānahaṁ tadā;"
    },
    {
      "id": "tha-ap321:3.3",
      "pali": "Matthake abhiropesiṁ,"
    },
    {
      "id": "tha-ap321:3.4",
      "pali": "buddhassādiccabandhuno."
    },
    {
      "id": "tha-ap321:4.1",
      "pali": "Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap321:4.2",
      "pali": "Anukūle samāhitaṁ;"
    },
    {
      "id": "tha-ap321:4.3",
      "pali": "Tidhāpabhinnamātaṅgaṁ,"
    },
    {
      "id": "tha-ap321:4.4",
      "pali": "Kuñjaraṁva durāsadaṁ."
    },
    {
      "id": "tha-ap321:5.1",
      "pali": "Tamahaṁ upagantvāna,"
    },
    {
      "id": "tha-ap321:5.2",
      "pali": "nipakaṁ bhāvitindriyaṁ;"
    },
    {
      "id": "tha-ap321:5.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap321:5.4",
      "pali": "avandiṁ satthuno ahaṁ."
    },
    {
      "id": "tha-ap321:6.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap321:6.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap321:6.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap321:6.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap321:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap321:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap321:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap321:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā kandalipupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap321:9.1",
      "pali": "Kandalipupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
