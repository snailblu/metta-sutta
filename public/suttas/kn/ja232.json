{
  "uid": "ja232",
  "title": "Upāhanavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja232:1.1",
      "pali": "“Ekacintito yamattho,"
    },
    {
      "id": "ja232:1.2",
      "pali": "bālo apariṇāyako;"
    },
    {
      "id": "ja232:1.3",
      "pali": "Na hi khujjena vāmena,"
    },
    {
      "id": "ja232:1.4",
      "pali": "bhoti saṅgantumarahasi”."
    },
    {
      "id": "ja232:2.1",
      "pali": "“Purisūsabhaṁ maññamānā,"
    },
    {
      "id": "ja232:2.2",
      "pali": "ahaṁ khujjamakāmayiṁ;"
    },
    {
      "id": "ja232:2.3",
      "pali": "Soyaṁ saṅkuṭito seti,"
    },
    {
      "id": "ja232:2.4",
      "pali": "chinnatanti yathā viṇā”ti."
    },
    {
      "id": "ja232:3.1",
      "pali": "Vīṇāguṇajātakaṁ dutiyaṁ."
    }
  ]
}
