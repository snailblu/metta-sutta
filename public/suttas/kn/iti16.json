{
  "uid": "iti16",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti16:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti16:2.1",
      "pali": "“Sekhassa, bhikkhave, bhikkhuno appattamānasassa anuttaraṁ yogakkhemaṁ patthayamānassa viharato ajjhattikaṁ aṅganti karitvā nāññaṁ ekaṅgampi samanupassāmi yaṁ evaṁ bahūpakāraṁ yathayidaṁ, bhikkhave, yoniso manasikāro."
    },
    {
      "id": "iti16:2.2",
      "pali": "Yoniso, bhikkhave, bhikkhu manasi karonto akusalaṁ pajahati, kusalaṁ bhāvetī”ti."
    },
    {
      "id": "iti16:2.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti16:2.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti16:3.1",
      "pali": "“Yonisomanasikāro,"
    },
    {
      "id": "iti16:3.2",
      "pali": "dhammo sekhassa bhikkhuno;"
    },
    {
      "id": "iti16:3.3",
      "pali": "Natthañño evaṁ bahukāro,"
    },
    {
      "id": "iti16:3.4",
      "pali": "uttamatthassa pattiyā;"
    },
    {
      "id": "iti16:3.5",
      "pali": "Yoniso padahaṁ bhikkhu,"
    },
    {
      "id": "iti16:3.6",
      "pali": "khayaṁ dukkhassa pāpuṇe”ti."
    },
    {
      "id": "iti16:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti16:4.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
