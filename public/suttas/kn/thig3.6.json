{
  "uid": "thig3.6",
  "title": "Sukkātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig3.6:1.1",
      "pali": "“Kiṁme katā rājagahe manussā,"
    },
    {
      "id": "thig3.6:1.2",
      "pali": "Madhuṁ pītāva acchare;"
    },
    {
      "id": "thig3.6:1.3",
      "pali": "Ye sukkaṁ na upāsanti,"
    },
    {
      "id": "thig3.6:1.4",
      "pali": "Desentiṁ buddhasāsanaṁ."
    },
    {
      "id": "thig3.6:2.1",
      "pali": "Tañca appaṭivānīyaṁ,"
    },
    {
      "id": "thig3.6:2.2",
      "pali": "asecanakamojavaṁ;"
    },
    {
      "id": "thig3.6:2.3",
      "pali": "Pivanti maññe sappaññā,"
    },
    {
      "id": "thig3.6:2.4",
      "pali": "valāhakamivaddhagū."
    },
    {
      "id": "thig3.6:3.1",
      "pali": "Sukkā sukkehi dhammehi,"
    },
    {
      "id": "thig3.6:3.2",
      "pali": "vītarāgā samāhitā;"
    },
    {
      "id": "thig3.6:3.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "thig3.6:3.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "thig3.6:4.1",
      "pali": "… Sukkā therī …."
    }
  ]
}
