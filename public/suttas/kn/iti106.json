{
  "uid": "iti106",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti106:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti106:2.1",
      "pali": "“Sabrahmakāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "iti106:2.2",
      "pali": "Sapubbadevatāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "iti106:2.3",
      "pali": "Sapubbācariyakāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "iti106:2.4",
      "pali": "Sāhuneyyakāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "iti106:3.1",
      "pali": "‘Brahmā’ti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "iti106:3.2",
      "pali": "‘Pubbadevatā’ti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "iti106:3.3",
      "pali": "‘Pubbācariyā’ti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "iti106:3.4",
      "pali": "‘Āhuneyyā’ti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "iti106:3.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "iti106:3.6",
      "pali": "Bahukārā, bhikkhave, mātāpitaro puttānaṁ āpādakā posakā imassa lokassa dassetāro”ti."
    },
    {
      "id": "iti106:3.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti106:3.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti106:4.1",
      "pali": "“Brahmāti mātāpitaro,"
    },
    {
      "id": "iti106:4.2",
      "pali": "pubbācariyāti vuccare;"
    },
    {
      "id": "iti106:4.3",
      "pali": "Āhuneyyā ca puttānaṁ,"
    },
    {
      "id": "iti106:4.4",
      "pali": "pajāya anukampakā."
    },
    {
      "id": "iti106:5.1",
      "pali": "Tasmā hi ne namasseyya,"
    },
    {
      "id": "iti106:5.2",
      "pali": "sakkareyya ca paṇḍito;"
    },
    {
      "id": "iti106:5.3",
      "pali": "Annena atha pānena,"
    },
    {
      "id": "iti106:5.4",
      "pali": "vatthena sayanena ca;"
    },
    {
      "id": "iti106:5.5",
      "pali": "Ucchādanena nhāpanena,"
    },
    {
      "id": "iti106:5.6",
      "pali": "pādānaṁ dhovanena ca."
    },
    {
      "id": "iti106:6.1",
      "pali": "Tāya naṁ pāricariyāya,"
    },
    {
      "id": "iti106:6.2",
      "pali": "mātāpitūsu paṇḍitā;"
    },
    {
      "id": "iti106:6.3",
      "pali": "Idheva naṁ pasaṁsanti,"
    },
    {
      "id": "iti106:6.4",
      "pali": "pecca sagge pamodatī”ti."
    },
    {
      "id": "iti106:7.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti106:7.2",
      "pali": "Sattamaṁ."
    }
  ]
}
