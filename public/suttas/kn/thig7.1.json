{
  "uid": "thig7.1",
  "title": "Uttarātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig7.1:1.1",
      "pali": "“Musalāni gahetvāna,"
    },
    {
      "id": "thig7.1:1.2",
      "pali": "dhaññaṁ koṭṭenti māṇavā;"
    },
    {
      "id": "thig7.1:1.3",
      "pali": "Puttadārāni posentā,"
    },
    {
      "id": "thig7.1:1.4",
      "pali": "dhanaṁ vindanti māṇavā."
    },
    {
      "id": "thig7.1:2.1",
      "pali": "Ghaṭetha buddhasāsane,"
    },
    {
      "id": "thig7.1:2.2",
      "pali": "yaṁ katvā nānutappati;"
    },
    {
      "id": "thig7.1:2.3",
      "pali": "Khippaṁ pādāni dhovitvā,"
    },
    {
      "id": "thig7.1:2.4",
      "pali": "ekamantaṁ nisīdatha."
    },
    {
      "id": "thig7.1:3.1",
      "pali": "Cittaṁ upaṭṭhapetvāna,"
    },
    {
      "id": "thig7.1:3.2",
      "pali": "ekaggaṁ susamāhitaṁ;"
    },
    {
      "id": "thig7.1:3.3",
      "pali": "Paccavekkhatha saṅkhāre,"
    },
    {
      "id": "thig7.1:3.4",
      "pali": "parato no ca attato”."
    },
    {
      "id": "thig7.1:4.1",
      "pali": "“Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig7.1:4.2",
      "pali": "paṭācārānusāsaniṁ;"
    },
    {
      "id": "thig7.1:4.3",
      "pali": "Pāde pakkhālayitvāna,"
    },
    {
      "id": "thig7.1:4.4",
      "pali": "ekamante upāvisiṁ."
    },
    {
      "id": "thig7.1:5.1",
      "pali": "Rattiyā purime yāme,"
    },
    {
      "id": "thig7.1:5.2",
      "pali": "pubbajātimanussariṁ;"
    },
    {
      "id": "thig7.1:5.3",
      "pali": "Rattiyā majjhime yāme,"
    },
    {
      "id": "thig7.1:5.4",
      "pali": "dibbacakkhuṁ visodhayiṁ."
    },
    {
      "id": "thig7.1:6.1",
      "pali": "Rattiyā pacchime yāme,"
    },
    {
      "id": "thig7.1:6.2",
      "pali": "tamokhandhaṁ padālayiṁ;"
    },
    {
      "id": "thig7.1:6.3",
      "pali": "Tevijjā atha vuṭṭhāsiṁ,"
    },
    {
      "id": "thig7.1:6.4",
      "pali": "katā te anusāsanī."
    },
    {
      "id": "thig7.1:7.1",
      "pali": "Sakkaṁva devā tidasā,"
    },
    {
      "id": "thig7.1:7.2",
      "pali": "saṅgāme aparājitaṁ;"
    },
    {
      "id": "thig7.1:7.3",
      "pali": "Purakkhatvā vihassāmi,"
    },
    {
      "id": "thig7.1:7.4",
      "pali": "tevijjāmhi anāsavā”."
    },
    {
      "id": "thig7.1:8.1",
      "pali": "… Uttarā therī …."
    }
  ]
}
