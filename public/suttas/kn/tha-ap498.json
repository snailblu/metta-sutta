{
  "uid": "tha-ap498",
  "title": "Ghatamaṇḍadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap498:1.1",
      "pali": "“Sucintitaṁ bhagavantaṁ,"
    },
    {
      "id": "tha-ap498:1.2",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap498:1.3",
      "pali": "Upaviṭṭhaṁ mahāraññaṁ,"
    },
    {
      "id": "tha-ap498:1.4",
      "pali": "vātābādhena pīḷitaṁ."
    },
    {
      "id": "tha-ap498:2.1",
      "pali": "Disvā cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap498:2.2",
      "pali": "ghatamaṇḍamupānayiṁ;"
    },
    {
      "id": "tha-ap498:2.3",
      "pali": "Katattā ācitattā ca,"
    },
    {
      "id": "tha-ap498:2.4",
      "pali": "gaṅgā bhāgīrathī ayaṁ."
    },
    {
      "id": "tha-ap498:3.1",
      "pali": "Mahāsamuddā cattāro,"
    },
    {
      "id": "tha-ap498:3.2",
      "pali": "ghataṁ sampajjare mama;"
    },
    {
      "id": "tha-ap498:3.3",
      "pali": "Ayañca pathavī ghorā,"
    },
    {
      "id": "tha-ap498:3.4",
      "pali": "appamāṇā asaṅkhiyā."
    },
    {
      "id": "tha-ap498:4.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap498:4.2",
      "pali": "bhavate madhusakkarā;"
    },
    {
      "id": "tha-ap498:4.3",
      "pali": "Cātuddīpā ime rukkhā,"
    },
    {
      "id": "tha-ap498:4.4",
      "pali": "pādapā dharaṇīruhā."
    },
    {
      "id": "tha-ap498:5.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap498:5.2",
      "pali": "kapparukkhā bhavanti te;"
    },
    {
      "id": "tha-ap498:5.3",
      "pali": "Paññāsakkhattuṁ devindo,"
    },
    {
      "id": "tha-ap498:5.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap498:6.1",
      "pali": "Ekapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap498:6.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap498:6.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap498:6.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap498:7.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap498:7.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap498:7.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap498:7.4",
      "pali": "ghatamaṇḍassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap498:8.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap498:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap498:8.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap498:9.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap498:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap498:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap498:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap498:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap498:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap498:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā ghatamaṇḍadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap498:12.1",
      "pali": "Ghatamaṇḍadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
