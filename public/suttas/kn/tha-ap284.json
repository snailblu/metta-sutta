{
  "uid": "tha-ap284",
  "title": "Phaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap284:1.1",
      "pali": "“Sinerusamasantoso,"
    },
    {
      "id": "tha-ap284:1.2",
      "pali": "dharaṇīsamasādiso;"
    },
    {
      "id": "tha-ap284:1.3",
      "pali": "Vuṭṭhahitvā samādhimhā,"
    },
    {
      "id": "tha-ap284:1.4",
      "pali": "bhikkhāya mamupaṭṭhito."
    },
    {
      "id": "tha-ap284:2.1",
      "pali": "Harītakaṁ āmalakaṁ,"
    },
    {
      "id": "tha-ap284:2.2",
      "pali": "ambajambuvibhītakaṁ;"
    },
    {
      "id": "tha-ap284:2.3",
      "pali": "Kolaṁ bhallātakaṁ billaṁ,"
    },
    {
      "id": "tha-ap284:2.4",
      "pali": "phārusakaphalāni ca."
    },
    {
      "id": "tha-ap284:3.1",
      "pali": "Siddhatthassa mahesissa,"
    },
    {
      "id": "tha-ap284:3.2",
      "pali": "sabbalokānukampino;"
    },
    {
      "id": "tha-ap284:3.3",
      "pali": "Tañca sabbaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap284:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap284:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap284:4.2",
      "pali": "yaṁ phalaṁ adadiṁ tadā;"
    },
    {
      "id": "tha-ap284:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap284:4.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap284:5.1",
      "pali": "Sattapaññāsito kappe,"
    },
    {
      "id": "tha-ap284:5.2",
      "pali": "ekajjho nāma khattiyo;"
    },
    {
      "id": "tha-ap284:5.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap284:5.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap284:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap284:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap284:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap284:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā phaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap284:8.1",
      "pali": "Phaladāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
