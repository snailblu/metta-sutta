{
  "uid": "ja483",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja483:1.1",
      "pali": "“Āsīsetheva puriso,"
    },
    {
      "id": "ja483:1.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja483:1.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja483:1.4",
      "pali": "yathā icchiṁ tathā ahu."
    },
    {
      "id": "ja483:2.1",
      "pali": "Āsīsetheva puriso,"
    },
    {
      "id": "ja483:2.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja483:2.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja483:2.4",
      "pali": "udakā thalamubbhataṁ."
    },
    {
      "id": "ja483:3.1",
      "pali": "Vāyametheva puriso,"
    },
    {
      "id": "ja483:3.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja483:3.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja483:3.4",
      "pali": "yathā icchiṁ tathā ahu."
    },
    {
      "id": "ja483:4.1",
      "pali": "Vāyametheva puriso,"
    },
    {
      "id": "ja483:4.2",
      "pali": "na nibbindeyya paṇḍito;"
    },
    {
      "id": "ja483:4.3",
      "pali": "Passāmi vohaṁ attānaṁ,"
    },
    {
      "id": "ja483:4.4",
      "pali": "udakā thalamubbhataṁ."
    },
    {
      "id": "ja483:5.1",
      "pali": "Dukkhūpanītopi naro sapañño,"
    },
    {
      "id": "ja483:5.2",
      "pali": "Āsaṁ na chindeyya sukhāgamāya;"
    },
    {
      "id": "ja483:5.3",
      "pali": "Bahū hi phassā ahitā hitā ca,"
    },
    {
      "id": "ja483:5.4",
      "pali": "Avitakkitā maccamupabbajanti."
    },
    {
      "id": "ja483:6.1",
      "pali": "Acintitampi bhavati,"
    },
    {
      "id": "ja483:6.2",
      "pali": "cintitampi vinassati;"
    },
    {
      "id": "ja483:6.3",
      "pali": "Na hi cintāmayā bhogā,"
    },
    {
      "id": "ja483:6.4",
      "pali": "itthiyā purisassa vā”."
    },
    {
      "id": "ja483:7.1",
      "pali": "“Sarabhaṁ giriduggasmiṁ,"
    },
    {
      "id": "ja483:7.2",
      "pali": "yaṁ tvaṁ anusarī pure;"
    },
    {
      "id": "ja483:7.3",
      "pali": "Alīnacittassa tuvaṁ,"
    },
    {
      "id": "ja483:7.4",
      "pali": "vikkantamanujīvasi."
    },
    {
      "id": "ja483:8.1",
      "pali": "Yo taṁ viduggā narakā samuddhari,"
    },
    {
      "id": "ja483:8.2",
      "pali": "Silāya yoggaṁ sarabho karitvā;"
    },
    {
      "id": "ja483:8.3",
      "pali": "Dukkhūpanītaṁ maccumukhā pamocayi,"
    },
    {
      "id": "ja483:8.4",
      "pali": "Alīnacittaṁ ta migaṁ vadesi”."
    },
    {
      "id": "ja483:9.1",
      "pali": "“Kiṁ tvaṁ nu tattheva tadā ahosi,"
    },
    {
      "id": "ja483:9.2",
      "pali": "Udāhu te koci naṁ etadakkhā;"
    },
    {
      "id": "ja483:9.3",
      "pali": "Vivaṭṭacchaddo nusi sabbadassī,"
    },
    {
      "id": "ja483:9.4",
      "pali": "Ñāṇaṁ nu te brāhmaṇa bhiṁsarūpaṁ”."
    },
    {
      "id": "ja483:10.1",
      "pali": "“Na cevahaṁ tattha tadā ahosiṁ,"
    },
    {
      "id": "ja483:10.2",
      "pali": "Na cāpi me koci naṁ etadakkhā;"
    },
    {
      "id": "ja483:10.3",
      "pali": "Gāthāpadānañca subhāsitānaṁ,"
    },
    {
      "id": "ja483:10.4",
      "pali": "Atthaṁ tadānenti janinda dhīrā”."
    },
    {
      "id": "ja483:11.1",
      "pali": "“Ādāya pattiṁ paraviriyaghātiṁ,"
    },
    {
      "id": "ja483:11.2",
      "pali": "Cāpe saraṁ kiṁ vicikicchase tuvaṁ;"
    },
    {
      "id": "ja483:11.3",
      "pali": "Nunno saro sarabhaṁ hantu khippaṁ,"
    },
    {
      "id": "ja483:11.4",
      "pali": "Annañhi etaṁ varapañña rañño”."
    },
    {
      "id": "ja483:12.1",
      "pali": "“Addhā pajānāmi ahampi etaṁ,"
    },
    {
      "id": "ja483:12.2",
      "pali": "Annaṁ migo brāhmaṇa khattiyassa;"
    },
    {
      "id": "ja483:12.3",
      "pali": "Pubbe katañca apacāyamāno,"
    },
    {
      "id": "ja483:12.4",
      "pali": "Tasmā migaṁ sarabhaṁ no hanāmi”."
    },
    {
      "id": "ja483:13.1",
      "pali": "“Neso migo mahārāja,"
    },
    {
      "id": "ja483:13.2",
      "pali": "asureso disampati;"
    },
    {
      "id": "ja483:13.3",
      "pali": "Etaṁ hantvā manussinda,"
    },
    {
      "id": "ja483:13.4",
      "pali": "bhavassu amarādhipo."
    },
    {
      "id": "ja483:14.1",
      "pali": "Sace ca rājā vicikicchase tuvaṁ,"
    },
    {
      "id": "ja483:14.2",
      "pali": "Hantuṁ migaṁ sarabhaṁ sahāyakaṁ;"
    },
    {
      "id": "ja483:14.3",
      "pali": "Saputtadāro naravīraseṭṭha,"
    },
    {
      "id": "ja483:14.4",
      "pali": "Gantā tuvaṁ vetaraṇiṁ yamassa”."
    },
    {
      "id": "ja483:15.1",
      "pali": "“Kāmaṁ ahaṁ jānapadā ca sabbe,"
    },
    {
      "id": "ja483:15.2",
      "pali": "Puttā ca dārā ca sahāyasaṅghā;"
    },
    {
      "id": "ja483:15.3",
      "pali": "Gacchemu taṁ vetaraṇiṁ yamassa,"
    },
    {
      "id": "ja483:15.4",
      "pali": "Na tveva hañño mama pāṇado yo."
    },
    {
      "id": "ja483:16.1",
      "pali": "Ayaṁ migo kicchagatassa mayhaṁ,"
    },
    {
      "id": "ja483:16.2",
      "pali": "Ekassa kattā vivanasmi ghore;"
    },
    {
      "id": "ja483:16.3",
      "pali": "Taṁ tādisaṁ pubbakiccaṁ saranto,"
    },
    {
      "id": "ja483:16.4",
      "pali": "Jānaṁ mahābrahme kathaṁ haneyyaṁ”."
    },
    {
      "id": "ja483:17.1",
      "pali": "“Mittābhirādhī cirameva jīva,"
    },
    {
      "id": "ja483:17.2",
      "pali": "Rajjaṁ imaṁ dhammaguṇe pasāsa;"
    },
    {
      "id": "ja483:17.3",
      "pali": "Nārīgaṇehi paricāriyanto,"
    },
    {
      "id": "ja483:17.4",
      "pali": "Modassu raṭṭhe tidiveva vāsavo."
    },
    {
      "id": "ja483:18.1",
      "pali": "Akkodhano niccapasannacitto,"
    },
    {
      "id": "ja483:18.2",
      "pali": "Sabbātithī yācayogo bhavitvā;"
    },
    {
      "id": "ja483:18.3",
      "pali": "Datvā ca bhutvā ca yathānubhāvaṁ,"
    },
    {
      "id": "ja483:18.4",
      "pali": "Anindito saggamupehi ṭhānan”ti."
    },
    {
      "id": "ja483:19.1",
      "pali": "Sarabhamigajātakaṁ dasamaṁ."
    },
    {
      "id": "ja483:20.1",
      "pali": "Terasakanipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja483:21.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja483:22.1",
      "pali": "Varaamba kuṭhāri sahaṁsavaro,"
    },
    {
      "id": "ja483:22.2",
      "pali": "Atharaññasmiṁ dūtakapañcamako;"
    },
    {
      "id": "ja483:22.3",
      "pali": "Atha bodhi akitti sutakkarinā,"
    },
    {
      "id": "ja483:22.4",
      "pali": "Atha rurumigenaparo sarabhoti."
    }
  ]
}
