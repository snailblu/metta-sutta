{
  "uid": "tha-ap136",
  "title": "4 Pupphacchadaniyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap136:1.1",
      "pali": "“Sunando nāma nāmena,"
    },
    {
      "id": "tha-ap136:1.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap136:1.3",
      "pali": "Ajjhāyako yācayogo,"
    },
    {
      "id": "tha-ap136:1.4",
      "pali": "vājapeyyaṁ ayājayi."
    },
    {
      "id": "tha-ap136:2.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap136:2.2",
      "pali": "aggo kāruṇiko isi;"
    },
    {
      "id": "tha-ap136:2.3",
      "pali": "Janataṁ anukampanto,"
    },
    {
      "id": "tha-ap136:2.4",
      "pali": "ambare caṅkamī tadā."
    },
    {
      "id": "tha-ap136:3.1",
      "pali": "Caṅkamitvāna sambuddho,"
    },
    {
      "id": "tha-ap136:3.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap136:3.3",
      "pali": "Mettāya aphari satte,"
    },
    {
      "id": "tha-ap136:3.4",
      "pali": "appamāṇe nirūpadhi."
    },
    {
      "id": "tha-ap136:4.1",
      "pali": "Vaṇṭe chetvāna pupphāni,"
    },
    {
      "id": "tha-ap136:4.2",
      "pali": "brāhmaṇo mantapāragū;"
    },
    {
      "id": "tha-ap136:4.3",
      "pali": "Sabbe sisse samānetvā,"
    },
    {
      "id": "tha-ap136:4.4",
      "pali": "ākāse ukkhipāpayi."
    },
    {
      "id": "tha-ap136:5.1",
      "pali": "Yāvatā nagaraṁ āsi,"
    },
    {
      "id": "tha-ap136:5.2",
      "pali": "pupphānaṁ chadanaṁ tadā;"
    },
    {
      "id": "tha-ap136:5.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap136:5.4",
      "pali": "sattāhaṁ na vigacchatha."
    },
    {
      "id": "tha-ap136:6.1",
      "pali": "Teneva sukkamūlena,"
    },
    {
      "id": "tha-ap136:6.2",
      "pali": "anubhotvāna sampadā;"
    },
    {
      "id": "tha-ap136:6.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap136:6.4",
      "pali": "tiṇṇo loke visattikaṁ."
    },
    {
      "id": "tha-ap136:7.1",
      "pali": "Ekārase kappasate,"
    },
    {
      "id": "tha-ap136:7.2",
      "pali": "pañcatiṁsāsu khattiyā;"
    },
    {
      "id": "tha-ap136:7.3",
      "pali": "Ambaraṁsasanāmā te,"
    },
    {
      "id": "tha-ap136:7.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap136:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap136:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap136:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap136:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā pupphacchadaniyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap136:10.1",
      "pali": "Pupphacchadaniyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
