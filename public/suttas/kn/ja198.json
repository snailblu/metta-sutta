{
  "uid": "ja198",
  "title": "Ruhakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja198:1.1",
      "pali": "“Pavāsā āgato tāta,"
    },
    {
      "id": "ja198:1.2",
      "pali": "idāni nacirāgato;"
    },
    {
      "id": "ja198:1.3",
      "pali": "Kaccinnu tāta te mātā,"
    },
    {
      "id": "ja198:1.4",
      "pali": "na aññamupasevati”."
    },
    {
      "id": "ja198:2.1",
      "pali": "“Na kho panetaṁ subhaṇaṁ,"
    },
    {
      "id": "ja198:2.2",
      "pali": "Giraṁ saccupasaṁhitaṁ;"
    },
    {
      "id": "ja198:2.3",
      "pali": "Sayetha poṭṭhapādova,"
    },
    {
      "id": "ja198:2.4",
      "pali": "Mummure upakūthito”ti."
    },
    {
      "id": "ja198:3.1",
      "pali": "Rādhajātakaṁ aṭṭhamaṁ."
    }
  ]
}
