{
  "uid": "tha-ap220",
  "title": "Akkantasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap220:1.1",
      "pali": "“Kusāṭakaṁ gahetvāna,"
    },
    {
      "id": "tha-ap220:1.2",
      "pali": "upajjhāyassahaṁ pure;"
    },
    {
      "id": "tha-ap220:1.3",
      "pali": "Mantañca anusikkhāmi,"
    },
    {
      "id": "tha-ap220:1.4",
      "pali": "ganthādosassa pattiyā."
    },
    {
      "id": "tha-ap220:2.1",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap220:2.2",
      "pali": "Āhutīnaṁ paṭiggahaṁ;"
    },
    {
      "id": "tha-ap220:2.3",
      "pali": "Usabhaṁ pavaraṁ aggaṁ,"
    },
    {
      "id": "tha-ap220:2.4",
      "pali": "Tissaṁ buddhaṁ gaṇuttamaṁ."
    },
    {
      "id": "tha-ap220:3.1",
      "pali": "Kusāṭakaṁ pattharitaṁ,"
    },
    {
      "id": "tha-ap220:3.2",
      "pali": "akkamantaṁ naruttamaṁ;"
    },
    {
      "id": "tha-ap220:3.3",
      "pali": "Samuggataṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap220:3.4",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ."
    },
    {
      "id": "tha-ap220:4.1",
      "pali": "Disvā taṁ lokapajjotaṁ,"
    },
    {
      "id": "tha-ap220:4.2",
      "pali": "vimalaṁ candasannibhaṁ;"
    },
    {
      "id": "tha-ap220:4.3",
      "pali": "Avandiṁ satthuno pāde,"
    },
    {
      "id": "tha-ap220:4.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap220:5.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap220:5.2",
      "pali": "yaṁ adāsiṁ kusāṭakaṁ;"
    },
    {
      "id": "tha-ap220:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap220:5.4",
      "pali": "kusāṭakassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap220:6.1",
      "pali": "Sattatiṁse ito kappe,"
    },
    {
      "id": "tha-ap220:6.2",
      "pali": "eko āsiṁ janādhipo;"
    },
    {
      "id": "tha-ap220:6.3",
      "pali": "Sunando nāma nāmena,"
    },
    {
      "id": "tha-ap220:6.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap220:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap220:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap220:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap220:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā akkantasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap220:9.1",
      "pali": "Akkantasaññakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
