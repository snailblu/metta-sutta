{
  "uid": "tha-ap403",
  "title": "Tissametteyyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap403:1.1",
      "pali": "“Pabbhārakūṭaṁ nissāya,"
    },
    {
      "id": "tha-ap403:1.2",
      "pali": "sobhito nāma tāpaso;"
    },
    {
      "id": "tha-ap403:1.3",
      "pali": "Pavattaphalaṁ bhuñjitvā,"
    },
    {
      "id": "tha-ap403:1.4",
      "pali": "vasati pabbatantare."
    },
    {
      "id": "tha-ap403:2.1",
      "pali": "Aggiṁ dāruṁ āharitvā,"
    },
    {
      "id": "tha-ap403:2.2",
      "pali": "ujjālesiṁ ahaṁ tadā;"
    },
    {
      "id": "tha-ap403:2.3",
      "pali": "Uttamatthaṁ gavesanto,"
    },
    {
      "id": "tha-ap403:2.4",
      "pali": "brahmalokūpapattiyā."
    },
    {
      "id": "tha-ap403:3.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap403:3.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap403:3.3",
      "pali": "Mamuddharitukāmo so,"
    },
    {
      "id": "tha-ap403:3.4",
      "pali": "āgacchi mama santike."
    },
    {
      "id": "tha-ap403:4.1",
      "pali": "‘Kiṁ karosi mahāpuñña,"
    },
    {
      "id": "tha-ap403:4.2",
      "pali": "dehi me aggidārukaṁ;"
    },
    {
      "id": "tha-ap403:4.3",
      "pali": "Ahamaggiṁ paricare,"
    },
    {
      "id": "tha-ap403:4.4",
      "pali": "tato me suddhi hohiti’."
    },
    {
      "id": "tha-ap403:5.1",
      "pali": "‘Subhaddako tvaṁ manuje,"
    },
    {
      "id": "tha-ap403:5.2",
      "pali": "devate tvaṁ pajānasi;"
    },
    {
      "id": "tha-ap403:5.3",
      "pali": "Tuvaṁ aggiṁ paricara,"
    },
    {
      "id": "tha-ap403:5.4",
      "pali": "handa te aggidārukaṁ’."
    },
    {
      "id": "tha-ap403:6.1",
      "pali": "Tato kaṭṭhaṁ gahetvāna,"
    },
    {
      "id": "tha-ap403:6.2",
      "pali": "aggiṁ ujjālayī jino;"
    },
    {
      "id": "tha-ap403:6.3",
      "pali": "Na tattha kaṭṭhaṁ pajjhāyi,"
    },
    {
      "id": "tha-ap403:6.4",
      "pali": "pāṭiheraṁ mahesino."
    },
    {
      "id": "tha-ap403:7.1",
      "pali": "‘Na te aggi pajjalati,"
    },
    {
      "id": "tha-ap403:7.2",
      "pali": "āhutī te na vijjati;"
    },
    {
      "id": "tha-ap403:7.3",
      "pali": "Niratthakaṁ vataṁ tuyhaṁ,"
    },
    {
      "id": "tha-ap403:7.4",
      "pali": "aggiṁ paricarassu me’."
    },
    {
      "id": "tha-ap403:8.1",
      "pali": "‘Kīdiso so mahāvīra,"
    },
    {
      "id": "tha-ap403:8.2",
      "pali": "aggi tava pavuccati;"
    },
    {
      "id": "tha-ap403:8.3",
      "pali": "Mayhampi kathayassetaṁ,"
    },
    {
      "id": "tha-ap403:8.4",
      "pali": "ubho paricarāmase’."
    },
    {
      "id": "tha-ap403:9.1",
      "pali": "‘Hetudhammanirodhāya,"
    },
    {
      "id": "tha-ap403:9.2",
      "pali": "kilesasamaṇāya ca;"
    },
    {
      "id": "tha-ap403:9.3",
      "pali": "Issāmacchariyaṁ hitvā,"
    },
    {
      "id": "tha-ap403:9.4",
      "pali": "tayo ete mamāhutī’."
    },
    {
      "id": "tha-ap403:10.1",
      "pali": "‘Kīdiso tvaṁ mahāvīra,"
    },
    {
      "id": "tha-ap403:10.2",
      "pali": "kathaṁ gottosi mārisa;"
    },
    {
      "id": "tha-ap403:10.3",
      "pali": "Ācārapaṭipatti te,"
    },
    {
      "id": "tha-ap403:10.4",
      "pali": "bāḷhaṁ kho mama ruccati’."
    },
    {
      "id": "tha-ap403:11.1",
      "pali": "‘Khattiyamhi kule jāto,"
    },
    {
      "id": "tha-ap403:11.2",
      "pali": "abhiññāpāramiṁ gato;"
    },
    {
      "id": "tha-ap403:11.3",
      "pali": "Sabbāsavaparikkhīṇo,"
    },
    {
      "id": "tha-ap403:11.4",
      "pali": "natthi dāni punabbhavo’."
    },
    {
      "id": "tha-ap403:12.1",
      "pali": "‘Yadi buddhosi sabbaññū,"
    },
    {
      "id": "tha-ap403:12.2",
      "pali": "pabhaṅkara tamonuda;"
    },
    {
      "id": "tha-ap403:12.3",
      "pali": "Namassissāmi taṁ deva,"
    },
    {
      "id": "tha-ap403:12.4",
      "pali": "dukkhassantakaro tuvaṁ’."
    },
    {
      "id": "tha-ap403:13.1",
      "pali": "Pattharitvājinacammaṁ,"
    },
    {
      "id": "tha-ap403:13.2",
      "pali": "nisīdanamadāsahaṁ;"
    },
    {
      "id": "tha-ap403:13.3",
      "pali": "Nisīda nātha sabbaññu,"
    },
    {
      "id": "tha-ap403:13.4",
      "pali": "upaṭṭhissāmahaṁ tuvaṁ."
    },
    {
      "id": "tha-ap403:14.1",
      "pali": "Nisīdi bhagavā tattha,"
    },
    {
      "id": "tha-ap403:14.2",
      "pali": "ajinamhi suvitthate;"
    },
    {
      "id": "tha-ap403:14.3",
      "pali": "Nimantayitvā sambuddhaṁ,"
    },
    {
      "id": "tha-ap403:14.4",
      "pali": "pabbataṁ agamāsahaṁ."
    },
    {
      "id": "tha-ap403:15.1",
      "pali": "Khāribhārañca pūretvā,"
    },
    {
      "id": "tha-ap403:15.2",
      "pali": "tindukaphalamāhariṁ;"
    },
    {
      "id": "tha-ap403:15.3",
      "pali": "Madhunā yojayitvāna,"
    },
    {
      "id": "tha-ap403:15.4",
      "pali": "phalaṁ buddhassadāsahaṁ."
    },
    {
      "id": "tha-ap403:16.1",
      "pali": "Mama nijjhāyamānassa,"
    },
    {
      "id": "tha-ap403:16.2",
      "pali": "paribhuñji tadā jino;"
    },
    {
      "id": "tha-ap403:16.3",
      "pali": "Tattha cittaṁ pasādesiṁ,"
    },
    {
      "id": "tha-ap403:16.4",
      "pali": "pekkhanto lokanāyakaṁ."
    },
    {
      "id": "tha-ap403:17.1",
      "pali": "Padumuttaro lokavidū,"
    },
    {
      "id": "tha-ap403:17.2",
      "pali": "āhutīnaṁ paṭiggaho;"
    },
    {
      "id": "tha-ap403:17.3",
      "pali": "Mamassame nisīditvā,"
    },
    {
      "id": "tha-ap403:17.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap403:18.1",
      "pali": "‘Yo maṁ phalena tappesi,"
    },
    {
      "id": "tha-ap403:18.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap403:18.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap403:18.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap403:19.1",
      "pali": "Pañcavīsatikkhattuṁ so,"
    },
    {
      "id": "tha-ap403:19.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap403:19.3",
      "pali": "Sahassakkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap403:19.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap403:20.1",
      "pali": "Tassa saṅkappamaññāya,"
    },
    {
      "id": "tha-ap403:20.2",
      "pali": "pubbakammasamaṅgino;"
    },
    {
      "id": "tha-ap403:20.3",
      "pali": "Annaṁ pānañca vatthañca,"
    },
    {
      "id": "tha-ap403:20.4",
      "pali": "sayanañca mahārahaṁ."
    },
    {
      "id": "tha-ap403:21.1",
      "pali": "Puññakammena saṁyuttā,"
    },
    {
      "id": "tha-ap403:21.2",
      "pali": "nibbattissanti tāvade;"
    },
    {
      "id": "tha-ap403:21.3",
      "pali": "Sadā pamudito cāyaṁ,"
    },
    {
      "id": "tha-ap403:21.4",
      "pali": "bhavissati anāmayo."
    },
    {
      "id": "tha-ap403:22.1",
      "pali": "Upapajjati yaṁ yoniṁ,"
    },
    {
      "id": "tha-ap403:22.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap403:22.3",
      "pali": "Sabbattha sukhito hutvā,"
    },
    {
      "id": "tha-ap403:22.4",
      "pali": "manussattaṁ gamissati."
    },
    {
      "id": "tha-ap403:23.1",
      "pali": "Ajjhāyako mantadharo,"
    },
    {
      "id": "tha-ap403:23.2",
      "pali": "tiṇṇaṁ vedāna pāragū;"
    },
    {
      "id": "tha-ap403:23.3",
      "pali": "Sambuddhaṁ upagantvāna,"
    },
    {
      "id": "tha-ap403:23.4",
      "pali": "arahā so bhavissati’."
    },
    {
      "id": "tha-ap403:24.1",
      "pali": "Yato sarāmi attānaṁ,"
    },
    {
      "id": "tha-ap403:24.2",
      "pali": "yato pattosmi viññutaṁ;"
    },
    {
      "id": "tha-ap403:24.3",
      "pali": "Bhoge me ūnatā natthi,"
    },
    {
      "id": "tha-ap403:24.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap403:25.1",
      "pali": "Varadhammamanuppatto,"
    },
    {
      "id": "tha-ap403:25.2",
      "pali": "rāgadose samūhaniṁ;"
    },
    {
      "id": "tha-ap403:25.3",
      "pali": "Sabbāsavaparikkhīṇo,"
    },
    {
      "id": "tha-ap403:25.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap403:26.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap403:26.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap403:26.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap403:26.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap403:27.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap403:27.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "tha-ap403:27.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap403:27.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap403:28.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap403:28.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap403:28.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap403:28.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap403:29.1",
      "pali": "Itthaṁ sudaṁ āyasmā tissametteyyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap403:30.1",
      "pali": "Tissametteyyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
