{
  "uid": "tha-ap42",
  "title": "Kapparukkhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap42:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap42:1.2",
      "pali": "thūpaseṭṭhassa sammukhā;"
    },
    {
      "id": "tha-ap42:1.3",
      "pali": "Vicittadusse lagetvā,"
    },
    {
      "id": "tha-ap42:1.4",
      "pali": "kapparukkhaṁ ṭhapesahaṁ."
    },
    {
      "id": "tha-ap42:2.1",
      "pali": "Yaṁ yaṁ yonupapajjāmi,"
    },
    {
      "id": "tha-ap42:2.2",
      "pali": "devattaṁ atha mānusaṁ;"
    },
    {
      "id": "tha-ap42:2.3",
      "pali": "Sobhayanto mama dvāraṁ,"
    },
    {
      "id": "tha-ap42:2.4",
      "pali": "kapparukkho patiṭṭhati."
    },
    {
      "id": "tha-ap42:3.1",
      "pali": "Ahañca parisā ceva,"
    },
    {
      "id": "tha-ap42:3.2",
      "pali": "ye keci mama vassitā;"
    },
    {
      "id": "tha-ap42:3.3",
      "pali": "Tamhā dussaṁ gahetvāna,"
    },
    {
      "id": "tha-ap42:3.4",
      "pali": "nivāsema mayaṁ sadā."
    },
    {
      "id": "tha-ap42:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap42:4.2",
      "pali": "yaṁ rukkhaṁ ṭhapayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap42:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap42:4.4",
      "pali": "kapparukkhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap42:5.1",
      "pali": "Ito ca sattame kappe,"
    },
    {
      "id": "tha-ap42:5.2",
      "pali": "suceḷā aṭṭha khattiyā;"
    },
    {
      "id": "tha-ap42:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap42:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap42:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap42:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap42:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap42:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kapparukkhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap42:8.1",
      "pali": "Kapparukkhiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap42:9.1",
      "pali": "Kuṇḍadhānavaggo catuttho."
    },
    {
      "id": "tha-ap42:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap42:11.1",
      "pali": "Kuṇḍasāgatakaccānā,"
    },
    {
      "id": "tha-ap42:11.2",
      "pali": "udāyī mogharājako;"
    },
    {
      "id": "tha-ap42:11.3",
      "pali": "Adhimutto lasuṇado,"
    },
    {
      "id": "tha-ap42:11.4",
      "pali": "āyāgī dhammacakkiko;"
    },
    {
      "id": "tha-ap42:11.5",
      "pali": "Kapparukkhī ca dasamo,"
    },
    {
      "id": "tha-ap42:11.6",
      "pali": "gāthā dvayadasasataṁ."
    }
  ]
}
