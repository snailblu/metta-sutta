{
  "uid": "tha-ap363",
  "title": "1 Mandāravapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap363:1.1",
      "pali": "“Tāvatiṁsā idhāgantvā,"
    },
    {
      "id": "tha-ap363:1.2",
      "pali": "maṅgalo nāma māṇavo;"
    },
    {
      "id": "tha-ap363:1.3",
      "pali": "Mandāravaṁ gahetvāna,"
    },
    {
      "id": "tha-ap363:1.4",
      "pali": "vipassissa mahesino."
    },
    {
      "id": "tha-ap363:2.1",
      "pali": "Samādhinā nisinnassa,"
    },
    {
      "id": "tha-ap363:2.2",
      "pali": "matthake dhārayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap363:2.3",
      "pali": "Sattāhaṁ dhārayitvāna,"
    },
    {
      "id": "tha-ap363:2.4",
      "pali": "devalokaṁ punāgamiṁ."
    },
    {
      "id": "tha-ap363:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap363:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap363:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap363:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap363:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap363:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap363:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap363:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap363:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā mandāravapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap363:6.1",
      "pali": "Mandāravapupphiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
