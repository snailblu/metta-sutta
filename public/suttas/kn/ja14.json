{
  "uid": "ja14",
  "title": "Sīlavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja14:1.1",
      "pali": "“Na kiratthi rasehi pāpiyo,"
    },
    {
      "id": "ja14:1.2",
      "pali": "Āvāsehi va santhavehi vā;"
    },
    {
      "id": "ja14:1.3",
      "pali": "Vātamigaṁ gahananissitaṁ,"
    },
    {
      "id": "ja14:1.4",
      "pali": "Vasamānesi rasehi sañjayo”ti."
    },
    {
      "id": "ja14:2.1",
      "pali": "Vātamigajātakaṁ catutthaṁ."
    }
  ]
}
