{
  "uid": "cp1",
  "title": "Dānapāramī 1",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp1:1.1",
      "pali": "Namo tassa Bhagavato Arahato Sammāsambuddhassa."
    },
    {
      "id": "cp1:2.1",
      "pali": "“Kappe ca satasahasse,"
    },
    {
      "id": "cp1:2.2",
      "pali": "caturo ca asaṅkhiye;"
    },
    {
      "id": "cp1:2.3",
      "pali": "Etthantare yaṁ caritaṁ,"
    },
    {
      "id": "cp1:2.4",
      "pali": "sabbaṁ taṁ bodhipācanaṁ."
    },
    {
      "id": "cp1:3.1",
      "pali": "Atītakappe caritaṁ,"
    },
    {
      "id": "cp1:3.2",
      "pali": "ṭhapayitvā bhavābhave;"
    },
    {
      "id": "cp1:3.3",
      "pali": "Imamhi kappe caritaṁ,"
    },
    {
      "id": "cp1:3.4",
      "pali": "pavakkhissaṁ suṇohi me."
    },
    {
      "id": "cp1:4.1",
      "pali": "Yadā ahaṁ brahāraññe,"
    },
    {
      "id": "cp1:4.2",
      "pali": "suññe vipinakānane;"
    },
    {
      "id": "cp1:4.3",
      "pali": "Ajjhogāhetvā viharāmi,"
    },
    {
      "id": "cp1:4.4",
      "pali": "akitti nāma tāpaso."
    },
    {
      "id": "cp1:5.1",
      "pali": "Tadā maṁ tapatejena,"
    },
    {
      "id": "cp1:5.2",
      "pali": "santatto tidivābhibhū;"
    },
    {
      "id": "cp1:5.3",
      "pali": "Dhārento brāhmaṇavaṇṇaṁ,"
    },
    {
      "id": "cp1:5.4",
      "pali": "bhikkhāya maṁ upāgami."
    },
    {
      "id": "cp1:6.1",
      "pali": "Pavanā ābhataṁ paṇṇaṁ,"
    },
    {
      "id": "cp1:6.2",
      "pali": "atelañca aloṇikaṁ;"
    },
    {
      "id": "cp1:6.3",
      "pali": "Mama dvāre ṭhitaṁ disvā,"
    },
    {
      "id": "cp1:6.4",
      "pali": "sakaṭāhena ākiriṁ."
    },
    {
      "id": "cp1:7.1",
      "pali": "Tassa datvānahaṁ paṇṇaṁ,"
    },
    {
      "id": "cp1:7.2",
      "pali": "nikkujjitvāna bhājanaṁ;"
    },
    {
      "id": "cp1:7.3",
      "pali": "Punesanaṁ jahitvāna,"
    },
    {
      "id": "cp1:7.4",
      "pali": "pāvisiṁ paṇṇasālakaṁ."
    },
    {
      "id": "cp1:8.1",
      "pali": "Dutiyampi tatiyampi,"
    },
    {
      "id": "cp1:8.2",
      "pali": "upagañchi mamantikaṁ;"
    },
    {
      "id": "cp1:8.3",
      "pali": "Akampito anolaggo,"
    },
    {
      "id": "cp1:8.4",
      "pali": "evamevamadāsahaṁ."
    },
    {
      "id": "cp1:9.1",
      "pali": "Na me tappaccayā atthi,"
    },
    {
      "id": "cp1:9.2",
      "pali": "sarīrasmiṁ vivaṇṇiyaṁ;"
    },
    {
      "id": "cp1:9.3",
      "pali": "Pītisukhena ratiyā,"
    },
    {
      "id": "cp1:9.4",
      "pali": "vītināmemi taṁ divaṁ."
    },
    {
      "id": "cp1:10.1",
      "pali": "Yadi māsampi dvemāsaṁ,"
    },
    {
      "id": "cp1:10.2",
      "pali": "dakkhiṇeyyaṁ varaṁ labhe;"
    },
    {
      "id": "cp1:10.3",
      "pali": "Akampito anolīno,"
    },
    {
      "id": "cp1:10.4",
      "pali": "dadeyyaṁ dānamuttamaṁ."
    },
    {
      "id": "cp1:11.1",
      "pali": "Na tassa dānaṁ dadamāno,"
    },
    {
      "id": "cp1:11.2",
      "pali": "yasaṁ lābhañca patthayiṁ;"
    },
    {
      "id": "cp1:11.3",
      "pali": "Sabbaññutaṁ patthayāno,"
    },
    {
      "id": "cp1:11.4",
      "pali": "tāni kammāni ācarin”ti."
    },
    {
      "id": "cp1:12.1",
      "pali": "Akitticariyaṁ paṭhamaṁ."
    }
  ]
}
