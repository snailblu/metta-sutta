{
  "uid": "tha-ap450",
  "title": "Pādapīṭhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap450:1.1",
      "pali": "“Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap450:1.2",
      "pali": "aggo kāruṇiko muni;"
    },
    {
      "id": "tha-ap450:1.3",
      "pali": "Tārayitvā bahū satte,"
    },
    {
      "id": "tha-ap450:1.4",
      "pali": "nibbuto so mahāyaso."
    },
    {
      "id": "tha-ap450:2.1",
      "pali": "Sīhāsanassa sāmantā,"
    },
    {
      "id": "tha-ap450:2.2",
      "pali": "sumedhassa mahesino;"
    },
    {
      "id": "tha-ap450:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap450:2.4",
      "pali": "pādapīṭhamakārayiṁ."
    },
    {
      "id": "tha-ap450:3.1",
      "pali": "Katvāna kusalaṁ kammaṁ,"
    },
    {
      "id": "tha-ap450:3.2",
      "pali": "sukhapākaṁ sukhudrayaṁ;"
    },
    {
      "id": "tha-ap450:3.3",
      "pali": "Puññakammena saṁyutto,"
    },
    {
      "id": "tha-ap450:3.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap450:4.1",
      "pali": "Tattha me vasamānassa,"
    },
    {
      "id": "tha-ap450:4.2",
      "pali": "puññakammasamaṅgino;"
    },
    {
      "id": "tha-ap450:4.3",
      "pali": "Padāni uddharantassa,"
    },
    {
      "id": "tha-ap450:4.4",
      "pali": "soṇṇapīṭhā bhavanti me."
    },
    {
      "id": "tha-ap450:5.1",
      "pali": "Lābhā tesaṁ suladdhaṁ vo,"
    },
    {
      "id": "tha-ap450:5.2",
      "pali": "ye labhanti upassutiṁ;"
    },
    {
      "id": "tha-ap450:5.3",
      "pali": "Nibbute kāraṁ katvāna,"
    },
    {
      "id": "tha-ap450:5.4",
      "pali": "labhanti vipulaṁ sukhaṁ."
    },
    {
      "id": "tha-ap450:6.1",
      "pali": "Mayāpi sukataṁ kammaṁ,"
    },
    {
      "id": "tha-ap450:6.2",
      "pali": "vāṇijjaṁ suppayojitaṁ;"
    },
    {
      "id": "tha-ap450:6.3",
      "pali": "Pādapīṭhaṁ karitvāna,"
    },
    {
      "id": "tha-ap450:6.4",
      "pali": "soṇṇapīṭhaṁ labhāmahaṁ."
    },
    {
      "id": "tha-ap450:7.1",
      "pali": "Yaṁ yaṁ disaṁ pakkamāmi,"
    },
    {
      "id": "tha-ap450:7.2",
      "pali": "kenaci kiccayenahaṁ;"
    },
    {
      "id": "tha-ap450:7.3",
      "pali": "Soṇṇapīṭhe akkamāmi,"
    },
    {
      "id": "tha-ap450:7.4",
      "pali": "puññakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap450:8.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap450:8.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap450:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap450:8.4",
      "pali": "pādapīṭhassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap450:9.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap450:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap450:9.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap450:10.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap450:10.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap450:10.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap450:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap450:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap450:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap450:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā pādapīṭhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap450:13.1",
      "pali": "Pādapīṭhiyattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
