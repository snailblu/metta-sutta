    },
    {
      "id": "ps2.2:15.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:16.1",
      "pali": "Kathaṁ tathaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:16.2",
      "pali": "Soḷasahākārehi tathaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:16.3",
      "pali": "Dukkhassa pīḷanaṭṭho, saṅkhataṭṭho, santāpaṭṭho, vipariṇāmaṭṭho, tathaṭṭho;"
    },
    {
      "id": "ps2.2:16.4",
      "pali": "samudayassa āyūhanaṭṭho, nidānaṭṭho, saṁyogaṭṭho, palibodhaṭṭho tathaṭṭho;"
    },
    {
      "id": "ps2.2:16.5",
      "pali": "nirodhassa nissaraṇaṭṭho, vivekaṭṭho, asaṅkhataṭṭho, amataṭṭho tathaṭṭho;"
    },
    {
      "id": "ps2.2:16.6",
      "pali": "maggassa niyyānaṭṭho, hetuṭṭho, dassanaṭṭho, ādhipateyyaṭṭho tathaṭṭho—"
    },
    {
      "id": "ps2.2:16.7",
      "pali": "imehi soḷasahi ākārehi tathaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:16.8",
