    },
    {
      "id": "ps2.2:17.12",
      "pali": "Soḷasahi ākārehi abhisamayaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:17.13",
      "pali": "Dukkhassa pīḷanaṭṭho, saṅkhataṭṭho, santāpaṭṭho, vipariṇāmaṭṭho, abhisamayaṭṭho;"
    },
    {
      "id": "ps2.2:17.14",
      "pali": "samudayassa āyūhanaṭṭho, nidānaṭṭho, saṁyogaṭṭho, palibodhaṭṭho, abhisamayaṭṭho;"
    },
    {
      "id": "ps2.2:17.15",
      "pali": "nirodhassa nissaraṇaṭṭho, vivekaṭṭho, asaṅkhataṭṭho, amataṭṭho, abhisamayaṭṭho;"
    },
    {
      "id": "ps2.2:17.16",
      "pali": "maggassa niyyānaṭṭho, hetuṭṭho, dassanaṭṭho, ādhipateyyaṭṭho, abhisamayaṭṭho—"
    },
    {
      "id": "ps2.2:17.17",
      "pali": "imehi soḷasahi ākārehi abhisamayaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:17.18",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:17.19",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:17.20",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:18.1",
      "pali": "Saccānaṁ kati lakkhaṇāni?"
    },
    {
      "id": "ps2.2:18.2",
      "pali": "Saccānaṁ dve lakkhaṇāni."
    },
    {
      "id": "ps2.2:18.3",
      "pali": "Saṅkhatalakkhaṇañca, asaṅkhatalakkhaṇañca—"
    },
    {
      "id": "ps2.2:18.4",
      "pali": "saccānaṁ imāni dve lakkhaṇāni."
    },
    {
      "id": "ps2.2:19.1",
      "pali": "Saccānaṁ kati lakkhaṇāni?"
    },
    {
      "id": "ps2.2:19.2",
      "pali": "Saccānaṁ cha lakkhaṇāni."
    },
    {
      "id": "ps2.2:19.3",
      "pali": "Saṅkhatānaṁ saccānaṁ uppādo paññāyati, vayo paññāyati, ṭhitānaṁ aññathattaṁ paññāyati asaṅkhatassa saccassa na uppādo paññāyati, na vayo paññāyati, na ṭhitassa aññathattaṁ paññāyati—"
    },
    {
      "id": "ps2.2:19.4",
      "pali": "saccānaṁ imāni cha lakkhaṇāni."
    },
    {
      "id": "ps2.2:20.1",
      "pali": "Saccānaṁ kati lakkhaṇāni?"
    },
    {
      "id": "ps2.2:20.2",
      "pali": "Saccānaṁ dvādasa lakkhaṇāni."
    },
    {
      "id": "ps2.2:20.3",
      "pali": "Dukkhasaccassa uppādo paññāyati, vayo paññāyati, ṭhitassa aññathattaṁ paññāyati;"
    },
    {
      "id": "ps2.2:20.4",
      "pali": "samudayasaccassa uppādo paññāyati, vayo paññāyati, ṭhitassa aññathattaṁ paññāyati;"
    },
    {
      "id": "ps2.2:20.5",
      "pali": "maggasaccassa uppādo paññāyati, vayo paññāyati, ṭhitassa aññathattaṁ paññāyati;"
    },
    {
      "id": "ps2.2:20.6",
      "pali": "nirodhasaccassa na uppādo paññāyati, na vayo paññāyati, na ṭhitassa aññathattaṁ paññāyati—"
    },
    {
      "id": "ps2.2:20.7",
      "pali": "saccānaṁ imāni dvādasa lakkhaṇāni."
    },
    {
      "id": "ps2.2:21.1",
      "pali": "Catunnaṁ saccānaṁ kati kusalā, kati akusalā, kati abyākatā?"
    },
    {
      "id": "ps2.2:21.2",
      "pali": "Samudayasaccaṁ akusalaṁ, maggasaccaṁ kusalaṁ, nirodhasaccaṁ abyākataṁ."
    },
    {
      "id": "ps2.2:21.3",
      "pali": "Dukkhasaccaṁ siyā kusalaṁ, siyā akusalaṁ, siyā abyākataṁ."
    },
    {
      "id": "ps2.2:22.1",
      "pali": "Siyā tīṇi saccāni ekasaccena saṅgahitāni, ekasaccaṁ tīhi saccehi saṅgahitaṁ?"
    },
    {
      "id": "ps2.2:22.2",
      "pali": "Vatthuvasena pariyāyena siyāti."
    },
    {
      "id": "ps2.2:22.3",
      "pali": "Kathañca siyā?"
    },
    {
      "id": "ps2.2:22.4",
      "pali": "Yaṁ dukkhasaccaṁ akusalaṁ, samudayasaccaṁ akusalaṁ—"
    },
    {
      "id": "ps2.2:22.5",
      "pali": "evaṁ akusalaṭṭhena dve saccāni ekasaccena saṅgahitāni, ekasaccaṁ dvīhi saccehi saṅgahitaṁ."
    },
    {
      "id": "ps2.2:22.6",
      "pali": "Yaṁ dukkhasaccaṁ kusalaṁ, maggasaccaṁ kusalaṁ—"
    },
    {
      "id": "ps2.2:22.7",
      "pali": "evaṁ kusalaṭṭhena dve saccāni ekasaccena saṅgahitāni, ekasaccaṁ dvīhi saccehi saṅgahitaṁ."
    },
    {
      "id": "ps2.2:22.8",
      "pali": "Yaṁ dukkhasaccaṁ abyākataṁ, nirodhasaccaṁ abyākataṁ—"
    },
    {
      "id": "ps2.2:22.9",
      "pali": "evaṁ abyākataṭṭhena dve saccāni ekasaccena saṅgahitāni, ekasaccaṁ dvīhi saccehi saṅgahitaṁ."
    },
    {
      "id": "ps2.2:22.10",
      "pali": "Evaṁ siyā tīṇi saccāni ekasaccena saṅgahitāni, ekasaccaṁ tīhi saccehi saṅgahitaṁ vatthuvasena pariyāyenāti."
    },
    {
      "id": "ps2.2:23.1",
      "pali": "“Pubbe me, bhikkhave, sambodhā anabhisambuddhassa bodhisattasseva sato etadahosi—"
    },
    {
      "id": "ps2.2:23.2",
      "pali": "‘ko nu kho rūpassa assādo, ko ādīnavo, kiṁ nissaraṇaṁ;"
    },
    {
      "id": "ps2.2:23.3",
      "pali": "ko vedanāya assādo, ko ādīnavo, kiṁ nissaraṇaṁ;"
    },
    {
      "id": "ps2.2:23.4",
      "pali": "ko saññāya assādo, ko ādīnavo, kiṁ nissaraṇaṁ;"
    },
    {
      "id": "ps2.2:23.5",
      "pali": "ko saṅkhārānaṁ assādo, ko ādīnavo, kiṁ nissaraṇaṁ;"
    },
    {
      "id": "ps2.2:23.6",
      "pali": "ko viññāṇassa assādo, ko ādīnavo, kiṁ nissaraṇan’ti?"
    },
    {
      "id": "ps2.2:23.7",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi—"
    },
    {
      "id": "ps2.2:23.8",
      "pali": "‘yaṁ kho rūpaṁ paṭicca uppajjati sukhaṁ somanassaṁ—"
    },
    {
      "id": "ps2.2:23.9",
      "pali": "ayaṁ rūpassa assādo."
    },
    {
      "id": "ps2.2:23.10",
      "pali": "Yaṁ rūpaṁ aniccaṁ, taṁ dukkhaṁ vipariṇāmadhammaṁ—"
    },
    {
      "id": "ps2.2:23.11",
      "pali": "ayaṁ rūpassa ādīnavo."
    },
    {
      "id": "ps2.2:23.12",
      "pali": "Yo rūpasmiṁ chandarāgavinayo chandarāgappahānaṁ—"
    },
    {
      "id": "ps2.2:23.13",
      "pali": "idaṁ rūpassa nissaraṇaṁ."
    },
    {
      "id": "ps2.2:23.14",
      "pali": "Yaṁ vedanaṁ paṭicca …pe…"
    },
    {
      "id": "ps2.2:23.15",
      "pali": "yaṁ saññaṁ paṭicca …"
    },
    {
      "id": "ps2.2:23.16",
      "pali": "yaṁ saṅkhāre paṭicca …"
    },
    {
      "id": "ps2.2:23.17",
      "pali": "yaṁ viññāṇaṁ paṭicca uppajjati sukhaṁ somanassaṁ—"
    },
    {
      "id": "ps2.2:23.18",
      "pali": "ayaṁ viññāṇassa assādo."
    },
    {
      "id": "ps2.2:23.19",
      "pali": "Yaṁ viññāṇaṁ aniccaṁ taṁ dukkhaṁ vipariṇāmadhammaṁ—"
    },
    {
      "id": "ps2.2:23.20",
      "pali": "ayaṁ viññāṇassa ādīnavo."
    },
    {
      "id": "ps2.2:23.21",
      "pali": "Yo viññāṇasmiṁ chandarāgavinayo chandarāgappahānaṁ—"
    },
    {
      "id": "ps2.2:23.22",
      "pali": "idaṁ viññāṇassa nissaraṇaṁ’."
    },
    {
      "id": "ps2.2:24.1",
      "pali": "Yāvakīvañcāhaṁ, bhikkhave, imesaṁ pañcannaṁ upādānakkhandhānaṁ evaṁ assādañca assādato ādīnavañca ādīnavato nissaraṇañca nissaraṇato yathābhūtaṁ nābbhaññāsiṁ, neva tāvāhaṁ, bhikkhave, sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya ‘anuttaraṁ sammāsambodhiṁ abhisambuddho’ti paccaññāsiṁ yato ca khvāhaṁ, bhikkhave, imesaṁ pañcannaṁ upādānakkhandhānaṁ evaṁ assādañca assādato ādīnavañca ādīnavato nissaraṇañca nissaraṇato yathābhūtaṁ abbhaññāsiṁ, athāhaṁ, bhikkhave, ‘sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya anuttaraṁ sammāsambodhiṁ abhisambuddho’ti paccaññāsiṁ."
    },
    {
      "id": "ps2.2:24.2",
      "pali": "Ñāṇañca pana me dassanaṁ udapādi—"
    },
    {
      "id": "ps2.2:24.3",
      "pali": "‘akuppā me vimutti."
    },
    {
      "id": "ps2.2:24.4",
      "pali": "Ayamantimā jāti, natthi dāni punabbhavo’”ti."
    },
    {
      "id": "ps2.2:25.1",
      "pali": "Yaṁ rūpaṁ paṭicca uppajjati sukhaṁ somanassaṁ, ayaṁ rūpassa assādoti—"
    },
    {
      "id": "ps2.2:25.2",
      "pali": "pahānappaṭivedho samudayasaccaṁ."
    },
    {
      "id": "ps2.2:25.3",
      "pali": "Yaṁ rūpaṁ aniccaṁ taṁ dukkhaṁ vipariṇāmadhammaṁ, ayaṁ rūpassa ādīnavoti—"
    },
    {
      "id": "ps2.2:25.4",
      "pali": "pariññāpaṭivedho dukkhasaccaṁ."
    },
    {
      "id": "ps2.2:25.5",
      "pali": "Yo rūpasmiṁ chandarāgavinayo chandarāgappahānaṁ, idaṁ rūpassa nissaraṇanti—"
    },
    {
      "id": "ps2.2:25.6",
      "pali": "sacchikiriyāpaṭivedho nirodhasaccaṁ."
    },
    {
      "id": "ps2.2:25.7",
      "pali": "Yā imesu tīsu ṭhānesu diṭṭhi saṅkappo vācā kammanto ājīvo vāyāmo sati samādhi—"
    },
    {
      "id": "ps2.2:25.8",
      "pali": "bhāvanāpaṭivedho maggasaccaṁ."
    },
    {
      "id": "ps2.2:26.1",
      "pali": "Yaṁ vedanaṁ paṭicca …pe…"
    },
    {
      "id": "ps2.2:26.2",
      "pali": "yaṁ saññaṁ paṭicca …"
    },
    {
      "id": "ps2.2:26.3",
      "pali": "yaṁ saṅkhāre paṭicca …"
    },
    {
      "id": "ps2.2:26.4",
      "pali": "yaṁ viññāṇaṁ paṭicca uppajjati sukhaṁ somanassaṁ, ayaṁ viññāṇassa assādoti—"
    },
    {
      "id": "ps2.2:26.5",
      "pali": "pahānappaṭivedho samudayasaccaṁ."
    },
    {
      "id": "ps2.2:26.6",
      "pali": "Yaṁ viññāṇaṁ aniccaṁ taṁ dukkhaṁ vipariṇāmadhammaṁ, ayaṁ viññāṇassa ādīnavoti—"
    },
    {
      "id": "ps2.2:26.7",
      "pali": "pariññāpaṭivedho dukkhasaccaṁ."
    },
    {
      "id": "ps2.2:26.8",
      "pali": "Yo viññāṇasmiṁ chandarāgavinayo chandarāgappahānaṁ, idaṁ viññāṇassa nissaraṇanti—"
    },
    {
      "id": "ps2.2:26.9",
      "pali": "sacchikiriyāpaṭivedho nirodhasaccaṁ."
    },
    {
      "id": "ps2.2:26.10",
      "pali": "Yā imesu tīsu ṭhānesu diṭṭhi saṅkappo vācā kammanto ājīvo vāyāmo sati samādhi—"
    },
    {
      "id": "ps2.2:26.11",
      "pali": "bhāvanāpaṭivedho maggasaccaṁ."
    },
    {
      "id": "ps2.2:27.1",
      "pali": "<b>Saccan</b>ti katihākārehi saccaṁ?"
    },
    {
      "id": "ps2.2:27.2",
      "pali": "Esanaṭṭhena, pariggahaṭṭhena, paṭivedhaṭṭhena."
    },
    {
      "id": "ps2.2:27.3",
      "pali": "Kathaṁ esanaṭṭhena saccaṁ?"
    },
    {
      "id": "ps2.2:27.4",
      "pali": "Jarāmaraṇaṁ kiṁnidānaṁ, kiṁsamudayaṁ, kiṁjātikaṁ, kiṁpabhavanti—"
    },
    {
      "id": "ps2.2:27.5",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:27.6",
      "pali": "Jarāmaraṇaṁ jātinidānaṁ, jātisamudayaṁ, jātijātikaṁ, jātippabhavanti—"
    },
    {
      "id": "ps2.2:27.7",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:27.8",
      "pali": "Jarāmaraṇañca pajānāti, jarāmaraṇasamudayañca pajānāti, jarāmaraṇanirodhañca pajānāti, jarāmaraṇanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:27.9",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:28.1",
      "pali": "Jāti kiṁnidānā, kiṁsamudayā, kiṁjātikā, kiṁpabhavāti—"
    },
    {
      "id": "ps2.2:28.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:28.3",
      "pali": "Jāti bhavanidānā, bhavasamudayā, bhavajātikā, bhavappabhavāti—"
    },
    {
      "id": "ps2.2:28.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:28.5",
      "pali": "Jātiñca pajānāti, jātisamudayañca pajānāti, jātinirodhañca pajānāti, jātinirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:28.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:29.1",
      "pali": "Bhavo kiṁnidāno, kiṁsamudayo, kiṁjātiko, kiṁpabhavoti—"
    },
    {
      "id": "ps2.2:29.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:29.3",
      "pali": "Bhavo upādānanidāno, upādānasamudayo, upādānajātiko, upādānappabhavoti—"
    },
    {
      "id": "ps2.2:29.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:29.5",
      "pali": "Bhavaṁ ca pajānāti, bhavasamudayañca pajānāti, bhavanirodhañca pajānāti, bhavanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:29.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:30.1",
      "pali": "Upādānaṁ kiṁnidānaṁ, kiṁsamudayaṁ, kiṁjātikaṁ, kiṁpabhavanti—"
    },
    {
      "id": "ps2.2:30.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:30.3",
      "pali": "Upādānaṁ taṇhānidānaṁ, taṇhāsamudayaṁ, taṇhājātikaṁ, taṇhāpabhavanti—"
    },
    {
      "id": "ps2.2:30.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:30.5",
      "pali": "Upādānañca pajānāti, upādānasamudayañca pajānāti, upādānanirodhañca pajānāti upādānanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:30.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:31.1",
      "pali": "Taṇhā kiṁnidānā, kiṁsamudayā, kiṁjātikā, kiṁpabhavāti—"
    },
    {
      "id": "ps2.2:31.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:31.3",
      "pali": "Taṇhā vedanānidānā, vedanāsamudayā, vedanājātikā, vedanāpabhavāti—"
    },
    {
      "id": "ps2.2:31.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:31.5",
      "pali": "Taṇhañca pajānāti, taṇhāsamudayañca pajānāti, taṇhānirodhañca pajānāti, taṇhānirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:31.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:32.1",
      "pali": "Vedanā kiṁnidānā, kiṁsamudayā, kiṁjātikā, kiṁpabhavāti—"
    },
    {
      "id": "ps2.2:32.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:32.3",
      "pali": "Vedanā phassanidānā, phassasamudayā, phassajātikā, phassappabhavāti—"
    },
    {
      "id": "ps2.2:32.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:32.5",
      "pali": "Vedanañca pajānāti, vedanāsamudayañca pajānāti, vedanānirodhañca pajānāti, vedanānirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:32.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:33.1",
      "pali": "Phasso kiṁnidāno, kiṁsamudayo, kiṁjātiko, kiṁpabhavoti—"
    },
    {
      "id": "ps2.2:33.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:33.3",
      "pali": "Phasso saḷāyatananidāno, saḷāyatanasamudayo, saḷāyatanajātiko, saḷāyatanappabhavoti—"
    },
    {
      "id": "ps2.2:33.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:33.5",
      "pali": "Phassañca pajānāti, phassasamudayañca pajānāti, phassanirodhañca pajānāti, phassanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:33.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:34.1",
      "pali": "Saḷāyatanaṁ kiṁnidānaṁ, kiṁsamudayaṁ, kiṁjātikaṁ, kiṁpabhavanti—"
    },
    {
      "id": "ps2.2:34.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:34.3",
      "pali": "Saḷāyatanaṁ nāmarūpanidānaṁ, nāmarūpasamudayaṁ, nāmarūpajātikaṁ, nāmarūpappabhavanti—"
    },
    {
      "id": "ps2.2:34.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:34.5",
      "pali": "Saḷāyatanañca pajānāti, saḷāyatanasamudayañca pajānāti, saḷāyatananirodhañca pajānāti, saḷāyatananirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:34.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:35.1",
      "pali": "Nāmarūpaṁ kiṁnidānaṁ, kiṁsamudayaṁ, kiṁjātikaṁ, kiṁpabhavanti—"
    },
    {
      "id": "ps2.2:35.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:35.3",
      "pali": "Nāmarūpaṁ viññāṇanidānaṁ, viññāṇasamudayaṁ, viññāṇajātikaṁ, viññāṇappabhavanti—"
    },
    {
      "id": "ps2.2:35.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:35.5",
      "pali": "Nāmarūpañca pajānāti, nāmarūpasamudayañca pajānāti, nāmarūpanirodhañca pajānāti, nāmarūpanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:35.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:36.1",
      "pali": "Viññāṇaṁ kiṁnidānaṁ, kiṁsamudayaṁ, kiṁjātikaṁ, kiṁpabhavanti—"
    },
    {
      "id": "ps2.2:36.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:36.3",
      "pali": "Viññāṇaṁ saṅkhāranidānaṁ, saṅkhārasamudayaṁ, saṅkhārajātikaṁ, saṅkhārappabhavanti—"
    },
    {
      "id": "ps2.2:36.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:36.5",
      "pali": "Viññāṇañca pajānāti, viññāṇasamudayañca pajānāti, viññāṇanirodhañca pajānāti, viññāṇanirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:36.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:37.1",
      "pali": "Saṅkhārā kiṁnidānā, kiṁsamudayā, kiṁjātikā, kiṁpabhavāti—"
    },
    {
      "id": "ps2.2:37.2",
      "pali": "evaṁ esanaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:37.3",
      "pali": "Saṅkhārā avijjānidānā, avijjāsamudayā, avijjājātikā, avijjāpabhavāti—"
    },
    {
      "id": "ps2.2:37.4",
      "pali": "evaṁ pariggahaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:37.5",
      "pali": "Saṅkhāre ca pajānāti, saṅkhārasamudayañca pajānāti, saṅkhāranirodhañca pajānāti, saṅkhāranirodhagāminiṁ paṭipadañca pajānāti—"
    },
    {
      "id": "ps2.2:37.6",
      "pali": "evaṁ paṭivedhaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:38.1",
      "pali": "Jarāmaraṇaṁ dukkhasaccaṁ, jāti samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.2",
      "pali": "Jāti dukkhasaccaṁ, bhavo samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.3",
      "pali": "Bhavo dukkhasaccaṁ, upādānaṁ samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.4",
      "pali": "Upādānaṁ dukkhasaccaṁ, taṇhā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.5",
      "pali": "Taṇhā dukkhasaccaṁ, vedanā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.6",
      "pali": "Vedanā dukkhasaccaṁ, phasso samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.7",
      "pali": "Phasso dukkhasaccaṁ, saḷāyatanaṁ samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.8",
      "pali": "Saḷāyatanaṁ dukkhasaccaṁ, nāmarūpaṁ samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.9",
      "pali": "Nāmarūpaṁ dukkhasaccaṁ, viññāṇaṁ samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.10",
      "pali": "Viññāṇaṁ dukkhasaccaṁ, saṅkhārā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:38.11",
      "pali": "Saṅkhārā dukkhasaccaṁ, avijjā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:39.1",
      "pali": "Jarāmaraṇaṁ siyā dukkhasaccaṁ, siyā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccaṁ."
    },
    {
      "id": "ps2.2:39.2",
      "pali": "Jāti siyā dukkhasaccaṁ, siyā samudayasaccaṁ …pe…"
    },
    {
      "id": "ps2.2:39.3",
      "pali": "bhavo siyā dukkhasaccaṁ, siyā samudayasaccaṁ, ubhinnampi nissaraṇaṁ nirodhasaccaṁ, nirodhappajānanā maggasaccanti."
    },
    {
      "id": "ps2.2:39.4",
      "pali": "Saccakathā niṭṭhitā."
    },
    {
      "id": "ps2.2:39.5",
      "pali": "Bhāṇavāro."
    }
  ]
}
