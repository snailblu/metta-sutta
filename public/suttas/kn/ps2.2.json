{
  "uid": "ps2.2",
  "title": "2.2. Saccakathā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ps2.2:1.1",
      "pali": "Purimanidānaṁ."
    },
    {
      "id": "ps2.2:1.2",
      "pali": "“Cattārimāni, bhikkhave, tathāni avitathāni anaññathāni."
    },
    {
      "id": "ps2.2:1.3",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "ps2.2:1.4",
      "pali": "‘Idaṁ dukkhan’ti, bhikkhave, tathametaṁ avitathametaṁ anaññathametaṁ;"
    },
    {
      "id": "ps2.2:1.5",
      "pali": "‘ayaṁ dukkhasamudayo’ti tathametaṁ avitathametaṁ anaññathametaṁ, ‘ayaṁ dukkhanirodho’ti tathametaṁ avitathametaṁ anaññathametaṁ, ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti tathametaṁ avitathametaṁ anaññathametaṁ."
    },
    {
      "id": "ps2.2:1.6",
      "pali": "Imāni kho, bhikkhave, cattāri tathāni avitathāni anaññathāni”."
    },
    {
      "id": "ps2.2:2.1",
      "pali": "Kathaṁ dukkhaṁ tathaṭṭhena saccaṁ?"
    },
    {
      "id": "ps2.2:2.2",
      "pali": "Cattāro dukkhassa dukkhaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:2.3",
      "pali": "Dukkhassa pīḷanaṭṭho, saṅkhataṭṭho, santāpaṭṭho, vipariṇāmaṭṭho—"
    },
    {
      "id": "ps2.2:2.4",
      "pali": "ime cattāro dukkhassa dukkhaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:2.5",
      "pali": "Evaṁ dukkhaṁ tathaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:3.1",
      "pali": "Kathaṁ samudayo tathaṭṭhena saccaṁ?"
    },
    {
      "id": "ps2.2:3.2",
      "pali": "Cattāro samudayassa samudayaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:3.3",
      "pali": "Samudayassa āyūhanaṭṭho, nidānaṭṭho, saṁyogaṭṭho palibodhaṭṭho—"
    },
    {
      "id": "ps2.2:3.4",
      "pali": "ime cattāro samudayassa samudayaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:3.5",
      "pali": "Evaṁ samudayo tathaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:4.1",
      "pali": "Kathaṁ nirodho tathaṭṭhena saccaṁ?"
    },
    {
      "id": "ps2.2:4.2",
      "pali": "Cattāro nirodhassa nirodhaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:4.3",
      "pali": "Nirodhassa nissaraṇaṭṭho, vivekaṭṭho, asaṅkhataṭṭho, amataṭṭho—"
    },
    {
      "id": "ps2.2:4.4",
      "pali": "ime cattāro nirodhassa nirodhaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:4.5",
      "pali": "Evaṁ nirodho tathaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:5.1",
      "pali": "Kathaṁ maggo tathaṭṭhena saccaṁ?"
    },
    {
      "id": "ps2.2:5.2",
      "pali": "Cattāro maggassa maggaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:5.3",
      "pali": "Maggassa niyyānaṭṭho, hetuṭṭho, dassanaṭṭho, ādhipateyyaṭṭho—"
    },
    {
      "id": "ps2.2:5.4",
      "pali": "ime cattāro maggassa maggaṭṭhā tathā avitathā anaññathā."
    },
    {
      "id": "ps2.2:5.5",
      "pali": "Evaṁ maggo tathaṭṭhena saccaṁ."
    },
    {
      "id": "ps2.2:6.1",
      "pali": "Katihākārehi cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:6.2",
      "pali": "Catūhākārehi cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:6.3",
      "pali": "Tathaṭṭhena, anattaṭṭhena, saccaṭṭhena, paṭivedhaṭṭhena—"
    },
    {
      "id": "ps2.2:6.4",
      "pali": "imehi catūhākārehi cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:6.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:6.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:6.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:7.1",
      "pali": "Kathaṁ tathaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:7.2",
      "pali": "Catūhākārehi tathaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:7.3",
      "pali": "Dukkhassa dukkhaṭṭho tathaṭṭho, samudayassa samudayaṭṭho tathaṭṭho, nirodhassa nirodhaṭṭho tathaṭṭho, maggassa maggaṭṭho tathaṭṭho—"
    },
    {
      "id": "ps2.2:7.4",
      "pali": "imehi catūhākārehi tathaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:7.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:7.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:7.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:8.1",
      "pali": "Kathaṁ anattaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:8.2",
      "pali": "Catūhākārehi anattaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:8.3",
      "pali": "Dukkhassa dukkhaṭṭho anattaṭṭho, samudayassa samudayaṭṭho anattaṭṭho, nirodhassa nirodhaṭṭho anattaṭṭho, maggassa maggaṭṭho anattaṭṭho—"
    },
    {
      "id": "ps2.2:8.4",
      "pali": "imehi catūhākārehi anattaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:8.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:8.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:8.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:9.1",
      "pali": "Kathaṁ saccaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:9.2",
      "pali": "Catūhākārehi saccaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:9.3",
      "pali": "Dukkhassa dukkhaṭṭho saccaṭṭho, samudayassa samudayaṭṭho saccaṭṭho, nirodhassa nirodhaṭṭho saccaṭṭho, maggassa maggaṭṭho saccaṭṭho—"
    },
    {
      "id": "ps2.2:9.4",
      "pali": "imehi catūhākārehi saccaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:9.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:9.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:9.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:10.1",
      "pali": "Kathaṁ paṭivedhaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:10.2",
      "pali": "Catūhākārehi paṭivedhaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:10.3",
      "pali": "Dukkhassa dukkhaṭṭho paṭivedhaṭṭho, samudayassa samudayaṭṭho paṭivedhaṭṭho nirodhassa nirodhaṭṭho paṭivedhaṭṭho, maggassa maggaṭṭho paṭivedhaṭṭho—"
    },
    {
      "id": "ps2.2:10.4",
      "pali": "imehi catūhākārehi paṭivedhaṭṭhena cattāri saccāni ekasaṅgahitāni yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:10.5",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:10.6",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:11.1",
      "pali": "Katihākārehi cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:11.2",
      "pali": "Yaṁ aniccaṁ taṁ dukkhaṁ, yaṁ dukkhaṁ taṁ aniccaṁ, yaṁ aniccañca dukkhañca taṁ anattā."
    },
    {
      "id": "ps2.2:11.3",
      "pali": "Yaṁ aniccañca dukkhañca anattā ca taṁ tathaṁ."
    },
    {
      "id": "ps2.2:11.4",
      "pali": "Yaṁ aniccaṁ ca dukkhañca anattā ca tathañca taṁ saccaṁ."
    },
    {
      "id": "ps2.2:11.5",
      "pali": "Yaṁ aniccañca dukkhañca anattā ca tathañca saccañca taṁ ekasaṅgahitaṁ."
    },
    {
      "id": "ps2.2:11.6",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:11.7",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:11.8",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:12.1",
      "pali": "Katihākārehi cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:12.2",
      "pali": "Navahākārehi cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:12.3",
      "pali": "Tathaṭṭhena, anattaṭṭhena, saccaṭṭhena, paṭivedhaṭṭhena, abhiññaṭṭhena, pariññaṭṭhena, pahānaṭṭhena, bhāvanaṭṭhena, sacchikiriyaṭṭhena—"
    },
    {
      "id": "ps2.2:12.4",
      "pali": "imehi navahākārehi cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:12.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:12.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:12.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:13.1",
      "pali": "Kathaṁ tathaṭṭhena cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:13.2",
      "pali": "Navahākārehi tathaṭṭhena cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:13.3",
      "pali": "Dukkhassa dukkhaṭṭho tathaṭṭho, samudayassa samudayaṭṭho tathaṭṭho, nirodhassa nirodhaṭṭho tathaṭṭho, maggassa maggaṭṭho tathaṭṭho, abhiññāya abhiññaṭṭho tathaṭṭho, pariññāya pariññaṭṭho tathaṭṭho, pahānassa pahānaṭṭho tathaṭṭho, bhāvanāya bhāvanaṭṭho tathaṭṭho, sacchikiriyāya sacchikiriyaṭṭho tathaṭṭho—"
    },
    {
      "id": "ps2.2:13.4",
      "pali": "imehi navahākārehi tathaṭṭhena cattāri saccāni ekasaṅgahitāni."
    },
    {
      "id": "ps2.2:13.5",
      "pali": "Yaṁ ekasaṅgahitaṁ taṁ ekattaṁ."
    },
    {
      "id": "ps2.2:13.6",
      "pali": "Ekattaṁ ekena ñāṇena paṭivijjhatīti—"
    },
    {
      "id": "ps2.2:13.7",
      "pali": "cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:14.1",
      "pali": "Kathaṁ anattaṭṭhena …"
    },
    {
      "id": "ps2.2:14.2",
      "pali": "saccaṭṭhena …"
    },
    {
