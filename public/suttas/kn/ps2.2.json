    },
    {
      "id": "ps2.2:15.1",
      "pali": "Katihākārehi cattāri saccāni ekappaṭivedhāni?"
    },
    {
      "id": "ps2.2:15.2",
      "pali": "Dvādasahākārehi cattāri saccāni ekappaṭivedhāni."
    },
    {
      "id": "ps2.2:15.3",
      "pali": "Tathaṭṭhena, anattaṭṭhena, saccaṭṭhena, paṭivedhaṭṭhena, abhijānanaṭṭhena, parijānanaṭṭhena, dhammaṭṭhena, tathaṭṭhena, ñātaṭṭhena, sacchikiriyaṭṭhena, phassanaṭṭhena, abhisamayaṭṭhena—"
    },
    {
      "id": "ps2.2:15.4",
      "pali": "imehi dvādasahi ākārehi cattāri saccāni ekasaṅgahitāni."
