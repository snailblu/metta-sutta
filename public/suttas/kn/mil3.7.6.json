{
  "uid": "mil3.7.6",
  "title": "6. Bojjhaṅgapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.7.6:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.7.6:1.2",
      "pali": "“kati nu kho, bhante nāgasena, bojjhaṅgā”ti?"
    },
    {
      "id": "mil3.7.6:1.3",
      "pali": "“Satta kho, mahārāja, bojjhaṅgā”ti."
    },
    {
      "id": "mil3.7.6:1.4",
      "pali": "“Katihi pana, bhante, bojjhaṅgehi bujjhatī”ti?"
    },
    {
      "id": "mil3.7.6:1.5",
      "pali": "“Ekena kho, mahārāja, bojjhaṅgena bujjhati dhammavicayasambojjhaṅgenā”ti."
    },
    {
      "id": "mil3.7.6:1.6",
      "pali": "“Atha kissa nu kho, bhante, vuccanti ‘satta bojjhaṅgā’”ti?"
    },
    {
      "id": "mil3.7.6:1.7",
      "pali": "“Taṁ kiṁ maññasi, mahārāja, asi kosiyā pakkhitto aggahito hatthena ussahati chejjaṁ chinditun”ti."
    },
    {
      "id": "mil3.7.6:1.8",
      "pali": "“Na hi, bhante”ti."
    },
    {
      "id": "mil3.7.6:1.9",
      "pali": "“Evameva kho, mahārāja, dhammavicayasambojjhaṅgena vinā chahi bojjhaṅgehi na bujjhatī”ti."
    },
    {
      "id": "mil3.7.6:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.7.6:3.1",
      "pali": "Bojjhaṅgapañho chaṭṭho."
    }
  ]
}
