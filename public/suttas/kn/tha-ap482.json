{
  "uid": "tha-ap482",
  "title": "10 Pulinacaṅkamiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap482:1.1",
      "pali": "“Migaluddo pure āsiṁ,"
    },
    {
      "id": "tha-ap482:1.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap482:1.3",
      "pali": "Vātamigaṁ gavesanto,"
    },
    {
      "id": "tha-ap482:1.4",
      "pali": "caṅkamaṁ addasaṁ ahaṁ."
    },
    {
      "id": "tha-ap482:2.1",
      "pali": "Ucchaṅgena pulinaṁ gayha,"
    },
    {
      "id": "tha-ap482:2.2",
      "pali": "caṅkame okiriṁ ahaṁ;"
    },
    {
      "id": "tha-ap482:2.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap482:2.4",
      "pali": "sugatassa sirīmato."
    },
    {
      "id": "tha-ap482:3.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap482:3.2",
      "pali": "pulinaṁ okiriṁ ahaṁ;"
    },
    {
      "id": "tha-ap482:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap482:3.4",
      "pali": "pulinassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap482:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap482:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap482:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap482:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap482:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap482:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap482:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap482:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap482:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap482:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā pulinacaṅkamiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap482:8.1",
      "pali": "Pulinacaṅkamiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap482:9.1",
      "pali": "Naḷamālivaggo aṭṭhacattālīsamo."
    },
    {
      "id": "tha-ap482:10.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap482:11.1",
      "pali": "Naḷamālī maṇidado,"
    },
    {
      "id": "tha-ap482:11.2",
      "pali": "ukkāsatikabījanī;"
    },
    {
      "id": "tha-ap482:11.3",
      "pali": "Kummāso ca kusaṭṭho ca,"
    },
    {
      "id": "tha-ap482:11.4",
      "pali": "giripunnāgiyopi ca."
    },
    {
      "id": "tha-ap482:12.1",
      "pali": "Vallikāro pānadhido,"
    },
    {
      "id": "tha-ap482:12.2",
      "pali": "atho pulinacaṅkamo;"
    },
    {
      "id": "tha-ap482:12.3",
      "pali": "Gāthāyo pañcanavuti,"
    },
    {
      "id": "tha-ap482:12.4",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
