{
  "uid": "thig10.1",
  "title": "Kisāgotamītherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig10.1:1.1",
      "pali": "“Kalyāṇamittatā muninā,"
    },
    {
      "id": "thig10.1:1.2",
      "pali": "lokaṁ ādissa vaṇṇitā;"
    },
    {
      "id": "thig10.1:1.3",
      "pali": "Kalyāṇamitte bhajamāno,"
    },
    {
      "id": "thig10.1:1.4",
      "pali": "api bālo paṇḍito assa."
    },
    {
      "id": "thig10.1:2.1",
      "pali": "Bhajitabbā sappurisā,"
    },
    {
      "id": "thig10.1:2.2",
      "pali": "Paññā tathā vaḍḍhati bhajantānaṁ;"
    },
    {
      "id": "thig10.1:2.3",
      "pali": "Bhajamāno sappurise,"
    },
    {
      "id": "thig10.1:2.4",
      "pali": "Sabbehipi dukkhehi pamucceyya."
    },
    {
      "id": "thig10.1:3.1",
      "pali": "Dukkhañca vijāneyya,"
    },
    {
      "id": "thig10.1:3.2",
      "pali": "Dukkhassa ca samudayaṁ nirodhaṁ;"
    },
    {
      "id": "thig10.1:3.3",
      "pali": "Aṭṭhaṅgikañca maggaṁ,"
    },
    {
      "id": "thig10.1:3.4",
      "pali": "Cattāripi ariyasaccāni”."
    },
    {
      "id": "thig10.1:4.1",
      "pali": "“Dukkho itthibhāvo,"
    },
    {
      "id": "thig10.1:4.2",
      "pali": "Akkhāto purisadammasārathinā;"
    },
    {
      "id": "thig10.1:4.3",
      "pali": "Sapattikampi hi dukkhaṁ,"
    },
    {
      "id": "thig10.1:4.4",
      "pali": "Appekaccā sakiṁ vijātāyo."
    },
    {
      "id": "thig10.1:5.1",
      "pali": "Galake api kantanti,"
    },
    {
      "id": "thig10.1:5.2",
      "pali": "Sukhumāliniyo visāni khādanti;"
    },
    {
      "id": "thig10.1:5.3",
      "pali": "Janamārakamajjhagatā,"
    },
    {
      "id": "thig10.1:5.4",
      "pali": "Ubhopi byasanāni anubhonti”."
    },
    {
      "id": "thig10.1:6.1",
      "pali": "“Upavijaññā gacchantī,"
    },
    {
      "id": "thig10.1:6.2",
      "pali": "addasāhaṁ patiṁ mataṁ;"
    },
    {
      "id": "thig10.1:6.3",
      "pali": "Panthamhi vijāyitvāna,"
    },
    {
      "id": "thig10.1:6.4",
      "pali": "appattāva sakaṁ gharaṁ."
    },
    {
      "id": "thig10.1:7.1",
      "pali": "Dve puttā kālakatā,"
    },
    {
      "id": "thig10.1:7.2",
      "pali": "Patī ca panthe mato kapaṇikāya;"
    },
    {
      "id": "thig10.1:7.3",
      "pali": "Mātā pitā ca bhātā,"
    },
    {
      "id": "thig10.1:7.4",
      "pali": "Ḍayhanti ca ekacitakāyaṁ”."
    },
    {
      "id": "thig10.1:8.1",
      "pali": "“Khīṇakulīne kapaṇe,"
    },
    {
      "id": "thig10.1:8.2",
      "pali": "Anubhūtaṁ te dukhaṁ aparimāṇaṁ;"
    },
    {
      "id": "thig10.1:8.3",
      "pali": "Assū ca te pavattaṁ,"
    },
    {
      "id": "thig10.1:8.4",
      "pali": "Bahūni ca jātisahassāni."
    },
    {
      "id": "thig10.1:9.1",
      "pali": "Vasitā susānamajjhe,"
    },
    {
      "id": "thig10.1:9.2",
      "pali": "Athopi khāditāni puttamaṁsāni;"
    },
    {
      "id": "thig10.1:9.3",
      "pali": "Hatakulikā sabbagarahitā,"
    },
    {
      "id": "thig10.1:9.4",
      "pali": "Matapatikā amatamadhigacchiṁ."
    },
    {
      "id": "thig10.1:10.1",
      "pali": "Bhāvito me maggo,"
    },
    {
      "id": "thig10.1:10.2",
      "pali": "Ariyo aṭṭhaṅgiko amatagāmī;"
    },
    {
      "id": "thig10.1:10.3",
      "pali": "Nibbānaṁ sacchikataṁ,"
    },
    {
      "id": "thig10.1:10.4",
      "pali": "Dhammādāsaṁ avekkhiṁhaṁ."
    },
    {
      "id": "thig10.1:11.1",
      "pali": "Ahamamhi kantasallā,"
    },
    {
      "id": "thig10.1:11.2",
      "pali": "Ohitabhārā katañhi karaṇīyaṁ;"
    },
    {
      "id": "thig10.1:11.3",
      "pali": "Kisā gotamī therī,"
    },
    {
      "id": "thig10.1:11.4",
      "pali": "Vimuttacittā imaṁ bhaṇī”ti."
    },
    {
      "id": "thig10.1:12.1",
      "pali": "… Kisā gotamī therī …."
    },
    {
      "id": "thig10.1:13.1",
      "pali": "Ekādasakanipāto niṭṭhito."
    }
  ]
}
