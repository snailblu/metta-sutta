{
  "uid": "thag1.71",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.71:1.1",
      "pali": "“Susukhumanipuṇatthadassinā,"
    },
    {
      "id": "thag1.71:1.2",
      "pali": "Matikusalena nivātavuttinā;"
    },
    {
      "id": "thag1.71:1.3",
      "pali": "Saṁsevitavuddhasīlinā,"
    },
    {
      "id": "thag1.71:1.4",
      "pali": "Nibbānaṁ na hi tena dullabhan”ti."
    },
    {
      "id": "thag1.71:1.5",
      "pali": "… Vacchapālo thero …."
    }
  ]
}
