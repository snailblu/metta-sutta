{
  "uid": "bv19",
  "title": "19. Tissabuddhavaṁsa",
  "nikaya": "kn",
  "segments": [
    {
      "id": "bv19:1.1",
      "pali": "“Siddhatthassa aparena,"
    },
    {
      "id": "bv19:1.2",
      "pali": "Asamo appaṭipuggalo;"
    },
    {
      "id": "bv19:1.3",
      "pali": "Anantatejo amitayaso,"
    },
    {
      "id": "bv19:1.4",
      "pali": "Tisso lokagganāyako."
    },
    {
      "id": "bv19:2.1",
      "pali": "Tamandhakāraṁ vidhamitvā,"
    },
    {
      "id": "bv19:2.2",
      "pali": "obhāsetvā sadevakaṁ;"
    },
    {
      "id": "bv19:2.3",
      "pali": "Anukampako mahāvīro,"
    },
    {
      "id": "bv19:2.4",
      "pali": "loke uppajji cakkhumā."
    },
    {
      "id": "bv19:3.1",
      "pali": "Tassāpi atulā iddhi,"
    },
    {
      "id": "bv19:3.2",
      "pali": "atulaṁ sīlaṁ samādhi ca;"
    },
    {
      "id": "bv19:3.3",
      "pali": "Sabbattha pāramiṁ gantvā,"
    },
    {
      "id": "bv19:3.4",
      "pali": "dhammacakkaṁ pavattayi."
    },
    {
      "id": "bv19:4.1",
      "pali": "So buddho dasasahassimhi,"
    },
    {
      "id": "bv19:4.2",
      "pali": "Viññāpesi giraṁ suciṁ;"
    },
    {
      "id": "bv19:4.3",
      "pali": "Koṭisatāni abhisamiṁsu,"
    },
    {
      "id": "bv19:4.4",
      "pali": "Paṭhame dhammadesane."
    },
    {
      "id": "bv19:5.1",
      "pali": "Dutiyo navutikoṭīnaṁ,"
    },
    {
      "id": "bv19:5.2",
      "pali": "tatiyo saṭṭhikoṭiyo;"
    },
    {
      "id": "bv19:5.3",
      "pali": "Bandhanāto pamocesi,"
    },
    {
      "id": "bv19:5.4",
      "pali": "satte naramarū tadā."
    },
    {
      "id": "bv19:6.1",
      "pali": "Sannipātā tayo āsuṁ,"
    },
    {
      "id": "bv19:6.2",
      "pali": "tisse lokagganāyake;"
    },
    {
      "id": "bv19:6.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv19:6.4",
      "pali": "santacittāna tādinaṁ."
    },
    {
      "id": "bv19:7.1",
      "pali": "Khīṇāsavasatasahassānaṁ,"
    },
    {
      "id": "bv19:7.2",
      "pali": "Paṭhamo āsi samāgamo;"
    },
    {
      "id": "bv19:7.3",
      "pali": "Navutisatasahassānaṁ,"
    },
    {
      "id": "bv19:7.4",
      "pali": "Dutiyo āsi samāgamo."
    },
    {
      "id": "bv19:8.1",
      "pali": "Asītisatasahassānaṁ,"
    },
    {
      "id": "bv19:8.2",
      "pali": "tatiyo āsi samāgamo;"
    },
    {
      "id": "bv19:8.3",
      "pali": "Khīṇāsavānaṁ vimalānaṁ,"
    },
    {
      "id": "bv19:8.4",
      "pali": "pupphitānaṁ vimuttiyā."
    },
    {
      "id": "bv19:9.1",
      "pali": "Ahaṁ tena samayena,"
    },
    {
      "id": "bv19:9.2",
      "pali": "sujāto nāma khattiyo;"
    },
    {
      "id": "bv19:9.3",
      "pali": "Mahābhogaṁ chaḍḍayitvā,"
    },
    {
      "id": "bv19:9.4",
      "pali": "pabbajiṁ isipabbajaṁ."
    },
    {
      "id": "bv19:10.1",
      "pali": "Mayi pabbajite sante,"
    },
    {
      "id": "bv19:10.2",
      "pali": "uppajji lokanāyako;"
    },
    {
      "id": "bv19:10.3",
      "pali": "Buddhoti saddaṁ sutvāna,"
    },
    {
      "id": "bv19:10.4",
      "pali": "pīti me upapajjatha."
    },
    {
      "id": "bv19:11.1",
      "pali": "Dibbaṁ mandāravaṁ pupphaṁ,"
    },
    {
      "id": "bv19:11.2",
      "pali": "padumaṁ pārichattakaṁ;"
    },
    {
      "id": "bv19:11.3",
      "pali": "Ubho hatthehi paggayha,"
    },
    {
      "id": "bv19:11.4",
      "pali": "dhunamāno upāgamiṁ."
    },
    {
      "id": "bv19:12.1",
      "pali": "Catuvaṇṇaparivutaṁ,"
    },
    {
      "id": "bv19:12.2",
      "pali": "tissaṁ lokagganāyakaṁ;"
    },
    {
      "id": "bv19:12.3",
      "pali": "Tamahaṁ pupphaṁ gahetvā,"
    },
    {
      "id": "bv19:12.4",
      "pali": "matthake dhārayiṁ jinaṁ."
    },
    {
      "id": "bv19:13.1",
      "pali": "Sopi maṁ buddho byākāsi,"
    },
    {
      "id": "bv19:13.2",
      "pali": "janamajjhe nisīdiya;"
    },
    {
      "id": "bv19:13.3",
      "pali": "‘Dvenavute ito kappe,"
    },
    {
      "id": "bv19:13.4",
      "pali": "ayaṁ buddho bhavissati."
    },
    {
      "id": "bv19:14.1",
      "pali": "Padhānaṁ padahitvāna,"
    },
    {
      "id": "bv19:14.2",
      "pali": "…pe…"
    },
    {
      "id": "bv19:14.3",
      "pali": "hessāma sammukhā imaṁ’."
    },
    {
      "id": "bv19:15.1",
      "pali": "Tassāpi vacanaṁ sutvā,"
    },
    {
      "id": "bv19:15.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "bv19:15.3",
      "pali": "Uttariṁ vatamadhiṭṭhāsiṁ,"
    },
    {
      "id": "bv19:15.4",
      "pali": "dasapāramipūriyā."
    },
    {
      "id": "bv19:16.1",
      "pali": "Khemakaṁ nāma nagaraṁ,"
    },
    {
      "id": "bv19:16.2",
      "pali": "janasandho nāma khattiyo;"
    },
    {
      "id": "bv19:16.3",
      "pali": "Padumā nāma janikā,"
    },
    {
      "id": "bv19:16.4",
      "pali": "tissassa ca mahesino."
    },
    {
      "id": "bv19:17.1",
      "pali": "Sattavassasahassāni,"
    },
    {
      "id": "bv19:17.2",
      "pali": "Agāraṁ ajjha so vasi;"
    },
    {
      "id": "bv19:17.3",
      "pali": "Guhāsela nārisaya nisabhā,"
    },
    {
      "id": "bv19:17.4",
      "pali": "Tayo pāsādamuttamā."
    },
    {
      "id": "bv19:18.1",
      "pali": "Samatiṁsasahassāni,"
    },
    {
      "id": "bv19:18.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "bv19:18.3",
      "pali": "Subhaddānāmikā nārī,"
    },
    {
      "id": "bv19:18.4",
      "pali": "ānando nāma atrajo."
    },
    {
      "id": "bv19:19.1",
      "pali": "Nimitte caturo disvā,"
    },
    {
      "id": "bv19:19.2",
      "pali": "assayānena nikkhami;"
    },
    {
      "id": "bv19:19.3",
      "pali": "Anūnaaṭṭhamāsāni,"
    },
    {
      "id": "bv19:19.4",
      "pali": "padhānaṁ padahī jino."
    },
    {
      "id": "bv19:20.1",
      "pali": "Brahmunā yācito santo,"
    },
    {
      "id": "bv19:20.2",
      "pali": "tisso lokagganāyako;"
    },
    {
      "id": "bv19:20.3",
      "pali": "Vatti cakkaṁ mahāvīro,"
    },
    {
      "id": "bv19:20.4",
      "pali": "yasavatiyamuttame."
    },
    {
      "id": "bv19:21.1",
      "pali": "Brahmadevo udayo ca,"
    },
    {
      "id": "bv19:21.2",
      "pali": "ahesuṁ aggasāvakā;"
    },
    {
      "id": "bv19:21.3",
      "pali": "Samaṅgo nāmupaṭṭhāko,"
    },
    {
      "id": "bv19:21.4",
      "pali": "tissassa ca mahesino."
    },
    {
      "id": "bv19:22.1",
      "pali": "Phussā ceva sudattā ca,"
    },
    {
      "id": "bv19:22.2",
      "pali": "ahesuṁ aggasāvikā;"
    },
    {
      "id": "bv19:22.3",
      "pali": "Bodhi tassa bhagavato,"
    },
    {
      "id": "bv19:22.4",
      "pali": "asanoti pavuccati."
    },
    {
      "id": "bv19:23.1",
      "pali": "Sambalo ca sirimā ceva,"
    },
    {
      "id": "bv19:23.2",
      "pali": "ahesuṁ aggupaṭṭhakā;"
    },
    {
      "id": "bv19:23.3",
      "pali": "Kisāgotamī upasenā,"
    },
    {
      "id": "bv19:23.4",
      "pali": "ahesuṁ aggupaṭṭhikā."
    },
    {
      "id": "bv19:24.1",
      "pali": "So buddho saṭṭhiratano,"
    },
    {
      "id": "bv19:24.2",
      "pali": "ahu uccattane jino;"
    },
    {
      "id": "bv19:24.3",
      "pali": "Anūpamo asadiso,"
    },
    {
      "id": "bv19:24.4",
      "pali": "himavā viya dissati."
    },
    {
      "id": "bv19:25.1",
      "pali": "Tassāpi atulatejassa,"
    },
    {
      "id": "bv19:25.2",
      "pali": "āyu āsi anuttaro;"
    },
    {
      "id": "bv19:25.3",
      "pali": "Vassasatasahassāni,"
    },
    {
      "id": "bv19:25.4",
      "pali": "loke aṭṭhāsi cakkhumā."
    },
    {
      "id": "bv19:26.1",
      "pali": "Uttamaṁ pavaraṁ seṭṭhaṁ,"
    },
    {
      "id": "bv19:26.2",
      "pali": "anubhotvā mahāyasaṁ;"
    },
    {
      "id": "bv19:26.3",
      "pali": "Jalitvā aggikkhandhova,"
    },
    {
      "id": "bv19:26.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv19:27.1",
      "pali": "Valāhakova anilena,"
    },
    {
      "id": "bv19:27.2",
      "pali": "sūriyena viya ussavo;"
    },
    {
      "id": "bv19:27.3",
      "pali": "Andhakārova padīpena,"
    },
    {
      "id": "bv19:27.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "bv19:28.1",
      "pali": "Tisso jinavaro buddho,"
    },
    {
      "id": "bv19:28.2",
      "pali": "Nandārāmamhi nibbuto;"
    },
    {
      "id": "bv19:28.3",
      "pali": "Tatthevassa jinathūpo,"
    },
    {
      "id": "bv19:28.4",
      "pali": "Tīṇiyojanamuggato”ti."
    },
    {
      "id": "bv19:29.1",
      "pali": "Tissassa bhagavato vaṁso sattarasamo."
    }
  ]
}
