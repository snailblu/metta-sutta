{
  "uid": "ja30",
  "title": "Kuruṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja30:1.1",
      "pali": "“Mā munikassa pihayi,"
    },
    {
      "id": "ja30:1.2",
      "pali": "āturannāni bhuñjati;"
    },
    {
      "id": "ja30:1.3",
      "pali": "Appossukko bhusaṁ khāda,"
    },
    {
      "id": "ja30:1.4",
      "pali": "etaṁ dīghāyulakkhaṇan”ti."
    },
    {
      "id": "ja30:2.1",
      "pali": "Munikajātakaṁ dasamaṁ."
    },
    {
      "id": "ja30:2.2",
      "pali": "Kuruṅgavaggo tatiyo."
    },
    {
      "id": "ja30:3.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja30:4.1",
      "pali": "Kuruṅgassa kukkuragojavaro,"
    },
    {
      "id": "ja30:4.2",
      "pali": "Puna vāḷavassasirivhayano;"
    },
    {
      "id": "ja30:4.3",
      "pali": "Mahiḷāmukhanāmanuññavaro,"
    },
    {
      "id": "ja30:4.4",
      "pali": "Vahate dhura munikena dasāti."
    }
  ]
}
