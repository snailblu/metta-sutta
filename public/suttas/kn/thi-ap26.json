{
  "uid": "thi-ap26",
  "title": "Soṇātherīapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap26:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "thi-ap26:1.2",
      "pali": "sabbadhammāna pāragū;"
    },
    {
      "id": "thi-ap26:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "thi-ap26:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "thi-ap26:2.1",
      "pali": "Tadā seṭṭhikule jātā,"
    },
    {
      "id": "thi-ap26:2.2",
      "pali": "sukhitā pūjitā piyā;"
    },
    {
      "id": "thi-ap26:2.3",
      "pali": "Upetvā taṁ munivaraṁ,"
    },
    {
      "id": "thi-ap26:2.4",
      "pali": "assosiṁ madhuraṁ vacaṁ."
    },
    {
      "id": "thi-ap26:3.1",
      "pali": "Āraddhavīriyānaggaṁ,"
    },
    {
      "id": "thi-ap26:3.2",
      "pali": "vaṇṇesi bhikkhuniṁ jino;"
    },
    {
      "id": "thi-ap26:3.3",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap26:3.4",
      "pali": "kāraṁ katvāna satthuno."
    },
    {
      "id": "thi-ap26:4.1",
      "pali": "Abhivādiya sambuddhaṁ,"
    },
    {
      "id": "thi-ap26:4.2",
      "pali": "ṭhānaṁ taṁ patthayiṁ tadā;"
    },
    {
      "id": "thi-ap26:4.3",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "thi-ap26:4.4",
      "pali": "‘sijjhataṁ paṇidhī tava."
    },
    {
      "id": "thi-ap26:5.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "thi-ap26:5.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "thi-ap26:5.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "thi-ap26:5.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "thi-ap26:6.1",
      "pali": "Tassa dhammesu dāyādā,"
    },
    {
      "id": "thi-ap26:6.2",
      "pali": "orasā dhammanimmitā;"
    },
    {
      "id": "thi-ap26:6.3",
      "pali": "Soṇāti nāma nāmena,"
    },
    {
      "id": "thi-ap26:6.4",
      "pali": "hessati satthu sāvikā’."
    },
    {
      "id": "thi-ap26:7.1",
      "pali": "Taṁ sutvā muditā hutvā,"
    },
    {
      "id": "thi-ap26:7.2",
      "pali": "yāvajīvaṁ tadā jinaṁ;"
    },
    {
      "id": "thi-ap26:7.3",
      "pali": "Mettacittā paricariṁ,"
    },
    {
      "id": "thi-ap26:7.4",
      "pali": "paccayehi vināyakaṁ."
    },
    {
      "id": "thi-ap26:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "thi-ap26:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "thi-ap26:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "thi-ap26:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "thi-ap26:9.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "thi-ap26:9.2",
      "pali": "jātā seṭṭhikule ahaṁ;"
    },
    {
      "id": "thi-ap26:9.3",
      "pali": "Sāvatthiyaṁ puravare,"
    },
    {
      "id": "thi-ap26:9.4",
      "pali": "iddhe phīte mahaddhane."
    },
    {
      "id": "thi-ap26:10.1",
      "pali": "Yadā ca yobbanappattā,"
    },
    {
      "id": "thi-ap26:10.2",
      "pali": "gantvā patikulaṁ ahaṁ;"
    },
    {
      "id": "thi-ap26:10.3",
      "pali": "Dasa puttāni ajaniṁ,"
    },
    {
      "id": "thi-ap26:10.4",
      "pali": "surūpāni visesato."
    },
    {
      "id": "thi-ap26:11.1",
      "pali": "Sukhedhitā ca te sabbe,"
    },
    {
      "id": "thi-ap26:11.2",
      "pali": "jananettamanoharā;"
    },
    {
      "id": "thi-ap26:11.3",
      "pali": "Amittānampi rucitā,"
    },
    {
      "id": "thi-ap26:11.4",
      "pali": "mama pageva te piyā."
    },
    {
      "id": "thi-ap26:12.1",
      "pali": "Tato mayhaṁ akāmāya,"
    },
    {
      "id": "thi-ap26:12.2",
      "pali": "dasaputtapurakkhato;"
    },
    {
      "id": "thi-ap26:12.3",
      "pali": "Pabbajittha sa me bhattā,"
    },
    {
      "id": "thi-ap26:12.4",
      "pali": "devadevassa sāsane."
    },
    {
      "id": "thi-ap26:13.1",
      "pali": "Tadekikā vicintesiṁ,"
    },
    {
      "id": "thi-ap26:13.2",
      "pali": "‘jīvitenālamatthu me;"
    },
    {
      "id": "thi-ap26:13.3",
      "pali": "Cattāya patiputtehi,"
    },
    {
      "id": "thi-ap26:13.4",
      "pali": "vuḍḍhāya ca varākiyā."
    },
    {
      "id": "thi-ap26:14.1",
      "pali": "Ahampi tattha gacchissaṁ,"
    },
    {
      "id": "thi-ap26:14.2",
      "pali": "sampatto yattha me pati’;"
    },
    {
      "id": "thi-ap26:14.3",
      "pali": "Evāhaṁ cintayitvāna,"
    },
    {
      "id": "thi-ap26:14.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "thi-ap26:15.1",
      "pali": "Tato ca maṁ bhikkhuniyo,"
    },
    {
      "id": "thi-ap26:15.2",
      "pali": "ekaṁ bhikkhunupassaye;"
    },
    {
      "id": "thi-ap26:15.3",
      "pali": "Vihāya gacchumovādaṁ,"
    },
    {
      "id": "thi-ap26:15.4",
      "pali": "‘tāpehi udakaṁ’ iti."
    },
    {
      "id": "thi-ap26:16.1",
      "pali": "Tadā udakamāhitvā,"
    },
    {
      "id": "thi-ap26:16.2",
      "pali": "okiritvāna kumbhiyā;"
    },
    {
      "id": "thi-ap26:16.3",
      "pali": "Culle ṭhapetvā āsīnā,"
    },
    {
      "id": "thi-ap26:16.4",
      "pali": "tato cittaṁ samādahiṁ."
    },
    {
      "id": "thi-ap26:17.1",
      "pali": "Khandhe aniccato disvā,"
    },
    {
      "id": "thi-ap26:17.2",
      "pali": "dukkhato ca anattato;"
    },
    {
      "id": "thi-ap26:17.3",
      "pali": "Khepetvā āsave sabbe,"
    },
    {
      "id": "thi-ap26:17.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "thi-ap26:18.1",
      "pali": "Tadāgantvā bhikkhuniyo,"
    },
    {
      "id": "thi-ap26:18.2",
      "pali": "uṇhodakamapucchisuṁ;"
    },
    {
      "id": "thi-ap26:18.3",
      "pali": "Tejodhātumadhiṭṭhāya,"
    },
    {
      "id": "thi-ap26:18.4",
      "pali": "khippaṁ santāpayiṁ jalaṁ."
    },
    {
      "id": "thi-ap26:19.1",
      "pali": "Vimhitā tā jinavaraṁ,"
    },
    {
      "id": "thi-ap26:19.2",
      "pali": "etamatthamasāvayuṁ;"
    },
    {
      "id": "thi-ap26:19.3",
      "pali": "Taṁ sutvā mudito nātho,"
    },
    {
      "id": "thi-ap26:19.4",
      "pali": "imaṁ gāthaṁ abhāsatha."
    },
    {
      "id": "thi-ap26:20.1",
      "pali": "‘Yo ca vassasataṁ jīve,"
    },
    {
      "id": "thi-ap26:20.2",
      "pali": "kusīto hīnavīriyo;"
    },
    {
      "id": "thi-ap26:20.3",
      "pali": "Ekāhaṁ jīvitaṁ seyyo,"
    },
    {
      "id": "thi-ap26:20.4",
      "pali": "vīriyamārabhato daḷhaṁ’."
    },
    {
      "id": "thi-ap26:21.1",
      "pali": "Ārādhito mahāvīro,"
    },
    {
      "id": "thi-ap26:21.2",
      "pali": "mayā suppaṭipattiyā;"
    },
    {
      "id": "thi-ap26:21.3",
      "pali": "Āraddhavīriyānaggaṁ,"
    },
    {
      "id": "thi-ap26:21.4",
      "pali": "mamāha sa mahāmuni."
    },
    {
      "id": "thi-ap26:22.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "thi-ap26:22.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap26:22.3",
      "pali": "viharāmi anāsavā."
    },
    {
      "id": "thi-ap26:23.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "thi-ap26:23.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap26:23.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap26:24.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap26:24.2",
      "pali": "…pe…"
    },
    {
      "id": "thi-ap26:24.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap26:25.1",
      "pali": "Itthaṁ sudaṁ soṇā bhikkhunī imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap26:26.1",
      "pali": "Soṇātheriyāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
