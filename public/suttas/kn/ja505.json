{
  "uid": "ja505",
  "title": "Mātaṅgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja505:1.1",
      "pali": "“Ko taṁ hiṁsati heṭheti,"
    },
    {
      "id": "ja505:1.2",
      "pali": "Kiṁ dummano socasi appatīto;"
    },
    {
      "id": "ja505:1.3",
      "pali": "Kassajja mātāpitaro rudantu,"
    },
    {
      "id": "ja505:1.4",
      "pali": "Kvajja setu nihato pathabyā”."
    },
    {
      "id": "ja505:2.1",
      "pali": "“Tuṭṭhosmi deva tava dassanena,"
    },
    {
      "id": "ja505:2.2",
      "pali": "Cirassaṁ passāmi taṁ bhūmipāla;"
    },
    {
      "id": "ja505:2.3",
      "pali": "Ahiṁsako reṇumanuppavissa,"
    },
    {
      "id": "ja505:2.4",
      "pali": "Puttena te heṭhayitosmi deva”."
    },
    {
      "id": "ja505:3.1",
      "pali": "“Āyantu dovārikā khaggabandhā,"
    },
    {
      "id": "ja505:3.2",
      "pali": "Kāsāviyā yantu antepurantaṁ;"
    },
    {
      "id": "ja505:3.3",
      "pali": "Hantvāna taṁ somanassaṁ kumāraṁ,"
    },
    {
      "id": "ja505:3.4",
      "pali": "Chetvāna sīsaṁ varamāharantu”."
    },
    {
      "id": "ja505:4.1",
      "pali": "“Pesitā rājino dūtā,"
    },
    {
      "id": "ja505:4.2",
      "pali": "kumāraṁ etadabravuṁ;"
    },
    {
      "id": "ja505:4.3",
      "pali": "Issarena vitiṇṇosi,"
    },
    {
      "id": "ja505:4.4",
      "pali": "vadhaṁ pattosi khattiya”."
    },
    {
      "id": "ja505:5.1",
      "pali": "“Sa rājaputto paridevayanto,"
    },
    {
      "id": "ja505:5.2",
      "pali": "Dasaṅguliṁ añjaliṁ paggahetvā;"
    },
    {
      "id": "ja505:5.3",
      "pali": "Ahampi icchāmi janinda daṭṭhuṁ,"
    },
    {
      "id": "ja505:5.4",
      "pali": "Jīvaṁ maṁ netvā paṭidassayetha”."
    },
    {
      "id": "ja505:6.1",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "ja505:6.2",
      "pali": "rañño puttaṁ adassayuṁ;"
    },
    {
      "id": "ja505:6.3",
      "pali": "Putto ca pitaraṁ disvā,"
    },
    {
      "id": "ja505:6.4",
      "pali": "dūratovajjhabhāsatha."
    },
    {
      "id": "ja505:7.1",
      "pali": "“Āgacchuṁ dovārikā khaggabandhā,"
    },
    {
      "id": "ja505:7.2",
      "pali": "Kāsāviyā hantu mamaṁ janinda;"
    },
    {
      "id": "ja505:7.3",
      "pali": "Akkhāhi me pucchito etamatthaṁ,"
    },
    {
      "id": "ja505:7.4",
      "pali": "Aparādho ko nidha mamajja atthi”."
    },
    {
      "id": "ja505:8.1",
      "pali": "“Sāyañca pāto udakaṁ sajāti,"
    },
    {
      "id": "ja505:8.2",
      "pali": "Aggiṁ sadā pāricaratappamatto;"
    },
    {
      "id": "ja505:8.3",
      "pali": "Taṁ tādisaṁ saṁyataṁ brahmacāriṁ,"
    },
    {
      "id": "ja505:8.4",
      "pali": "Kasmā tuvaṁ brūsi gahappatīti”."
    },
    {
      "id": "ja505:9.1",
      "pali": "“Tālā ca mūlā ca phalā ca deva,"
    },
    {
      "id": "ja505:9.2",
      "pali": "Pariggahā vividhā santimassa;"
    },
    {
      "id": "ja505:9.3",
      "pali": "Te rakkhati gopayatappamatto,"
    },
    {
      "id": "ja505:9.4",
      "pali": "Tasmā ahaṁ brūmi gahappatīti”."
    },
    {
      "id": "ja505:10.1",
      "pali": "“Saccaṁ kho etaṁ vadasi kumāra,"
    },
    {
      "id": "ja505:10.2",
      "pali": "Pariggahā vividhā santimassa;"
    },
    {
      "id": "ja505:10.3",
      "pali": "Te rakkhati gopayatappamatto,"
    },
    {
      "id": "ja505:10.4",
      "pali": "Sa brāhmaṇo gahapati tena hoti”."
    },
    {
      "id": "ja505:11.1",
      "pali": "“Suṇantu mayhaṁ parisā samāgatā,"
    },
    {
      "id": "ja505:11.2",
      "pali": "Sanegamā jānapadā ca sabbe;"
    },
    {
      "id": "ja505:11.3",
      "pali": "Bālāyaṁ bālassa vaco nisamma,"
    },
    {
      "id": "ja505:11.4",
      "pali": "Ahetunā ghātayate maṁ janindo."
    },
    {
      "id": "ja505:12.1",
      "pali": "Daḷhasmi mūle visaṭe virūḷhe,"
    },
    {
      "id": "ja505:12.2",
      "pali": "Dunnikkayo veḷu pasākhajāto;"
    },
    {
      "id": "ja505:12.3",
      "pali": "Vandāmi pādāni tava janinda,"
    },
    {
      "id": "ja505:12.4",
      "pali": "Anujāna maṁ pabbajissāmi deva”."
    },
    {
      "id": "ja505:13.1",
      "pali": "“Bhuñjassu bhoge vipule kumāra,"
    },
    {
      "id": "ja505:13.2",
      "pali": "Sabbañca te issariyaṁ dadāmi;"
    },
    {
      "id": "ja505:13.3",
      "pali": "Ajjeva tvaṁ kurūnaṁ hohi rājā,"
    },
    {
      "id": "ja505:13.4",
      "pali": "Mā pabbajī pabbajjā hi dukkhā”."
    },
    {
      "id": "ja505:14.1",
      "pali": "“Kinnūdha deva tavamatthi bhogā,"
    },
    {
      "id": "ja505:14.2",
      "pali": "Pubbevahaṁ devaloke ramissaṁ;"
    },
    {
      "id": "ja505:14.3",
      "pali": "Rūpehi saddehi atho rasehi,"
    },
    {
      "id": "ja505:14.4",
      "pali": "Gandhehi phassehi manoramehi."
    },
    {
      "id": "ja505:15.1",
      "pali": "Bhuttā ca me bhogā tidivasmiṁ deva,"
    },
    {
      "id": "ja505:15.2",
      "pali": "Parivārito accharānaṁ gaṇena;"
    },
    {
      "id": "ja505:15.3",
      "pali": "Tuvañca bālaṁ paraneyyaṁ viditvā,"
    },
    {
      "id": "ja505:15.4",
      "pali": "Na tādise rājakule vaseyyaṁ”."
    },
    {
      "id": "ja505:16.1",
      "pali": "“Sacāhaṁ bālo paraneyyo asmi,"
    },
    {
      "id": "ja505:16.2",
      "pali": "Ekāparādhaṁ khama putta mayhaṁ;"
    },
    {
      "id": "ja505:16.3",
      "pali": "Punapi ce edisakaṁ bhaveyya,"
    },
    {
      "id": "ja505:16.4",
      "pali": "Yathāmatiṁ somanassa karohi”."
    },
    {
      "id": "ja505:17.1",
      "pali": "“Anisamma kataṁ kammaṁ,"
    },
    {
      "id": "ja505:17.2",
      "pali": "anavatthāya cintitaṁ;"
    },
    {
      "id": "ja505:17.3",
      "pali": "Bhesajjasseva vebhaṅgo,"
    },
    {
      "id": "ja505:17.4",
      "pali": "vipāko hoti pāpako."
    },
    {
      "id": "ja505:18.1",
      "pali": "Nisamma ca kataṁ kammaṁ,"
    },
    {
      "id": "ja505:18.2",
      "pali": "sammāvatthāya cintitaṁ;"
    },
    {
      "id": "ja505:18.3",
      "pali": "Bhesajjasseva sampatti,"
    },
    {
      "id": "ja505:18.4",
      "pali": "vipāko hoti bhadrako."
    },
    {
      "id": "ja505:19.1",
      "pali": "Alaso gihī kāmabhogī na sādhu,"
    },
    {
      "id": "ja505:19.2",
      "pali": "Asaññato pabbajito na sādhu;"
    },
    {
      "id": "ja505:19.3",
      "pali": "Rājā na sādhu anisammakārī,"
    },
    {
      "id": "ja505:19.4",
      "pali": "Yo paṇḍito kodhano taṁ na sādhu."
    },
    {
      "id": "ja505:20.1",
      "pali": "Nisamma khattiyo kayirā,"
    },
    {
      "id": "ja505:20.2",
      "pali": "nānisamma disampati;"
    },
    {
      "id": "ja505:20.3",
      "pali": "Nisammakārino rāja,"
    },
    {
      "id": "ja505:20.4",
      "pali": "yaso kitti ca vaḍḍhati."
    },
    {
      "id": "ja505:21.1",
      "pali": "Nisamma daṇḍaṁ paṇayeyya issaro,"
    },
    {
      "id": "ja505:21.2",
      "pali": "Vegā kataṁ tappati bhūmipāla;"
    },
    {
      "id": "ja505:21.3",
      "pali": "Sammāpaṇīdhī ca narassa atthā,"
    },
    {
      "id": "ja505:21.4",
      "pali": "Anānutappā te bhavanti pacchā."
    },
    {
      "id": "ja505:22.1",
      "pali": "Anānutappāni hi ye karonti,"
    },
    {
      "id": "ja505:22.2",
      "pali": "Vibhajja kammāyatanāni loke;"
    },
    {
      "id": "ja505:22.3",
      "pali": "Viññuppasatthāni sukhudrayāni,"
    },
    {
      "id": "ja505:22.4",
      "pali": "Bhavanti buddhānumatāni tāni."
    },
    {
      "id": "ja505:23.1",
      "pali": "Āgacchuṁ dovārikā khaggabandhā,"
    },
    {
      "id": "ja505:23.2",
      "pali": "Kāsāviyā hantu mamaṁ janinda;"
    },
    {
      "id": "ja505:23.3",
      "pali": "Mātuñca aṅkasmimahaṁ nisinno,"
    },
    {
      "id": "ja505:23.4",
      "pali": "Ākaḍḍhito sahasā tehi deva."
    },
    {
      "id": "ja505:24.1",
      "pali": "Kaṭukañhi sambādhaṁ sukicchaṁ patto,"
    },
    {
      "id": "ja505:24.2",
      "pali": "Madhurampi yaṁ jīvitaṁ laddha rāja;"
    },
    {
      "id": "ja505:24.3",
      "pali": "Kicchenahaṁ ajja vadhā pamutto,"
    },
    {
      "id": "ja505:24.4",
      "pali": "Pabbajjamevābhimanohamasmi”."
    },
    {
      "id": "ja505:25.1",
      "pali": "“Putto tavāyaṁ taruṇo sudhamme,"
    },
    {
      "id": "ja505:25.2",
      "pali": "Anukampako somanasso kumāro;"
    },
    {
      "id": "ja505:25.3",
      "pali": "Taṁ yācamāno na labhāmi svajja,"
    },
    {
      "id": "ja505:25.4",
      "pali": "Arahasi naṁ yācitave tuvampi”."
    },
    {
      "id": "ja505:26.1",
      "pali": "“Ramassu bhikkhācariyāya putta,"
    },
    {
      "id": "ja505:26.2",
      "pali": "Nisamma dhammesu paribbajassu;"
    },
    {
      "id": "ja505:26.3",
      "pali": "Sabbesu bhūtesu nidhāya daṇḍaṁ,"
    },
    {
      "id": "ja505:26.4",
      "pali": "Anindito brahmamupehi ṭhānaṁ”."
    },
    {
      "id": "ja505:27.1",
      "pali": "“Acchera rūpaṁ vata yādisañca,"
    },
    {
      "id": "ja505:27.2",
      "pali": "Dukkhitaṁ maṁ dukkhāpayase sudhamme;"
    },
    {
      "id": "ja505:27.3",
      "pali": "Yācassu puttaṁ iti vuccamānā,"
    },
    {
      "id": "ja505:27.4",
      "pali": "Bhiyyova ussāhayase kumāraṁ”."
    },
    {
      "id": "ja505:28.1",
      "pali": "“Ye vippamuttā anavajjabhogino,"
    },
    {
      "id": "ja505:28.2",
      "pali": "Parinibbutā lokamimaṁ caranti;"
    },
    {
      "id": "ja505:28.3",
      "pali": "Tamariyamaggaṁ paṭipajjamānaṁ,"
    },
    {
      "id": "ja505:28.4",
      "pali": "Na ussahe vārayituṁ kumāraṁ”."
    },
    {
      "id": "ja505:29.1",
      "pali": "“Addhā have sevitabbā sapaññā,"
    },
    {
      "id": "ja505:29.2",
      "pali": "Bahussutā ye bahuṭhānacintino;"
    },
    {
      "id": "ja505:29.3",
      "pali": "Yesāyaṁ sutvāna subhāsitāni,"
    },
    {
      "id": "ja505:29.4",
      "pali": "Appossukkā vītasokā sudhammā”ti."
    },
    {
      "id": "ja505:30.1",
      "pali": "Somanassajātakaṁ navamaṁ."
    }
  ]
}
