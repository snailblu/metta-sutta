{
  "uid": "tha-ap375",
  "title": "3 Tīṇuppalamāliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap375:1.1",
      "pali": "“Candabhāgānadītīre,"
    },
    {
      "id": "tha-ap375:1.2",
      "pali": "ahosiṁ vānaro tadā;"
    },
    {
      "id": "tha-ap375:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap375:1.4",
      "pali": "nisinnaṁ pabbatantare."
    },
    {
      "id": "tha-ap375:2.1",
      "pali": "Obhāsentaṁ disā sabbā,"
    },
    {
      "id": "tha-ap375:2.2",
      "pali": "sālarājaṁva phullitaṁ;"
    },
    {
      "id": "tha-ap375:2.3",
      "pali": "Lakkhaṇabyañjanūpetaṁ,"
    },
    {
      "id": "tha-ap375:2.4",
      "pali": "disvānattamano ahaṁ."
    },
    {
      "id": "tha-ap375:3.1",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap375:3.2",
      "pali": "pītiyā haṭṭhamānaso;"
    },
    {
      "id": "tha-ap375:3.3",
      "pali": "Tīṇi uppalapupphāni,"
    },
    {
      "id": "tha-ap375:3.4",
      "pali": "matthake abhiropayiṁ."
    },
    {
      "id": "tha-ap375:4.1",
      "pali": "Pūjayitvāna pupphāni,"
    },
    {
      "id": "tha-ap375:4.2",
      "pali": "phussassāhaṁ mahesino;"
    },
    {
      "id": "tha-ap375:4.3",
      "pali": "Sagāravo bhavitvāna,"
    },
    {
      "id": "tha-ap375:4.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap375:5.1",
      "pali": "Gacchanto paṭikuṭiko,"
    },
    {
      "id": "tha-ap375:5.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "tha-ap375:5.3",
      "pali": "Selantare patitvāna,"
    },
    {
      "id": "tha-ap375:5.4",
      "pali": "pāpuṇiṁ jīvitakkhayaṁ."
    },
    {
      "id": "tha-ap375:6.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap375:6.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap375:6.3",
      "pali": "Jahitvā purimaṁ jātiṁ,"
    },
    {
      "id": "tha-ap375:6.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap375:7.1",
      "pali": "Satānaṁ tīṇikkhattuñca,"
    },
    {
      "id": "tha-ap375:7.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap375:7.3",
      "pali": "Satānaṁ pañcakkhattuñca,"
    },
    {
      "id": "tha-ap375:7.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap375:8.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap375:8.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap375:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap375:8.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap375:9.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap375:9.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap375:9.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap375:10.1",
      "pali": "Itthaṁ sudaṁ āyasmā tīṇuppalamāliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap375:11.1",
      "pali": "Tīṇuppalamāliyattherassāpadānaṁ tatiyaṁ."
    }
  ]
}
