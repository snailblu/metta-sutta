{
  "uid": "thag3.11",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag3.11:1.1",
      "pali": "“Saddhāya abhinikkhamma,"
    },
    {
      "id": "thag3.11:1.2",
      "pali": "navapabbajito navo;"
    },
    {
      "id": "thag3.11:1.3",
      "pali": "Mitte bhajeyya kalyāṇe,"
    },
    {
      "id": "thag3.11:1.4",
      "pali": "suddhājīve atandite."
    },
    {
      "id": "thag3.11:2.1",
      "pali": "Saddhāya abhinikkhamma,"
    },
    {
      "id": "thag3.11:2.2",
      "pali": "navapabbajito navo;"
    },
    {
      "id": "thag3.11:2.3",
      "pali": "Saṅghasmiṁ viharaṁ bhikkhu,"
    },
    {
      "id": "thag3.11:2.4",
      "pali": "sikkhetha vinayaṁ budho."
    },
    {
      "id": "thag3.11:3.1",
      "pali": "Saddhāya abhinikkhamma,"
    },
    {
      "id": "thag3.11:3.2",
      "pali": "navapabbajito navo;"
    },
    {
      "id": "thag3.11:3.3",
      "pali": "Kappākappesu kusalo,"
    },
    {
      "id": "thag3.11:3.4",
      "pali": "careyya apurakkhato”ti."
    },
    {
      "id": "thag3.11:3.5",
      "pali": "… Upālitthero …."
    }
  ]
}
