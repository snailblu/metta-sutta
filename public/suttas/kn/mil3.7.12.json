{
  "uid": "mil3.7.12",
  "title": "12. Samuddapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.7.12:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.7.12:1.2",
      "pali": "“bhante nāgasena, ‘samuddo samuddo’ti vuccati, kena kāraṇena udakaṁ ‘samuddo’ti vuccatī”ti?"
    },
    {
      "id": "mil3.7.12:1.3",
      "pali": "Thero āha—"
    },
    {
      "id": "mil3.7.12:1.4",
      "pali": "“yattakaṁ, mahārāja, udakaṁ, tattakaṁ loṇaṁ."
    },
    {
      "id": "mil3.7.12:1.5",
      "pali": "Yattakaṁ loṇaṁ, tattakaṁ udakaṁ."
    },
    {
      "id": "mil3.7.12:1.6",
      "pali": "Tasmā ‘samuddo’ti vuccatī”ti."
    },
    {
      "id": "mil3.7.12:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.7.12:3.1",
      "pali": "Samuddapañho dvādasamo."
    }
  ]
}
