{
  "uid": "ja360",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja360:1.1",
      "pali": "“Vāti gandho timirānaṁ,"
    },
    {
      "id": "ja360:1.2",
      "pali": "kusamuddo ca ghosavā;"
    },
    {
      "id": "ja360:1.3",
      "pali": "Dūre ito suyonandī,"
    },
    {
      "id": "ja360:1.4",
      "pali": "tamba kāmā tudanti maṁ”."
    },
    {
      "id": "ja360:2.1",
      "pali": "“Kathaṁ samuddamatari,"
    },
    {
      "id": "ja360:2.2",
      "pali": "Kathaṁ addakkhi sedumaṁ;"
    },
    {
      "id": "ja360:2.3",
      "pali": "Kathaṁ tassā ca tuyhañca,"
    },
    {
      "id": "ja360:2.4",
      "pali": "Ahu saggasamāgamo”."
    },
    {
      "id": "ja360:3.1",
      "pali": "“Kurukacchā payātānaṁ,"
    },
    {
      "id": "ja360:3.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja360:3.3",
      "pali": "Makarehi abhidā nāvā,"
    },
    {
      "id": "ja360:3.4",
      "pali": "phalakenāhamaplaviṁ."
    },
    {
      "id": "ja360:4.1",
      "pali": "Sā maṁ saṇhena mudunā,"
    },
    {
      "id": "ja360:4.2",
      "pali": "niccaṁ candanagandhinī;"
    },
    {
      "id": "ja360:4.3",
      "pali": "Aṅgena uddharī bhaddā,"
    },
    {
      "id": "ja360:4.4",
      "pali": "mātā puttaṁva orasaṁ."
    },
    {
      "id": "ja360:5.1",
      "pali": "Sā maṁ annena pānena,"
    },
    {
      "id": "ja360:5.2",
      "pali": "vatthena sayanena ca;"
    },
    {
      "id": "ja360:5.3",
      "pali": "Attanāpi ca mandakkhī,"
    },
    {
      "id": "ja360:5.4",
      "pali": "evaṁ tamba vijānahī”ti."
    },
    {
      "id": "ja360:6.1",
      "pali": "Suyonandījātakaṁ dasamaṁ."
    },
    {
      "id": "ja360:6.2",
      "pali": "Maṇikuṇḍalavaggo paṭhamo."
    },
    {
      "id": "ja360:7.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja360:8.1",
      "pali": "Atha jinavaro haritaṁ tiṇako,"
    },
    {
      "id": "ja360:8.2",
      "pali": "Atha bhinnaplavo uragova ghaṭo;"
    },
    {
      "id": "ja360:8.3",
      "pali": "Dariyā puna kuñjara bhūnahatā,"
    },
    {
      "id": "ja360:8.4",
      "pali": "Migamuttamasaggavarena dasāti."
    }
  ]
}
