{
  "uid": "ja537",
  "title": "Cūḷahaṁsavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja537:1.1",
      "pali": "“Kasmā tuvaṁ rasaka edisāni,"
    },
    {
      "id": "ja537:1.2",
      "pali": "Karosi kammāni sudāruṇāni;"
    },
    {
      "id": "ja537:1.3",
      "pali": "Hanāsi itthī purise ca mūḷho,"
    },
    {
      "id": "ja537:1.4",
      "pali": "Maṁsassa hetu adu dhanassa kāraṇā”."
    },
    {
      "id": "ja537:2.1",
      "pali": "“Na attahetū na dhanassa kāraṇā,"
    },
    {
      "id": "ja537:2.2",
      "pali": "Na puttadārassa sahāyañātinaṁ;"
    },
    {
      "id": "ja537:2.3",
      "pali": "Bhattā ca me bhagavā bhūmipālo,"
    },
    {
      "id": "ja537:2.4",
      "pali": "So khādati maṁsaṁ bhadantedisaṁ”."
    },
    {
      "id": "ja537:3.1",
      "pali": "“Sace tuvaṁ bhatturatthe payutto,"
    },
    {
      "id": "ja537:3.2",
      "pali": "Karosi kammāni sudāruṇāni;"
    },
    {
      "id": "ja537:3.3",
      "pali": "Pātova antepuraṁ pāpuṇitvā,"
    },
    {
      "id": "ja537:3.4",
      "pali": "Lapeyyāsi me rājino sammukhe taṁ”."
    },
    {
      "id": "ja537:4.1",
      "pali": "“Tathā karissāmi ahaṁ bhadante,"
    },
    {
      "id": "ja537:4.2",
      "pali": "Yathā tuvaṁ bhāsasi kāḷahatthi;"
    },
    {
      "id": "ja537:4.3",
      "pali": "Pātova antepuraṁ pāpuṇitvā,"
    },
    {
      "id": "ja537:4.4",
      "pali": "Vakkhāmi te rājino sammukhe taṁ”."
    },
    {
      "id": "ja537:5.1",
      "pali": "Tato ratyā vivasāne,"
    },
    {
      "id": "ja537:5.2",
      "pali": "sūriyuggamanaṁ pati;"
    },
    {
      "id": "ja537:5.3",
      "pali": "Kāḷo rasakamādāya,"
    },
    {
      "id": "ja537:5.4",
      "pali": "rājānaṁ upasaṅkami;"
    },
    {
      "id": "ja537:5.5",
      "pali": "Upasaṅkamma rājānaṁ,"
    },
    {
      "id": "ja537:5.6",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "ja537:6.1",
      "pali": "“Saccaṁ kira mahārāja,"
    },
    {
      "id": "ja537:6.2",
      "pali": "rasako pesito tayā;"
    },
    {
      "id": "ja537:6.3",
      "pali": "Hanati itthipurise,"
    },
    {
      "id": "ja537:6.4",
      "pali": "tuvaṁ maṁsāni khādasi”."
    },
    {
      "id": "ja537:7.1",
      "pali": "“Evameva tathā kāḷa,"
    },
    {
      "id": "ja537:7.2",
      "pali": "rasako pesito mayā;"
    },
    {
      "id": "ja537:7.3",
      "pali": "Mama atthaṁ karontassa,"
    },
    {
      "id": "ja537:7.4",
      "pali": "kimetaṁ paribhāsasi”."
    },
    {
      "id": "ja537:8.1",
      "pali": "“Ānando sabbamacchānaṁ,"
    },
    {
      "id": "ja537:8.2",
      "pali": "khāditvā rasagiddhimā;"
    },
    {
      "id": "ja537:8.3",
      "pali": "Parikkhīṇāya parisāya,"
    },
    {
      "id": "ja537:8.4",
      "pali": "attānaṁ khādiyā mato."
    },
    {
      "id": "ja537:9.1",
      "pali": "Evaṁ pamatto rasagārave ratto,"
    },
    {
      "id": "ja537:9.2",
      "pali": "Bālo yadī āyati nāvabujjhati;"
    },
    {
      "id": "ja537:9.3",
      "pali": "Vidhamma putte caji ñātake ca,"
    },
    {
      "id": "ja537:9.4",
      "pali": "Parivattiya attānaññeva khādati."
    },
    {
      "id": "ja537:10.1",
      "pali": "Idaṁ te sutvāna vigetu chando,"
    },
    {
      "id": "ja537:10.2",
      "pali": "Mā bhakkhayī rāja manussamaṁsaṁ;"
    },
    {
      "id": "ja537:10.3",
      "pali": "Mā tvaṁ imaṁ kevalaṁ vārijova,"
    },
    {
      "id": "ja537:10.4",
      "pali": "Dvipadādhipa suññamakāsi raṭṭhaṁ”."
    },
    {
      "id": "ja537:11.1",
      "pali": "“Sujāto nāma nāmena,"
    },
    {
      "id": "ja537:11.2",
      "pali": "oraso tassa atrajo;"
    },
    {
      "id": "ja537:11.3",
      "pali": "Jambupesimaladdhāna,"
    },
    {
      "id": "ja537:11.4",
      "pali": "mato so tassa saṅkhaye."
    },
    {
      "id": "ja537:12.1",
      "pali": "Evameva ahaṁ kāḷa,"
    },
    {
      "id": "ja537:12.2",
      "pali": "bhutvā bhakkhaṁ rasuttamaṁ;"
    },
    {
      "id": "ja537:12.3",
      "pali": "Aladdhā mānusaṁ maṁsaṁ,"
    },
    {
      "id": "ja537:12.4",
      "pali": "maññe hissāmi jīvitaṁ”."
    },
    {
      "id": "ja537:13.1",
      "pali": "“Māṇava abhirūposi,"
    },
    {
      "id": "ja537:13.2",
      "pali": "kule jātosi sotthiye;"
    },
    {
      "id": "ja537:13.3",
      "pali": "Na tvaṁ arahasi tāta,"
    },
    {
      "id": "ja537:13.4",
      "pali": "abhakkhaṁ bhakkhayetave”."
    },
    {
      "id": "ja537:14.1",
      "pali": "“Rasānaṁ aññataraṁ etaṁ,"
    },
    {
      "id": "ja537:14.2",
      "pali": "kasmā maṁ tvaṁ nivāraye;"
    },
    {
      "id": "ja537:14.3",
      "pali": "Sohaṁ tattha gamissāmi,"
    },
    {
      "id": "ja537:14.4",
      "pali": "yattha lacchāmi edisaṁ."
    },
    {
      "id": "ja537:15.1",
      "pali": "Sovāhaṁ nippatissāmi,"
    },
    {
      "id": "ja537:15.2",
      "pali": "na te vacchāmi santike;"
    },
    {
      "id": "ja537:15.3",
      "pali": "Yassa me dassanena tvaṁ,"
    },
    {
      "id": "ja537:15.4",
      "pali": "nābhinandasi brāhmaṇa”."
    },
    {
      "id": "ja537:16.1",
      "pali": "“Addhā aññepi dāyāde,"
    },
    {
      "id": "ja537:16.2",
      "pali": "putte lacchāma māṇava;"
    },
    {
      "id": "ja537:16.3",
      "pali": "Tvañca jamma vinassassu,"
    },
    {
      "id": "ja537:16.4",
      "pali": "yattha pattaṁ na taṁ suṇe”."
    },
    {
      "id": "ja537:17.1",
      "pali": "“Evameva tuvaṁ rāja,"
    },
    {
      "id": "ja537:17.2",
      "pali": "dvipadinda suṇohi me;"
    },
    {
      "id": "ja537:17.3",
      "pali": "Pabbājessanti taṁ raṭṭhā,"
    },
    {
      "id": "ja537:17.4",
      "pali": "soṇḍaṁ māṇavakaṁ yathā”."
    },
    {
      "id": "ja537:18.1",
      "pali": "“Sujāto nāma nāmena,"
    },
    {
      "id": "ja537:18.2",
      "pali": "bhāvitattāna sāvako;"
    },
    {
      "id": "ja537:18.3",
      "pali": "Accharaṁ kāmayantova,"
    },
    {
      "id": "ja537:18.4",
      "pali": "na so bhuñji na so pivi."
    },
    {
      "id": "ja537:19.1",
      "pali": "Kusaggenudakamādāya,"
    },
    {
      "id": "ja537:19.2",
      "pali": "samudde udakaṁ mine;"
    },
    {
      "id": "ja537:19.3",
      "pali": "Evaṁ mānusakā kāmā,"
    },
    {
      "id": "ja537:19.4",
      "pali": "dibbakāmāna santike."
    },
    {
      "id": "ja537:20.1",
      "pali": "Evameva ahaṁ kāḷa,"
    },
    {
      "id": "ja537:20.2",
      "pali": "bhutvā bhakkhaṁ rasuttamaṁ;"
    },
    {
      "id": "ja537:20.3",
      "pali": "Aladdhā mānusaṁ maṁsaṁ,"
    },
    {
      "id": "ja537:20.4",
      "pali": "maññe hissāmi jīvitaṁ”."
    },
    {
      "id": "ja537:21.1",
      "pali": "“Yathāpi te dhataraṭṭhā,"
    },
    {
      "id": "ja537:21.2",
      "pali": "haṁsā vehāyasaṅgamā;"
    },
    {
      "id": "ja537:21.3",
      "pali": "Abhuttaparibhogena,"
    },
    {
      "id": "ja537:21.4",
      "pali": "sabbe abbhatthataṁ gatā."
    },
    {
      "id": "ja537:22.1",
      "pali": "Evameva tuvaṁ rāja,"
    },
    {
      "id": "ja537:22.2",
      "pali": "dvipadinda suṇohi me;"
    },
    {
      "id": "ja537:22.3",
      "pali": "Abhakkhaṁ rāja bhakkhesi,"
    },
    {
      "id": "ja537:22.4",
      "pali": "tasmā pabbājayanti taṁ”."
    },
    {
      "id": "ja537:23.1",
      "pali": "“Tiṭṭhāhīti mayā vutto,"
    },
    {
      "id": "ja537:23.2",
      "pali": "So tvaṁ gacchasi pammukho;"
    },
    {
      "id": "ja537:23.3",
      "pali": "Aṭṭhito tvaṁ ṭhitomhīti,"
    },
    {
      "id": "ja537:23.4",
      "pali": "Lapasi brahmacārini;"
    },
    {
      "id": "ja537:23.5",
      "pali": "Idaṁ te samaṇāyuttaṁ,"
    },
    {
      "id": "ja537:23.6",
      "pali": "Asiñca me maññasi kaṅkapattaṁ”."
    },
    {
      "id": "ja537:24.1",
      "pali": "“Ṭhitohamasmī sadhammesu rāja,"
    },
    {
      "id": "ja537:24.2",
      "pali": "Na nāmagottaṁ parivattayāmi;"
    },
    {
      "id": "ja537:24.3",
      "pali": "Corañca loke aṭhitaṁ vadanti,"
    },
    {
      "id": "ja537:24.4",
      "pali": "Āpāyikaṁ nerayikaṁ ito cutaṁ."
    },
    {
      "id": "ja537:25.1",
      "pali": "Sace tvaṁ saddahasi rāja,"
    },
    {
      "id": "ja537:25.2",
      "pali": "sutaṁ gaṇhāhi khattiya;"
    },
    {
      "id": "ja537:25.3",
      "pali": "Tena yaññaṁ yajitvāna,"
    },
    {
      "id": "ja537:25.4",
      "pali": "evaṁ saggaṁ gamissasi”."
    },
    {
      "id": "ja537:26.1",
      "pali": "“Kismiṁ nu raṭṭhe tava jātibhūmi,"
    },
    {
      "id": "ja537:26.2",
      "pali": "Atha kena atthena idhānupatto;"
    },
    {
      "id": "ja537:26.3",
      "pali": "Akkhāhi me brāhmaṇa etamatthaṁ,"
    },
    {
      "id": "ja537:26.4",
      "pali": "Kimicchasī demi tayajja patthitaṁ”."
    },
    {
      "id": "ja537:27.1",
      "pali": "“Gāthā catasso dharaṇīmahissara,"
    },
    {
      "id": "ja537:27.2",
      "pali": "Sugambhiratthā varasāgarūpamā;"
    },
    {
      "id": "ja537:27.3",
      "pali": "Taveva atthāya idhāgatosmi,"
    },
    {
      "id": "ja537:27.4",
      "pali": "Suṇohi gāthā paramatthasaṁhitā”."
    },
    {
      "id": "ja537:28.1",
      "pali": "“Na ve rudanti matimanto sapaññā,"
    },
    {
      "id": "ja537:28.2",
      "pali": "Bahussutā ye bahuṭhānacintino;"
    },
    {
      "id": "ja537:28.3",
      "pali": "Dīpañhi etaṁ paramaṁ narānaṁ,"
    },
    {
      "id": "ja537:28.4",
      "pali": "Yaṁ paṇḍitā sokanudā bhavanti."
    },
    {
      "id": "ja537:29.1",
      "pali": "Attānaṁ ñātī udāhu puttadāraṁ,"
    },
    {
      "id": "ja537:29.2",
      "pali": "Dhaññaṁ dhanaṁ rajataṁ jātarūpaṁ;"
    },
    {
      "id": "ja537:29.3",
      "pali": "Kimeva tvaṁ sutasomānutappe,"
    },
    {
      "id": "ja537:29.4",
      "pali": "Korabyaseṭṭha vacanaṁ suṇoma tetaṁ”."
    },
    {
      "id": "ja537:30.1",
      "pali": "“Nevāhamattānamanutthunāmi,"
    },
    {
      "id": "ja537:30.2",
      "pali": "Na puttadāraṁ na dhanaṁ na raṭṭhaṁ;"
    },
    {
      "id": "ja537:30.3",
      "pali": "Satañca dhammo carito purāṇo,"
    },
    {
      "id": "ja537:30.4",
      "pali": "Taṁ saṅkaraṁ brāhmaṇassānutappe."
    },
    {
      "id": "ja537:31.1",
      "pali": "Kato mayā saṅkaro brāhmaṇena,"
    },
    {
      "id": "ja537:31.2",
      "pali": "Raṭṭhe sake issariye ṭhitena;"
    },
    {
      "id": "ja537:31.3",
      "pali": "Taṁ saṅkaraṁ brāhmaṇasappadāya,"
    },
    {
      "id": "ja537:31.4",
      "pali": "Saccānurakkhī punarāvajissaṁ”."
    },
    {
      "id": "ja537:32.1",
      "pali": "“Nevāhametaṁ abhisaddahāmi,"
    },
    {
      "id": "ja537:32.2",
      "pali": "Sukhī naro maccumukhā pamutto;"
    },
    {
      "id": "ja537:32.3",
      "pali": "Amittahatthaṁ punarāvajeyya,"
    },
    {
      "id": "ja537:32.4",
      "pali": "Korabyaseṭṭha na hi maṁ upesi."
    },
    {
      "id": "ja537:33.1",
      "pali": "Mutto tuvaṁ porisādassa hatthā,"
    },
    {
      "id": "ja537:33.2",
      "pali": "Gantvā sakaṁ mandiraṁ kāmakāmī;"
    },
    {
      "id": "ja537:33.3",
      "pali": "Madhuraṁ piyaṁ jīvitaṁ laddha rāja,"
    },
    {
      "id": "ja537:33.4",
      "pali": "Kuto tuvaṁ ehisi me sakāsaṁ”."
    },
    {
      "id": "ja537:34.1",
      "pali": "“Mataṁ vareyya parisuddhasīlo,"
    },
    {
      "id": "ja537:34.2",
      "pali": "Na jīvitaṁ garahito pāpadhammo;"
    },
    {
      "id": "ja537:34.3",
      "pali": "Na hi taṁ naraṁ tāyati duggatīhi,"
    },
    {
      "id": "ja537:34.4",
      "pali": "Yassāpi hetu alikaṁ bhaṇeyya."
    },
    {
      "id": "ja537:35.1",
      "pali": "Sacepi vāto girimāvaheyya,"
    },
    {
      "id": "ja537:35.2",
      "pali": "Cando ca suriyo ca chamā pateyyuṁ;"
    },
    {
      "id": "ja537:35.3",
      "pali": "Sabbā ca najjo paṭisotaṁ vajeyyuṁ,"
    },
    {
      "id": "ja537:35.4",
      "pali": "Na tvevahaṁ rāja musā bhaṇeyyaṁ."
    },
    {
      "id": "ja537:36.1",
      "pali": "Nabhaṁ phaleyya udadhīpi susse,"
    },
    {
      "id": "ja537:36.2",
      "pali": "Saṁvaṭṭaye bhūtadharā vasundharā;"
    },
    {
      "id": "ja537:36.3",
      "pali": "Siluccayo meru samūlamuppate,"
    },
    {
      "id": "ja537:36.4",
      "pali": "Na tvevahaṁ rāja musā bhaṇeyyaṁ."
    },
    {
      "id": "ja537:37.1",
      "pali": "Asiñca sattiñca parāmasāmi,"
    },
    {
      "id": "ja537:37.2",
      "pali": "Sapathampi te samma ahaṁ karomi;"
    },
    {
      "id": "ja537:37.3",
      "pali": "Tayā pamutto anaṇo bhavitvā,"
    },
    {
      "id": "ja537:37.4",
      "pali": "Saccānurakkhī punarāvajissaṁ”."
    },
    {
      "id": "ja537:38.1",
      "pali": "“Yo te kato saṅgaro brāhmaṇena,"
    },
    {
      "id": "ja537:38.2",
      "pali": "Raṭṭhe sake issariye ṭhitena;"
    },
    {
      "id": "ja537:38.3",
      "pali": "Taṁ saṅgaraṁ brāhmaṇasappadāya,"
    },
    {
      "id": "ja537:38.4",
      "pali": "Saccānurakkhī punarāvajassu”."
    },
    {
      "id": "ja537:39.1",
      "pali": "“Yo me kato saṅgaro brāhmaṇena,"
    },
    {
      "id": "ja537:39.2",
      "pali": "Raṭṭhe sake issariye ṭhitena;"
    },
    {
      "id": "ja537:39.3",
      "pali": "Taṁ saṅgaraṁ brāhmaṇasappadāya,"
    },
    {
      "id": "ja537:39.4",
      "pali": "Saccānurakkhī punarāvajissaṁ”."
    },
    {
      "id": "ja537:40.1",
      "pali": "Mutto ca so porisādassa hatthā,"
    },
    {
      "id": "ja537:40.2",
      "pali": "Gantvāna taṁ brāhmaṇaṁ etadavoca;"
    },
    {
      "id": "ja537:40.3",
      "pali": "“Suṇoma gāthāyo satārahāyo,"
    },
    {
      "id": "ja537:40.4",
      "pali": "Yā me sutā assu hitāya brahme”."
    },
    {
      "id": "ja537:41.1",
      "pali": "“Sakideva sutasoma,"
    },
    {
      "id": "ja537:41.2",
      "pali": "sabbhi hoti samāgamo;"
    },
    {
      "id": "ja537:41.3",
      "pali": "Sā naṁ saṅgati pāleti,"
    },
    {
      "id": "ja537:41.4",
      "pali": "nāsabbhi bahu saṅgamo."
    },
    {
      "id": "ja537:42.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "ja537:42.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "ja537:42.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "ja537:42.4",
      "pali": "seyyo hoti na pāpiyo."
    },
    {
      "id": "ja537:43.1",
      "pali": "Jīranti ve rājarathā sucittā,"
    },
    {
      "id": "ja537:43.2",
      "pali": "Atho sarīrampi jaraṁ upeti;"
    },
    {
      "id": "ja537:43.3",
      "pali": "Satañca dhammo na jaraṁ upeti,"
    },
    {
      "id": "ja537:43.4",
      "pali": "Santo have sabbhi pavedayanti."
    },
    {
      "id": "ja537:44.1",
      "pali": "Nabhañca dūre pathavī ca dūre,"
    },
    {
      "id": "ja537:44.2",
      "pali": "Pāraṁ samuddassa tadāhu dūre;"
    },
    {
      "id": "ja537:44.3",
      "pali": "Tato have dūrataraṁ vadanti,"
    },
    {
      "id": "ja537:44.4",
      "pali": "Satañca dhammo asatañca rāja”."
    },
    {
      "id": "ja537:45.1",
      "pali": "“Sahassiyā imā gāthā,"
    },
    {
      "id": "ja537:45.2",
      "pali": "nahimā gāthā satārahā;"
    },
    {
      "id": "ja537:45.3",
      "pali": "Cattāri tvaṁ sahassāni,"
    },
    {
      "id": "ja537:45.4",
      "pali": "khippaṁ gaṇhāhi brāhmaṇa”."
    },
    {
      "id": "ja537:46.1",
      "pali": "“Āsītiyā nāvutiyā ca gāthā,"
    },
    {
      "id": "ja537:46.2",
      "pali": "Satārahā cāpi bhaveyya gāthā;"
    },
    {
      "id": "ja537:46.3",
      "pali": "Paccattameva sutasoma jānahi,"
    },
    {
      "id": "ja537:46.4",
      "pali": "Sahassiyā nāma kā atthi gāthā”."
    },
    {
      "id": "ja537:47.1",
      "pali": "“Icchāmi vohaṁ sutavuddhimattano,"
    },
    {
      "id": "ja537:47.2",
      "pali": "Santoti maṁ sappurisā bhajeyyuṁ;"
    },
    {
      "id": "ja537:47.3",
      "pali": "Ahaṁ savantīhi mahodadhīva,"
    },
    {
      "id": "ja537:47.4",
      "pali": "Na hi tāta tappāmi subhāsitena."
    },
    {
      "id": "ja537:48.1",
      "pali": "Aggi yathā tiṇakaṭṭhaṁ dahanto,"
    },
    {
      "id": "ja537:48.2",
      "pali": "Na tappatī sāgarova nadīhi;"
    },
    {
      "id": "ja537:48.3",
      "pali": "Evampi te paṇḍitā rājaseṭṭha,"
    },
    {
      "id": "ja537:48.4",
      "pali": "Sutvā na tappanti subhāsitena."
    },
    {
      "id": "ja537:49.1",
      "pali": "Sakassa dāsassa yadā suṇomi,"
    },
    {
      "id": "ja537:49.2",
      "pali": "Gāthaṁ ahaṁ atthavatiṁ janinda;"
    },
    {
      "id": "ja537:49.3",
      "pali": "Tameva sakkacca nisāmayāmi,"
    },
    {
      "id": "ja537:49.4",
      "pali": "Na hi tāta dhammesu mamatthi titti."
    },
    {
      "id": "ja537:50.1",
      "pali": "Idaṁ te raṭṭhaṁ sadhanaṁ sayoggaṁ,"
    },
    {
      "id": "ja537:50.2",
      "pali": "Sakāyuraṁ sabbakāmūpapannaṁ;"
    },
    {
      "id": "ja537:50.3",
      "pali": "Kiṁ kāmahetu paribhāsasi maṁ,"
    },
    {
      "id": "ja537:50.4",
      "pali": "Gacchāmahaṁ porisādassa ñatte”."
    },
    {
      "id": "ja537:51.1",
      "pali": "“Attānurakkhāya bhavanti hete,"
    },
    {
      "id": "ja537:51.2",
      "pali": "Hatthārohā rathikā pattikā ca;"
    },
    {
      "id": "ja537:51.3",
      "pali": "Assāruhā ye ca dhanuggahāse,"
    },
    {
      "id": "ja537:51.4",
      "pali": "Senaṁ payuñjāma hanāma sattuṁ”."
    },
    {
      "id": "ja537:52.1",
      "pali": "“Sudukkaraṁ porisādo akāsi,"
    },
    {
      "id": "ja537:52.2",
      "pali": "Jīvaṁ gahetvāna avassajī maṁ;"
    },
    {
      "id": "ja537:52.3",
      "pali": "Taṁ tādisaṁ pubbakiccaṁ saranto,"
    },
    {
      "id": "ja537:52.4",
      "pali": "Dubbhe ahaṁ tassa kathaṁ janinda”."
    },
    {
      "id": "ja537:53.1",
      "pali": "Vanditvā so pitaraṁ mātarañca,"
    },
    {
      "id": "ja537:53.2",
      "pali": "Anusāsetvā negamañca balañca;"
    },
    {
      "id": "ja537:53.3",
      "pali": "Saccavādī saccānurakkhamāno,"
    },
    {
      "id": "ja537:53.4",
      "pali": "Agamāsi so yattha porisādo."
    },
    {
      "id": "ja537:54.1",
      "pali": "“Kato mayā saṅgaro brāhmaṇena,"
    },
    {
      "id": "ja537:54.2",
      "pali": "Raṭṭhe sake issariye ṭhitena;"
    },
    {
      "id": "ja537:54.3",
      "pali": "Taṁ saṅgaraṁ brāhmaṇasappadāya,"
    },
    {
      "id": "ja537:54.4",
      "pali": "Saccānurakkhī punarāgatosmi;"
    },
    {
      "id": "ja537:54.5",
      "pali": "Yajassu yaññaṁ khāda maṁ porisāda”."
    },
    {
      "id": "ja537:55.1",
      "pali": "“Na hāyate khāditaṁ mayhaṁ pacchā,"
    },
    {
      "id": "ja537:55.2",
      "pali": "Citakā ayaṁ tāva sadhūmikāva;"
    },
    {
      "id": "ja537:55.3",
      "pali": "Niddhūmake pacitaṁ sādhupakkaṁ,"
    },
    {
      "id": "ja537:55.4",
      "pali": "Suṇoma gāthāyo satārahāyo”."
    },
    {
      "id": "ja537:56.1",
      "pali": "“Adhammiko tvaṁ porisādakāsi,"
    },
    {
      "id": "ja537:56.2",
      "pali": "Raṭṭhā ca bhaṭṭho udarassa hetu;"
    },
    {
      "id": "ja537:56.3",
      "pali": "Dhammañcimā abhivadanti gāthā,"
    },
    {
      "id": "ja537:56.4",
      "pali": "Dhammo ca adhammo ca kuhiṁ sameti."
    },
    {
      "id": "ja537:57.1",
      "pali": "Adhammikassa luddassa,"
    },
    {
      "id": "ja537:57.2",
      "pali": "niccaṁ lohitapāṇino;"
    },
    {
      "id": "ja537:57.3",
      "pali": "Natthi saccaṁ kuto dhammo,"
    },
    {
      "id": "ja537:57.4",
      "pali": "kiṁ sutena karissasi”."
    },
    {
      "id": "ja537:58.1",
      "pali": "“Yo maṁsahetu migavaṁ careyya,"
    },
    {
      "id": "ja537:58.2",
      "pali": "Yo vā hane purisamattahetu;"
    },
    {
      "id": "ja537:58.3",
      "pali": "Ubhopi te pecca samā bhavanti,"
    },
    {
      "id": "ja537:58.4",
      "pali": "Kasmā no adhammikaṁ brūsi maṁ tvaṁ”."
    },
    {
      "id": "ja537:59.1",
      "pali": "“Pañca pañca na khā bhakkhā,"
    },
    {
      "id": "ja537:59.2",
      "pali": "khattiyena pajānatā;"
    },
    {
      "id": "ja537:59.3",
      "pali": "Abhakkhaṁ rāja bhakkhesi,"
    },
    {
      "id": "ja537:59.4",
      "pali": "tasmā adhammiko tuvaṁ”."
    },
    {
      "id": "ja537:60.1",
      "pali": "“Mutto tuvaṁ porisādassa hatthā,"
    },
    {
      "id": "ja537:60.2",
      "pali": "Gantvā sakaṁ mandiraṁ kāmakāmī;"
    },
    {
      "id": "ja537:60.3",
      "pali": "Amittahatthaṁ punarāgatosi,"
    },
    {
      "id": "ja537:60.4",
      "pali": "Na khattadhamme kusalosi rāja”."
    },
    {
      "id": "ja537:61.1",
      "pali": "“Ye khattadhamme kusalā bhavanti,"
    },
    {
      "id": "ja537:61.2",
      "pali": "Pāyena te nerayikā bhavanti;"
    },
    {
      "id": "ja537:61.3",
      "pali": "Tasmā ahaṁ khattadhammaṁ pahāya,"
    },
    {
      "id": "ja537:61.4",
      "pali": "Saccānurakkhī punarāgatosmi;"
    },
    {
      "id": "ja537:61.5",
      "pali": "Yajassu yaññaṁ khāda maṁ porisāda”."
    },
    {
      "id": "ja537:62.1",
      "pali": "“Pāsādavāsā pathavīgavāssā,"
    },
    {
      "id": "ja537:62.2",
      "pali": "Kāmitthiyo kāsikacandanañca;"
    },
    {
      "id": "ja537:62.3",
      "pali": "Sabbaṁ tahiṁ labhasi sāmitāya,"
    },
    {
      "id": "ja537:62.4",
      "pali": "Saccena kiṁ passasi ānisaṁsaṁ”."
    },
    {
      "id": "ja537:63.1",
      "pali": "“Ye kecime atthi rasā pathabyā,"
    },
    {
      "id": "ja537:63.2",
      "pali": "Saccaṁ tesaṁ sādhutaraṁ rasānaṁ;"
    },
    {
      "id": "ja537:63.3",
      "pali": "Sacce ṭhitā samaṇabrāhmaṇā ca,"
    },
    {
      "id": "ja537:63.4",
      "pali": "Taranti jātimaraṇassa pāraṁ”."
    },
    {
      "id": "ja537:64.1",
      "pali": "“Mutto tuvaṁ porisādassa hatthā,"
    },
    {
      "id": "ja537:64.2",
      "pali": "Gantvā sakaṁ mandiraṁ kāmakāmī;"
    },
    {
      "id": "ja537:64.3",
      "pali": "Amittahatthaṁ punarāgatosi,"
    },
    {
      "id": "ja537:64.4",
      "pali": "Na hi nūna te maraṇabhayaṁ janinda;"
    },
    {
      "id": "ja537:64.5",
      "pali": "Alīnacitto asi saccavādī”."
    },
    {
      "id": "ja537:65.1",
      "pali": "“Katā me kalyāṇā anekarūpā,"
    },
    {
      "id": "ja537:65.2",
      "pali": "Yaññā yiṭṭhā ye vipulā pasatthā;"
    },
    {
      "id": "ja537:65.3",
      "pali": "Visodhito paralokassa maggo,"
    },
    {
      "id": "ja537:65.4",
      "pali": "Dhamme ṭhito ko maraṇassa bhāye."
    },
    {
      "id": "ja537:66.1",
      "pali": "Katā me kalyāṇā anekarūpā,"
    },
    {
      "id": "ja537:66.2",
      "pali": "Yaññā yiṭṭhā ye vipulā pasatthā;"
    },
    {
      "id": "ja537:66.3",
      "pali": "Anānutappaṁ paralokaṁ gamissaṁ,"
    },
    {
      "id": "ja537:66.4",
      "pali": "Yajassu yaññaṁ ada maṁ porisāda."
    },
    {
      "id": "ja537:67.1",
      "pali": "Pitā ca mātā ca upaṭṭhitā me,"
    },
    {
      "id": "ja537:67.2",
      "pali": "Dhammena me issariyaṁ pasatthaṁ;"
    },
    {
      "id": "ja537:67.3",
      "pali": "Visodhito paralokassa maggo,"
    },
    {
      "id": "ja537:67.4",
      "pali": "Dhamme ṭhito ko maraṇassa bhāye."
    },
    {
      "id": "ja537:68.1",
      "pali": "Pitā ca mātā ca upaṭṭhitā me,"
    },
    {
      "id": "ja537:68.2",
      "pali": "Dhammena me issariyaṁ pasatthaṁ;"
    },
    {
      "id": "ja537:68.3",
      "pali": "Anānutappaṁ paralokaṁ gamissaṁ,"
    },
    {
      "id": "ja537:68.4",
      "pali": "Yajassu yaññaṁ ada maṁ porisāda."
    },
    {
      "id": "ja537:69.1",
      "pali": "Ñātīsu mittesu katā me kārā,"
    },
    {
      "id": "ja537:69.2",
      "pali": "Dhammena me issariyaṁ pasatthaṁ;"
    },
    {
      "id": "ja537:69.3",
      "pali": "Visodhito paralokassa maggo,"
    },
    {
      "id": "ja537:69.4",
      "pali": "Dhamme ṭhito ko maraṇassa bhāye."
    },
    {
      "id": "ja537:70.1",
      "pali": "Ñātīsu mittesu katā me kārā,"
    },
    {
      "id": "ja537:70.2",
      "pali": "Dhammena me issariyaṁ pasatthaṁ;"
    },
    {
      "id": "ja537:70.3",
      "pali": "Anānutappaṁ paralokaṁ gamissaṁ,"
    },
    {
      "id": "ja537:70.4",
      "pali": "Yajassu yaññaṁ ada maṁ porisāda."
    },
    {
      "id": "ja537:71.1",
      "pali": "Dinnaṁ me dānaṁ bahudhā bahūnaṁ,"
    },
    {
      "id": "ja537:71.2",
      "pali": "Santappitā samaṇabrāhmaṇā ca;"
    },
    {
      "id": "ja537:71.3",
      "pali": "Visodhito paralokassa maggo,"
    },
    {
      "id": "ja537:71.4",
      "pali": "Dhamme ṭhito ko maraṇassa bhāye."
    },
    {
      "id": "ja537:72.1",
      "pali": "Dinnaṁ me dānaṁ bahudhā bahūnaṁ,"
    },
    {
      "id": "ja537:72.2",
      "pali": "Santappitā samaṇabrāhmaṇā ca;"
    },
    {
      "id": "ja537:72.3",
      "pali": "Anānutappaṁ paralokaṁ gamissaṁ,"
    },
    {
      "id": "ja537:72.4",
      "pali": "Yajassu yaññaṁ ada maṁ porisāda”."
    },
    {
      "id": "ja537:73.1",
      "pali": "“Visaṁ pajānaṁ puriso adeyya,"
    },
    {
      "id": "ja537:73.2",
      "pali": "Āsīvisaṁ jalitamuggatejaṁ;"
    },
    {
      "id": "ja537:73.3",
      "pali": "Muddhāpi tassa viphaleyya sattadhā,"
    },
    {
      "id": "ja537:73.4",
      "pali": "Yo tādisaṁ saccavādiṁ adeyya."
    },
    {
      "id": "ja537:74.1",
      "pali": "Sutvā dhammaṁ vijānanti,"
    },
    {
      "id": "ja537:74.2",
      "pali": "Narā kalyāṇapāpakaṁ;"
    },
    {
      "id": "ja537:74.3",
      "pali": "Api gāthā suṇitvāna,"
    },
    {
      "id": "ja537:74.4",
      "pali": "Dhamme me ramate mano”."
    },
    {
      "id": "ja537:75.1",
      "pali": "“Sakideva mahārāja,"
    },
    {
      "id": "ja537:75.2",
      "pali": "sabbhi hoti samāgamo;"
    },
    {
      "id": "ja537:75.3",
      "pali": "Sā naṁ saṅgati pāleti,"
    },
    {
      "id": "ja537:75.4",
      "pali": "nāsabbhi bahu saṅgamo."
    },
    {
      "id": "ja537:76.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "ja537:76.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "ja537:76.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "ja537:76.4",
      "pali": "seyyo hoti na pāpiyo."
    },
    {
      "id": "ja537:77.1",
      "pali": "Jīranti ve rājarathā sucittā,"
    },
    {
      "id": "ja537:77.2",
      "pali": "Atho sarīrampi jaraṁ upeti;"
    },
    {
      "id": "ja537:77.3",
      "pali": "Satañca dhammo na jaraṁ upeti,"
    },
    {
      "id": "ja537:77.4",
      "pali": "Santo have sabbhi pavedayanti."
    },
    {
      "id": "ja537:78.1",
      "pali": "Nabhañca dūre pathavī ca dūre,"
    },
    {
      "id": "ja537:78.2",
      "pali": "Pāraṁ samuddassa tadāhu dūre;"
    },
    {
      "id": "ja537:78.3",
      "pali": "Tato have dūrataraṁ vadanti,"
    },
    {
      "id": "ja537:78.4",
      "pali": "Satañca dhammo asatañca rāja”."
    },
    {
      "id": "ja537:79.1",
      "pali": "“Gāthā imā atthavatī subyañjanā,"
    },
    {
      "id": "ja537:79.2",
      "pali": "Subhāsitā tuyha janinda sutvā;"
    },
    {
      "id": "ja537:79.3",
      "pali": "Ānandi vitto sumano patīto,"
    },
    {
      "id": "ja537:79.4",
      "pali": "Cattāri te samma vare dadāmi”."
    },
    {
      "id": "ja537:80.1",
      "pali": "“Yo nattano maraṇaṁ bujjhasi tuvaṁ,"
    },
    {
      "id": "ja537:80.2",
      "pali": "Hitāhitaṁ vinipātañca saggaṁ;"
    },
    {
      "id": "ja537:80.3",
      "pali": "Giddho rase duccarite niviṭṭho,"
    },
    {
      "id": "ja537:80.4",
      "pali": "Kiṁ tvaṁ varaṁ dassasi pāpadhamma."
    },
    {
      "id": "ja537:81.1",
      "pali": "Ahañca taṁ dehi varanti vajjaṁ,"
    },
    {
      "id": "ja537:81.2",
      "pali": "Tvañcāpi datvāna avākareyya;"
    },
    {
      "id": "ja537:81.3",
      "pali": "Sandiṭṭhikaṁ kalahamimaṁ vivādaṁ,"
    },
    {
      "id": "ja537:81.4",
      "pali": "Ko paṇḍito jānamupabbajeyya”."
    },
    {
      "id": "ja537:82.1",
      "pali": "“Na taṁ varaṁ arahati jantu dātuṁ,"
    },
    {
      "id": "ja537:82.2",
      "pali": "Yaṁ vāpi datvāna avākareyya;"
    },
    {
      "id": "ja537:82.3",
      "pali": "Varassu samma avikampamāno,"
    },
    {
      "id": "ja537:82.4",
      "pali": "Pāṇaṁ cajitvānapi dassameva”."
    },
    {
      "id": "ja537:83.1",
      "pali": "“Ariyassa ariyena sameti sakhyaṁ,"
    },
    {
      "id": "ja537:83.2",
      "pali": "Paññassa paññāṇavatā sameti;"
    },
    {
      "id": "ja537:83.3",
      "pali": "Passeyya taṁ vassasataṁ arogaṁ,"
    },
    {
      "id": "ja537:83.4",
      "pali": "Etaṁ varānaṁ paṭhamaṁ varāmi”."
    },
    {
      "id": "ja537:84.1",
      "pali": "“Ariyassa ariyena sameti sakhyaṁ,"
    },
    {
      "id": "ja537:84.2",
      "pali": "Paññassa paññāṇavatā sameti;"
    },
    {
      "id": "ja537:84.3",
      "pali": "Passāsi maṁ vassasataṁ arogaṁ,"
    },
    {
      "id": "ja537:84.4",
      "pali": "Etaṁ varānaṁ paṭhamaṁ dadāmi”."
    },
    {
      "id": "ja537:85.1",
      "pali": "“Ye khattiyāse idha bhūmipālā,"
    },
    {
      "id": "ja537:85.2",
      "pali": "Muddhābhisittā katanāmadheyyā;"
    },
    {
      "id": "ja537:85.3",
      "pali": "Na tādise bhūmipatī adesi,"
    },
    {
      "id": "ja537:85.4",
      "pali": "Etaṁ varānaṁ dutiyaṁ varāmi”."
    },
    {
      "id": "ja537:86.1",
      "pali": "“Ye khattiyāse idha bhūmipālā,"
    },
    {
      "id": "ja537:86.2",
      "pali": "Muddhābhisittā katanāmadheyyā;"
    },
    {
      "id": "ja537:86.3",
      "pali": "Na tādise bhūmipatī ademi,"
    },
    {
      "id": "ja537:86.4",
      "pali": "Etaṁ varānaṁ dutiyaṁ dadāmi”."
    },
    {
      "id": "ja537:87.1",
      "pali": "“Parosataṁ khattiyā te gahitā,"
    },
    {
      "id": "ja537:87.2",
      "pali": "Talāvutā assumukhā rudantā;"
    },
    {
      "id": "ja537:87.3",
      "pali": "Sake te raṭṭhe paṭipādayāhi,"
    },
    {
      "id": "ja537:87.4",
      "pali": "Etaṁ varānaṁ tatiyaṁ varāmi”."
    },
    {
      "id": "ja537:88.1",
      "pali": "“Parosataṁ khattiyā me gahitā,"
    },
    {
      "id": "ja537:88.2",
      "pali": "Talāvutā assumukhā rudantā;"
    },
    {
      "id": "ja537:88.3",
      "pali": "Sake te raṭṭhe paṭipādayāmi,"
    },
    {
      "id": "ja537:88.4",
      "pali": "Etaṁ varānaṁ tatiyaṁ dadāmi”."
    },
    {
      "id": "ja537:89.1",
      "pali": "“Chiddaṁ te raṭṭhaṁ byathitā bhayā hi,"
    },
    {
      "id": "ja537:89.2",
      "pali": "Puthū narā leṇamanuppaviṭṭhā;"
    },
    {
      "id": "ja537:89.3",
      "pali": "Manussamaṁsaṁ viramehi rāja,"
    },
    {
      "id": "ja537:89.4",
      "pali": "Etaṁ varānaṁ catutthaṁ varāmi”."
    },
    {
      "id": "ja537:90.1",
      "pali": "“Addhā hi so bhakkho mama manāpo,"
    },
    {
      "id": "ja537:90.2",
      "pali": "Etassa hetumhi vanaṁ paviṭṭho;"
    },
    {
      "id": "ja537:90.3",
      "pali": "Sohaṁ kathaṁ etto upārameyyaṁ,"
    },
    {
      "id": "ja537:90.4",
      "pali": "Aññaṁ varānaṁ catutthaṁ varassu”."
    },
    {
      "id": "ja537:91.1",
      "pali": "“Na ve piyaṁ meti janinda tādiso,"
    },
    {
      "id": "ja537:91.2",
      "pali": "Attaṁ niraṅkacca piyāni sevati;"
    },
    {
      "id": "ja537:91.3",
      "pali": "Attāva seyyo paramā ca seyyo,"
    },
    {
      "id": "ja537:91.4",
      "pali": "Labbhā piyā ocitatthena pacchā”."
    },
    {
      "id": "ja537:92.1",
      "pali": "“Piyaṁ me mānusaṁ maṁsaṁ,"
    },
    {
      "id": "ja537:92.2",
      "pali": "Sutasoma vijānahi;"
    },
    {
      "id": "ja537:92.3",
      "pali": "Namhi sakkā nivāretuṁ,"
    },
    {
      "id": "ja537:92.4",
      "pali": "Aññaṁ varaṁ samma varassu”."
    },
    {
      "id": "ja537:93.1",
      "pali": "“Yo ve piyaṁ meti piyānurakkhī,"
    },
    {
      "id": "ja537:93.2",
      "pali": "Attaṁ niraṅkacca piyāni sevati;"
    },
    {
      "id": "ja537:93.3",
      "pali": "Soṇḍova pitvā visamissapānaṁ,"
    },
    {
      "id": "ja537:93.4",
      "pali": "Teneva so hoti dukkhī parattha."
    },
    {
      "id": "ja537:94.1",
      "pali": "Yo cīdha saṅkhāya piyāni hitvā,"
    },
    {
      "id": "ja537:94.2",
      "pali": "Kicchenapi sevati ariyadhamme;"
    },
    {
      "id": "ja537:94.3",
      "pali": "Dukkhitova pitvāna yathosadhāni,"
    },
    {
      "id": "ja537:94.4",
      "pali": "Teneva so hoti sukhī parattha”."
    },
    {
      "id": "ja537:95.1",
      "pali": "“Ohāyahaṁ pitaraṁ mātarañca,"
    },
    {
      "id": "ja537:95.2",
      "pali": "Manāpiye kāmaguṇe ca pañca;"
    },
    {
      "id": "ja537:95.3",
      "pali": "Etassa hetumhi vanaṁ paviṭṭho,"
    },
    {
      "id": "ja537:95.4",
      "pali": "Taṁ te varaṁ kinti mahaṁ dadāmi”."
    },
    {
      "id": "ja537:96.1",
      "pali": "“Na paṇḍitā diguṇamāhu vākyaṁ,"
    },
    {
      "id": "ja537:96.2",
      "pali": "Saccappaṭiññāva bhavanti santo;"
    },
    {
      "id": "ja537:96.3",
      "pali": "Varassu samma iti maṁ avoca,"
    },
    {
      "id": "ja537:96.4",
      "pali": "Iccabravī tvaṁ na hi te sameti”."
    },
    {
      "id": "ja537:97.1",
      "pali": "“Apuññalābhaṁ ayasaṁ akittiṁ,"
    },
    {
      "id": "ja537:97.2",
      "pali": "Pāpaṁ bahuṁ duccaritaṁ kilesaṁ;"
    },
    {
      "id": "ja537:97.3",
      "pali": "Manussamaṁsassa kate upāgā,"
    },
    {
      "id": "ja537:97.4",
      "pali": "Taṁ te varaṁ kinti mahaṁ dadeyyaṁ”."
    },
    {
      "id": "ja537:98.1",
      "pali": "“Na taṁ varaṁ arahati jantu dātuṁ,"
    },
    {
      "id": "ja537:98.2",
      "pali": "Yaṁ vāpi datvāna avākareyya;"
    },
    {
      "id": "ja537:98.3",
      "pali": "Varassu samma avikampamāno,"
    },
    {
      "id": "ja537:98.4",
      "pali": "Pāṇaṁ cajitvānapi dassameva."
    },
    {
      "id": "ja537:99.1",
      "pali": "Pāṇaṁ cajanti santo nāpi dhammaṁ,"
    },
    {
      "id": "ja537:99.2",
      "pali": "Saccappaṭiññāva bhavanti santo;"
    },
    {
      "id": "ja537:99.3",
      "pali": "Datvā varaṁ khippamavākarohi,"
    },
    {
      "id": "ja537:99.4",
      "pali": "Etena sampajja surājaseṭṭha."
    },
    {
      "id": "ja537:100.1",
      "pali": "Caje dhanaṁ aṅgavarassa hetu,"
    },
    {
      "id": "ja537:100.2",
      "pali": "Aṅgaṁ caje jīvitaṁ rakkhamāno;"
    },
    {
      "id": "ja537:100.3",
      "pali": "Aṅgaṁ dhanaṁ jīvitañcāpi sabbaṁ,"
    },
    {
      "id": "ja537:100.4",
      "pali": "Caje naro dhammamanussaranto."
    },
    {
      "id": "ja537:101.1",
      "pali": "Yasmā hi dhammaṁ puriso vijaññā,"
    },
    {
      "id": "ja537:101.2",
      "pali": "Ye cassa kaṅkhaṁ vinayanti santo;"
    },
    {
      "id": "ja537:101.3",
      "pali": "Taṁ hissa dīpañca parāyaṇañca,"
    },
    {
      "id": "ja537:101.4",
      "pali": "Na tena mittiṁ jirayetha pañño”."
    },
    {
      "id": "ja537:102.1",
      "pali": "“Addhā hi so bhakkho mama manāpo,"
    },
    {
      "id": "ja537:102.2",
      "pali": "Etassa hetumhi vanaṁ paviṭṭho;"
    },
    {
      "id": "ja537:102.3",
      "pali": "Sace ca maṁ yācasi etamatthaṁ,"
    },
    {
      "id": "ja537:102.4",
      "pali": "Etampi te samma varaṁ dadāmi."
    },
    {
      "id": "ja537:103.1",
      "pali": "Satthā ca me hosi sakhā ca mesi,"
    },
    {
      "id": "ja537:103.2",
      "pali": "Vacanampi te samma ahaṁ akāsiṁ;"
    },
    {
      "id": "ja537:103.3",
      "pali": "Tuvampi me samma karohi vākyaṁ,"
    },
    {
      "id": "ja537:103.4",
      "pali": "Ubhopi gantvāna pamocayāma”."
    },
    {
      "id": "ja537:104.1",
      "pali": "“Satthā ca te homi sakhā ca tyamhi,"
    },
    {
      "id": "ja537:104.2",
      "pali": "Vacanampi me samma tuvaṁ akāsi;"
    },
    {
      "id": "ja537:104.3",
      "pali": "Ahampi te samma karomi vākyaṁ,"
    },
    {
      "id": "ja537:104.4",
      "pali": "Ubhopi gantvāna pamocayāma”."
    },
    {
      "id": "ja537:105.1",
      "pali": "“Kammāsapādena viheṭhitattha,"
    },
    {
      "id": "ja537:105.2",
      "pali": "Talāvutā assumukhā rudantā;"
    },
    {
      "id": "ja537:105.3",
      "pali": "Na jātu dubbhetha imassa rañño,"
    },
    {
      "id": "ja537:105.4",
      "pali": "Saccappaṭiññaṁ me paṭissuṇātha”."
    },
    {
      "id": "ja537:106.1",
      "pali": "“Kammāsapādena viheṭhitamhā,"
    },
    {
      "id": "ja537:106.2",
      "pali": "Talāvutā assumukhā rudantā;"
    },
    {
      "id": "ja537:106.3",
      "pali": "Na jātu dubbhema imassa rañño,"
    },
    {
      "id": "ja537:106.4",
      "pali": "Saccappaṭiññaṁ te paṭissuṇāma”."
    },
    {
      "id": "ja537:107.1",
      "pali": "“Yathā pitā vā atha vāpi mātā,"
    },
    {
      "id": "ja537:107.2",
      "pali": "Anukampakā atthakāmā pajānaṁ;"
    },
    {
      "id": "ja537:107.3",
      "pali": "Evameva vo hotu ayañca rājā,"
    },
    {
      "id": "ja537:107.4",
      "pali": "Tumhe ca vo hotha yatheva puttā”."
    },
    {
      "id": "ja537:108.1",
      "pali": "“Yathā pitā vā atha vāpi mātā,"
    },
    {
      "id": "ja537:108.2",
      "pali": "Anukampakā atthakāmā pajānaṁ;"
    },
    {
      "id": "ja537:108.3",
      "pali": "Evameva no hotu ayañca rājā,"
    },
    {
      "id": "ja537:108.4",
      "pali": "Mayampi hessāma yatheva puttā”."
    },
    {
      "id": "ja537:109.1",
      "pali": "“Catuppadaṁ sakuṇañcāpi maṁsaṁ,"
    },
    {
      "id": "ja537:109.2",
      "pali": "Sūdehi randhaṁ sukataṁ suniṭṭhitaṁ;"
    },
    {
      "id": "ja537:109.3",
      "pali": "Sudhaṁva indo paribhuñjiyāna,"
    },
    {
      "id": "ja537:109.4",
      "pali": "Hitvā katheko ramasī araññe."
    },
    {
      "id": "ja537:110.1",
      "pali": "Tā khattiyā vallivilākamajjhā,"
    },
    {
      "id": "ja537:110.2",
      "pali": "Alaṅkatā samparivārayitvā;"
    },
    {
      "id": "ja537:110.3",
      "pali": "Indaṁva devesu pamodayiṁsu,"
    },
    {
      "id": "ja537:110.4",
      "pali": "Hitvā katheko ramasī araññe."
    },
    {
      "id": "ja537:111.1",
      "pali": "Tambūpadhāne bahugoṇakamhi,"
    },
    {
      "id": "ja537:111.2",
      "pali": "Subhamhi sabbassayanamhi saṅge;"
    },
    {
      "id": "ja537:111.3",
      "pali": "Seyyassa majjhamhi sukhaṁ sayitvā,"
    },
    {
      "id": "ja537:111.4",
      "pali": "Hitvā katheko ramasī araññe."
    },
    {
      "id": "ja537:112.1",
      "pali": "Pāṇissaraṁ kumbhathūṇaṁ nisīthe,"
    },
    {
      "id": "ja537:112.2",
      "pali": "Athopi ve nippurisampi tūriyaṁ;"
    },
    {
      "id": "ja537:112.3",
      "pali": "Bahuṁ sugītañca suvāditañca,"
    },
    {
      "id": "ja537:112.4",
      "pali": "Hitvā katheko ramasī araññe."
    },
    {
      "id": "ja537:113.1",
      "pali": "Uyyānasampannaṁ pahūtamālyaṁ,"
    },
    {
      "id": "ja537:113.2",
      "pali": "Migājinūpetapuraṁ surammaṁ;"
    },
    {
      "id": "ja537:113.3",
      "pali": "Hayehi nāgehi rathehupetaṁ,"
    },
    {
      "id": "ja537:113.4",
      "pali": "Hitvā katheko ramasī araññe”."
    },
    {
      "id": "ja537:114.1",
      "pali": "“Kāḷapakkhe yathā cando,"
    },
    {
      "id": "ja537:114.2",
      "pali": "hāyateva suve suve;"
    },
    {
      "id": "ja537:114.3",
      "pali": "Kāḷapakkhūpamo rāja,"
    },
    {
      "id": "ja537:114.4",
      "pali": "asataṁ hoti samāgamo."
    },
    {
      "id": "ja537:115.1",
      "pali": "Yathāhaṁ rasakamāgamma,"
    },
    {
      "id": "ja537:115.2",
      "pali": "sūdaṁ kāpurisādhamaṁ;"
    },
    {
      "id": "ja537:115.3",
      "pali": "Akāsiṁ pāpakaṁ kammaṁ,"
    },
    {
      "id": "ja537:115.4",
      "pali": "yena gacchāmi duggatiṁ."
    },
    {
      "id": "ja537:116.1",
      "pali": "Sukkapakkhe yathā cando,"
    },
    {
      "id": "ja537:116.2",
      "pali": "vaḍḍhateva suve suve;"
    },
    {
      "id": "ja537:116.3",
      "pali": "Sukkapakkhūpamo rāja,"
    },
    {
      "id": "ja537:116.4",
      "pali": "sataṁ hoti samāgamo."
    },
    {
      "id": "ja537:117.1",
      "pali": "Yathāhaṁ tuvamāgamma,"
    },
    {
      "id": "ja537:117.2",
      "pali": "sutasoma vijānahi;"
    },
    {
      "id": "ja537:117.3",
      "pali": "Kāhāmi kusalaṁ kammaṁ,"
    },
    {
      "id": "ja537:117.4",
      "pali": "yena gacchāmi suggatiṁ."
    },
    {
      "id": "ja537:118.1",
      "pali": "Thale yathā vāri janinda vuṭṭhaṁ,"
    },
    {
      "id": "ja537:118.2",
      "pali": "Anaddhaneyyaṁ na ciraṭṭhitīkaṁ;"
    },
    {
      "id": "ja537:118.3",
      "pali": "Evampi hoti asataṁ samāgamo,"
    },
    {
      "id": "ja537:118.4",
      "pali": "Anaddhaneyyo udakaṁ thaleva."
    },
    {
      "id": "ja537:119.1",
      "pali": "Sare yathā vāri janinda vuṭṭhaṁ,"
    },
    {
      "id": "ja537:119.2",
      "pali": "Ciraṭṭhitīkaṁ naravīraseṭṭha;"
    },
    {
      "id": "ja537:119.3",
      "pali": "Evampi ve hoti sataṁ samāgamo,"
    },
    {
      "id": "ja537:119.4",
      "pali": "Ciraṭṭhitīko udakaṁ sareva."
    },
    {
      "id": "ja537:120.1",
      "pali": "Abyāyiko hoti sataṁ samāgamo,"
    },
    {
      "id": "ja537:120.2",
      "pali": "Yāvampi tiṭṭheyya tatheva hoti;"
    },
    {
      "id": "ja537:120.3",
      "pali": "Khippañhi veti asataṁ samāgamo,"
    },
    {
      "id": "ja537:120.4",
      "pali": "Tasmā sataṁ dhammo asabbhi ārakā”."
    },
    {
      "id": "ja537:121.1",
      "pali": "“Na so rājā yo ajeyyaṁ jināti,"
    },
    {
      "id": "ja537:121.2",
      "pali": "Na so sakhā yo sakhāraṁ jināti;"
    },
    {
      "id": "ja537:121.3",
      "pali": "Na sā bhariyā yā patino na vibheti,"
    },
    {
      "id": "ja537:121.4",
      "pali": "Na te puttā ye na bharanti jiṇṇaṁ."
    },
    {
      "id": "ja537:122.1",
      "pali": "Na sā sabhā yattha na santi santo,"
    },
    {
      "id": "ja537:122.2",
      "pali": "Na te santo ye na bhaṇanti dhammaṁ;"
    },
    {
      "id": "ja537:122.3",
      "pali": "Rāgañca dosañca pahāya mohaṁ,"
    },
    {
      "id": "ja537:122.4",
      "pali": "Dhammaṁ bhaṇantāva bhavanti santo."
    },
    {
      "id": "ja537:123.1",
      "pali": "Nābhāsamānaṁ jānanti,"
    },
    {
      "id": "ja537:123.2",
      "pali": "missaṁ bālehi paṇḍitaṁ;"
    },
    {
      "id": "ja537:123.3",
      "pali": "Bhāsamānañca jānanti,"
    },
    {
      "id": "ja537:123.4",
      "pali": "desentaṁ amataṁ padaṁ."
    },
    {
      "id": "ja537:124.1",
      "pali": "Bhāsaye jotaye dhammaṁ,"
    },
    {
      "id": "ja537:124.2",
      "pali": "Paggaṇhe isinaṁ dhajaṁ;"
    },
    {
      "id": "ja537:124.3",
      "pali": "Subhāsitaddhajā isayo,"
    },
    {
      "id": "ja537:124.4",
      "pali": "Dhammo hi isinaṁ dhajo”ti."
    },
    {
      "id": "ja537:125.1",
      "pali": "Mahāsutasomajātakaṁ pañcamaṁ."
    },
    {
      "id": "ja537:126.1",
      "pali": "Asītinipātaṁ niṭṭhitaṁ."
    },
    {
      "id": "ja537:127.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja537:128.1",
      "pali": "Sumukho pana haṁsavaro ca mahā,"
    },
    {
      "id": "ja537:128.2",
      "pali": "Sudhabhojaniko ca paro pavaro;"
    },
    {
      "id": "ja537:128.3",
      "pali": "Sakuṇāladijādhipativhayano,"
    },
    {
      "id": "ja537:128.4",
      "pali": "Sutasomavaruttamasavhayanoti."
    }
  ]
}
