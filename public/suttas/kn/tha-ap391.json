{
  "uid": "tha-ap391",
  "title": "9 Soṇakoṭivīsattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap391:1.1",
      "pali": "“Vipassino pāvacane,"
    },
    {
      "id": "tha-ap391:1.2",
      "pali": "ekaṁ leṇaṁ mayā kataṁ;"
    },
    {
      "id": "tha-ap391:1.3",
      "pali": "Cātuddisassa saṅghassa,"
    },
    {
      "id": "tha-ap391:1.4",
      "pali": "bandhumārājadhāniyā."
    },
    {
      "id": "tha-ap391:2.1",
      "pali": "Dussehi bhūmiṁ leṇassa,"
    },
    {
      "id": "tha-ap391:2.2",
      "pali": "santharitvā pariccajiṁ;"
    },
    {
      "id": "tha-ap391:2.3",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "tha-ap391:2.4",
      "pali": "akāsiṁ paṇidhiṁ tadā."
    },
    {
      "id": "tha-ap391:3.1",
      "pali": "Ārādhayeyyaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap391:3.2",
      "pali": "pabbajjañca labheyyahaṁ;"
    },
    {
      "id": "tha-ap391:3.3",
      "pali": "Anuttarañca nibbānaṁ,"
    },
    {
      "id": "tha-ap391:3.4",
      "pali": "phuseyyaṁ santimuttamaṁ."
    },
    {
      "id": "tha-ap391:4.1",
      "pali": "Teneva sukkamūlena,"
    },
    {
      "id": "tha-ap391:4.2",
      "pali": "kappe navuti saṁsariṁ;"
    },
    {
      "id": "tha-ap391:4.3",
      "pali": "Devabhūto manusso ca,"
    },
    {
      "id": "tha-ap391:4.4",
      "pali": "katapuñño virocahaṁ."
    },
    {
      "id": "tha-ap391:5.1",
      "pali": "Tato kammāvasesena,"
    },
    {
      "id": "tha-ap391:5.2",
      "pali": "idha pacchimake bhave;"
    },
    {
      "id": "tha-ap391:5.3",
      "pali": "Campāyaṁ aggaseṭṭhissa,"
    },
    {
      "id": "tha-ap391:5.4",
      "pali": "jātomhi ekaputtako."
    },
    {
      "id": "tha-ap391:6.1",
      "pali": "Jātamattassa me sutvā,"
    },
    {
      "id": "tha-ap391:6.2",
      "pali": "pitu chando ayaṁ ahu;"
    },
    {
      "id": "tha-ap391:6.3",
      "pali": "Dadāmahaṁ kumārassa,"
    },
    {
      "id": "tha-ap391:6.4",
      "pali": "vīsakoṭī anūnakā."
    },
    {
      "id": "tha-ap391:7.1",
      "pali": "Caturaṅgulā ca me lomā,"
    },
    {
      "id": "tha-ap391:7.2",
      "pali": "jātā pādatale ubho;"
    },
    {
      "id": "tha-ap391:7.3",
      "pali": "Sukhumā mudusamphassā,"
    },
    {
      "id": "tha-ap391:7.4",
      "pali": "tūlāpicusamā subhā."
    },
    {
      "id": "tha-ap391:8.1",
      "pali": "Atītā navuti kappā,"
    },
    {
      "id": "tha-ap391:8.2",
      "pali": "ayaṁ eko ca uttari;"
    },
    {
      "id": "tha-ap391:8.3",
      "pali": "Nābhijānāmi nikkhitte,"
    },
    {
      "id": "tha-ap391:8.4",
      "pali": "pāde bhūmyā asanthate."
    },
    {
      "id": "tha-ap391:9.1",
      "pali": "Ārādhito me sambuddho,"
    },
    {
      "id": "tha-ap391:9.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap391:9.3",
      "pali": "Arahattañca me pattaṁ,"
    },
    {
      "id": "tha-ap391:9.4",
      "pali": "sītibhūtomhi nibbuto."
    },
    {
      "id": "tha-ap391:10.1",
      "pali": "Aggo āraddhavīriyānaṁ,"
    },
    {
      "id": "tha-ap391:10.2",
      "pali": "niddiṭṭho sabbadassinā;"
    },
    {
      "id": "tha-ap391:10.3",
      "pali": "Khīṇāsavomhi arahā,"
    },
    {
      "id": "tha-ap391:10.4",
      "pali": "chaḷabhiñño mahiddhiko."
    },
    {
      "id": "tha-ap391:11.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap391:11.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap391:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap391:11.4",
      "pali": "leṇadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap391:12.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap391:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap391:12.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap391:13.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap391:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap391:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap391:14.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap391:14.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap391:14.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap391:15.1",
      "pali": "Thero koṭivīso soṇo,"
    },
    {
      "id": "tha-ap391:15.2",
      "pali": "bhikkhusaṅghassa aggato;"
    },
    {
      "id": "tha-ap391:15.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "tha-ap391:15.4",
      "pali": "anotatte mahāsareti."
    },
    {
      "id": "tha-ap391:16.1",
      "pali": "Itthaṁ sudaṁ āyasmā soṇo koṭivīso thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap391:17.1",
      "pali": "Soṇakoṭivīsattherassāpadānaṁ navamaṁ."
    }
  ]
}
