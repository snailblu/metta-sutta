{
  "uid": "tha-ap170",
  "title": "Dussadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap170:1.1",
      "pali": "“Tivarāyaṁ pure ramme,"
    },
    {
      "id": "tha-ap170:1.2",
      "pali": "rājaputtosahaṁ tadā;"
    },
    {
      "id": "tha-ap170:1.3",
      "pali": "Paṇṇākāraṁ labhitvāna,"
    },
    {
      "id": "tha-ap170:1.4",
      "pali": "upasantassadāsahaṁ."
    },
    {
      "id": "tha-ap170:2.1",
      "pali": "Adhivāsesi bhagavā,"
    },
    {
      "id": "tha-ap170:2.2",
      "pali": "vatthaṁ hatthena āmasi;"
    },
    {
      "id": "tha-ap170:2.3",
      "pali": "Siddhattho adhivāsetvā,"
    },
    {
      "id": "tha-ap170:2.4",
      "pali": "vehāsaṁ nabhamuggami."
    },
    {
      "id": "tha-ap170:3.1",
      "pali": "Buddhassa gacchamānassa,"
    },
    {
      "id": "tha-ap170:3.2",
      "pali": "dussā dhāvanti pacchato;"
    },
    {
      "id": "tha-ap170:3.3",
      "pali": "Tattha cittaṁ pasādesiṁ,"
    },
    {
      "id": "tha-ap170:3.4",
      "pali": "buddho no aggapuggalo."
    },
    {
      "id": "tha-ap170:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap170:4.2",
      "pali": "yaṁ dussamadadiṁ tadā;"
    },
    {
      "id": "tha-ap170:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap170:4.4",
      "pali": "dussadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap170:5.1",
      "pali": "Sattasaṭṭhimhito kappe,"
    },
    {
      "id": "tha-ap170:5.2",
      "pali": "cakkavattī tadā ahuṁ;"
    },
    {
      "id": "tha-ap170:5.3",
      "pali": "Parisuddhoti nāmena,"
    },
    {
      "id": "tha-ap170:5.4",
      "pali": "manujindo mahabbalo."
    },
    {
      "id": "tha-ap170:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap170:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap170:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap170:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā dussadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap170:8.1",
      "pali": "Dussadāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
