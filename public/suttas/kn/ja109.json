{
  "uid": "ja109",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja109:1.1",
      "pali": "“Yathanno puriso hoti,"
    },
    {
      "id": "ja109:1.2",
      "pali": "tathannā tassa devatā;"
    },
    {
      "id": "ja109:1.3",
      "pali": "Āharetaṁ kuṇḍapūvaṁ,"
    },
    {
      "id": "ja109:1.4",
      "pali": "mā me bhāgaṁ vināsayā”ti."
    },
    {
      "id": "ja109:2.1",
      "pali": "Kuṇḍapūvajātakaṁ navamaṁ."
    }
  ]
}
