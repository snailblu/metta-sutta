{
  "uid": "tha-ap49",
  "title": "Sayanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap49:1.1",
      "pali": "“Siddhatthassa bhagavato,"
    },
    {
      "id": "tha-ap49:1.2",
      "pali": "mettacittassa tādino;"
    },
    {
      "id": "tha-ap49:1.3",
      "pali": "Sayanaggaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap49:1.4",
      "pali": "dussabhaṇḍehi atthataṁ."
    },
    {
      "id": "tha-ap49:2.1",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap49:2.2",
      "pali": "kappiyaṁ sayanāsanaṁ;"
    },
    {
      "id": "tha-ap49:2.3",
      "pali": "Uṭṭhāya sayanā tamhā,"
    },
    {
      "id": "tha-ap49:2.4",
      "pali": "vehāsaṁ uggamī jino."
    },
    {
      "id": "tha-ap49:3.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap49:3.2",
      "pali": "yaṁ sayanamadāsahaṁ;"
    },
    {
      "id": "tha-ap49:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap49:3.4",
      "pali": "sayanassa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap49:4.1",
      "pali": "Ekapaññāsito kappe,"
    },
    {
      "id": "tha-ap49:4.2",
      "pali": "varako devasavhayo;"
    },
    {
      "id": "tha-ap49:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap49:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap49:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap49:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap49:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap49:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā sayanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap49:7.1",
      "pali": "Sayanadāyakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
