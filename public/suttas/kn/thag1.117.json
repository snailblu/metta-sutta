{
  "uid": "thag1.117",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.117:1.1",
      "pali": "“Suvilitto suvasano,"
    },
    {
      "id": "thag1.117:1.2",
      "pali": "sabbābharaṇabhūsito;"
    },
    {
      "id": "thag1.117:1.3",
      "pali": "Tisso vijjā ajjhagamiṁ,"
    },
    {
      "id": "thag1.117:1.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag1.117:1.5",
      "pali": "… Yaso thero …."
    }
  ]
}
