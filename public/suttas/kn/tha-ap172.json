{
  "uid": "tha-ap172",
  "title": "Pañcaṅguliyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap172:1.1",
      "pali": "“Tisso nāmāsi bhagavā,"
    },
    {
      "id": "tha-ap172:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap172:1.3",
      "pali": "Pavisati gandhakuṭiṁ,"
    },
    {
      "id": "tha-ap172:1.4",
      "pali": "vihārakusalo muni."
    },
    {
      "id": "tha-ap172:2.1",
      "pali": "Sugandhamālamādāya,"
    },
    {
      "id": "tha-ap172:2.2",
      "pali": "agamāsiṁ jinantikaṁ;"
    },
    {
      "id": "tha-ap172:2.3",
      "pali": "Apasaddo ca sambuddhe,"
    },
    {
      "id": "tha-ap172:2.4",
      "pali": "pañcaṅgulimadāsahaṁ."
    },
    {
      "id": "tha-ap172:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap172:3.2",
      "pali": "yaṁ gandhamabhiropayiṁ;"
    },
    {
      "id": "tha-ap172:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap172:3.4",
      "pali": "pañcaṅgulissidaṁ phalaṁ."
    },
    {
      "id": "tha-ap172:4.1",
      "pali": "Dvesattatimhito kappe,"
    },
    {
      "id": "tha-ap172:4.2",
      "pali": "rājā āsiṁ sayampabho;"
    },
    {
      "id": "tha-ap172:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap172:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap172:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap172:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap172:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap172:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā pañcaṅguliyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap172:7.1",
      "pali": "Pañcaṅguliyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap172:8.1",
      "pali": "Supāricariyavaggo sattarasamo."
    },
    {
      "id": "tha-ap172:9.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap172:10.1",
      "pali": "Supāricari kaṇaverī,"
    },
    {
      "id": "tha-ap172:10.2",
      "pali": "khajjako desapūjako;"
    },
    {
      "id": "tha-ap172:10.3",
      "pali": "Kaṇikāro sappidado,"
    },
    {
      "id": "tha-ap172:10.4",
      "pali": "yūthiko dussadāyako;"
    },
    {
      "id": "tha-ap172:10.5",
      "pali": "Māḷo ca pañcaṅguliko,"
    },
    {
      "id": "tha-ap172:10.6",
      "pali": "catupaññāsa gāthakāti."
    }
  ]
}
