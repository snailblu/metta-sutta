{
  "uid": "tha-ap464",
  "title": "Citakapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap464:1.1",
      "pali": "“Jhāyamānassa bhagavato,"
    },
    {
      "id": "tha-ap464:1.2",
      "pali": "sikhino lokabandhuno;"
    },
    {
      "id": "tha-ap464:1.3",
      "pali": "Aṭṭha campakapupphāni,"
    },
    {
      "id": "tha-ap464:1.4",
      "pali": "citakaṁ abhiropayiṁ."
    },
    {
      "id": "tha-ap464:2.1",
      "pali": "Ekatiṁse ito kappe,"
    },
    {
      "id": "tha-ap464:2.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap464:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap464:2.4",
      "pali": "citapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap464:3.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap464:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap464:3.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap464:4.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap464:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap464:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap464:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap464:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap464:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap464:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā citakapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap464:7.1",
      "pali": "Citakapūjakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
