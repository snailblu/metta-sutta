{
  "uid": "snp5.16",
  "title": "Mogharājamāṇavapucchā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "snp5.16:1.1",
      "pali": "“Dvāhaṁ sakkaṁ apucchissaṁ,"
    },
    {
      "id": "snp5.16:1.2",
      "pali": "(iccāyasmā mogharājā)"
    },
    {
      "id": "snp5.16:1.3",
      "pali": "Na me byākāsi cakkhumā;"
    },
    {
      "id": "snp5.16:1.4",
      "pali": "Yāvatatiyañca devīsi,"
    },
    {
      "id": "snp5.16:1.5",
      "pali": "Byākarotīti me sutaṁ."
    },
    {
      "id": "snp5.16:2.1",
      "pali": "Ayaṁ loko paro loko,"
    },
    {
      "id": "snp5.16:2.2",
      "pali": "brahmaloko sadevako;"
    },
    {
      "id": "snp5.16:2.3",
      "pali": "Diṭṭhiṁ te nābhijānāti,"
    },
    {
      "id": "snp5.16:2.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "snp5.16:3.1",
      "pali": "Evaṁ abhikkantadassāviṁ,"
    },
    {
      "id": "snp5.16:3.2",
      "pali": "atthi pañhena āgamaṁ;"
    },
    {
      "id": "snp5.16:3.3",
      "pali": "Kathaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "snp5.16:3.4",
      "pali": "maccurājā na passati”."
    },
    {
      "id": "snp5.16:4.1",
      "pali": "“Suññato lokaṁ avekkhassu,"
    },
    {
      "id": "snp5.16:4.2",
      "pali": "Mogharāja sadā sato;"
    },
    {
      "id": "snp5.16:4.3",
      "pali": "Attānudiṭṭhiṁ ūhacca,"
    },
    {
      "id": "snp5.16:4.4",
      "pali": "Evaṁ maccutaro siyā;"
    },
    {
      "id": "snp5.16:4.5",
      "pali": "Evaṁ lokaṁ avekkhantaṁ,"
    },
    {
      "id": "snp5.16:4.6",
      "pali": "Maccurājā na passatī”ti."
    },
    {
      "id": "snp5.16:4.7",
      "pali": "Mogharājamāṇavapucchā pannarasamā."
    }
  ]
}
