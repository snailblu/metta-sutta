{
  "uid": "thag1.7",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.7:1.1",
      "pali": "“Yopānudī maccurājassa senaṁ,"
    },
    {
      "id": "thag1.7:1.2",
      "pali": "Naḷasetuṁva sudubbalaṁ mahogho;"
    },
    {
      "id": "thag1.7:1.3",
      "pali": "Vijitāvī apetabheravo hi,"
    },
    {
      "id": "thag1.7:1.4",
      "pali": "Danto so parinibbuto ṭhitatto”ti."
    },
    {
      "id": "thag1.7:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā bhalliyo thero gāthaṁ abhāsitthāti."
    }
  ]
}
