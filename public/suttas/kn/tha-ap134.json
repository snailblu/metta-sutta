{
  "uid": "tha-ap134",
  "title": "Sudassanattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap134:1.1",
      "pali": "“Vinatā nadiyā tīre,"
    },
    {
      "id": "tha-ap134:1.2",
      "pali": "pilakkhu phalito ahu;"
    },
    {
      "id": "tha-ap134:1.3",
      "pali": "Tāhaṁ rukkhaṁ gavesanto,"
    },
    {
      "id": "tha-ap134:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap134:2.1",
      "pali": "Ketakaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap134:2.2",
      "pali": "vaṇṭe chetvānahaṁ tadā;"
    },
    {
      "id": "tha-ap134:2.3",
      "pali": "Buddhassa abhiropesiṁ,"
    },
    {
      "id": "tha-ap134:2.4",
      "pali": "sikhino lokabandhuno."
    },
    {
      "id": "tha-ap134:3.1",
      "pali": "Yena ñāṇena pattosi,"
    },
    {
      "id": "tha-ap134:3.2",
      "pali": "accutaṁ amataṁ padaṁ;"
    },
    {
      "id": "tha-ap134:3.3",
      "pali": "Taṁ ñāṇaṁ abhipūjemi,"
    },
    {
      "id": "tha-ap134:3.4",
      "pali": "buddhaseṭṭha mahāmuni."
    },
    {
      "id": "tha-ap134:4.1",
      "pali": "Ñāṇamhi pūjaṁ katvāna,"
    },
    {
      "id": "tha-ap134:4.2",
      "pali": "pilakkhumaddasaṁ ahaṁ;"
    },
    {
      "id": "tha-ap134:4.3",
      "pali": "Paṭiladdhomhi taṁ paññaṁ,"
    },
    {
      "id": "tha-ap134:4.4",
      "pali": "ñāṇapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap134:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap134:5.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap134:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap134:5.4",
      "pali": "ñāṇapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap134:6.1",
      "pali": "Ito terasakappamhi,"
    },
    {
      "id": "tha-ap134:6.2",
      "pali": "dvādasāsuṁ phaluggatā;"
    },
    {
      "id": "tha-ap134:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap134:6.4",
      "pali": "cakkavattī mahapphalā."
    },
    {
      "id": "tha-ap134:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap134:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap134:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap134:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā sudassano thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap134:9.1",
      "pali": "Sudassanattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
