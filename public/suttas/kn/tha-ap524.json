{
  "uid": "tha-ap524",
  "title": "2 Mañcadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap524:1.1",
      "pali": "“Vipassino bhagavato,"
    },
    {
      "id": "tha-ap524:1.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap524:1.3",
      "pali": "Ekamañcaṁ mayā dinnaṁ,"
    },
    {
      "id": "tha-ap524:1.4",
      "pali": "pasannena sapāṇinā."
    },
    {
      "id": "tha-ap524:2.1",
      "pali": "Hatthiyānaṁ assayānaṁ,"
    },
    {
      "id": "tha-ap524:2.2",
      "pali": "dibbayānaṁ samajjhagaṁ;"
    },
    {
      "id": "tha-ap524:2.3",
      "pali": "Tena mañcakadānena,"
    },
    {
      "id": "tha-ap524:2.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap524:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap524:3.2",
      "pali": "yaṁ mañcamadadiṁ tadā;"
    },
    {
      "id": "tha-ap524:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap524:3.4",
      "pali": "mañcadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap524:4.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap524:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap524:4.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap524:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap524:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap524:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap524:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap524:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap524:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap524:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā mañcadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap524:8.1",
      "pali": "Mañcadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
