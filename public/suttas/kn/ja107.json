{
  "uid": "ja107",
  "title": "Parosatavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja107:1.1",
      "pali": "“Sādhu kho sippakaṁ nāma,"
    },
    {
      "id": "ja107:1.2",
      "pali": "api yādisa kīdisaṁ;"
    },
    {
      "id": "ja107:1.3",
      "pali": "Passa khañjappahārena,"
    },
    {
      "id": "ja107:1.4",
      "pali": "laddhā gāmā catuddisā”ti."
    },
    {
      "id": "ja107:2.1",
      "pali": "Sālittakajātakaṁ sattamaṁ."
    }
  ]
}
