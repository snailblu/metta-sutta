{
  "uid": "ja362",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja362:1.1",
      "pali": "“Sīlaṁ seyyo sutaṁ seyyo,"
    },
    {
      "id": "ja362:1.2",
      "pali": "iti me saṁsayo ahu;"
    },
    {
      "id": "ja362:1.3",
      "pali": "Sīlameva sutā seyyo,"
    },
    {
      "id": "ja362:1.4",
      "pali": "iti me natthi saṁsayo."
    },
    {
      "id": "ja362:2.1",
      "pali": "Moghā jāti ca vaṇṇo ca,"
    },
    {
      "id": "ja362:2.2",
      "pali": "sīlameva kiruttamaṁ;"
    },
    {
      "id": "ja362:2.3",
      "pali": "Sīlena anupetassa,"
    },
    {
      "id": "ja362:2.4",
      "pali": "sutenattho na vijjati."
    },
    {
      "id": "ja362:3.1",
      "pali": "Khattiyo ca adhammaṭṭho,"
    },
    {
      "id": "ja362:3.2",
      "pali": "vesso cādhammanissito;"
    },
    {
      "id": "ja362:3.3",
      "pali": "Te pariccajjubho loke,"
    },
    {
      "id": "ja362:3.4",
      "pali": "upapajjanti duggatiṁ."
    },
    {
      "id": "ja362:4.1",
      "pali": "Khattiyā brāhmaṇā vessā,"
    },
    {
      "id": "ja362:4.2",
      "pali": "suddā caṇḍālapukkusā;"
    },
    {
      "id": "ja362:4.3",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "ja362:4.4",
      "pali": "bhavanti tidive samā."
    },
    {
      "id": "ja362:5.1",
      "pali": "Na vedā samparāyāya,"
    },
    {
      "id": "ja362:5.2",
      "pali": "Na jāti nāpi bandhavā;"
    },
    {
      "id": "ja362:5.3",
      "pali": "Sakañca sīlaṁ saṁsuddhaṁ,"
    },
    {
      "id": "ja362:5.4",
      "pali": "Samparāyāya sukhāya cā”ti."
    },
    {
      "id": "ja362:6.1",
      "pali": "Sīlavīmaṁsajātakaṁ dutiyaṁ."
    }
  ]
}
