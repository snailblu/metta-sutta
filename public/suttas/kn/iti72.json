{
  "uid": "iti72",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti72:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti72:2.1",
      "pali": "“Tisso imā, bhikkhave, nissaraṇiyā dhātuyo."
    },
    {
      "id": "iti72:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti72:2.3",
      "pali": "Kāmānametaṁ nissaraṇaṁ yadidaṁ nekkhammaṁ, rūpānametaṁ nissaraṇaṁ yadidaṁ āruppaṁ, yaṁ kho pana kiñci bhūtaṁ saṅkhataṁ paṭiccasamuppannaṁ nirodho tassa nissaraṇaṁ—"
    },
    {
      "id": "iti72:2.4",
      "pali": "imā kho, bhikkhave, tisso nissaraṇiyā dhātuyo”ti."
    },
    {
      "id": "iti72:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti72:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti72:3.1",
      "pali": "“Kāmanissaraṇaṁ ñatvā,"
    },
    {
      "id": "iti72:3.2",
      "pali": "rūpānañca atikkamaṁ;"
    },
    {
      "id": "iti72:3.3",
      "pali": "Sabbasaṅkhārasamathaṁ,"
    },
    {
      "id": "iti72:3.4",
      "pali": "phusaṁ ātāpi sabbadā."
    },
    {
      "id": "iti72:4.1",
      "pali": "Sa ve sammaddaso bhikkhu,"
    },
    {
      "id": "iti72:4.2",
      "pali": "yato tattha vimuccati;"
    },
    {
      "id": "iti72:4.3",
      "pali": "Abhiññāvosito santo,"
    },
    {
      "id": "iti72:4.4",
      "pali": "sa ve yogātigo munī”ti."
    },
    {
      "id": "iti72:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti72:5.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
