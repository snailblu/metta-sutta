{
  "uid": "thag4.1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.1:1.1",
      "pali": "“Alaṅkatā suvasanā,"
    },
    {
      "id": "thag4.1:1.2",
      "pali": "mālinī candanussadā;"
    },
    {
      "id": "thag4.1:1.3",
      "pali": "Majjhe mahāpathe nārī,"
    },
    {
      "id": "thag4.1:1.4",
      "pali": "tūriye naccati naṭṭakī."
    },
    {
      "id": "thag4.1:2.1",
      "pali": "Piṇḍikāya paviṭṭhohaṁ,"
    },
    {
      "id": "thag4.1:2.2",
      "pali": "gacchanto naṁ udikkhisaṁ;"
    },
    {
      "id": "thag4.1:2.3",
      "pali": "Alaṅkataṁ suvasanaṁ,"
    },
    {
      "id": "thag4.1:2.4",
      "pali": "maccupāsaṁva oḍḍitaṁ."
    },
    {
      "id": "thag4.1:3.1",
      "pali": "Tato me manasīkāro,"
    },
    {
      "id": "thag4.1:3.2",
      "pali": "yoniso udapajjatha;"
    },
    {
      "id": "thag4.1:3.3",
      "pali": "Ādīnavo pāturahu,"
    },
    {
      "id": "thag4.1:3.4",
      "pali": "nibbidā samatiṭṭhatha."
    },
    {
      "id": "thag4.1:4.1",
      "pali": "Tato cittaṁ vimucci me,"
    },
    {
      "id": "thag4.1:4.2",
      "pali": "passa dhammasudhammataṁ;"
    },
    {
      "id": "thag4.1:4.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thag4.1:4.4",
      "pali": "kataṁ buddhassa sāsanan”ti."
    },
    {
      "id": "thag4.1:4.5",
      "pali": "… Nāgasamālo thero …."
    }
  ]
}
