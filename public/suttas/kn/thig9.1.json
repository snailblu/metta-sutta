{
  "uid": "thig9.1",
  "title": "Vaḍḍhamātutherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig9.1:1.1",
      "pali": "“Mā su te vaḍḍha lokamhi,"
    },
    {
      "id": "thig9.1:1.2",
      "pali": "vanatho āhu kudācanaṁ;"
    },
    {
      "id": "thig9.1:1.3",
      "pali": "Mā puttaka punappunaṁ,"
    },
    {
      "id": "thig9.1:1.4",
      "pali": "ahu dukkhassa bhāgimā."
    },
    {
      "id": "thig9.1:2.1",
      "pali": "Sukhañhi vaḍḍha munayo,"
    },
    {
      "id": "thig9.1:2.2",
      "pali": "anejā chinnasaṁsayā;"
    },
    {
      "id": "thig9.1:2.3",
      "pali": "Sītibhūtā damappattā,"
    },
    {
      "id": "thig9.1:2.4",
      "pali": "viharanti anāsavā."
    },
    {
      "id": "thig9.1:3.1",
      "pali": "Tehānuciṇṇaṁ isībhi,"
    },
    {
      "id": "thig9.1:3.2",
      "pali": "maggaṁ dassanapattiyā;"
    },
    {
      "id": "thig9.1:3.3",
      "pali": "Dukkhassantakiriyāya,"
    },
    {
      "id": "thig9.1:3.4",
      "pali": "tvaṁ vaḍḍha anubrūhaya”."
    },
    {
      "id": "thig9.1:4.1",
      "pali": "“Visāradāva bhaṇasi,"
    },
    {
      "id": "thig9.1:4.2",
      "pali": "etamatthaṁ janetti me;"
    },
    {
      "id": "thig9.1:4.3",
      "pali": "Maññāmi nūna māmike,"
    },
    {
      "id": "thig9.1:4.4",
      "pali": "vanatho te na vijjati”."
    },
    {
      "id": "thig9.1:5.1",
      "pali": "“Ye keci vaḍḍha saṅkhārā,"
    },
    {
      "id": "thig9.1:5.2",
      "pali": "hīnā ukkaṭṭhamajjhimā;"
    },
    {
      "id": "thig9.1:5.3",
      "pali": "Aṇūpi aṇumattopi,"
    },
    {
      "id": "thig9.1:5.4",
      "pali": "vanatho me na vijjati."
    },
    {
      "id": "thig9.1:6.1",
      "pali": "Sabbe me āsavā khīṇā,"
    },
    {
      "id": "thig9.1:6.2",
      "pali": "appamattassa jhāyato;"
    },
    {
      "id": "thig9.1:6.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thig9.1:6.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thig9.1:7.1",
      "pali": "“Uḷāraṁ vata me mātā,"
    },
    {
      "id": "thig9.1:7.2",
      "pali": "patodaṁ samavassari;"
    },
    {
      "id": "thig9.1:7.3",
      "pali": "Paramatthasañhitā gāthā,"
    },
    {
      "id": "thig9.1:7.4",
      "pali": "yathāpi anukampikā."
    },
    {
      "id": "thig9.1:8.1",
      "pali": "Tassāhaṁ vacanaṁ sutvā,"
    },
    {
      "id": "thig9.1:8.2",
      "pali": "anusiṭṭhiṁ janettiyā;"
    },
    {
      "id": "thig9.1:8.3",
      "pali": "Dhammasaṁvegamāpādiṁ,"
    },
    {
      "id": "thig9.1:8.4",
      "pali": "yogakkhemassa pattiyā."
    },
    {
      "id": "thig9.1:9.1",
      "pali": "Sohaṁ padhānapahitatto,"
    },
    {
      "id": "thig9.1:9.2",
      "pali": "rattindivamatandito;"
    },
    {
      "id": "thig9.1:9.3",
      "pali": "Mātarā codito santo,"
    },
    {
      "id": "thig9.1:9.4",
      "pali": "aphusiṁ santimuttamaṁ”."
    },
    {
      "id": "thig9.1:10.1",
      "pali": "… Vaḍḍhamātā therī …."
    },
    {
      "id": "thig9.1:11.1",
      "pali": "Navakanipāto niṭṭhito."
    }
  ]
}
