{
  "uid": "vv60",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv60:1.1",
      "pali": "“Susukkakhandhaṁ abhiruyha nāgaṁ,"
    },
    {
      "id": "vv60:1.2",
      "pali": "Akācinaṁ dantiṁ baliṁ mahājavaṁ;"
    },
    {
      "id": "vv60:1.3",
      "pali": "Abhiruyha gajavaraṁ sukappitaṁ,"
    },
    {
      "id": "vv60:1.4",
      "pali": "Idhāgamā vehāyasaṁ antalikkhe."
    },
    {
      "id": "vv60:2.1",
      "pali": "Nāgassa dantesu duvesu nimmitā,"
    },
    {
      "id": "vv60:2.2",
      "pali": "Acchodakā paduminiyo suphullā;"
    },
    {
      "id": "vv60:2.3",
      "pali": "Padumesu ca tūriyagaṇā pavajjare,"
    },
    {
      "id": "vv60:2.4",
      "pali": "Imā ca naccanti manoharāyo."
    },
    {
      "id": "vv60:3.1",
      "pali": "Deviddhipattosi mahānubhāvo,"
    },
    {
      "id": "vv60:3.2",
      "pali": "Manussabhūto kimakāsi puññaṁ;"
    },
    {
      "id": "vv60:3.3",
      "pali": "Kenāsi evaṁ jalitānubhāvo,"
    },
    {
      "id": "vv60:3.4",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv60:4.1",
      "pali": "So devaputto attamano,"
    },
    {
      "id": "vv60:4.2",
      "pali": "moggallānena pucchito;"
    },
    {
      "id": "vv60:4.3",
      "pali": "Pañhaṁ puṭṭho viyākāsi,"
    },
    {
      "id": "vv60:4.4",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv60:5.1",
      "pali": "“Aṭṭheva muttapupphāni,"
    },
    {
      "id": "vv60:5.2",
      "pali": "kassapassa mahesino;"
    },
    {
      "id": "vv60:5.3",
      "pali": "Thūpasmiṁ abhiropesiṁ,"
    },
    {
      "id": "vv60:5.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "vv60:6.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv60:6.2",
      "pali": "…pe…"
    },
    {
      "id": "vv60:6.3",
      "pali": "vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv60:7.1",
      "pali": "Paṭhamanāgavimānaṁ dasamaṁ."
    }
  ]
}
