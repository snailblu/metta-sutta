{
  "uid": "tha-ap142",
  "title": "10 Piyālaphaladāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap142:1.1",
      "pali": "“Pārāvato tadā āsiṁ,"
    },
    {
      "id": "tha-ap142:1.2",
      "pali": "paraṁ anuparodhako;"
    },
    {
      "id": "tha-ap142:1.3",
      "pali": "Pabbhāre seyyaṁ kappemi,"
    },
    {
      "id": "tha-ap142:1.4",
      "pali": "avidūre sikhisatthuno."
    },
    {
      "id": "tha-ap142:2.1",
      "pali": "Sāyaṁ pātañca passāmi,"
    },
    {
      "id": "tha-ap142:2.2",
      "pali": "buddhaṁ lokagganāyakaṁ;"
    },
    {
      "id": "tha-ap142:2.3",
      "pali": "Deyyadhammo ca me natthi,"
    },
    {
      "id": "tha-ap142:2.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap142:3.1",
      "pali": "Piyālaphalamādāya,"
    },
    {
      "id": "tha-ap142:3.2",
      "pali": "agamaṁ buddhasantikaṁ;"
    },
    {
      "id": "tha-ap142:3.3",
      "pali": "Paṭiggahesi bhagavā,"
    },
    {
      "id": "tha-ap142:3.4",
      "pali": "lokajeṭṭho narāsabho."
    },
    {
      "id": "tha-ap142:4.1",
      "pali": "Tato paraṁ upādāya,"
    },
    {
      "id": "tha-ap142:4.2",
      "pali": "paricāriṁ vināyakaṁ;"
    },
    {
      "id": "tha-ap142:4.3",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap142:4.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap142:5.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap142:5.2",
      "pali": "yaṁ phalaṁ adadiṁ ahaṁ;"
    },
    {
      "id": "tha-ap142:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap142:5.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap142:6.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap142:6.2",
      "pali": "tayo āsuṁ piyālino;"
    },
    {
      "id": "tha-ap142:6.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap142:6.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap142:7.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap142:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap142:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap142:8.1",
      "pali": "Itthaṁ sudaṁ āyasmā piyālaphaladāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap142:9.1",
      "pali": "Piyālaphaladāyakattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap142:10.1",
      "pali": "Sobhitavaggo cuddasamo."
    },
    {
      "id": "tha-ap142:11.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap142:12.1",
      "pali": "Sobhitasudassano ca,"
    },
    {
      "id": "tha-ap142:12.2",
      "pali": "candano pupphachadano;"
    },
    {
      "id": "tha-ap142:12.3",
      "pali": "Raho campakapupphī ca,"
    },
    {
      "id": "tha-ap142:12.4",
      "pali": "atthasandassakena ca."
    },
    {
      "id": "tha-ap142:13.1",
      "pali": "Ekapasādī sāladado,"
    },
    {
      "id": "tha-ap142:13.2",
      "pali": "dasamo phaladāyako;"
    },
    {
      "id": "tha-ap142:13.3",
      "pali": "Gāthāyo sattati dve ca,"
    },
    {
      "id": "tha-ap142:13.4",
      "pali": "gaṇitāyo vibhāvibhi."
    }
  ]
}
