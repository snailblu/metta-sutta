{
  "uid": "thag1.73",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.73:1.1",
      "pali": "“Jiṇṇañca disvā dukhitañca byādhitaṁ,"
    },
    {
      "id": "thag1.73:1.2",
      "pali": "Matañca disvā gatamāyusaṅkhayaṁ;"
    },
    {
      "id": "thag1.73:1.3",
      "pali": "Tato ahaṁ nikkhamitūna pabbajiṁ,"
    },
    {
      "id": "thag1.73:1.4",
      "pali": "Pahāya kāmāni manoramānī”ti."
    },
    {
      "id": "thag1.73:1.5",
      "pali": "… Māṇavo thero …."
    }
  ]
}
