{
  "uid": "ja290",
  "title": "Abbhantaravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja290:1.1",
      "pali": "“Sīlaṁ kireva kalyāṇaṁ,"
    },
    {
      "id": "ja290:1.2",
      "pali": "sīlaṁ loke anuttaraṁ;"
    },
    {
      "id": "ja290:1.3",
      "pali": "Passa ghoraviso nāgo,"
    },
    {
      "id": "ja290:1.4",
      "pali": "sīlavāti na haññati."
    },
    {
      "id": "ja290:2.1",
      "pali": "Sohaṁ sīlaṁ samādissaṁ,"
    },
    {
      "id": "ja290:2.2",
      "pali": "loke anumataṁ sivaṁ;"
    },
    {
      "id": "ja290:2.3",
      "pali": "Ariyavuttisamācāro,"
    },
    {
      "id": "ja290:2.4",
      "pali": "yena vuccati sīlavā."
    },
    {
      "id": "ja290:3.1",
      "pali": "Ñātīnañca piyo hoti,"
    },
    {
      "id": "ja290:3.2",
      "pali": "mittesu ca virocati;"
    },
    {
      "id": "ja290:3.3",
      "pali": "Kāyassa bhedā sugatiṁ,"
    },
    {
      "id": "ja290:3.4",
      "pali": "upapajjati sīlavā”ti."
    },
    {
      "id": "ja290:4.1",
      "pali": "Sīlavīmaṁsakajātakaṁ dasamaṁ."
    },
    {
      "id": "ja290:4.2",
      "pali": "Abbhantaravaggo catuttho."
    },
    {
      "id": "ja290:5.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja290:6.1",
      "pali": "Duma kaṁsavaruttamabyagghamigā,"
    },
    {
      "id": "ja290:6.2",
      "pali": "Maṇayo maṇi sālukamavhayano;"
    },
    {
      "id": "ja290:6.3",
      "pali": "Anusāsaniyopi ca macchavaro,"
    },
    {
      "id": "ja290:6.4",
      "pali": "Maṇikuṇḍalakena kirena dasāti."
    }
  ]
}
