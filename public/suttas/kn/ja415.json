{
  "uid": "ja415",
  "title": "Gandhāravagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja415:1.1",
      "pali": "“Na kiratthi anomadassisu,"
    },
    {
      "id": "ja415:1.2",
      "pali": "Pāricariyā buddhesu appikā;"
    },
    {
      "id": "ja415:1.3",
      "pali": "Sukkhāya aloṇikāya ca,"
    },
    {
      "id": "ja415:1.4",
      "pali": "Passaphalaṁ kummāsapiṇḍiyā."
    },
    {
      "id": "ja415:2.1",
      "pali": "Hatthigavassā cime bahū,"
    },
    {
      "id": "ja415:2.2",
      "pali": "Dhanadhaññaṁ pathavī ca kevalā;"
    },
    {
      "id": "ja415:2.3",
      "pali": "Nāriyo cimā accharūpamā,"
    },
    {
      "id": "ja415:2.4",
      "pali": "Passa phalaṁ kummāsapiṇḍiyā”."
    },
    {
      "id": "ja415:3.1",
      "pali": "“Abhikkhaṇaṁ rājakuñjara,"
    },
    {
      "id": "ja415:3.2",
      "pali": "Gāthā bhāsasi kosalādhipa;"
    },
    {
      "id": "ja415:3.3",
      "pali": "Pucchāmi taṁ raṭṭhavaḍḍhana,"
    },
    {
      "id": "ja415:3.4",
      "pali": "Bāḷhaṁ pītimano pabhāsasi”."
    },
    {
      "id": "ja415:4.1",
      "pali": "“Imasmiññeva nagare,"
    },
    {
      "id": "ja415:4.2",
      "pali": "kule aññatare ahuṁ;"
    },
    {
      "id": "ja415:4.3",
      "pali": "Parakammakaro āsiṁ,"
    },
    {
      "id": "ja415:4.4",
      "pali": "bhatako sīlasaṁvuto."
    },
    {
      "id": "ja415:5.1",
      "pali": "Kammāya nikkhamantohaṁ,"
    },
    {
      "id": "ja415:5.2",
      "pali": "caturo samaṇeddasaṁ;"
    },
    {
      "id": "ja415:5.3",
      "pali": "Ācārasīlasampanne,"
    },
    {
      "id": "ja415:5.4",
      "pali": "sītibhūte anāsave."
    },
    {
      "id": "ja415:6.1",
      "pali": "Tesu cittaṁ pasādetvā,"
    },
    {
      "id": "ja415:6.2",
      "pali": "nisīdetvā paṇṇasanthate;"
    },
    {
      "id": "ja415:6.3",
      "pali": "Adaṁ buddhāna kummāsaṁ,"
    },
    {
      "id": "ja415:6.4",
      "pali": "pasanno sehi pāṇibhi."
    },
    {
      "id": "ja415:7.1",
      "pali": "Tassa kammassa kusalassa,"
    },
    {
      "id": "ja415:7.2",
      "pali": "idaṁ me edisaṁ phalaṁ;"
    },
    {
      "id": "ja415:7.3",
      "pali": "Anubhomi idaṁ rajjaṁ,"
    },
    {
      "id": "ja415:7.4",
      "pali": "phītaṁ dharaṇimuttamaṁ”."
    },
    {
      "id": "ja415:8.1",
      "pali": "“Dadaṁ bhuñja mā ca pamādo,"
    },
    {
      "id": "ja415:8.2",
      "pali": "Cakkaṁ vattaya kosalādhipa;"
    },
    {
      "id": "ja415:8.3",
      "pali": "Mā rāja adhammiko ahu,"
    },
    {
      "id": "ja415:8.4",
      "pali": "Dhammaṁ pālaya kosalādhipa”."
    },
    {
      "id": "ja415:9.1",
      "pali": "“Sohaṁ tadeva punappunaṁ,"
    },
    {
      "id": "ja415:9.2",
      "pali": "Vaṭumaṁ ācarissāmi sobhane;"
    },
    {
      "id": "ja415:9.3",
      "pali": "Ariyācaritaṁ sukosale,"
    },
    {
      "id": "ja415:9.4",
      "pali": "Arahanto me manāpāva passituṁ."
    },
    {
      "id": "ja415:10.1",
      "pali": "Devī viya accharūpamā,"
    },
    {
      "id": "ja415:10.2",
      "pali": "Majjhe nārigaṇassa sobhasi;"
    },
    {
      "id": "ja415:10.3",
      "pali": "Kiṁ kammamakāsi bhaddakaṁ,"
    },
    {
      "id": "ja415:10.4",
      "pali": "Kenāsi vaṇṇavatī sukosale”."
    },
    {
      "id": "ja415:11.1",
      "pali": "“Ambaṭṭhakulassa khattiya,"
    },
    {
      "id": "ja415:11.2",
      "pali": "Dāsyāhaṁ parapesiyā ahuṁ;"
    },
    {
      "id": "ja415:11.3",
      "pali": "Saññatā ca dhammajīvinī,"
    },
    {
      "id": "ja415:11.4",
      "pali": "Sīlavatī ca apāpadassanā."
    },
    {
      "id": "ja415:12.1",
      "pali": "Uddhaṭabhattaṁ ahaṁ tadā,"
    },
    {
      "id": "ja415:12.2",
      "pali": "Caramānassa adāsi bhikkhuno;"
    },
    {
      "id": "ja415:12.3",
      "pali": "Vittā sumanā sayaṁ ahaṁ,"
    },
    {
      "id": "ja415:12.4",
      "pali": "Tassa kammassa phalaṁ mamedisan”ti."
    },
    {
      "id": "ja415:13.1",
      "pali": "Kummāsapiṇḍijātakaṁ dasamaṁ."
    }
  ]
}
