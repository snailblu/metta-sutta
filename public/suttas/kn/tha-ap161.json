{
  "uid": "tha-ap161",
  "title": "Punnāgapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap161:1.1",
      "pali": "“Kānanaṁ vanamogayha,"
    },
    {
      "id": "tha-ap161:1.2",
      "pali": "vasāmi luddako ahaṁ;"
    },
    {
      "id": "tha-ap161:1.3",
      "pali": "Punnāgaṁ pupphitaṁ disvā,"
    },
    {
      "id": "tha-ap161:1.4",
      "pali": "buddhaseṭṭhaṁ anussariṁ."
    },
    {
      "id": "tha-ap161:2.1",
      "pali": "Taṁ pupphaṁ ocinitvāna,"
    },
    {
      "id": "tha-ap161:2.2",
      "pali": "sugandhaṁ gandhitaṁ subhaṁ;"
    },
    {
      "id": "tha-ap161:2.3",
      "pali": "Thūpaṁ karitvā puline,"
    },
    {
      "id": "tha-ap161:2.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap161:3.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap161:3.2",
      "pali": "yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap161:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap161:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap161:4.1",
      "pali": "Ekamhi navute kappe,"
    },
    {
      "id": "tha-ap161:4.2",
      "pali": "eko āsiṁ tamonudo;"
    },
    {
      "id": "tha-ap161:4.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap161:4.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap161:5.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap161:5.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap161:5.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap161:6.1",
      "pali": "Itthaṁ sudaṁ āyasmā punnāgapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap161:7.1",
      "pali": "Punnāgapupphiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
