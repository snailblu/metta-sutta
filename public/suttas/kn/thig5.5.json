{
  "uid": "thig5.5",
  "title": "Nanduttarātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig5.5:1.1",
      "pali": "“Aggiṁ candañca sūriyañca,"
    },
    {
      "id": "thig5.5:1.2",
      "pali": "devatā ca namassihaṁ;"
    },
    {
      "id": "thig5.5:1.3",
      "pali": "Nadītitthāni gantvāna,"
    },
    {
      "id": "thig5.5:1.4",
      "pali": "udakaṁ oruhāmihaṁ."
    },
    {
      "id": "thig5.5:2.1",
      "pali": "Bahūvatasamādānā,"
    },
    {
      "id": "thig5.5:2.2",
      "pali": "aḍḍhaṁ sīsassa olikhiṁ;"
    },
    {
      "id": "thig5.5:2.3",
      "pali": "Chamāya seyyaṁ kappemi,"
    },
    {
      "id": "thig5.5:2.4",
      "pali": "rattiṁ bhattaṁ na bhuñjahaṁ."
    },
    {
      "id": "thig5.5:3.1",
      "pali": "Vibhūsāmaṇḍanaratā,"
    },
    {
      "id": "thig5.5:3.2",
      "pali": "nhāpanucchādanehi ca;"
    },
    {
      "id": "thig5.5:3.3",
      "pali": "Upakāsiṁ imaṁ kāyaṁ,"
    },
    {
      "id": "thig5.5:3.4",
      "pali": "kāmarāgena aṭṭitā."
    },
    {
      "id": "thig5.5:4.1",
      "pali": "Tato saddhaṁ labhitvāna,"
    },
    {
      "id": "thig5.5:4.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "thig5.5:4.3",
      "pali": "Disvā kāyaṁ yathābhūtaṁ,"
    },
    {
      "id": "thig5.5:4.4",
      "pali": "kāmarāgo samūhato."
    },
    {
      "id": "thig5.5:5.1",
      "pali": "Sabbe bhavā samucchinnā,"
    },
    {
      "id": "thig5.5:5.2",
      "pali": "icchā ca patthanāpi ca;"
    },
    {
      "id": "thig5.5:5.3",
      "pali": "Sabbayogavisaṁyuttā,"
    },
    {
      "id": "thig5.5:5.4",
      "pali": "santiṁ pāpuṇi cetaso”ti."
    },
    {
      "id": "thig5.5:6.1",
      "pali": "… Nanduttarā therī …."
    }
  ]
}
