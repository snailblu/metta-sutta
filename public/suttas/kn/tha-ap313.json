{
  "uid": "tha-ap313",
  "title": "Ārakkhadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap313:1.1",
      "pali": "“Dhammadassissa munino,"
    },
    {
      "id": "tha-ap313:1.2",
      "pali": "vati kārāpitā mayā;"
    },
    {
      "id": "tha-ap313:1.3",
      "pali": "Ārakkho ca mayā dinno,"
    },
    {
      "id": "tha-ap313:1.4",
      "pali": "dvipadindassa tādino."
    },
    {
      "id": "tha-ap313:2.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap313:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap313:2.3",
      "pali": "Tena kammavisesena,"
    },
    {
      "id": "tha-ap313:2.4",
      "pali": "patto me āsavakkhayo."
    },
    {
      "id": "tha-ap313:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap313:3.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap313:3.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap313:3.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap313:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā ārakkhadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap313:5.1",
      "pali": "Ārakkhadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
