{
  "uid": "iti93",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti93:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti93:2.1",
      "pali": "“Tayome, bhikkhave, aggī."
    },
    {
      "id": "iti93:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti93:2.3",
      "pali": "Rāgaggi, dosaggi, mohaggi—"
    },
    {
      "id": "iti93:2.4",
      "pali": "ime kho, bhikkhave, tayo aggī”ti."
    },
    {
      "id": "iti93:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti93:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti93:3.1",
      "pali": "“Rāgaggi dahati macce,"
    },
    {
      "id": "iti93:3.2",
      "pali": "ratte kāmesu mucchite;"
    },
    {
      "id": "iti93:3.3",
      "pali": "Dosaggi pana byāpanne,"
    },
    {
      "id": "iti93:3.4",
      "pali": "nare pāṇātipātino."
    },
    {
      "id": "iti93:4.1",
      "pali": "Mohaggi pana sammūḷhe,"
    },
    {
      "id": "iti93:4.2",
      "pali": "ariyadhamme akovide;"
    },
    {
      "id": "iti93:4.3",
      "pali": "Ete aggī ajānantā,"
    },
    {
      "id": "iti93:4.4",
      "pali": "sakkāyābhiratā pajā."
    },
    {
      "id": "iti93:5.1",
      "pali": "Te vaḍḍhayanti nirayaṁ,"
    },
    {
      "id": "iti93:5.2",
      "pali": "tiracchānañca yoniyo;"
    },
    {
      "id": "iti93:5.3",
      "pali": "Asuraṁ pettivisayaṁ,"
    },
    {
      "id": "iti93:5.4",
      "pali": "amuttā mārabandhanā."
    },
    {
      "id": "iti93:6.1",
      "pali": "Ye ca rattindivā yuttā,"
    },
    {
      "id": "iti93:6.2",
      "pali": "sammāsambuddhasāsane;"
    },
    {
      "id": "iti93:6.3",
      "pali": "Te nibbāpenti rāgaggiṁ,"
    },
    {
      "id": "iti93:6.4",
      "pali": "niccaṁ asubhasaññino."
    },
    {
      "id": "iti93:7.1",
      "pali": "Dosaggiṁ pana mettāya,"
    },
    {
      "id": "iti93:7.2",
      "pali": "nibbāpenti naruttamā;"
    },
    {
      "id": "iti93:7.3",
      "pali": "Mohaggiṁ pana paññāya,"
    },
    {
      "id": "iti93:7.4",
      "pali": "yāyaṁ nibbedhagāminī."
    },
    {
      "id": "iti93:8.1",
      "pali": "Te nibbāpetvā nipakā,"
    },
    {
      "id": "iti93:8.2",
      "pali": "rattindivamatanditā;"
    },
    {
      "id": "iti93:8.3",
      "pali": "Asesaṁ parinibbanti,"
    },
    {
      "id": "iti93:8.4",
      "pali": "asesaṁ dukkhamaccaguṁ."
    },
    {
      "id": "iti93:9.1",
      "pali": "Ariyaddasā vedaguno,"
    },
    {
      "id": "iti93:9.2",
      "pali": "sammadaññāya paṇḍitā;"
    },
    {
      "id": "iti93:9.3",
      "pali": "Jātikkhayamabhiññāya,"
    },
    {
      "id": "iti93:9.4",
      "pali": "nāgacchanti punabbhavan”ti."
    },
    {
      "id": "iti93:10.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti93:10.2",
      "pali": "Catutthaṁ."
    }
  ]
}
