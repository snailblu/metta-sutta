{
  "uid": "iti108",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti108:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti108:2.1",
      "pali": "“Ye keci, bhikkhave, bhikkhū kuhā thaddhā lapā siṅgī unnaḷā asamāhitā, na me te, bhikkhave, bhikkhū māmakā."
    },
    {
      "id": "iti108:2.2",
      "pali": "Apagatā ca te, bhikkhave, bhikkhū imasmā dhammavinayā; na ca te imasmiṁ dhammavinaye vuddhiṁ virūḷhiṁ vepullaṁ āpajjanti."
    },
    {
      "id": "iti108:2.3",
      "pali": "Ye ca kho, bhikkhave, bhikkhū nikkuhā nillapā dhīrā atthaddhā susamāhitā, te kho me, bhikkhave, bhikkhū māmakā."
    },
    {
      "id": "iti108:2.4",
      "pali": "Anapagatā ca te, bhikkhave, bhikkhū imasmā dhammavinayā; te ca imasmiṁ dhammavinaye vuddhiṁ virūḷhiṁ vepullaṁ āpajjantī”ti."
    },
    {
      "id": "iti108:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti108:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti108:3.1",
      "pali": "“Kuhā thaddhā lapā siṅgī,"
    },
    {
      "id": "iti108:3.2",
      "pali": "unnaḷā asamāhitā;"
    },
    {
      "id": "iti108:3.3",
      "pali": "Na te dhamme virūhanti,"
    },
    {
      "id": "iti108:3.4",
      "pali": "sammāsambuddhadesite."
    },
    {
      "id": "iti108:4.1",
      "pali": "Nikkuhā nillapā dhīrā,"
    },
    {
      "id": "iti108:4.2",
      "pali": "atthaddhā susamāhitā;"
    },
    {
      "id": "iti108:4.3",
      "pali": "Te ve dhamme virūhanti,"
    },
    {
      "id": "iti108:4.4",
      "pali": "sammāsambuddhadesite”ti."
    },
    {
      "id": "iti108:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti108:5.2",
      "pali": "Navamaṁ."
    }
  ]
}
