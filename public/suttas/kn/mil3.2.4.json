{
  "uid": "mil3.2.4",
  "title": "4. Paṭisandahanapuggalavediyanapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.2.4:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.2.4:1.2",
      "pali": "“bhante nāgasena, yo na paṭisandahati, vedeti so kiñci dukkhaṁ vedanan”ti?"
    },
    {
      "id": "mil3.2.4:1.3",
      "pali": "Thero āha—"
    },
    {
      "id": "mil3.2.4:1.4",
      "pali": "“kiñci vedeti, kiñci na vedetī”ti."
    },
    {
      "id": "mil3.2.4:1.5",
      "pali": "“Kiṁ vedeti, kiṁ na vedetī”ti?"
    },
    {
      "id": "mil3.2.4:1.6",
      "pali": "“Kāyikaṁ, mahārāja, vedanaṁ vedeti, cetasikaṁ vedanaṁ na vedetī”ti."
    },
    {
      "id": "mil3.2.4:1.7",
      "pali": "“Kathaṁ, bhante, kāyikaṁ vedanaṁ vedeti, kathaṁ cetasikaṁ vedanaṁ na vedetī”ti?"
    },
    {
      "id": "mil3.2.4:1.8",
      "pali": "“Yo hetu yo paccayo kāyikāya dukkhavedanāya uppattiyā, tassa hetussa tassa paccayassa anuparamā kāyikaṁ dukkhavedanaṁ vedeti, yo hetu yo paccayo cetasikāya dukkhavedanāya uppattiyā, tassa hetussa tassa paccayassa uparamā cetasikaṁ dukkhavedanaṁ na vedeti."
    },
    {
      "id": "mil3.2.4:1.9",
      "pali": "Bhāsitampetaṁ, mahārāja, bhagavatā—"
    },
    {
      "id": "mil3.2.4:1.10",
      "pali": "‘so ekaṁ vedanaṁ vedeti kāyikaṁ na cetasikan’”ti."
    },
    {
      "id": "mil3.2.4:2.1",
      "pali": "“Bhante nāgasena, yo dukkhaṁ vedanaṁ vedeti, kasmā so na parinibbāyatī”ti?"
    },
    {
      "id": "mil3.2.4:2.2",
      "pali": "“Natthi, mahārāja, arahato anunayo vā paṭigho vā, na ca arahanto apakkaṁ pātenti paripākaṁ āgamenti paṇḍitā."
    },
    {
      "id": "mil3.2.4:2.3",
      "pali": "Bhāsitampetaṁ, mahārāja, therena sāriputtena dhammasenāpatinā—"
    },
    {
      "id": "mil3.2.4:3.1",
      "pali": "‘Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "mil3.2.4:3.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "mil3.2.4:3.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "mil3.2.4:3.4",
      "pali": "nibbisaṁ bhatako yathā."
    },
    {
      "id": "mil3.2.4:4.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "mil3.2.4:4.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "mil3.2.4:4.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "mil3.2.4:4.4",
      "pali": "sampajāno patissato’”ti."
    },
    {
      "id": "mil3.2.4:5.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.2.4:6.1",
      "pali": "Paṭisandahanapuggalavediyanapañho catuttho."
    }
  ]
}
