{
  "uid": "tha-ap146",
  "title": "Saparivāriyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap146:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap146:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap146:1.3",
      "pali": "Jalitvā aggikkhandhova,"
    },
    {
      "id": "tha-ap146:1.4",
      "pali": "sambuddho parinibbuto."
    },
    {
      "id": "tha-ap146:2.1",
      "pali": "Nibbute ca mahāvīre,"
    },
    {
      "id": "tha-ap146:2.2",
      "pali": "thūpo vitthāriko ahu;"
    },
    {
      "id": "tha-ap146:2.3",
      "pali": "Dūratova upaṭṭhenti,"
    },
    {
      "id": "tha-ap146:2.4",
      "pali": "dhātugehavaruttame."
    },
    {
      "id": "tha-ap146:3.1",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap146:3.2",
      "pali": "akaṁ candanavedikaṁ;"
    },
    {
      "id": "tha-ap146:3.3",
      "pali": "Dissati thūpakhandho ca,"
    },
    {
      "id": "tha-ap146:3.4",
      "pali": "thūpānucchaviko tadā."
    },
    {
      "id": "tha-ap146:4.1",
      "pali": "Bhave nibbattamānamhi,"
    },
    {
      "id": "tha-ap146:4.2",
      "pali": "devatte atha mānuse;"
    },
    {
      "id": "tha-ap146:4.3",
      "pali": "Omattaṁ me na passāmi,"
    },
    {
      "id": "tha-ap146:4.4",
      "pali": "pubbakammassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap146:5.1",
      "pali": "Pañcadasakappasate,"
    },
    {
      "id": "tha-ap146:5.2",
      "pali": "ito aṭṭha janā ahuṁ;"
    },
    {
      "id": "tha-ap146:5.3",
      "pali": "Sabbe samattanāmā te,"
    },
    {
      "id": "tha-ap146:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap146:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap146:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap146:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap146:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā saparivāriyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap146:8.1",
      "pali": "Saparivāriyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
