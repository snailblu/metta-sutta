{
  "uid": "tha-ap396",
  "title": "Madhudāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap396:1.1",
      "pali": "“Sindhuyā nadiyā tīre,"
    },
    {
      "id": "tha-ap396:1.2",
      "pali": "sukato assamo mama;"
    },
    {
      "id": "tha-ap396:1.3",
      "pali": "Tattha vācemahaṁ sisse,"
    },
    {
      "id": "tha-ap396:1.4",
      "pali": "itihāsaṁ salakkhaṇaṁ."
    },
    {
      "id": "tha-ap396:2.1",
      "pali": "Dhammakāmā vinītā te,"
    },
    {
      "id": "tha-ap396:2.2",
      "pali": "sotukāmā susāsanaṁ;"
    },
    {
      "id": "tha-ap396:2.3",
      "pali": "Chaḷaṅge pāramippattā,"
    },
    {
      "id": "tha-ap396:2.4",
      "pali": "sindhukūle vasanti te."
    },
    {
      "id": "tha-ap396:3.1",
      "pali": "Uppātagamane ceva,"
    },
    {
      "id": "tha-ap396:3.2",
      "pali": "lakkhaṇesu ca kovidā;"
    },
    {
      "id": "tha-ap396:3.3",
      "pali": "Uttamatthaṁ gavesantā,"
    },
    {
      "id": "tha-ap396:3.4",
      "pali": "vasanti vipine tadā."
    },
    {
      "id": "tha-ap396:4.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap396:4.2",
      "pali": "loke uppajji tāvade;"
    },
    {
      "id": "tha-ap396:4.3",
      "pali": "Amhākaṁ anukampanto,"
    },
    {
      "id": "tha-ap396:4.4",
      "pali": "upāgacchi vināyako."
    },
    {
      "id": "tha-ap396:5.1",
      "pali": "Upāgataṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap396:5.2",
      "pali": "sumedhaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap396:5.3",
      "pali": "Tiṇasanthārakaṁ katvā,"
    },
    {
      "id": "tha-ap396:5.4",
      "pali": "lokajeṭṭhassadāsahaṁ."
    },
    {
      "id": "tha-ap396:6.1",
      "pali": "Vipināto madhuṁ gayha,"
    },
    {
      "id": "tha-ap396:6.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap396:6.3",
      "pali": "Sambuddho paribhuñjitvā,"
    },
    {
      "id": "tha-ap396:6.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "tha-ap396:7.1",
      "pali": "‘Yo taṁ adāsi madhuṁ me,"
    },
    {
      "id": "tha-ap396:7.2",
      "pali": "pasanno sehi pāṇibhi;"
    },
    {
      "id": "tha-ap396:7.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap396:7.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap396:8.1",
      "pali": "Iminā madhudānena,"
    },
    {
      "id": "tha-ap396:8.2",
      "pali": "tiṇasanthārakena ca;"
    },
    {
      "id": "tha-ap396:8.3",
      "pali": "Tiṁsa kappasahassāni,"
    },
    {
      "id": "tha-ap396:8.4",
      "pali": "devaloke ramissati."
    },
    {
      "id": "tha-ap396:9.1",
      "pali": "Tiṁsa kappasahassamhi,"
    },
    {
      "id": "tha-ap396:9.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap396:9.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap396:9.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap396:10.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap396:10.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap396:10.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap396:10.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap396:11.1",
      "pali": "Devalokā idhāgantvā,"
    },
    {
      "id": "tha-ap396:11.2",
      "pali": "mātukucchiṁ upāgate;"
    },
    {
      "id": "tha-ap396:11.3",
      "pali": "Madhuvassaṁ pavassittha,"
    },
    {
      "id": "tha-ap396:11.4",
      "pali": "chādayaṁ madhunā mahiṁ."
    },
    {
      "id": "tha-ap396:12.1",
      "pali": "Mayi nikkhantamattamhi,"
    },
    {
      "id": "tha-ap396:12.2",
      "pali": "kucchiyā ca suduttarā;"
    },
    {
      "id": "tha-ap396:12.3",
      "pali": "Tatrāpi madhuvassaṁ me,"
    },
    {
      "id": "tha-ap396:12.4",
      "pali": "vassate niccakālikaṁ."
    },
    {
      "id": "tha-ap396:13.1",
      "pali": "Agārā abhinikkhamma,"
    },
    {
      "id": "tha-ap396:13.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap396:13.3",
      "pali": "Lābhī annassa pānassa,"
    },
    {
      "id": "tha-ap396:13.4",
      "pali": "madhudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap396:14.1",
      "pali": "Sabbakāmasamiddhohaṁ,"
    },
    {
      "id": "tha-ap396:14.2",
      "pali": "bhavitvā devamānuse;"
    },
    {
      "id": "tha-ap396:14.3",
      "pali": "Teneva madhudānena,"
    },
    {
      "id": "tha-ap396:14.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap396:15.1",
      "pali": "Vuṭṭhamhi deve caturaṅgule tiṇe,"
    },
    {
      "id": "tha-ap396:15.2",
      "pali": "Sampupphite dharaṇīruhe sañchanne;"
    },
    {
      "id": "tha-ap396:15.3",
      "pali": "Suññe ghare maṇḍaparukkhamūlake,"
    },
    {
      "id": "tha-ap396:15.4",
      "pali": "Vasāmi niccaṁ sukhito anāsavo."
    },
    {
      "id": "tha-ap396:16.1",
      "pali": "Majjhe mahante hīne ca,"
    },
    {
      "id": "tha-ap396:16.2",
      "pali": "bhave sabbe atikkamiṁ;"
    },
    {
      "id": "tha-ap396:16.3",
      "pali": "Ajja me āsavā khīṇā,"
    },
    {
      "id": "tha-ap396:16.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap396:17.1",
      "pali": "Tiṁsakappasahassamhi,"
    },
    {
      "id": "tha-ap396:17.2",
      "pali": "yaṁ dānamadadiṁ tadā;"
    },
    {
      "id": "tha-ap396:17.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap396:17.4",
      "pali": "madhudānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap396:18.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap396:18.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap396:18.3",
      "pali": "Sabbāsavā parikkhīṇā,"
    },
    {
      "id": "tha-ap396:18.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap396:19.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap396:19.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap396:19.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap396:20.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap396:20.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap396:20.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap396:21.1",
      "pali": "Itthaṁ sudaṁ āyasmā madhudāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap396:22.1",
      "pali": "Madhudāyakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
