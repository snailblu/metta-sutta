{
  "uid": "thag1.37",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.37:1.1",
      "pali": "“Nānājanapadaṁ yanti,"
    },
    {
      "id": "thag1.37:1.2",
      "pali": "Vicarantā asaññatā;"
    },
    {
      "id": "thag1.37:1.3",
      "pali": "Samādhiñca virādhenti,"
    },
    {
      "id": "thag1.37:1.4",
      "pali": "Kiṁsu raṭṭhacariyā karissati;"
    },
    {
      "id": "thag1.37:1.5",
      "pali": "Tasmā vineyya sārambhaṁ,"
    },
    {
      "id": "thag1.37:1.6",
      "pali": "Jhāyeyya apurakkhato”ti."
    },
    {
      "id": "thag1.37:1.7",
      "pali": "… Kumāputtattherassa sahāyako thero …."
    }
  ]
}
