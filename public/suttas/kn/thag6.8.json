{
  "uid": "thag6.8",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.8:1.1",
      "pali": "“Sudesito cakkhumatā,"
    },
    {
      "id": "thag6.8:1.2",
      "pali": "buddhenādiccabandhunā;"
    },
    {
      "id": "thag6.8:1.3",
      "pali": "Sabbasaṁyojanātīto,"
    },
    {
      "id": "thag6.8:1.4",
      "pali": "sabbavaṭṭavināsano."
    },
    {
      "id": "thag6.8:2.1",
      "pali": "Niyyāniko uttaraṇo,"
    },
    {
      "id": "thag6.8:2.2",
      "pali": "taṇhāmūlavisosano;"
    },
    {
      "id": "thag6.8:2.3",
      "pali": "Visamūlaṁ āghātanaṁ,"
    },
    {
      "id": "thag6.8:2.4",
      "pali": "chetvā pāpeti nibbutiṁ."
    },
    {
      "id": "thag6.8:3.1",
      "pali": "Aññāṇamūlabhedāya,"
    },
    {
      "id": "thag6.8:3.2",
      "pali": "kammayantavighāṭano;"
    },
    {
      "id": "thag6.8:3.3",
      "pali": "Viññāṇānaṁ pariggahe,"
    },
    {
      "id": "thag6.8:3.4",
      "pali": "ñāṇavajiranipātano."
    },
    {
      "id": "thag6.8:4.1",
      "pali": "Vedanānaṁ viññāpano,"
    },
    {
      "id": "thag6.8:4.2",
      "pali": "upādānappamocano;"
    },
    {
      "id": "thag6.8:4.3",
      "pali": "Bhavaṁ aṅgārakāsuṁva,"
    },
    {
      "id": "thag6.8:4.4",
      "pali": "ñāṇena anupassano."
    },
    {
      "id": "thag6.8:5.1",
      "pali": "Mahāraso sugambhīro,"
    },
    {
      "id": "thag6.8:5.2",
      "pali": "jarāmaccunivāraṇo;"
    },
    {
      "id": "thag6.8:5.3",
      "pali": "Ariyo aṭṭhaṅgiko maggo,"
    },
    {
      "id": "thag6.8:5.4",
      "pali": "dukkhūpasamano sivo."
    },
    {
      "id": "thag6.8:6.1",
      "pali": "Kammaṁ kammanti ñatvāna,"
    },
    {
      "id": "thag6.8:6.2",
      "pali": "vipākañca vipākato;"
    },
    {
      "id": "thag6.8:6.3",
      "pali": "Paṭiccuppannadhammānaṁ,"
    },
    {
      "id": "thag6.8:6.4",
      "pali": "yathāvālokadassano;"
    },
    {
      "id": "thag6.8:6.5",
      "pali": "Mahākhemaṅgamo santo,"
    },
    {
      "id": "thag6.8:6.6",
      "pali": "pariyosānabhaddako”ti."
    },
    {
      "id": "thag6.8:6.7",
      "pali": "… Migajālo thero …."
    }
  ]
}
