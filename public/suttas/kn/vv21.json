{
  "uid": "vv21",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv21:1.1",
      "pali": "“Caṇḍāli vanda pādāni,"
    },
    {
      "id": "vv21:1.2",
      "pali": "gotamassa yasassino;"
    },
    {
      "id": "vv21:1.3",
      "pali": "Tameva anukampāya,"
    },
    {
      "id": "vv21:1.4",
      "pali": "aṭṭhāsi isisattamo."
    },
    {
      "id": "vv21:2.1",
      "pali": "Abhippasādehi manaṁ,"
    },
    {
      "id": "vv21:2.2",
      "pali": "arahantamhi tādini;"
    },
    {
      "id": "vv21:2.3",
      "pali": "Khippaṁ pañjalikā vanda,"
    },
    {
      "id": "vv21:2.4",
      "pali": "parittaṁ tava jīvitan”ti."
    },
    {
      "id": "vv21:3.1",
      "pali": "Coditā bhāvitattena,"
    },
    {
      "id": "vv21:3.2",
      "pali": "sarīrantimadhārinā;"
    },
    {
      "id": "vv21:3.3",
      "pali": "Caṇḍālī vandi pādāni,"
    },
    {
      "id": "vv21:3.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv21:4.1",
      "pali": "Tamenaṁ avadhī gāvī,"
    },
    {
      "id": "vv21:4.2",
      "pali": "caṇḍāliṁ pañjaliṁ ṭhitaṁ;"
    },
    {
      "id": "vv21:4.3",
      "pali": "Namassamānaṁ sambuddhaṁ,"
    },
    {
      "id": "vv21:4.4",
      "pali": "andhakāre pabhaṅkaranti."
    },
    {
      "id": "vv21:5.1",
      "pali": "“Khīṇāsavaṁ vigatarajaṁ anejaṁ,"
    },
    {
      "id": "vv21:5.2",
      "pali": "Ekaṁ araññamhi raho nisinnaṁ;"
    },
    {
      "id": "vv21:5.3",
      "pali": "Deviddhipattā upasaṅkamitvā,"
    },
    {
      "id": "vv21:5.4",
      "pali": "Vandāmi taṁ vīra mahānubhāvan”ti."
    },
    {
      "id": "vv21:6.1",
      "pali": "“Suvaṇṇavaṇṇā jalitā mahāyasā,"
    },
    {
      "id": "vv21:6.2",
      "pali": "Vimānamoruyha anekacittā;"
    },
    {
      "id": "vv21:6.3",
      "pali": "Parivāritā accharāsaṅgaṇena,"
    },
    {
      "id": "vv21:6.4",
      "pali": "Kā tvaṁ subhe devate vandase maman”ti."
    },
    {
      "id": "vv21:7.1",
      "pali": "“Ahaṁ bhaddante caṇḍālī,"
    },
    {
      "id": "vv21:7.2",
      "pali": "tayā vīrena pesitā;"
    },
    {
      "id": "vv21:7.3",
      "pali": "Vandiṁ arahato pāde,"
    },
    {
      "id": "vv21:7.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv21:8.1",
      "pali": "Sāhaṁ vanditvā pādāni,"
    },
    {
      "id": "vv21:8.2",
      "pali": "cutā caṇḍālayoniyā;"
    },
    {
      "id": "vv21:8.3",
      "pali": "Vimānaṁ sabbato bhaddaṁ,"
    },
    {
      "id": "vv21:8.4",
      "pali": "upapannamhi nandane."
    },
    {
      "id": "vv21:9.1",
      "pali": "Accharānaṁ satasahassaṁ,"
    },
    {
      "id": "vv21:9.2",
      "pali": "purakkhatvāna tiṭṭhati;"
    },
    {
      "id": "vv21:9.3",
      "pali": "Tāsāhaṁ pavarā seṭṭhā,"
    },
    {
      "id": "vv21:9.4",
      "pali": "vaṇṇena yasasāyunā."
    },
    {
      "id": "vv21:10.1",
      "pali": "Pahūtakatakalyāṇā,"
    },
    {
      "id": "vv21:10.2",
      "pali": "Sampajānā paṭissatā;"
    },
    {
      "id": "vv21:10.3",
      "pali": "Muniṁ kāruṇikaṁ loke,"
    },
    {
      "id": "vv21:10.4",
      "pali": "Taṁ bhante vanditumāgatā”ti."
    },
    {
      "id": "vv21:11.1",
      "pali": "Idaṁ vatvāna caṇḍālī,"
    },
    {
      "id": "vv21:11.2",
      "pali": "kataññū katavedinī;"
    },
    {
      "id": "vv21:11.3",
      "pali": "Vanditvā arahato pāde,"
    },
    {
      "id": "vv21:11.4",
      "pali": "tatthevantaradhāyathāti."
    },
    {
      "id": "vv21:12.1",
      "pali": "Caṇḍālivimānaṁ catutthaṁ."
    }
  ]
}
