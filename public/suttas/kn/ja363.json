{
  "uid": "ja363",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja363:1.1",
      "pali": "“Hiriṁ tarantaṁ vijigucchamānaṁ,"
    },
    {
      "id": "ja363:1.2",
      "pali": "Tavāhamasmī iti bhāsamānaṁ;"
    },
    {
      "id": "ja363:1.3",
      "pali": "Seyyāni kammāni anādiyantaṁ,"
    },
    {
      "id": "ja363:1.4",
      "pali": "Neso mamanti iti naṁ vijaññā."
    },
    {
      "id": "ja363:2.1",
      "pali": "Yañhi kayirā tañhi vade,"
    },
    {
      "id": "ja363:2.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "ja363:2.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "ja363:2.4",
      "pali": "parijānanti paṇḍitā."
    },
    {
      "id": "ja363:3.1",
      "pali": "Na so mitto yo sadā appamatto,"
    },
    {
      "id": "ja363:3.2",
      "pali": "Bhedāsaṅkī randhamevānupassī;"
    },
    {
      "id": "ja363:3.3",
      "pali": "Yasmiñca setī urasīva putto,"
    },
    {
      "id": "ja363:3.4",
      "pali": "Sa ve mitto yo abhejjo parehi."
    },
    {
      "id": "ja363:4.1",
      "pali": "Pāmojjakaraṇaṁ ṭhānaṁ,"
    },
    {
      "id": "ja363:4.2",
      "pali": "pasaṁsāvahanaṁ sukhaṁ;"
    },
    {
      "id": "ja363:4.3",
      "pali": "Phalānisaṁso bhāveti,"
    },
    {
      "id": "ja363:4.4",
      "pali": "vahanto porisaṁ dhuraṁ."
    },
    {
      "id": "ja363:5.1",
      "pali": "Pavivekarasaṁ pitvā,"
    },
    {
      "id": "ja363:5.2",
      "pali": "rasaṁ upasamassa ca;"
    },
    {
      "id": "ja363:5.3",
      "pali": "Niddaro hoti nippāpo,"
    },
    {
      "id": "ja363:5.4",
      "pali": "dhammappītirasaṁ pivan”ti."
    },
    {
      "id": "ja363:6.1",
      "pali": "Hirijātakaṁ tatiyaṁ."
    }
  ]
}
