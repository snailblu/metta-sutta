{
  "uid": "ja354",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja354:1.1",
      "pali": "“Uragova tacaṁ jiṇṇaṁ,"
    },
    {
      "id": "ja354:1.2",
      "pali": "hitvā gacchati saṁ tanuṁ;"
    },
    {
      "id": "ja354:1.3",
      "pali": "Evaṁ sarīre nibbhoge,"
    },
    {
      "id": "ja354:1.4",
      "pali": "pete kālaṅkate sati."
    },
    {
      "id": "ja354:2.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "ja354:2.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "ja354:2.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja354:2.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "ja354:3.1",
      "pali": "“Anavhito tato āgā,"
    },
    {
      "id": "ja354:3.2",
      "pali": "ananuññāto ito gato;"
    },
    {
      "id": "ja354:3.3",
      "pali": "Yathāgato tathā gato,"
    },
    {
      "id": "ja354:3.4",
      "pali": "tattha kā paridevanā."
    },
    {
      "id": "ja354:4.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "ja354:4.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "ja354:4.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja354:4.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "ja354:5.1",
      "pali": "“Sace rode kisā assaṁ,"
    },
    {
      "id": "ja354:5.2",
      "pali": "tassā me kiṁ phalaṁ siyā;"
    },
    {
      "id": "ja354:5.3",
      "pali": "Ñātimittasuhajjānaṁ,"
    },
    {
      "id": "ja354:5.4",
      "pali": "bhiyyo no aratī siyā."
    },
    {
      "id": "ja354:6.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "ja354:6.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "ja354:6.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja354:6.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "ja354:7.1",
      "pali": "“Yathāpi dārako candaṁ,"
    },
    {
      "id": "ja354:7.2",
      "pali": "gacchantamanurodati;"
    },
    {
      "id": "ja354:7.3",
      "pali": "Evaṁsampadamevetaṁ,"
    },
    {
      "id": "ja354:7.4",
      "pali": "yo petamanusocati."
    },
    {
      "id": "ja354:8.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "ja354:8.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "ja354:8.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja354:8.4",
      "pali": "gato so tassa yā gati”."
    },
    {
      "id": "ja354:9.1",
      "pali": "“Yathāpi udakakumbho,"
    },
    {
      "id": "ja354:9.2",
      "pali": "bhinno appaṭisandhiyo;"
    },
    {
      "id": "ja354:9.3",
      "pali": "Evaṁsampadamevetaṁ,"
    },
    {
      "id": "ja354:9.4",
      "pali": "yo petamanusocati."
    },
    {
      "id": "ja354:10.1",
      "pali": "Ḍayhamāno na jānāti,"
    },
    {
      "id": "ja354:10.2",
      "pali": "ñātīnaṁ paridevitaṁ;"
    },
    {
      "id": "ja354:10.3",
      "pali": "Tasmā etaṁ na socāmi,"
    },
    {
      "id": "ja354:10.4",
      "pali": "gato so tassa yā gatī”ti."
    },
    {
      "id": "ja354:11.1",
      "pali": "Uragajātakaṁ catutthaṁ."
    }
  ]
}
