{
  "uid": "tha-ap233",
  "title": "Udakāsanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap233:1.1",
      "pali": "“Ārāmadvārā nikkhamma,"
    },
    {
      "id": "tha-ap233:1.2",
      "pali": "phalakaṁ santhariṁ ahaṁ;"
    },
    {
      "id": "tha-ap233:1.3",
      "pali": "Udakañca upaṭṭhāsiṁ,"
    },
    {
      "id": "tha-ap233:1.4",
      "pali": "uttamatthassa pattiyā."
    },
    {
      "id": "tha-ap233:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap233:2.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap233:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap233:2.4",
      "pali": "āsane codake phalaṁ."
    },
    {
      "id": "tha-ap233:3.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap233:3.2",
      "pali": "abhisāmasamavhayo;"
    },
    {
      "id": "tha-ap233:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap233:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap233:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap233:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap233:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap233:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap233:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā udakāsanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap233:6.1",
      "pali": "Udakāsanadāyakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
