{
  "uid": "tha-ap350",
  "title": "Tiṇamuṭṭhidāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap350:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap350:1.2",
      "pali": "lambako nāma pabbato;"
    },
    {
      "id": "tha-ap350:1.3",
      "pali": "Upatisso nāma sambuddho,"
    },
    {
      "id": "tha-ap350:1.4",
      "pali": "abbhokāsamhi caṅkami."
    },
    {
      "id": "tha-ap350:2.1",
      "pali": "Migaluddo tadā āsiṁ,"
    },
    {
      "id": "tha-ap350:2.2",
      "pali": "araññe kānane ahaṁ;"
    },
    {
      "id": "tha-ap350:2.3",
      "pali": "Disvāna taṁ devadevaṁ,"
    },
    {
      "id": "tha-ap350:2.4",
      "pali": "sayambhuṁ aparājitaṁ."
    },
    {
      "id": "tha-ap350:3.1",
      "pali": "Vippasannena cittena,"
    },
    {
      "id": "tha-ap350:3.2",
      "pali": "tadā tassa mahesino;"
    },
    {
      "id": "tha-ap350:3.3",
      "pali": "Nisīdanatthaṁ buddhassa,"
    },
    {
      "id": "tha-ap350:3.4",
      "pali": "tiṇamuṭṭhimadāsahaṁ."
    },
    {
      "id": "tha-ap350:4.1",
      "pali": "Datvāna devadevassa,"
    },
    {
      "id": "tha-ap350:4.2",
      "pali": "bhiyyo cittaṁ pasādayiṁ;"
    },
    {
      "id": "tha-ap350:4.3",
      "pali": "Sambuddhaṁ abhivādetvā,"
    },
    {
      "id": "tha-ap350:4.4",
      "pali": "pakkāmiṁ uttarāmukho."
    },
    {
      "id": "tha-ap350:5.1",
      "pali": "Aciraṁ gatamattaṁ maṁ,"
    },
    {
      "id": "tha-ap350:5.2",
      "pali": "migarājā apothayi;"
    },
    {
      "id": "tha-ap350:5.3",
      "pali": "Sīhena pothito santo,"
    },
    {
      "id": "tha-ap350:5.4",
      "pali": "tattha kālaṅkato ahaṁ."
    },
    {
      "id": "tha-ap350:6.1",
      "pali": "Āsanne me kataṁ kammaṁ,"
    },
    {
      "id": "tha-ap350:6.2",
      "pali": "buddhaseṭṭhe anāsave;"
    },
    {
      "id": "tha-ap350:6.3",
      "pali": "Sumutto saravegova,"
    },
    {
      "id": "tha-ap350:6.4",
      "pali": "devalokaṁ agañchahaṁ."
    },
    {
      "id": "tha-ap350:7.1",
      "pali": "Yūpo tattha subho āsi,"
    },
    {
      "id": "tha-ap350:7.2",
      "pali": "puññakammābhinimmito;"
    },
    {
      "id": "tha-ap350:7.3",
      "pali": "Sahassakaṇḍo satabheṇḍu,"
    },
    {
      "id": "tha-ap350:7.4",
      "pali": "dhajālu haritāmayo."
    },
    {
      "id": "tha-ap350:8.1",
      "pali": "Pabhā niddhāvate tassa,"
    },
    {
      "id": "tha-ap350:8.2",
      "pali": "sataraṁsīva uggato;"
    },
    {
      "id": "tha-ap350:8.3",
      "pali": "Ākiṇṇo devakaññāhi,"
    },
    {
      "id": "tha-ap350:8.4",
      "pali": "āmodiṁ kāmakāmahaṁ."
    },
    {
      "id": "tha-ap350:9.1",
      "pali": "Devalokā cavitvāna,"
    },
    {
      "id": "tha-ap350:9.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap350:9.3",
      "pali": "Āgantvāna manussattaṁ,"
    },
    {
      "id": "tha-ap350:9.4",
      "pali": "pattomhi āsavakkhayaṁ."
    },
    {
      "id": "tha-ap350:10.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap350:10.2",
      "pali": "nisīdanamadāsahaṁ;"
    },
    {
      "id": "tha-ap350:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap350:10.4",
      "pali": "tiṇamuṭṭhiyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap350:11.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap350:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap350:11.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap350:12.1",
      "pali": "Itthaṁ sudaṁ āyasmā tiṇamuṭṭhidāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap350:13.1",
      "pali": "Tiṇamuṭṭhidāyakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
