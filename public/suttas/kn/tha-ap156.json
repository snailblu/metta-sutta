{
  "uid": "tha-ap156",
  "title": "4 Kakkārupupphapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap156:1.1",
      "pali": "“Devaputto ahaṁ santo,"
    },
    {
      "id": "tha-ap156:1.2",
      "pali": "pūjayiṁ sikhināyakaṁ;"
    },
    {
      "id": "tha-ap156:1.3",
      "pali": "Kakkārupupphaṁ paggayha,"
    },
    {
      "id": "tha-ap156:1.4",
      "pali": "buddhassa abhiropayiṁ."
    },
    {
      "id": "tha-ap156:2.1",
      "pali": "Ekattiṁse ito kappe,"
    },
    {
      "id": "tha-ap156:2.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap156:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap156:2.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap156:3.1",
      "pali": "Ito ca navame kappe,"
    },
    {
      "id": "tha-ap156:3.2",
      "pali": "rājā sattuttamo ahuṁ;"
    },
    {
      "id": "tha-ap156:3.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap156:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap156:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap156:4.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap156:4.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap156:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā kakkārupupphapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap156:6.1",
      "pali": "Kakkārupupphapūjakattherassāpadānaṁ catutthaṁ."
    }
  ]
}
