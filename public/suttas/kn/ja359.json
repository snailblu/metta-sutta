{
  "uid": "ja359",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja359:1.1",
      "pali": "“Vikkama re haripāda,"
    },
    {
      "id": "ja359:1.2",
      "pali": "vikkama re mahāmiga;"
    },
    {
      "id": "ja359:1.3",
      "pali": "Chinda vārattikaṁ pāsaṁ,"
    },
    {
      "id": "ja359:1.4",
      "pali": "nāhaṁ ekā vane rame”."
    },
    {
      "id": "ja359:2.1",
      "pali": "“Vikkamāmi na pāremi,"
    },
    {
      "id": "ja359:2.2",
      "pali": "bhūmiṁ sumbhāmi vegasā;"
    },
    {
      "id": "ja359:2.3",
      "pali": "Daḷho vārattiko pāso,"
    },
    {
      "id": "ja359:2.4",
      "pali": "pādaṁ me parikantati”."
    },
    {
      "id": "ja359:3.1",
      "pali": "“Attharassu palāsāni,"
    },
    {
      "id": "ja359:3.2",
      "pali": "asiṁ nibbāha luddaka;"
    },
    {
      "id": "ja359:3.3",
      "pali": "Paṭhamaṁ maṁ vadhitvāna,"
    },
    {
      "id": "ja359:3.4",
      "pali": "hana pacchā mahāmigaṁ”."
    },
    {
      "id": "ja359:4.1",
      "pali": "“Na me sutaṁ vā diṭṭhaṁ vā,"
    },
    {
      "id": "ja359:4.2",
      "pali": "Bhāsantiṁ mānusiṁ migiṁ;"
    },
    {
      "id": "ja359:4.3",
      "pali": "Tvañca bhadde sukhī hohi,"
    },
    {
      "id": "ja359:4.4",
      "pali": "Eso cāpi mahāmigo”."
    },
    {
      "id": "ja359:5.1",
      "pali": "“Evaṁ luddaka nandassu,"
    },
    {
      "id": "ja359:5.2",
      "pali": "saha sabbehi ñātibhi;"
    },
    {
      "id": "ja359:5.3",
      "pali": "Yathāhamajja nandāmi,"
    },
    {
      "id": "ja359:5.4",
      "pali": "muttaṁ disvā mahāmigan”ti."
    },
    {
      "id": "ja359:6.1",
      "pali": "Suvaṇṇamigajātakaṁ navamaṁ."
    }
  ]
}
