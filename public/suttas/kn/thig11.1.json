{
  "uid": "thig11.1",
  "title": "Uppalavaṇṇātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig11.1:1.1",
      "pali": "“Ubho mātā ca dhītā ca,"
    },
    {
      "id": "thig11.1:1.2",
      "pali": "mayaṁ āsuṁ sapattiyo;"
    },
    {
      "id": "thig11.1:1.3",
      "pali": "Tassā me ahu saṁvego,"
    },
    {
      "id": "thig11.1:1.4",
      "pali": "abbhuto lomahaṁsano."
    },
    {
      "id": "thig11.1:2.1",
      "pali": "Dhiratthu kāmā asucī,"
    },
    {
      "id": "thig11.1:2.2",
      "pali": "duggandhā bahukaṇṭakā;"
    },
    {
      "id": "thig11.1:2.3",
      "pali": "Yattha mātā ca dhītā ca,"
    },
    {
      "id": "thig11.1:2.4",
      "pali": "sabhariyā mayaṁ ahuṁ."
    },
    {
      "id": "thig11.1:3.1",
      "pali": "Kāmesvādīnavaṁ disvā,"
    },
    {
      "id": "thig11.1:3.2",
      "pali": "nekkhammaṁ daṭṭhu khemato;"
    },
    {
      "id": "thig11.1:3.3",
      "pali": "Sā pabbajjiṁ rājagahe,"
    },
    {
      "id": "thig11.1:3.4",
      "pali": "agārasmānagāriyaṁ."
    },
    {
      "id": "thig11.1:4.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "thig11.1:4.2",
      "pali": "dibbacakkhu visodhitaṁ;"
    },
    {
      "id": "thig11.1:4.3",
      "pali": "Cetopariccañāṇañca,"
    },
    {
      "id": "thig11.1:4.4",
      "pali": "sotadhātu visodhitā."
    },
    {
      "id": "thig11.1:5.1",
      "pali": "Iddhīpi me sacchikatā,"
    },
    {
      "id": "thig11.1:5.2",
      "pali": "patto me āsavakkhayo;"
    },
    {
      "id": "thig11.1:5.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thig11.1:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig11.1:6.1",
      "pali": "Iddhiyā abhinimmitvā,"
    },
    {
      "id": "thig11.1:6.2",
      "pali": "caturassaṁ rathaṁ ahaṁ;"
    },
    {
      "id": "thig11.1:6.3",
      "pali": "Buddhassa pāde vanditvā,"
    },
    {
      "id": "thig11.1:6.4",
      "pali": "lokanāthassa tādino”."
    },
    {
      "id": "thig11.1:7.1",
      "pali": "“Supupphitaggaṁ upagamma pādapaṁ,"
    },
    {
      "id": "thig11.1:7.2",
      "pali": "Ekā tuvaṁ tiṭṭhasi sālamūle;"
    },
    {
      "id": "thig11.1:7.3",
      "pali": "Na cāpi te dutiyo atthi koci,"
    },
    {
      "id": "thig11.1:7.4",
      "pali": "Bāle na tvaṁ bhāyasi dhuttakānaṁ”."
    },
    {
      "id": "thig11.1:8.1",
      "pali": "“Sataṁ sahassānipi dhuttakānaṁ,"
    },
    {
      "id": "thig11.1:8.2",
      "pali": "Samāgatā edisakā bhaveyyuṁ;"
    },
    {
      "id": "thig11.1:8.3",
      "pali": "Lomaṁ na iñje napi sampavedhe,"
    },
    {
      "id": "thig11.1:8.4",
      "pali": "Kiṁ me tuvaṁ māra karissaseko."
    },
    {
      "id": "thig11.1:9.1",
      "pali": "Esā antaradhāyāmi,"
    },
    {
      "id": "thig11.1:9.2",
      "pali": "kucchiṁ vā pavisāmi te;"
    },
    {
      "id": "thig11.1:9.3",
      "pali": "Bhamukantare tiṭṭhāmi,"
    },
    {
      "id": "thig11.1:9.4",
      "pali": "tiṭṭhantiṁ maṁ na dakkhasi."
    },
    {
      "id": "thig11.1:10.1",
      "pali": "Cittamhi vasībhūtāhaṁ,"
    },
    {
      "id": "thig11.1:10.2",
      "pali": "iddhipādā subhāvitā;"
    },
    {
      "id": "thig11.1:10.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thig11.1:10.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thig11.1:11.1",
      "pali": "Sattisūlūpamā kāmā,"
    },
    {
      "id": "thig11.1:11.2",
      "pali": "khandhāsaṁ adhikuṭṭanā;"
    },
    {
      "id": "thig11.1:11.3",
      "pali": "Yaṁ tvaṁ ‘kāmaratiṁ’ brūsi,"
    },
    {
      "id": "thig11.1:11.4",
      "pali": "‘āratī’ dāni sā mama."
    },
    {
      "id": "thig11.1:12.1",
      "pali": "Sabbattha vihatā nandī,"
    },
    {
      "id": "thig11.1:12.2",
      "pali": "Tamokhandho padālito;"
    },
    {
      "id": "thig11.1:12.3",
      "pali": "Evaṁ jānāhi pāpima,"
    },
    {
      "id": "thig11.1:12.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "thig11.1:13.1",
      "pali": "… Uppalavaṇṇā therī …."
    },
    {
      "id": "thig11.1:14.1",
      "pali": "Dvādasakanipāto niṭṭhito."
    }
  ]
}
