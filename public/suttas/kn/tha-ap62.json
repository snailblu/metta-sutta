{
  "uid": "tha-ap62",
  "title": "Asanabodhiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap62:1.1",
      "pali": "“Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap62:1.2",
      "pali": "addasaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap62:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap62:1.4",
      "pali": "upagacchiṁ naruttamaṁ."
    },
    {
      "id": "tha-ap62:2.1",
      "pali": "Tissassāhaṁ bhagavato,"
    },
    {
      "id": "tha-ap62:2.2",
      "pali": "lokajeṭṭhassa tādino;"
    },
    {
      "id": "tha-ap62:2.3",
      "pali": "Haṭṭho haṭṭhena cittena,"
    },
    {
      "id": "tha-ap62:2.4",
      "pali": "ropayiṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap62:3.1",
      "pali": "Asano nāmadheyyena,"
    },
    {
      "id": "tha-ap62:3.2",
      "pali": "dharaṇīruhapādapo;"
    },
    {
      "id": "tha-ap62:3.3",
      "pali": "Pañcavasse paricariṁ,"
    },
    {
      "id": "tha-ap62:3.4",
      "pali": "asanaṁ bodhimuttamaṁ."
    },
    {
      "id": "tha-ap62:4.1",
      "pali": "Pupphitaṁ pādapaṁ disvā,"
    },
    {
      "id": "tha-ap62:4.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "tha-ap62:4.3",
      "pali": "Sakaṁ kammaṁ pakittento,"
    },
    {
      "id": "tha-ap62:4.4",
      "pali": "buddhaseṭṭhaṁ upāgamiṁ."
    },
    {
      "id": "tha-ap62:5.1",
      "pali": "Tisso tadā so sambuddho,"
    },
    {
      "id": "tha-ap62:5.2",
      "pali": "sayambhū aggapuggalo;"
    },
    {
      "id": "tha-ap62:5.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap62:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap62:6.1",
      "pali": "‘Yenāyaṁ ropitā bodhi,"
    },
    {
      "id": "tha-ap62:6.2",
      "pali": "buddhapūjā ca sakkatā;"
    },
    {
      "id": "tha-ap62:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap62:6.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap62:7.1",
      "pali": "Tiṁsakappāni devesu,"
    },
    {
      "id": "tha-ap62:7.2",
      "pali": "devarajjaṁ karissati;"
    },
    {
      "id": "tha-ap62:7.3",
      "pali": "Catusaṭṭhi cakkhattuṁ so,"
    },
    {
      "id": "tha-ap62:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap62:8.1",
      "pali": "Tusitā hi cavitvāna,"
    },
    {
      "id": "tha-ap62:8.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap62:8.3",
      "pali": "Dve sampattī anubhotvā,"
    },
    {
      "id": "tha-ap62:8.4",
      "pali": "manussatte ramissati."
    },
    {
      "id": "tha-ap62:9.1",
      "pali": "Padhānapahitatto so,"
    },
    {
      "id": "tha-ap62:9.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap62:9.3",
      "pali": "Sabbāsave pariññāya,"
    },
    {
      "id": "tha-ap62:9.4",
      "pali": "nibbāyissatināsavo’."
    },
    {
      "id": "tha-ap62:10.1",
      "pali": "Vivekamanuyuttohaṁ,"
    },
    {
      "id": "tha-ap62:10.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap62:10.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap62:10.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap62:11.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap62:11.2",
      "pali": "bodhiṁ ropesahaṁ tadā;"
    },
    {
      "id": "tha-ap62:11.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap62:11.4",
      "pali": "bodhiropassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap62:12.1",
      "pali": "Catusattatito kappe,"
    },
    {
      "id": "tha-ap62:12.2",
      "pali": "daṇḍasenoti vissuto;"
    },
    {
      "id": "tha-ap62:12.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap62:12.4",
      "pali": "cakkavattī tadā ahuṁ."
    },
    {
      "id": "tha-ap62:13.1",
      "pali": "Tesattatimhito kappe,"
    },
    {
      "id": "tha-ap62:13.2",
      "pali": "sattāhesuṁ mahīpatī;"
    },
    {
      "id": "tha-ap62:13.3",
      "pali": "Samantanemināmena,"
    },
    {
      "id": "tha-ap62:13.4",
      "pali": "rājāno cakkavattino."
    },
    {
      "id": "tha-ap62:14.1",
      "pali": "Paṇṇavīsatito kappe,"
    },
    {
      "id": "tha-ap62:14.2",
      "pali": "puṇṇako nāma khattiyo;"
    },
    {
      "id": "tha-ap62:14.3",
      "pali": "Sattaratanasampanno,"
    },
    {
      "id": "tha-ap62:14.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap62:15.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap62:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap62:15.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap62:16.1",
      "pali": "Itthaṁ sudaṁ āyasmā asanabodhiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap62:17.1",
      "pali": "Asanabodhiyattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap62:18.1",
      "pali": "Bījanivaggo chaṭṭho."
    },
    {
      "id": "tha-ap62:19.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap62:20.1",
      "pali": "Bījanī sataraṁsī ca,"
    },
    {
      "id": "tha-ap62:20.2",
      "pali": "sayanodakivāhiyo;"
    },
    {
      "id": "tha-ap62:20.3",
      "pali": "Parivāro padīpañca,"
    },
    {
      "id": "tha-ap62:20.4",
      "pali": "dhajo padumapūjako;"
    },
    {
      "id": "tha-ap62:20.5",
      "pali": "Bodhi ca dasamo vutto,"
    },
    {
      "id": "tha-ap62:20.6",
      "pali": "gāthā dvenavuti tathā."
    }
  ]
}
