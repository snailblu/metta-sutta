{
  "uid": "thag1.72",
  "title": "Aṭṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.72:1.1",
      "pali": "“Yathā kaḷīro susu vaḍḍhitaggo,"
    },
    {
      "id": "thag1.72:1.2",
      "pali": "Dunnikkhamo hoti pasākhajāto;"
    },
    {
      "id": "thag1.72:1.3",
      "pali": "Evaṁ ahaṁ bhariyāyānitāya,"
    },
    {
      "id": "thag1.72:1.4",
      "pali": "Anumaññaṁ maṁ pabbajitomhi dānī”ti."
    },
    {
      "id": "thag1.72:1.5",
      "pali": "… Ātumo thero …."
    }
  ]
}
