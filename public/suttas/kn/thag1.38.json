{
  "uid": "thag1.38",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.38:1.1",
      "pali": "“Yo iddhiyā sarabhuṁ aṭṭhapesi,"
    },
    {
      "id": "thag1.38:1.2",
      "pali": "So gavampati asito anejo;"
    },
    {
      "id": "thag1.38:1.3",
      "pali": "Taṁ sabbasaṅgātigataṁ mahāmuniṁ,"
    },
    {
      "id": "thag1.38:1.4",
      "pali": "Devā namassanti bhavassa pāragun”ti."
    },
    {
      "id": "thag1.38:1.5",
      "pali": "… Gavampatitthero …."
    }
  ]
}
