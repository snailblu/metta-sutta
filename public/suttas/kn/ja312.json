{
  "uid": "ja312",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja312:1.1",
      "pali": "“Api kassapa mandiyā,"
    },
    {
      "id": "ja312:1.2",
      "pali": "yuvā sapati hanti vā;"
    },
    {
      "id": "ja312:1.3",
      "pali": "Sabbaṁ taṁ khamate dhīro,"
    },
    {
      "id": "ja312:1.4",
      "pali": "paṇḍito taṁ titikkhati."
    },
    {
      "id": "ja312:2.1",
      "pali": "Sacepi santo vivadanti,"
    },
    {
      "id": "ja312:2.2",
      "pali": "khippaṁ sandhīyare puna;"
    },
    {
      "id": "ja312:2.3",
      "pali": "Bālā pattāva bhijjanti,"
    },
    {
      "id": "ja312:2.4",
      "pali": "na te samathamajjhagū."
    },
    {
      "id": "ja312:3.1",
      "pali": "Ete bhiyyo samāyanti,"
    },
    {
      "id": "ja312:3.2",
      "pali": "sandhi tesaṁ na jīrati;"
    },
    {
      "id": "ja312:3.3",
      "pali": "Yo cādhipannaṁ jānāti,"
    },
    {
      "id": "ja312:3.4",
      "pali": "yo ca jānāti desanaṁ."
    },
    {
      "id": "ja312:4.1",
      "pali": "Eso hi uttaritaro,"
    },
    {
      "id": "ja312:4.2",
      "pali": "Bhāravaho dhuraddharo;"
    },
    {
      "id": "ja312:4.3",
      "pali": "Yo paresādhipannānaṁ,"
    },
    {
      "id": "ja312:4.4",
      "pali": "Sayaṁ sandhātumarahatī”ti."
    },
    {
      "id": "ja312:5.1",
      "pali": "Kassapamandiyajātakaṁ dutiyaṁ."
    }
  ]
}
