{
  "uid": "tha-ap164",
  "title": "Kaṇaverapupphiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap164:1.1",
      "pali": "“Siddhattho nāma bhagavā,"
    },
    {
      "id": "tha-ap164:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap164:1.3",
      "pali": "Purakkhato sāvakehi,"
    },
    {
      "id": "tha-ap164:1.4",
      "pali": "nagaraṁ paṭipajjatha."
    },
    {
      "id": "tha-ap164:2.1",
      "pali": "Rañño antepure āsiṁ,"
    },
    {
      "id": "tha-ap164:2.2",
      "pali": "gopako abhisammato;"
    },
    {
      "id": "tha-ap164:2.3",
      "pali": "Pāsāde upaviṭṭhohaṁ,"
    },
    {
      "id": "tha-ap164:2.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap164:3.1",
      "pali": "Kaṇaveraṁ gahetvāna,"
    },
    {
      "id": "tha-ap164:3.2",
      "pali": "bhikkhusaṅghe samokiriṁ;"
    },
    {
      "id": "tha-ap164:3.3",
      "pali": "Buddhassa visuṁ katvāna,"
    },
    {
      "id": "tha-ap164:3.4",
      "pali": "tato bhiyyo samokiriṁ."
    },
    {
      "id": "tha-ap164:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap164:4.2",
      "pali": "Yaṁ pupphamabhipūjayiṁ;"
    },
    {
      "id": "tha-ap164:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap164:4.4",
      "pali": "Buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap164:5.1",
      "pali": "Sattāsītimhito kappe,"
    },
    {
      "id": "tha-ap164:5.2",
      "pali": "caturāsuṁ mahiddhikā;"
    },
    {
      "id": "tha-ap164:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap164:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap164:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap164:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap164:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap164:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā kaṇaverapupphiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap164:8.1",
      "pali": "Kaṇaverapupphiyattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
