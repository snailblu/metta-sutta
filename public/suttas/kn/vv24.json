{
  "uid": "vv24",
  "title": "Cittalatāvagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv24:1.1",
      "pali": "“Abhikkantena vaṇṇena,"
    },
    {
      "id": "vv24:1.2",
      "pali": "yā tvaṁ tiṭṭhasi devate;"
    },
    {
      "id": "vv24:1.3",
      "pali": "Obhāsentī disā sabbā,"
    },
    {
      "id": "vv24:1.4",
      "pali": "osadhī viya tārakā."
    },
    {
      "id": "vv24:2.1",
      "pali": "Kena tetādiso vaṇṇo,"
    },
    {
      "id": "vv24:2.2",
      "pali": "…pe…"
    },
    {
      "id": "vv24:2.3",
      "pali": "Vaṇṇo ca te sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv24:3.1",
      "pali": "Sā devatā attamanā,"
    },
    {
      "id": "vv24:3.2",
      "pali": "…pe…"
    },
    {
      "id": "vv24:3.3",
      "pali": "yassa kammassidaṁ phalaṁ."
    },
    {
      "id": "vv24:4.1",
      "pali": "“Uposathāti maṁ aññaṁsu,"
    },
    {
      "id": "vv24:4.2",
      "pali": "sāketāyaṁ upāsikā;"
    },
    {
      "id": "vv24:4.3",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "vv24:4.4",
      "pali": "saṁvibhāgaratā sadā."
    },
    {
      "id": "vv24:5.1",
      "pali": "Acchādanañca bhattañca,"
    },
    {
      "id": "vv24:5.2",
      "pali": "senāsanaṁ padīpiyaṁ;"
    },
    {
      "id": "vv24:5.3",
      "pali": "Adāsiṁ ujubhūtesu,"
    },
    {
      "id": "vv24:5.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "vv24:6.1",
      "pali": "Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "vv24:6.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "vv24:6.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "vv24:6.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "vv24:7.1",
      "pali": "Uposathaṁ upavasissaṁ,"
    },
    {
      "id": "vv24:7.2",
      "pali": "sadā sīlesu saṁvutā;"
    },
    {
      "id": "vv24:7.3",
      "pali": "Saññamā saṁvibhāgā ca,"
    },
    {
      "id": "vv24:7.4",
      "pali": "vimānaṁ āvasāmahaṁ."
    },
    {
      "id": "vv24:8.1",
      "pali": "Pāṇātipātā viratā,"
    },
    {
      "id": "vv24:8.2",
      "pali": "musāvādā ca saññatā;"
    },
    {
      "id": "vv24:8.3",
      "pali": "Theyyā ca aticārā ca,"
    },
    {
      "id": "vv24:8.4",
      "pali": "majjapānā ca ārakā."
    },
    {
      "id": "vv24:9.1",
      "pali": "Pañcasikkhāpade ratā,"
    },
    {
      "id": "vv24:9.2",
      "pali": "ariyasaccāna kovidā;"
    },
    {
      "id": "vv24:9.3",
      "pali": "Upāsikā cakkhumato,"
    },
    {
      "id": "vv24:9.4",
      "pali": "gotamassa yasassino."
    },
    {
      "id": "vv24:10.1",
      "pali": "Tena metādiso vaṇṇo,"
    },
    {
      "id": "vv24:10.2",
      "pali": "…pe…"
    },
    {
      "id": "vv24:10.3",
      "pali": "Vaṇṇo ca me sabbadisā pabhāsatī”ti."
    },
    {
      "id": "vv24:11.1",
      "pali": "“Abhikkhaṇaṁ nandanaṁ sutvā,"
    },
    {
      "id": "vv24:11.2",
      "pali": "Chando me udapajjatha;"
    },
    {
      "id": "vv24:11.3",
      "pali": "Tattha cittaṁ paṇidhāya,"
    },
    {
      "id": "vv24:11.4",
      "pali": "Upapannāmhi nandanaṁ."
    },
    {
      "id": "vv24:12.1",
      "pali": "Nākāsiṁ satthu vacanaṁ,"
    },
    {
      "id": "vv24:12.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "vv24:12.3",
      "pali": "Hīne cittaṁ paṇidhāya,"
    },
    {
      "id": "vv24:12.4",
      "pali": "sāmhi pacchānutāpinī”ti."
    },
    {
      "id": "vv24:13.1",
      "pali": "“Kīva ciraṁ vimānamhi,"
    },
    {
      "id": "vv24:13.2",
      "pali": "idha vacchasuposathe;"
    },
    {
      "id": "vv24:13.3",
      "pali": "Devate pucchitācikkha,"
    },
    {
      "id": "vv24:13.4",
      "pali": "yadi jānāsi āyuno”ti."
    },
    {
      "id": "vv24:14.1",
      "pali": "“Saṭṭhi vassasahassāni,"
    },
    {
      "id": "vv24:14.2",
      "pali": "tisso ca vassakoṭiyo;"
    },
    {
      "id": "vv24:14.3",
      "pali": "Idha ṭhatvā mahāmuni,"
    },
    {
      "id": "vv24:14.4",
      "pali": "ito cutā gamissāmi;"
    },
    {
      "id": "vv24:14.5",
      "pali": "Manussānaṁ sahabyatan”ti."
    },
    {
      "id": "vv24:15.1",
      "pali": "“Mā tvaṁ uposathe bhāyi,"
    },
    {
      "id": "vv24:15.2",
      "pali": "sambuddhenāsi byākatā;"
    },
    {
      "id": "vv24:15.3",
      "pali": "Sotāpannā visesayi,"
    },
    {
      "id": "vv24:15.4",
      "pali": "pahīnā tava duggatī”ti."
    },
    {
      "id": "vv24:16.1",
      "pali": "Uposathāvimānaṁ sattamaṁ."
    }
  ]
}
