{
  "uid": "tha-ap543",
  "title": "1 Lakuṇḍabhaddiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap543:1.1",
      "pali": "“Padumuttaro nāma jino,"
    },
    {
      "id": "tha-ap543:1.2",
      "pali": "sabbadhammesu cakkhumā;"
    },
    {
      "id": "tha-ap543:1.3",
      "pali": "Ito satasahassamhi,"
    },
    {
      "id": "tha-ap543:1.4",
      "pali": "kappe uppajji nāyako."
    },
    {
      "id": "tha-ap543:2.1",
      "pali": "Tadāhaṁ haṁsavatiyaṁ,"
    },
    {
      "id": "tha-ap543:2.2",
      "pali": "seṭṭhiputto mahaddhano;"
    },
    {
      "id": "tha-ap543:2.3",
      "pali": "Jaṅghāvihāraṁ vicaraṁ,"
    },
    {
      "id": "tha-ap543:2.4",
      "pali": "saṅghārāmaṁ agacchahaṁ."
    },
    {
      "id": "tha-ap543:3.1",
      "pali": "Tadā so lokapajjoto,"
    },
    {
      "id": "tha-ap543:3.2",
      "pali": "dhammaṁ desesi nāyako;"
    },
    {
      "id": "tha-ap543:3.3",
      "pali": "Mañjussarānaṁ pavaraṁ,"
    },
    {
      "id": "tha-ap543:3.4",
      "pali": "sāvakaṁ abhikittayi."
    },
    {
      "id": "tha-ap543:4.1",
      "pali": "Taṁ sutvā mudito hutvā,"
    },
    {
      "id": "tha-ap543:4.2",
      "pali": "kāraṁ katvā mahesino;"
    },
    {
      "id": "tha-ap543:4.3",
      "pali": "Vanditvā satthuno pāde,"
    },
    {
      "id": "tha-ap543:4.4",
      "pali": "taṁ ṭhānamabhipatthayiṁ."
    },
    {
      "id": "tha-ap543:5.1",
      "pali": "Tadā buddho viyākāsi,"
    },
    {
      "id": "tha-ap543:5.2",
      "pali": "saṅghamajjhe vināyako;"
    },
    {
      "id": "tha-ap543:5.3",
      "pali": "‘Anāgatamhi addhāne,"
    },
    {
      "id": "tha-ap543:5.4",
      "pali": "lacchase taṁ manorathaṁ."
    },
    {
      "id": "tha-ap543:6.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap543:6.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap543:6.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap543:6.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap543:7.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap543:7.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap543:7.3",
      "pali": "Bhaddiyo nāma nāmena,"
    },
    {
      "id": "tha-ap543:7.4",
      "pali": "hessati satthu sāvako’."
    },
    {
      "id": "tha-ap543:8.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap543:8.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap543:8.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap543:8.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap543:9.1",
      "pali": "Dvenavute ito kappe,"
    },
    {
      "id": "tha-ap543:9.2",
      "pali": "phusso uppajji nāyako;"
    },
    {
      "id": "tha-ap543:9.3",
      "pali": "Durāsado duppasaho,"
    },
    {
      "id": "tha-ap543:9.4",
      "pali": "sabbalokuttamo jino."
    },
    {
      "id": "tha-ap543:10.1",
      "pali": "Caraṇena ca sampanno,"
    },
    {
      "id": "tha-ap543:10.2",
      "pali": "brahā uju patāpavā;"
    },
    {
      "id": "tha-ap543:10.3",
      "pali": "Hitesī sabbasattānaṁ,"
    },
    {
      "id": "tha-ap543:10.4",
      "pali": "bahuṁ mocesi bandhanā."
    },
    {
      "id": "tha-ap543:11.1",
      "pali": "Nandārāmavane tassa,"
    },
    {
      "id": "tha-ap543:11.2",
      "pali": "ahosiṁ phussakokilo;"
    },
    {
      "id": "tha-ap543:11.3",
      "pali": "Gandhakuṭisamāsanne,"
    },
    {
      "id": "tha-ap543:11.4",
      "pali": "ambarukkhe vasāmahaṁ."
    },
    {
      "id": "tha-ap543:12.1",
      "pali": "Tadā piṇḍāya gacchantaṁ,"
    },
    {
      "id": "tha-ap543:12.2",
      "pali": "dakkhiṇeyyaṁ jinuttamaṁ;"
    },
    {
      "id": "tha-ap543:12.3",
      "pali": "Disvā cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap543:12.4",
      "pali": "mañjunābhinikūjahaṁ."
    },
    {
      "id": "tha-ap543:13.1",
      "pali": "Rājuyyānaṁ tadā gantvā,"
    },
    {
      "id": "tha-ap543:13.2",
      "pali": "supakkaṁ kanakattacaṁ;"
    },
    {
      "id": "tha-ap543:13.3",
      "pali": "Ambapiṇḍaṁ gahetvāna,"
    },
    {
      "id": "tha-ap543:13.4",
      "pali": "sambuddhassopanāmayiṁ."
    },
    {
      "id": "tha-ap543:14.1",
      "pali": "Tadā me cittamaññāya,"
    },
    {
      "id": "tha-ap543:14.2",
      "pali": "mahākāruṇiko jino;"
    },
    {
      "id": "tha-ap543:14.3",
      "pali": "Upaṭṭhākassa hatthato,"
    },
    {
      "id": "tha-ap543:14.4",
      "pali": "pattaṁ paggaṇhi nāyako."
    },
    {
      "id": "tha-ap543:15.1",
      "pali": "Adāsiṁ haṭṭhacittohaṁ,"
    },
    {
      "id": "tha-ap543:15.2",
      "pali": "ambapiṇḍaṁ mahāmune;"
    },
    {
      "id": "tha-ap543:15.3",
      "pali": "Patte pakkhippa pakkhehi,"
    },
    {
      "id": "tha-ap543:15.4",
      "pali": "pañjaliṁ katvāna mañjunā."
    },
    {
      "id": "tha-ap543:16.1",
      "pali": "Sarena rajanīyena,"
    },
    {
      "id": "tha-ap543:16.2",
      "pali": "savanīyena vaggunā;"
    },
    {
      "id": "tha-ap543:16.3",
      "pali": "Vassanto buddhapūjatthaṁ,"
    },
    {
      "id": "tha-ap543:16.4",
      "pali": "nīḷaṁ gantvā nipajjahaṁ."
    },
    {
      "id": "tha-ap543:17.1",
      "pali": "Tadā muditacittaṁ maṁ,"
    },
    {
      "id": "tha-ap543:17.2",
      "pali": "buddhapemagatāsayaṁ;"
    },
    {
      "id": "tha-ap543:17.3",
      "pali": "Sakuṇagghi upāgantvā,"
    },
    {
      "id": "tha-ap543:17.4",
      "pali": "ghātayī duṭṭhamānaso."
    },
    {
      "id": "tha-ap543:18.1",
      "pali": "Tato cutohaṁ tusite,"
    },
    {
      "id": "tha-ap543:18.2",
      "pali": "anubhotvā mahāsukhaṁ;"
    },
    {
      "id": "tha-ap543:18.3",
      "pali": "Manussayonimāgacchiṁ,"
    },
    {
      "id": "tha-ap543:18.4",
      "pali": "tassa kammassa vāhasā."
    },
    {
      "id": "tha-ap543:19.1",
      "pali": "Imamhi bhaddake kappe,"
    },
    {
      "id": "tha-ap543:19.2",
      "pali": "brahmabandhu mahāyaso;"
    },
    {
      "id": "tha-ap543:19.3",
      "pali": "Kassapo nāma gottena,"
    },
    {
      "id": "tha-ap543:19.4",
      "pali": "uppajji vadataṁ varo."
    },
    {
      "id": "tha-ap543:20.1",
      "pali": "Sāsanaṁ jotayitvā so,"
    },
    {
      "id": "tha-ap543:20.2",
      "pali": "abhibhuyya kutitthiye;"
    },
    {
      "id": "tha-ap543:20.3",
      "pali": "Vinayitvāna veneyye,"
    },
    {
      "id": "tha-ap543:20.4",
      "pali": "nibbuto so sasāvako."
    },
    {
      "id": "tha-ap543:21.1",
      "pali": "Nibbute tamhi lokagge,"
    },
    {
      "id": "tha-ap543:21.2",
      "pali": "pasannā janatā bahū;"
    },
    {
      "id": "tha-ap543:21.3",
      "pali": "Pūjanatthāya buddhassa,"
    },
    {
      "id": "tha-ap543:21.4",
      "pali": "thūpaṁ kubbanti satthuno."
    },
    {
      "id": "tha-ap543:22.1",
      "pali": "‘Sattayojanikaṁ thūpaṁ,"
    },
    {
      "id": "tha-ap543:22.2",
      "pali": "sattaratanabhūsitaṁ;"
    },
    {
      "id": "tha-ap543:22.3",
      "pali": "Karissāma mahesissa’,"
    },
    {
      "id": "tha-ap543:22.4",
      "pali": "iccevaṁ mantayanti te."
    },
    {
      "id": "tha-ap543:23.1",
      "pali": "Kikino kāsirājassa,"
    },
    {
      "id": "tha-ap543:23.2",
      "pali": "tadā senāya nāyako;"
    },
    {
      "id": "tha-ap543:23.3",
      "pali": "Hutvāhaṁ appamāṇassa,"
    },
    {
      "id": "tha-ap543:23.4",
      "pali": "pamāṇaṁ cetiye vadiṁ."
    },
    {
      "id": "tha-ap543:24.1",
      "pali": "Tadā te mama vākyena,"
    },
    {
      "id": "tha-ap543:24.2",
      "pali": "cetiyaṁ yojanuggataṁ;"
    },
    {
      "id": "tha-ap543:24.3",
      "pali": "Akaṁsu naravīrassa,"
    },
    {
      "id": "tha-ap543:24.4",
      "pali": "nānāratanabhūsitaṁ."
    },
    {
      "id": "tha-ap543:25.1",
      "pali": "Tena kammena sukatena,"
    },
    {
      "id": "tha-ap543:25.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap543:25.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap543:25.4",
      "pali": "tāvatiṁsamagacchahaṁ."
    },
    {
      "id": "tha-ap543:26.1",
      "pali": "Pacchime ca bhave dāni,"
    },
    {
      "id": "tha-ap543:26.2",
      "pali": "jāto seṭṭhikule ahaṁ;"
    },
    {
      "id": "tha-ap543:26.3",
      "pali": "Sāvatthiyaṁ puravare,"
    },
    {
      "id": "tha-ap543:26.4",
      "pali": "iddhe phīte mahaddhane."
    },
    {
      "id": "tha-ap543:27.1",
      "pali": "Purappavese sugataṁ,"
    },
    {
      "id": "tha-ap543:27.2",
      "pali": "disvā vimhitamānaso;"
    },
    {
      "id": "tha-ap543:27.3",
      "pali": "Pabbajitvāna na ciraṁ,"
    },
    {
      "id": "tha-ap543:27.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap543:28.1",
      "pali": "Cetiyassa pamāṇaṁ yaṁ,"
    },
    {
      "id": "tha-ap543:28.2",
      "pali": "akariṁ tena kammunā;"
    },
    {
      "id": "tha-ap543:28.3",
      "pali": "Lakuṇḍakasarīrohaṁ,"
    },
    {
      "id": "tha-ap543:28.4",
      "pali": "jāto paribhavāraho."
    },
    {
      "id": "tha-ap543:29.1",
      "pali": "Sarena madhurenāhaṁ,"
    },
    {
      "id": "tha-ap543:29.2",
      "pali": "pūjitvā isisattamaṁ;"
    },
    {
      "id": "tha-ap543:29.3",
      "pali": "Mañjussarānaṁ bhikkhūnaṁ,"
    },
    {
      "id": "tha-ap543:29.4",
      "pali": "aggattamanupāpuṇiṁ."
    },
    {
      "id": "tha-ap543:30.1",
      "pali": "Phaladānena buddhassa,"
    },
    {
      "id": "tha-ap543:30.2",
      "pali": "guṇānussaraṇena ca;"
    },
    {
      "id": "tha-ap543:30.3",
      "pali": "Sāmaññaphalasampanno,"
    },
    {
      "id": "tha-ap543:30.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap543:31.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap543:31.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "tha-ap543:31.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap543:31.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap543:32.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap543:32.2",
      "pali": "buddhaseṭṭhassa santike;"
    },
    {
      "id": "tha-ap543:32.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "tha-ap543:32.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap543:33.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap543:33.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap543:33.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap543:33.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap543:34.1",
      "pali": "Itthaṁ sudaṁ āyasmā lakuṇḍabhaddiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap543:35.1",
      "pali": "Lakuṇḍabhaddiyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
