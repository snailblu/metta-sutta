{
  "uid": "tha-ap347",
  "title": "Naḷāgārikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap347:1.1",
      "pali": "“Himavantassāvidūre,"
    },
    {
      "id": "tha-ap347:1.2",
      "pali": "hārito nāma pabbato;"
    },
    {
      "id": "tha-ap347:1.3",
      "pali": "Sayambhū nārado nāma,"
    },
    {
      "id": "tha-ap347:1.4",
      "pali": "rukkhamūle vasī tadā."
    },
    {
      "id": "tha-ap347:2.1",
      "pali": "Naḷāgāraṁ karitvāna,"
    },
    {
      "id": "tha-ap347:2.2",
      "pali": "tiṇena chādayiṁ ahaṁ;"
    },
    {
      "id": "tha-ap347:2.3",
      "pali": "Caṅkamaṁ sodhayitvāna,"
    },
    {
      "id": "tha-ap347:2.4",
      "pali": "sayambhussa adāsahaṁ."
    },
    {
      "id": "tha-ap347:3.1",
      "pali": "Catuddasasu kappesu,"
    },
    {
      "id": "tha-ap347:3.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap347:3.3",
      "pali": "Catusattatikkhattuñca,"
    },
    {
      "id": "tha-ap347:3.4",
      "pali": "devarajjaṁ akārayiṁ."
    },
    {
      "id": "tha-ap347:4.1",
      "pali": "Catusattatikkhattuñca,"
    },
    {
      "id": "tha-ap347:4.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap347:4.3",
      "pali": "Padesarajjaṁ vipulaṁ,"
    },
    {
      "id": "tha-ap347:4.4",
      "pali": "gaṇanāto asaṅkhiyaṁ."
    },
    {
      "id": "tha-ap347:5.1",
      "pali": "Ubbiddhaṁ bhavanaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap347:5.2",
      "pali": "Indalaṭṭhīva uggataṁ;"
    },
    {
      "id": "tha-ap347:5.3",
      "pali": "Sahassathambhaṁ atulaṁ,"
    },
    {
      "id": "tha-ap347:5.4",
      "pali": "Vimānaṁ sapabhassaraṁ."
    },
    {
      "id": "tha-ap347:6.1",
      "pali": "Dve sampattī anubhotvā,"
    },
    {
      "id": "tha-ap347:6.2",
      "pali": "sukkamūlena codito;"
    },
    {
      "id": "tha-ap347:6.3",
      "pali": "Gotamassa bhagavato,"
    },
    {
      "id": "tha-ap347:6.4",
      "pali": "sāsane pabbajiṁ ahaṁ."
    },
    {
      "id": "tha-ap347:7.1",
      "pali": "Padhānapahitattomhi,"
    },
    {
      "id": "tha-ap347:7.2",
      "pali": "upasanto nirūpadhi;"
    },
    {
      "id": "tha-ap347:7.3",
      "pali": "Nāgova bandhanaṁ chetvā,"
    },
    {
      "id": "tha-ap347:7.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap347:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap347:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap347:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap347:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā naḷāgāriko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap347:10.1",
      "pali": "Naḷāgārikattherassāpadānaṁ pañcamaṁ."
    }
  ]
}
