{
  "uid": "mil3.5.3",
  "title": "3. Buddhassaanuttarabhāvajānanapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.5.3:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.5.3:1.2",
      "pali": "“bhante nāgasena, sakkā jānituṁ ‘buddho anuttaro’”ti?"
    },
    {
      "id": "mil3.5.3:1.3",
      "pali": "“Āma, mahārāja, sakkā jānituṁ ‘bhagavā anuttaro’”ti."
    },
    {
      "id": "mil3.5.3:1.4",
      "pali": "“Kathaṁ, bhante nāgasena, sakkā jānituṁ ‘buddho anuttaro’”ti?"
    },
    {
      "id": "mil3.5.3:1.5",
      "pali": "“Bhūtapubbaṁ, mahārāja, tissatthero nāma lekhācariyo ahosi, bahūni vassāni abbhatītāni kālaṅkatassa kathaṁ so ñāyatī”ti."
    },
    {
      "id": "mil3.5.3:1.6",
      "pali": "“Lekhena, bhante”ti."
    },
    {
      "id": "mil3.5.3:1.7",
      "pali": "“Evameva kho, mahārāja, yo dhammaṁ passati, so bhagavantaṁ passati, dhammo hi, mahārāja, bhagavatā desito”ti."
    },
    {
      "id": "mil3.5.3:2.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.5.3:3.1",
      "pali": "Buddhassa anuttarabhāvajānanapañho tatiyo."
    }
  ]
}
