{
  "uid": "thag8.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag8.2:1.1",
      "pali": "“Akkodhanonupanāhī,"
    },
    {
      "id": "thag8.2:1.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "thag8.2:1.3",
      "pali": "Sa ve tādisako bhikkhu,"
    },
    {
      "id": "thag8.2:1.4",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "thag8.2:2.1",
      "pali": "Akkodhanonupanāhī,"
    },
    {
      "id": "thag8.2:2.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "thag8.2:2.3",
      "pali": "Guttadvāro sadā bhikkhu,"
    },
    {
      "id": "thag8.2:2.4",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "thag8.2:3.1",
      "pali": "Akkodhanonupanāhī,"
    },
    {
      "id": "thag8.2:3.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "thag8.2:3.3",
      "pali": "Kalyāṇasīlo so bhikkhu,"
    },
    {
      "id": "thag8.2:3.4",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "thag8.2:4.1",
      "pali": "Akkodhanonupanāhī,"
    },
    {
      "id": "thag8.2:4.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "thag8.2:4.3",
      "pali": "Kalyāṇamitto so bhikkhu,"
    },
    {
      "id": "thag8.2:4.4",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "thag8.2:5.1",
      "pali": "Akkodhanonupanāhī,"
    },
    {
      "id": "thag8.2:5.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "thag8.2:5.3",
      "pali": "Kalyāṇapañño so bhikkhu,"
    },
    {
      "id": "thag8.2:5.4",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "thag8.2:6.1",
      "pali": "Yassa saddhā tathāgate,"
    },
    {
      "id": "thag8.2:6.2",
      "pali": "acalā suppatiṭṭhitā;"
    },
    {
      "id": "thag8.2:6.3",
      "pali": "Sīlañca yassa kalyāṇaṁ,"
    },
    {
      "id": "thag8.2:6.4",
      "pali": "ariyakantaṁ pasaṁsitaṁ."
    },
    {
      "id": "thag8.2:7.1",
      "pali": "Saṅghe pasādo yassatthi,"
    },
    {
      "id": "thag8.2:7.2",
      "pali": "ujubhūtañca dassanaṁ;"
    },
    {
      "id": "thag8.2:7.3",
      "pali": "‘Adaliddo’ti taṁ āhu,"
    },
    {
      "id": "thag8.2:7.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "thag8.2:8.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "thag8.2:8.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "thag8.2:8.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "thag8.2:8.4",
      "pali": "saraṁ buddhāna sāsanan”ti."
    },
    {
      "id": "thag8.2:8.5",
      "pali": "… Sirimitto thero …."
    }
  ]
}
