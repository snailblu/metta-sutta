{
  "uid": "ja333",
  "title": "Kokilavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja333:1.1",
      "pali": "“Tadeva me tvaṁ vidito,"
    },
    {
      "id": "ja333:1.2",
      "pali": "vanamajjhe rathesabha;"
    },
    {
      "id": "ja333:1.3",
      "pali": "Yassa te khaggabaddhassa,"
    },
    {
      "id": "ja333:1.4",
      "pali": "sannaddhassa tirīṭino;"
    },
    {
      "id": "ja333:1.5",
      "pali": "Assatthadumasākhāya,"
    },
    {
      "id": "ja333:1.6",
      "pali": "pakkā godhā palāyatha”."
    },
    {
      "id": "ja333:2.1",
      "pali": "“Name namantassa bhaje bhajantaṁ,"
    },
    {
      "id": "ja333:2.2",
      "pali": "Kiccānukubbassa kareyya kiccaṁ;"
    },
    {
      "id": "ja333:2.3",
      "pali": "Nānatthakāmassa kareyya atthaṁ,"
    },
    {
      "id": "ja333:2.4",
      "pali": "Asambhajantampi na sambhajeyya."
    },
    {
      "id": "ja333:3.1",
      "pali": "Caje cajantaṁ vanathaṁ na kayirā,"
    },
    {
      "id": "ja333:3.2",
      "pali": "Apetacittena na sambhajeyya;"
    },
    {
      "id": "ja333:3.3",
      "pali": "Dijo dumaṁ khīṇaphalanti ñatvā,"
    },
    {
      "id": "ja333:3.4",
      "pali": "Aññaṁ samekkheyya mahā hi loko”."
    },
    {
      "id": "ja333:4.1",
      "pali": "“So te karissāmi yathānubhāvaṁ,"
    },
    {
      "id": "ja333:4.2",
      "pali": "Kataññutaṁ khattiye pekkhamāno;"
    },
    {
      "id": "ja333:4.3",
      "pali": "Sabbañca te issariyaṁ dadāmi,"
    },
    {
      "id": "ja333:4.4",
      "pali": "Yassicchasī tassa tuvaṁ dadāmī”ti."
    },
    {
      "id": "ja333:5.1",
      "pali": "Pakkagodhajātakaṁ tatiyaṁ."
    }
  ]
}
