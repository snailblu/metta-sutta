{
  "uid": "ja317",
  "title": "Pucimandavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja317:1.1",
      "pali": "“Mataṁ mataṁ evaṁ rodatha,"
    },
    {
      "id": "ja317:1.2",
      "pali": "Na hi taṁ rodatha yo marissati;"
    },
    {
      "id": "ja317:1.3",
      "pali": "Sabbepi sarīradhārino,"
    },
    {
      "id": "ja317:1.4",
      "pali": "Anupubbena jahanti jīvitaṁ."
    },
    {
      "id": "ja317:2.1",
      "pali": "Devamanussā catuppadā,"
    },
    {
      "id": "ja317:2.2",
      "pali": "Pakkhigaṇā uragā ca bhogino;"
    },
    {
      "id": "ja317:2.3",
      "pali": "Samhi sarīre anissarā,"
    },
    {
      "id": "ja317:2.4",
      "pali": "Ramamānāva jahanti jīvitaṁ."
    },
    {
      "id": "ja317:3.1",
      "pali": "Evaṁ calitaṁ asaṇṭhitaṁ,"
    },
    {
      "id": "ja317:3.2",
      "pali": "Sukhadukkhaṁ manujesvapekkhiya;"
    },
    {
      "id": "ja317:3.3",
      "pali": "Kanditaruditaṁ niratthakaṁ,"
    },
    {
      "id": "ja317:3.4",
      "pali": "Kiṁ vo sokagaṇābhikīrare."
    },
    {
      "id": "ja317:4.1",
      "pali": "Dhuttā ca soṇḍā akatā,"
    },
    {
      "id": "ja317:4.2",
      "pali": "bālā sūrā ayogino;"
    },
    {
      "id": "ja317:4.3",
      "pali": "Dhīraṁ maññanti bāloti,"
    },
    {
      "id": "ja317:4.4",
      "pali": "ye dhammassa akovidā”ti."
    },
    {
      "id": "ja317:5.1",
      "pali": "Matarodanajātakaṁ sattamaṁ."
    }
  ]
}
