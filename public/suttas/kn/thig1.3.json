{
  "uid": "thig1.3",
  "title": "Puṇṇātherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig1.3:1.1",
      "pali": "“Puṇṇe pūrassu dhammehi,"
    },
    {
      "id": "thig1.3:1.2",
      "pali": "Cando pannaraseriva;"
    },
    {
      "id": "thig1.3:1.3",
      "pali": "Paripuṇṇāya paññāya,"
    },
    {
      "id": "thig1.3:1.4",
      "pali": "Tamokhandhaṁ padālayā”ti."
    },
    {
      "id": "thig1.3:2.1",
      "pali": "Itthaṁ sudaṁ puṇṇā therī gāthaṁ abhāsitthāti."
    }
  ]
}
