{
  "uid": "ja395",
  "title": "Kharaputtavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja395:1.1",
      "pali": "“Cirassaṁ vata passāmi,"
    },
    {
      "id": "ja395:1.2",
      "pali": "sahāyaṁ maṇidhārinaṁ;"
    },
    {
      "id": "ja395:1.3",
      "pali": "Sukatā massukuttiyā,"
    },
    {
      "id": "ja395:1.4",
      "pali": "sobhate vata me sakhā”."
    },
    {
      "id": "ja395:2.1",
      "pali": "“Parūḷhakacchanakhalomo,"
    },
    {
      "id": "ja395:2.2",
      "pali": "ahaṁ kammesu byāvaṭo;"
    },
    {
      "id": "ja395:2.3",
      "pali": "Cirassaṁ nhāpitaṁ laddhā,"
    },
    {
      "id": "ja395:2.4",
      "pali": "lomaṁ taṁ ajja hārayiṁ”."
    },
    {
      "id": "ja395:3.1",
      "pali": "“Yannu lomaṁ ahāresi,"
    },
    {
      "id": "ja395:3.2",
      "pali": "dullabhaṁ laddha kappakaṁ;"
    },
    {
      "id": "ja395:3.3",
      "pali": "Atha kiñcarahi te samma,"
    },
    {
      "id": "ja395:3.4",
      "pali": "kaṇṭhe kiṇikiṇāyati”."
    },
    {
      "id": "ja395:4.1",
      "pali": "“Manussasukhumālānaṁ,"
    },
    {
      "id": "ja395:4.2",
      "pali": "maṇi kaṇṭhesu lambati;"
    },
    {
      "id": "ja395:4.3",
      "pali": "Tesāhaṁ anusikkhāmi,"
    },
    {
      "id": "ja395:4.4",
      "pali": "mā tvaṁ maññi davā kataṁ."
    },
    {
      "id": "ja395:5.1",
      "pali": "Sacepimaṁ pihayasi,"
    },
    {
      "id": "ja395:5.2",
      "pali": "massukuttiṁ sukāritaṁ;"
    },
    {
      "id": "ja395:5.3",
      "pali": "Kārayissāmi te samma,"
    },
    {
      "id": "ja395:5.4",
      "pali": "maṇiñcāpi dadāmi te”."
    },
    {
      "id": "ja395:6.1",
      "pali": "“Tvaññeva maṇinā channo,"
    },
    {
      "id": "ja395:6.2",
      "pali": "Sukatāya ca massuyā;"
    },
    {
      "id": "ja395:6.3",
      "pali": "Āmanta kho taṁ gacchāmi,"
    },
    {
      "id": "ja395:6.4",
      "pali": "Piyaṁ me tavadassanan”ti."
    },
    {
      "id": "ja395:7.1",
      "pali": "Pārāvatajātakaṁ dasamaṁ."
    },
    {
      "id": "ja395:7.2",
      "pali": "Kharaputtavaggo dutiyo."
    },
    {
      "id": "ja395:8.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "ja395:9.1",
      "pali": "Atha passa sasūci ca tuṇḍilako,"
    },
    {
      "id": "ja395:9.2",
      "pali": "Miga mayhakapañcamapakkhivaro;"
    },
    {
      "id": "ja395:9.3",
      "pali": "Atha pañjali vārija mejjha puna,"
    },
    {
      "id": "ja395:9.4",
      "pali": "Atha vaṭṭa kapotavarena dasāti."
    },
    {
      "id": "ja395:10.1",
      "pali": "Atha vagguddānaṁ"
    },
    {
      "id": "ja395:11.1",
      "pali": "Atha vaggaṁ pakittissaṁ,"
    },
    {
      "id": "ja395:11.2",
      "pali": "chanipātaṁ varuttame;"
    },
    {
      "id": "ja395:11.3",
      "pali": "Avāriyā ca kharo ca,"
    },
    {
      "id": "ja395:11.4",
      "pali": "dve ca vuttā subyañjanāti."
    },
    {
      "id": "ja395:12.1",
      "pali": "Chakkanipātaṁ niṭṭhitaṁ."
    }
  ]
}
