{
  "uid": "ja63",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja63:1.1",
      "pali": "“Kodhanā akataññū ca,"
    },
    {
      "id": "ja63:1.2",
      "pali": "pisuṇā mittabhedikā;"
    },
    {
      "id": "ja63:1.3",
      "pali": "Brahmacariyaṁ cara bhikkhu,"
    },
    {
      "id": "ja63:1.4",
      "pali": "so sukhaṁ na vihāhasīti."
    },
    {
      "id": "ja63:2.1",
      "pali": "Takkapaṇḍitajātakaṁ tatiyaṁ."
    }
  ]
}
