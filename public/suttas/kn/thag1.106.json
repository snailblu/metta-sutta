{
  "uid": "thag1.106",
  "title": "Ekādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.106:1.1",
      "pali": "“Sataliṅgassa atthassa,"
    },
    {
      "id": "thag1.106:1.2",
      "pali": "satalakkhaṇadhārino;"
    },
    {
      "id": "thag1.106:1.3",
      "pali": "Ekaṅgadassī dummedho,"
    },
    {
      "id": "thag1.106:1.4",
      "pali": "satadassī ca paṇḍito”ti."
    },
    {
      "id": "thag1.106:1.5",
      "pali": "… Suhemanto thero …."
    }
  ]
}
