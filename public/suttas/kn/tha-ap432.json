{
  "uid": "tha-ap432",
  "title": "10 Soṇṇakontarikattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap432:1.1",
      "pali": "“Manobhāvaniyaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap432:1.2",
      "pali": "attadantaṁ samāhitaṁ;"
    },
    {
      "id": "tha-ap432:1.3",
      "pali": "Iriyamānaṁ brahmapathe,"
    },
    {
      "id": "tha-ap432:1.4",
      "pali": "cittavūpasame rataṁ."
    },
    {
      "id": "tha-ap432:2.1",
      "pali": "Nittiṇṇaoghaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap432:2.2",
      "pali": "jhāyiṁ jhānarataṁ muniṁ;"
    },
    {
      "id": "tha-ap432:2.3",
      "pali": "Upatitthaṁ samāpannaṁ,"
    },
    {
      "id": "tha-ap432:2.4",
      "pali": "indivaradalappabhaṁ."
    },
    {
      "id": "tha-ap432:3.1",
      "pali": "Alābunodakaṁ gayha,"
    },
    {
      "id": "tha-ap432:3.2",
      "pali": "buddhaseṭṭhaṁ upāgamiṁ;"
    },
    {
      "id": "tha-ap432:3.3",
      "pali": "Buddhassa pāde dhovitvā,"
    },
    {
      "id": "tha-ap432:3.4",
      "pali": "alābukamadāsahaṁ."
    },
    {
      "id": "tha-ap432:4.1",
      "pali": "Āṇāpesi ca sambuddho,"
    },
    {
      "id": "tha-ap432:4.2",
      "pali": "padumuttaranāmako;"
    },
    {
      "id": "tha-ap432:4.3",
      "pali": "‘Iminā dakamāhatvā,"
    },
    {
      "id": "tha-ap432:4.4",
      "pali": "pādamūle ṭhapehi me’."
    },
    {
      "id": "tha-ap432:5.1",
      "pali": "Sādhūtihaṁ paṭissutvā,"
    },
    {
      "id": "tha-ap432:5.2",
      "pali": "satthugāravatāya ca;"
    },
    {
      "id": "tha-ap432:5.3",
      "pali": "Dakaṁ alābunāhatvā,"
    },
    {
      "id": "tha-ap432:5.4",
      "pali": "buddhaseṭṭhaṁ upāgamiṁ."
    },
    {
      "id": "tha-ap432:6.1",
      "pali": "Anumodi mahāvīro,"
    },
    {
      "id": "tha-ap432:6.2",
      "pali": "cittaṁ nibbāpayaṁ mama;"
    },
    {
      "id": "tha-ap432:6.3",
      "pali": "‘Iminālābudānena,"
    },
    {
      "id": "tha-ap432:6.4",
      "pali": "saṅkappo te samijjhatu’."
    },
    {
      "id": "tha-ap432:7.1",
      "pali": "Pannarasesu kappesu,"
    },
    {
      "id": "tha-ap432:7.2",
      "pali": "devaloke ramiṁ ahaṁ;"
    },
    {
      "id": "tha-ap432:7.3",
      "pali": "Tiṁsatikkhattuṁ rājā ca,"
    },
    {
      "id": "tha-ap432:7.4",
      "pali": "cakkavattī ahosahaṁ."
    },
    {
      "id": "tha-ap432:8.1",
      "pali": "Divā vā yadi vā rattiṁ,"
    },
    {
      "id": "tha-ap432:8.2",
      "pali": "caṅkamantassa tiṭṭhato;"
    },
    {
      "id": "tha-ap432:8.3",
      "pali": "Sovaṇṇaṁ kontaraṁ gayha,"
    },
    {
      "id": "tha-ap432:8.4",
      "pali": "tiṭṭhate purato mama."
    },
    {
      "id": "tha-ap432:9.1",
      "pali": "Buddhassa datvānalābuṁ,"
    },
    {
      "id": "tha-ap432:9.2",
      "pali": "labhāmi soṇṇakontaraṁ;"
    },
    {
      "id": "tha-ap432:9.3",
      "pali": "Appakampi kataṁ kāraṁ,"
    },
    {
      "id": "tha-ap432:9.4",
      "pali": "vipulaṁ hoti tādisu."
    },
    {
      "id": "tha-ap432:10.1",
      "pali": "Satasahassito kappe,"
    },
    {
      "id": "tha-ap432:10.2",
      "pali": "yaṁlābumadadiṁ tadā;"
    },
    {
      "id": "tha-ap432:10.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap432:10.4",
      "pali": "alābussa idaṁ phalaṁ."
    },
    {
      "id": "tha-ap432:11.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap432:11.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap432:11.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap432:12.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap432:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap432:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap432:13.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap432:13.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap432:13.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap432:14.1",
      "pali": "Itthaṁ sudaṁ āyasmā soṇṇakontariko thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap432:15.1",
      "pali": "Soṇṇakontarikattherassāpadānaṁ dasamaṁ."
    },
    {
      "id": "tha-ap432:16.1",
      "pali": "Sakiṁsammajjakavaggo tecattālīsamo."
    },
    {
      "id": "tha-ap432:17.1",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "tha-ap432:18.1",
      "pali": "Sakiṁsammajjako thero,"
    },
    {
      "id": "tha-ap432:18.2",
      "pali": "ekadussī ekāsanī;"
    },
    {
      "id": "tha-ap432:18.3",
      "pali": "Kadambakoraṇḍakado,"
    },
    {
      "id": "tha-ap432:18.4",
      "pali": "ghatassavanikopi ca."
    },
    {
      "id": "tha-ap432:19.1",
      "pali": "Sucintiko kiṅkaṇiko,"
    },
    {
      "id": "tha-ap432:19.2",
      "pali": "soṇṇakontarikopi ca;"
    },
    {
      "id": "tha-ap432:19.3",
      "pali": "Ekagāthāsatañcettha,"
    },
    {
      "id": "tha-ap432:19.4",
      "pali": "ekasattatimeva ca."
    }
  ]
}
