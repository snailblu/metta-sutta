{
  "uid": "thag4.11",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag4.11:1.1",
      "pali": "“Yadā balākā sucipaṇḍaracchadā,"
    },
    {
      "id": "thag4.11:1.2",
      "pali": "Kāḷassa meghassa bhayena tajjitā;"
    },
    {
      "id": "thag4.11:1.3",
      "pali": "Palehiti ālayamālayesinī,"
    },
    {
      "id": "thag4.11:1.4",
      "pali": "Tadā nadī ajakaraṇī rameti maṁ."
    },
    {
      "id": "thag4.11:2.1",
      "pali": "Yadā balākā suvisuddhapaṇḍarā,"
    },
    {
      "id": "thag4.11:2.2",
      "pali": "Kāḷassa meghassa bhayena tajjitā;"
    },
    {
      "id": "thag4.11:2.3",
      "pali": "Pariyesati leṇamaleṇadassinī,"
    },
    {
      "id": "thag4.11:2.4",
      "pali": "Tadā nadī ajakaraṇī rameti maṁ."
    },
    {
      "id": "thag4.11:3.1",
      "pali": "Kaṁ nu tattha na ramenti,"
    },
    {
      "id": "thag4.11:3.2",
      "pali": "jambuyo ubhato tahiṁ;"
    },
    {
      "id": "thag4.11:3.3",
      "pali": "Sobhenti āpagākūlaṁ,"
    },
    {
      "id": "thag4.11:3.4",
      "pali": "mama leṇassa pacchato."
    },
    {
      "id": "thag4.11:4.1",
      "pali": "Tāmatamadasaṅghasuppahīnā,"
    },
    {
      "id": "thag4.11:4.2",
      "pali": "Bhekā mandavatī panādayanti;"
    },
    {
      "id": "thag4.11:4.3",
      "pali": "‘Nājja girinadīhi vippavāsasamayo,"
    },
    {
      "id": "thag4.11:4.4",
      "pali": "Khemā ajakaraṇī sivā surammā’”ti."
    },
    {
      "id": "thag4.11:4.5",
      "pali": "… Sappako thero …."
    }
  ]
}
