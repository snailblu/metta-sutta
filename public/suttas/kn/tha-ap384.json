{
  "uid": "tha-ap384",
  "title": "Labujadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap384:1.1",
      "pali": "“Nagare bandhumatiyā,"
    },
    {
      "id": "tha-ap384:1.2",
      "pali": "āsiṁ ārāmiko tadā;"
    },
    {
      "id": "tha-ap384:1.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap384:1.4",
      "pali": "gacchantaṁ anilañjase."
    },
    {
      "id": "tha-ap384:2.1",
      "pali": "Labujassa phalaṁ gayha,"
    },
    {
      "id": "tha-ap384:2.2",
      "pali": "buddhaseṭṭhassadāsahaṁ;"
    },
    {
      "id": "tha-ap384:2.3",
      "pali": "Ākāse ṭhitako santo,"
    },
    {
      "id": "tha-ap384:2.4",
      "pali": "paṭigaṇhi mahāyaso."
    },
    {
      "id": "tha-ap384:3.1",
      "pali": "Vittisañjananaṁ mayhaṁ,"
    },
    {
      "id": "tha-ap384:3.2",
      "pali": "diṭṭhadhammasukhāvahaṁ;"
    },
    {
      "id": "tha-ap384:3.3",
      "pali": "Phalaṁ buddhassa datvāna,"
    },
    {
      "id": "tha-ap384:3.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap384:4.1",
      "pali": "Adhigacchiṁ tadā pītiṁ,"
    },
    {
      "id": "tha-ap384:4.2",
      "pali": "vipulañca sukhuttamaṁ;"
    },
    {
      "id": "tha-ap384:4.3",
      "pali": "Uppajjateva ratanaṁ,"
    },
    {
      "id": "tha-ap384:4.4",
      "pali": "nibbattassa tahiṁ tahiṁ."
    },
    {
      "id": "tha-ap384:5.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap384:5.2",
      "pali": "yaṁ phalamadadiṁ tadā;"
    },
    {
      "id": "tha-ap384:5.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap384:5.4",
      "pali": "phaladānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap384:6.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap384:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap384:6.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap384:7.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap384:7.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap384:7.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap384:8.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap384:8.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap384:8.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap384:9.1",
      "pali": "Itthaṁ sudaṁ āyasmā labujadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap384:10.1",
      "pali": "Labujadāyakattherassāpadānaṁ dutiyaṁ."
    }
  ]
}
