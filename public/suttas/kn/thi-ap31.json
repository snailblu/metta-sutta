{
  "uid": "thi-ap31",
  "title": "1 Yasavatīpamukhaaṭṭhārasabhikkhunīsahassaapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thi-ap31:1.1",
      "pali": "“Bhavā sabbe parikkhīṇā,"
    },
    {
      "id": "thi-ap31:1.2",
      "pali": "bhavā santi vimocitā;"
    },
    {
      "id": "thi-ap31:1.3",
      "pali": "Sabbāsavā ca no natthi,"
    },
    {
      "id": "thi-ap31:1.4",
      "pali": "ārocema mahāmune."
    },
    {
      "id": "thi-ap31:2.1",
      "pali": "Purimaṁ kusalaṁ kammaṁ,"
    },
    {
      "id": "thi-ap31:2.2",
      "pali": "yaṁ kiñci sādhupatthitaṁ;"
    },
    {
      "id": "thi-ap31:2.3",
      "pali": "Paribhogamayaṁ dinnaṁ,"
    },
    {
      "id": "thi-ap31:2.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap31:3.1",
      "pali": "Buddhapaccekabuddhānaṁ,"
    },
    {
      "id": "thi-ap31:3.2",
      "pali": "sāvakānañca patthitaṁ;"
    },
    {
      "id": "thi-ap31:3.3",
      "pali": "Paribhogamayaṁ dinnaṁ,"
    },
    {
      "id": "thi-ap31:3.4",
      "pali": "tuyhatthāya mahāmune."
    },
    {
      "id": "thi-ap31:4.1",
      "pali": "Uccanīcamayaṁ kammaṁ,"
    },
    {
      "id": "thi-ap31:4.2",
      "pali": "bhikkhūnaṁ sādhupatthitaṁ;"
    },
    {
      "id": "thi-ap31:4.3",
      "pali": "Uccākulaparikammaṁ,"
    },
    {
      "id": "thi-ap31:4.4",
      "pali": "katametaṁ mahāmune."
    },
    {
      "id": "thi-ap31:5.1",
      "pali": "Teneva sukkamūlena,"
    },
    {
      "id": "thi-ap31:5.2",
      "pali": "coditā kammasampadā;"
    },
    {
      "id": "thi-ap31:5.3",
      "pali": "Mānusikamatikkantā,"
    },
    {
      "id": "thi-ap31:5.4",
      "pali": "jāyiṁsu khattiye kule."
    },
    {
      "id": "thi-ap31:6.1",
      "pali": "Uppatte ca kate kamme,"
    },
    {
      "id": "thi-ap31:6.2",
      "pali": "jātiyā vāpi ekato;"
    },
    {
      "id": "thi-ap31:6.3",
      "pali": "Pacchime ekato jātā,"
    },
    {
      "id": "thi-ap31:6.4",
      "pali": "khattiyā kulasambhavā."
    },
    {
      "id": "thi-ap31:7.1",
      "pali": "Rūpavatī bhogavatī,"
    },
    {
      "id": "thi-ap31:7.2",
      "pali": "lābhasakkārapūjitā;"
    },
    {
      "id": "thi-ap31:7.3",
      "pali": "Antepure mahāvīra,"
    },
    {
      "id": "thi-ap31:7.4",
      "pali": "devānaṁ viya nandane."
    },
    {
      "id": "thi-ap31:8.1",
      "pali": "Nibbinditvā agāramhā,"
    },
    {
      "id": "thi-ap31:8.2",
      "pali": "pabbajimhanagāriyaṁ;"
    },
    {
      "id": "thi-ap31:8.3",
      "pali": "Katipāhaṁ upādāya,"
    },
    {
      "id": "thi-ap31:8.4",
      "pali": "sabbā pattāmha nibbutiṁ."
    },
    {
      "id": "thi-ap31:9.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "thi-ap31:9.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "thi-ap31:9.3",
      "pali": "Upanenti bahū amhe,"
    },
    {
      "id": "thi-ap31:9.4",
      "pali": "sadā sakkatapūjitā."
    },
    {
      "id": "thi-ap31:10.1",
      "pali": "Kilesā jhāpitā amhaṁ,"
    },
    {
      "id": "thi-ap31:10.2",
      "pali": "bhavā sabbe samūhatā;"
    },
    {
      "id": "thi-ap31:10.3",
      "pali": "Nāgīva bandhanaṁ chetvā,"
    },
    {
      "id": "thi-ap31:10.4",
      "pali": "viharāma anāsavā."
    },
    {
      "id": "thi-ap31:11.1",
      "pali": "Svāgataṁ vata no āsi,"
    },
    {
      "id": "thi-ap31:11.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "thi-ap31:11.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "thi-ap31:11.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "thi-ap31:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "thi-ap31:12.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "thi-ap31:12.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "thi-ap31:12.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "thi-ap31:13.1",
      "pali": "Itthaṁ sudaṁ yasavatīpamukhāni khattiyakaññābhikkhuniyo aṭṭhārasasahassāni bhagavato sammukhā imā gāthāyo abhāsitthāti."
    },
    {
      "id": "thi-ap31:14.1",
      "pali": "Yasavatīpamukhaaṭṭhārasabhikkhunīsahassāpadānaṁ paṭhamaṁ."
    }
  ]
}
