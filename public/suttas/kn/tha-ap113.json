{
  "uid": "tha-ap113",
  "title": "1 Mahāparivārakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap113:1.1",
      "pali": "“Vipassī nāma bhagavā,"
    },
    {
      "id": "tha-ap113:1.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap113:1.3",
      "pali": "Aṭṭhasaṭṭhisahassehi,"
    },
    {
      "id": "tha-ap113:1.4",
      "pali": "pāvisi bandhumaṁ tadā."
    },
    {
      "id": "tha-ap113:2.1",
      "pali": "Nagarā abhinikkhamma,"
    },
    {
      "id": "tha-ap113:2.2",
      "pali": "agamaṁ dīpacetiyaṁ;"
    },
    {
      "id": "tha-ap113:2.3",
      "pali": "Addasaṁ virajaṁ buddhaṁ,"
    },
    {
      "id": "tha-ap113:2.4",
      "pali": "āhutīnaṁ paṭiggahaṁ."
    },
    {
      "id": "tha-ap113:3.1",
      "pali": "Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap113:3.2",
      "pali": "yakkhā mayhaṁ upantike;"
    },
    {
      "id": "tha-ap113:3.3",
      "pali": "Upaṭṭhahanti sakkaccaṁ,"
    },
    {
      "id": "tha-ap113:3.4",
      "pali": "indaṁva tidasā gaṇā."
    },
    {
      "id": "tha-ap113:4.1",
      "pali": "Bhavanā abhinikkhamma,"
    },
    {
      "id": "tha-ap113:4.2",
      "pali": "dussaṁ paggayhahaṁ tadā;"
    },
    {
      "id": "tha-ap113:4.3",
      "pali": "Sirasā abhivādesiṁ,"
    },
    {
      "id": "tha-ap113:4.4",
      "pali": "tañcādāsiṁ mahesino."
    },
    {
      "id": "tha-ap113:5.1",
      "pali": "Aho buddhā aho dhammā,"
    },
    {
      "id": "tha-ap113:5.2",
      "pali": "aho no satthu sampadā;"
    },
    {
      "id": "tha-ap113:5.3",
      "pali": "Buddhassa ānubhāvena,"
    },
    {
      "id": "tha-ap113:5.4",
      "pali": "vasudhāyaṁ pakampatha."
    },
    {
      "id": "tha-ap113:6.1",
      "pali": "Tañca acchariyaṁ disvā,"
    },
    {
      "id": "tha-ap113:6.2",
      "pali": "abbhutaṁ lomahaṁsanaṁ;"
    },
    {
      "id": "tha-ap113:6.3",
      "pali": "Buddhe cittaṁ pasādemi,"
    },
    {
      "id": "tha-ap113:6.4",
      "pali": "dvipadindamhi tādine."
    },
    {
      "id": "tha-ap113:7.1",
      "pali": "Sohaṁ cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap113:7.2",
      "pali": "dussaṁ datvāna satthuno;"
    },
    {
      "id": "tha-ap113:7.3",
      "pali": "Saraṇañca upāgacchiṁ,"
    },
    {
      "id": "tha-ap113:7.4",
      "pali": "sāmacco saparijjano."
    },
    {
      "id": "tha-ap113:8.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap113:8.2",
      "pali": "yaṁ kammamakariṁ tadā;"
    },
    {
      "id": "tha-ap113:8.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap113:8.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap113:9.1",
      "pali": "Ito pannarase kappe,"
    },
    {
      "id": "tha-ap113:9.2",
      "pali": "soḷasāsuṁ suvāhanā;"
    },
    {
      "id": "tha-ap113:9.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap113:9.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap113:10.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap113:10.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap113:10.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap113:10.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap113:11.1",
      "pali": "Itthaṁ sudaṁ āyasmā mahāparivārako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap113:12.1",
      "pali": "Mahāparivārakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
