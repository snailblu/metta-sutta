{
  "uid": "iti58",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti58:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti58:2.1",
      "pali": "“Tisso imā, bhikkhave, taṇhā."
    },
    {
      "id": "iti58:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "iti58:2.3",
      "pali": "Kāmataṇhā, bhavataṇhā, vibhavataṇhā—"
    },
    {
      "id": "iti58:2.4",
      "pali": "imā kho, bhikkhave, tisso taṇhā”ti."
    },
    {
      "id": "iti58:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti58:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti58:3.1",
      "pali": "“Taṇhāyogena saṁyuttā,"
    },
    {
      "id": "iti58:3.2",
      "pali": "rattacittā bhavābhave;"
    },
    {
      "id": "iti58:3.3",
      "pali": "Te yogayuttā mārassa,"
    },
    {
      "id": "iti58:3.4",
      "pali": "ayogakkhemino janā;"
    },
    {
      "id": "iti58:3.5",
      "pali": "Sattā gacchanti saṁsāraṁ,"
    },
    {
      "id": "iti58:3.6",
      "pali": "jātīmaraṇagāmino."
    },
    {
      "id": "iti58:4.1",
      "pali": "Ye ca taṇhaṁ pahantvāna,"
    },
    {
      "id": "iti58:4.2",
      "pali": "vītataṇhā bhavābhave;"
    },
    {
      "id": "iti58:4.3",
      "pali": "Te ve pāraṅgatā loke,"
    },
    {
      "id": "iti58:4.4",
      "pali": "ye pattā āsavakkhayan”ti."
    },
    {
      "id": "iti58:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti58:5.2",
      "pali": "Navamaṁ."
    }
  ]
}
