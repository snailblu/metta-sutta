{
  "uid": "iti1",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti1:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti1:2.1",
      "pali": "“Ekadhammaṁ, bhikkhave, pajahatha;"
    },
    {
      "id": "iti1:2.2",
      "pali": "ahaṁ vo pāṭibhogo anāgāmitāya."
    },
    {
      "id": "iti1:2.3",
      "pali": "Katamaṁ ekadhammaṁ?"
    },
    {
      "id": "iti1:2.4",
      "pali": "Lobhaṁ, bhikkhave, ekadhammaṁ pajahatha;"
    },
    {
      "id": "iti1:2.5",
      "pali": "ahaṁ vo pāṭibhogo anāgāmitāyā”ti."
    },
    {
      "id": "iti1:2.6",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti1:2.7",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti1:3.1",
      "pali": "“Yena lobhena luddhāse,"
    },
    {
      "id": "iti1:3.2",
      "pali": "sattā gacchanti duggatiṁ;"
    },
    {
      "id": "iti1:3.3",
      "pali": "Taṁ lobhaṁ sammadaññāya,"
    },
    {
      "id": "iti1:3.4",
      "pali": "pajahanti vipassino;"
    },
    {
      "id": "iti1:3.5",
      "pali": "Pahāya na punāyanti,"
    },
    {
      "id": "iti1:3.6",
      "pali": "imaṁ lokaṁ kudācanan”ti."
    },
    {
      "id": "iti1:4.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti1:4.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
