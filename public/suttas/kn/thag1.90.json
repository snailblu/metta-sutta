{
  "uid": "thag1.90",
  "title": "Navamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.90:1.1",
      "pali": "“Pañcakkhandhā pariññātā,"
    },
    {
      "id": "thag1.90:1.2",
      "pali": "tiṭṭhanti chinnamūlakā;"
    },
    {
      "id": "thag1.90:1.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "thag1.90:1.4",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag1.90:1.5",
      "pali": "… Sāmidatto thero …"
    },
    {
      "id": "thag1.90:1.6",
      "pali": "vaggo navamo."
    },
    {
      "id": "thag1.90:2.1",
      "pali": "Thero samitigutto ca,"
    },
    {
      "id": "thag1.90:2.2",
      "pali": "kassapo sīhasavhayo;"
    },
    {
      "id": "thag1.90:2.3",
      "pali": "Nīto sunāgo nāgito,"
    },
    {
      "id": "thag1.90:2.4",
      "pali": "paviṭṭho ajjuno isi;"
    },
    {
      "id": "thag1.90:2.5",
      "pali": "Devasabho ca yo thero,"
    },
    {
      "id": "thag1.90:2.6",
      "pali": "sāmidatto mahabbaloti."
    }
  ]
}
