{
  "uid": "iti27",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti27:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti27:2.1",
      "pali": "“Yāni kānici, bhikkhave, opadhikāni puññakiriyavatthūni sabbāni tāni mettāya cetovimuttiyā kalaṁ nāgghanti soḷasiṁ."
    },
    {
      "id": "iti27:2.2",
      "pali": "Mettāyeva tāni cetovimutti adhiggahetvā bhāsate ca tapate ca virocati ca."
    },
    {
      "id": "iti27:3.1",
      "pali": "Seyyathāpi, bhikkhave, yā kāci tārakarūpānaṁ pabhā sabbā tā candiyā pabhāya kalaṁ nāgghanti soḷasiṁ, candapabhāyeva tā adhiggahetvā bhāsate ca tapate ca virocati ca;"
    },
    {
      "id": "iti27:3.2",
      "pali": "evamevaṁ kho, bhikkhave, yāni kānici opadhikāni puññakiriyavatthūni sabbāni tāni mettāya cetovimuttiyā kalaṁ nāgghanti soḷasiṁ, mettāyeva tāni cetovimutti adhiggahetvā bhāsate ca tapate ca virocati ca."
    },
    {
      "id": "iti27:4.1",
      "pali": "Seyyathāpi, bhikkhave, vassānaṁ pacchime māse saradasamaye viddhe vigatavalāhake deve ādicco nabhaṁ abbhussakkamāno sabbaṁ ākāsagataṁ tamagataṁ abhivihacca bhāsate ca tapate ca virocati ca;"
    },
    {
      "id": "iti27:4.2",
      "pali": "evamevaṁ kho, bhikkhave, yāni kānici opadhikāni puññakiriyavatthūni sabbāni tāni mettāya cetovimuttiyā kalaṁ nāgghanti soḷasiṁ, mettāyeva tāni cetovimutti adhiggahetvā bhāsate ca tapate ca virocati ca."
    },
    {
      "id": "iti27:5.1",
      "pali": "Seyyathāpi, bhikkhave, rattiyā paccūsasamayaṁ osadhitārakā bhāsate ca tapate ca virocati ca;"
    },
    {
      "id": "iti27:5.2",
      "pali": "evamevaṁ kho, bhikkhave, yāni kānici opadhikāni puññakiriyavatthūni sabbāni tāni mettāya cetovimuttiyā kalaṁ nāgghanti soḷasiṁ, mettāyeva tāni cetovimutti adhiggahetvā bhāsate ca tapate ca virocati cā”ti."
    },
    {
      "id": "iti27:5.3",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti27:5.4",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti27:6.1",
      "pali": "“Yo ca mettaṁ bhāvayati,"
    },
    {
      "id": "iti27:6.2",
      "pali": "appamāṇaṁ paṭissato;"
    },
    {
      "id": "iti27:6.3",
      "pali": "Tanū saṁyojanā honti,"
    },
    {
      "id": "iti27:6.4",
      "pali": "passato upadhikkhayaṁ."
    },
    {
      "id": "iti27:7.1",
      "pali": "Ekampi ce pāṇamaduṭṭhacitto,"
    },
    {
      "id": "iti27:7.2",
      "pali": "Mettāyati kusalo tena hoti;"
    },
    {
      "id": "iti27:7.3",
      "pali": "Sabbe ca pāṇe manasānukampaṁ,"
    },
    {
      "id": "iti27:7.4",
      "pali": "Pahūtamariyo pakaroti puññaṁ."
    },
    {
      "id": "iti27:8.1",
      "pali": "Ye sattasaṇḍaṁ pathaviṁ vijitvā,"
    },
    {
      "id": "iti27:8.2",
      "pali": "Rājisayo yajamānānupariyagā;"
    },
    {
      "id": "iti27:8.3",
      "pali": "Assamedhaṁ purisamedhaṁ,"
    },
    {
      "id": "iti27:8.4",
      "pali": "Sammāpāsaṁ vājapeyyaṁ niraggaḷaṁ."
    },
    {
      "id": "iti27:9.1",
      "pali": "Mettassa cittassa subhāvitassa,"
    },
    {
      "id": "iti27:9.2",
      "pali": "Kalampi te nānubhavanti soḷasiṁ;"
    },
    {
      "id": "iti27:9.3",
      "pali": "Candappabhā tāragaṇāva sabbe."
    },
    {
      "id": "iti27:10.1",
      "pali": "Yo na hanti na ghāteti,"
    },
    {
      "id": "iti27:10.2",
      "pali": "na jināti na jāpaye;"
    },
    {
      "id": "iti27:10.3",
      "pali": "Mettaṁso sabbabhūtesu,"
    },
    {
      "id": "iti27:10.4",
      "pali": "veraṁ tassa na kenacī”ti."
    },
    {
      "id": "iti27:11.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti27:11.2",
      "pali": "Sattamaṁ."
    },
    {
      "id": "iti27:11.3",
      "pali": "Tatiyo vaggo."
    },
    {
      "id": "iti27:12.1",
      "pali": "Cittaṁ mettaṁ ubho atthe,"
    },
    {
      "id": "iti27:12.2",
      "pali": "puñjaṁ vepullapabbataṁ;"
    },
    {
      "id": "iti27:12.3",
      "pali": "Sampajānamusāvādo,"
    },
    {
      "id": "iti27:12.4",
      "pali": "dānañca mettabhāvanā."
    },
    {
      "id": "iti27:13.1",
      "pali": "Sattimāni ca suttāni,"
    },
    {
      "id": "iti27:13.2",
      "pali": "purimāni ca vīsati;"
    },
    {
      "id": "iti27:13.3",
      "pali": "Ekadhammesu suttantā,"
    },
    {
      "id": "iti27:13.4",
      "pali": "sattavīsatisaṅgahāti."
    },
    {
      "id": "iti27:13.5",
      "pali": "Ekakanipāto niṭṭhito."
    }
  ]
}
