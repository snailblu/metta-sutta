{
  "uid": "thag1.45",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.45:1.1",
      "pali": "“Yathāpi bhaddo ājañño,"
    },
    {
      "id": "thag1.45:1.2",
      "pali": "khalitvā patitiṭṭhati;"
    },
    {
      "id": "thag1.45:1.3",
      "pali": "Evaṁ dassanasampannaṁ,"
    },
    {
      "id": "thag1.45:1.4",
      "pali": "sammāsambuddhasāvakan”ti."
    },
    {
      "id": "thag1.45:1.5",
      "pali": "… Ramaṇīyavihāritthero …."
    }
  ]
}
