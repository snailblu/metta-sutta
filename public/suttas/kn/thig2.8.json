{
  "uid": "thig2.8",
  "title": "Abhayamātutherīgāthā",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thig2.8:1.1",
      "pali": "“Uddhaṁ pādatalā amma,"
    },
    {
      "id": "thig2.8:1.2",
      "pali": "adho ve kesamatthakā;"
    },
    {
      "id": "thig2.8:1.3",
      "pali": "Paccavekkhassumaṁ kāyaṁ,"
    },
    {
      "id": "thig2.8:1.4",
      "pali": "asuciṁ pūtigandhikaṁ."
    },
    {
      "id": "thig2.8:2.1",
      "pali": "Evaṁ viharamānāya,"
    },
    {
      "id": "thig2.8:2.2",
      "pali": "sabbo rāgo samūhato;"
    },
    {
      "id": "thig2.8:2.3",
      "pali": "Pariḷāho samucchinno,"
    },
    {
      "id": "thig2.8:2.4",
      "pali": "sītibhūtāmhi nibbutā”ti."
    },
    {
      "id": "thig2.8:3.1",
      "pali": "… Abhayamātā therī …."
    }
  ]
}
