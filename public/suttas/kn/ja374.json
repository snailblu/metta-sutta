{
  "uid": "ja374",
  "title": "Aḍḍhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja374:1.1",
      "pali": "“Sabbaṁ bhaṇḍaṁ samādāya,"
    },
    {
      "id": "ja374:1.2",
      "pali": "pāraṁ tiṇṇosi brāhmaṇa;"
    },
    {
      "id": "ja374:1.3",
      "pali": "Paccāgaccha lahuṁ khippaṁ,"
    },
    {
      "id": "ja374:1.4",
      "pali": "mampi tārehi dānito”."
    },
    {
      "id": "ja374:2.1",
      "pali": "“Asanthutaṁ maṁ cirasanthutena,"
    },
    {
      "id": "ja374:2.2",
      "pali": "Nimīni bhotī addhuvaṁ dhuvena;"
    },
    {
      "id": "ja374:2.3",
      "pali": "Mayāpi bhotī nimineyya aññaṁ,"
    },
    {
      "id": "ja374:2.4",
      "pali": "Ito ahaṁ dūrataraṁ gamissaṁ”."
    },
    {
      "id": "ja374:3.1",
      "pali": "“Kāyaṁ eḷagalāgumbe,"
    },
    {
      "id": "ja374:3.2",
      "pali": "karoti ahuhāsiyaṁ;"
    },
    {
      "id": "ja374:3.3",
      "pali": "Nayīdha naccagītaṁ vā,"
    },
    {
      "id": "ja374:3.4",
      "pali": "tāḷaṁ vā susamāhitaṁ;"
    },
    {
      "id": "ja374:3.5",
      "pali": "Anamhikāle susoṇi,"
    },
    {
      "id": "ja374:3.6",
      "pali": "kiṁ nu jagghasi sobhane”."
    },
    {
      "id": "ja374:4.1",
      "pali": "“Siṅgāla bāla dummedha,"
    },
    {
      "id": "ja374:4.2",
      "pali": "appapaññosi jambuka;"
    },
    {
      "id": "ja374:4.3",
      "pali": "Jīno macchañca pesiñca,"
    },
    {
      "id": "ja374:4.4",
      "pali": "kapaṇo viya jhāyasi”."
    },
    {
      "id": "ja374:5.1",
      "pali": "“Sudassaṁ vajjamaññesaṁ,"
    },
    {
      "id": "ja374:5.2",
      "pali": "attano pana duddasaṁ;"
    },
    {
      "id": "ja374:5.3",
      "pali": "Jīnā patiñca jārañca,"
    },
    {
      "id": "ja374:5.4",
      "pali": "maññe tvaññeva jhāyasi”."
    },
    {
      "id": "ja374:6.1",
      "pali": "“Evametaṁ migarāja,"
    },
    {
      "id": "ja374:6.2",
      "pali": "yathā bhāsasi jambuka;"
    },
    {
      "id": "ja374:6.3",
      "pali": "Sā nūnāhaṁ ito gantvā,"
    },
    {
      "id": "ja374:6.4",
      "pali": "bhattu hessaṁ vasānugā”."
    },
    {
      "id": "ja374:7.1",
      "pali": "“Yo hare mattikaṁ thālaṁ,"
    },
    {
      "id": "ja374:7.2",
      "pali": "kaṁsathālampi so hare;"
    },
    {
      "id": "ja374:7.3",
      "pali": "Katañceva tayā pāpaṁ,"
    },
    {
      "id": "ja374:7.4",
      "pali": "punapevaṁ karissasī”ti."
    },
    {
      "id": "ja374:8.1",
      "pali": "Cūḷadhanuggahajātakaṁ catutthaṁ."
    }
  ]
}
