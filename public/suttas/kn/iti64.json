{
  "uid": "iti64",
  "title": "Dutiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti64:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti64:2.1",
      "pali": "“Tīṇimāni, bhikkhave, duccaritāni."
    },
    {
      "id": "iti64:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "iti64:2.3",
      "pali": "Kāyaduccaritaṁ, vacīduccaritaṁ, manoduccaritaṁ—"
    },
    {
      "id": "iti64:2.4",
      "pali": "imāni kho, bhikkhave, tīṇi duccaritānī”ti."
    },
    {
      "id": "iti64:2.5",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti64:2.6",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti64:3.1",
      "pali": "“Kāyaduccaritaṁ katvā,"
    },
    {
      "id": "iti64:3.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "iti64:3.3",
      "pali": "Manoduccaritaṁ katvā,"
    },
    {
      "id": "iti64:3.4",
      "pali": "yañcaññaṁ dosasaṁhitaṁ."
    },
    {
      "id": "iti64:4.1",
      "pali": "Akatvā kusalaṁ kammaṁ,"
    },
    {
      "id": "iti64:4.2",
      "pali": "katvānākusalaṁ bahuṁ;"
    },
    {
      "id": "iti64:4.3",
      "pali": "Kāyassa bhedā duppañño,"
    },
    {
      "id": "iti64:4.4",
      "pali": "nirayaṁ sopapajjatī”ti."
    },
    {
      "id": "iti64:5.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti64:5.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
