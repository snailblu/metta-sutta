{
  "uid": "ja154",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja154:1.1",
      "pali": "“Idhūragānaṁ pavaro paviṭṭho,"
    },
    {
      "id": "ja154:1.2",
      "pali": "Selassa vaṇṇena pamokkhamicchaṁ;"
    },
    {
      "id": "ja154:1.3",
      "pali": "Brahmañca vaṇṇaṁ apacāyamāno,"
    },
    {
      "id": "ja154:1.4",
      "pali": "Bubhukkhito no vitarāmi bhottuṁ”."
    },
    {
      "id": "ja154:2.1",
      "pali": "“So brahmagutto cirameva jīva,"
    },
    {
      "id": "ja154:2.2",
      "pali": "Dibyā ca te pātubhavantu bhakkhā;"
    },
    {
      "id": "ja154:2.3",
      "pali": "Yo brahmavaṇṇaṁ apacāyamāno,"
    },
    {
      "id": "ja154:2.4",
      "pali": "Bubhukkhito no vitarāsi bhottun”ti."
    },
    {
      "id": "ja154:3.1",
      "pali": "Uragajātakaṁ catutthaṁ."
    }
  ]
}
