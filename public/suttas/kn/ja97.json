{
  "uid": "ja97",
  "title": "Littavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja97:1.1",
      "pali": "“Jīvakañca mataṁ disvā,"
    },
    {
      "id": "ja97:1.2",
      "pali": "dhanapāliñca duggataṁ;"
    },
    {
      "id": "ja97:1.3",
      "pali": "Panthakañca vane mūḷhaṁ,"
    },
    {
      "id": "ja97:1.4",
      "pali": "pāpako punarāgato”ti."
    },
    {
      "id": "ja97:2.1",
      "pali": "Nāmasiddhijātakaṁ sattamaṁ."
    }
  ]
}
