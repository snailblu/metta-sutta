{
  "uid": "tha-ap316",
  "title": "Sattapadumiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap316:1.1",
      "pali": "“Nadīkūle vasāmahaṁ,"
    },
    {
      "id": "tha-ap316:1.2",
      "pali": "nesādo nāma brāhmaṇo;"
    },
    {
      "id": "tha-ap316:1.3",
      "pali": "Satapattehi pupphehi,"
    },
    {
      "id": "tha-ap316:1.4",
      "pali": "sammajjitvāna assamaṁ."
    },
    {
      "id": "tha-ap316:2.1",
      "pali": "Suvaṇṇavaṇṇaṁ sambuddhaṁ,"
    },
    {
      "id": "tha-ap316:2.2",
      "pali": "Siddhatthaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap316:2.3",
      "pali": "Disvā nabhena gacchantaṁ,"
    },
    {
      "id": "tha-ap316:2.4",
      "pali": "Hāso me udapajjatha."
    },
    {
      "id": "tha-ap316:3.1",
      "pali": "Paccuggantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap316:3.2",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap316:3.3",
      "pali": "Assamaṁ atināmetvā,"
    },
    {
      "id": "tha-ap316:3.4",
      "pali": "jalajaggehi okiriṁ."
    },
    {
      "id": "tha-ap316:4.1",
      "pali": "Catunnavutito kappe,"
    },
    {
      "id": "tha-ap316:4.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap316:4.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap316:4.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap316:5.1",
      "pali": "Ito te sattame kappe,"
    },
    {
      "id": "tha-ap316:5.2",
      "pali": "caturo pādapāvarā;"
    },
    {
      "id": "tha-ap316:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap316:5.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap316:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap316:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap316:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap316:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā sattapadumiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap316:8.1",
      "pali": "Sattapadumiyattherassāpadānaṁ catutthaṁ."
    }
  ]
}
