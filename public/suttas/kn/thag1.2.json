{
  "uid": "thag1.2",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.2:1.1",
      "pali": "“Upasanto uparato,"
    },
    {
      "id": "thag1.2:1.2",
      "pali": "mantabhāṇī anuddhato;"
    },
    {
      "id": "thag1.2:1.3",
      "pali": "Dhunāti pāpake dhamme,"
    },
    {
      "id": "thag1.2:1.4",
      "pali": "dumapattaṁva māluto”ti."
    },
    {
      "id": "thag1.2:1.5",
      "pali": "Itthaṁ sudaṁ āyasmā mahākoṭṭhiko thero gāthaṁ abhāsitthāti."
    }
  ]
}
