{
  "uid": "thag6.13",
  "title": "Paṭhamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag6.13:1.1",
      "pali": "“Channamativassati,"
    },
    {
      "id": "thag6.13:1.2",
      "pali": "vivaṭaṁ nātivassati;"
    },
    {
      "id": "thag6.13:1.3",
      "pali": "Tasmā channaṁ vivaretha,"
    },
    {
      "id": "thag6.13:1.4",
      "pali": "evaṁ taṁ nātivassati."
    },
    {
      "id": "thag6.13:2.1",
      "pali": "Maccunābbhahato loko,"
    },
    {
      "id": "thag6.13:2.2",
      "pali": "jarāya parivārito;"
    },
    {
      "id": "thag6.13:2.3",
      "pali": "Taṇhāsallena otiṇṇo,"
    },
    {
      "id": "thag6.13:2.4",
      "pali": "icchādhūpāyito sadā."
    },
    {
      "id": "thag6.13:3.1",
      "pali": "Maccunābbhahato loko,"
    },
    {
      "id": "thag6.13:3.2",
      "pali": "parikkhitto jarāya ca;"
    },
    {
      "id": "thag6.13:3.3",
      "pali": "Haññati niccamattāṇo,"
    },
    {
      "id": "thag6.13:3.4",
      "pali": "pattadaṇḍova takkaro."
    },
    {
      "id": "thag6.13:4.1",
      "pali": "Āgacchantaggikhandhāva,"
    },
    {
      "id": "thag6.13:4.2",
      "pali": "maccu byādhi jarā tayo;"
    },
    {
      "id": "thag6.13:4.3",
      "pali": "Paccuggantuṁ balaṁ natthi,"
    },
    {
      "id": "thag6.13:4.4",
      "pali": "javo natthi palāyituṁ."
    },
    {
      "id": "thag6.13:5.1",
      "pali": "Amoghaṁ divasaṁ kayirā,"
    },
    {
      "id": "thag6.13:5.2",
      "pali": "appena bahukena vā;"
    },
    {
      "id": "thag6.13:5.3",
      "pali": "Yaṁ yaṁ vijahate rattiṁ,"
    },
    {
      "id": "thag6.13:5.4",
      "pali": "tadūnaṁ tassa jīvitaṁ."
    },
    {
      "id": "thag6.13:6.1",
      "pali": "Carato tiṭṭhato vāpi,"
    },
    {
      "id": "thag6.13:6.2",
      "pali": "āsīnasayanassa vā;"
    },
    {
      "id": "thag6.13:6.3",
      "pali": "Upeti carimā ratti,"
    },
    {
      "id": "thag6.13:6.4",
      "pali": "na te kālo pamajjitun”ti."
    },
    {
      "id": "thag6.13:6.5",
      "pali": "… Sirimaṇḍo thero …."
    }
  ]
}
