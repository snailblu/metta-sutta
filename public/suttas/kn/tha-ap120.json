{
  "uid": "tha-ap120",
  "title": "Maggasaññakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap120:1.1",
      "pali": "“Padumuttarabuddhassa,"
    },
    {
      "id": "tha-ap120:1.2",
      "pali": "sāvakā vanacārino;"
    },
    {
      "id": "tha-ap120:1.3",
      "pali": "Vippanaṭṭhā brahāraññe,"
    },
    {
      "id": "tha-ap120:1.4",
      "pali": "andhāva anusuyyare."
    },
    {
      "id": "tha-ap120:2.1",
      "pali": "Anussaritvā sambuddhaṁ,"
    },
    {
      "id": "tha-ap120:2.2",
      "pali": "padumuttaranāyakaṁ;"
    },
    {
      "id": "tha-ap120:2.3",
      "pali": "Tassa te munino puttā,"
    },
    {
      "id": "tha-ap120:2.4",
      "pali": "vippanaṭṭhā mahāvane."
    },
    {
      "id": "tha-ap120:3.1",
      "pali": "Bhavanā oruhitvāna,"
    },
    {
      "id": "tha-ap120:3.2",
      "pali": "agamiṁ bhikkhusantikaṁ;"
    },
    {
      "id": "tha-ap120:3.3",
      "pali": "Tesaṁ maggañca ācikkhiṁ,"
    },
    {
      "id": "tha-ap120:3.4",
      "pali": "bhojanañca adāsahaṁ."
    },
    {
      "id": "tha-ap120:4.1",
      "pali": "Tena kammena dvipadinda,"
    },
    {
      "id": "tha-ap120:4.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap120:4.3",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap120:4.4",
      "pali": "arahattamapāpuṇiṁ."
    },
    {
      "id": "tha-ap120:5.1",
      "pali": "Sacakkhū nāma nāmena,"
    },
    {
      "id": "tha-ap120:5.2",
      "pali": "dvādasa cakkavattino;"
    },
    {
      "id": "tha-ap120:5.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap120:5.4",
      "pali": "pañcakappasate ito."
    },
    {
      "id": "tha-ap120:6.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap120:6.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap120:6.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap120:7.1",
      "pali": "Itthaṁ sudaṁ āyasmā maggasaññako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap120:8.1",
      "pali": "Maggasaññakattherassāpadānaṁ aṭṭhamaṁ."
    }
  ]
}
