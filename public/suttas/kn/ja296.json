{
  "uid": "ja296",
  "title": "Kumbhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja296:1.1",
      "pali": "“Ko nāyaṁ loṇatoyasmiṁ,"
    },
    {
      "id": "ja296:1.2",
      "pali": "samantā paridhāvati;"
    },
    {
      "id": "ja296:1.3",
      "pali": "Macche makare ca vāreti,"
    },
    {
      "id": "ja296:1.4",
      "pali": "ūmīsu ca vihaññati”."
    },
    {
      "id": "ja296:2.1",
      "pali": "“Anantapāyī sakuṇo,"
    },
    {
      "id": "ja296:2.2",
      "pali": "atittoti disāsuto;"
    },
    {
      "id": "ja296:2.3",
      "pali": "Samuddaṁ pātumicchāmi,"
    },
    {
      "id": "ja296:2.4",
      "pali": "sāgaraṁ saritaṁ patiṁ”."
    },
    {
      "id": "ja296:3.1",
      "pali": "“So ayaṁ hāyati ceva,"
    },
    {
      "id": "ja296:3.2",
      "pali": "pūrate ca mahodadhi;"
    },
    {
      "id": "ja296:3.3",
      "pali": "Nāssa nāyati pītanto,"
    },
    {
      "id": "ja296:3.4",
      "pali": "apeyyo kira sāgaro”ti."
    },
    {
      "id": "ja296:4.1",
      "pali": "Samuddajātakaṁ chaṭṭhaṁ."
    }
  ]
}
