{
  "uid": "ja64",
  "title": "Itthivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja64:1.1",
      "pali": "Mā su nandi icchati maṁ,"
    },
    {
      "id": "ja64:1.2",
      "pali": "mā su soci na micchati;"
    },
    {
      "id": "ja64:1.3",
      "pali": "Thīnaṁ bhāvo durājāno,"
    },
    {
      "id": "ja64:1.4",
      "pali": "macchassevodake gatan”ti."
    },
    {
      "id": "ja64:2.1",
      "pali": "Durājānajātakaṁ catutthaṁ."
    }
  ]
}
