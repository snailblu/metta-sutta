{
  "uid": "tha-ap29",
  "title": "7 Pulinapūjakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap29:1.1",
      "pali": "“Vipassissa bhagavato,"
    },
    {
      "id": "tha-ap29:1.2",
      "pali": "bodhiyā pādaputtame;"
    },
    {
      "id": "tha-ap29:1.3",
      "pali": "Purāṇapulinaṁ hitvā,"
    },
    {
      "id": "tha-ap29:1.4",
      "pali": "suddhapulinamākiriṁ."
    },
    {
      "id": "tha-ap29:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap29:2.2",
      "pali": "yaṁ pulinamadāsahaṁ;"
    },
    {
      "id": "tha-ap29:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap29:2.4",
      "pali": "pulinadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap29:3.1",
      "pali": "Tiṁsatime ito kappe,"
    },
    {
      "id": "tha-ap29:3.2",
      "pali": "rājā āsiṁ janādhibhū;"
    },
    {
      "id": "tha-ap29:3.3",
      "pali": "Mahāpulinanāmena,"
    },
    {
      "id": "tha-ap29:3.4",
      "pali": "cakkavattī mahabbalo."
    },
    {
      "id": "tha-ap29:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap29:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap29:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap29:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap29:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā pulinapūjako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap29:6.1",
      "pali": "Pulinapūjakattherassāpadānaṁ sattamaṁ."
    }
  ]
}
