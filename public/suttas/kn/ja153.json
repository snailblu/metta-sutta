{
  "uid": "ja153",
  "title": "Daḷhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja153:1.1",
      "pali": "“Catuppado ahaṁ samma,"
    },
    {
      "id": "ja153:1.2",
      "pali": "tvampi samma catuppado;"
    },
    {
      "id": "ja153:1.3",
      "pali": "Ehi samma nivattassu,"
    },
    {
      "id": "ja153:1.4",
      "pali": "kiṁ nu bhīto palāyasi”."
    },
    {
      "id": "ja153:2.1",
      "pali": "“Asuci pūtilomosi,"
    },
    {
      "id": "ja153:2.2",
      "pali": "duggandho vāsi sūkara;"
    },
    {
      "id": "ja153:2.3",
      "pali": "Sace yujjhitukāmosi,"
    },
    {
      "id": "ja153:2.4",
      "pali": "jayaṁ samma dadāmi te”ti."
    },
    {
      "id": "ja153:3.1",
      "pali": "Sūkarajātakaṁ tatiyaṁ."
    }
  ]
}
