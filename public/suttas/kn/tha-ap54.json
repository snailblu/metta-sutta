{
  "uid": "tha-ap54",
  "title": "2 Sataraṁsittheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap54:1.1",
      "pali": "“Ubbiddhaṁ selamāruyha,"
    },
    {
      "id": "tha-ap54:1.2",
      "pali": "nisīdi purisuttamo;"
    },
    {
      "id": "tha-ap54:1.3",
      "pali": "Pabbatassāvidūramhi,"
    },
    {
      "id": "tha-ap54:1.4",
      "pali": "brāhmaṇo mantapāragū."
    },
    {
      "id": "tha-ap54:2.1",
      "pali": "Upaviṭṭhaṁ mahāvīraṁ,"
    },
    {
      "id": "tha-ap54:2.2",
      "pali": "devadevaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap54:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap54:2.4",
      "pali": "santhaviṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap54:3.1",
      "pali": "‘Esa buddho mahāvīro,"
    },
    {
      "id": "tha-ap54:3.2",
      "pali": "varadhammappakāsako;"
    },
    {
      "id": "tha-ap54:3.3",
      "pali": "Jalati aggikhandhova,"
    },
    {
      "id": "tha-ap54:3.4",
      "pali": "bhikkhusaṅghapurakkhato."
    },
    {
      "id": "tha-ap54:4.1",
      "pali": "Mahāsamuddovakkhubbho,"
    },
    {
      "id": "tha-ap54:4.2",
      "pali": "aṇṇavova duruttaro;"
    },
    {
      "id": "tha-ap54:4.3",
      "pali": "Migarājāvasambhīto,"
    },
    {
      "id": "tha-ap54:4.4",
      "pali": "dhammaṁ deseti cakkhumā’."
    },
    {
      "id": "tha-ap54:5.1",
      "pali": "Mama saṅkappamaññāya,"
    },
    {
      "id": "tha-ap54:5.2",
      "pali": "padumuttaranāyako;"
    },
    {
      "id": "tha-ap54:5.3",
      "pali": "Bhikkhusaṅghe ṭhito satthā,"
    },
    {
      "id": "tha-ap54:5.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap54:6.1",
      "pali": "‘Yenāyaṁ añjalī dinno,"
    },
    {
      "id": "tha-ap54:6.2",
      "pali": "buddhaseṭṭho ca thomito;"
    },
    {
      "id": "tha-ap54:6.3",
      "pali": "Tiṁsakappasahassāni,"
    },
    {
      "id": "tha-ap54:6.4",
      "pali": "devarajjaṁ karissati."
    },
    {
      "id": "tha-ap54:7.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap54:7.2",
      "pali": "aṅgīrasasanāmako;"
    },
    {
      "id": "tha-ap54:7.3",
      "pali": "Vivaṭṭacchado sambuddho,"
    },
    {
      "id": "tha-ap54:7.4",
      "pali": "uppajjissati tāvade."
    },
    {
      "id": "tha-ap54:8.1",
      "pali": "Tassa dhammesu dāyādo,"
    },
    {
      "id": "tha-ap54:8.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap54:8.3",
      "pali": "Sataraṁsīti nāmena,"
    },
    {
      "id": "tha-ap54:8.4",
      "pali": "arahā so bhavissati’."
    },
    {
      "id": "tha-ap54:9.1",
      "pali": "Jātiyā sattavassohaṁ,"
    },
    {
      "id": "tha-ap54:9.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap54:9.3",
      "pali": "Sataraṁsimhi nāmena,"
    },
    {
      "id": "tha-ap54:9.4",
      "pali": "pabhā niddhāvate mama."
    },
    {
      "id": "tha-ap54:10.1",
      "pali": "Maṇḍape rukkhamūle vā,"
    },
    {
      "id": "tha-ap54:10.2",
      "pali": "jhāyī jhānarato ahaṁ;"
    },
    {
      "id": "tha-ap54:10.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap54:10.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap54:11.1",
      "pali": "Saṭṭhikappasahassamhi,"
    },
    {
      "id": "tha-ap54:11.2",
      "pali": "caturo rāmanāmakā;"
    },
    {
      "id": "tha-ap54:11.3",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "tha-ap54:11.4",
      "pali": "cakkavattī mahabbalā."
    },
    {
      "id": "tha-ap54:12.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap54:12.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap54:12.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap54:13.1",
      "pali": "Itthaṁ sudaṁ āyasmā sataraṁsi thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap54:14.1",
      "pali": "Sataraṁsittherassāpadānaṁ dutiyaṁ."
    }
  ]
}
