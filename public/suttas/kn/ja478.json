{
  "uid": "ja478",
  "title": "Ambavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja478:1.1",
      "pali": "“Dūte te brahme pāhesiṁ,"
    },
    {
      "id": "ja478:1.2",
      "pali": "Gaṅgātīrasmi jhāyato;"
    },
    {
      "id": "ja478:1.3",
      "pali": "Tesaṁ puṭṭho na byākāsi,"
    },
    {
      "id": "ja478:1.4",
      "pali": "Dukkhaṁ guyhamataṁ nu te”."
    },
    {
      "id": "ja478:2.1",
      "pali": "“Sace te dukkhamuppajje,"
    },
    {
      "id": "ja478:2.2",
      "pali": "kāsīnaṁ raṭṭhavaḍḍhana;"
    },
    {
      "id": "ja478:2.3",
      "pali": "Mā kho naṁ tassa akkhāhi,"
    },
    {
      "id": "ja478:2.4",
      "pali": "yo taṁ dukkhā na mocaye."
    },
    {
      "id": "ja478:3.1",
      "pali": "Yo tassa dukkhajātassa,"
    },
    {
      "id": "ja478:3.2",
      "pali": "ekaṅgamapi bhāgaso;"
    },
    {
      "id": "ja478:3.3",
      "pali": "Vippamoceyya dhammena,"
    },
    {
      "id": "ja478:3.4",
      "pali": "kāmaṁ tassa pavedaya."
    },
    {
      "id": "ja478:4.1",
      "pali": "Suvijānaṁ siṅgālānaṁ,"
    },
    {
      "id": "ja478:4.2",
      "pali": "sakuṇānañca vassitaṁ;"
    },
    {
      "id": "ja478:4.3",
      "pali": "Manussavassitaṁ rāja,"
    },
    {
      "id": "ja478:4.4",
      "pali": "dubbijānataraṁ tato."
    },
    {
      "id": "ja478:5.1",
      "pali": "Api ce maññatī poso,"
    },
    {
      "id": "ja478:5.2",
      "pali": "ñāti mitto sakhāti vā;"
    },
    {
      "id": "ja478:5.3",
      "pali": "Yo pubbe sumano hutvā,"
    },
    {
      "id": "ja478:5.4",
      "pali": "pacchā sampajjate diso."
    },
    {
      "id": "ja478:6.1",
      "pali": "Yo attano dukkhamanānupuṭṭho,"
    },
    {
      "id": "ja478:6.2",
      "pali": "Pavedaye jantu akālarūpe;"
    },
    {
      "id": "ja478:6.3",
      "pali": "Ānandino tassa bhavantimittā,"
    },
    {
      "id": "ja478:6.4",
      "pali": "Hitesino tassa dukhī bhavanti."
    },
    {
      "id": "ja478:7.1",
      "pali": "Kālañca ñatvāna tathāvidhassa,"
    },
    {
      "id": "ja478:7.2",
      "pali": "Medhāvīnaṁ ekamanaṁ viditvā;"
    },
    {
      "id": "ja478:7.3",
      "pali": "Akkheyya tibbāni parassa dhīro,"
    },
    {
      "id": "ja478:7.4",
      "pali": "Saṇhaṁ giraṁ atthavatiṁ pamuñce."
    },
    {
      "id": "ja478:8.1",
      "pali": "Sace ca jaññā avisayhamattano,"
    },
    {
      "id": "ja478:8.2",
      "pali": "Na te hi mayhaṁ sukhāgamāya;"
    },
    {
      "id": "ja478:8.3",
      "pali": "Ekova tibbāni saheyya dhīro,"
    },
    {
      "id": "ja478:8.4",
      "pali": "Saccaṁ hirottappamapekkhamāno."
    },
    {
      "id": "ja478:9.1",
      "pali": "Ahaṁ raṭṭhe vicaranto,"
    },
    {
      "id": "ja478:9.2",
      "pali": "nigame rājadhāniyo;"
    },
    {
      "id": "ja478:9.3",
      "pali": "Bhikkhamāno mahārāja,"
    },
    {
      "id": "ja478:9.4",
      "pali": "ācariyassa dhanatthiko."
    },
    {
      "id": "ja478:10.1",
      "pali": "Gahapatī rājapurise,"
    },
    {
      "id": "ja478:10.2",
      "pali": "mahāsāle ca brāhmaṇe;"
    },
    {
      "id": "ja478:10.3",
      "pali": "Alatthaṁ satta nikkhāni,"
    },
    {
      "id": "ja478:10.4",
      "pali": "suvaṇṇassa janādhipa;"
    },
    {
      "id": "ja478:10.5",
      "pali": "Te me naṭṭhā mahārāja,"
    },
    {
      "id": "ja478:10.6",
      "pali": "tasmā socāmahaṁ bhusaṁ."
    },
    {
      "id": "ja478:11.1",
      "pali": "Purisā te mahārāja,"
    },
    {
      "id": "ja478:11.2",
      "pali": "manasānuvicintitā;"
    },
    {
      "id": "ja478:11.3",
      "pali": "Nālaṁ dukkhā pamocetuṁ,"
    },
    {
      "id": "ja478:11.4",
      "pali": "tasmā tesaṁ na byāhariṁ."
    },
    {
      "id": "ja478:12.1",
      "pali": "Tvañca kho me mahārāja,"
    },
    {
      "id": "ja478:12.2",
      "pali": "manasānuvicintito;"
    },
    {
      "id": "ja478:12.3",
      "pali": "Alaṁ dukkhā pamocetuṁ,"
    },
    {
      "id": "ja478:12.4",
      "pali": "tasmā tuyhaṁ pavedayiṁ”."
    },
    {
      "id": "ja478:13.1",
      "pali": "“Tassādāsi pasannatto,"
    },
    {
      "id": "ja478:13.2",
      "pali": "kāsīnaṁ raṭṭhavaḍḍhano;"
    },
    {
      "id": "ja478:13.3",
      "pali": "Jātarūpamaye nikkhe,"
    },
    {
      "id": "ja478:13.4",
      "pali": "suvaṇṇassa catuddasā”ti."
    },
    {
      "id": "ja478:14.1",
      "pali": "Dūtajātakaṁ pañcamaṁ."
    }
  ]
}
