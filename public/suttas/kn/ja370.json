{
  "uid": "ja370",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja370:1.1",
      "pali": "“Haṁso palāsamavaca,"
    },
    {
      "id": "ja370:1.2",
      "pali": "nigrodho samma jāyati;"
    },
    {
      "id": "ja370:1.3",
      "pali": "Aṅkasmiṁ te nisinnova,"
    },
    {
      "id": "ja370:1.4",
      "pali": "so te mammāni checchati”."
    },
    {
      "id": "ja370:2.1",
      "pali": "“Vaḍḍhatāmeva nigrodho,"
    },
    {
      "id": "ja370:2.2",
      "pali": "patiṭṭhassa bhavāmahaṁ;"
    },
    {
      "id": "ja370:2.3",
      "pali": "Yathā pitā ca mātā ca,"
    },
    {
      "id": "ja370:2.4",
      "pali": "evaṁ me so bhavissati”."
    },
    {
      "id": "ja370:3.1",
      "pali": "“Yaṁ tvaṁ aṅkasmiṁ vaḍḍhesi,"
    },
    {
      "id": "ja370:3.2",
      "pali": "khīrarukkhaṁ bhayānakaṁ;"
    },
    {
      "id": "ja370:3.3",
      "pali": "Āmanta kho taṁ gacchāma,"
    },
    {
      "id": "ja370:3.4",
      "pali": "vuḍḍhi massa na ruccati”."
    },
    {
      "id": "ja370:4.1",
      "pali": "“Idāni kho maṁ bhāyeti,"
    },
    {
      "id": "ja370:4.2",
      "pali": "mahānerunidassanaṁ;"
    },
    {
      "id": "ja370:4.3",
      "pali": "Haṁsassa anabhiññāya,"
    },
    {
      "id": "ja370:4.4",
      "pali": "mahā me bhayamāgataṁ”."
    },
    {
      "id": "ja370:5.1",
      "pali": "“Na tassa vuḍḍhi kusalappasatthā,"
    },
    {
      "id": "ja370:5.2",
      "pali": "Yo vaḍḍhamāno ghasate patiṭṭhaṁ;"
    },
    {
      "id": "ja370:5.3",
      "pali": "Tassūparodhaṁ parisaṅkamāno,"
    },
    {
      "id": "ja370:5.4",
      "pali": "Patārayī mūlavadhāya dhīro”ti."
    },
    {
      "id": "ja370:6.1",
      "pali": "Palāsajātakaṁ dasamaṁ."
    },
    {
      "id": "ja370:6.2",
      "pali": "Vaṇṇārohavaggo dutiyo."
    }
  ]
}
