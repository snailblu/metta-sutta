{
  "uid": "tha-ap431",
  "title": "9 Sovaṇṇakiṅkaṇiyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap431:1.1",
      "pali": "“Saddhāya abhinikkhamma,"
    },
    {
      "id": "tha-ap431:1.2",
      "pali": "pabbajiṁ anagāriyaṁ;"
    },
    {
      "id": "tha-ap431:1.3",
      "pali": "Vākacīradharo āsiṁ,"
    },
    {
      "id": "tha-ap431:1.4",
      "pali": "tapokammamapassito."
    },
    {
      "id": "tha-ap431:2.1",
      "pali": "Atthadassī tu bhagavā,"
    },
    {
      "id": "tha-ap431:2.2",
      "pali": "lokajeṭṭho narāsabho;"
    },
    {
      "id": "tha-ap431:2.3",
      "pali": "Uppajji tamhi samaye,"
    },
    {
      "id": "tha-ap431:2.4",
      "pali": "tārayanto mahājanaṁ."
    },
    {
      "id": "tha-ap431:3.1",
      "pali": "Balañca vata me khīṇaṁ,"
    },
    {
      "id": "tha-ap431:3.2",
      "pali": "byādhinā paramena taṁ;"
    },
    {
      "id": "tha-ap431:3.3",
      "pali": "Buddhaseṭṭhaṁ saritvāna,"
    },
    {
      "id": "tha-ap431:3.4",
      "pali": "puline thūpamuttamaṁ."
    },
    {
      "id": "tha-ap431:4.1",
      "pali": "Karitvā haṭṭhacittohaṁ,"
    },
    {
      "id": "tha-ap431:4.2",
      "pali": "sahatthena samokiriṁ;"
    },
    {
      "id": "tha-ap431:4.3",
      "pali": "Soṇṇakiṅkaṇipupphāni,"
    },
    {
      "id": "tha-ap431:4.4",
      "pali": "udaggamanaso ahaṁ."
    },
    {
      "id": "tha-ap431:5.1",
      "pali": "Sammukhā viya sambuddhaṁ,"
    },
    {
      "id": "tha-ap431:5.2",
      "pali": "thūpaṁ paricariṁ ahaṁ;"
    },
    {
      "id": "tha-ap431:5.3",
      "pali": "Tena cetopasādena,"
    },
    {
      "id": "tha-ap431:5.4",
      "pali": "atthadassissa tādino."
    },
    {
      "id": "tha-ap431:6.1",
      "pali": "Devalokaṁ gato santo,"
    },
    {
      "id": "tha-ap431:6.2",
      "pali": "labhāmi vipulaṁ sukhaṁ;"
    },
    {
      "id": "tha-ap431:6.3",
      "pali": "Suvaṇṇavaṇṇo tatthāsiṁ,"
    },
    {
      "id": "tha-ap431:6.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap431:7.1",
      "pali": "Asītikoṭiyo mayhaṁ,"
    },
    {
      "id": "tha-ap431:7.2",
      "pali": "nāriyo samalaṅkatā;"
    },
    {
      "id": "tha-ap431:7.3",
      "pali": "Sadā mayhaṁ upaṭṭhanti,"
    },
    {
      "id": "tha-ap431:7.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap431:8.1",
      "pali": "Saṭṭhituriyasahassāni,"
    },
    {
      "id": "tha-ap431:8.2",
      "pali": "bheriyo paṇavāni ca;"
    },
    {
      "id": "tha-ap431:8.3",
      "pali": "Saṅkhā ca ḍiṇḍimā tattha,"
    },
    {
      "id": "tha-ap431:8.4",
      "pali": "vaggū vajjanti dundubhī."
    },
    {
      "id": "tha-ap431:9.1",
      "pali": "Cullāsītisahassāni,"
    },
    {
      "id": "tha-ap431:9.2",
      "pali": "hatthino samalaṅkatā;"
    },
    {
      "id": "tha-ap431:9.3",
      "pali": "Tidhāpabhinnamātaṅgā,"
    },
    {
      "id": "tha-ap431:9.4",
      "pali": "kuñjarā saṭṭhihāyanā."
    },
    {
      "id": "tha-ap431:10.1",
      "pali": "Hemajālābhisañchannā,"
    },
    {
      "id": "tha-ap431:10.2",
      "pali": "upaṭṭhānaṁ karonti me;"
    },
    {
      "id": "tha-ap431:10.3",
      "pali": "Balakāye gaje ceva,"
    },
    {
      "id": "tha-ap431:10.4",
      "pali": "ūnatā me na vijjati."
    },
    {
      "id": "tha-ap431:11.1",
      "pali": "Soṇṇakiṅkaṇipupphānaṁ,"
    },
    {
      "id": "tha-ap431:11.2",
      "pali": "vipākaṁ anubhomahaṁ;"
    },
    {
      "id": "tha-ap431:11.3",
      "pali": "Aṭṭhapaññāsakkhattuñca,"
    },
    {
      "id": "tha-ap431:11.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "tha-ap431:12.1",
      "pali": "Ekasattatikkhattuñca,"
    },
    {
      "id": "tha-ap431:12.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap431:12.3",
      "pali": "Pathabyā rajjaṁ ekasataṁ,"
    },
    {
      "id": "tha-ap431:12.4",
      "pali": "mahiyā kārayiṁ ahaṁ."
    },
    {
      "id": "tha-ap431:13.1",
      "pali": "So dāni amataṁ patto,"
    },
    {
      "id": "tha-ap431:13.2",
      "pali": "asaṅkhataṁ sududdasaṁ;"
    },
    {
      "id": "tha-ap431:13.3",
      "pali": "Saṁyojanaparikkhīṇo,"
    },
    {
      "id": "tha-ap431:13.4",
      "pali": "natthi dāni punabbhavo."
    },
    {
      "id": "tha-ap431:14.1",
      "pali": "Aṭṭhārase kappasate,"
    },
    {
      "id": "tha-ap431:14.2",
      "pali": "yaṁ pupphamabhiropayiṁ;"
    },
    {
      "id": "tha-ap431:14.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap431:14.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap431:15.1",
      "pali": "Kilesā jhāpitā mayhaṁ,"
    },
    {
      "id": "tha-ap431:15.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap431:15.3",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap431:16.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "tha-ap431:16.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap431:16.3",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "tha-ap431:17.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap431:17.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap431:17.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap431:18.1",
      "pali": "Itthaṁ sudaṁ āyasmā sovaṇṇakiṅkaṇiyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap431:19.1",
      "pali": "Sovaṇṇakiṅkaṇiyattherassāpadānaṁ navamaṁ."
    }
  ]
}
