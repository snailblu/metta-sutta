{
  "uid": "thag2.41",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.41:1.1",
      "pali": "“Aho buddhā aho dhammā,"
    },
    {
      "id": "thag2.41:1.2",
      "pali": "aho no satthu sampadā;"
    },
    {
      "id": "thag2.41:1.3",
      "pali": "Yattha etādisaṁ dhammaṁ,"
    },
    {
      "id": "thag2.41:1.4",
      "pali": "sāvako sacchikāhiti."
    },
    {
      "id": "thag2.41:2.1",
      "pali": "Asaṅkheyyesu kappesu,"
    },
    {
      "id": "thag2.41:2.2",
      "pali": "sakkāyādhigatā ahū;"
    },
    {
      "id": "thag2.41:2.3",
      "pali": "Tesamayaṁ pacchimako,"
    },
    {
      "id": "thag2.41:2.4",
      "pali": "carimoyaṁ samussayo;"
    },
    {
      "id": "thag2.41:2.5",
      "pali": "Jātimaraṇasaṁsāro,"
    },
    {
      "id": "thag2.41:2.6",
      "pali": "natthi dāni punabbhavo”ti."
    },
    {
      "id": "thag2.41:2.7",
      "pali": "… Kumārakassapo thero …."
    }
  ]
}
