{
  "uid": "cp29",
  "title": "Saccapāramī 3",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp29:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp29:1.2",
      "pali": "magadhe vaṭṭapotako;"
    },
    {
      "id": "cp29:1.3",
      "pali": "Ajātapakkho taruṇo,"
    },
    {
      "id": "cp29:1.4",
      "pali": "maṁsapesi kulāvake."
    },
    {
      "id": "cp29:2.1",
      "pali": "Mukhatuṇḍakenāharitvā,"
    },
    {
      "id": "cp29:2.2",
      "pali": "mātā posayatī mamaṁ;"
    },
    {
      "id": "cp29:2.3",
      "pali": "Tassā phassena jīvāmi,"
    },
    {
      "id": "cp29:2.4",
      "pali": "natthi me kāyikaṁ balaṁ."
    },
    {
      "id": "cp29:3.1",
      "pali": "Saṁvacchare gimhasamaye,"
    },
    {
      "id": "cp29:3.2",
      "pali": "davaḍāho padippati;"
    },
    {
      "id": "cp29:3.3",
      "pali": "Upagacchati amhākaṁ,"
    },
    {
      "id": "cp29:3.4",
      "pali": "pāvako kaṇhavattanī."
    },
    {
      "id": "cp29:4.1",
      "pali": "Dhamadhamāiti evaṁ,"
    },
    {
      "id": "cp29:4.2",
      "pali": "saddāyanto mahāsikhī;"
    },
    {
      "id": "cp29:4.3",
      "pali": "Anupubbena jhāpento,"
    },
    {
      "id": "cp29:4.4",
      "pali": "aggi mamamupāgami."
    },
    {
      "id": "cp29:5.1",
      "pali": "Aggivegabhayātītā,"
    },
    {
      "id": "cp29:5.2",
      "pali": "tasitā mātāpitā mama;"
    },
    {
      "id": "cp29:5.3",
      "pali": "Kulāvake maṁ chaḍḍetvā,"
    },
    {
      "id": "cp29:5.4",
      "pali": "attānaṁ parimocayuṁ."
    },
    {
      "id": "cp29:6.1",
      "pali": "Pāde pakkhe pajahāmi,"
    },
    {
      "id": "cp29:6.2",
      "pali": "natthi me kāyikaṁ balaṁ;"
    },
    {
      "id": "cp29:6.3",
      "pali": "Sohaṁ agatiko tattha,"
    },
    {
      "id": "cp29:6.4",
      "pali": "evaṁ cintesahaṁ tadā."
    },
    {
      "id": "cp29:7.1",
      "pali": "‘Yesāhaṁ upadhāveyyaṁ,"
    },
    {
      "id": "cp29:7.2",
      "pali": "bhīto tasitavedhito;"
    },
    {
      "id": "cp29:7.3",
      "pali": "Te maṁ ohāya pakkantā,"
    },
    {
      "id": "cp29:7.4",
      "pali": "kathaṁ me ajja kātave."
    },
    {
      "id": "cp29:8.1",
      "pali": "Atthi loke sīlaguṇo,"
    },
    {
      "id": "cp29:8.2",
      "pali": "saccaṁ soceyyanuddayā;"
    },
    {
      "id": "cp29:8.3",
      "pali": "Tena saccena kāhāmi,"
    },
    {
      "id": "cp29:8.4",
      "pali": "saccakiriyamuttamaṁ."
    },
    {
      "id": "cp29:9.1",
      "pali": "Āvejjetvā dhammabalaṁ,"
    },
    {
      "id": "cp29:9.2",
      "pali": "saritvā pubbake jine;"
    },
    {
      "id": "cp29:9.3",
      "pali": "Saccabalamavassāya,"
    },
    {
      "id": "cp29:9.4",
      "pali": "saccakiriyamakāsahaṁ."
    },
    {
      "id": "cp29:10.1",
      "pali": "Santi pakkhā apatanā,"
    },
    {
      "id": "cp29:10.2",
      "pali": "santi pādā avañcanā;"
    },
    {
      "id": "cp29:10.3",
      "pali": "Mātāpitā ca nikkhantā,"
    },
    {
      "id": "cp29:10.4",
      "pali": "jātaveda paṭikkama’."
    },
    {
      "id": "cp29:11.1",
      "pali": "Sahasacce kate mayhaṁ,"
    },
    {
      "id": "cp29:11.2",
      "pali": "Mahāpajjalito sikhī;"
    },
    {
      "id": "cp29:11.3",
      "pali": "Vajjesi soḷasakarīsāni,"
    },
    {
      "id": "cp29:11.4",
      "pali": "Udakaṁ patvā yathā sikhī;"
    },
    {
      "id": "cp29:11.5",
      "pali": "Saccena me samo natthi,"
    },
    {
      "id": "cp29:11.6",
      "pali": "Esā me saccapāramī”ti."
    },
    {
      "id": "cp29:12.1",
      "pali": "Vaṭṭapotakacariyaṁ navamaṁ."
    }
  ]
}
