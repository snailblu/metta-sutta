{
  "uid": "vv53",
  "title": "Mahārathavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "vv53:1.1",
      "pali": "“Yo vadataṁ pavaro manujesu,"
    },
    {
      "id": "vv53:1.2",
      "pali": "Sakyamunī bhagavā katakicco;"
    },
    {
      "id": "vv53:1.3",
      "pali": "Pāragato balaviriyasamaṅgī,"
    },
    {
      "id": "vv53:1.4",
      "pali": "Taṁ sugataṁ saraṇatthamupehi."
    },
    {
      "id": "vv53:2.1",
      "pali": "Rāgavirāgamanejamasokaṁ,"
    },
    {
      "id": "vv53:2.2",
      "pali": "Dhammamasaṅkhatamappaṭikūlaṁ;"
    },
    {
      "id": "vv53:2.3",
      "pali": "Madhuramimaṁ paguṇaṁ suvibhattaṁ,"
    },
    {
      "id": "vv53:2.4",
      "pali": "Dhammamimaṁ saraṇatthamupehi."
    },
    {
      "id": "vv53:3.1",
      "pali": "Yattha ca dinna mahapphalamāhu,"
    },
    {
      "id": "vv53:3.2",
      "pali": "Catūsu sucīsu purisayugesu;"
    },
    {
      "id": "vv53:3.3",
      "pali": "Aṭṭha ca puggaladhammadasā te,"
    },
    {
      "id": "vv53:3.4",
      "pali": "Saṅghamimaṁ saraṇatthamupehi."
    },
    {
      "id": "vv53:4.1",
      "pali": "Na tathā tapati nabhe sūriyo,"
    },
    {
      "id": "vv53:4.2",
      "pali": "Cando ca na bhāsati na phusso;"
    },
    {
      "id": "vv53:4.3",
      "pali": "Yathā atulamidaṁ mahappabhāsaṁ,"
    },
    {
      "id": "vv53:4.4",
      "pali": "Ko nu tvaṁ tidivā mahiṁ upāgā."
    },
    {
      "id": "vv53:5.1",
      "pali": "Chindati raṁsī pabhaṅkarassa,"
    },
    {
      "id": "vv53:5.2",
      "pali": "Sādhikavīsatiyojanāni ābhā;"
    },
    {
      "id": "vv53:5.3",
      "pali": "Rattimapi yathā divaṁ karoti,"
    },
    {
      "id": "vv53:5.4",
      "pali": "Parisuddhaṁ vimalaṁ subhaṁ vimānaṁ."
    },
    {
      "id": "vv53:6.1",
      "pali": "Bahupadumavicitrapuṇḍarīkaṁ,"
    },
    {
      "id": "vv53:6.2",
      "pali": "Vokiṇṇaṁ kusumehi nekacittaṁ;"
    },
    {
      "id": "vv53:6.3",
      "pali": "Arajavirajahemajālachannaṁ,"
    },
    {
      "id": "vv53:6.4",
      "pali": "Ākāse tapati yathāpi sūriyo."
    },
    {
      "id": "vv53:7.1",
      "pali": "Rattambarapītavāsasāhi,"
    },
    {
      "id": "vv53:7.2",
      "pali": "Agarupiyaṅgucandanussadāhi;"
    },
    {
      "id": "vv53:7.3",
      "pali": "Kañcanatanusannibhattacāhi,"
    },
    {
      "id": "vv53:7.4",
      "pali": "Paripūraṁ gaganaṁva tārakāhi."
    },
    {
      "id": "vv53:8.1",
      "pali": "Naranāriyo bahuketthanekavaṇṇā,"
    },
    {
      "id": "vv53:8.2",
      "pali": "Kusumavibhūsitābharaṇettha sumanā;"
    },
    {
      "id": "vv53:8.3",
      "pali": "Anilapamuñcitā pavanti surabhiṁ,"
    },
    {
      "id": "vv53:8.4",
      "pali": "Tapaniyavitatā suvaṇṇachannā."
    },
    {
      "id": "vv53:9.1",
      "pali": "Kissa saṁyamassa ayaṁ vipāko,"
    },
    {
      "id": "vv53:9.2",
      "pali": "Kenāsi kammaphalenidhūpapanno;"
    },
    {
      "id": "vv53:9.3",
      "pali": "Yathā ca te adhigatamidaṁ vimānaṁ,"
    },
    {
      "id": "vv53:9.4",
      "pali": "Tadanupadaṁ avacāsi iṅgha puṭṭho”ti."
    },
    {
      "id": "vv53:10.1",
      "pali": "“Sayamidha pathe samecca māṇavena,"
    },
    {
      "id": "vv53:10.2",
      "pali": "Satthānusāsi anukampamāno;"
    },
    {
      "id": "vv53:10.3",
      "pali": "Tava ratanavarassa dhammaṁ sutvā,"
    },
    {
      "id": "vv53:10.4",
      "pali": "Karissāmīti ca bravittha chatto."
    },
    {
      "id": "vv53:11.1",
      "pali": "Jinavarapavaraṁ upehi saraṇaṁ,"
    },
    {
      "id": "vv53:11.2",
      "pali": "Dhammañcāpi tatheva bhikkhusaṅghaṁ;"
    },
    {
      "id": "vv53:11.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:11.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:12.1",
      "pali": "Mā ca pāṇavadhaṁ vividhaṁ carassu asuciṁ,"
    },
    {
      "id": "vv53:12.2",
      "pali": "Na hi pāṇesu asaññataṁ avaṇṇayiṁsu sappaññā;"
    },
    {
      "id": "vv53:12.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:12.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:13.1",
      "pali": "Mā ca parajanassa rakkhitampi,"
    },
    {
      "id": "vv53:13.2",
      "pali": "Ādātabbamamaññitho adinnaṁ;"
    },
    {
      "id": "vv53:13.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:13.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:14.1",
      "pali": "Mā ca parajanassa rakkhitāyo,"
    },
    {
      "id": "vv53:14.2",
      "pali": "Parabhariyā agamā anariyametaṁ;"
    },
    {
      "id": "vv53:14.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:14.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:15.1",
      "pali": "Mā ca vitathaṁ aññathā abhāṇi,"
    },
    {
      "id": "vv53:15.2",
      "pali": "Na hi musāvādaṁ avaṇṇayiṁsu sappaññā;"
    },
    {
      "id": "vv53:15.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:15.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:16.1",
      "pali": "Yena ca purisassa apeti saññā,"
    },
    {
      "id": "vv53:16.2",
      "pali": "Taṁ majjaṁ parivajjayassu sabbaṁ;"
    },
    {
      "id": "vv53:16.3",
      "pali": "Noti paṭhamaṁ avocahaṁ bhante,"
    },
    {
      "id": "vv53:16.4",
      "pali": "Pacchā te vacanaṁ tathevakāsiṁ."
    },
    {
      "id": "vv53:17.1",
      "pali": "Svāhaṁ idha pañca sikkhā karitvā,"
    },
    {
      "id": "vv53:17.2",
      "pali": "Paṭipajjitvā tathāgatassa dhamme;"
    },
    {
      "id": "vv53:17.3",
      "pali": "Dvepathamagamāsiṁ coramajjhe,"
    },
    {
      "id": "vv53:17.4",
      "pali": "Te maṁ tattha vadhiṁsu bhogahetu."
    },
    {
      "id": "vv53:18.1",
      "pali": "Ettakamidaṁ anussarāmi kusalaṁ,"
    },
    {
      "id": "vv53:18.2",
      "pali": "Tato paraṁ na me vijjati aññaṁ;"
    },
    {
      "id": "vv53:18.3",
      "pali": "Tena sucaritena kammunāhaṁ,"
    },
    {
      "id": "vv53:18.4",
      "pali": "Uppanno tidivesu kāmakāmī."
    },
    {
      "id": "vv53:19.1",
      "pali": "Passa khaṇamuhuttasaññamassa,"
    },
    {
      "id": "vv53:19.2",
      "pali": "Anudhammappaṭipattiyā vipākaṁ;"
    },
    {
      "id": "vv53:19.3",
      "pali": "Jalamiva yasasā samekkhamānā,"
    },
    {
      "id": "vv53:19.4",
      "pali": "Bahukā maṁ pihayanti hīnakammā."
    },
    {
      "id": "vv53:20.1",
      "pali": "Passa katipayāya desanāya,"
    },
    {
      "id": "vv53:20.2",
      "pali": "Sugatiñcamhi gato sukhañca patto;"
    },
    {
      "id": "vv53:20.3",
      "pali": "Ye ca te satataṁ suṇanti dhammaṁ,"
    },
    {
      "id": "vv53:20.4",
      "pali": "Maññe te amataṁ phusanti khemaṁ."
    },
    {
      "id": "vv53:21.1",
      "pali": "Appampi kataṁ mahāvipākaṁ,"
    },
    {
      "id": "vv53:21.2",
      "pali": "Vipulaṁ hoti tathāgatassa dhamme;"
    },
    {
      "id": "vv53:21.3",
      "pali": "Passa katapuññatāya chatto,"
    },
    {
      "id": "vv53:21.4",
      "pali": "Obhāseti pathaviṁ yathāpi sūriyo."
    },
    {
      "id": "vv53:22.1",
      "pali": "Kimidaṁ kusalaṁ kimācarema,"
    },
    {
      "id": "vv53:22.2",
      "pali": "Icceke hi samecca mantayanti;"
    },
    {
      "id": "vv53:22.3",
      "pali": "Te mayaṁ punareva laddha mānusattaṁ,"
    },
    {
      "id": "vv53:22.4",
      "pali": "Paṭipannā viharemu sīlavanto."
    },
    {
      "id": "vv53:23.1",
      "pali": "Bahukāro anukampako ca satthā,"
    },
    {
      "id": "vv53:23.2",
      "pali": "Iti me sati agamā divā divassa;"
    },
    {
      "id": "vv53:23.3",
      "pali": "Svāhaṁ upagatomhi saccanāmaṁ,"
    },
    {
      "id": "vv53:23.4",
      "pali": "Anukampassu punapi suṇemu dhammaṁ."
    },
    {
      "id": "vv53:24.1",
      "pali": "Ye cidha pajahanti kāmarāgaṁ,"
    },
    {
      "id": "vv53:24.2",
      "pali": "Bhavarāgānusayañca pahāya mohaṁ;"
    },
    {
      "id": "vv53:24.3",
      "pali": "Na ca te punamupenti gabbhaseyyaṁ,"
    },
    {
      "id": "vv53:24.4",
      "pali": "Parinibbānagatā hi sītibhūtā”ti."
    },
    {
      "id": "vv53:25.1",
      "pali": "Chattamāṇavakavimānaṁ tatiyaṁ."
    }
  ]
}
