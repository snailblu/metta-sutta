{
  "uid": "tha-ap303",
  "title": "Padumakesariyattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap303:1.1",
      "pali": "“Isisaṅghe ahaṁ pubbe,"
    },
    {
      "id": "tha-ap303:1.2",
      "pali": "āsiṁ mātaṅgavāraṇo;"
    },
    {
      "id": "tha-ap303:1.3",
      "pali": "Mahesīnaṁ pasādena,"
    },
    {
      "id": "tha-ap303:1.4",
      "pali": "padmakesaramokiriṁ."
    },
    {
      "id": "tha-ap303:2.1",
      "pali": "Paccekajinaseṭṭhesu,"
    },
    {
      "id": "tha-ap303:2.2",
      "pali": "dhutarāgesu tādisu;"
    },
    {
      "id": "tha-ap303:2.3",
      "pali": "Tesu cittaṁ pasādetvā,"
    },
    {
      "id": "tha-ap303:2.4",
      "pali": "kappaṁ saggamhi modahaṁ."
    },
    {
      "id": "tha-ap303:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap303:3.2",
      "pali": "kesaraṁ okiriṁ tadā;"
    },
    {
      "id": "tha-ap303:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap303:3.4",
      "pali": "buddhapūjāyidaṁ phalaṁ."
    },
    {
      "id": "tha-ap303:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap303:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap303:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap303:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap303:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā padumakesariyo thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap303:6.1",
      "pali": "Padumakesariyattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
