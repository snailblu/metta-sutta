{
  "uid": "ja464",
  "title": "Cūḷakuṇālavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja464:1.1",
      "pali": "“Luddhānaṁ lahucittānaṁ,"
    },
    {
      "id": "ja464:1.2",
      "pali": "akataññūna dubbhinaṁ;"
    },
    {
      "id": "ja464:1.3",
      "pali": "Nādevasatto puriso,"
    },
    {
      "id": "ja464:1.4",
      "pali": "thīnaṁ saddhātumarahati."
    },
    {
      "id": "ja464:2.1",
      "pali": "Na tā pajānanti kataṁ na kiccaṁ,"
    },
    {
      "id": "ja464:2.2",
      "pali": "Na mātaraṁ pitaraṁ bhātaraṁ vā;"
    },
    {
      "id": "ja464:2.3",
      "pali": "Anariyā samatikkantadhammā,"
    },
    {
      "id": "ja464:2.4",
      "pali": "Sasseva cittassa vasaṁ vajanti."
    },
    {
      "id": "ja464:3.1",
      "pali": "Cirānuvutthampi piyaṁ manāpaṁ,"
    },
    {
      "id": "ja464:3.2",
      "pali": "Anukampakaṁ pāṇasamampi bhattuṁ;"
    },
    {
      "id": "ja464:3.3",
      "pali": "Āvāsu kiccesu ca naṁ jahanti,"
    },
    {
      "id": "ja464:3.4",
      "pali": "Tasmāhamitthīnaṁ na vissasāmi."
    },
    {
      "id": "ja464:4.1",
      "pali": "Thīnañhi cittaṁ yathā vānarassa,"
    },
    {
      "id": "ja464:4.2",
      "pali": "Kannappakannaṁ yathā rukkhachāyā;"
    },
    {
      "id": "ja464:4.3",
      "pali": "Calācalaṁ hadayamitthiyānaṁ,"
    },
    {
      "id": "ja464:4.4",
      "pali": "Cakkassa nemi viya parivattati."
    },
    {
      "id": "ja464:5.1",
      "pali": "Yadā tā passanti samekkhamānā,"
    },
    {
      "id": "ja464:5.2",
      "pali": "Ādeyyarūpaṁ purisassa vittaṁ;"
    },
    {
      "id": "ja464:5.3",
      "pali": "Saṇhāhi vācāhi nayanti menaṁ,"
    },
    {
      "id": "ja464:5.4",
      "pali": "Kambojakā jalajeneva assaṁ."
    },
    {
      "id": "ja464:6.1",
      "pali": "Yadā na passanti samekkhamānā,"
    },
    {
      "id": "ja464:6.2",
      "pali": "Ādeyyarūpaṁ purisassa vittaṁ;"
    },
    {
      "id": "ja464:6.3",
      "pali": "Samantato naṁ parivajjayanti,"
    },
    {
      "id": "ja464:6.4",
      "pali": "Tiṇṇo nadīpāragatova kullaṁ."
    },
    {
      "id": "ja464:7.1",
      "pali": "Silesūpamā sikhiriva sabbabhakkhā,"
    },
    {
      "id": "ja464:7.2",
      "pali": "Tikkhamāyā nadīriva sīghasotā;"
    },
    {
      "id": "ja464:7.3",
      "pali": "Sevanti hetā piyamappiyañca,"
    },
    {
      "id": "ja464:7.4",
      "pali": "Nāvā yathā orakūlaṁ parañca."
    },
    {
      "id": "ja464:8.1",
      "pali": "Na tā ekassa na dvinnaṁ,"
    },
    {
      "id": "ja464:8.2",
      "pali": "āpaṇova pasārito;"
    },
    {
      "id": "ja464:8.3",
      "pali": "Yo tā mayhanti maññeyya,"
    },
    {
      "id": "ja464:8.4",
      "pali": "vātaṁ jālena bādhaye."
    },
    {
      "id": "ja464:9.1",
      "pali": "Yathā nadī ca pantho ca,"
    },
    {
      "id": "ja464:9.2",
      "pali": "pānāgāraṁ sabhā papā;"
    },
    {
      "id": "ja464:9.3",
      "pali": "Evaṁ lokitthiyo nāma,"
    },
    {
      "id": "ja464:9.4",
      "pali": "velā tāsaṁ na vijjati."
    },
    {
      "id": "ja464:10.1",
      "pali": "Ghatāsanasamā etā,"
    },
    {
      "id": "ja464:10.2",
      "pali": "kaṇhasappasirūpamā;"
    },
    {
      "id": "ja464:10.3",
      "pali": "Gāvo bahitiṇasseva,"
    },
    {
      "id": "ja464:10.4",
      "pali": "omasanti varaṁ varaṁ."
    },
    {
      "id": "ja464:11.1",
      "pali": "Ghatāsanaṁ kuñjaraṁ kaṇhasappaṁ,"
    },
    {
      "id": "ja464:11.2",
      "pali": "Muddhābhisittaṁ pamadā ca sabbā;"
    },
    {
      "id": "ja464:11.3",
      "pali": "Ete naro niccayato bhajetha,"
    },
    {
      "id": "ja464:11.4",
      "pali": "Tesaṁ have dubbidu sabbabhāvo."
    },
    {
      "id": "ja464:12.1",
      "pali": "Naccantavaṇṇā na bahūnaṁ kantā,"
    },
    {
      "id": "ja464:12.2",
      "pali": "Na dakkhiṇā pamadā sevitabbā;"
    },
    {
      "id": "ja464:12.3",
      "pali": "Na parassa bhariyā na dhanassa hetu,"
    },
    {
      "id": "ja464:12.4",
      "pali": "Etitthiyo pañca na sevitabbā”ti."
    },
    {
      "id": "ja464:13.1",
      "pali": "Cūḷakuṇālajātakaṁ paṭhamaṁ."
    }
  ]
}
