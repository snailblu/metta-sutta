{
  "uid": "thag2.46",
  "title": "Pañcamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.46:1.1",
      "pali": "“Nadanti morā susikhā supekhuṇā,"
    },
    {
      "id": "thag2.46:1.2",
      "pali": "Sunīlagīvā sumukhā sugajjino;"
    },
    {
      "id": "thag2.46:1.3",
      "pali": "Susaddalā cāpi mahāmahī ayaṁ,"
    },
    {
      "id": "thag2.46:1.4",
      "pali": "Subyāpitambu suvalāhakaṁ nabhaṁ."
    },
    {
      "id": "thag2.46:2.1",
      "pali": "Sukallarūpo sumanassa jhāyataṁ,"
    },
    {
      "id": "thag2.46:2.2",
      "pali": "Sunikkamo sādhu subuddhasāsane;"
    },
    {
      "id": "thag2.46:2.3",
      "pali": "Susukkasukkaṁ nipuṇaṁ sududdasaṁ,"
    },
    {
      "id": "thag2.46:2.4",
      "pali": "Phusāhi taṁ uttamamaccutaṁ padan”ti."
    },
    {
      "id": "thag2.46:2.5",
      "pali": "… Cūḷako thero …."
    }
  ]
}
