{
  "uid": "ja355",
  "title": "Maṇikuṇḍalavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja355:1.1",
      "pali": "“Aññe socanti rodanti,"
    },
    {
      "id": "ja355:1.2",
      "pali": "aññe assumukhā janā;"
    },
    {
      "id": "ja355:1.3",
      "pali": "Pasannamukhavaṇṇosi,"
    },
    {
      "id": "ja355:1.4",
      "pali": "kasmā ghaṭa na socasi”."
    },
    {
      "id": "ja355:2.1",
      "pali": "“Nābbhatītaharo soko,"
    },
    {
      "id": "ja355:2.2",
      "pali": "nānāgatasukhāvaho;"
    },
    {
      "id": "ja355:2.3",
      "pali": "Tasmā dhaṅka na socāmi,"
    },
    {
      "id": "ja355:2.4",
      "pali": "natthi soke dutīyatā."
    },
    {
      "id": "ja355:3.1",
      "pali": "Socaṁ paṇḍu kiso hoti,"
    },
    {
      "id": "ja355:3.2",
      "pali": "bhattañcassa na ruccati;"
    },
    {
      "id": "ja355:3.3",
      "pali": "Amittā sumanā honti,"
    },
    {
      "id": "ja355:3.4",
      "pali": "sallaviddhassa ruppato."
    },
    {
      "id": "ja355:4.1",
      "pali": "Gāme vā yadi vāraññe,"
    },
    {
      "id": "ja355:4.2",
      "pali": "ninne vā yadi vā thale;"
    },
    {
      "id": "ja355:4.3",
      "pali": "Ṭhitaṁ maṁ nāgamissati,"
    },
    {
      "id": "ja355:4.4",
      "pali": "evaṁ diṭṭhapado ahaṁ."
    },
    {
      "id": "ja355:5.1",
      "pali": "Yassattā nālamekova,"
    },
    {
      "id": "ja355:5.2",
      "pali": "sabbakāmarasāharo;"
    },
    {
      "id": "ja355:5.3",
      "pali": "Sabbāpi pathavī tassa,"
    },
    {
      "id": "ja355:5.4",
      "pali": "na sukhaṁ āvahissatī”ti."
    },
    {
      "id": "ja355:6.1",
      "pali": "Ghaṭajātakaṁ pañcamaṁ."
    }
  ]
}
