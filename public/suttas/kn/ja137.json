{
  "uid": "ja137",
  "title": "Asampadānavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja137:1.1",
      "pali": "“Yattheko labhate babbu,"
    },
    {
      "id": "ja137:1.2",
      "pali": "dutiyo tattha jāyati;"
    },
    {
      "id": "ja137:1.3",
      "pali": "Tatiyo ca catuttho ca,"
    },
    {
      "id": "ja137:1.4",
      "pali": "idaṁ te babbukā bilan”ti."
    },
    {
      "id": "ja137:2.1",
      "pali": "Babbujātakaṁ sattamaṁ."
    }
  ]
}
