{
  "uid": "tha-ap6",
  "title": "Anuruddhattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap6:1.1",
      "pali": "“Sumedhaṁ bhagavantāhaṁ,"
    },
    {
      "id": "tha-ap6:1.2",
      "pali": "lokajeṭṭhaṁ narāsabhaṁ;"
    },
    {
      "id": "tha-ap6:1.3",
      "pali": "Vūpakaṭṭhaṁ viharantaṁ,"
    },
    {
      "id": "tha-ap6:1.4",
      "pali": "addasaṁ lokanāyakaṁ."
    },
    {
      "id": "tha-ap6:2.1",
      "pali": "Upagantvāna sambuddhaṁ,"
    },
    {
      "id": "tha-ap6:2.2",
      "pali": "sumedhaṁ lokanāyakaṁ;"
    },
    {
      "id": "tha-ap6:2.3",
      "pali": "Añjaliṁ paggahetvāna,"
    },
    {
      "id": "tha-ap6:2.4",
      "pali": "buddhaseṭṭhamayācahaṁ."
    },
    {
      "id": "tha-ap6:3.1",
      "pali": "Anukampa mahāvīra,"
    },
    {
      "id": "tha-ap6:3.2",
      "pali": "lokajeṭṭha narāsabha;"
    },
    {
      "id": "tha-ap6:3.3",
      "pali": "Padīpaṁ te padassāmi,"
    },
    {
      "id": "tha-ap6:3.4",
      "pali": "rukkhamūlamhi jhāyato."
    },
    {
      "id": "tha-ap6:4.1",
      "pali": "Adhivāsesi so dhīro,"
    },
    {
      "id": "tha-ap6:4.2",
      "pali": "sayambhū vadataṁ varo;"
    },
    {
      "id": "tha-ap6:4.3",
      "pali": "Dumesu vinivijjhitvā,"
    },
    {
      "id": "tha-ap6:4.4",
      "pali": "yantaṁ yojiyahaṁ tadā."
    },
    {
      "id": "tha-ap6:5.1",
      "pali": "Sahassavaṭṭiṁ pādāsiṁ,"
    },
    {
      "id": "tha-ap6:5.2",
      "pali": "buddhassa lokabandhuno;"
    },
    {
      "id": "tha-ap6:5.3",
      "pali": "Sattāhaṁ pajjalitvāna,"
    },
    {
      "id": "tha-ap6:5.4",
      "pali": "dīpā vūpasamiṁsu me."
    },
    {
      "id": "tha-ap6:6.1",
      "pali": "Tena cittappasādena,"
    },
    {
      "id": "tha-ap6:6.2",
      "pali": "cetanāpaṇidhīhi ca;"
    },
    {
      "id": "tha-ap6:6.3",
      "pali": "Jahitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "tha-ap6:6.4",
      "pali": "vimānamupapajjahaṁ."
    },
    {
      "id": "tha-ap6:7.1",
      "pali": "Upapannassa devattaṁ,"
    },
    {
      "id": "tha-ap6:7.2",
      "pali": "byamhaṁ āsi sunimmitaṁ;"
    },
    {
      "id": "tha-ap6:7.3",
      "pali": "Samantato pajjalati,"
    },
    {
      "id": "tha-ap6:7.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap6:8.1",
      "pali": "Samantā yojanasataṁ,"
    },
    {
      "id": "tha-ap6:8.2",
      "pali": "virocesimahaṁ tadā;"
    },
    {
      "id": "tha-ap6:8.3",
      "pali": "Sabbe deve abhibhomi,"
    },
    {
      "id": "tha-ap6:8.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap6:9.1",
      "pali": "Tiṁsakappāni devindo,"
    },
    {
      "id": "tha-ap6:9.2",
      "pali": "devarajjamakārayiṁ;"
    },
    {
      "id": "tha-ap6:9.3",
      "pali": "Na maṁ kecītimaññanti,"
    },
    {
      "id": "tha-ap6:9.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap6:10.1",
      "pali": "Aṭṭhavīsatikkhattuñca,"
    },
    {
      "id": "tha-ap6:10.2",
      "pali": "cakkavattī ahosahaṁ;"
    },
    {
      "id": "tha-ap6:10.3",
      "pali": "Divā rattiñca passāmi,"
    },
    {
      "id": "tha-ap6:10.4",
      "pali": "samantā yojanaṁ tadā."
    },
    {
      "id": "tha-ap6:11.1",
      "pali": "Sahassalokaṁ ñāṇena,"
    },
    {
      "id": "tha-ap6:11.2",
      "pali": "passāmi satthu sāsane;"
    },
    {
      "id": "tha-ap6:11.3",
      "pali": "Dibbacakkhumanuppatto,"
    },
    {
      "id": "tha-ap6:11.4",
      "pali": "dīpadānassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap6:12.1",
      "pali": "Sumedho nāma sambuddho,"
    },
    {
      "id": "tha-ap6:12.2",
      "pali": "tiṁsakappasahassito;"
    },
    {
      "id": "tha-ap6:12.3",
      "pali": "Tassa dīpo mayā dinno,"
    },
    {
      "id": "tha-ap6:12.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "tha-ap6:13.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap6:13.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap6:13.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap6:13.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap6:14.1",
      "pali": "Itthaṁ sudaṁ āyasmā anuruddho thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap6:15.1",
      "pali": "Anuruddhattherassāpadānaṁ catutthaṁ."
    }
  ]
}
