{
  "uid": "iti79",
  "title": "Tatiyavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti79:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti79:2.1",
      "pali": "“Tayome, bhikkhave, dhammā sekhassa bhikkhuno parihānāya saṁvattanti."
    },
    {
      "id": "iti79:2.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti79:2.3",
      "pali": "Idha, bhikkhave, sekho bhikkhu kammārāmo hoti, kammarato, kammārāmatamanuyutto;"
    },
    {
      "id": "iti79:2.4",
      "pali": "bhassārāmo hoti, bhassarato, bhassārāmatamanuyutto;"
    },
    {
      "id": "iti79:2.5",
      "pali": "niddārāmo hoti, niddārato, niddārāmatamanuyutto."
    },
    {
      "id": "iti79:2.6",
      "pali": "Ime kho, bhikkhave, tayo dhammā sekhassa bhikkhuno parihānāya saṁvattanti."
    },
    {
      "id": "iti79:3.1",
      "pali": "Tayome, bhikkhave, dhammā sekhassa bhikkhuno aparihānāya saṁvattanti."
    },
    {
      "id": "iti79:3.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "iti79:3.3",
      "pali": "Idha, bhikkhave, sekho bhikkhu na kammārāmo hoti, na kammarato, na kammārāmatamanuyutto;"
    },
    {
      "id": "iti79:3.4",
      "pali": "na bhassārāmo hoti, na bhassarato, na bhassārāmatamanuyutto;"
    },
    {
      "id": "iti79:3.5",
      "pali": "na niddārāmo hoti, na niddārato, na niddārāmatamanuyutto."
    },
    {
      "id": "iti79:3.6",
      "pali": "Ime kho, bhikkhave, tayo dhammā sekhassa bhikkhuno aparihānāya saṁvattantī”ti."
    },
    {
      "id": "iti79:3.7",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti79:3.8",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti79:4.1",
      "pali": "“Kammārāmo bhassārāmo,"
    },
    {
      "id": "iti79:4.2",
      "pali": "Niddārāmo ca uddhato;"
    },
    {
      "id": "iti79:4.3",
      "pali": "Abhabbo tādiso bhikkhu,"
    },
    {
      "id": "iti79:4.4",
      "pali": "Phuṭṭhuṁ sambodhimuttamaṁ."
    },
    {
      "id": "iti79:5.1",
      "pali": "Tasmā hi appakiccassa,"
    },
    {
      "id": "iti79:5.2",
      "pali": "Appamiddho anuddhato;"
    },
    {
      "id": "iti79:5.3",
      "pali": "Bhabbo so tādiso bhikkhu,"
    },
    {
      "id": "iti79:5.4",
      "pali": "Phuṭṭhuṁ sambodhimuttaman”ti."
    },
    {
      "id": "iti79:6.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti79:6.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "iti79:6.3",
      "pali": "Tatiyo vaggo."
    },
    {
      "id": "iti79:7.1",
      "pali": "Dve diṭṭhī nissaraṇaṁ rūpaṁ,"
    },
    {
      "id": "iti79:7.2",
      "pali": "putto avuṭṭhikena ca;"
    },
    {
      "id": "iti79:7.3",
      "pali": "Sukhā ca bhiduro dhātu,"
    },
    {
      "id": "iti79:7.4",
      "pali": "parihānena te dasāti."
    }
  ]
}
