{
  "uid": "mil3.1.8",
  "title": "8. Manasikāralakkhaṇapañha",
  "nikaya": "kn",
  "segments": [
    {
      "id": "mil3.1.8:1.1",
      "pali": "Rājā āha—"
    },
    {
      "id": "mil3.1.8:1.2",
      "pali": "“kiṁlakkhaṇo, bhante nāgasena, manasikāro, kiṁlakkhaṇā paññā”ti?"
    },
    {
      "id": "mil3.1.8:1.3",
      "pali": "“Ūhanalakkhaṇo kho, mahārāja, manasikāro, chedanalakkhaṇā paññā”ti."
    },
    {
      "id": "mil3.1.8:2.1",
      "pali": "“Kathaṁ ūhanalakkhaṇo manasikāro, kathaṁ chedanalakkhaṇā paññā?"
    },
    {
      "id": "mil3.1.8:2.2",
      "pali": "Opammaṁ karohī”ti."
    },
    {
      "id": "mil3.1.8:2.3",
      "pali": "“Jānāsi tvaṁ, mahārāja, yavalāvake”ti."
    },
    {
      "id": "mil3.1.8:2.4",
      "pali": "“Āma, bhante, jānāmī”ti."
    },
    {
      "id": "mil3.1.8:2.5",
      "pali": "“Kathaṁ, mahārāja, yavalāvakā yavaṁ lunantī”ti?"
    },
    {
      "id": "mil3.1.8:2.6",
      "pali": "“Vāmena, bhante, hatthena yavakalāpaṁ gahetvā dakkhiṇena hatthena dāttaṁ gahetvā dāttena chindantī”ti."
    },
    {
      "id": "mil3.1.8:3.1",
      "pali": "“Yathā, mahārāja, yavalāvako vāmena hatthena yavakalāpaṁ gahetvā dakkhiṇena hatthena dāttaṁ gahetvā yavaṁ chindati;"
    },
    {
      "id": "mil3.1.8:3.2",
      "pali": "evameva kho, mahārāja, yogāvacaro manasikārena mānasaṁ gahetvā paññāya kilese chindati, evaṁ kho, mahārāja, ūhanalakkhaṇo manasikāro, evaṁ chedanalakkhaṇā paññā”ti."
    },
    {
      "id": "mil3.1.8:4.1",
      "pali": "“Kallosi, bhante nāgasenā”ti."
    },
    {
      "id": "mil3.1.8:5.1",
      "pali": "Manasikāralakkhaṇapañho aṭṭhamo."
    }
  ]
}
