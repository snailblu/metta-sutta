{
  "uid": "iti100",
  "title": "Brāhmaṇadhammayāgavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti100:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti100:2.1",
      "pali": "“Ahamasmi, bhikkhave, brāhmaṇo yācayogo sadā payatapāṇi antimadehadharo anuttaro bhisakko sallakatto."
    },
    {
      "id": "iti100:2.2",
      "pali": "Tassa me tumhe puttā orasā mukhato jātā dhammajā dhammanimmitā dhammadāyādā, no āmisadāyādā."
    },
    {
      "id": "iti100:3.1",
      "pali": "Dvemāni, bhikkhave, dānāni—"
    },
    {
      "id": "iti100:3.2",
      "pali": "āmisadānañca dhammadānañca."
    },
    {
      "id": "iti100:3.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ dānānaṁ yadidaṁ dhammadānaṁ."
    },
    {
      "id": "iti100:4.1",
      "pali": "Dveme, bhikkhave, saṁvibhāgā—"
    },
    {
      "id": "iti100:4.2",
      "pali": "āmisasaṁvibhāgo ca dhammasaṁvibhāgo ca."
    },
    {
      "id": "iti100:4.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ saṁvibhāgānaṁ yadidaṁ dhammasaṁvibhāgo."
    },
    {
      "id": "iti100:5.1",
      "pali": "Dveme, bhikkhave, anuggahā—"
    },
    {
      "id": "iti100:5.2",
      "pali": "āmisānuggaho ca dhammānuggaho ca."
    },
    {
      "id": "iti100:5.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ anuggahānaṁ yadidaṁ dhammānuggaho."
    },
    {
      "id": "iti100:6.1",
      "pali": "Dveme, bhikkhave, yāgā—"
    },
    {
      "id": "iti100:6.2",
      "pali": "āmisayāgo ca dhammayāgo ca."
    },
    {
      "id": "iti100:6.3",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ yāgānaṁ yadidaṁ dhammayāgo”ti."
    },
    {
      "id": "iti100:6.4",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti100:6.5",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti100:7.1",
      "pali": "“Yo dhammayāgaṁ ayajī amaccharī,"
    },
    {
      "id": "iti100:7.2",
      "pali": "Tathāgato sabbabhūtānukampī;"
    },
    {
      "id": "iti100:7.3",
      "pali": "Taṁ tādisaṁ devamanussaseṭṭhaṁ,"
    },
    {
      "id": "iti100:7.4",
      "pali": "Sattā namassanti bhavassa pāragun”ti."
    },
    {
      "id": "iti100:8.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti100:8.2",
      "pali": "Paṭhamaṁ."
    }
  ]
}
