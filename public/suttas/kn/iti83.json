{
  "uid": "iti83",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "iti83:1.1",
      "pali": "Vuttañhetaṁ bhagavatā vuttamarahatāti me sutaṁ:"
    },
    {
      "id": "iti83:2.1",
      "pali": "“Yadā, bhikkhave, devo devakāyā cavanadhammo hoti, pañcassa pubbanimittāni pātubhavanti—"
    },
    {
      "id": "iti83:2.2",
      "pali": "mālā milāyanti, vatthāni kilissanti, kacchehi sedā muccanti, kāye dubbaṇṇiyaṁ okkamati, sake devo devāsane nābhiramatīti."
    },
    {
      "id": "iti83:2.3",
      "pali": "Tamenaṁ, bhikkhave, devā ‘cavanadhammo ayaṁ devaputto’ti iti viditvā tīhi vācāhi anumodenti:"
    },
    {
      "id": "iti83:2.4",
      "pali": "‘ito, bho, sugatiṁ gaccha."
    },
    {
      "id": "iti83:3.1",
      "pali": "Sugatiṁ gantvā suladdhalābhaṁ labha."
    },
    {
      "id": "iti83:4.1",
      "pali": "Suladdhalābhaṁ labhitvā suppatiṭṭhito bhavāhī’”ti."
    },
    {
      "id": "iti83:5.1",
      "pali": "Evaṁ vutte, aññataro bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "iti83:5.2",
      "pali": "“kiṁ nu kho, bhante, devānaṁ sugatigamanasaṅkhātaṁ."
    },
    {
      "id": "iti83:6.1",
      "pali": "Kiñca, bhante, devānaṁ suladdhalābhasaṅkhātaṁ."
    },
    {
      "id": "iti83:7.1",
      "pali": "Kiṁ pana, bhante, devānaṁ suppatiṭṭhitasaṅkhātan”ti?"
    },
    {
      "id": "iti83:8.1",
      "pali": "“Manussattaṁ kho, bhikkhu, devānaṁ sugatigamanasaṅkhātaṁ."
    },
    {
      "id": "iti83:9.1",
      "pali": "Yaṁ manussabhūto samāno tathāgatappavedite dhammavinaye saddhaṁ paṭilabhati;"
    },
    {
      "id": "iti83:9.2",
      "pali": "idaṁ kho, bhikkhu, devānaṁ suladdhalābhasaṅkhātaṁ."
    },
    {
      "id": "iti83:10.1",
      "pali": "Sā kho panassa saddhā niviṭṭhā hoti mūlajātā patiṭṭhitā daḷhā asaṁhāriyā samaṇena vā brāhmaṇena vā devena vā mārena vā brahmunā vā kenaci vā lokasmiṁ;"
    },
    {
      "id": "iti83:10.2",
      "pali": "idaṁ kho, bhikkhu, devānaṁ suppatiṭṭhitasaṅkhātan”ti."
    },
    {
      "id": "iti83:11.1",
      "pali": "Etamatthaṁ bhagavā avoca."
    },
    {
      "id": "iti83:11.2",
      "pali": "Tatthetaṁ iti vuccati:"
    },
    {
      "id": "iti83:12.1",
      "pali": "“Yadā devo devakāyā,"
    },
    {
      "id": "iti83:12.2",
      "pali": "cavati āyusaṅkhayā;"
    },
    {
      "id": "iti83:12.3",
      "pali": "Tayo saddā niccharanti,"
    },
    {
      "id": "iti83:12.4",
      "pali": "devānaṁ anumodataṁ."
    },
    {
      "id": "iti83:13.1",
      "pali": "‘Ito bho sugatiṁ gaccha,"
    },
    {
      "id": "iti83:13.2",
      "pali": "manussānaṁ sahabyataṁ;"
    },
    {
      "id": "iti83:13.3",
      "pali": "Manussabhūto saddhamme,"
    },
    {
      "id": "iti83:13.4",
      "pali": "labha saddhaṁ anuttaraṁ."
    },
    {
      "id": "iti83:14.1",
      "pali": "Sā te saddhā niviṭṭhassa,"
    },
    {
      "id": "iti83:14.2",
      "pali": "mūlajātā patiṭṭhitā;"
    },
    {
      "id": "iti83:14.3",
      "pali": "Yāvajīvaṁ asaṁhīrā,"
    },
    {
      "id": "iti83:14.4",
      "pali": "saddhamme suppavedite."
    },
    {
      "id": "iti83:15.1",
      "pali": "Kāyaduccaritaṁ hitvā,"
    },
    {
      "id": "iti83:15.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "iti83:15.3",
      "pali": "Manoduccaritaṁ hitvā,"
    },
    {
      "id": "iti83:15.4",
      "pali": "yañcaññaṁ dosasañhitaṁ."
    },
    {
      "id": "iti83:16.1",
      "pali": "Kāyena kusalaṁ katvā,"
    },
    {
      "id": "iti83:16.2",
      "pali": "vācāya kusalaṁ bahuṁ;"
    },
    {
      "id": "iti83:16.3",
      "pali": "Manasā kusalaṁ katvā,"
    },
    {
      "id": "iti83:16.4",
      "pali": "appamāṇaṁ nirūpadhiṁ."
    },
    {
      "id": "iti83:17.1",
      "pali": "Tato opadhikaṁ puññaṁ,"
    },
    {
      "id": "iti83:17.2",
      "pali": "katvā dānena taṁ bahuṁ;"
    },
    {
      "id": "iti83:17.3",
      "pali": "Aññepi macce saddhamme,"
    },
    {
      "id": "iti83:17.4",
      "pali": "brahmacariye nivesaya’."
    },
    {
      "id": "iti83:18.1",
      "pali": "Imāya anukampāya,"
    },
    {
      "id": "iti83:18.2",
      "pali": "devā devaṁ yadā vidū;"
    },
    {
      "id": "iti83:18.3",
      "pali": "Cavantaṁ anumodenti,"
    },
    {
      "id": "iti83:18.4",
      "pali": "ehi deva punappunan”ti."
    },
    {
      "id": "iti83:19.1",
      "pali": "Ayampi attho vutto bhagavatā, iti me sutanti."
    },
    {
      "id": "iti83:19.2",
      "pali": "Catutthaṁ."
    }
  ]
}
