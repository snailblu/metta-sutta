{
  "uid": "ja529",
  "title": "Soṇakavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja529:1.1",
      "pali": "“Tassa sutvā sataṁ dammi,"
    },
    {
      "id": "ja529:1.2",
      "pali": "sahassaṁ diṭṭha soṇakaṁ;"
    },
    {
      "id": "ja529:1.3",
      "pali": "Ko me soṇakamakkhāti,"
    },
    {
      "id": "ja529:1.4",
      "pali": "sahāyaṁ paṁsukīḷitaṁ”."
    },
    {
      "id": "ja529:2.1",
      "pali": "“Athabravī māṇavako,"
    },
    {
      "id": "ja529:2.2",
      "pali": "daharo pañcacūḷako;"
    },
    {
      "id": "ja529:2.3",
      "pali": "Mayhaṁ sutvā sataṁ dehi,"
    },
    {
      "id": "ja529:2.4",
      "pali": "sahassaṁ diṭṭha soṇakaṁ;"
    },
    {
      "id": "ja529:2.5",
      "pali": "Ahaṁ te soṇakakkhissaṁ,"
    },
    {
      "id": "ja529:2.6",
      "pali": "sahāyaṁ paṁsukīḷitaṁ”."
    },
    {
      "id": "ja529:3.1",
      "pali": "“Katamasmiṁ so janapade,"
    },
    {
      "id": "ja529:3.2",
      "pali": "raṭṭhesu nigamesu ca;"
    },
    {
      "id": "ja529:3.3",
      "pali": "Kattha soṇakamaddakkhi,"
    },
    {
      "id": "ja529:3.4",
      "pali": "taṁ me akkhāhi pucchito”."
    },
    {
      "id": "ja529:4.1",
      "pali": "“Taveva deva vijite,"
    },
    {
      "id": "ja529:4.2",
      "pali": "tavevuyyānabhūmiyā;"
    },
    {
      "id": "ja529:4.3",
      "pali": "Ujuvaṁsā mahāsālā,"
    },
    {
      "id": "ja529:4.4",
      "pali": "nīlobhāsā manoramā."
    },
    {
      "id": "ja529:5.1",
      "pali": "Tiṭṭhanti meghasamānā,"
    },
    {
      "id": "ja529:5.2",
      "pali": "rammā aññoññanissitā;"
    },
    {
      "id": "ja529:5.3",
      "pali": "Tesaṁ mūlamhi soṇako,"
    },
    {
      "id": "ja529:5.4",
      "pali": "jhāyatī anupādano;"
    },
    {
      "id": "ja529:5.5",
      "pali": "Upādānesu lokesu,"
    },
    {
      "id": "ja529:5.6",
      "pali": "ḍayhamānesu nibbuto”."
    },
    {
      "id": "ja529:6.1",
      "pali": "Tato ca rājā pāyāsi,"
    },
    {
      "id": "ja529:6.2",
      "pali": "senāya caturaṅgiyā;"
    },
    {
      "id": "ja529:6.3",
      "pali": "Kārāpetvā samaṁ maggaṁ,"
    },
    {
      "id": "ja529:6.4",
      "pali": "agamā yena soṇako."
    },
    {
      "id": "ja529:7.1",
      "pali": "Uyyānabhūmiṁ gantvāna,"
    },
    {
      "id": "ja529:7.2",
      "pali": "vicaranto brahāvane;"
    },
    {
      "id": "ja529:7.3",
      "pali": "Āsīnaṁ soṇakaṁ dakkhi,"
    },
    {
      "id": "ja529:7.4",
      "pali": "ḍayhamānesu nibbutaṁ."
    },
    {
      "id": "ja529:8.1",
      "pali": "“Kapaṇo vatayaṁ bhikkhu,"
    },
    {
      "id": "ja529:8.2",
      "pali": "muṇḍo saṅghāṭipāruto;"
    },
    {
      "id": "ja529:8.3",
      "pali": "Amātiko apitiko,"
    },
    {
      "id": "ja529:8.4",
      "pali": "rukkhamūlasmi jhāyati”."
    },
    {
      "id": "ja529:9.1",
      "pali": "Imaṁ vākyaṁ nisāmetvā,"
    },
    {
      "id": "ja529:9.2",
      "pali": "Soṇako etadabravi;"
    },
    {
      "id": "ja529:9.3",
      "pali": "“Na rāja kapaṇo hoti,"
    },
    {
      "id": "ja529:9.4",
      "pali": "Dhammaṁ kāyena phassayaṁ."
    },
    {
      "id": "ja529:10.1",
      "pali": "Yo ca dhammaṁ niraṅkatvā,"
    },
    {
      "id": "ja529:10.2",
      "pali": "Adhammamanuvattati;"
    },
    {
      "id": "ja529:10.3",
      "pali": "Sa rāja kapaṇo hoti,"
    },
    {
      "id": "ja529:10.4",
      "pali": "Pāpo pāpaparāyaṇo”."
    },
    {
      "id": "ja529:11.1",
      "pali": "“Arindamoti me nāmaṁ,"
    },
    {
      "id": "ja529:11.2",
      "pali": "kāsirājāti maṁ vidū;"
    },
    {
      "id": "ja529:11.3",
      "pali": "Kacci bhoto sukhasseyyā,"
    },
    {
      "id": "ja529:11.4",
      "pali": "idha pattassa soṇaka”."
    },
    {
      "id": "ja529:12.1",
      "pali": "“Sadāpi bhadramadhanassa,"
    },
    {
      "id": "ja529:12.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:12.3",
      "pali": "Na tesaṁ koṭṭhe openti,"
    },
    {
      "id": "ja529:12.4",
      "pali": "Na kumbhiṁ na khaḷopiyaṁ;"
    },
    {
      "id": "ja529:12.5",
      "pali": "Paraniṭṭhitamesānā,"
    },
    {
      "id": "ja529:12.6",
      "pali": "Tena yāpenti subbatā."
    },
    {
      "id": "ja529:13.1",
      "pali": "Dutiyampi bhadramadhanassa,"
    },
    {
      "id": "ja529:13.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:13.3",
      "pali": "Anavajjapiṇḍo bhottabbo,"
    },
    {
      "id": "ja529:13.4",
      "pali": "Na ca kocūparodhati."
    },
    {
      "id": "ja529:14.1",
      "pali": "Tatiyampi bhadramadhanassa,"
    },
    {
      "id": "ja529:14.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:14.3",
      "pali": "Nibbuto piṇḍo bhottabbo,"
    },
    {
      "id": "ja529:14.4",
      "pali": "Na ca kocūparodhati."
    },
    {
      "id": "ja529:15.1",
      "pali": "Catutthampi bhadramadhanassa,"
    },
    {
      "id": "ja529:15.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:15.3",
      "pali": "Muttassa raṭṭhe carato,"
    },
    {
      "id": "ja529:15.4",
      "pali": "Saṅgo yassa na vijjati."
    },
    {
      "id": "ja529:16.1",
      "pali": "Pañcamampi bhadramadhanassa,"
    },
    {
      "id": "ja529:16.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:16.3",
      "pali": "Nagaramhi ḍayhamānamhi,"
    },
    {
      "id": "ja529:16.4",
      "pali": "Nāssa kiñci aḍayhatha."
    },
    {
      "id": "ja529:17.1",
      "pali": "Chaṭṭhampi bhadramadhanassa,"
    },
    {
      "id": "ja529:17.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:17.3",
      "pali": "Raṭṭhe vilumpamānamhi,"
    },
    {
      "id": "ja529:17.4",
      "pali": "Nāssa kiñci ahīratha."
    },
    {
      "id": "ja529:18.1",
      "pali": "Sattamampi bhadramadhanassa,"
    },
    {
      "id": "ja529:18.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:18.3",
      "pali": "Corehi rakkhitaṁ maggaṁ,"
    },
    {
      "id": "ja529:18.4",
      "pali": "Ye caññe paripanthikā;"
    },
    {
      "id": "ja529:18.5",
      "pali": "Pattacīvaramādāya,"
    },
    {
      "id": "ja529:18.6",
      "pali": "Sotthiṁ gacchati subbato."
    },
    {
      "id": "ja529:19.1",
      "pali": "Aṭṭhamampi bhadramadhanassa,"
    },
    {
      "id": "ja529:19.2",
      "pali": "Anāgārassa bhikkhuno;"
    },
    {
      "id": "ja529:19.3",
      "pali": "Yaṁ yaṁ disaṁ pakkamati,"
    },
    {
      "id": "ja529:19.4",
      "pali": "Anapekkhova gacchati”."
    },
    {
      "id": "ja529:20.1",
      "pali": "“Bahūni samaṇabhadrāni,"
    },
    {
      "id": "ja529:20.2",
      "pali": "ye tvaṁ bhikkhu pasaṁsasi;"
    },
    {
      "id": "ja529:20.3",
      "pali": "Ahañca giddho kāmesu,"
    },
    {
      "id": "ja529:20.4",
      "pali": "kathaṁ kāhāmi soṇaka."
    },
    {
      "id": "ja529:21.1",
      "pali": "Piyā me mānusā kāmā,"
    },
    {
      "id": "ja529:21.2",
      "pali": "atho dibyāpi me piyā;"
    },
    {
      "id": "ja529:21.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "ja529:21.4",
      "pali": "ubho loke labhāmase”."
    },
    {
      "id": "ja529:22.1",
      "pali": "“Kāme giddhā kāmaratā,"
    },
    {
      "id": "ja529:22.2",
      "pali": "kāmesu adhimucchitā;"
    },
    {
      "id": "ja529:22.3",
      "pali": "Narā pāpāni katvāna,"
    },
    {
      "id": "ja529:22.4",
      "pali": "upapajjanti duggatiṁ."
    },
    {
      "id": "ja529:23.1",
      "pali": "Ye ca kāme pahantvāna,"
    },
    {
      "id": "ja529:23.2",
      "pali": "nikkhantā akutobhayā;"
    },
    {
      "id": "ja529:23.3",
      "pali": "Ekodibhāvādhigatā,"
    },
    {
      "id": "ja529:23.4",
      "pali": "na te gacchanti duggatiṁ."
    },
    {
      "id": "ja529:24.1",
      "pali": "Upamaṁ te karissāmi,"
    },
    {
      "id": "ja529:24.2",
      "pali": "taṁ suṇohi arindama;"
    },
    {
      "id": "ja529:24.3",
      "pali": "Upamāya midhekacce,"
    },
    {
      "id": "ja529:24.4",
      "pali": "atthaṁ jānanti paṇḍitā."
    },
    {
      "id": "ja529:25.1",
      "pali": "Gaṅgāya kuṇapaṁ disvā,"
    },
    {
      "id": "ja529:25.2",
      "pali": "vuyhamānaṁ mahaṇṇave;"
    },
    {
      "id": "ja529:25.3",
      "pali": "Vāyaso samacintesi,"
    },
    {
      "id": "ja529:25.4",
      "pali": "appapañño acetaso."
    },
    {
      "id": "ja529:26.1",
      "pali": "‘Yānañca vatidaṁ laddhaṁ,"
    },
    {
      "id": "ja529:26.2",
      "pali": "bhakkho cāyaṁ anappako’;"
    },
    {
      "id": "ja529:26.3",
      "pali": "Tattha rattiṁ tattha divā,"
    },
    {
      "id": "ja529:26.4",
      "pali": "tattheva nirato mano."
    },
    {
      "id": "ja529:27.1",
      "pali": "Khādaṁ nāgassa maṁsāni,"
    },
    {
      "id": "ja529:27.2",
      "pali": "pivaṁ bhāgīrathodakaṁ;"
    },
    {
      "id": "ja529:27.3",
      "pali": "Sampassaṁ vanacetyāni,"
    },
    {
      "id": "ja529:27.4",
      "pali": "na palettha vihaṅgamo."
    },
    {
      "id": "ja529:28.1",
      "pali": "Tañca otaraṇī gaṅgā,"
    },
    {
      "id": "ja529:28.2",
      "pali": "pamattaṁ kuṇape rataṁ;"
    },
    {
      "id": "ja529:28.3",
      "pali": "Samuddaṁ ajjhagāhāsi,"
    },
    {
      "id": "ja529:28.4",
      "pali": "agatī yattha pakkhinaṁ."
    },
    {
      "id": "ja529:29.1",
      "pali": "So ca bhakkhaparikkhīṇo,"
    },
    {
      "id": "ja529:29.2",
      "pali": "udapatvā vihaṅgamo;"
    },
    {
      "id": "ja529:29.3",
      "pali": "Na pacchato na purato,"
    },
    {
      "id": "ja529:29.4",
      "pali": "nuttaraṁ nopi dakkhiṇaṁ."
    },
    {
      "id": "ja529:30.1",
      "pali": "Dīpaṁ so najjhagāgañchi,"
    },
    {
      "id": "ja529:30.2",
      "pali": "agatī yattha pakkhinaṁ;"
    },
    {
      "id": "ja529:30.3",
      "pali": "So ca tattheva pāpattha,"
    },
    {
      "id": "ja529:30.4",
      "pali": "yathā dubbalako tathā."
    },
    {
      "id": "ja529:31.1",
      "pali": "Tañca sāmuddikā macchā,"
    },
    {
      "id": "ja529:31.2",
      "pali": "kumbhīlā makarā susū;"
    },
    {
      "id": "ja529:31.3",
      "pali": "Pasayhakārā khādiṁsu,"
    },
    {
      "id": "ja529:31.4",
      "pali": "phandamānaṁ vipakkhakaṁ."
    },
    {
      "id": "ja529:32.1",
      "pali": "Evameva tuvaṁ rāja,"
    },
    {
      "id": "ja529:32.2",
      "pali": "ye caññe kāmabhogino;"
    },
    {
      "id": "ja529:32.3",
      "pali": "Giddhā ce na vamissanti,"
    },
    {
      "id": "ja529:32.4",
      "pali": "kākapaññāva te vidū."
    },
    {
      "id": "ja529:33.1",
      "pali": "Esā te upamā rāja,"
    },
    {
      "id": "ja529:33.2",
      "pali": "atthasandassanī katā;"
    },
    {
      "id": "ja529:33.3",
      "pali": "Tvañca paññāyase tena,"
    },
    {
      "id": "ja529:33.4",
      "pali": "yadi kāhasi vā na vā."
    },
    {
      "id": "ja529:34.1",
      "pali": "Ekavācampi dvivācaṁ,"
    },
    {
      "id": "ja529:34.2",
      "pali": "bhaṇeyya anukampako;"
    },
    {
      "id": "ja529:34.3",
      "pali": "Tatuttariṁ na bhāseyya,"
    },
    {
      "id": "ja529:34.4",
      "pali": "dāsovayyassa santike”."
    },
    {
      "id": "ja529:35.1",
      "pali": "Idaṁ vatvāna pakkāmi,"
    },
    {
      "id": "ja529:35.2",
      "pali": "soṇako amitabuddhimā;"
    },
    {
      "id": "ja529:35.3",
      "pali": "Vehāse antalikkhasmiṁ,"
    },
    {
      "id": "ja529:35.4",
      "pali": "anusāsitvāna khattiyaṁ."
    },
    {
      "id": "ja529:36.1",
      "pali": "“Ko nume rājakattāro,"
    },
    {
      "id": "ja529:36.2",
      "pali": "suddā veyyattamāgatā;"
    },
    {
      "id": "ja529:36.3",
      "pali": "Rajjaṁ niyyādayissāmi,"
    },
    {
      "id": "ja529:36.4",
      "pali": "nāhaṁ rajjena matthiko."
    },
    {
      "id": "ja529:37.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:37.2",
      "pali": "Ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:37.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:37.4",
      "pali": "Kāmānaṁ vasamanvagaṁ”."
    },
    {
      "id": "ja529:38.1",
      "pali": "“Atthi te daharo putto,"
    },
    {
      "id": "ja529:38.2",
      "pali": "dīghāvu raṭṭhavaḍḍhano;"
    },
    {
      "id": "ja529:38.3",
      "pali": "Taṁ rajje abhisiñcassu,"
    },
    {
      "id": "ja529:38.4",
      "pali": "so no rājā bhavissati”."
    },
    {
      "id": "ja529:39.1",
      "pali": "“Khippaṁ kumāramānetha,"
    },
    {
      "id": "ja529:39.2",
      "pali": "dīghāvuṁ raṭṭhavaḍḍhanaṁ;"
    },
    {
      "id": "ja529:39.3",
      "pali": "Taṁ rajje abhisiñcissaṁ,"
    },
    {
      "id": "ja529:39.4",
      "pali": "so vo rājā bhavissati”."
    },
    {
      "id": "ja529:40.1",
      "pali": "Tato kumāramānesuṁ,"
    },
    {
      "id": "ja529:40.2",
      "pali": "dīghāvuṁ raṭṭhavaḍḍhanaṁ;"
    },
    {
      "id": "ja529:40.3",
      "pali": "Taṁ disvā ālapī rājā,"
    },
    {
      "id": "ja529:40.4",
      "pali": "ekaputtaṁ manoramaṁ."
    },
    {
      "id": "ja529:41.1",
      "pali": "“Saṭṭhi gāmasahassāni,"
    },
    {
      "id": "ja529:41.2",
      "pali": "paripuṇṇāni sabbaso;"
    },
    {
      "id": "ja529:41.3",
      "pali": "Te putta paṭipajjassu,"
    },
    {
      "id": "ja529:41.4",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:42.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:42.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:42.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:42.4",
      "pali": "kāmānaṁ vasamanvagaṁ."
    },
    {
      "id": "ja529:43.1",
      "pali": "Saṭṭhi nāgasahassāni,"
    },
    {
      "id": "ja529:43.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "ja529:43.3",
      "pali": "Suvaṇṇakacchā mātaṅgā,"
    },
    {
      "id": "ja529:43.4",
      "pali": "hemakappanavāsasā."
    },
    {
      "id": "ja529:44.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "ja529:44.2",
      "pali": "tomaraṅkusapāṇibhi;"
    },
    {
      "id": "ja529:44.3",
      "pali": "Te putta paṭipajjassu,"
    },
    {
      "id": "ja529:44.4",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:45.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:45.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:45.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:45.4",
      "pali": "kāmānaṁ vasamanvagaṁ."
    },
    {
      "id": "ja529:46.1",
      "pali": "Saṭṭhi assasahassāni,"
    },
    {
      "id": "ja529:46.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "ja529:46.3",
      "pali": "Ājānīyāva jātiyā,"
    },
    {
      "id": "ja529:46.4",
      "pali": "sindhavā sīghavāhino."
    },
    {
      "id": "ja529:47.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "ja529:47.2",
      "pali": "illiyācāpadhāribhi;"
    },
    {
      "id": "ja529:47.3",
      "pali": "Te putta paṭipajjassu,"
    },
    {
      "id": "ja529:47.4",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:48.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:48.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:48.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:48.4",
      "pali": "kāmānaṁ vasamanvagaṁ."
    },
    {
      "id": "ja529:49.1",
      "pali": "Saṭṭhi rathasahassāni,"
    },
    {
      "id": "ja529:49.2",
      "pali": "sannaddhā ussitaddhajā;"
    },
    {
      "id": "ja529:49.3",
      "pali": "Dīpā athopi veyyagghā,"
    },
    {
      "id": "ja529:49.4",
      "pali": "sabbālaṅkārabhūsitā."
    },
    {
      "id": "ja529:50.1",
      "pali": "Ārūḷhā gāmaṇīyehi,"
    },
    {
      "id": "ja529:50.2",
      "pali": "cāpahatthehi vammibhi;"
    },
    {
      "id": "ja529:50.3",
      "pali": "Te putta paṭipajjassu,"
    },
    {
      "id": "ja529:50.4",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:51.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:51.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:51.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:51.4",
      "pali": "kāmānaṁ vasamanvagaṁ."
    },
    {
      "id": "ja529:52.1",
      "pali": "Saṭṭhi dhenusahassāni,"
    },
    {
      "id": "ja529:52.2",
      "pali": "rohaññā puṅgavūsabhā;"
    },
    {
      "id": "ja529:52.3",
      "pali": "Tā putta paṭipajjassu,"
    },
    {
      "id": "ja529:52.4",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:53.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:53.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:53.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:53.4",
      "pali": "kāmānaṁ vasamanvagaṁ."
    },
    {
      "id": "ja529:54.1",
      "pali": "Soḷasitthisahassāni,"
    },
    {
      "id": "ja529:54.2",
      "pali": "sabbālaṅkārabhūsitā;"
    },
    {
      "id": "ja529:54.3",
      "pali": "Vicitravatthābharaṇā,"
    },
    {
      "id": "ja529:54.4",
      "pali": "āmuttamaṇikuṇḍalā;"
    },
    {
      "id": "ja529:54.5",
      "pali": "Tā putta paṭipajjassu,"
    },
    {
      "id": "ja529:54.6",
      "pali": "rajjaṁ niyyādayāmi te."
    },
    {
      "id": "ja529:55.1",
      "pali": "Ajjeva pabbajissāmi,"
    },
    {
      "id": "ja529:55.2",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "ja529:55.3",
      "pali": "Māhaṁ kākova dummedho,"
    },
    {
      "id": "ja529:55.4",
      "pali": "kāmānaṁ vasamanvagaṁ”."
    },
    {
      "id": "ja529:56.1",
      "pali": "“Daharasseva me tāta,"
    },
    {
      "id": "ja529:56.2",
      "pali": "mātā matāti me sutaṁ;"
    },
    {
      "id": "ja529:56.3",
      "pali": "Tayā vinā ahaṁ tāta,"
    },
    {
      "id": "ja529:56.4",
      "pali": "jīvitumpi na ussahe."
    },
    {
      "id": "ja529:57.1",
      "pali": "Yathā āraññakaṁ nāgaṁ,"
    },
    {
      "id": "ja529:57.2",
      "pali": "poto anveti pacchato;"
    },
    {
      "id": "ja529:57.3",
      "pali": "Jessantaṁ giriduggesu,"
    },
    {
      "id": "ja529:57.4",
      "pali": "samesu visamesu ca."
    },
    {
      "id": "ja529:58.1",
      "pali": "Evaṁ taṁ anugacchāmi,"
    },
    {
      "id": "ja529:58.2",
      "pali": "pattamādāya pacchato;"
    },
    {
      "id": "ja529:58.3",
      "pali": "Subharo te bhavissāmi,"
    },
    {
      "id": "ja529:58.4",
      "pali": "na te hessāmi dubbharo”."
    },
    {
      "id": "ja529:59.1",
      "pali": "“Yathā sāmuddikaṁ nāvaṁ,"
    },
    {
      "id": "ja529:59.2",
      "pali": "vāṇijānaṁ dhanesinaṁ;"
    },
    {
      "id": "ja529:59.3",
      "pali": "Vohāro tattha gaṇheyya,"
    },
    {
      "id": "ja529:59.4",
      "pali": "vāṇijā byasanī siyā."
    },
    {
      "id": "ja529:60.1",
      "pali": "Evamevāyaṁ puttakali,"
    },
    {
      "id": "ja529:60.2",
      "pali": "antarāyakaro mama;"
    },
    {
      "id": "ja529:60.3",
      "pali": "Imaṁ kumāraṁ pāpetha,"
    },
    {
      "id": "ja529:60.4",
      "pali": "pāsādaṁ rativaḍḍhanaṁ."
    },
    {
      "id": "ja529:61.1",
      "pali": "Tattha kambusahatthāyo,"
    },
    {
      "id": "ja529:61.2",
      "pali": "yathā sakkaṁva accharā;"
    },
    {
      "id": "ja529:61.3",
      "pali": "Tā naṁ tattha ramessanti,"
    },
    {
      "id": "ja529:61.4",
      "pali": "tāhi ceso ramissati."
    },
    {
      "id": "ja529:62.1",
      "pali": "Tato kumāraṁ pāpesuṁ,"
    },
    {
      "id": "ja529:62.2",
      "pali": "pāsādaṁ rativaḍḍhanaṁ;"
    },
    {
      "id": "ja529:62.3",
      "pali": "Taṁ disvā avacuṁ kaññā,"
    },
    {
      "id": "ja529:62.4",
      "pali": "dīghāvuṁ raṭṭhavaḍḍhanaṁ."
    },
    {
      "id": "ja529:63.1",
      "pali": "Devatā nusi gandhabbo,"
    },
    {
      "id": "ja529:63.2",
      "pali": "adu sakko purindado;"
    },
    {
      "id": "ja529:63.3",
      "pali": "Ko vā tvaṁ kassa vā putto,"
    },
    {
      "id": "ja529:63.4",
      "pali": "kathaṁ jānemu taṁ mayaṁ”."
    },
    {
      "id": "ja529:64.1",
      "pali": "“Namhi devo na gandhabbo,"
    },
    {
      "id": "ja529:64.2",
      "pali": "Nāpi sakko purindado;"
    },
    {
      "id": "ja529:64.3",
      "pali": "Kāsirañño ahaṁ putto,"
    },
    {
      "id": "ja529:64.4",
      "pali": "Dīghāvu raṭṭhavaḍḍhano;"
    },
    {
      "id": "ja529:64.5",
      "pali": "Mamaṁ bharatha bhaddaṁ vo,"
    },
    {
      "id": "ja529:64.6",
      "pali": "Ahaṁ bhattā bhavāmi vo”."
    },
    {
      "id": "ja529:65.1",
      "pali": "Taṁ tattha avacuṁ kaññā,"
    },
    {
      "id": "ja529:65.2",
      "pali": "dīghāvuṁ raṭṭhavaḍḍhanaṁ;"
    },
    {
      "id": "ja529:65.3",
      "pali": "“Kuhiṁ rājā anuppatto,"
    },
    {
      "id": "ja529:65.4",
      "pali": "ito rājā kuhiṁ gato”."
    },
    {
      "id": "ja529:66.1",
      "pali": "“Paṅkaṁ rājā atikkanto,"
    },
    {
      "id": "ja529:66.2",
      "pali": "thale rājā patiṭṭhito;"
    },
    {
      "id": "ja529:66.3",
      "pali": "Akaṇṭakaṁ agahanaṁ,"
    },
    {
      "id": "ja529:66.4",
      "pali": "paṭipanno mahāpathaṁ."
    },
    {
      "id": "ja529:67.1",
      "pali": "Ahañca paṭipannosmi,"
    },
    {
      "id": "ja529:67.2",
      "pali": "maggaṁ duggatigāminaṁ;"
    },
    {
      "id": "ja529:67.3",
      "pali": "Sakaṇṭakaṁ sagahanaṁ,"
    },
    {
      "id": "ja529:67.4",
      "pali": "yena gacchanti duggatiṁ”."
    },
    {
      "id": "ja529:68.1",
      "pali": "“Tassa te svāgataṁ rāja,"
    },
    {
      "id": "ja529:68.2",
      "pali": "sīhasseva giribbajaṁ;"
    },
    {
      "id": "ja529:68.3",
      "pali": "Anusāsa mahārāja,"
    },
    {
      "id": "ja529:68.4",
      "pali": "tvaṁ no sabbāsamissaro”ti."
    },
    {
      "id": "ja529:69.1",
      "pali": "Soṇakajātakaṁ paṭhamaṁ."
    }
  ]
}
