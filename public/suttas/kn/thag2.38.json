{
  "uid": "thag2.38",
  "title": "Catutthavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag2.38:1.1",
      "pali": "“Pañca kāmaguṇe hitvā,"
    },
    {
      "id": "thag2.38:1.2",
      "pali": "Piyarūpe manorame;"
    },
    {
      "id": "thag2.38:1.3",
      "pali": "Saddhāya gharā nikkhamma,"
    },
    {
      "id": "thag2.38:1.4",
      "pali": "Dukkhassantakaro bhave."
    },
    {
      "id": "thag2.38:2.1",
      "pali": "Nābhinandāmi maraṇaṁ,"
    },
    {
      "id": "thag2.38:2.2",
      "pali": "nābhinandāmi jīvitaṁ;"
    },
    {
      "id": "thag2.38:2.3",
      "pali": "Kālañca paṭikaṅkhāmi,"
    },
    {
      "id": "thag2.38:2.4",
      "pali": "sampajāno patissato”ti."
    },
    {
      "id": "thag2.38:2.5",
      "pali": "… Nisabho thero …."
    }
  ]
}
