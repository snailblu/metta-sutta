{
  "uid": "tha-ap253",
  "title": "Thomakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap253:1.1",
      "pali": "“Devaloke ṭhito santo,"
    },
    {
      "id": "tha-ap253:1.2",
      "pali": "vipassissa mahesino;"
    },
    {
      "id": "tha-ap253:1.3",
      "pali": "Dhammaṁ suṇitvā mudito,"
    },
    {
      "id": "tha-ap253:1.4",
      "pali": "imaṁ vācaṁ abhāsahaṁ."
    },
    {
      "id": "tha-ap253:2.1",
      "pali": "‘Namo te purisājañña,"
    },
    {
      "id": "tha-ap253:2.2",
      "pali": "namo te purisuttama;"
    },
    {
      "id": "tha-ap253:2.3",
      "pali": "Bahujjanaṁ tārayasi,"
    },
    {
      "id": "tha-ap253:2.4",
      "pali": "desento amataṁ padaṁ’."
    },
    {
      "id": "tha-ap253:3.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap253:3.2",
      "pali": "yaṁ vācamabhaṇiṁ tadā;"
    },
    {
      "id": "tha-ap253:3.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap253:3.4",
      "pali": "thomanāya idaṁ phalaṁ."
    },
    {
      "id": "tha-ap253:4.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap253:4.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap253:4.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap253:4.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap253:5.1",
      "pali": "Itthaṁ sudaṁ āyasmā thomako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap253:6.1",
      "pali": "Thomakattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
