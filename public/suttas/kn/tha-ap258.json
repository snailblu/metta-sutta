{
  "uid": "tha-ap258",
  "title": "Upāhanadāyakattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap258:1.1",
      "pali": "“Ahosiṁ candano nāma,"
    },
    {
      "id": "tha-ap258:1.2",
      "pali": "sambuddhassatrajo tadā;"
    },
    {
      "id": "tha-ap258:1.3",
      "pali": "Ekopāhano mayā dinno,"
    },
    {
      "id": "tha-ap258:1.4",
      "pali": "bodhiṁ sampajja me tuvaṁ."
    },
    {
      "id": "tha-ap258:2.1",
      "pali": "Ekanavutito kappe,"
    },
    {
      "id": "tha-ap258:2.2",
      "pali": "yaṁ pānadhiṁ dadiṁ tadā;"
    },
    {
      "id": "tha-ap258:2.3",
      "pali": "Duggatiṁ nābhijānāmi,"
    },
    {
      "id": "tha-ap258:2.4",
      "pali": "upāhanassidaṁ phalaṁ."
    },
    {
      "id": "tha-ap258:3.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap258:3.2",
      "pali": "…pe…"
    },
    {
      "id": "tha-ap258:3.3",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap258:4.1",
      "pali": "Itthaṁ sudaṁ āyasmā upāhanadāyako thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap258:5.1",
      "pali": "Upāhanadāyakattherassāpadānaṁ chaṭṭhaṁ."
    }
  ]
}
