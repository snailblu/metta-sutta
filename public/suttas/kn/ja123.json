{
  "uid": "ja123",
  "title": "Kusanāḷivagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja123:1.1",
      "pali": "“Asabbatthagāmiṁ vācaṁ,"
    },
    {
      "id": "ja123:1.2",
      "pali": "Bālo sabbattha bhāsati;"
    },
    {
      "id": "ja123:1.3",
      "pali": "Nāyaṁ dadhiṁ vedi na naṅgalīsaṁ,"
    },
    {
      "id": "ja123:1.4",
      "pali": "Dadhippayaṁ maññati naṅgalīsan”ti."
    },
    {
      "id": "ja123:2.1",
      "pali": "Naṅgalīsajātakaṁ tatiyaṁ."
    }
  ]
}
