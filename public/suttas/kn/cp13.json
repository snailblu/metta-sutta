{
  "uid": "cp13",
  "title": "Sīlapāramī 3",
  "nikaya": "kn",
  "segments": [
    {
      "id": "cp13:1.1",
      "pali": "“Punāparaṁ yadā homi,"
    },
    {
      "id": "cp13:1.2",
      "pali": "campeyyako mahiddhiko;"
    },
    {
      "id": "cp13:1.3",
      "pali": "Tadāpi dhammiko āsiṁ,"
    },
    {
      "id": "cp13:1.4",
      "pali": "sīlabbatasamappito."
    },
    {
      "id": "cp13:2.1",
      "pali": "Tadāpi maṁ dhammacāriṁ,"
    },
    {
      "id": "cp13:2.2",
      "pali": "upavutthaṁ uposathaṁ;"
    },
    {
      "id": "cp13:2.3",
      "pali": "Ahituṇḍiko gahetvāna,"
    },
    {
      "id": "cp13:2.4",
      "pali": "rājadvāramhi kīḷati."
    },
    {
      "id": "cp13:3.1",
      "pali": "Yaṁ yaṁ so vaṇṇaṁ cintayi,"
    },
    {
      "id": "cp13:3.2",
      "pali": "nīlaṁva pītalohitaṁ;"
    },
    {
      "id": "cp13:3.3",
      "pali": "Tassa cittānuvattanto,"
    },
    {
      "id": "cp13:3.4",
      "pali": "homi cintitasannibho."
    },
    {
      "id": "cp13:4.1",
      "pali": "Thalaṁ kareyyamudakaṁ,"
    },
    {
      "id": "cp13:4.2",
      "pali": "udakampi thalaṁ kare;"
    },
    {
      "id": "cp13:4.3",
      "pali": "Yadihaṁ tassa pakuppeyyaṁ,"
    },
    {
      "id": "cp13:4.4",
      "pali": "khaṇena chārikaṁ kare."
    },
    {
      "id": "cp13:5.1",
      "pali": "Yadi cittavasī hessaṁ,"
    },
    {
      "id": "cp13:5.2",
      "pali": "parihāyissāmi sīlato;"
    },
    {
      "id": "cp13:5.3",
      "pali": "Sīlena parihīnassa,"
    },
    {
      "id": "cp13:5.4",
      "pali": "uttamattho na sijjhati."
    },
    {
      "id": "cp13:6.1",
      "pali": "Kāmaṁ bhijjatuyaṁ kāyo,"
    },
    {
      "id": "cp13:6.2",
      "pali": "idheva vikirīyatu;"
    },
    {
      "id": "cp13:6.3",
      "pali": "Neva sīlaṁ pabhindeyyaṁ,"
    },
    {
      "id": "cp13:6.4",
      "pali": "vikirante bhusaṁ viyā”ti."
    },
    {
      "id": "cp13:7.1",
      "pali": "Campeyyanāgacariyaṁ tatiyaṁ."
    }
  ]
}
