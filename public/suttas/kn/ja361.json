{
  "uid": "ja361",
  "title": "Vaṇṇārohavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja361:1.1",
      "pali": "“Vaṇṇārohena jātiyā,"
    },
    {
      "id": "ja361:1.2",
      "pali": "balanikkamanena ca;"
    },
    {
      "id": "ja361:1.3",
      "pali": "Subāhu na mayā seyyo,"
    },
    {
      "id": "ja361:1.4",
      "pali": "sudāṭha iti bhāsasi”."
    },
    {
      "id": "ja361:2.1",
      "pali": "“Vaṇṇārohena jātiyā,"
    },
    {
      "id": "ja361:2.2",
      "pali": "balanikkamanena ca;"
    },
    {
      "id": "ja361:2.3",
      "pali": "Sudāṭho na mayā seyyo,"
    },
    {
      "id": "ja361:2.4",
      "pali": "subāhu iti bhāsasi."
    },
    {
      "id": "ja361:3.1",
      "pali": "Evañce maṁ viharantaṁ,"
    },
    {
      "id": "ja361:3.2",
      "pali": "subāhu samma dubbhasi;"
    },
    {
      "id": "ja361:3.3",
      "pali": "Na dānāhaṁ tayā saddhiṁ,"
    },
    {
      "id": "ja361:3.4",
      "pali": "saṁvāsamabhirocaye."
    },
    {
      "id": "ja361:4.1",
      "pali": "Yo paresaṁ vacanāni,"
    },
    {
      "id": "ja361:4.2",
      "pali": "saddaheyya yathātathaṁ;"
    },
    {
      "id": "ja361:4.3",
      "pali": "Khippaṁ bhijjetha mittasmiṁ,"
    },
    {
      "id": "ja361:4.4",
      "pali": "verañca pasave bahuṁ."
    },
    {
      "id": "ja361:5.1",
      "pali": "Na so mitto yo sadā appamatto,"
    },
    {
      "id": "ja361:5.2",
      "pali": "Bhedāsaṅkī randhamevānupassī;"
    },
    {
      "id": "ja361:5.3",
      "pali": "Yasmiñca setī urasīva putto,"
    },
    {
      "id": "ja361:5.4",
      "pali": "Sa ve mitto yo abhejjo parehī”ti."
    },
    {
      "id": "ja361:6.1",
      "pali": "Vaṇṇārohajātakaṁ paṭhamaṁ."
    }
  ]
}
