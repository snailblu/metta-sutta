{
  "uid": "thag1.118",
  "title": "Dvādasamavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "thag1.118:1.1",
      "pali": "“Abhisattova nipatati,"
    },
    {
      "id": "thag1.118:1.2",
      "pali": "Vayo rūpaṁ aññamiva tatheva santaṁ;"
    },
    {
      "id": "thag1.118:1.3",
      "pali": "Tasseva sato avippavasato,"
    },
    {
      "id": "thag1.118:1.4",
      "pali": "Aññasseva sarāmi attānan”ti."
    },
    {
      "id": "thag1.118:1.5",
      "pali": "… Kimilo thero …."
    }
  ]
}
