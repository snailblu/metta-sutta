{
  "uid": "ja268",
  "title": "Padumavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja268:1.1",
      "pali": "“Yo ve sabbasametānaṁ,"
    },
    {
      "id": "ja268:1.2",
      "pali": "ahuvā seṭṭhasammato;"
    },
    {
      "id": "ja268:1.3",
      "pali": "Tassāyaṁ edisī paññā,"
    },
    {
      "id": "ja268:1.4",
      "pali": "kimeva itarā pajā”."
    },
    {
      "id": "ja268:2.1",
      "pali": "“Evameva tuvaṁ brahme,"
    },
    {
      "id": "ja268:2.2",
      "pali": "anaññāya vinindasi;"
    },
    {
      "id": "ja268:2.3",
      "pali": "Kathaṁ mūlaṁ adisvāna,"
    },
    {
      "id": "ja268:2.4",
      "pali": "rukkhaṁ jaññā patiṭṭhitaṁ”."
    },
    {
      "id": "ja268:3.1",
      "pali": "“Nāhaṁ tumhe vinindāmi,"
    },
    {
      "id": "ja268:3.2",
      "pali": "ye caññe vānarā vane;"
    },
    {
      "id": "ja268:3.3",
      "pali": "Vissasenova gārayho,"
    },
    {
      "id": "ja268:3.4",
      "pali": "yassatthā rukkharopakā”ti."
    },
    {
      "id": "ja268:4.1",
      "pali": "Ārāmadūsakajātakaṁ aṭṭhamaṁ."
    }
  ]
}
