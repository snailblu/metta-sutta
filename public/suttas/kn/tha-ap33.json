{
  "uid": "tha-ap33",
  "title": "Kuṇḍadhānattheraapadāna",
  "nikaya": "kn",
  "segments": [
    {
      "id": "tha-ap33:1.1",
      "pali": "“Sattāhaṁ paṭisallīnaṁ,"
    },
    {
      "id": "tha-ap33:1.2",
      "pali": "sayambhuṁ aggapuggalaṁ;"
    },
    {
      "id": "tha-ap33:1.3",
      "pali": "Pasannacitto sumano,"
    },
    {
      "id": "tha-ap33:1.4",
      "pali": "buddhaseṭṭhaṁ upaṭṭhahiṁ."
    },
    {
      "id": "tha-ap33:2.1",
      "pali": "Vuṭṭhitaṁ kālamaññāya,"
    },
    {
      "id": "tha-ap33:2.2",
      "pali": "padumuttaraṁ mahāmuniṁ;"
    },
    {
      "id": "tha-ap33:2.3",
      "pali": "Mahantiṁ kadalīkaṇṇiṁ,"
    },
    {
      "id": "tha-ap33:2.4",
      "pali": "gahetvā upagacchahaṁ."
    },
    {
      "id": "tha-ap33:3.1",
      "pali": "Paṭiggahetvā bhagavā,"
    },
    {
      "id": "tha-ap33:3.2",
      "pali": "sabbaññū lokanāyako;"
    },
    {
      "id": "tha-ap33:3.3",
      "pali": "Mama cittaṁ pasādento,"
    },
    {
      "id": "tha-ap33:3.4",
      "pali": "paribhuñji mahāmuni."
    },
    {
      "id": "tha-ap33:4.1",
      "pali": "Paribhuñjitvā sambuddho,"
    },
    {
      "id": "tha-ap33:4.2",
      "pali": "satthavāho anuttaro;"
    },
    {
      "id": "tha-ap33:4.3",
      "pali": "Sakāsane nisīditvā,"
    },
    {
      "id": "tha-ap33:4.4",
      "pali": "imā gāthā abhāsatha."
    },
    {
      "id": "tha-ap33:5.1",
      "pali": "‘Ye ca santi samitāro,"
    },
    {
      "id": "tha-ap33:5.2",
      "pali": "yakkhā imamhi pabbate;"
    },
    {
      "id": "tha-ap33:5.3",
      "pali": "Araññe bhūtabhabyāni,"
    },
    {
      "id": "tha-ap33:5.4",
      "pali": "suṇantu vacanaṁ mama."
    },
    {
      "id": "tha-ap33:6.1",
      "pali": "Yo so buddhaṁ upaṭṭhāsi,"
    },
    {
      "id": "tha-ap33:6.2",
      "pali": "migarājaṁva kesariṁ;"
    },
    {
      "id": "tha-ap33:6.3",
      "pali": "Tamahaṁ kittayissāmi,"
    },
    {
      "id": "tha-ap33:6.4",
      "pali": "suṇātha mama bhāsato."
    },
    {
      "id": "tha-ap33:7.1",
      "pali": "Ekādasañcakkhattuṁ so,"
    },
    {
      "id": "tha-ap33:7.2",
      "pali": "devarājā bhavissati;"
    },
    {
      "id": "tha-ap33:7.3",
      "pali": "Catutiṁsatikkhattuñca,"
    },
    {
      "id": "tha-ap33:7.4",
      "pali": "cakkavattī bhavissati."
    },
    {
      "id": "tha-ap33:8.1",
      "pali": "Kappasatasahassamhi,"
    },
    {
      "id": "tha-ap33:8.2",
      "pali": "okkākakulasambhavo;"
    },
    {
      "id": "tha-ap33:8.3",
      "pali": "Gotamo nāma gottena,"
    },
    {
      "id": "tha-ap33:8.4",
      "pali": "satthā loke bhavissati."
    },
    {
      "id": "tha-ap33:9.1",
      "pali": "Akkositvāna samaṇe,"
    },
    {
      "id": "tha-ap33:9.2",
      "pali": "sīlavante anāsave;"
    },
    {
      "id": "tha-ap33:9.3",
      "pali": "Pāpakammavipākena,"
    },
    {
      "id": "tha-ap33:9.4",
      "pali": "nāmadheyyaṁ labhissati."
    },
    {
      "id": "tha-ap33:10.1",
      "pali": "Tassa dhamme sudāyādo,"
    },
    {
      "id": "tha-ap33:10.2",
      "pali": "oraso dhammanimmito;"
    },
    {
      "id": "tha-ap33:10.3",
      "pali": "Kuṇḍadhānoti nāmena,"
    },
    {
      "id": "tha-ap33:10.4",
      "pali": "sāvako so bhavissati’."
    },
    {
      "id": "tha-ap33:11.1",
      "pali": "Pavivekamanuyutto,"
    },
    {
      "id": "tha-ap33:11.2",
      "pali": "jhāyī jhānarato ahaṁ;"
    },
    {
      "id": "tha-ap33:11.3",
      "pali": "Tosayitvāna satthāraṁ,"
    },
    {
      "id": "tha-ap33:11.4",
      "pali": "viharāmi anāsavo."
    },
    {
      "id": "tha-ap33:12.1",
      "pali": "Sāvakehi parivuto,"
    },
    {
      "id": "tha-ap33:12.2",
      "pali": "bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "tha-ap33:12.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap33:12.4",
      "pali": "salākaṁ gāhayī jino."
    },
    {
      "id": "tha-ap33:13.1",
      "pali": "Ekaṁsaṁ cīvaraṁ katvā,"
    },
    {
      "id": "tha-ap33:13.2",
      "pali": "vanditvā lokanāyakaṁ;"
    },
    {
      "id": "tha-ap33:13.3",
      "pali": "Vadataṁ varassa purato,"
    },
    {
      "id": "tha-ap33:13.4",
      "pali": "paṭhamaṁ aggahesahaṁ."
    },
    {
      "id": "tha-ap33:14.1",
      "pali": "Tena kammena bhagavā,"
    },
    {
      "id": "tha-ap33:14.2",
      "pali": "dasasahassikampako;"
    },
    {
      "id": "tha-ap33:14.3",
      "pali": "Bhikkhusaṅghe nisīditvā,"
    },
    {
      "id": "tha-ap33:14.4",
      "pali": "aggaṭṭhāne ṭhapesi maṁ."
    },
    {
      "id": "tha-ap33:15.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "tha-ap33:15.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "tha-ap33:15.3",
      "pali": "Dhāremi antimaṁ dehaṁ,"
    },
    {
      "id": "tha-ap33:15.4",
      "pali": "sammāsambuddhasāsane."
    },
    {
      "id": "tha-ap33:16.1",
      "pali": "Paṭisambhidā catasso,"
    },
    {
      "id": "tha-ap33:16.2",
      "pali": "vimokkhāpi ca aṭṭhime;"
    },
    {
      "id": "tha-ap33:16.3",
      "pali": "Chaḷabhiññā sacchikatā,"
    },
    {
      "id": "tha-ap33:16.4",
      "pali": "kataṁ buddhassa sāsanaṁ”."
    },
    {
      "id": "tha-ap33:17.1",
      "pali": "Itthaṁ sudaṁ āyasmā kuṇḍadhāno thero imā gāthāyo abhāsitthāti."
    },
    {
      "id": "tha-ap33:18.1",
      "pali": "Kuṇḍadhānattherassāpadānaṁ paṭhamaṁ."
    }
  ]
}
