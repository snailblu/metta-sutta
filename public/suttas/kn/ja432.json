{
  "uid": "ja432",
  "title": "Gijjhavagga",
  "nikaya": "kn",
  "segments": [
    {
      "id": "ja432:1.1",
      "pali": "“Bahussutaṁ cittakathiṁ,"
    },
    {
      "id": "ja432:1.2",
      "pali": "gaṅgā vahati pāṭaliṁ;"
    },
    {
      "id": "ja432:1.3",
      "pali": "Vuyhamānaka bhaddante,"
    },
    {
      "id": "ja432:1.4",
      "pali": "ekaṁ me dehi gāthakaṁ”."
    },
    {
      "id": "ja432:2.1",
      "pali": "“Yena siñcanti dukkhitaṁ,"
    },
    {
      "id": "ja432:2.2",
      "pali": "yena siñcanti āturaṁ;"
    },
    {
      "id": "ja432:2.3",
      "pali": "Tassa majjhe marissāmi,"
    },
    {
      "id": "ja432:2.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:3.1",
      "pali": "“Yattha bījāni rūhanti,"
    },
    {
      "id": "ja432:3.2",
      "pali": "sattā yattha patiṭṭhitā;"
    },
    {
      "id": "ja432:3.3",
      "pali": "Sā me sīsaṁ nipīḷeti,"
    },
    {
      "id": "ja432:3.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:4.1",
      "pali": "“Yena bhattāni paccanti,"
    },
    {
      "id": "ja432:4.2",
      "pali": "sītaṁ yena vihaññati;"
    },
    {
      "id": "ja432:4.3",
      "pali": "So maṁ ḍahati gattāni,"
    },
    {
      "id": "ja432:4.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:5.1",
      "pali": "“Yena bhuttena yāpenti,"
    },
    {
      "id": "ja432:5.2",
      "pali": "puthū brāhmaṇakhattiyā;"
    },
    {
      "id": "ja432:5.3",
      "pali": "So maṁ bhutto byāpādeti,"
    },
    {
      "id": "ja432:5.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:6.1",
      "pali": "“Gimhānaṁ pacchime māse,"
    },
    {
      "id": "ja432:6.2",
      "pali": "vātamicchanti paṇḍitā;"
    },
    {
      "id": "ja432:6.3",
      "pali": "So maṁ bhañjati gattāni,"
    },
    {
      "id": "ja432:6.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:7.1",
      "pali": "“Yaṁ nissitā jagatiruhaṁ,"
    },
    {
      "id": "ja432:7.2",
      "pali": "svāyaṁ aggiṁ pamuñcati;"
    },
    {
      "id": "ja432:7.3",
      "pali": "Disā bhajatha vakkaṅgā,"
    },
    {
      "id": "ja432:7.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:8.1",
      "pali": "“Yamānayiṁ somanassaṁ,"
    },
    {
      "id": "ja432:8.2",
      "pali": "māliniṁ candanussadaṁ;"
    },
    {
      "id": "ja432:8.3",
      "pali": "Sā maṁ gharā nicchubhati,"
    },
    {
      "id": "ja432:8.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:9.1",
      "pali": "“Yena jātena nandissaṁ,"
    },
    {
      "id": "ja432:9.2",
      "pali": "yassa ca bhavamicchisaṁ;"
    },
    {
      "id": "ja432:9.3",
      "pali": "So maṁ gharā nicchubhati,"
    },
    {
      "id": "ja432:9.4",
      "pali": "jātaṁ saraṇato bhayaṁ”."
    },
    {
      "id": "ja432:10.1",
      "pali": "“Suṇantu me jānapadā,"
    },
    {
      "id": "ja432:10.2",
      "pali": "negamā ca samāgatā;"
    },
    {
      "id": "ja432:10.3",
      "pali": "Yatodakaṁ tadādittaṁ,"
    },
    {
      "id": "ja432:10.4",
      "pali": "yato khemaṁ tato bhayaṁ."
    },
    {
      "id": "ja432:11.1",
      "pali": "Rājā vilumpate raṭṭhaṁ,"
    },
    {
      "id": "ja432:11.2",
      "pali": "brāhmaṇo ca purohito;"
    },
    {
      "id": "ja432:11.3",
      "pali": "Attaguttā viharatha,"
    },
    {
      "id": "ja432:11.4",
      "pali": "jātaṁ saraṇato bhayan”ti."
    },
    {
      "id": "ja432:12.1",
      "pali": "Padakusalamāṇavajātakaṁ chaṭṭhaṁ."
    }
  ]
}
