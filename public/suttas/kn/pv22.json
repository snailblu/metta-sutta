{
  "uid": "pv22",
  "title": "10. Uttaramātupetivatthu",
  "nikaya": "kn",
  "segments": [
    {
      "id": "pv22:1.1",
      "pali": "Divāvihāragataṁ bhikkhuṁ,"
    },
    {
      "id": "pv22:1.2",
      "pali": "gaṅgātīre nisinnakaṁ;"
    },
    {
      "id": "pv22:1.3",
      "pali": "Taṁ petī upasaṅkamma,"
    },
    {
      "id": "pv22:1.4",
      "pali": "dubbaṇṇā bhīrudassanā."
    },
    {
      "id": "pv22:2.1",
      "pali": "Kesā cassā atidīghā,"
    },
    {
      "id": "pv22:2.2",
      "pali": "yāvabhūmāvalambare;"
    },
    {
      "id": "pv22:2.3",
      "pali": "Kesehi sā paṭicchannā,"
    },
    {
      "id": "pv22:2.4",
      "pali": "samaṇaṁ etadabravi."
    },
    {
      "id": "pv22:3.1",
      "pali": "“Pañcapaṇṇāsavassāni,"
    },
    {
      "id": "pv22:3.2",
      "pali": "yato kālaṅkatā ahaṁ;"
    },
    {
      "id": "pv22:3.3",
      "pali": "Nābhijānāmi bhuttaṁ vā,"
    },
    {
      "id": "pv22:3.4",
      "pali": "pītaṁ vā pana pāniyaṁ;"
    },
    {
      "id": "pv22:3.5",
      "pali": "Dehi tvaṁ pāniyaṁ bhante,"
    },
    {
      "id": "pv22:3.6",
      "pali": "tasitā pāniyāya me”ti."
    },
    {
      "id": "pv22:4.1",
      "pali": "“Ayaṁ sītodikā gaṅgā,"
    },
    {
      "id": "pv22:4.2",
      "pali": "himavantato sandati;"
    },
    {
      "id": "pv22:4.3",
      "pali": "Piva etto gahetvāna,"
    },
    {
      "id": "pv22:4.4",
      "pali": "kiṁ maṁ yācasi pāniyan”ti."
    },
    {
      "id": "pv22:5.1",
      "pali": "“Sacāhaṁ bhante gaṅgāya,"
    },
    {
      "id": "pv22:5.2",
      "pali": "sayaṁ gaṇhāmi pāniyaṁ;"
    },
    {
      "id": "pv22:5.3",
      "pali": "Lohitaṁ me parivattati,"
    },
    {
      "id": "pv22:5.4",
      "pali": "tasmā yācāmi pāniyan”ti."
    },
    {
      "id": "pv22:6.1",
      "pali": "“Kiṁ nu kāyena vācāya,"
    },
    {
      "id": "pv22:6.2",
      "pali": "manasā dukkaṭaṁ kataṁ;"
    },
    {
      "id": "pv22:6.3",
      "pali": "Kissa kammavipākena,"
    },
    {
      "id": "pv22:6.4",
      "pali": "gaṅgā te hoti lohitan”ti."
    },
    {
      "id": "pv22:7.1",
      "pali": "“Putto me uttaro nāma,"
    },
    {
      "id": "pv22:7.2",
      "pali": "saddho āsi upāsako;"
    },
    {
      "id": "pv22:7.3",
      "pali": "So ca mayhaṁ akāmāya,"
    },
    {
      "id": "pv22:7.4",
      "pali": "samaṇānaṁ pavecchati."
    },
    {
      "id": "pv22:8.1",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "pv22:8.2",
      "pali": "paccayaṁ sayanāsanaṁ;"
    },
    {
      "id": "pv22:8.3",
      "pali": "Tamahaṁ paribhāsāmi,"
    },
    {
      "id": "pv22:8.4",
      "pali": "maccherena upaddutā."
    },
    {
      "id": "pv22:9.1",
      "pali": "Yaṁ tvaṁ mayhaṁ akāmāya,"
    },
    {
      "id": "pv22:9.2",
      "pali": "samaṇānaṁ pavecchasi;"
    },
    {
      "id": "pv22:9.3",
      "pali": "Cīvaraṁ piṇḍapātañca,"
    },
    {
      "id": "pv22:9.4",
      "pali": "paccayaṁ sayanāsanaṁ."
    },
    {
      "id": "pv22:10.1",
      "pali": "Etaṁ te paralokasmiṁ,"
    },
    {
      "id": "pv22:10.2",
      "pali": "lohitaṁ hotu uttara;"
    },
    {
      "id": "pv22:10.3",
      "pali": "Tassa kammassa vipākena,"
    },
    {
      "id": "pv22:10.4",
      "pali": "gaṅgā me hoti lohitan”ti."
    },
    {
      "id": "pv22:11.1",
      "pali": "Uttaramātupetivatthu dasamaṁ."
    }
  ]
}
