{
  "uid": "an5.237",
  "title": "Dutiyaavaṇṇārahasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.237:1.1",
      "pali": "“Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an5.237:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.237:1.3",
      "pali": "Ananuvicca apariyogāhetvā avaṇṇārahassa vaṇṇaṁ bhāsati;"
    },
    {
      "id": "an5.237:1.4",
      "pali": "ananuvicca apariyogāhetvā vaṇṇārahassa avaṇṇaṁ bhāsati;"
    },
    {
      "id": "an5.237:1.5",
      "pali": "āvāsamaccharī hoti āvāsapaligedhī;"
    },
    {
      "id": "an5.237:1.6",
      "pali": "kulamaccharī hoti kulapaligedhī;"
    },
    {
      "id": "an5.237:1.7",
      "pali": "saddhādeyyaṁ vinipāteti."
    },
    {
      "id": "an5.237:1.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an5.237:2.1",
      "pali": "Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "an5.237:2.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.237:2.3",
      "pali": "Anuvicca pariyogāhetvā avaṇṇārahassa avaṇṇaṁ bhāsati;"
    },
    {
      "id": "an5.237:2.4",
      "pali": "anuvicca pariyogāhetvā vaṇṇārahassa vaṇṇaṁ bhāsati;"
    },
    {
      "id": "an5.237:2.5",
      "pali": "na āvāsamaccharī hoti na āvāsapaligedhī;"
    },
    {
      "id": "an5.237:2.6",
      "pali": "na kulamaccharī hoti na kulapaligedhī;"
    },
    {
      "id": "an5.237:2.7",
      "pali": "saddhādeyyaṁ na vinipāteti."
    },
    {
      "id": "an5.237:2.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "an5.237:2.9",
      "pali": "Sattamaṁ."
    }
  ]
}
