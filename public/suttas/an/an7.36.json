{
  "uid": "an7.36",
  "title": "Paṭhamamittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.36:1.1",
      "pali": "“Sattahi, bhikkhave, aṅgehi samannāgato mitto sevitabbo."
    },
    {
      "id": "an7.36:1.2",
      "pali": "Katamehi sattahi?"
    },
    {
      "id": "an7.36:1.3",
      "pali": "Duddadaṁ dadāti, dukkaraṁ karoti, dukkhamaṁ khamati, guyhamassa āvi karoti, guyhamassa pariguhati, āpadāsu na jahati, khīṇena nātimaññati."
    },
    {
      "id": "an7.36:1.4",
      "pali": "Imehi kho, bhikkhave, sattahi aṅgehi samannāgato mitto sevitabboti."
    },
    {
      "id": "an7.36:2.1",
      "pali": "Duddadaṁ dadāti mitto,"
    },
    {
      "id": "an7.36:2.2",
      "pali": "dukkarañcāpi kubbati;"
    },
    {
      "id": "an7.36:2.3",
      "pali": "Athopissa duruttāni,"
    },
    {
      "id": "an7.36:2.4",
      "pali": "khamati dukkhamāni ca."
    },
    {
      "id": "an7.36:3.1",
      "pali": "Guyhañca tassa akkhāti,"
    },
    {
      "id": "an7.36:3.2",
      "pali": "guyhassa parigūhati;"
    },
    {
      "id": "an7.36:3.3",
      "pali": "Āpadāsu na jahāti,"
    },
    {
      "id": "an7.36:3.4",
      "pali": "khīṇena nātimaññati."
    },
    {
      "id": "an7.36:4.1",
      "pali": "Yamhi etāni ṭhānāni,"
    },
    {
      "id": "an7.36:4.2",
      "pali": "saṁvijjantīdha puggale;"
    },
    {
      "id": "an7.36:4.3",
      "pali": "So mitto mittakāmena,"
    },
    {
      "id": "an7.36:4.4",
      "pali": "bhajitabbo tathāvidho”ti."
    },
    {
      "id": "an7.36:4.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
