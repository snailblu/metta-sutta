{
  "uid": "an8.50",
  "title": "Dutiyaidhalokikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.50:1.1",
      "pali": "“Catūhi, bhikkhave, dhammehi samannāgato mātugāmo idhalokavijayāya paṭipanno hoti, ayaṁsa loko āraddho hoti."
    },
    {
      "id": "an8.50:1.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an8.50:1.3",
      "pali": "Idha, bhikkhave, mātugāmo susaṁvihitakammanto hoti, saṅgahitaparijano, bhattu manāpaṁ carati, sambhataṁ anurakkhati."
    },
    {
      "id": "an8.50:2.1",
      "pali": "Kathañca, bhikkhave, mātugāmo susaṁvihitakammanto hoti?"
    },
    {
      "id": "an8.50:2.2",
      "pali": "Idha, bhikkhave, mātugāmo ye te bhattu abbhantarā kammantā …pe…"
    },
    {
      "id": "an8.50:2.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo susaṁvihitakammanto hoti."
    },
    {
      "id": "an8.50:3.1",
      "pali": "Kathañca, bhikkhave, mātugāmo saṅgahitaparijano hoti?"
    },
    {
      "id": "an8.50:3.2",
      "pali": "Idha, bhikkhave, mātugāmo yo so bhattu abbhantaro antojano …pe…"
    },
    {
      "id": "an8.50:3.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo saṅgahitaparijano hoti."
    },
    {
      "id": "an8.50:4.1",
      "pali": "Kathañca, bhikkhave, mātugāmo bhattu manāpaṁ carati?"
    },
    {
      "id": "an8.50:4.2",
      "pali": "Idha, bhikkhave, mātugāmo yaṁ bhattu amanāpasaṅkhātaṁ taṁ jīvitahetupi na ajjhācarati."
    },
    {
      "id": "an8.50:4.3",
      "pali": "Evaṁ kho, bhikkhave, mātugāmo bhattu manāpaṁ carati."
    },
    {
      "id": "an8.50:5.1",
      "pali": "Kathañca, bhikkhave, mātugāmo sambhataṁ anurakkhati?"
    },
    {
      "id": "an8.50:5.2",
      "pali": "Idha, bhikkhave, mātugāmo yaṁ bhattā āharati …pe…"
    },
    {
      "id": "an8.50:5.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo sambhataṁ anurakkhati."
    },
    {
      "id": "an8.50:5.4",
      "pali": "Imehi kho, bhikkhave, catūhi dhammehi samannāgato mātugāmo idhalokavijayāya paṭipanno hoti, ayaṁsa loko āraddho hoti."
    },
    {
      "id": "an8.50:6.1",
      "pali": "Catūhi, bhikkhave, dhammehi samannāgato mātugāmo paralokavijayāya paṭipanno hoti, paraloko āraddho hoti."
    },
    {
      "id": "an8.50:6.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an8.50:6.3",
      "pali": "Idha, bhikkhave, mātugāmo saddhāsampanno hoti, sīlasampanno hoti, cāgasampanno hoti, paññāsampanno hoti."
    },
    {
      "id": "an8.50:7.1",
      "pali": "Kathañca, bhikkhave, mātugāmo saddhāsampanno hoti?"
    },
    {
      "id": "an8.50:7.2",
      "pali": "Idha, bhikkhave, mātugāmo saddho hoti …pe…"
    },
    {
      "id": "an8.50:7.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo saddhāsampanno hoti."
    },
    {
      "id": "an8.50:8.1",
      "pali": "Kathañca, bhikkhave, mātugāmo sīlasampanno hoti?"
    },
    {
      "id": "an8.50:8.2",
      "pali": "Idha, bhikkhave, mātugāmo pāṇātipātā paṭivirato hoti …pe…"
    },
    {
      "id": "an8.50:8.3",
      "pali": "surāmerayamajjapamādaṭṭhānā paṭivirato hoti."
    },
    {
      "id": "an8.50:8.4",
      "pali": "Evaṁ kho, bhikkhave, mātugāmo sīlasampanno hoti."
    },
    {
      "id": "an8.50:9.1",
      "pali": "Kathañca, bhikkhave, mātugāmo cāgasampanno hoti?"
    },
    {
      "id": "an8.50:9.2",
      "pali": "Idha, bhikkhave, mātugāmo vigatamalamaccherena cetasā agāraṁ ajjhāvasati …pe…"
    },
    {
      "id": "an8.50:9.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo cāgasampanno hoti."
    },
    {
      "id": "an8.50:10.1",
      "pali": "Kathañca, bhikkhave, mātugāmo paññāsampanno hoti?"
    },
    {
      "id": "an8.50:10.2",
      "pali": "Idha, bhikkhave, mātugāmo paññavā hoti …pe…"
    },
    {
      "id": "an8.50:10.3",
      "pali": "evaṁ kho, bhikkhave, mātugāmo paññāsampanno hoti."
    },
    {
      "id": "an8.50:10.4",
      "pali": "Imehi kho, bhikkhave, catūhi dhammehi samannāgato mātugāmo paralokavijayāya paṭipanno hoti, paraloko āraddho hotīti."
    },
    {
      "id": "an8.50:11.1",
      "pali": "Susaṁvihitakammantā,"
    },
    {
      "id": "an8.50:11.2",
      "pali": "saṅgahitaparijjanā;"
    },
    {
      "id": "an8.50:11.3",
      "pali": "Bhattu manāpaṁ carati,"
    },
    {
      "id": "an8.50:11.4",
      "pali": "sambhataṁ anurakkhati."
    },
    {
      "id": "an8.50:12.1",
      "pali": "Saddhā sīlena sampannā,"
    },
    {
      "id": "an8.50:12.2",
      "pali": "vadaññū vītamaccharā;"
    },
    {
      "id": "an8.50:12.3",
      "pali": "Niccaṁ maggaṁ visodheti,"
    },
    {
      "id": "an8.50:12.4",
      "pali": "sotthānaṁ samparāyikaṁ."
    },
    {
      "id": "an8.50:13.1",
      "pali": "Iccete aṭṭha dhammā ca,"
    },
    {
      "id": "an8.50:13.2",
      "pali": "yassā vijjanti nāriyā;"
    },
    {
      "id": "an8.50:13.3",
      "pali": "Tampi sīlavatiṁ āhu,"
    },
    {
      "id": "an8.50:13.4",
      "pali": "dhammaṭṭhaṁ saccavādiniṁ."
    },
    {
      "id": "an8.50:14.1",
      "pali": "Soḷasākārasampannā,"
    },
    {
      "id": "an8.50:14.2",
      "pali": "Aṭṭhaṅgasusamāgatā;"
    },
    {
      "id": "an8.50:14.3",
      "pali": "Tādisī sīlavatī upāsikā,"
    },
    {
      "id": "an8.50:14.4",
      "pali": "Upapajjati devalokaṁ manāpan”ti."
    },
    {
      "id": "an8.50:14.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an8.50:14.6",
      "pali": "Uposathavaggo pañcamo."
    },
    {
      "id": "an8.50:15.1",
      "pali": "Saṅkhitte vitthate visākhe,"
    },
    {
      "id": "an8.50:15.2",
      "pali": "Vāseṭṭho bojjhāya pañcamaṁ;"
    },
    {
      "id": "an8.50:15.3",
      "pali": "Anuruddhaṁ puna visākhe,"
    },
    {
      "id": "an8.50:15.4",
      "pali": "Nakulā idhalokikā dveti."
    },
    {
      "id": "an8.50:15.5",
      "pali": "Paṭhamo paṇṇāsako samatto."
    }
  ]
}
