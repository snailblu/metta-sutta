{
  "uid": "an8.31",
  "title": "Paṭhamadānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.31:1.1",
      "pali": "“Aṭṭhimāni, bhikkhave, dānāni."
    },
    {
      "id": "an8.31:1.2",
      "pali": "Katamāni aṭṭha?"
    },
    {
      "id": "an8.31:1.3",
      "pali": "Āsajja dānaṁ deti,"
    },
    {
      "id": "an8.31:1.4",
      "pali": "bhayā dānaṁ deti,"
    },
    {
      "id": "an8.31:1.5",
      "pali": "‘adāsi me’ti dānaṁ deti,"
    },
    {
      "id": "an8.31:1.6",
      "pali": "‘dassati me’ti dānaṁ deti,"
    },
    {
      "id": "an8.31:1.7",
      "pali": "‘sāhu dānan’ti dānaṁ deti,"
    },
    {
      "id": "an8.31:1.8",
      "pali": "‘ahaṁ pacāmi, ime na pacanti; nārahāmi pacanto apacantānaṁ dānaṁ adātun’ti dānaṁ deti,"
    },
    {
      "id": "an8.31:1.9",
      "pali": "‘imaṁ me dānaṁ dadato kalyāṇo kittisaddo abbhuggacchatī’ti dānaṁ deti,"
    },
    {
      "id": "an8.31:1.10",
      "pali": "cittālaṅkāracittaparikkhāratthaṁ dānaṁ deti."
    },
    {
      "id": "an8.31:1.11",
      "pali": "Imāni kho, bhikkhave, aṭṭha dānānī”ti."
    },
    {
      "id": "an8.31:1.12",
      "pali": "Paṭhamaṁ."
    }
  ]
}
