{
  "uid": "an5.204",
  "title": "Balasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.204:1.1",
      "pali": "“Pañcimāni, bhikkhave, balāni."
    },
    {
      "id": "an5.204:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.204:1.3",
      "pali": "Saddhābalaṁ, hiribalaṁ, ottappabalaṁ, vīriyabalaṁ, paññābalaṁ—"
    },
    {
      "id": "an5.204:1.4",
      "pali": "imāni kho, bhikkhave, pañca balānī”ti."
    },
    {
      "id": "an5.204:1.5",
      "pali": "Catutthaṁ."
    }
  ]
}
