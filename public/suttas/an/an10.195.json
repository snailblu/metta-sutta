{
  "uid": "an10.195",
  "title": "Bhāvetabbadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.195:1.1",
      "pali": "“Bhāvetabbañca vo, bhikkhave, dhammaṁ desessāmi na bhāvetabbañca."
    },
    {
      "id": "an10.195:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.195:1.3",
      "pali": "katamo ca, bhikkhave, na bhāvetabbo dhammo?"
    },
    {
      "id": "an10.195:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.195:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.195:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, na bhāvetabbo dhammo."
    },
    {
      "id": "an10.195:2.1",
      "pali": "Katamo ca, bhikkhave, bhāvetabbo dhammo?"
    },
    {
      "id": "an10.195:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.195:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.195:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, bhāvetabbo dhammo”ti."
    },
    {
      "id": "an10.195:2.5",
      "pali": "Sattamaṁ."
    }
  ]
}
