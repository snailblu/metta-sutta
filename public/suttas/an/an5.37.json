{
  "uid": "an5.37",
  "title": "Bhojanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.37:1.1",
      "pali": "“Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ pañca ṭhānāni deti."
    },
    {
      "id": "an5.37:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.37:1.3",
      "pali": "Āyuṁ deti, vaṇṇaṁ deti, sukhaṁ deti, balaṁ deti, paṭibhānaṁ deti."
    },
    {
      "id": "an5.37:1.4",
      "pali": "Āyuṁ kho pana datvā āyussa bhāgī hoti dibbassa vā mānusassa vā;"
    },
    {
      "id": "an5.37:1.5",
      "pali": "vaṇṇaṁ datvā vaṇṇassa bhāgī hoti dibbassa vā mānusassa vā;"
    },
    {
      "id": "an5.37:1.6",
      "pali": "sukhaṁ datvā sukhassa bhāgī hoti dibbassa vā mānusassa vā;"
    },
    {
      "id": "an5.37:1.7",
      "pali": "balaṁ datvā balassa bhāgī hoti dibbassa vā mānusassa vā;"
    },
    {
      "id": "an5.37:1.8",
      "pali": "paṭibhānaṁ datvā paṭibhānassa bhāgī hoti dibbassa vā mānusassa vā."
    },
    {
      "id": "an5.37:1.9",
      "pali": "Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ imāni pañca ṭhānāni detīti."
    },
    {
      "id": "an5.37:2.1",
      "pali": "Āyudo balado dhīro,"
    },
    {
      "id": "an5.37:2.2",
      "pali": "vaṇṇado paṭibhānado;"
    },
    {
      "id": "an5.37:2.3",
      "pali": "Sukhassa dātā medhāvī,"
    },
    {
      "id": "an5.37:2.4",
      "pali": "sukhaṁ so adhigacchati."
    },
    {
      "id": "an5.37:3.1",
      "pali": "Āyuṁ datvā balaṁ vaṇṇaṁ,"
    },
    {
      "id": "an5.37:3.2",
      "pali": "sukhañca paṭibhānakaṁ;"
    },
    {
      "id": "an5.37:3.3",
      "pali": "Dīghāyu yasavā hoti,"
    },
    {
      "id": "an5.37:3.4",
      "pali": "yattha yatthūpapajjatī”ti."
    },
    {
      "id": "an5.37:3.5",
      "pali": "Sattamaṁ."
    }
  ]
}
