{
  "uid": "an10.96",
  "title": "Kokanudasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.96:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā ānando rājagahe viharati tapodārāme."
    },
    {
      "id": "an10.96:1.2",
      "pali": "Atha kho āyasmā ānando rattiyā paccūsasamayaṁ paccuṭṭhāya yena tapodā tenupasaṅkami gattāni parisiñcituṁ."
    },
    {
      "id": "an10.96:1.3",
      "pali": "Tapodāya gattāni parisiñcitvā paccuttaritvā ekacīvaro aṭṭhāsi gattāni pubbāpayamāno."
    },
    {
      "id": "an10.96:1.4",
      "pali": "Kokanudopi kho paribbājako rattiyā paccūsasamayaṁ paccuṭṭhāya yena tapodā tenupasaṅkami gattāni parisiñcituṁ."
    },
    {
      "id": "an10.96:2.1",
      "pali": "Addasā kho kokanudo paribbājako āyasmantaṁ ānandaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "an10.96:2.2",
      "pali": "Disvāna āyasmantaṁ ānandaṁ etadavoca:"
    },
    {
      "id": "an10.96:2.3",
      "pali": "“kvettha, āvuso”ti?"
    },
    {
      "id": "an10.96:2.4",
      "pali": "“Ahamāvuso, bhikkhū”ti."
    },
    {
      "id": "an10.96:3.1",
      "pali": "“Katamesaṁ, āvuso, bhikkhūnan”ti?"
    },
    {
      "id": "an10.96:3.2",
      "pali": "“Samaṇānaṁ, āvuso, sakyaputtiyānan”ti."
    },
    {
      "id": "an10.96:4.1",
      "pali": "“Puccheyyāma mayaṁ āyasmantaṁ kiñcideva desaṁ, sace āyasmā okāsaṁ karoti pañhassa veyyākaraṇāyā”ti."
    },
    {
      "id": "an10.96:4.2",
      "pali": "“Pucchāvuso, sutvā vedissāmā”ti."
    },
    {
      "id": "an10.96:5.1",
      "pali": "“Kiṁ nu kho, bho, ‘sassato loko, idameva saccaṁ moghamaññan’ti—evaṁdiṭṭhi bhavan”ti?"
    },
    {
      "id": "an10.96:5.2",
      "pali": "“Na kho ahaṁ, āvuso, evaṁdiṭṭhi:"
    },
    {
      "id": "an10.96:5.3",
      "pali": "‘sassato loko, idameva saccaṁ moghamaññan’”ti."
    },
    {
      "id": "an10.96:6.1",
      "pali": "“Kiṁ pana, bho, ‘asassato loko, idameva saccaṁ moghamaññan’ti—evaṁdiṭṭhi bhavan”ti?"
    },
    {
      "id": "an10.96:6.2",
      "pali": "“Na kho ahaṁ, āvuso, evaṁdiṭṭhi:"
    },
    {
      "id": "an10.96:6.3",
      "pali": "‘asassato loko, idameva saccaṁ moghamaññan’”ti."
    },
    {
      "id": "an10.96:7.1",
      "pali": "“Kiṁ nu kho, bho, antavā loko …pe…"
    },
    {
      "id": "an10.96:7.2",
      "pali": "anantavā loko …"
    },
    {
      "id": "an10.96:7.3",
      "pali": "taṁ jīvaṁ taṁ sarīraṁ …"
    },
    {
      "id": "an10.96:7.4",
      "pali": "aññaṁ jīvaṁ aññaṁ sarīraṁ …"
    },
    {
      "id": "an10.96:7.5",
      "pali": "hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:7.6",
      "pali": "na hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:7.7",
      "pali": "hoti ca na ca hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:7.8",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññanti—evaṁdiṭṭhi bhavan”ti?"
    },
    {
      "id": "an10.96:7.9",
      "pali": "“Na kho ahaṁ, āvuso, evaṁdiṭṭhi:"
    },
    {
      "id": "an10.96:7.10",
      "pali": "‘neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan’”ti."
    },
    {
      "id": "an10.96:8.1",
      "pali": "“Tena hi bhavaṁ na jānāti, na passatī”ti?"
    },
    {
      "id": "an10.96:8.2",
      "pali": "“Na kho ahaṁ, āvuso, na jānāmi na passāmi."
    },
    {
      "id": "an10.96:8.3",
      "pali": "Jānāmahaṁ, āvuso, passāmī”ti."
    },
    {
      "id": "an10.96:9.1",
      "pali": "“‘Kiṁ nu kho, bho, sassato loko, idameva saccaṁ moghamaññanti—"
    },
    {
      "id": "an10.96:9.2",
      "pali": "evaṁdiṭṭhi bhavan’ti, iti puṭṭho samāno:"
    },
    {
      "id": "an10.96:9.3",
      "pali": "‘na kho ahaṁ, āvuso, evaṁdiṭṭhi—"
    },
    {
      "id": "an10.96:9.4",
      "pali": "sassato loko, idameva saccaṁ moghamaññan’ti vadesi."
    },
    {
      "id": "an10.96:10.1",
      "pali": "‘Kiṁ pana, bho, asassato loko, idameva saccaṁ moghamaññanti—"
    },
    {
      "id": "an10.96:10.2",
      "pali": "evaṁdiṭṭhi bhavan’ti, iti puṭṭho samāno:"
    },
    {
      "id": "an10.96:10.3",
      "pali": "‘na kho ahaṁ, āvuso, evaṁdiṭṭhi—"
    },
    {
      "id": "an10.96:10.4",
      "pali": "asassato loko, idameva saccaṁ moghamaññan’ti vadesi."
    },
    {
      "id": "an10.96:11.1",
      "pali": "Kiṁ nu kho, bho, antavā loko …pe…"
    },
    {
      "id": "an10.96:11.2",
      "pali": "anantavā loko …"
    },
    {
      "id": "an10.96:11.3",
      "pali": "taṁ jīvaṁ taṁ sarīraṁ …"
    },
    {
      "id": "an10.96:11.4",
      "pali": "aññaṁ jīvaṁ aññaṁ sarīraṁ …"
    },
    {
      "id": "an10.96:11.5",
      "pali": "hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:11.6",
      "pali": "na hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:11.7",
      "pali": "hoti ca na ca hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:11.8",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññanti—"
    },
    {
      "id": "an10.96:11.9",
      "pali": "evaṁdiṭṭhi bhavanti, iti puṭṭho samāno:"
    },
    {
      "id": "an10.96:11.10",
      "pali": "‘na kho ahaṁ, āvuso, evaṁdiṭṭhi—"
    },
    {
      "id": "an10.96:11.11",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan’ti vadesi."
    },
    {
      "id": "an10.96:12.1",
      "pali": "‘Tena hi bhavaṁ na jānāti na passatī’ti, iti puṭṭho samāno:"
    },
    {
      "id": "an10.96:12.2",
      "pali": "‘na kho ahaṁ, āvuso, na jānāmi na passāmi."
    },
    {
      "id": "an10.96:12.3",
      "pali": "Jānāmahaṁ, āvuso, passāmī’ti vadesi."
    },
    {
      "id": "an10.96:12.4",
      "pali": "Yathā kathaṁ panāvuso, imassa bhāsitassa attho daṭṭhabbo”ti?"
    },
    {
      "id": "an10.96:13.1",
      "pali": "“‘Sassato loko, idameva saccaṁ moghamaññan’ti kho, āvuso, diṭṭhigatametaṁ."
    },
    {
      "id": "an10.96:13.2",
      "pali": "‘Asassato loko, idameva saccaṁ moghamaññan’ti kho, āvuso, diṭṭhigatametaṁ."
    },
    {
      "id": "an10.96:13.3",
      "pali": "Antavā loko …pe…"
    },
    {
      "id": "an10.96:13.4",
      "pali": "anantavā loko …"
    },
    {
      "id": "an10.96:13.5",
      "pali": "taṁ jīvaṁ taṁ sarīraṁ …"
    },
    {
      "id": "an10.96:13.6",
      "pali": "aññaṁ jīvaṁ aññaṁ sarīraṁ …"
    },
    {
      "id": "an10.96:13.7",
      "pali": "hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:13.8",
      "pali": "na hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:13.9",
      "pali": "hoti ca na ca hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "an10.96:13.10",
      "pali": "‘neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan’ti kho, āvuso, diṭṭhigatametaṁ."
    },
    {
      "id": "an10.96:14.1",
      "pali": "Yāvatā, āvuso, diṭṭhi yāvatā diṭṭhiṭṭhānaṁ diṭṭhiadhiṭṭhānaṁ diṭṭhipariyuṭṭhānaṁ diṭṭhisamuṭṭhānaṁ diṭṭhisamugghāto, tamahaṁ jānāmi tamahaṁ passāmi."
    },
    {
      "id": "an10.96:14.2",
      "pali": "Tamahaṁ jānanto tamahaṁ passanto kyāhaṁ vakkhāmi:"
    },
    {
      "id": "an10.96:14.3",
      "pali": "‘na jānāmi na passāmī’ti?"
    },
    {
      "id": "an10.96:14.4",
      "pali": "Jānāmahaṁ, āvuso, passāmī”ti."
    },
    {
      "id": "an10.96:15.1",
      "pali": "“Ko nāmo āyasmā, kathañca panāyasmantaṁ sabrahmacārī jānantī”ti?"
    },
    {
      "id": "an10.96:15.2",
      "pali": "“‘Ānando’ti kho me, āvuso, nāmaṁ."
    },
    {
      "id": "an10.96:15.3",
      "pali": "‘Ānando’ti ca pana maṁ sabrahmacārī jānantī”ti."
    },
    {
      "id": "an10.96:15.4",
      "pali": "“Mahācariyena vata kira, bho, saddhiṁ mantayamānā na jānimha:"
    },
    {
      "id": "an10.96:15.5",
      "pali": "‘āyasmā ānando’ti."
    },
    {
      "id": "an10.96:15.6",
      "pali": "Sace hi mayaṁ jāneyyāma:"
    },
    {
      "id": "an10.96:15.7",
      "pali": "‘ayaṁ āyasmā ānando’ti, ettakampi no nappaṭibhāyeyya."
    },
    {
      "id": "an10.96:15.8",
      "pali": "Khamatu ca me āyasmā ānando”ti."
    },
    {
      "id": "an10.96:15.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
