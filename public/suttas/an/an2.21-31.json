{
  "uid": "an2.21-31",
  "title": "an2.21-31",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.21:1.1",
      "pali": "“Dveme, bhikkhave, bālā."
    },
    {
      "id": "an2.21:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.21:1.3",
      "pali": "Yo ca accayaṁ accayato na passati, yo ca accayaṁ desentassa yathādhammaṁ nappaṭiggaṇhāti."
    },
    {
      "id": "an2.21:1.4",
      "pali": "Ime kho, bhikkhave, dve bālāti."
    },
    {
      "id": "an2.21:2.1",
      "pali": "Dveme, bhikkhave, paṇḍitā."
    },
    {
      "id": "an2.21:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.21:2.3",
      "pali": "Yo ca accayaṁ accayato passati, yo ca accayaṁ desentassa yathādhammaṁ paṭiggaṇhāti."
    },
    {
      "id": "an2.21:2.4",
      "pali": "Ime kho, bhikkhave, dve paṇḍitā”ti."
    },
    {
      "id": "an2.22:1.1",
      "pali": "“Dveme, bhikkhave, tathāgataṁ abbhācikkhanti."
    },
    {
      "id": "an2.22:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.22:1.3",
      "pali": "Duṭṭho vā dosantaro, saddho vā duggahitena."
    },
    {
      "id": "an2.22:1.4",
      "pali": "Ime kho, bhikkhave, dve tathāgataṁ abbhācikkhantī”ti."
    },
    {
      "id": "an2.23:1.1",
      "pali": "“Dveme, bhikkhave, tathāgataṁ abbhācikkhanti."
    },
    {
      "id": "an2.23:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.23:1.3",
      "pali": "Yo ca abhāsitaṁ alapitaṁ tathāgatena bhāsitaṁ lapitaṁ tathāgatenāti dīpeti, yo ca bhāsitaṁ lapitaṁ tathāgatena abhāsitaṁ alapitaṁ tathāgatenāti dīpeti."
    },
    {
      "id": "an2.23:1.4",
      "pali": "Ime kho, bhikkhave, dve tathāgataṁ abbhācikkhantīti."
    },
    {
      "id": "an2.23:2.1",
      "pali": "Dveme, bhikkhave, tathāgataṁ nābbhācikkhanti."
    },
    {
      "id": "an2.23:2.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.23:2.3",
      "pali": "Yo ca abhāsitaṁ alapitaṁ tathāgatena abhāsitaṁ alapitaṁ tathāgatenāti dīpeti, yo ca bhāsitaṁ lapitaṁ tathāgatena bhāsitaṁ lapitaṁ tathāgatenāti dīpeti."
    },
    {
      "id": "an2.23:2.4",
      "pali": "Ime kho, bhikkhave, dve tathāgataṁ nābbhācikkhantī”ti."
    },
    {
      "id": "an2.24:1.1",
      "pali": "“Dveme, bhikkhave, tathāgataṁ abbhācikkhanti."
    },
    {
      "id": "an2.24:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.24:1.3",
      "pali": "Yo ca neyyatthaṁ suttantaṁ nītattho suttantoti dīpeti, yo ca nītatthaṁ suttantaṁ neyyattho suttantoti dīpeti."
    },
    {
      "id": "an2.24:1.4",
      "pali": "Ime kho, bhikkhave, dve tathāgataṁ abbhācikkhantī”ti."
    },
    {
      "id": "an2.25:1.1",
      "pali": "“Dveme, bhikkhave, tathāgataṁ nābbhācikkhanti."
    },
    {
      "id": "an2.25:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.25:1.3",
      "pali": "Yo ca neyyatthaṁ suttantaṁ neyyattho suttantoti dīpeti, yo ca nītatthaṁ suttantaṁ nītattho suttantoti dīpeti."
    },
    {
      "id": "an2.25:1.4",
      "pali": "Ime kho, bhikkhave, dve tathāgataṁ nābbhācikkhantī”ti."
    },
    {
      "id": "an2.26:1.1",
      "pali": "“Paṭicchannakammantassa, bhikkhave, dvinnaṁ gatīnaṁ aññatarā gati pāṭikaṅkhā—"
    },
    {
      "id": "an2.26:1.2",
      "pali": "nirayo vā tiracchānayoni vāti."
    },
    {
      "id": "an2.26:2.1",
      "pali": "Appaṭicchannakammantassa, bhikkhave, dvinnaṁ gatīnaṁ aññatarā gati pāṭikaṅkhā—"
    },
    {
      "id": "an2.26:2.2",
      "pali": "devā vā manussā vā”ti."
    },
    {
      "id": "an2.27:1.1",
      "pali": "“Micchādiṭṭhikassa, bhikkhave, dvinnaṁ gatīnaṁ aññatarā gati pāṭikaṅkhā—"
    },
    {
      "id": "an2.27:1.2",
      "pali": "nirayo vā tiracchānayoni vā”ti."
    },
    {
      "id": "an2.28:1.1",
      "pali": "“Sammādiṭṭhikassa, bhikkhave, dvinnaṁ gatīnaṁ aññatarā gati pāṭikaṅkhā—"
    },
    {
      "id": "an2.28:1.2",
      "pali": "devā vā manussā vā”ti."
    },
    {
      "id": "an2.29:1.1",
      "pali": "“Dussīlassa, bhikkhave, dve paṭiggāhā—"
    },
    {
      "id": "an2.29:1.2",
      "pali": "nirayo vā tiracchānayoni vā."
    },
    {
      "id": "an2.29:2.1",
      "pali": "Sīlavato, bhikkhave, dve paṭiggāhā—"
    },
    {
      "id": "an2.29:2.2",
      "pali": "devā vā manussā vā”ti."
    },
    {
      "id": "an2.30:1.1",
      "pali": "“Dvāhaṁ, bhikkhave, atthavase sampassamāno araññavanapatthāni pantāni senāsanāni paṭisevāmi."
    },
    {
      "id": "an2.30:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.30:1.3",
      "pali": "Attano ca diṭṭhadhammasukhavihāraṁ sampassamāno, pacchimañca janataṁ anukampamāno."
    },
    {
      "id": "an2.30:1.4",
      "pali": "Ime kho ahaṁ, bhikkhave, dve atthavase sampassamāno araññavanapatthāni pantāni senāsanāni paṭisevāmī”ti."
    },
    {
      "id": "an2.31:1.1",
      "pali": "“Dve me, bhikkhave, dhammā vijjābhāgiyā."
    },
    {
      "id": "an2.31:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.31:1.3",
      "pali": "Samatho ca vipassanā ca."
    },
    {
      "id": "an2.31:1.4",
      "pali": "Samatho, bhikkhave, bhāvito kamatthamanubhoti?"
    },
    {
      "id": "an2.31:1.5",
      "pali": "Cittaṁ bhāvīyati."
    },
    {
      "id": "an2.31:1.6",
      "pali": "Cittaṁ bhāvitaṁ kamatthamanubhoti?"
    },
    {
      "id": "an2.31:1.7",
      "pali": "Yo rāgo so pahīyati."
    },
    {
      "id": "an2.31:1.8",
      "pali": "Vipassanā, bhikkhave, bhāvitā kamatthamanubhoti?"
    },
    {
      "id": "an2.31:1.9",
      "pali": "Paññā bhāvīyati."
    },
    {
      "id": "an2.31:1.10",
      "pali": "Paññā bhāvitā kamatthamanubhoti?"
    },
    {
      "id": "an2.31:1.11",
      "pali": "Yā avijjā sā pahīyati."
    },
    {
      "id": "an2.31:1.12",
      "pali": "Rāgupakkiliṭṭhaṁ vā, bhikkhave, cittaṁ na vimuccati, avijjupakkiliṭṭhā vā paññā na bhāvīyati."
    },
    {
      "id": "an2.31:1.13",
      "pali": "Iti kho, bhikkhave, rāgavirāgā cetovimutti, avijjāvirāgā paññāvimuttī”ti."
    },
    {
      "id": "an2.31:1.14",
      "pali": "Bālavaggo tatiyo."
    }
  ]
}
