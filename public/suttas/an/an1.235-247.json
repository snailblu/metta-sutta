{
  "uid": "an1.235-247",
  "title": "an1.235-247",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.235:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvikānaṁ bhikkhunīnaṁ rattaññūnaṁ yadidaṁ mahāpajāpatigotamī."
    },
    {
      "id": "an1.236:1.1",
      "pali": "… Mahāpaññānaṁ yadidaṁ khemā."
    },
    {
      "id": "an1.237:1.1",
      "pali": "… Iddhimantīnaṁ yadidaṁ uppalavaṇṇā."
    },
    {
      "id": "an1.238:1.1",
      "pali": "… Vinayadharānaṁ yadidaṁ paṭācārā."
    },
    {
      "id": "an1.239:1.1",
      "pali": "… Dhammakathikānaṁ yadidaṁ dhammadinnā."
    },
    {
      "id": "an1.240:1.1",
      "pali": "… Jhāyīnaṁ yadidaṁ nandā."
    },
    {
      "id": "an1.241:1.1",
      "pali": "… Āraddhavīriyānaṁ yadidaṁ soṇā."
    },
    {
      "id": "an1.242:1.1",
      "pali": "… Dibbacakkhukānaṁ yadidaṁ bakulā."
    },
    {
      "id": "an1.243:1.1",
      "pali": "… Khippābhiññānaṁ yadidaṁ bhaddā kuṇḍalakesā."
    },
    {
      "id": "an1.244:1.1",
      "pali": "… Pubbenivāsaṁ anussarantīnaṁ yadidaṁ bhaddā kāpilānī."
    },
    {
      "id": "an1.245:1.1",
      "pali": "… Mahābhiññāpattānaṁ yadidaṁ bhaddakaccānā."
    },
    {
      "id": "an1.246:1.1",
      "pali": "… Lūkhacīvaradharānaṁ yadidaṁ kisāgotamī."
    },
    {
      "id": "an1.247:1.1",
      "pali": "… Saddhādhimuttānaṁ yadidaṁ siṅgālakamātā”ti."
    },
    {
      "id": "an1.247:1.2",
      "pali": "Vaggo pañcamo."
    }
  ]
}
