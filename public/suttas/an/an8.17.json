{
  "uid": "an8.17",
  "title": "Paṭhamabandhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.17:1.1",
      "pali": "“Aṭṭhahi, bhikkhave, ākārehi itthī purisaṁ bandhati."
    },
    {
      "id": "an8.17:1.2",
      "pali": "Katamehi aṭṭhahi?"
    },
    {
      "id": "an8.17:1.3",
      "pali": "Ruṇṇena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.4",
      "pali": "hasitena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.5",
      "pali": "bhaṇitena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.6",
      "pali": "ākappena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.7",
      "pali": "vanabhaṅgena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.8",
      "pali": "gandhena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.9",
      "pali": "rasena, bhikkhave, itthī purisaṁ bandhati;"
    },
    {
      "id": "an8.17:1.10",
      "pali": "phassena, bhikkhave, itthī purisaṁ bandhati."
    },
    {
      "id": "an8.17:1.11",
      "pali": "Imehi kho, bhikkhave, aṭṭhahākārehi itthī purisaṁ bandhati."
    },
    {
      "id": "an8.17:1.12",
      "pali": "Te, bhikkhave, sattā subaddhā, ye phassena baddhā”ti."
    },
    {
      "id": "an8.17:1.13",
      "pali": "Sattamaṁ."
    }
  ]
}
