{
  "uid": "an8.7",
  "title": "Devadattavipattisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.7:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati gijjhakūṭe pabbate acirapakkante devadatte."
    },
    {
      "id": "an8.7:1.2",
      "pali": "Tatra bhagavā devadattaṁ ārabbha bhikkhū āmantesi:"
    },
    {
      "id": "an8.7:1.3",
      "pali": "“sādhu, bhikkhave, bhikkhu kālena kālaṁ attavipattiṁ paccavekkhitā hoti."
    },
    {
      "id": "an8.7:1.4",
      "pali": "Sādhu, bhikkhave, bhikkhu kālena kālaṁ paravipattiṁ paccavekkhitā hoti."
    },
    {
      "id": "an8.7:1.5",
      "pali": "Sādhu, bhikkhave, bhikkhu kālena kālaṁ attasampattiṁ paccavekkhitā hoti."
    },
    {
      "id": "an8.7:1.6",
      "pali": "Sādhu, bhikkhave, bhikkhu kālena kālaṁ parasampattiṁ paccavekkhitā hoti."
    },
    {
      "id": "an8.7:1.7",
      "pali": "Aṭṭhahi, bhikkhave, asaddhammehi abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "an8.7:2.1",
      "pali": "Katamehi aṭṭhahi?"
    },
    {
      "id": "an8.7:2.2",
      "pali": "Lābhena hi, bhikkhave, abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "an8.7:2.3",
      "pali": "Alābhena, bhikkhave …pe…"
    },
    {
      "id": "an8.7:2.4",
      "pali": "yasena, bhikkhave …"
    },
    {
      "id": "an8.7:2.5",
      "pali": "ayasena, bhikkhave …"
    },
    {
      "id": "an8.7:2.6",
      "pali": "sakkārena, bhikkhave …"
    },
    {
      "id": "an8.7:2.7",
      "pali": "asakkārena, bhikkhave …"
    },
    {
      "id": "an8.7:2.8",
      "pali": "pāpicchatāya, bhikkhave …"
    },
    {
      "id": "an8.7:2.9",
      "pali": "pāpamittatāya, bhikkhave, abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "an8.7:2.10",
      "pali": "Imehi kho, bhikkhave, aṭṭhahi asaddhammehi abhibhūto pariyādinnacitto devadatto āpāyiko nerayiko kappaṭṭho atekiccho."
    },
    {
      "id": "an8.7:3.1",
      "pali": "Sādhu, bhikkhave, bhikkhu uppannaṁ lābhaṁ abhibhuyya abhibhuyya vihareyya,"
    },
    {
      "id": "an8.7:3.2",
      "pali": "uppannaṁ alābhaṁ …pe…"
    },
    {
      "id": "an8.7:3.3",
      "pali": "uppannaṁ yasaṁ …"
    },
    {
      "id": "an8.7:3.4",
      "pali": "uppannaṁ ayasaṁ …"
    },
    {
      "id": "an8.7:3.5",
      "pali": "uppannaṁ sakkāraṁ …"
    },
    {
      "id": "an8.7:3.6",
      "pali": "uppannaṁ asakkāraṁ …"
    },
    {
      "id": "an8.7:3.7",
      "pali": "uppannaṁ pāpicchataṁ …"
    },
    {
      "id": "an8.7:3.8",
      "pali": "uppannaṁ pāpamittataṁ abhibhuyya abhibhuyya vihareyya."
    },
    {
      "id": "an8.7:4.1",
      "pali": "Kiñca, bhikkhave, bhikkhu atthavasaṁ paṭicca uppannaṁ lābhaṁ abhibhuyya abhibhuyya vihareyya,"
    },
    {
      "id": "an8.7:4.2",
      "pali": "uppannaṁ alābhaṁ …pe…"
    },
    {
      "id": "an8.7:4.3",
      "pali": "uppannaṁ yasaṁ …"
    },
    {
      "id": "an8.7:4.4",
      "pali": "uppannaṁ ayasaṁ …"
    },
    {
      "id": "an8.7:4.5",
      "pali": "uppannaṁ sakkāraṁ …"
    },
    {
      "id": "an8.7:4.6",
      "pali": "uppannaṁ asakkāraṁ …"
    },
    {
      "id": "an8.7:4.7",
      "pali": "uppannaṁ pāpicchataṁ …"
    },
    {
      "id": "an8.7:4.8",
      "pali": "uppannaṁ pāpamittataṁ abhibhuyya abhibhuyya vihareyya?"
    },
    {
      "id": "an8.7:5.1",
      "pali": "Yaṁ hissa, bhikkhave, uppannaṁ lābhaṁ anabhibhuyya viharato uppajjeyyuṁ āsavā vighātapariḷāhā, uppannaṁ lābhaṁ abhibhuyya viharato evaṁsa te āsavā vighātapariḷāhā na honti."
    },
    {
      "id": "an8.7:5.2",
      "pali": "Yaṁ hissa, bhikkhave, uppannaṁ alābhaṁ …pe…"
    },
    {
      "id": "an8.7:5.3",
      "pali": "uppannaṁ yasaṁ …"
    },
    {
      "id": "an8.7:5.4",
      "pali": "uppannaṁ ayasaṁ …"
    },
    {
      "id": "an8.7:5.5",
      "pali": "uppannaṁ sakkāraṁ …"
    },
    {
      "id": "an8.7:5.6",
      "pali": "uppannaṁ asakkāraṁ …"
    },
    {
      "id": "an8.7:5.7",
      "pali": "uppannaṁ pāpicchataṁ …"
    },
    {
      "id": "an8.7:5.8",
      "pali": "uppannaṁ pāpamittataṁ anabhibhuyya viharato uppajjeyyuṁ āsavā vighātapariḷāhā, uppannaṁ pāpamittataṁ abhibhuyya viharato evaṁsa te āsavā vighātapariḷāhā na honti."
    },
    {
      "id": "an8.7:5.9",
      "pali": "Idaṁ kho, bhikkhave, bhikkhu atthavasaṁ paṭicca uppannaṁ lābhaṁ abhibhuyya abhibhuyya vihareyya,"
    },
    {
      "id": "an8.7:5.10",
      "pali": "uppannaṁ alābhaṁ …pe…"
    },
    {
      "id": "an8.7:5.11",
      "pali": "uppannaṁ yasaṁ …"
    },
    {
      "id": "an8.7:5.12",
      "pali": "uppannaṁ ayasaṁ …"
    },
    {
      "id": "an8.7:5.13",
      "pali": "uppannaṁ sakkāraṁ …"
    },
    {
      "id": "an8.7:5.14",
      "pali": "uppannaṁ asakkāraṁ …"
    },
    {
      "id": "an8.7:5.15",
      "pali": "uppannaṁ pāpicchataṁ …"
    },
    {
      "id": "an8.7:5.16",
      "pali": "uppannaṁ pāpamittataṁ abhibhuyya abhibhuyya vihareyya."
    },
    {
      "id": "an8.7:6.1",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "an8.7:6.2",
      "pali": "‘uppannaṁ lābhaṁ abhibhuyya abhibhuyya viharissāma,"
    },
    {
      "id": "an8.7:6.3",
      "pali": "uppannaṁ alābhaṁ …pe…"
    },
    {
      "id": "an8.7:6.4",
      "pali": "uppannaṁ yasaṁ …"
    },
    {
      "id": "an8.7:6.5",
      "pali": "uppannaṁ ayasaṁ …"
    },
    {
      "id": "an8.7:6.6",
      "pali": "uppannaṁ sakkāraṁ …"
    },
    {
      "id": "an8.7:6.7",
      "pali": "uppannaṁ asakkāraṁ …"
    },
    {
      "id": "an8.7:6.8",
      "pali": "uppannaṁ pāpicchataṁ …"
    },
    {
      "id": "an8.7:6.9",
      "pali": "uppannaṁ pāpamittataṁ abhibhuyya abhibhuyya viharissāmā’ti."
    },
    {
      "id": "an8.7:6.10",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "an8.7:6.11",
      "pali": "Sattamaṁ."
    }
  ]
}
