{
  "uid": "an4.154",
  "title": "Satibalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.154:1.1",
      "pali": "“Cattārimāni, bhikkhave, balāni."
    },
    {
      "id": "an4.154:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.154:1.3",
      "pali": "Satibalaṁ, samādhibalaṁ, anavajjabalaṁ, saṅgahabalaṁ—"
    },
    {
      "id": "an4.154:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri balānī”ti."
    },
    {
      "id": "an4.154:1.5",
      "pali": "Catutthaṁ."
    }
  ]
}
