{
  "uid": "an5.36",
  "title": "Kāladānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.36:1.1",
      "pali": "“Pañcimāni, bhikkhave, kāladānāni."
    },
    {
      "id": "an5.36:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.36:1.3",
      "pali": "Āgantukassa dānaṁ deti;"
    },
    {
      "id": "an5.36:1.4",
      "pali": "gamikassa dānaṁ deti;"
    },
    {
      "id": "an5.36:1.5",
      "pali": "gilānassa dānaṁ deti;"
    },
    {
      "id": "an5.36:1.6",
      "pali": "dubbhikkhe dānaṁ deti;"
    },
    {
      "id": "an5.36:1.7",
      "pali": "yāni tāni navasassāni navaphalāni tāni paṭhamaṁ sīlavantesu patiṭṭhāpeti."
    },
    {
      "id": "an5.36:1.8",
      "pali": "Imāni kho, bhikkhave, pañca kāladānānīti."
    },
    {
      "id": "an5.36:2.1",
      "pali": "Kāle dadanti sappaññā,"
    },
    {
      "id": "an5.36:2.2",
      "pali": "vadaññū vītamaccharā;"
    },
    {
      "id": "an5.36:2.3",
      "pali": "Kālena dinnaṁ ariyesu,"
    },
    {
      "id": "an5.36:2.4",
      "pali": "ujubhūtesu tādisu."
    },
    {
      "id": "an5.36:3.1",
      "pali": "Vippasannamanā tassa,"
    },
    {
      "id": "an5.36:3.2",
      "pali": "vipulā hoti dakkhiṇā;"
    },
    {
      "id": "an5.36:3.3",
      "pali": "Ye tattha anumodanti,"
    },
    {
      "id": "an5.36:3.4",
      "pali": "veyyāvaccaṁ karonti vā;"
    },
    {
      "id": "an5.36:3.5",
      "pali": "Na tena dakkhiṇā ūnā,"
    },
    {
      "id": "an5.36:3.6",
      "pali": "tepi puññassa bhāgino."
    },
    {
      "id": "an5.36:4.1",
      "pali": "Tasmā dade appaṭivānacitto,"
    },
    {
      "id": "an5.36:4.2",
      "pali": "Yattha dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "an5.36:4.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "an5.36:4.4",
      "pali": "Patiṭṭhā honti pāṇinan”ti."
    },
    {
      "id": "an5.36:4.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
