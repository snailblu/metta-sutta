{
  "uid": "an11.6",
  "title": "Byasanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an11.6:1.1",
      "pali": "“Yo so, bhikkhave, bhikkhu akkosako paribhāsako ariyūpavādo sabrahmacārīnaṁ, ṭhānametaṁ avakāso yaṁ so ekādasannaṁ byasanānaṁ aññataraṁ byasanaṁ nigaccheyya."
    },
    {
      "id": "an11.6:2.1",
      "pali": "Katamesaṁ ekādasannaṁ?"
    },
    {
      "id": "an11.6:2.2",
      "pali": "Anadhigataṁ nādhigacchati,"
    },
    {
      "id": "an11.6:2.3",
      "pali": "adhigatā parihāyati,"
    },
    {
      "id": "an11.6:2.4",
      "pali": "saddhammassa na vodāyanti,"
    },
    {
      "id": "an11.6:2.5",
      "pali": "saddhammesu vā adhimāniko hoti,"
    },
    {
      "id": "an11.6:2.6",
      "pali": "anabhirato vā brahmacariyaṁ carati,"
    },
    {
      "id": "an11.6:2.7",
      "pali": "aññataraṁ vā saṅkiliṭṭhaṁ āpattiṁ āpajjati,"
    },
    {
      "id": "an11.6:2.8",
      "pali": "sikkhaṁ vā paccakkhāya hīnāyāvattati,"
    },
    {
      "id": "an11.6:2.9",
      "pali": "gāḷhaṁ vā rogātaṅkaṁ phusati,"
    },
    {
      "id": "an11.6:2.10",
      "pali": "ummādaṁ vā pāpuṇāti cittakkhepaṁ vā,"
    },
    {
      "id": "an11.6:2.11",
      "pali": "sammūḷho kālaṁ karoti,"
    },
    {
      "id": "an11.6:2.12",
      "pali": "kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati—"
    },
    {
      "id": "an11.6:2.13",
      "pali": "yo so, bhikkhave, bhikkhu akkosako paribhāsako ariyūpavādo sabrahmacārīnaṁ, ṭhānametaṁ avakāso yaṁ so imesaṁ ekādasannaṁ byasanānaṁ aññataraṁ byasanaṁ nigaccheyya."
    },
    {
      "id": "an11.6:3.1",
      "pali": "Yo so, bhikkhave, bhikkhu akkosako paribhāsako ariyūpavādo sabrahmacārīnaṁ, aṭṭhānametaṁ anavakāso yaṁ so ekādasannaṁ byasanānaṁ aññataraṁ byasanaṁ na nigaccheyya."
    },
    {
      "id": "an11.6:4.1",
      "pali": "Katamesaṁ ekādasannaṁ?"
    },
    {
      "id": "an11.6:4.2",
      "pali": "Anadhigataṁ nādhigacchati,"
    },
    {
      "id": "an11.6:4.3",
      "pali": "adhigatā parihāyati,"
    },
    {
      "id": "an11.6:4.4",
      "pali": "saddhammassa na vodāyanti,"
    },
    {
      "id": "an11.6:4.5",
      "pali": "saddhammesu vā adhimāniko hoti,"
    },
    {
      "id": "an11.6:4.6",
      "pali": "anabhirato vā brahmacariyaṁ carati,"
    },
    {
      "id": "an11.6:4.7",
      "pali": "aññataraṁ vā saṅkiliṭṭhaṁ āpattiṁ āpajjati,"
    },
    {
      "id": "an11.6:4.8",
      "pali": "sikkhaṁ vā paccakkhāya hīnāyāvattati,"
    },
    {
      "id": "an11.6:4.9",
      "pali": "gāḷhaṁ vā rogātaṅkaṁ phusati,"
    },
    {
      "id": "an11.6:4.10",
      "pali": "ummādaṁ vā pāpuṇāti cittakkhepaṁ vā,"
    },
    {
      "id": "an11.6:4.11",
      "pali": "sammūḷho kālaṁ karoti,"
    },
    {
      "id": "an11.6:4.12",
      "pali": "kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati—"
    },
    {
      "id": "an11.6:4.13",
      "pali": "yo so, bhikkhave, bhikkhu akkosako paribhāsako ariyūpavādo sabrahmacārīnaṁ, aṭṭhānametaṁ anavakāso yaṁ so imesaṁ ekādasannaṁ byasanānaṁ aññataraṁ byasanaṁ na nigaccheyyā”ti."
    },
    {
      "id": "an11.6:4.14",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
