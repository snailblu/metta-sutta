{
  "uid": "an4.249",
  "title": "Bahukārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.249:1.1",
      "pali": "“Cattārome, bhikkhave, dhammā manussabhūtassa bahukārā honti."
    },
    {
      "id": "an4.249:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.249:1.3",
      "pali": "Sappurisasaṁsevo, saddhammasavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—"
    },
    {
      "id": "an4.249:1.4",
      "pali": "Ime kho, bhikkhave, cattāro dhammā manussabhūtassa bahukārā hontī”ti."
    },
    {
      "id": "an4.249:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
