{
  "uid": "an7.93",
  "title": "Asaddhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.93:1.1",
      "pali": "“Sattime, bhikkhave, asaddhammā."
    },
    {
      "id": "an7.93:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.93:1.3",
      "pali": "Assaddho hoti, ahiriko hoti, anottappī hoti, appassuto hoti, kusīto hoti, muṭṭhassati hoti, duppañño hoti."
    },
    {
      "id": "an7.93:1.4",
      "pali": "Ime kho, bhikkhave, satta asaddhammā”ti."
    },
    {
      "id": "an7.93:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
