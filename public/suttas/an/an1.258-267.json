{
  "uid": "an1.258-267",
  "title": "an1.258-267",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.258:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvikānaṁ upāsikānaṁ paṭhamaṁ saraṇaṁ gacchantīnaṁ yadidaṁ sujātā seniyadhītā."
    },
    {
      "id": "an1.259:1.1",
      "pali": "… Dāyikānaṁ yadidaṁ visākhā migāramātā."
    },
    {
      "id": "an1.260:1.1",
      "pali": "… Bahussutānaṁ yadidaṁ khujjuttarā."
    },
    {
      "id": "an1.261:1.1",
      "pali": "… Mettāvihārīnaṁ yadidaṁ sāmāvatī."
    },
    {
      "id": "an1.262:1.1",
      "pali": "… Jhāyīnaṁ yadidaṁ uttarānandamātā."
    },
    {
      "id": "an1.263:1.1",
      "pali": "… Paṇītadāyikānaṁ yadidaṁ suppavāsā koliyadhītā."
    },
    {
      "id": "an1.264:1.1",
      "pali": "… Gilānupaṭṭhākīnaṁ yadidaṁ suppiyā upāsikā."
    },
    {
      "id": "an1.265:1.1",
      "pali": "… Aveccappasannānaṁ yadidaṁ kātiyānī."
    },
    {
      "id": "an1.266:1.1",
      "pali": "… Vissāsikānaṁ yadidaṁ nakulamātā gahapatānī."
    },
    {
      "id": "an1.267:1.1",
      "pali": "… Anussavappasannānaṁ yadidaṁ kāḷī upāsikā kuraragharikā”ti."
    },
    {
      "id": "an1.267:1.2",
      "pali": "vaggo sattamo."
    },
    {
      "id": "an1.267:1.3",
      "pali": "(Etadaggavaggo niṭṭhito.)"
    }
  ]
}
