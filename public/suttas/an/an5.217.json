{
  "uid": "an5.217",
  "title": "Paṭhamaapāsādikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.217:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā apāsādike."
    },
    {
      "id": "an5.217:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.217:1.3",
      "pali": "Attāpi attānaṁ upavadati,"
    },
    {
      "id": "an5.217:1.4",
      "pali": "anuvicca viññū garahanti,"
    },
    {
      "id": "an5.217:1.5",
      "pali": "pāpako kittisaddo abbhuggacchati,"
    },
    {
      "id": "an5.217:1.6",
      "pali": "sammūḷho kālaṁ karoti,"
    },
    {
      "id": "an5.217:1.7",
      "pali": "kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati."
    },
    {
      "id": "an5.217:1.8",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā apāsādike."
    },
    {
      "id": "an5.217:2.1",
      "pali": "Pañcime, bhikkhave, ānisaṁsā pāsādike."
    },
    {
      "id": "an5.217:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.217:2.3",
      "pali": "Attāpi attānaṁ na upavadati,"
    },
    {
      "id": "an5.217:2.4",
      "pali": "anuvicca viññū pasaṁsanti,"
    },
    {
      "id": "an5.217:2.5",
      "pali": "kalyāṇo kittisaddo abbhuggacchati,"
    },
    {
      "id": "an5.217:2.6",
      "pali": "asammūḷho kālaṁ karoti,"
    },
    {
      "id": "an5.217:2.7",
      "pali": "kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati."
    },
    {
      "id": "an5.217:2.8",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā pāsādike”ti."
    },
    {
      "id": "an5.217:2.9",
      "pali": "Sattamaṁ."
    }
  ]
}
