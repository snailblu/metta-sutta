{
  "uid": "an3.134",
  "title": "Parisāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.134:1.1",
      "pali": "“Tisso imā, bhikkhave, parisā."
    },
    {
      "id": "an3.134:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.134:1.3",
      "pali": "Ukkācitavinītā parisā, paṭipucchāvinītā parisā, yāvatāvinītā parisā—"
    },
    {
      "id": "an3.134:1.4",
      "pali": "imā kho, bhikkhave, tisso parisā”ti."
    },
    {
      "id": "an3.134:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
