{
  "uid": "an4.75",
  "title": "Dutiyaaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.75:1.1",
      "pali": "“Cattārimāni, bhikkhave, aggāni."
    },
    {
      "id": "an4.75:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.75:1.3",
      "pali": "Rūpaggaṁ, vedanāggaṁ, saññāggaṁ, bhavaggaṁ—"
    },
    {
      "id": "an4.75:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri aggānī”ti."
    },
    {
      "id": "an4.75:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
