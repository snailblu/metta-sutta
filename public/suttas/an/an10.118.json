{
  "uid": "an10.118",
  "title": "Orimatīrasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.118:1.1",
      "pali": "“Orimañca, bhikkhave, tīraṁ desessāmi pārimañca tīraṁ."
    },
    {
      "id": "an10.118:1.2",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "an10.118:1.3",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "an10.118:1.4",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an10.118:2.1",
      "pali": "“Katamañca, bhikkhave, orimaṁ tīraṁ, katamañca pārimaṁ tīraṁ?"
    },
    {
      "id": "an10.118:2.2",
      "pali": "Micchādiṭṭhi orimaṁ tīraṁ, sammādiṭṭhi pārimaṁ tīraṁ …pe…"
    },
    {
      "id": "an10.118:2.3",
      "pali": "micchāvimutti orimaṁ tīraṁ, sammāvimutti pārimaṁ tīraṁ."
    },
    {
      "id": "an10.118:2.4",
      "pali": "Idaṁ kho, bhikkhave, orimaṁ tīraṁ, idaṁ pārimaṁ tīranti."
    },
    {
      "id": "an10.118:3.1",
      "pali": "Appakā te manussesu,"
    },
    {
      "id": "an10.118:3.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "an10.118:3.3",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "an10.118:3.4",
      "pali": "tīramevānudhāvati."
    },
    {
      "id": "an10.118:4.1",
      "pali": "Ye ca kho sammadakkhāte,"
    },
    {
      "id": "an10.118:4.2",
      "pali": "dhamme dhammānuvattino;"
    },
    {
      "id": "an10.118:4.3",
      "pali": "Te janā pāramessanti,"
    },
    {
      "id": "an10.118:4.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "an10.118:5.1",
      "pali": "Kaṇhaṁ dhammaṁ vippahāya,"
    },
    {
      "id": "an10.118:5.2",
      "pali": "sukkaṁ bhāvetha paṇḍito;"
    },
    {
      "id": "an10.118:5.3",
      "pali": "Okā anokamāgamma,"
    },
    {
      "id": "an10.118:5.4",
      "pali": "viveke yattha dūramaṁ."
    },
    {
      "id": "an10.118:6.1",
      "pali": "Tatrābhiratimiccheyya,"
    },
    {
      "id": "an10.118:6.2",
      "pali": "hitvā kāme akiñcano;"
    },
    {
      "id": "an10.118:6.3",
      "pali": "Pariyodapeyya attānaṁ,"
    },
    {
      "id": "an10.118:6.4",
      "pali": "cittaklesehi paṇḍito."
    },
    {
      "id": "an10.118:7.1",
      "pali": "Yesaṁ sambodhiyaṅgesu,"
    },
    {
      "id": "an10.118:7.2",
      "pali": "sammā cittaṁ subhāvitaṁ;"
    },
    {
      "id": "an10.118:7.3",
      "pali": "Ādānapaṭinissagge,"
    },
    {
      "id": "an10.118:7.4",
      "pali": "anupādāya ye ratā;"
    },
    {
      "id": "an10.118:7.5",
      "pali": "Khīṇāsavā jutimanto,"
    },
    {
      "id": "an10.118:7.6",
      "pali": "te loke parinibbutā”ti."
    },
    {
      "id": "an10.118:7.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
