{
  "uid": "an3.48",
  "title": "Pabbatarājasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.48:1.1",
      "pali": "“Himavantaṁ, bhikkhave, pabbatarājaṁ nissāya mahāsālā tīhi vaḍḍhīhi vaḍḍhanti."
    },
    {
      "id": "an3.48:1.2",
      "pali": "Katamāhi tīhi?"
    },
    {
      "id": "an3.48:1.3",
      "pali": "Sākhāpattapalāsena vaḍḍhanti, tacapapaṭikāya vaḍḍhanti, pheggusārena vaḍḍhanti."
    },
    {
      "id": "an3.48:1.4",
      "pali": "Himavantaṁ, bhikkhave, pabbatarājaṁ nissāya mahāsālā imāhi tīhi vaḍḍhīhi vaḍḍhanti."
    },
    {
      "id": "an3.48:2.1",
      "pali": "Evamevaṁ kho, bhikkhave, saddhaṁ kulapatiṁ nissāya anto jano tīhi vaḍḍhīhi vaḍḍhati."
    },
    {
      "id": "an3.48:2.2",
      "pali": "Katamāhi tīhi?"
    },
    {
      "id": "an3.48:2.3",
      "pali": "Saddhāya vaḍḍhati, sīlena vaḍḍhati, paññāya vaḍḍhati."
    },
    {
      "id": "an3.48:2.4",
      "pali": "Saddhaṁ, bhikkhave, kulapatiṁ nissāya anto jano imāhi tīhi vaḍḍhīhi vaḍḍhatīti."
    },
    {
      "id": "an3.48:3.1",
      "pali": "Yathāpi pabbato selo,"
    },
    {
      "id": "an3.48:3.2",
      "pali": "araññasmiṁ brahāvane;"
    },
    {
      "id": "an3.48:3.3",
      "pali": "Taṁ rukkhā upanissāya,"
    },
    {
      "id": "an3.48:3.4",
      "pali": "vaḍḍhante te vanappatī."
    },
    {
      "id": "an3.48:4.1",
      "pali": "Tatheva sīlasampannaṁ,"
    },
    {
      "id": "an3.48:4.2",
      "pali": "saddhaṁ kulapatiṁ idha;"
    },
    {
      "id": "an3.48:4.3",
      "pali": "Upanissāya vaḍḍhanti,"
    },
    {
      "id": "an3.48:4.4",
      "pali": "puttadārā ca bandhavā;"
    },
    {
      "id": "an3.48:4.5",
      "pali": "Amaccā ñātisaṅghā ca,"
    },
    {
      "id": "an3.48:4.6",
      "pali": "ye cassa anujīvino."
    },
    {
      "id": "an3.48:5.1",
      "pali": "Tyāssa sīlavato sīlaṁ,"
    },
    {
      "id": "an3.48:5.2",
      "pali": "cāgaṁ sucaritāni ca;"
    },
    {
      "id": "an3.48:5.3",
      "pali": "Passamānānukubbanti,"
    },
    {
      "id": "an3.48:5.4",
      "pali": "attamatthaṁ vicakkhaṇā."
    },
    {
      "id": "an3.48:6.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "an3.48:6.2",
      "pali": "maggaṁ sugatigāminaṁ;"
    },
    {
      "id": "an3.48:6.3",
      "pali": "Nandino devalokasmiṁ,"
    },
    {
      "id": "an3.48:6.4",
      "pali": "modanti kāmakāmino”ti."
    },
    {
      "id": "an3.48:6.5",
      "pali": "Navamaṁ."
    }
  ]
}
