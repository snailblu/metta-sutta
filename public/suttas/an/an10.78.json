{
  "uid": "an10.78",
  "title": "Nigaṇṭhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.78:1.1",
      "pali": "“Dasahi, bhikkhave, asaddhammehi samannāgatā nigaṇṭhā."
    },
    {
      "id": "an10.78:1.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.78:1.3",
      "pali": "Assaddhā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.4",
      "pali": "dussīlā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.5",
      "pali": "ahirikā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.6",
      "pali": "anottappino, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.7",
      "pali": "asappurisasambhattino, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.8",
      "pali": "attukkaṁsakaparavambhakā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.9",
      "pali": "sandiṭṭhiparāmāsā ādhānaggāhī duppaṭinissaggino, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.10",
      "pali": "kuhakā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.11",
      "pali": "pāpicchā, bhikkhave, nigaṇṭhā;"
    },
    {
      "id": "an10.78:1.12",
      "pali": "pāpamittā, bhikkhave, nigaṇṭhā—"
    },
    {
      "id": "an10.78:1.13",
      "pali": "imehi kho, bhikkhave, dasahi asaddhammehi samannāgatā nigaṇṭhā”ti."
    },
    {
      "id": "an10.78:1.14",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
