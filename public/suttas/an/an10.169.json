{
  "uid": "an10.169",
  "title": "Saṅgāravasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.169:1.1",
      "pali": "Atha kho saṅgāravo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "an10.169:1.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho saṅgāravo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "an10.169:2.1",
      "pali": "“Kiṁ nu kho, bho gotama, orimaṁ tīraṁ, kiṁ pārimaṁ tīran”ti?"
    },
    {
      "id": "an10.169:2.2",
      "pali": "“Pāṇātipāto kho, brāhmaṇa, orimaṁ tīraṁ, pāṇātipātā veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.3",
      "pali": "Adinnādānaṁ kho, brāhmaṇa, orimaṁ tīraṁ, adinnādānā veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.4",
      "pali": "Kāmesumicchācāro orimaṁ tīraṁ, kāmesumicchācārā veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.5",
      "pali": "Musāvādo orimaṁ tīraṁ, musāvādā veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.6",
      "pali": "Pisuṇā vācā orimaṁ tīraṁ, pisuṇāya vācāya veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.7",
      "pali": "Pharusā vācā orimaṁ tīraṁ, pharusāya vācāya veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.8",
      "pali": "Samphappalāpo orimaṁ tīraṁ, samphappalāpā veramaṇī pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.9",
      "pali": "Abhijjhā orimaṁ tīraṁ, anabhijjhā pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.10",
      "pali": "Byāpādo orimaṁ tīraṁ, abyāpādo pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.11",
      "pali": "Micchādiṭṭhi orimaṁ tīraṁ, sammādiṭṭhi pārimaṁ tīraṁ."
    },
    {
      "id": "an10.169:2.12",
      "pali": "Idaṁ kho, brāhmaṇa, orimaṁ tīraṁ, idaṁ pārimaṁ tīranti."
    },
    {
      "id": "an10.169:3.1",
      "pali": "Appakā te manussesu,"
    },
    {
      "id": "an10.169:3.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "an10.169:3.3",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "an10.169:3.4",
      "pali": "tīramevānudhāvati."
    },
    {
      "id": "an10.169:4.1",
      "pali": "Ye ca kho sammadakkhāte,"
    },
    {
      "id": "an10.169:4.2",
      "pali": "dhamme dhammānuvattino;"
    },
    {
      "id": "an10.169:4.3",
      "pali": "Te janā pāramessanti,"
    },
    {
      "id": "an10.169:4.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "an10.169:5.1",
      "pali": "Kaṇhaṁ dhammaṁ vippahāya,"
    },
    {
      "id": "an10.169:5.2",
      "pali": "Sukkaṁ bhāvetha paṇḍito;"
    },
    {
      "id": "an10.169:5.3",
      "pali": "Okā anokamāgamma,"
    },
    {
      "id": "an10.169:5.4",
      "pali": "Viveke yattha dūramaṁ."
    },
    {
      "id": "an10.169:6.1",
      "pali": "Tatrābhiratimiccheyya,"
    },
    {
      "id": "an10.169:6.2",
      "pali": "hitvā kāme akiñcano;"
    },
    {
      "id": "an10.169:6.3",
      "pali": "Pariyodapeyya attānaṁ,"
    },
    {
      "id": "an10.169:6.4",
      "pali": "cittaklesehi paṇḍito."
    },
    {
      "id": "an10.169:7.1",
      "pali": "Yesaṁ sambodhiyaṅgesu,"
    },
    {
      "id": "an10.169:7.2",
      "pali": "sammā cittaṁ subhāvitaṁ;"
    },
    {
      "id": "an10.169:7.3",
      "pali": "Ādānapaṭinissagge,"
    },
    {
      "id": "an10.169:7.4",
      "pali": "anupādāya ye ratā;"
    },
    {
      "id": "an10.169:7.5",
      "pali": "Khīṇāsavā jutimanto,"
    },
    {
      "id": "an10.169:7.6",
      "pali": "te loke parinibbutā”ti."
    },
    {
      "id": "an10.169:7.7",
      "pali": "Tatiyaṁ."
    }
  ]
}
