{
  "uid": "an10.145",
  "title": "Ariyamaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.145:1.1",
      "pali": "“Ariyamaggañca vo, bhikkhave, dhammaṁ desessāmi anariyamaggañca."
    },
    {
      "id": "an10.145:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.145:1.3",
      "pali": "katamo ca, bhikkhave, anariyo maggo?"
    },
    {
      "id": "an10.145:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.145:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, anariyo maggo."
    },
    {
      "id": "an10.145:1.6",
      "pali": "Katamo ca, bhikkhave, ariyo maggo?"
    },
    {
      "id": "an10.145:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.145:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, ariyo maggo”ti."
    },
    {
      "id": "an10.145:1.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
