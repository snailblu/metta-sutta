{
  "uid": "an7.29",
  "title": "Dutiyaparihānisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.29:1.1",
      "pali": "“Sattime, bhikkhave, dhammā upāsakassa parihānāya saṁvattanti."
    },
    {
      "id": "an7.29:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.29:1.3",
      "pali": "Bhikkhudassanaṁ hāpeti,"
    },
    {
      "id": "an7.29:1.4",
      "pali": "saddhammassavanaṁ pamajjati,"
    },
    {
      "id": "an7.29:1.5",
      "pali": "adhisīle na sikkhati,"
    },
    {
      "id": "an7.29:1.6",
      "pali": "appasādabahulo hoti,"
    },
    {
      "id": "an7.29:1.7",
      "pali": "bhikkhūsu theresu ceva navesu ca majjhimesu ca upārambhacitto dhammaṁ suṇāti randhagavesī,"
    },
    {
      "id": "an7.29:1.8",
      "pali": "ito bahiddhā dakkhiṇeyyaṁ gavesati,"
    },
    {
      "id": "an7.29:1.9",
      "pali": "tattha ca pubbakāraṁ karoti."
    },
    {
      "id": "an7.29:1.10",
      "pali": "Ime kho, bhikkhave, satta dhammā upāsakassa parihānāya saṁvattanti."
    },
    {
      "id": "an7.29:2.1",
      "pali": "Sattime, bhikkhave, dhammā upāsakassa aparihānāya saṁvattanti."
    },
    {
      "id": "an7.29:2.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.29:2.3",
      "pali": "Bhikkhudassanaṁ na hāpeti,"
    },
    {
      "id": "an7.29:2.4",
      "pali": "saddhammassavanaṁ nappamajjati,"
    },
    {
      "id": "an7.29:2.5",
      "pali": "adhisīle sikkhati,"
    },
    {
      "id": "an7.29:2.6",
      "pali": "pasādabahulo hoti,"
    },
    {
      "id": "an7.29:2.7",
      "pali": "bhikkhūsu theresu ceva navesu ca majjhimesu ca anupārambhacitto dhammaṁ suṇāti na randhagavesī,"
    },
    {
      "id": "an7.29:2.8",
      "pali": "na ito bahiddhā dakkhiṇeyyaṁ gavesati,"
    },
    {
      "id": "an7.29:2.9",
      "pali": "idha ca pubbakāraṁ karoti."
    },
    {
      "id": "an7.29:2.10",
      "pali": "Ime kho, bhikkhave, satta dhammā upāsakassa aparihānāya saṁvattantī”ti."
    },
    {
      "id": "an7.29:2.11",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "an7.29:2.12",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "an7.29:3.1",
      "pali": "“Dassanaṁ bhāvitattānaṁ,"
    },
    {
      "id": "an7.29:3.2",
      "pali": "Yo hāpeti upāsako;"
    },
    {
      "id": "an7.29:3.3",
      "pali": "Savanañca ariyadhammānaṁ,"
    },
    {
      "id": "an7.29:3.4",
      "pali": "Adhisīle na sikkhati."
    },
    {
      "id": "an7.29:4.1",
      "pali": "Appasādo ca bhikkhūsu,"
    },
    {
      "id": "an7.29:4.2",
      "pali": "bhiyyo bhiyyo pavaḍḍhati;"
    },
    {
      "id": "an7.29:4.3",
      "pali": "Upārambhakacitto ca,"
    },
    {
      "id": "an7.29:4.4",
      "pali": "saddhammaṁ sotumicchati."
    },
    {
      "id": "an7.29:5.1",
      "pali": "Ito ca bahiddhā aññaṁ,"
    },
    {
      "id": "an7.29:5.2",
      "pali": "dakkhiṇeyyaṁ gavesati;"
    },
    {
      "id": "an7.29:5.3",
      "pali": "Tattheva ca pubbakāraṁ,"
    },
    {
      "id": "an7.29:5.4",
      "pali": "yo karoti upāsako."
    },
    {
      "id": "an7.29:6.1",
      "pali": "Ete kho parihāniye,"
    },
    {
      "id": "an7.29:6.2",
      "pali": "satta dhamme sudesite;"
    },
    {
      "id": "an7.29:6.3",
      "pali": "Upāsako sevamāno,"
    },
    {
      "id": "an7.29:6.4",
      "pali": "saddhammā parihāyati."
    },
    {
      "id": "an7.29:7.1",
      "pali": "Dassanaṁ bhāvitattānaṁ,"
    },
    {
      "id": "an7.29:7.2",
      "pali": "Yo na hāpeti upāsako;"
    },
    {
      "id": "an7.29:7.3",
      "pali": "Savanañca ariyadhammānaṁ,"
    },
    {
      "id": "an7.29:7.4",
      "pali": "Adhisīle ca sikkhati."
    },
    {
      "id": "an7.29:8.1",
      "pali": "Pasādo cassa bhikkhūsu,"
    },
    {
      "id": "an7.29:8.2",
      "pali": "bhiyyo bhiyyo pavaḍḍhati;"
    },
    {
      "id": "an7.29:8.3",
      "pali": "Anupārambhacitto ca,"
    },
    {
      "id": "an7.29:8.4",
      "pali": "saddhammaṁ sotumicchati."
    },
    {
      "id": "an7.29:9.1",
      "pali": "Na ito bahiddhā aññaṁ,"
    },
    {
      "id": "an7.29:9.2",
      "pali": "dakkhiṇeyyaṁ gavesati;"
    },
    {
      "id": "an7.29:9.3",
      "pali": "Idheva ca pubbakāraṁ,"
    },
    {
      "id": "an7.29:9.4",
      "pali": "yo karoti upāsako."
    },
    {
      "id": "an7.29:10.1",
      "pali": "Ete kho aparihāniye,"
    },
    {
      "id": "an7.29:10.2",
      "pali": "Satta dhamme sudesite;"
    },
    {
      "id": "an7.29:10.3",
      "pali": "Upāsako sevamāno,"
    },
    {
      "id": "an7.29:10.4",
      "pali": "Saddhammā na parihāyatī”ti."
    },
    {
      "id": "an7.29:10.5",
      "pali": "Navamaṁ."
    }
  ]
}
