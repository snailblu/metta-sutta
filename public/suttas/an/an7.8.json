{
  "uid": "an7.8",
  "title": "Saṁyojanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.8:1.1",
      "pali": "“Sattimāni, bhikkhave, saṁyojanāni."
    },
    {
      "id": "an7.8:1.2",
      "pali": "Katamāni satta?"
    },
    {
      "id": "an7.8:1.3",
      "pali": "Anunayasaṁyojanaṁ, paṭighasaṁyojanaṁ, diṭṭhisaṁyojanaṁ, vicikicchāsaṁyojanaṁ, mānasaṁyojanaṁ, bhavarāgasaṁyojanaṁ, avijjāsaṁyojanaṁ."
    },
    {
      "id": "an7.8:1.4",
      "pali": "Imāni kho, bhikkhave, satta saṁyojanānī”ti."
    },
    {
      "id": "an7.8:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
