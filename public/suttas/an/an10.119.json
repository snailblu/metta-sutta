{
  "uid": "an10.119",
  "title": "Paṭhamapaccorohaṇīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.119:1.1",
      "pali": "Tena kho pana samayena jāṇussoṇi brāhmaṇo tadahuposathe sīsaṁnhāto navaṁ khomayugaṁ nivattho allakusamuṭṭhiṁ ādāya bhagavato avidūre ekamantaṁ ṭhito hoti."
    },
    {
      "id": "an10.119:2.1",
      "pali": "Addasā kho bhagavā jāṇussoṇiṁ brāhmaṇaṁ tadahuposathe sīsaṁnhātaṁ navaṁ khomayugaṁ nivatthaṁ allakusamuṭṭhiṁ ādāya ekamantaṁ ṭhitaṁ."
    },
    {
      "id": "an10.119:2.2",
      "pali": "Disvāna jāṇussoṇiṁ brāhmaṇaṁ etadavoca:"
    },
    {
      "id": "an10.119:2.3",
      "pali": "“kiṁ nu tvaṁ, brāhmaṇa, tadahuposathe sīsaṁnhāto navaṁ khomayugaṁ nivattho allakusamuṭṭhiṁ ādāya ekamantaṁ ṭhito?"
    },
    {
      "id": "an10.119:2.4",
      "pali": "Kiṁ nvajja brāhmaṇakulassā”ti?"
    },
    {
      "id": "an10.119:2.5",
      "pali": "“Paccorohaṇī, bho gotama, ajja brāhmaṇakulassā”ti."
    },
    {
      "id": "an10.119:3.1",
      "pali": "“Yathā kathaṁ pana, brāhmaṇa, brāhmaṇānaṁ paccorohaṇī hotī”ti?"
    },
    {
      "id": "an10.119:3.2",
      "pali": "“Idha, bho gotama, brāhmaṇā tadahuposathe sīsaṁnhātā navaṁ khomayugaṁ nivatthā allena gomayena pathaviṁ opuñjitvā haritehi kusehi pattharitvā antarā ca velaṁ antarā ca agyāgāraṁ seyyaṁ kappenti."
    },
    {
      "id": "an10.119:3.3",
      "pali": "Te taṁ rattiṁ tikkhattuṁ paccuṭṭhāya pañjalikā aggiṁ namassanti:"
    },
    {
      "id": "an10.119:3.4",
      "pali": "‘paccorohāma bhavantaṁ, paccorohāma bhavantan’ti."
    },
    {
      "id": "an10.119:3.5",
      "pali": "Bahukena ca sappitelanavanītena aggiṁ santappenti."
    },
    {
      "id": "an10.119:3.6",
      "pali": "Tassā ca rattiyā accayena paṇītena khādanīyena bhojanīyena brāhmaṇe santappenti."
    },
    {
      "id": "an10.119:3.7",
      "pali": "Evaṁ, bho gotama, brāhmaṇānaṁ paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.119:4.1",
      "pali": "“Aññathā kho, brāhmaṇa, brāhmaṇānaṁ paccorohaṇī hoti, aññathā ca pana ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.119:4.2",
      "pali": "“Yathā kathaṁ pana, bho gotama, ariyassa vinaye paccorohaṇī hoti?"
    },
    {
      "id": "an10.119:4.3",
      "pali": "Sādhu me bhavaṁ gotamo tathā dhammaṁ desetu yathā ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.119:5.1",
      "pali": "“Tena hi, brāhmaṇa, suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "an10.119:5.2",
      "pali": "“Evaṁ, bho”ti kho jāṇussoṇi brāhmaṇo bhagavato paccassosi."
    },
    {
      "id": "an10.119:5.3",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an10.119:6.1",
      "pali": "“Idha, brāhmaṇa, ariyasāvako iti paṭisañcikkhati:"
    },
    {
      "id": "an10.119:6.2",
      "pali": "‘micchādiṭṭhiyā kho pāpako vipāko"
    },
    {
      "id": "an10.119:6.3",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:6.4",
      "pali": "So iti paṭisaṅkhāya micchādiṭṭhiṁ pajahati;"
    },
    {
      "id": "an10.119:6.5",
      "pali": "micchādiṭṭhiyā paccorohati."
    },
    {
      "id": "an10.119:7.1",
      "pali": "… ‘Micchāsaṅkappassa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:7.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:7.3",
      "pali": "So iti paṭisaṅkhāya micchāsaṅkappaṁ pajahati;"
    },
    {
      "id": "an10.119:7.4",
      "pali": "micchāsaṅkappā paccorohati."
    },
    {
      "id": "an10.119:8.1",
      "pali": "… ‘Micchāvācāya kho pāpako vipāko—"
    },
    {
      "id": "an10.119:8.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:8.3",
      "pali": "So iti paṭisaṅkhāya micchāvācaṁ pajahati;"
    },
    {
      "id": "an10.119:8.4",
      "pali": "micchāvācāya paccorohati."
    },
    {
      "id": "an10.119:9.1",
      "pali": "… ‘Micchākammantassa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:9.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:9.3",
      "pali": "So iti paṭisaṅkhāya micchākammantaṁ pajahati;"
    },
    {
      "id": "an10.119:9.4",
      "pali": "micchākammantā paccorohati."
    },
    {
      "id": "an10.119:10.1",
      "pali": "… ‘Micchāājīvassa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:10.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:10.3",
      "pali": "So iti paṭisaṅkhāya micchāājīvaṁ pajahati;"
    },
    {
      "id": "an10.119:10.4",
      "pali": "micchāājīvā paccorohati."
    },
    {
      "id": "an10.119:11.1",
      "pali": "… ‘Micchāvāyāmassa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:11.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:11.3",
      "pali": "So iti paṭisaṅkhāya micchāvāyāmaṁ pajahati;"
    },
    {
      "id": "an10.119:11.4",
      "pali": "micchāvāyāmā paccorohati."
    },
    {
      "id": "an10.119:12.1",
      "pali": "… ‘Micchāsatiyā kho pāpako vipāko—"
    },
    {
      "id": "an10.119:12.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:12.3",
      "pali": "So iti paṭisaṅkhāya micchāsatiṁ pajahati;"
    },
    {
      "id": "an10.119:12.4",
      "pali": "micchāsatiyā paccorohati."
    },
    {
      "id": "an10.119:13.1",
      "pali": "… ‘Micchāsamādhissa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:13.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:13.3",
      "pali": "So iti paṭisaṅkhāya micchāsamādhiṁ pajahati;"
    },
    {
      "id": "an10.119:13.4",
      "pali": "micchāsamādhimhā paccorohati."
    },
    {
      "id": "an10.119:14.1",
      "pali": "… ‘Micchāñāṇassa kho pāpako vipāko—"
    },
    {
      "id": "an10.119:14.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:14.3",
      "pali": "So iti paṭisaṅkhāya micchāñāṇaṁ pajahati;"
    },
    {
      "id": "an10.119:14.4",
      "pali": "micchāñāṇamhā paccorohati."
    },
    {
      "id": "an10.119:15.1",
      "pali": "… ‘Micchāvimuttiyā kho pāpako vipāko—"
    },
    {
      "id": "an10.119:15.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.119:15.3",
      "pali": "So iti paṭisaṅkhāya micchāvimuttiṁ pajahati;"
    },
    {
      "id": "an10.119:15.4",
      "pali": "micchāvimuttiyā paccorohati."
    },
    {
      "id": "an10.119:15.5",
      "pali": "Evaṁ kho, brāhmaṇa, ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.119:16.1",
      "pali": "“Aññathā, bho gotama, brāhmaṇānaṁ paccorohaṇī, aññathā ca pana ariyassa vinaye paccorohaṇī hoti."
    },
    {
      "id": "an10.119:16.2",
      "pali": "Imissā ca, bho gotama, ariyassa vinaye paccorohaṇiyā brāhmaṇānaṁ paccorohaṇī kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "an10.119:16.3",
      "pali": "Abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "an10.119:16.4",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    },
    {
      "id": "an10.119:16.5",
      "pali": "Sattamaṁ."
    }
  ]
}
