{
  "uid": "an3.81",
  "title": "Samaṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.81:1.1",
      "pali": "“Tīṇimāni, bhikkhave, samaṇassa samaṇiyāni samaṇakaraṇīyāni."
    },
    {
      "id": "an3.81:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.81:1.3",
      "pali": "Adhisīlasikkhāsamādānaṁ, adhicittasikkhāsamādānaṁ, adhipaññāsikkhāsamādānaṁ—"
    },
    {
      "id": "an3.81:1.4",
      "pali": "imāni kho, bhikkhave, tīṇi samaṇassa samaṇiyāni samaṇakaraṇīyāni."
    },
    {
      "id": "an3.81:2.1",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "an3.81:2.2",
      "pali": "‘tibbo no chando bhavissati adhisīlasikkhāsamādāne, tibbo no chando bhavissati adhicittasikkhāsamādāne, tibbo no chando bhavissati adhipaññāsikkhāsamādāne’ti."
    },
    {
      "id": "an3.81:2.3",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "an3.81:2.4",
      "pali": "Paṭhamaṁ."
    }
  ]
}
