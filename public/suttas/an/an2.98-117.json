{
  "uid": "an2.98-117",
  "title": "an2.98-117",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.98:1.1",
      "pali": "“Dveme, bhikkhave, bālā."
    },
    {
      "id": "an2.98:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.98:1.3",
      "pali": "Yo ca anāgataṁ bhāraṁ vahati, yo ca āgataṁ bhāraṁ na vahati."
    },
    {
      "id": "an2.98:1.4",
      "pali": "Ime kho, bhikkhave, dve bālā”ti."
    },
    {
      "id": "an2.99:1.1",
      "pali": "“Dveme, bhikkhave, paṇḍitā."
    },
    {
      "id": "an2.99:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.99:1.3",
      "pali": "Yo ca anāgataṁ bhāraṁ na vahati, yo ca āgataṁ bhāraṁ vahati."
    },
    {
      "id": "an2.99:1.4",
      "pali": "Ime kho, bhikkhave, dve paṇḍitā”ti."
    },
    {
