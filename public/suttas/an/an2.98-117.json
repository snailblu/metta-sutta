      "id": "an2.107:1.4",
      "pali": "Ime kho, bhikkhave, dve paṇḍitā”ti."
    },
    {
      "id": "an2.108:1.1",
      "pali": "“Dvinnaṁ, bhikkhave, āsavā vaḍḍhanti."
    },
    {
      "id": "an2.108:1.2",
      "pali": "Katamesaṁ dvinnaṁ?"
    },
    {
      "id": "an2.108:1.3",
      "pali": "Yo ca na kukkuccāyitabbaṁ kukkuccāyati, yo ca kukkuccāyitabbaṁ na kukkuccāyati."
    },
    {
      "id": "an2.108:1.4",
      "pali": "Imesaṁ kho, bhikkhave, dvinnaṁ āsavā vaḍḍhantī”ti."
    },
    {
      "id": "an2.109:1.1",
      "pali": "“Dvinnaṁ, bhikkhave, āsavā na vaḍḍhanti."
    },
    {
      "id": "an2.109:1.2",
      "pali": "Katamesaṁ dvinnaṁ?"
    },
    {
      "id": "an2.109:1.3",
      "pali": "Yo ca na kukkuccāyitabbaṁ na kukkuccāyati, yo ca kukkuccāyitabbaṁ kukkuccāyati."
    },
    {
      "id": "an2.109:1.4",
      "pali": "Imesaṁ kho, bhikkhave, dvinnaṁ āsavā na vaḍḍhantī”ti."
    },
