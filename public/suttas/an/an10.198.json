{
  "uid": "an10.198",
  "title": "Sacchikātabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.198:1.1",
      "pali": "“Sacchikātabbañca vo, bhikkhave, dhammaṁ desessāmi na sacchikātabbañca."
    },
    {
      "id": "an10.198:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.198:1.3",
      "pali": "katamo ca, bhikkhave, na sacchikātabbo dhammo?"
    },
    {
      "id": "an10.198:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.198:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.198:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, na sacchikātabbo dhammo."
    },
    {
      "id": "an10.198:2.1",
      "pali": "Katamo ca, bhikkhave, sacchikātabbo dhammo?"
    },
    {
      "id": "an10.198:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.198:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.198:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, sacchikātabbo dhammo”ti."
    },
    {
      "id": "an10.198:2.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an10.198:2.6",
      "pali": "Ariyamaggavaggo catuttho."
    }
  ]
}
