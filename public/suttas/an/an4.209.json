{
  "uid": "an4.209",
  "title": "Tatiyapāpadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.209:1.1",
      "pali": "“Pāpadhammañca vo, bhikkhave, desessāmi, pāpadhammena pāpadhammatarañca;"
    },
    {
      "id": "an4.209:1.2",
      "pali": "kalyāṇadhammañca, kalyāṇadhammena kalyāṇadhammatarañca. Taṁ suṇātha …pe…."
    },
    {
      "id": "an4.209:2.1",
      "pali": "“Katamo ca, bhikkhave, pāpadhammo?"
    },
    {
      "id": "an4.209:2.2",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātī hoti …pe… micchādiṭṭhiko hoti."
    },
    {
      "id": "an4.209:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpadhammo."
    },
    {
      "id": "an4.209:3.1",
      "pali": "Katamo ca, bhikkhave, pāpadhammena pāpadhammataro?"
    },
    {
      "id": "an4.209:3.2",
      "pali": "Idha bhikkhave, ekacco attanā ca pāṇātipātī hoti, parañca pāṇātipāte samādapeti …pe… attanā ca micchādiṭṭhiko hoti, parañca micchādiṭṭhiyā samādapeti."
    },
    {
      "id": "an4.209:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpadhammena pāpadhammataro."
    },
    {
      "id": "an4.209:4.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇadhammo?"
    },
    {
      "id": "an4.209:4.2",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātā paṭivirato hoti …pe… sammādiṭṭhiko hoti."
    },
    {
      "id": "an4.209:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇadhammo."
    },
    {
      "id": "an4.209:5.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇadhammena kalyāṇadhammataro?"
    },
    {
      "id": "an4.209:5.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca pāṇātipātā paṭivirato hoti, parañca pāṇātipātā veramaṇiyā samādapeti …pe… attanā ca sammādiṭṭhiko hoti, parañca sammādiṭṭhiyā samādapeti."
    },
    {
      "id": "an4.209:5.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇadhammena kalyāṇadhammataro”ti."
    },
    {
      "id": "an4.209:5.4",
      "pali": "Navamaṁ."
    }
  ]
}
