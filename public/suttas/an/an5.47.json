{
  "uid": "an5.47",
  "title": "Dhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.47:1.1",
      "pali": "“Pañcimāni, bhikkhave, dhanāni."
    },
    {
      "id": "an5.47:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.47:1.3",
      "pali": "Saddhādhanaṁ, sīladhanaṁ, sutadhanaṁ, cāgadhanaṁ, paññādhanaṁ."
    },
    {
      "id": "an5.47:2.1",
      "pali": "Katamañca, bhikkhave, saddhādhanaṁ?"
    },
    {
      "id": "an5.47:2.2",
      "pali": "Idha, bhikkhave, ariyasāvako saddho hoti, saddahati tathāgatassa bodhiṁ:"
    },
    {
      "id": "an5.47:2.3",
      "pali": "‘itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavā’ti."
    },
    {
      "id": "an5.47:2.4",
      "pali": "Idaṁ vuccati, bhikkhave, saddhādhanaṁ."
    },
    {
      "id": "an5.47:3.1",
      "pali": "Katamañca, bhikkhave, sīladhanaṁ?"
    },
    {
      "id": "an5.47:3.2",
      "pali": "Idha, bhikkhave, ariyasāvako pāṇātipātā paṭivirato hoti …pe… surāmerayamajjapamādaṭṭhānā paṭivirato hoti."
    },
    {
      "id": "an5.47:3.3",
      "pali": "Idaṁ vuccati, bhikkhave, sīladhanaṁ."
    },
    {
      "id": "an5.47:4.1",
      "pali": "Katamañca, bhikkhave, sutadhanaṁ?"
    },
    {
      "id": "an5.47:4.2",
      "pali": "Idha, bhikkhave, ariyasāvako bahussuto hoti …pe… diṭṭhiyā suppaṭividdho."
    },
    {
      "id": "an5.47:4.3",
      "pali": "Idaṁ vuccati, bhikkhave, sutadhanaṁ."
    },
    {
      "id": "an5.47:5.1",
      "pali": "Katamañca, bhikkhave, cāgadhanaṁ?"
    },
    {
      "id": "an5.47:5.2",
      "pali": "Idha, bhikkhave, ariyasāvako vigatamalamaccherena cetasā agāraṁ ajjhāvasati muttacāgo payatapāṇi vosaggarato yācayogo dānasaṁvibhāgarato."
    },
    {
      "id": "an5.47:5.3",
      "pali": "Idaṁ vuccati, bhikkhave, cāgadhanaṁ."
    },
    {
      "id": "an5.47:6.1",
      "pali": "Katamañca, bhikkhave, paññādhanaṁ?"
    },
    {
      "id": "an5.47:6.2",
      "pali": "Idha, bhikkhave, ariyasāvako paññavā hoti, udayatthagāminiyā paññāya samannāgato ariyāya nibbedhikāya sammā dukkhakkhayagāminiyā."
    },
    {
      "id": "an5.47:6.3",
      "pali": "Idaṁ vuccati, bhikkhave, paññādhanaṁ."
    },
    {
      "id": "an5.47:6.4",
      "pali": "Imāni kho, bhikkhave, pañca dhanānīti."
    },
    {
      "id": "an5.47:7.1",
      "pali": "Yassa saddhā tathāgate,"
    },
    {
      "id": "an5.47:7.2",
      "pali": "acalā suppatiṭṭhitā;"
    },
    {
      "id": "an5.47:7.3",
      "pali": "Sīlañca yassa kalyāṇaṁ,"
    },
    {
      "id": "an5.47:7.4",
      "pali": "ariyakantaṁ pasaṁsitaṁ."
    },
    {
      "id": "an5.47:8.1",
      "pali": "Saṅghe pasādo yassatthi,"
    },
    {
      "id": "an5.47:8.2",
      "pali": "ujubhūtañca dassanaṁ;"
    },
    {
      "id": "an5.47:8.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "an5.47:8.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "an5.47:9.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "an5.47:9.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "an5.47:9.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "an5.47:9.4",
      "pali": "saraṁ buddhāna sāsanan”ti."
    },
    {
      "id": "an5.47:9.5",
      "pali": "Sattamaṁ."
    }
  ]
}
