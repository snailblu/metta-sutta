{
  "uid": "an4.32",
  "title": "Saṅgahasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.32:1.1",
      "pali": "“Cattārimāni, bhikkhave, saṅgahavatthūni."
    },
    {
      "id": "an4.32:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.32:1.3",
      "pali": "Dānaṁ, peyyavajjaṁ, atthacariyā, samānattatā—"
    },
    {
      "id": "an4.32:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri saṅgahavatthūnīti."
    },
    {
      "id": "an4.32:2.1",
      "pali": "Dānañca peyyavajjañca,"
    },
    {
      "id": "an4.32:2.2",
      "pali": "atthacariyā ca yā idha;"
    },
    {
      "id": "an4.32:2.3",
      "pali": "Samānattatā ca dhammesu,"
    },
    {
      "id": "an4.32:2.4",
      "pali": "tattha tattha yathārahaṁ;"
    },
    {
      "id": "an4.32:2.5",
      "pali": "Ete kho saṅgahā loke,"
    },
    {
      "id": "an4.32:2.6",
      "pali": "rathassāṇīva yāyato."
    },
    {
      "id": "an4.32:3.1",
      "pali": "Ete ca saṅgahā nāssu,"
    },
    {
      "id": "an4.32:3.2",
      "pali": "na mātā puttakāraṇā;"
    },
    {
      "id": "an4.32:3.3",
      "pali": "Labhetha mānaṁ pūjaṁ vā,"
    },
    {
      "id": "an4.32:3.4",
      "pali": "pitā vā puttakāraṇā."
    },
    {
      "id": "an4.32:4.1",
      "pali": "Yasmā ca saṅgahā ete,"
    },
    {
      "id": "an4.32:4.2",
      "pali": "samavekkhanti paṇḍitā;"
    },
    {
      "id": "an4.32:4.3",
      "pali": "Tasmā mahattaṁ papponti,"
    },
    {
      "id": "an4.32:4.4",
      "pali": "pāsaṁsā ca bhavanti te”ti."
    },
    {
      "id": "an4.32:4.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
