{
  "uid": "an2.151-162",
  "title": "an2.151-162",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.151:1.1",
      "pali": "“Dveme, bhikkhave, santhārā."
    },
    {
      "id": "an2.151:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.151:1.3",
      "pali": "Āmisasanthāro ca dhammasanthāro ca."
    },
    {
      "id": "an2.151:1.4",
      "pali": "Ime kho, bhikkhave, dve santhārā."
    },
    {
      "id": "an2.151:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ santhārānaṁ yadidaṁ dhammasanthāro”ti."
    },
    {
      "id": "an2.152:1.1",
      "pali": "“Dveme, bhikkhave, paṭisanthārā."
    },
    {
      "id": "an2.152:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.152:1.3",
      "pali": "Āmisapaṭisanthāro ca dhammapaṭisanthāro ca."
    },
    {
      "id": "an2.152:1.4",
      "pali": "Ime kho, bhikkhave, dve paṭisanthārā."
    },
    {
      "id": "an2.152:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ paṭisanthārānaṁ yadidaṁ dhammapaṭisanthāro”ti."
    },
    {
      "id": "an2.153:1.1",
      "pali": "“Dvemā, bhikkhave, esanā."
    },
    {
      "id": "an2.153:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.153:1.3",
      "pali": "Āmisesanā ca dhammesanā ca."
    },
    {
      "id": "an2.153:1.4",
      "pali": "Imā kho, bhikkhave, dve esanā."
    },
    {
      "id": "an2.153:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ esanānaṁ yadidaṁ dhammesanā”ti."
    },
    {
      "id": "an2.154:1.1",
      "pali": "“Dvemā, bhikkhave, pariyesanā."
    },
    {
      "id": "an2.154:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.154:1.3",
      "pali": "Āmisapariyesanā ca dhammapariyesanā ca."
    },
    {
      "id": "an2.154:1.4",
      "pali": "Imā kho, bhikkhave, dve pariyesanā."
    },
    {
      "id": "an2.154:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ pariyesanānaṁ yadidaṁ dhammapariyesanā”ti."
    },
    {
      "id": "an2.155:1.1",
      "pali": "“Dvemā, bhikkhave, pariyeṭṭhiyo."
    },
    {
      "id": "an2.155:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.155:1.3",
      "pali": "Āmisapariyeṭṭhi ca dhammapariyeṭṭhi ca."
    },
    {
      "id": "an2.155:1.4",
      "pali": "Imā kho, bhikkhave, dve pariyeṭṭhiyo."
    },
    {
      "id": "an2.155:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ pariyeṭṭhīnaṁ yadidaṁ dhammapariyeṭṭhī”ti."
    },
    {
      "id": "an2.156:1.1",
      "pali": "“Dvemā, bhikkhave, pūjā."
    },
    {
      "id": "an2.156:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.156:1.3",
      "pali": "Āmisapūjā ca dhammapūjā ca."
    },
    {
      "id": "an2.156:1.4",
      "pali": "Imā kho, bhikkhave, dve pūjā."
    },
    {
      "id": "an2.156:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ pūjānaṁ yadidaṁ dhammapūjā”ti."
    },
    {
      "id": "an2.157:1.1",
      "pali": "“Dvemāni, bhikkhave, ātitheyyāni."
    },
    {
      "id": "an2.157:1.2",
      "pali": "Katamāni dve?"
    },
    {
      "id": "an2.157:1.3",
      "pali": "Āmisātitheyyañca dhammātitheyyañca."
    },
    {
      "id": "an2.157:1.4",
      "pali": "Imāni kho, bhikkhave, dve ātitheyyāni."
    },
    {
      "id": "an2.157:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ ātitheyyānaṁ yadidaṁ dhammātitheyyan”ti."
    },
    {
      "id": "an2.158:1.1",
      "pali": "“Dvemā, bhikkhave, iddhiyo."
    },
    {
      "id": "an2.158:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.158:1.3",
      "pali": "Āmisiddhi ca dhammiddhi ca."
    },
    {
      "id": "an2.158:1.4",
      "pali": "Imā kho, bhikkhave, dve iddhiyo."
    },
    {
      "id": "an2.158:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ iddhīnaṁ yadidaṁ dhammiddhī”ti."
    },
    {
      "id": "an2.159:1.1",
      "pali": "“Dvemā, bhikkhave, vuddhiyo."
    },
    {
      "id": "an2.159:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.159:1.3",
      "pali": "Āmisavuddhi ca dhammavuddhi ca."
    },
    {
      "id": "an2.159:1.4",
      "pali": "Imā kho, bhikkhave, dve vuddhiyo."
    },
    {
      "id": "an2.159:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ vuddhīnaṁ yadidaṁ dhammavuddhī”ti."
    },
    {
      "id": "an2.160:1.1",
      "pali": "“Dvemāni, bhikkhave, ratanāni."
    },
    {
      "id": "an2.160:1.2",
      "pali": "Katamāni dve?"
    },
    {
      "id": "an2.160:1.3",
      "pali": "Āmisaratanañca dhammaratanañca."
    },
    {
      "id": "an2.160:1.4",
      "pali": "Imāni kho, bhikkhave, dve ratanāni."
    },
    {
      "id": "an2.160:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ ratanānaṁ yadidaṁ dhammaratanan”ti."
    },
    {
      "id": "an2.161:1.1",
      "pali": "“Dveme, bhikkhave, sannicayā."
    },
    {
      "id": "an2.161:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.161:1.3",
      "pali": "Āmisasannicayo ca dhammasannicayo ca."
    },
    {
      "id": "an2.161:1.4",
      "pali": "Ime kho, bhikkhave, dve sannicayā."
    },
    {
      "id": "an2.161:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ sannicayānaṁ yadidaṁ dhammasannicayo”ti."
    },
    {
      "id": "an2.162:1.1",
      "pali": "“Dvemāni, bhikkhave, vepullāni."
    },
    {
      "id": "an2.162:1.2",
      "pali": "Katamāni dve?"
    },
    {
      "id": "an2.162:1.3",
      "pali": "Āmisavepullañca dhammavepullañca."
    },
    {
      "id": "an2.162:1.4",
      "pali": "Imāni kho, bhikkhave, dve vepullāni."
    },
    {
      "id": "an2.162:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ vepullānaṁ yadidaṁ dhammavepullan”ti."
    },
    {
      "id": "an2.162:1.6",
      "pali": "Santhāravaggo catuttho."
    }
  ]
}
