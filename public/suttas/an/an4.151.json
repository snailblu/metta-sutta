{
  "uid": "an4.151",
  "title": "Indriyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.151:1.1",
      "pali": "“Cattārimāni, bhikkhave, indriyāni."
    },
    {
      "id": "an4.151:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.151:1.3",
      "pali": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ—"
    },
    {
      "id": "an4.151:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri indriyānī”ti."
    },
    {
      "id": "an4.151:1.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
