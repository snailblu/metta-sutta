{
  "uid": "an10.188",
  "title": "Vipākasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.188:1.1",
      "pali": "“Dukkhavipākañca vo, bhikkhave, dhammaṁ desessāmi sukhavipākañca."
    },
    {
      "id": "an10.188:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.188:1.3",
      "pali": "katamo ca, bhikkhave, dukkhavipāko dhammo?"
    },
    {
      "id": "an10.188:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.188:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.188:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhavipāko dhammo."
    },
    {
      "id": "an10.188:2.1",
      "pali": "Katamo ca, bhikkhave, sukhavipāko dhammo?"
    },
    {
      "id": "an10.188:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.188:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.188:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, sukhavipāko dhammo”ti."
    },
    {
      "id": "an10.188:2.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an10.188:2.6",
      "pali": "Sādhuvaggo tatiyo."
    }
  ]
}
