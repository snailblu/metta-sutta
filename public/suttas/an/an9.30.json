{
  "uid": "an9.30",
  "title": "Āghātapaṭivinayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.30:1.1",
      "pali": "“Navayime, bhikkhave, āghātapaṭivinayā."
    },
    {
      "id": "an9.30:1.2",
      "pali": "Katame nava?"
    },
    {
      "id": "an9.30:1.3",
      "pali": "‘Anatthaṁ me acari, taṁ kutettha labbhā’ti āghātaṁ paṭivineti;"
    },
    {
      "id": "an9.30:1.4",
      "pali": "‘anatthaṁ me carati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti;"
    },
    {
      "id": "an9.30:1.5",
      "pali": "‘anatthaṁ me carissati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti;"
    },
    {
      "id": "an9.30:1.6",
      "pali": "piyassa me manāpassa anatthaṁ acari …pe…"
    },
    {
      "id": "an9.30:1.7",
      "pali": "anatthaṁ carati …pe…"
    },
    {
      "id": "an9.30:1.8",
      "pali": "‘anatthaṁ carissati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti;"
    },
    {
      "id": "an9.30:1.9",
      "pali": "appiyassa me amanāpassa atthaṁ acari …pe…"
    },
    {
      "id": "an9.30:1.10",
      "pali": "atthaṁ carati …pe…"
    },
    {
      "id": "an9.30:1.11",
      "pali": "‘atthaṁ carissati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti."
    },
    {
      "id": "an9.30:1.12",
      "pali": "Ime kho, bhikkhave, nava āghātapaṭivinayā”ti."
    },
    {
      "id": "an9.30:1.13",
      "pali": "Dasamaṁ."
    }
  ]
}
