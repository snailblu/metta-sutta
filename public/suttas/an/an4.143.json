{
  "uid": "an4.143",
  "title": "Ālokasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.143:1.1",
      "pali": "“Cattārome, bhikkhave, ālokā."
    },
    {
      "id": "an4.143:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.143:1.3",
      "pali": "Candāloko, sūriyāloko, aggāloko, paññāloko—"
    },
    {
      "id": "an4.143:1.4",
      "pali": "Ime kho, bhikkhave, cattāro ālokā."
    },
    {
      "id": "an4.143:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ ālokānaṁ yadidaṁ paññāloko”ti."
    },
    {
      "id": "an4.143:1.6",
      "pali": "Tatiyaṁ."
    }
  ]
}
