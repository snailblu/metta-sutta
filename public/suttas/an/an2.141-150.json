{
  "uid": "an2.141-150",
  "title": "an2.141-150",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.141:1.1",
      "pali": "“Dvemāni, bhikkhave, dānāni."
    },
    {
      "id": "an2.141:1.2",
      "pali": "Katamāni dve?"
    },
    {
      "id": "an2.141:1.3",
      "pali": "Āmisadānañca dhammadānañca."
    },
    {
      "id": "an2.141:1.4",
      "pali": "Imāni kho, bhikkhave, dve dānāni."
    },
    {
      "id": "an2.141:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ dānānaṁ yadidaṁ dhammadānan”ti."
    },
    {
      "id": "an2.142:1.1",
      "pali": "“Dveme, bhikkhave, yāgā."
    },
    {
      "id": "an2.142:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.142:1.3",
      "pali": "Āmisayāgo ca dhammayāgo ca."
    },
    {
      "id": "an2.142:1.4",
      "pali": "Ime kho, bhikkhave, dve yāgā."
    },
    {
      "id": "an2.142:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ yāgānaṁ yadidaṁ dhammayāgo”ti."
    },
    {
      "id": "an2.143:1.1",
      "pali": "“Dveme, bhikkhave, cāgā."
    },
    {
      "id": "an2.143:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.143:1.3",
      "pali": "Āmisacāgo ca dhammacāgo ca."
    },
    {
      "id": "an2.143:1.4",
      "pali": "Ime kho, bhikkhave, dve cāgā."
    },
    {
      "id": "an2.143:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ cāgānaṁ yadidaṁ dhammacāgo”ti."
    },
    {
      "id": "an2.144:1.1",
      "pali": "“Dveme, bhikkhave, pariccāgā."
    },
    {
      "id": "an2.144:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.144:1.3",
      "pali": "Āmisapariccāgo ca dhammapariccāgo ca."
    },
    {
      "id": "an2.144:1.4",
      "pali": "Ime kho, bhikkhave, dve pariccāgā."
    },
    {
      "id": "an2.144:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ pariccāgānaṁ yadidaṁ dhammapariccāgo”ti."
    },
    {
      "id": "an2.145:1.1",
      "pali": "“Dveme, bhikkhave, bhogā."
    },
    {
      "id": "an2.145:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.145:1.3",
      "pali": "Āmisabhogo ca dhammabhogo ca."
    },
    {
      "id": "an2.145:1.4",
      "pali": "Ime kho, bhikkhave, dve bhogā."
    },
    {
      "id": "an2.145:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ bhogānaṁ yadidaṁ dhammabhogo”ti."
    },
    {
      "id": "an2.146:1.1",
      "pali": "“Dveme, bhikkhave, sambhogā."
    },
    {
      "id": "an2.146:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.146:1.3",
      "pali": "Āmisasambhogo ca dhammasambhogo ca."
    },
    {
      "id": "an2.146:1.4",
      "pali": "Ime kho, bhikkhave, dve sambhogā."
    },
    {
      "id": "an2.146:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ sambhogānaṁ yadidaṁ dhammasambhogo”ti."
    },
    {
      "id": "an2.147:1.1",
      "pali": "“Dveme, bhikkhave, saṁvibhāgā."
    },
    {
      "id": "an2.147:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.147:1.3",
      "pali": "Āmisasaṁvibhāgo ca dhammasaṁvibhāgo ca."
    },
    {
      "id": "an2.147:1.4",
      "pali": "Ime kho, bhikkhave, dve saṁvibhāgā."
    },
    {
      "id": "an2.147:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ saṁvibhāgānaṁ yadidaṁ dhammasaṁvibhāgo”ti."
    },
    {
      "id": "an2.148:1.1",
      "pali": "“Dveme, bhikkhave, saṅgahā."
    },
    {
      "id": "an2.148:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.148:1.3",
      "pali": "Āmisasaṅgaho ca dhammasaṅgaho ca."
    },
    {
      "id": "an2.148:1.4",
      "pali": "Ime kho, bhikkhave, dve saṅgahā."
    },
    {
      "id": "an2.148:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ saṅgahānaṁ yadidaṁ dhammasaṅgaho”ti."
    },
    {
      "id": "an2.149:1.1",
      "pali": "“Dveme, bhikkhave, anuggahā."
    },
    {
      "id": "an2.149:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.149:1.3",
      "pali": "Āmisānuggaho ca dhammānuggaho ca."
    },
    {
      "id": "an2.149:1.4",
      "pali": "Ime kho, bhikkhave, dve anuggahā."
    },
    {
      "id": "an2.149:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ anuggahānaṁ yadidaṁ dhammānuggaho”ti."
    },
    {
      "id": "an2.150:1.1",
      "pali": "“Dvemā, bhikkhave, anukampā."
    },
    {
      "id": "an2.150:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.150:1.3",
      "pali": "Āmisānukampā ca dhammānukampā ca."
    },
    {
      "id": "an2.150:1.4",
      "pali": "Imā kho, bhikkhave, dve anukampā."
    },
    {
      "id": "an2.150:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ dvinnaṁ anukampānaṁ yadidaṁ dhammānukampā”ti."
    },
    {
      "id": "an2.150:1.6",
      "pali": "Dānavaggo tatiyo."
    }
  ]
}
