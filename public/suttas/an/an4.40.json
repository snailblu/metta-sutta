{
  "uid": "an4.40",
  "title": "Udāyīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.40:1.1",
      "pali": "Atha kho udāyī brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā …pe… ekamantaṁ nisinno kho udāyī brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "an4.40:1.2",
      "pali": "“bhavampi no gotamo yaññaṁ vaṇṇetī”ti?"
    },
    {
      "id": "an4.40:1.3",
      "pali": "“Na kho ahaṁ, brāhmaṇa, sabbaṁ yaññaṁ vaṇṇemi;"
    },
    {
      "id": "an4.40:1.4",
      "pali": "na panāhaṁ, brāhmaṇa, sabbaṁ yaññaṁ na vaṇṇemi."
    },
    {
      "id": "an4.40:1.5",
      "pali": "Yathārūpe kho, brāhmaṇa, yaññe gāvo haññanti, ajeḷakā haññanti, kukkuṭasūkarā haññanti, vividhā pāṇā saṅghātaṁ āpajjanti;"
    },
    {
      "id": "an4.40:1.6",
      "pali": "evarūpaṁ kho ahaṁ, brāhmaṇa, sārambhaṁ yaññaṁ na vaṇṇemi."
    },
    {
      "id": "an4.40:1.7",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an4.40:1.8",
      "pali": "Evarūpañhi, brāhmaṇa, sārambhaṁ yaññaṁ na upasaṅkamanti arahanto vā arahattamaggaṁ vā samāpannā."
    },
    {
      "id": "an4.40:2.1",
      "pali": "Yathārūpe ca kho, brāhmaṇa, yaññe neva gāvo haññanti, na ajeḷakā haññanti, na kukkuṭasūkarā haññanti, na vividhā pāṇā saṅghātaṁ āpajjanti;"
    },
    {
      "id": "an4.40:2.2",
      "pali": "evarūpaṁ kho ahaṁ, brāhmaṇa, nirārambhaṁ yaññaṁ vaṇṇemi, yadidaṁ niccadānaṁ anukulayaññaṁ."
    },
    {
      "id": "an4.40:2.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an4.40:2.4",
      "pali": "Evarūpañhi, brāhmaṇa, nirārambhaṁ yaññaṁ upasaṅkamanti arahanto vā arahattamaggaṁ vā samāpannāti."
    },
    {
      "id": "an4.40:3.1",
      "pali": "Abhisaṅkhataṁ nirārambhaṁ,"
    },
    {
      "id": "an4.40:3.2",
      "pali": "yaññaṁ kālena kappiyaṁ;"
    },
    {
      "id": "an4.40:3.3",
      "pali": "Tādisaṁ upasaṁyanti,"
    },
    {
      "id": "an4.40:3.4",
      "pali": "saññatā brahmacārayo."
    },
    {
      "id": "an4.40:4.1",
      "pali": "Vivaṭacchadā ye loke,"
    },
    {
      "id": "an4.40:4.2",
      "pali": "vītivattā kulaṁ gatiṁ;"
    },
    {
      "id": "an4.40:4.3",
      "pali": "Yaññametaṁ pasaṁsanti,"
    },
    {
      "id": "an4.40:4.4",
      "pali": "buddhā yaññassa kovidā."
    },
    {
      "id": "an4.40:5.1",
      "pali": "Yaññe vā yadi vā saddhe,"
    },
    {
      "id": "an4.40:5.2",
      "pali": "habyaṁ katvā yathārahaṁ;"
    },
    {
      "id": "an4.40:5.3",
      "pali": "Pasannacitto yajati,"
    },
    {
      "id": "an4.40:5.4",
      "pali": "sukhette brahmacārisu."
    },
    {
      "id": "an4.40:6.1",
      "pali": "Suhutaṁ suyiṭṭhaṁ suppattaṁ,"
    },
    {
      "id": "an4.40:6.2",
      "pali": "Dakkhiṇeyyesu yaṁ kataṁ;"
    },
    {
      "id": "an4.40:6.3",
      "pali": "Yañño ca vipulo hoti,"
    },
    {
      "id": "an4.40:6.4",
      "pali": "Pasīdanti ca devatā."
    },
    {
      "id": "an4.40:7.1",
      "pali": "Evaṁ yajitvā medhāvī,"
    },
    {
      "id": "an4.40:7.2",
      "pali": "saddho muttena cetasā;"
    },
    {
      "id": "an4.40:7.3",
      "pali": "Abyābajjhaṁ sukhaṁ lokaṁ,"
    },
    {
      "id": "an4.40:7.4",
      "pali": "paṇḍito upapajjatī”ti."
    },
    {
      "id": "an4.40:7.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.40:7.6",
      "pali": "Cakkavaggo catuttho."
    },
    {
      "id": "an4.40:8.1",
      "pali": "Cakko saṅgaho sīho,"
    },
    {
      "id": "an4.40:8.2",
      "pali": "Pasādo vassakārena pañcamaṁ;"
    },
    {
      "id": "an4.40:8.3",
      "pali": "Doṇo aparihāniyo patilīno,"
    },
    {
      "id": "an4.40:8.4",
      "pali": "Ujjayo udāyinā te dasāti."
    }
  ]
}
