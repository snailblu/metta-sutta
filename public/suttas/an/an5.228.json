{
  "uid": "an5.228",
  "title": "Ussūrabhattasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.228:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā ussūrabhatte kule."
    },
    {
      "id": "an5.228:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.228:1.3",
      "pali": "Ye te atithī pāhunā, te na kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:1.4",
      "pali": "yā tā balipaṭiggāhikā devatā, tā na kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:1.5",
      "pali": "ye te samaṇabrāhmaṇā ekabhattikā rattūparatā viratā vikālabhojanā, te na kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:1.6",
      "pali": "dāsakammakaraporisā vimukhā kammaṁ karonti;"
    },
    {
      "id": "an5.228:1.7",
      "pali": "tāvatakaṁyeva asamayena bhuttaṁ anojavantaṁ hoti."
    },
    {
      "id": "an5.228:1.8",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā ussūrabhatte kule."
    },
    {
      "id": "an5.228:2.1",
      "pali": "Pañcime, bhikkhave, ānisaṁsā samayabhatte kule."
    },
    {
      "id": "an5.228:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.228:2.3",
      "pali": "Ye te atithī pāhunā, te kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:2.4",
      "pali": "yā tā balipaṭiggāhikā devatā, tā kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:2.5",
      "pali": "ye te samaṇabrāhmaṇā ekabhattikā rattūparatā viratā vikālabhojanā, te kālena paṭipūjenti;"
    },
    {
      "id": "an5.228:2.6",
      "pali": "dāsakammakaraporisā avimukhā kammaṁ karonti;"
    },
    {
      "id": "an5.228:2.7",
      "pali": "tāvatakaṁyeva samayena bhuttaṁ ojavantaṁ hoti."
    },
    {
      "id": "an5.228:2.8",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā samayabhatte kule”ti."
    },
    {
      "id": "an5.228:2.9",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
