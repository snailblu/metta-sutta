{
  "uid": "an10.196",
  "title": "Bahulīkātabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.196:1.1",
      "pali": "“Bahulīkātabbañca vo, bhikkhave, dhammaṁ desessāmi na bahulīkātabbañca."
    },
    {
      "id": "an10.196:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.196:1.3",
      "pali": "katamo ca, bhikkhave, na bahulīkātabbo dhammo?"
    },
    {
      "id": "an10.196:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.196:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.196:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, na bahulīkātabbo dhammo."
    },
    {
      "id": "an10.196:2.1",
      "pali": "Katamo ca, bhikkhave, bahulīkātabbo dhammo?"
    },
    {
      "id": "an10.196:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.196:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.196:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, bahulīkātabbo dhammo”ti."
    },
    {
      "id": "an10.196:2.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
