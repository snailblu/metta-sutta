{
  "uid": "an8.10",
  "title": "Kāraṇḍavasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.10:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā campāyaṁ viharati gaggarāya pokkharaṇiyā tīre."
    },
    {
      "id": "an8.10:1.2",
      "pali": "Tena kho pana samayena bhikkhū bhikkhuṁ āpattiyā codenti."
    },
    {
      "id": "an8.10:1.3",
      "pali": "So bhikkhu bhikkhūhi āpattiyā codiyamāno aññenāññaṁ paṭicarati, bahiddhā kathaṁ apanāmeti, kopañca dosañca appaccayañca pātukaroti."
    },
    {
      "id": "an8.10:2.1",
      "pali": "Atha kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "an8.10:2.2",
      "pali": "“niddhamathetaṁ, bhikkhave, puggalaṁ;"
    },
    {
      "id": "an8.10:2.3",
      "pali": "niddhamathetaṁ, bhikkhave, puggalaṁ."
    },
    {
      "id": "an8.10:2.4",
      "pali": "Apaneyyeso, bhikkhave, puggalo."
    },
    {
      "id": "an8.10:2.5",
      "pali": "Kiṁ vo tena paraputtena visodhitena."
    },
    {
      "id": "an8.10:2.6",
      "pali": "Idha, bhikkhave, ekaccassa puggalassa tādisaṁyeva hoti abhikkantaṁ paṭikkantaṁ ālokitaṁ vilokitaṁ samiñjitaṁ pasāritaṁ saṅghāṭipattacīvaradhāraṇaṁ, seyyathāpi aññesaṁ bhaddakānaṁ bhikkhūnaṁ—"
    },
    {
      "id": "an8.10:2.7",
      "pali": "yāvassa bhikkhū āpattiṁ na passanti."
    },
    {
      "id": "an8.10:2.8",
      "pali": "Yato ca khvassa bhikkhū āpattiṁ passanti, tamenaṁ evaṁ jānanti:"
    },
    {
      "id": "an8.10:2.9",
      "pali": "‘samaṇadūsīvāyaṁ samaṇapalāpo samaṇakāraṇḍavo’ti."
    },
    {
      "id": "an8.10:2.10",
      "pali": "Tamenaṁ iti viditvā bahiddhā nāsenti."
    },
    {
      "id": "an8.10:2.11",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:2.12",
      "pali": "Mā aññe bhaddake bhikkhū dūsesīti."
    },
    {
      "id": "an8.10:3.1",
      "pali": "Seyyathāpi, bhikkhave, sampanne yavakaraṇe yavadūsī jāyetha yavapalāpo yavakāraṇḍavoti."
    },
    {
      "id": "an8.10:3.2",
      "pali": "Tassa tādisaṁyeva mūlaṁ hoti, seyyathāpi aññesaṁ bhaddakānaṁ yavānaṁ;"
    },
    {
      "id": "an8.10:3.3",
      "pali": "tādisaṁyeva nāḷaṁ hoti, seyyathāpi aññesaṁ bhaddakānaṁ yavānaṁ;"
    },
    {
      "id": "an8.10:3.4",
      "pali": "tādisaṁyeva pattaṁ hoti, seyyathāpi aññesaṁ bhaddakānaṁ yavānaṁ—"
    },
    {
      "id": "an8.10:3.5",
      "pali": "yāvassa sīsaṁ na nibbattati."
    },
    {
      "id": "an8.10:3.6",
      "pali": "Yato ca khvassa sīsaṁ nibbattati, tamenaṁ evaṁ jānanti:"
    },
    {
      "id": "an8.10:3.7",
      "pali": "‘yavadūsīvāyaṁ yavapalāpo yavakāraṇḍavo’ti."
    },
    {
      "id": "an8.10:3.8",
      "pali": "Tamenaṁ iti viditvā samūlaṁ uppāṭetvā bahiddhā yavakaraṇassa chaḍḍenti."
    },
    {
      "id": "an8.10:3.9",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:3.10",
      "pali": "Mā aññe bhaddake yave dūsesīti."
    },
    {
      "id": "an8.10:4.1",
      "pali": "Evamevaṁ kho, bhikkhave, idhekaccassa puggalassa tādisaṁyeva hoti abhikkantaṁ paṭikkantaṁ ālokitaṁ vilokitaṁ samiñjitaṁ pasāritaṁ saṅghāṭipattacīvaradhāraṇaṁ, seyyathāpi aññesaṁ bhaddakānaṁ bhikkhūnaṁ—"
    },
    {
      "id": "an8.10:4.2",
      "pali": "yāvassa bhikkhū āpattiṁ na passanti."
    },
    {
      "id": "an8.10:4.3",
      "pali": "Yato ca khvassa bhikkhū āpattiṁ passanti, tamenaṁ evaṁ jānanti:"
    },
    {
      "id": "an8.10:4.4",
      "pali": "‘samaṇadūsīvāyaṁ samaṇapalāpo samaṇakāraṇḍavo’ti."
    },
    {
      "id": "an8.10:4.5",
      "pali": "Tamenaṁ iti viditvā bahiddhā nāsenti."
    },
    {
      "id": "an8.10:4.6",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:4.7",
      "pali": "Mā aññe bhaddake bhikkhū dūsesīti."
    },
    {
      "id": "an8.10:5.1",
      "pali": "Seyyathāpi, bhikkhave, mahato dhaññarāsissa phuṇamānassa tattha yāni tāni dhaññāni daḷhāni sāravantāni tāni ekamantaṁ puñjaṁ hoti, yāni pana tāni dhaññāni dubbalāni palāpāni tāni vāto ekamantaṁ apavahati."
    },
    {
      "id": "an8.10:5.2",
      "pali": "Tamenaṁ sāmikā sammajjaniṁ gahetvā bhiyyoso mattāya apasammajjanti."
    },
    {
      "id": "an8.10:5.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:5.4",
      "pali": "Mā aññe bhaddake dhaññe dūsesīti."
    },
    {
      "id": "an8.10:5.5",
      "pali": "Evamevaṁ kho, bhikkhave, idhekaccassa puggalassa tādisaṁyeva hoti abhikkantaṁ paṭikkantaṁ ālokitaṁ vilokitaṁ samiñjitaṁ pasāritaṁ saṅghāṭipattacīvaradhāraṇaṁ, seyyathāpi aññesaṁ bhaddakānaṁ bhikkhūnaṁ—"
    },
    {
      "id": "an8.10:5.6",
      "pali": "yāvassa bhikkhū āpattiṁ na passanti."
    },
    {
      "id": "an8.10:5.7",
      "pali": "Yato ca khvassa bhikkhū āpattiṁ passanti, tamenaṁ evaṁ jānanti:"
    },
    {
      "id": "an8.10:5.8",
      "pali": "‘samaṇadūsīvāyaṁ samaṇapalāpo samaṇakāraṇḍavo’ti."
    },
    {
      "id": "an8.10:5.9",
      "pali": "Tamenaṁ iti viditvā bahiddhā nāsenti."
    },
    {
      "id": "an8.10:5.10",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:5.11",
      "pali": "Mā aññe bhaddake bhikkhū dūsesīti."
    },
    {
      "id": "an8.10:6.1",
      "pali": "Seyyathāpi, bhikkhave, puriso udapānapanāḷiyatthiko tiṇhaṁ kuṭhāriṁ ādāya vanaṁ paviseyya."
    },
    {
      "id": "an8.10:6.2",
      "pali": "So yaṁ yadeva rukkhaṁ kuṭhāripāsena ākoṭeyya tattha yāni tāni rukkhāni daḷhāni sāravantāni tāni kuṭhāripāsena ākoṭitāni kakkhaḷaṁ paṭinadanti;"
    },
    {
      "id": "an8.10:6.3",
      "pali": "yāni pana tāni rukkhāni antopūtīni avassutāni kasambujātāni tāni kuṭhāripāsena ākoṭitāni daddaraṁ paṭinadanti."
    },
    {
      "id": "an8.10:6.4",
      "pali": "Tamenaṁ mūle chindati, mūle chinditvā agge chindati, agge chinditvā anto suvisodhitaṁ visodheti, anto suvisodhitaṁ visodhetvā udapānapanāḷiṁ yojeti."
    },
    {
      "id": "an8.10:6.5",
      "pali": "Evamevaṁ kho, bhikkhave, idhekaccassa puggalassa tādisaṁyeva hoti abhikkantaṁ paṭikkantaṁ ālokitaṁ vilokitaṁ samiñjitaṁ pasāritaṁ saṅghāṭipattacīvaradhāraṇaṁ, seyyathāpi aññesaṁ bhaddakānaṁ bhikkhūnaṁ—"
    },
    {
      "id": "an8.10:6.6",
      "pali": "yāvassa bhikkhū āpattiṁ na passanti."
    },
    {
      "id": "an8.10:6.7",
      "pali": "Yato ca khvassa bhikkhū āpattiṁ passanti, tamenaṁ evaṁ jānanti:"
    },
    {
      "id": "an8.10:6.8",
      "pali": "‘samaṇadūsīvāyaṁ samaṇapalāpo samaṇakāraṇḍavo’ti."
    },
    {
      "id": "an8.10:6.9",
      "pali": "Tamenaṁ iti viditvā bahiddhā nāsenti."
    },
    {
      "id": "an8.10:6.10",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an8.10:6.11",
      "pali": "Mā aññe bhaddake bhikkhū dūsesīti."
    },
    {
      "id": "an8.10:7.1",
      "pali": "Saṁvāsāyaṁ vijānātha,"
    },
    {
      "id": "an8.10:7.2",
      "pali": "pāpiccho kodhano iti;"
    },
    {
      "id": "an8.10:7.3",
      "pali": "Makkhī thambhī paḷāsī ca,"
    },
    {
      "id": "an8.10:7.4",
      "pali": "issukī maccharī saṭho."
    },
    {
      "id": "an8.10:8.1",
      "pali": "Santavāco janavati,"
    },
    {
      "id": "an8.10:8.2",
      "pali": "samaṇo viya bhāsati;"
    },
    {
      "id": "an8.10:8.3",
      "pali": "Raho karoti karaṇaṁ,"
    },
    {
      "id": "an8.10:8.4",
      "pali": "pāpadiṭṭhi anādaro."
    },
    {
      "id": "an8.10:9.1",
      "pali": "Saṁsappī ca musāvādī,"
    },
    {
      "id": "an8.10:9.2",
      "pali": "taṁ viditvā yathātathaṁ;"
    },
    {
      "id": "an8.10:9.3",
      "pali": "Sabbe samaggā hutvāna,"
    },
    {
      "id": "an8.10:9.4",
      "pali": "abhinibbajjayātha naṁ."
    },
    {
      "id": "an8.10:10.1",
      "pali": "Kāraṇḍavaṁ niddhamatha,"
    },
    {
      "id": "an8.10:10.2",
      "pali": "Kasambuṁ apakassatha;"
    },
    {
      "id": "an8.10:10.3",
      "pali": "Tato palāpe vāhetha,"
    },
    {
      "id": "an8.10:10.4",
      "pali": "Assamaṇe samaṇamānine."
    },
    {
      "id": "an8.10:11.1",
      "pali": "Niddhamitvāna pāpicche,"
    },
    {
      "id": "an8.10:11.2",
      "pali": "pāpaācāragocare;"
    },
    {
      "id": "an8.10:11.3",
      "pali": "Suddhāsuddhehi saṁvāsaṁ,"
    },
    {
      "id": "an8.10:11.4",
      "pali": "kappayavho patissatā;"
    },
    {
      "id": "an8.10:11.5",
      "pali": "Tato samaggā nipakā,"
    },
    {
      "id": "an8.10:11.6",
      "pali": "dukkhassantaṁ karissathā”ti."
    },
    {
      "id": "an8.10:11.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an8.10:11.8",
      "pali": "Mettāvaggo paṭhamo."
    },
    {
      "id": "an8.10:12.1",
      "pali": "Mettaṁ paññā ca dve piyā,"
    },
    {
      "id": "an8.10:12.2",
      "pali": "dve lokā dve vipattiyo;"
    },
    {
      "id": "an8.10:12.3",
      "pali": "Devadatto ca uttaro,"
    },
    {
      "id": "an8.10:12.4",
      "pali": "nando kāraṇḍavena cāti."
    }
  ]
}
