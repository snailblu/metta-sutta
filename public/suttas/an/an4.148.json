{
  "uid": "an4.148",
  "title": "Duccaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.148:1.1",
      "pali": "“Cattārimāni, bhikkhave, vacīduccaritāni."
    },
    {
      "id": "an4.148:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.148:1.3",
      "pali": "Musāvādo, pisuṇā vācā, pharusā vācā, samphappalāpo—"
    },
    {
      "id": "an4.148:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri vacīduccaritānī”ti."
    },
    {
      "id": "an4.148:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
