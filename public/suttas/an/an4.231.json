{
  "uid": "an4.231",
  "title": "Kavisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.231:1.1",
      "pali": "“Cattārome, bhikkhave, kavī."
    },
    {
      "id": "an4.231:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.231:1.3",
      "pali": "Cintākavi, sutakavi, atthakavi, paṭibhānakavi—"
    },
    {
      "id": "an4.231:1.4",
      "pali": "Ime kho, bhikkhave, cattāro kavī”ti."
    },
    {
      "id": "an4.231:1.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an4.231:1.6",
      "pali": "Duccaritavaggo tatiyo."
    },
    {
      "id": "an4.231:2.1",
      "pali": "Duccaritaṁ diṭṭhi akataññū ca,"
    },
    {
      "id": "an4.231:2.2",
      "pali": "Pāṇātipātāpi dve maggā;"
    },
    {
      "id": "an4.231:2.3",
      "pali": "Dve vohārapathā vuttā,"
    },
    {
      "id": "an4.231:2.4",
      "pali": "Ahirikaṁ duppaññakavinā cāti."
    }
  ]
}
