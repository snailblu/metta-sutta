{
  "uid": "an7.82",
  "title": "Catutthavinayadharasobhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.82:1.1",
      "pali": "“Sattahi, bhikkhave, dhammehi samannāgato vinayadharo sobhati."
    },
    {
      "id": "an7.82:1.2",
      "pali": "Katamehi sattahi?"
    },
    {
      "id": "an7.82:1.3",
      "pali": "Āpattiṁ jānāti,"
    },
    {
      "id": "an7.82:1.4",
      "pali": "anāpattiṁ jānāti,"
    },
    {
      "id": "an7.82:1.5",
      "pali": "lahukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.82:1.6",
      "pali": "garukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.82:1.7",
      "pali": "anekavihitaṁ pubbenivāsaṁ anussarati, seyyathidaṁ—ekampi jātiṁ, dvepi jātiyo …pe… iti sākāraṁ sauddesaṁ anekavihitaṁ pubbenivāsaṁ anussarati,"
    },
    {
      "id": "an7.82:1.8",
      "pali": "dibbena cakkhunā visuddhena atikkantamānusakena …pe…"
    },
    {
      "id": "an7.82:1.9",
      "pali": "āsavānaṁ khayā …pe… sacchikatvā upasampajja viharati."
    },
    {
      "id": "an7.82:1.10",
      "pali": "Imehi kho, bhikkhave, sattahi dhammehi samannāgato vinayadharo sobhatī”ti."
    },
    {
      "id": "an7.82:1.11",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
