{
  "uid": "an10.138",
  "title": "Dhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.138:1.1",
      "pali": "“Dhammañca vo, bhikkhave, desessāmi adhammañca."
    },
    {
      "id": "an10.138:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.138:1.3",
      "pali": "katamo ca, bhikkhave, adhammo?"
    },
    {
      "id": "an10.138:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.138:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, adhammo."
    },
    {
      "id": "an10.138:1.6",
      "pali": "Katamo ca, bhikkhave, dhammo?"
    },
    {
      "id": "an10.138:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.138:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, dhammo”ti."
    },
    {
      "id": "an10.138:1.9",
      "pali": "Pañcamaṁ."
    }
  ]
}
