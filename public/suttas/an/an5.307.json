{
  "uid": "an5.307",
  "title": "~",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.307:1.1",
      "pali": "“Rāgassa, bhikkhave, abhiññāya pañca dhammā bhāvetabbā."
    },
    {
      "id": "an5.307:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.307:1.3",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—"
    },
    {
      "id": "an5.307:1.4",
      "pali": "rāgassa, bhikkhave, abhiññāya ime pañca dhammā bhāvetabbā”ti."
    }
  ]
}
