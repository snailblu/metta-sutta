{
  "uid": "an4.134",
  "title": "Uṭṭhānaphalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.134:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.134:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.134:1.3",
      "pali": "Uṭṭhānaphalūpajīvī na kammaphalūpajīvī,"
    },
    {
      "id": "an4.134:1.4",
      "pali": "kammaphalūpajīvī na uṭṭhānaphalūpajīvī,"
    },
    {
      "id": "an4.134:1.5",
      "pali": "uṭṭhānaphalūpajīvī ceva kammaphalūpajīvī ca,"
    },
    {
      "id": "an4.134:1.6",
      "pali": "neva uṭṭhānaphalūpajīvī na kammaphalūpajīvī—"
    },
    {
      "id": "an4.134:1.7",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.134:1.8",
      "pali": "Catutthaṁ."
    }
  ]
}
