{
  "uid": "an1.188-197",
  "title": "an1.188-197",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.188:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ rattaññūnaṁ yadidaṁ aññāsikoṇḍañño."
    },
    {
      "id": "an1.189:1.1",
      "pali": "… Mahāpaññānaṁ yadidaṁ sāriputto."
    },
    {
      "id": "an1.190:1.1",
      "pali": "… Iddhimantānaṁ yadidaṁ mahāmoggallāno."
    },
    {
      "id": "an1.191:1.1",
      "pali": "… Dhutavādānaṁ yadidaṁ mahākassapo."
    },
    {
      "id": "an1.192:1.1",
      "pali": "… Dibbacakkhukānaṁ yadidaṁ anuruddho."
    },
    {
      "id": "an1.193:1.1",
      "pali": "… Uccākulikānaṁ yadidaṁ bhaddiyo kāḷigodhāya putto."
    },
    {
      "id": "an1.194:1.1",
      "pali": "… Mañjussarānaṁ yadidaṁ lakuṇḍaka bhaddiyo."
    },
    {
      "id": "an1.195:1.1",
      "pali": "… Sīhanādikānaṁ yadidaṁ piṇḍolabhāradvājo."
    },
    {
      "id": "an1.196:1.1",
      "pali": "… Dhammakathikānaṁ yadidaṁ puṇṇo mantāṇiputto."
    },
    {
      "id": "an1.197:1.1",
      "pali": "… saṅkhittena bhāsitassa vitthārena atthaṁ vibhajantānaṁ yadidaṁ mahākaccāno”ti."
    },
    {
      "id": "an1.197:1.2",
      "pali": "Vaggo paṭhamo."
    }
  ]
}
