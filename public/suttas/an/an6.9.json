{
  "uid": "an6.9",
  "title": "Anussatiṭṭhānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.9:1.1",
      "pali": "“Chayimāni, bhikkhave, anussatiṭṭhānāni."
    },
    {
      "id": "an6.9:1.2",
      "pali": "Katamāni cha?"
    },
    {
      "id": "an6.9:1.3",
      "pali": "Buddhānussati, dhammānussati, saṅghānussati, sīlānussati, cāgānussati, devatānussati."
    },
    {
      "id": "an6.9:1.4",
      "pali": "Imāni kho, bhikkhave, cha anussatiṭṭhānānī”ti."
    },
    {
      "id": "an6.9:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
