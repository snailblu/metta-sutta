  "segments": [
    {
      "id": "an10.225-228:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgato khataṁ upahataṁ attānaṁ pariharati …pe…"
    },
    {
      "id": "an10.225-228:1.2",
      "pali": "akkhataṁ anupahataṁ attānaṁ pariharati …pe…"
    },
    {
      "id": "an10.225-228:1.3",
      "pali": "vīsatiyā, bhikkhave …pe…"
    },
    {
      "id": "an10.225-228:1.4",
      "pali": "tiṁsāya, bhikkhave …pe…"
    },
    {
      "id": "an10.225-228:1.5",
      "pali": "cattārīsāya, bhikkhave, dhammehi samannāgato khataṁ upahataṁ attānaṁ pariharati …pe…."
    },
    {
      "id": "an10.225-228:1.6",
      "pali": "(…)"
    }
  ]
}
