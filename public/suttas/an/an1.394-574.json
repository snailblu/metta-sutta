      "pali": "‘jānāmi passāmī’ti—"
    },
    {
      "id": "an1.440:1.4",
      "pali": "evaṁsaññī hoti."
    },
    {
      "id": "an1.441:1.1",
      "pali": "… ajjhattaṁ arūpasaññī bahiddhā rūpāni passati parittāni suvaṇṇadubbaṇṇāni."
