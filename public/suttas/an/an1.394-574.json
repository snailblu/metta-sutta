      "id": "an1.573:1.1",
      "pali": "samādhibalaṁ bhāveti …"
    },
    {
      "id": "an1.574:1.1",
      "pali": "paññābalaṁ bhāveti."
    },
    {
      "id": "an1.574:2.1",
      "pali": "Ayaṁ vuccati, bhikkhave:"
    },
    {
      "id": "an1.574:2.2",
      "pali": "‘bhikkhu arittajjhāno viharati satthusāsanakaro ovādapatikaro, amoghaṁ raṭṭhapiṇḍaṁ bhuñjati’."
    },
    {
      "id": "an1.574:2.3",
      "pali": "Ko pana vādo ye naṁ bahulīkarontī”ti."
    },
    {
      "id": "an1.574:2.4",
      "pali": "(Aparaaccharāsaṅghātavaggo.)"
    }
  ]
}
