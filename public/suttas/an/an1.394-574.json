      "id": "an1.439:1.1",
      "pali": "Ajjhattaṁ rūpasaññī bahiddhā rūpāni passati parittāni suvaṇṇadubbaṇṇāni."
    },
    {
      "id": "an1.439:1.2",
      "pali": "Tāni abhibhuyya:"
    },
    {
      "id": "an1.439:1.3",
      "pali": "‘jānāmi passāmī’ti—"
    },
    {
      "id": "an1.439:1.4",
      "pali": "evaṁsaññī hoti."
    },
    {
      "id": "an1.440:1.1",
      "pali": "… ajjhattaṁ rūpasaññī bahiddhā rūpāni passati appamāṇāni suvaṇṇadubbaṇṇāni."
    },
    {
      "id": "an1.440:1.2",
