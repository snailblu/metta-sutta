  "segments": [
    {
      "id": "an1.394:1.1",
      "pali": "“Accharāsaṅghātamattampi ce, bhikkhave, bhikkhu paṭhamaṁ jhānaṁ bhāveti, ayaṁ vuccati, bhikkhave:"
    },
    {
      "id": "an1.394:1.2",
      "pali": "‘bhikkhu arittajjhāno viharati, satthusāsanakaro ovādapatikaro, amoghaṁ raṭṭhapiṇḍaṁ bhuñjati’."
    },
    {
      "id": "an1.394:1.3",
      "pali": "Ko pana vādo ye naṁ bahulīkarontī”ti."
    },
    {
      "id": "an1.395:1.1",
