{
  "uid": "an7.6",
  "title": "Vitthatadhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.6:1.1",
      "pali": "“Sattimāni, bhikkhave, dhanāni."
    },
    {
      "id": "an7.6:1.2",
      "pali": "Katamāni satta?"
    },
    {
      "id": "an7.6:1.3",
      "pali": "Saddhādhanaṁ, sīladhanaṁ, hirīdhanaṁ, ottappadhanaṁ, sutadhanaṁ, cāgadhanaṁ, paññādhanaṁ."
    },
    {
      "id": "an7.6:2.1",
      "pali": "Katamañca, bhikkhave, saddhādhanaṁ?"
    },
    {
      "id": "an7.6:2.2",
      "pali": "Idha, bhikkhave, ariyasāvako saddho hoti, saddahati tathāgatassa bodhiṁ:"
    },
    {
      "id": "an7.6:2.3",
      "pali": "‘itipi so bhagavā arahaṁ sammāsambuddho …pe… buddho bhagavā’ti."
    },
    {
      "id": "an7.6:2.4",
      "pali": "Idaṁ vuccati, bhikkhave, saddhādhanaṁ."
    },
    {
      "id": "an7.6:3.1",
      "pali": "Katamañca, bhikkhave, sīladhanaṁ?"
    },
    {
      "id": "an7.6:3.2",
      "pali": "Idha, bhikkhave, ariyasāvako pāṇātipātā paṭivirato hoti …pe… surāmerayamajjapamādaṭṭhānā paṭivirato hoti."
    },
    {
      "id": "an7.6:3.3",
      "pali": "Idaṁ vuccati, bhikkhave, sīladhanaṁ."
    },
    {
      "id": "an7.6:4.1",
      "pali": "Katamañca, bhikkhave, hirīdhanaṁ?"
    },
    {
      "id": "an7.6:4.2",
      "pali": "Idha, bhikkhave, ariyasāvako hirīmā hoti, hirīyati kāyaduccaritena vacīduccaritena manoduccaritena, hirīyati pāpakānaṁ akusalānaṁ dhammānaṁ samāpattiyā."
    },
    {
      "id": "an7.6:4.3",
      "pali": "Idaṁ vuccati, bhikkhave, hirīdhanaṁ."
    },
    {
      "id": "an7.6:5.1",
      "pali": "Katamañca, bhikkhave, ottappadhanaṁ?"
    },
    {
      "id": "an7.6:5.2",
      "pali": "Idha, bhikkhave, ariyasāvako ottappī hoti, ottappati kāyaduccaritena vacīduccaritena manoduccaritena, ottappati pāpakānaṁ akusalānaṁ dhammānaṁ samāpattiyā."
    },
    {
      "id": "an7.6:5.3",
      "pali": "Idaṁ vuccati, bhikkhave, ottappadhanaṁ."
    },
    {
      "id": "an7.6:6.1",
      "pali": "Katamañca, bhikkhave, sutadhanaṁ?"
    },
    {
      "id": "an7.6:6.2",
      "pali": "Idha, bhikkhave, ariyasāvako bahussuto hoti sutadharo sutasannicayo. Ye te dhammā ādikalyāṇā majjhekalyāṇā pariyosānakalyāṇā sātthaṁ sabyañjanaṁ kevalaparipuṇṇaṁ parisuddhaṁ brahmacariyaṁ abhivadanti. Tathārūpāssa dhammā bahussutā honti dhātā vacasā paricitā manasānupekkhitā diṭṭhiyā suppaṭividdhā."
    },
    {
      "id": "an7.6:6.3",
      "pali": "Idaṁ vuccati, bhikkhave, sutadhanaṁ."
    },
    {
      "id": "an7.6:7.1",
      "pali": "Katamañca, bhikkhave, cāgadhanaṁ?"
    },
    {
      "id": "an7.6:7.2",
      "pali": "Idha, bhikkhave, ariyasāvako vigatamalamaccherena cetasā agāraṁ ajjhāvasati muttacāgo payatapāṇi vosaggarato yācayogo dānasaṁvibhāgarato."
    },
    {
      "id": "an7.6:7.3",
      "pali": "Idaṁ vuccati, bhikkhave, cāgadhanaṁ."
    },
    {
      "id": "an7.6:8.1",
      "pali": "Katamañca, bhikkhave, paññādhanaṁ?"
    },
    {
      "id": "an7.6:8.2",
      "pali": "Idha, bhikkhave, ariyasāvako paññavā hoti …pe… sammā dukkhakkhayagāminiyā."
    },
    {
      "id": "an7.6:8.3",
      "pali": "Idaṁ vuccati, bhikkhave, paññādhanaṁ."
    },
    {
      "id": "an7.6:9.1",
      "pali": "Imāni kho, bhikkhave, sattadhanānīti."
    },
    {
      "id": "an7.6:10.1",
      "pali": "Saddhādhanaṁ sīladhanaṁ,"
    },
    {
      "id": "an7.6:10.2",
      "pali": "hirī ottappiyaṁ dhanaṁ;"
    },
    {
      "id": "an7.6:10.3",
      "pali": "Sutadhanañca cāgo ca,"
    },
    {
      "id": "an7.6:10.4",
      "pali": "paññā ve sattamaṁ dhanaṁ."
    },
    {
      "id": "an7.6:11.1",
      "pali": "Yassa ete dhanā atthi,"
    },
    {
      "id": "an7.6:11.2",
      "pali": "itthiyā purisassa vā;"
    },
    {
      "id": "an7.6:11.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "an7.6:11.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "an7.6:12.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "an7.6:12.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "an7.6:12.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "an7.6:12.4",
      "pali": "saraṁ buddhāna sāsanan”ti."
    },
    {
      "id": "an7.6:12.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
