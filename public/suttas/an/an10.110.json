{
  "uid": "an10.110",
  "title": "Niddhamanīyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.110:1.1",
      "pali": "“Dasayime, bhikkhave, niddhamanīyā dhammā."
    },
    {
      "id": "an10.110:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.110:1.3",
      "pali": "Sammādiṭṭhikassa, bhikkhave, micchādiṭṭhi niddhantā hoti;"
    },
    {
      "id": "an10.110:1.4",
      "pali": "ye ca micchādiṭṭhipaccayā aneke pāpakā akusalā dhammā sambhavanti te cassa niddhantā honti;"
    },
    {
      "id": "an10.110:1.5",
      "pali": "sammādiṭṭhipaccayā ca aneke kusalā dhammā bhāvanāpāripūriṁ gacchanti."
    },
    {
      "id": "an10.110:2.1",
      "pali": "Sammāsaṅkappassa, bhikkhave, micchāsaṅkappo niddhanto hoti …pe…"
    },
    {
      "id": "an10.110:2.2",
      "pali": "sammāvācassa bhikkhave, micchāvācā niddhantā hoti …"
    },
    {
      "id": "an10.110:2.3",
      "pali": "sammākammantassa, bhikkhave, micchākammanto niddhanto hoti …"
    },
    {
      "id": "an10.110:2.4",
      "pali": "sammāājīvassa, bhikkhave, micchāājīvo niddhanto hoti …"
    },
    {
      "id": "an10.110:2.5",
      "pali": "sammāvāyāmassa, bhikkhave, micchāvāyāmo niddhanto hoti …"
    },
    {
      "id": "an10.110:2.6",
      "pali": "sammāsatissa, bhikkhave, micchāsati niddhantā hoti …"
    },
    {
      "id": "an10.110:2.7",
      "pali": "sammāsamādhissa, bhikkhave, micchāsamādhi niddhanto hoti …"
    },
    {
      "id": "an10.110:2.8",
      "pali": "sammāñāṇissa, bhikkhave, micchāñāṇaṁ niddhantaṁ hoti …."
    },
    {
      "id": "an10.110:3.1",
      "pali": "Sammāvimuttissa, bhikkhave, micchāvimutti niddhantā hoti;"
    },
    {
      "id": "an10.110:3.2",
      "pali": "ye ca micchāvimuttipaccayā aneke pāpakā akusalā dhammā sambhavanti te cassa niddhantā honti;"
    },
    {
      "id": "an10.110:3.3",
      "pali": "sammāvimuttipaccayā ca aneke kusalā dhammā bhāvanāpāripūriṁ gacchanti."
    },
    {
      "id": "an10.110:3.4",
      "pali": "Ime kho, bhikkhave, dasa niddhamanīyā dhammā”ti."
    },
    {
      "id": "an10.110:3.5",
      "pali": "Dasamaṁ."
    }
  ]
}
