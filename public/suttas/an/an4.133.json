{
  "uid": "an4.133",
  "title": "Ugghaṭitaññūsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.133:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.133:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.133:1.3",
      "pali": "Ugghaṭitaññū, vipañcitaññū, neyyo, padaparamo—"
    },
    {
      "id": "an4.133:1.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.133:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
