{
  "uid": "an4.74",
  "title": "Paṭhamaaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.74:1.1",
      "pali": "“Cattārimāni, bhikkhave, aggāni."
    },
    {
      "id": "an4.74:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.74:1.3",
      "pali": "Sīlaggaṁ, samādhiggaṁ, paññāggaṁ, vimuttaggaṁ—"
    },
    {
      "id": "an4.74:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri aggānī”ti."
    },
    {
      "id": "an4.74:1.5",
      "pali": "Catutthaṁ."
    }
  ]
}
