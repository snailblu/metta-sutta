{
  "uid": "an9.31",
  "title": "Anupubbanirodhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.31:1.1",
      "pali": "“Navayime, bhikkhave, anupubbanirodhā."
    },
    {
      "id": "an9.31:1.2",
      "pali": "Katame nava?"
    },
    {
      "id": "an9.31:1.3",
      "pali": "Paṭhamaṁ jhānaṁ samāpannassa kāmasaññā niruddhā hoti;"
    },
    {
      "id": "an9.31:1.4",
      "pali": "dutiyaṁ jhānaṁ samāpannassa vitakkavicārā niruddhā honti;"
    },
    {
      "id": "an9.31:1.5",
      "pali": "tatiyaṁ jhānaṁ samāpannassa pīti niruddhā hoti;"
    },
    {
      "id": "an9.31:1.6",
      "pali": "catutthaṁ jhānaṁ samāpannassa assāsapassāsā niruddhā honti;"
    },
    {
      "id": "an9.31:1.7",
      "pali": "ākāsānañcāyatanaṁ samāpannassa rūpasaññā niruddhā hoti;"
    },
    {
      "id": "an9.31:1.8",
      "pali": "viññāṇañcāyatanaṁ samāpannassa ākāsānañcāyatanasaññā niruddhā hoti;"
    },
    {
      "id": "an9.31:1.9",
      "pali": "ākiñcaññāyatanaṁ samāpannassa viññāṇañcāyatanasaññā niruddhā hoti;"
    },
    {
      "id": "an9.31:1.10",
      "pali": "nevasaññānāsaññāyatanaṁ samāpannassa ākiñcaññāyatanasaññā niruddhā hoti;"
    },
    {
      "id": "an9.31:1.11",
      "pali": "saññāvedayitanirodhaṁ samāpannassa saññā ca vedanā ca niruddhā honti."
    },
    {
      "id": "an9.31:1.12",
      "pali": "Ime kho, bhikkhave, nava anupubbanirodhā”ti."
    },
    {
      "id": "an9.31:1.13",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an9.31:1.14",
      "pali": "Sattāvāsavaggo tatiyo."
    },
    {
      "id": "an9.31:2.1",
      "pali": "Tiṭhānaṁ khaḷuṅko taṇhā,"
    },
    {
      "id": "an9.31:2.2",
      "pali": "Sattapaññā silāyupo;"
    },
    {
      "id": "an9.31:2.3",
      "pali": "Dve verā dve āghātāni,"
    },
    {
      "id": "an9.31:2.4",
      "pali": "Anupubbanirodhena cāti."
    }
  ]
}
