{
  "uid": "an7.11",
  "title": "Paṭhamaanusayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.11:1.1",
      "pali": "“Sattime, bhikkhave, anusayā."
    },
    {
      "id": "an7.11:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.11:1.3",
      "pali": "Kāmarāgānusayo, paṭighānusayo, diṭṭhānusayo, vicikicchānusayo, mānānusayo, bhavarāgānusayo, avijjānusayo."
    },
    {
      "id": "an7.11:1.4",
      "pali": "Ime kho, bhikkhave, satta anusayā”ti."
    },
    {
      "id": "an7.11:1.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
