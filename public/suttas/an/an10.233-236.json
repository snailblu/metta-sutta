{
  "uid": "an10.233-236",
  "title": "~",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.233-236:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgato bālo veditabbo …pe…"
    },
    {
      "id": "an10.233-236:1.2",
      "pali": "paṇḍito veditabbo …pe…"
    },
    {
      "id": "an10.233-236:1.3",
      "pali": "vīsatiyā, bhikkhave …pe…"
    },
    {
      "id": "an10.233-236:1.4",
      "pali": "tiṁsāya, bhikkhave …pe…"
    },
    {
      "id": "an10.233-236:1.5",
      "pali": "cattārīsāya, bhikkhave, dhammehi samannāgato bālo veditabbo …pe…"
    },
    {
      "id": "an10.233-236:1.6",
      "pali": "paṇḍito veditabbo …pe…"
    },
    {
      "id": "an10.233-236:1.7",
      "pali": "imehi kho, bhikkhave, cattārīsāya dhammehi samannāgato paṇḍito veditabbo”ti."
    },
    {
      "id": "an10.233-236:1.8",
      "pali": "Sāmaññavaggo dutiyo."
    }
  ]
}
