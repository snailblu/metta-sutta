{
  "uid": "an1.198-208",
  "title": "an1.198-208",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.198:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ manomayaṁ kāyaṁ abhinimminantānaṁ yadidaṁ cūḷapanthako."
    },
    {
      "id": "an1.199:1.1",
      "pali": "… Cetovivaṭṭakusalānaṁ yadidaṁ cūḷapanthako."
    },
    {
      "id": "an1.200:1.1",
      "pali": "… Saññāvivaṭṭakusalānaṁ yadidaṁ mahāpanthako."
    },
    {
      "id": "an1.201:1.1",
      "pali": "… Araṇavihārīnaṁ yadidaṁ subhūti."
    },
    {
      "id": "an1.202:1.1",
      "pali": "… Dakkhiṇeyyānaṁ yadidaṁ subhūti."
    },
    {
      "id": "an1.203:1.1",
      "pali": "… Āraññakānaṁ yadidaṁ revato khadiravaniyo."
    },
    {
      "id": "an1.204:1.1",
      "pali": "… Jhāyīnaṁ yadidaṁ kaṅkhārevato."
    },
    {
      "id": "an1.205:1.1",
      "pali": "… Āraddhavīriyānaṁ yadidaṁ soṇo koḷiviso."
    },
    {
      "id": "an1.206:1.1",
      "pali": "… Kalyāṇavākkaraṇānaṁ yadidaṁ soṇo kuṭikaṇṇo."
    },
    {
      "id": "an1.207:1.1",
      "pali": "… Lābhīnaṁ yadidaṁ sīvali."
    },
    {
      "id": "an1.208:1.1",
      "pali": "… Saddhādhimuttānaṁ yadidaṁ vakkalī”ti."
    },
    {
      "id": "an1.208:1.2",
      "pali": "Vaggo dutiyo."
    }
  ]
}
