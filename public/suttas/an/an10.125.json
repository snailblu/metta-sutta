{
  "uid": "an10.125",
  "title": "Tatiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.125:1.1",
      "pali": "“Dasayime, bhikkhave, dhammā mahapphalā mahānisaṁsā, nāññatra sugatavinayā."
    },
    {
      "id": "an10.125:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.125:1.3",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.125:1.4",
      "pali": "ime kho, bhikkhave, dasa dhammā mahapphalā mahānisaṁsā, nāññatra sugatavinayā”ti."
    },
    {
      "id": "an10.125:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
