{
  "uid": "an4.261",
  "title": "Balasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.261:1.1",
      "pali": "“Cattārimāni, bhikkhave, balāni."
    },
    {
      "id": "an4.261:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.261:1.3",
      "pali": "Vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—"
    },
    {
      "id": "an4.261:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri balānī”ti."
    },
    {
      "id": "an4.261:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
