{
  "uid": "an8.56",
  "title": "Bhayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.56:1.1",
      "pali": "“‘Bhayan’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.2",
      "pali": "‘Dukkhan’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.3",
      "pali": "‘Rogo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.4",
      "pali": "‘Gaṇḍo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.5",
      "pali": "‘Sallan’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.6",
      "pali": "‘Saṅgo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.7",
      "pali": "‘Paṅko’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.8",
      "pali": "‘Gabbho’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.9",
      "pali": "Kasmā ca, bhikkhave, ‘bhayan’ti kāmānametaṁ adhivacanaṁ?"
    },
    {
      "id": "an8.56:1.10",
      "pali": "Yasmā ca kāmarāgarattāyaṁ, bhikkhave, chandarāgavinibaddho diṭṭhadhammikāpi bhayā na parimuccati, samparāyikāpi bhayā na parimuccati, tasmā ‘bhayan’ti kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:1.11",
      "pali": "Kasmā ca, bhikkhave, ‘dukkhan’ti …pe…"
    },
    {
      "id": "an8.56:1.12",
      "pali": "‘rogo’ti …"
    },
    {
      "id": "an8.56:1.13",
      "pali": "‘gaṇḍo’ti …"
    },
    {
      "id": "an8.56:1.14",
      "pali": "‘sallan’ti …"
    },
    {
      "id": "an8.56:1.15",
      "pali": "‘saṅgo’ti …"
    },
    {
      "id": "an8.56:1.16",
      "pali": "‘paṅko’ti …"
    },
    {
      "id": "an8.56:1.17",
      "pali": "‘gabbho’ti kāmānametaṁ adhivacanaṁ?"
    },
    {
      "id": "an8.56:1.18",
      "pali": "Yasmā ca kāmarāgarattāyaṁ, bhikkhave, chandarāgavinibaddho diṭṭhadhammikāpi gabbhā na parimuccati, samparāyikāpi gabbhā na parimuccati, tasmā ‘gabbho’ti kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an8.56:2.1",
      "pali": "Bhayaṁ dukkhañca rogo ca,"
    },
    {
      "id": "an8.56:2.2",
      "pali": "gaṇḍo sallañca saṅgo ca;"
    },
    {
      "id": "an8.56:2.3",
      "pali": "Paṅko gabbho ca ubhayaṁ,"
    },
    {
      "id": "an8.56:2.4",
      "pali": "ete kāmā pavuccanti;"
    },
    {
      "id": "an8.56:2.5",
      "pali": "Yattha satto puthujjano."
    },
    {
      "id": "an8.56:3.1",
      "pali": "Otiṇṇo sātarūpena,"
    },
    {
      "id": "an8.56:3.2",
      "pali": "puna gabbhāya gacchati;"
    },
    {
      "id": "an8.56:3.3",
      "pali": "Yato ca bhikkhu ātāpī,"
    },
    {
      "id": "an8.56:3.4",
      "pali": "sampajaññaṁ na riccati."
    },
    {
      "id": "an8.56:4.1",
      "pali": "So imaṁ palipathaṁ duggaṁ,"
    },
    {
      "id": "an8.56:4.2",
      "pali": "atikkamma tathāvidho;"
    },
    {
      "id": "an8.56:4.3",
      "pali": "Pajaṁ jātijarūpetaṁ,"
    },
    {
      "id": "an8.56:4.4",
      "pali": "phandamānaṁ avekkhatī”ti."
    },
    {
      "id": "an8.56:4.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
