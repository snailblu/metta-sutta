{
  "uid": "an2.87-97",
  "title": "an2.87-97",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.87:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.87:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.87:1.3",
      "pali": "Cetovimutti ca paññāvimutti ca."
    },
    {
      "id": "an2.87:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.88:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.88:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.88:1.3",
      "pali": "Paggāho ca avikkhepo ca."
    },
    {
      "id": "an2.88:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.89:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.89:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.89:1.3",
      "pali": "Nāmañca rūpañca."
    },
    {
      "id": "an2.89:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.90:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.90:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.90:1.3",
      "pali": "Vijjā ca vimutti ca."
    },
    {
      "id": "an2.90:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.91:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.91:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.91:1.3",
      "pali": "Bhavadiṭṭhi ca vibhavadiṭṭhi ca."
    },
    {
      "id": "an2.91:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.92:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.92:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.92:1.3",
      "pali": "Ahirikañca anottappañca."
    },
    {
      "id": "an2.92:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.93:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.93:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.93:1.3",
      "pali": "Hirī ca ottappañca."
    },
    {
      "id": "an2.93:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.94:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.94:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.94:1.3",
      "pali": "Dovacassatā ca pāpamittatā ca."
    },
    {
      "id": "an2.94:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.95:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.95:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.95:1.3",
      "pali": "Sovacassatā ca kalyāṇamittatā ca."
    },
    {
      "id": "an2.95:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.96:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.96:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.96:1.3",
      "pali": "Dhātukusalatā ca manasikārakusalatā ca."
    },
    {
      "id": "an2.96:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.97:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.97:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.97:1.3",
      "pali": "Āpattikusalatā ca āpattivuṭṭhānakusalatā ca."
    },
    {
      "id": "an2.97:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.97:1.5",
      "pali": "Dhammavaggo catuttho."
    }
  ]
}
