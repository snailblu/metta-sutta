{
  "uid": "an4.43",
  "title": "Paṭhamakodhagarusutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.43:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.43:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.43:1.3",
      "pali": "Kodhagaru na saddhammagaru, makkhagaru na saddhammagaru, lābhagaru na saddhammagaru, sakkāragaru na saddhammagaru."
    },
    {
      "id": "an4.43:1.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.43:2.1",
      "pali": "Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.43:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.43:2.3",
      "pali": "Saddhammagaru na kodhagaru, saddhammagaru na makkhagaru, saddhammagaru na lābhagaru, saddhammagaru na sakkāragaru."
    },
    {
      "id": "an4.43:2.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasminti."
    },
    {
      "id": "an4.43:3.1",
      "pali": "Kodhamakkhagarū bhikkhū,"
    },
    {
      "id": "an4.43:3.2",
      "pali": "lābhasakkāragāravā;"
    },
    {
      "id": "an4.43:3.3",
      "pali": "Na te dhamme virūhanti,"
    },
    {
      "id": "an4.43:3.4",
      "pali": "sammāsambuddhadesite."
    },
    {
      "id": "an4.43:4.1",
      "pali": "Ye ca saddhammagaruno,"
    },
    {
      "id": "an4.43:4.2",
      "pali": "vihaṁsu viharanti ca;"
    },
    {
      "id": "an4.43:4.3",
      "pali": "Te ve dhamme virūhanti,"
    },
    {
      "id": "an4.43:4.4",
      "pali": "sammāsambuddhadesite”ti."
    },
    {
      "id": "an4.43:4.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
