{
  "uid": "an4.120",
  "title": "Dutiyabhayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.120:1.1",
      "pali": "“Cattārimāni, bhikkhave, bhayāni."
    },
    {
      "id": "an4.120:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.120:1.3",
      "pali": "Aggibhayaṁ, udakabhayaṁ, rājabhayaṁ, corabhayaṁ—"
    },
    {
      "id": "an4.120:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri bhayānī”ti."
    },
    {
      "id": "an4.120:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.120:1.6",
      "pali": "Kesivaggo dutiyo."
    },
    {
      "id": "an4.120:2.1",
      "pali": "Kesi javo patodo ca,"
    },
    {
      "id": "an4.120:2.2",
      "pali": "Nāgo ṭhānena pañcamaṁ;"
    },
    {
      "id": "an4.120:2.3",
      "pali": "Appamādo ca ārakkho,"
    },
    {
      "id": "an4.120:2.4",
      "pali": "Saṁvejanīyañca dve bhayāti."
    }
  ]
}
