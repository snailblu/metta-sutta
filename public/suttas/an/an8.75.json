{
  "uid": "an8.75",
  "title": "Paṭhamasampadāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.75:1.1",
      "pali": "“Aṭṭhimā, bhikkhave, sampadā."
    },
    {
      "id": "an8.75:1.2",
      "pali": "Katamā aṭṭha?"
    },
    {
      "id": "an8.75:1.3",
      "pali": "Uṭṭhānasampadā, ārakkhasampadā, kalyāṇamittatā, samajīvitā, saddhāsampadā, sīlasampadā, cāgasampadā, paññāsampadā—"
    },
    {
      "id": "an8.75:1.4",
      "pali": "imā kho, bhikkhave, aṭṭha sampadāti."
    },
    {
      "id": "an8.75:2.1",
      "pali": "Uṭṭhātā kammadheyyesu,"
    },
    {
      "id": "an8.75:2.2",
      "pali": "appamatto vidhānavā;"
    },
    {
      "id": "an8.75:2.3",
      "pali": "Samaṁ kappeti jīvikaṁ,"
    },
    {
      "id": "an8.75:2.4",
      "pali": "sambhataṁ anurakkhati."
    },
    {
      "id": "an8.75:3.1",
      "pali": "Saddho sīlena sampanno,"
    },
    {
      "id": "an8.75:3.2",
      "pali": "vadaññū vītamaccharo;"
    },
    {
      "id": "an8.75:3.3",
      "pali": "Niccaṁ maggaṁ visodheti,"
    },
    {
      "id": "an8.75:3.4",
      "pali": "sotthānaṁ samparāyikaṁ."
    },
    {
      "id": "an8.75:4.1",
      "pali": "Iccete aṭṭha dhammā ca,"
    },
    {
      "id": "an8.75:4.2",
      "pali": "saddhassa gharamesino;"
    },
    {
      "id": "an8.75:4.3",
      "pali": "Akkhātā saccanāmena,"
    },
    {
      "id": "an8.75:4.4",
      "pali": "ubhayattha sukhāvahā."
    },
    {
      "id": "an8.75:5.1",
      "pali": "Diṭṭhadhammahitatthāya,"
    },
    {
      "id": "an8.75:5.2",
      "pali": "samparāyasukhāya ca;"
    },
    {
      "id": "an8.75:5.3",
      "pali": "Evametaṁ gahaṭṭhānaṁ,"
    },
    {
      "id": "an8.75:5.4",
      "pali": "cāgo puññaṁ pavaḍḍhatī”ti."
    },
    {
      "id": "an8.75:5.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
