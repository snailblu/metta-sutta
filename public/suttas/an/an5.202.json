{
  "uid": "an5.202",
  "title": "Dhammassavanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.202:1.1",
      "pali": "“Pañcime, bhikkhave, ānisaṁsā dhammassavane."
    },
    {
      "id": "an5.202:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.202:1.3",
      "pali": "Assutaṁ suṇāti, sutaṁ pariyodāpeti, kaṅkhaṁ vitarati, diṭṭhiṁ ujuṁ karoti, cittamassa pasīdati."
    },
    {
      "id": "an5.202:1.4",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā dhammassavane”ti."
    },
    {
      "id": "an5.202:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
