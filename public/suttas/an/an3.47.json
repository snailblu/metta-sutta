{
  "uid": "an3.47",
  "title": "Saṅkhatalakkhaṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.47:1.1",
      "pali": "“Tīṇimāni, bhikkhave, saṅkhatassa saṅkhatalakkhaṇāni."
    },
    {
      "id": "an3.47:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.47:1.3",
      "pali": "Uppādo paññāyati, vayo paññāyati, ṭhitassa aññathattaṁ paññāyati."
    },
    {
      "id": "an3.47:1.4",
      "pali": "Imāni kho, bhikkhave, tīṇi saṅkhatassa saṅkhatalakkhaṇānī”ti."
    },
    {
      "id": "an3.47:1.5",
      "pali": "Sattamaṁ."
    },
    {
      "id": "an3.47:2.1",
      "pali": "“Tīṇimāni, bhikkhave, asaṅkhatassa asaṅkhatalakkhaṇāni."
    },
    {
      "id": "an3.47:2.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.47:2.3",
      "pali": "Na uppādo paññāyati, na vayo paññāyati, na ṭhitassa aññathattaṁ paññāyati."
    },
    {
      "id": "an3.47:2.4",
      "pali": "Imāni kho, bhikkhave, tīṇi asaṅkhatassa asaṅkhatalakkhaṇānī”ti."
    },
    {
      "id": "an3.47:2.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
