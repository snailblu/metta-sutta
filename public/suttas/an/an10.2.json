{
  "uid": "an10.2",
  "title": "Cetanākaraṇīyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.2:1.1",
      "pali": "“Sīlavato, bhikkhave, sīlasampannassa na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.2",
      "pali": "‘avippaṭisāro me uppajjatū’ti."
    },
    {
      "id": "an10.2:1.3",
      "pali": "Dhammatā esā, bhikkhave, yaṁ sīlavato sīlasampannassa avippaṭisāro uppajjati."
    },
    {
      "id": "an10.2:1.4",
      "pali": "Avippaṭisārissa, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.5",
      "pali": "‘pāmojjaṁ me uppajjatū’ti."
    },
    {
      "id": "an10.2:1.6",
      "pali": "Dhammatā esā, bhikkhave, yaṁ avippaṭisārissa pāmojjaṁ jāyati."
    },
    {
      "id": "an10.2:1.7",
      "pali": "Pamuditassa, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.8",
      "pali": "‘pīti me uppajjatū’ti."
    },
    {
      "id": "an10.2:1.9",
      "pali": "Dhammatā esā, bhikkhave, yaṁ pamuditassa pīti uppajjati."
    },
    {
      "id": "an10.2:1.10",
      "pali": "Pītimanassa, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.11",
      "pali": "‘kāyo me passambhatū’ti."
    },
    {
      "id": "an10.2:1.12",
      "pali": "Dhammatā esā, bhikkhave, yaṁ pītimanassa kāyo passambhati."
    },
    {
      "id": "an10.2:1.13",
      "pali": "Passaddhakāyassa, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.14",
      "pali": "‘sukhaṁ vediyāmī’ti."
    },
    {
      "id": "an10.2:1.15",
      "pali": "Dhammatā esā, bhikkhave, yaṁ passaddhakāyo sukhaṁ vediyati."
    },
    {
      "id": "an10.2:1.16",
      "pali": "Sukhino, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.17",
      "pali": "‘cittaṁ me samādhiyatū’ti."
    },
    {
      "id": "an10.2:1.18",
      "pali": "Dhammatā esā, bhikkhave, yaṁ sukhino cittaṁ samādhiyati."
    },
    {
      "id": "an10.2:1.19",
      "pali": "Samāhitassa, bhikkhave, na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.20",
      "pali": "‘yathābhūtaṁ jānāmi passāmī’ti."
    },
    {
      "id": "an10.2:1.21",
      "pali": "Dhammatā esā, bhikkhave, yaṁ samāhito yathābhūtaṁ jānāti passati."
    },
    {
      "id": "an10.2:1.22",
      "pali": "Yathābhūtaṁ, bhikkhave, jānato passato na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.23",
      "pali": "‘nibbindāmi virajjāmī’ti."
    },
    {
      "id": "an10.2:1.24",
      "pali": "Dhammatā esā, bhikkhave, yaṁ yathābhūtaṁ jānaṁ passaṁ nibbindati virajjati."
    },
    {
      "id": "an10.2:1.25",
      "pali": "Nibbinnassa, bhikkhave, virattassa na cetanāya karaṇīyaṁ:"
    },
    {
      "id": "an10.2:1.26",
      "pali": "‘vimuttiñāṇadassanaṁ sacchikaromī’ti."
    },
    {
      "id": "an10.2:1.27",
      "pali": "Dhammatā esā, bhikkhave, yaṁ nibbinno viratto vimuttiñāṇadassanaṁ sacchikaroti."
    },
    {
      "id": "an10.2:2.1",
      "pali": "Iti kho, bhikkhave, nibbidāvirāgo vimuttiñāṇadassanattho vimuttiñāṇadassanānisaṁso;"
    },
    {
      "id": "an10.2:2.2",
      "pali": "yathābhūtañāṇadassanaṁ nibbidāvirāgatthaṁ nibbidāvirāgānisaṁsaṁ;"
    },
    {
      "id": "an10.2:2.3",
      "pali": "samādhi yathābhūtañāṇadassanattho yathābhūtañāṇadassanānisaṁso;"
    },
    {
      "id": "an10.2:2.4",
      "pali": "sukhaṁ samādhatthaṁ samādhānisaṁsaṁ;"
    },
    {
      "id": "an10.2:2.5",
      "pali": "passaddhi sukhatthā sukhānisaṁsā;"
    },
    {
      "id": "an10.2:2.6",
      "pali": "pīti passaddhatthā passaddhānisaṁsā;"
    },
    {
      "id": "an10.2:2.7",
      "pali": "pāmojjaṁ pītatthaṁ pītānisaṁsaṁ;"
    },
    {
      "id": "an10.2:2.8",
      "pali": "avippaṭisāro pāmojjattho pāmojjānisaṁso;"
    },
    {
      "id": "an10.2:2.9",
      "pali": "kusalāni sīlāni avippaṭisāratthāni avippaṭisārānisaṁsāni."
    },
    {
      "id": "an10.2:2.10",
      "pali": "Iti kho, bhikkhave, dhammā dhamme abhisandenti, dhammā dhamme paripūrenti apārā pāraṁ gamanāyā”ti."
    },
    {
      "id": "an10.2:2.11",
      "pali": "Dutiyaṁ."
    }
  ]
}
