{
  "uid": "an7.5",
  "title": "Saṅkhittadhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.5:1.1",
      "pali": "“Sattimāni, bhikkhave, dhanāni."
    },
    {
      "id": "an7.5:1.2",
      "pali": "Katamāni satta?"
    },
    {
      "id": "an7.5:1.3",
      "pali": "Saddhādhanaṁ, sīladhanaṁ, hirīdhanaṁ, ottappadhanaṁ, sutadhanaṁ, cāgadhanaṁ, paññādhanaṁ."
    },
    {
      "id": "an7.5:1.4",
      "pali": "Imāni kho, bhikkhave, satta dhanānīti."
    },
    {
      "id": "an7.5:2.1",
      "pali": "Saddhādhanaṁ sīladhanaṁ,"
    },
    {
      "id": "an7.5:2.2",
      "pali": "hirī ottappiyaṁ dhanaṁ;"
    },
    {
      "id": "an7.5:2.3",
      "pali": "Sutadhanañca cāgo ca,"
    },
    {
      "id": "an7.5:2.4",
      "pali": "paññā ve sattamaṁ dhanaṁ."
    },
    {
      "id": "an7.5:3.1",
      "pali": "Yassa ete dhanā atthi,"
    },
    {
      "id": "an7.5:3.2",
      "pali": "itthiyā purisassa vā;"
    },
    {
      "id": "an7.5:3.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "an7.5:3.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "an7.5:4.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "an7.5:4.2",
      "pali": "Pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "an7.5:4.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "an7.5:4.4",
      "pali": "Saraṁ buddhāna sāsanan”ti."
    },
    {
      "id": "an7.5:4.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
