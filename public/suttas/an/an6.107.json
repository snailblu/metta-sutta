{
  "uid": "an6.107",
  "title": "Rāgasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.107:1.1",
      "pali": "“Tayome, bhikkhave, dhammā."
    },
    {
      "id": "an6.107:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.107:1.3",
      "pali": "Rāgo, doso, moho."
    },
    {
      "id": "an6.107:1.4",
      "pali": "Ime kho, bhikkhave, tayo dhammā."
    },
    {
      "id": "an6.107:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā."
    },
    {
      "id": "an6.107:1.6",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.107:1.7",
      "pali": "Rāgassa pahānāya asubhā bhāvetabbā, dosassa pahānāya mettā bhāvetabbā, mohassa pahānāya paññā bhāvetabbā."
    },
    {
      "id": "an6.107:1.8",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti."
    },
    {
      "id": "an6.107:1.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
