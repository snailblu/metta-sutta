{
  "uid": "an10.74",
  "title": "Vaḍḍhisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.74:1.1",
      "pali": "“Dasahi, bhikkhave, vaḍḍhīhi vaḍḍhamāno ariyasāvako ariyāya vaḍḍhiyā vaḍḍhati, sārādāyī ca hoti varādāyī kāyassa."
    },
    {
      "id": "an10.74:1.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.74:1.3",
      "pali": "Khettavatthūhi vaḍḍhati, dhanadhaññena vaḍḍhati, puttadārehi vaḍḍhati, dāsakammakaraporisehi vaḍḍhati, catuppadehi vaḍḍhati, saddhāya vaḍḍhati, sīlena vaḍḍhati, sutena vaḍḍhati, cāgena vaḍḍhati, paññāya vaḍḍhati—"
    },
    {
      "id": "an10.74:1.4",
      "pali": "imehi kho, bhikkhave, dasahi vaḍḍhīhi vaḍḍhamāno ariyasāvako ariyāya vaḍḍhiyā vaḍḍhati, sārādāyī ca hoti varādāyī kāyassāti."
    },
    {
      "id": "an10.74:2.1",
      "pali": "Dhanena dhaññena ca yodha vaḍḍhati,"
    },
    {
      "id": "an10.74:2.2",
      "pali": "Puttehi dārehi catuppadehi ca;"
    },
    {
      "id": "an10.74:2.3",
      "pali": "Sa bhogavā hoti yasassi pūjito,"
    },
    {
      "id": "an10.74:2.4",
      "pali": "Ñātīhi mittehi athopi rājubhi."
    },
    {
      "id": "an10.74:3.1",
      "pali": "Saddhāya sīlena ca yodha vaḍḍhati,"
    },
    {
      "id": "an10.74:3.2",
      "pali": "Paññāya cāgena sutena cūbhayaṁ;"
    },
    {
      "id": "an10.74:3.3",
      "pali": "So tādiso sappuriso vicakkhaṇo,"
    },
    {
      "id": "an10.74:3.4",
      "pali": "Diṭṭheva dhamme ubhayena vaḍḍhatī”ti."
    },
    {
      "id": "an10.74:3.5",
      "pali": "Catutthaṁ."
    }
  ]
}
