{
  "uid": "an10.49",
  "title": "Sarīraṭṭhadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.49:1.1",
      "pali": "“Dasayime, bhikkhave, dhammā sarīraṭṭhā."
    },
    {
      "id": "an10.49:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.49:1.3",
      "pali": "Sītaṁ, uṇhaṁ, jighacchā, pipāsā, uccāro, passāvo, kāyasaṁvaro, vacīsaṁvaro, ājīvasaṁvaro, ponobhaviko bhavasaṅkhāro—"
    },
    {
      "id": "an10.49:1.4",
      "pali": "ime kho, bhikkhave, dasa dhammā sarīraṭṭhā”ti."
    },
    {
      "id": "an10.49:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
