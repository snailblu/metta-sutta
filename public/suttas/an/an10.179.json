{
  "uid": "an10.179",
  "title": "Ariyadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.179:1.1",
      "pali": "“Ariyadhammañca vo, bhikkhave, desessāmi anariyadhammañca."
    },
    {
      "id": "an10.179:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.179:1.3",
      "pali": "katamo ca, bhikkhave, anariyo dhammo?"
    },
    {
      "id": "an10.179:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.179:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.179:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, anariyo dhammo."
    },
    {
      "id": "an10.179:2.1",
      "pali": "Katamo ca, bhikkhave, ariyo dhammo?"
    },
    {
      "id": "an10.179:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.179:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.179:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, ariyo dhammo”ti."
    },
    {
      "id": "an10.179:2.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
