{
  "uid": "an10.194",
  "title": "Āsevitabbadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.194:1.1",
      "pali": "“Āsevitabbañca vo, bhikkhave, dhammaṁ desessāmi nāsevitabbañca."
    },
    {
      "id": "an10.194:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.194:1.3",
      "pali": "katamo ca, bhikkhave, nāsevitabbo dhammo?"
    },
    {
      "id": "an10.194:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.194:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.194:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, nāsevitabbo dhammo."
    },
    {
      "id": "an10.194:2.1",
      "pali": "Katamo ca, bhikkhave, āsevitabbo dhammo?"
    },
    {
      "id": "an10.194:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.194:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.194:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, āsevitabbo dhammo”ti."
    },
    {
      "id": "an10.194:2.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
