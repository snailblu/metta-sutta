{
  "uid": "an10.167",
  "title": "Brāhmaṇapaccorohaṇīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.167:1.1",
      "pali": "Tena kho pana samayena jāṇussoṇi brāhmaṇo tadahuposathe sīsaṁnhāto navaṁ khomayugaṁ nivattho allakusamuṭṭhiṁ ādāya bhagavato avidūre ekamantaṁ ṭhito hoti."
    },
    {
      "id": "an10.167:2.1",
      "pali": "Addasā kho bhagavā jāṇussoṇiṁ brāhmaṇaṁ tadahuposathe sīsaṁnhātaṁ navaṁ khomayugaṁ nivatthaṁ allakusamuṭṭhiṁ ādāya ekamantaṁ ṭhitaṁ."
    },
    {
      "id": "an10.167:2.2",
      "pali": "Disvāna jāṇussoṇiṁ brāhmaṇaṁ etadavoca:"
    },
    {
      "id": "an10.167:2.3",
      "pali": "“kiṁ nu tvaṁ, brāhmaṇa, tadahuposathe sīsaṁnhāto navaṁ khomayugaṁ nivattho allakusamuṭṭhiṁ ādāya ekamantaṁ ṭhito?"
    },
    {
      "id": "an10.167:2.4",
      "pali": "Kiṁ nvajja brāhmaṇakulassā”ti?"
    },
    {
      "id": "an10.167:2.5",
      "pali": "“Paccorohaṇī, bho gotama, ajja brāhmaṇakulassā”ti."
    },
    {
      "id": "an10.167:3.1",
      "pali": "“Yathā kathaṁ pana, brāhmaṇa, brāhmaṇānaṁ paccorohaṇī hotī”ti?"
    },
    {
      "id": "an10.167:3.2",
      "pali": "“Idha, bho gotama, brāhmaṇā tadahuposathe sīsaṁnhātā navaṁ khomayugaṁ nivatthā allena gomayena pathaviṁ opuñjitvā haritehi kusehi pattharitvā antarā ca velaṁ antarā ca agyāgāraṁ seyyaṁ kappenti."
    },
    {
      "id": "an10.167:3.3",
      "pali": "Te taṁ rattiṁ tikkhattuṁ paccuṭṭhāya pañjalikā aggiṁ namassanti:"
    },
    {
      "id": "an10.167:3.4",
      "pali": "‘paccorohāma bhavantaṁ, paccorohāma bhavantan’ti."
    },
    {
      "id": "an10.167:3.5",
      "pali": "Bahukena ca sappitelanavanītena aggiṁ santappenti."
    },
    {
      "id": "an10.167:3.6",
      "pali": "Tassā ca rattiyā accayena paṇītena khādanīyena bhojanīyena brāhmaṇe santappenti."
    },
    {
      "id": "an10.167:3.7",
      "pali": "Evaṁ, bho gotama, brāhmaṇānaṁ paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.167:4.1",
      "pali": "“Aññathā kho, brāhmaṇa, brāhmaṇānaṁ paccorohaṇī hoti, aññathā ca pana ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.167:4.2",
      "pali": "“Yathā kathaṁ pana, bho gotama, ariyassa vinaye paccorohaṇī hoti?"
    },
    {
      "id": "an10.167:4.3",
      "pali": "Sādhu me bhavaṁ gotamo tathā dhammaṁ desetu yathā ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.167:5.1",
      "pali": "“Tena hi, brāhmaṇa, suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "an10.167:5.2",
      "pali": "“Evaṁ, bho”ti kho jāṇussoṇi brāhmaṇo bhagavato paccassosi."
    },
    {
      "id": "an10.167:5.3",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an10.167:6.1",
      "pali": "“Idha, brāhmaṇa, ariyasāvako iti paṭisañcikkhati:"
    },
    {
      "id": "an10.167:6.2",
      "pali": "‘pāṇātipātassa kho pāpako vipāko diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:6.3",
      "pali": "So iti paṭisaṅkhāya pāṇātipātaṁ pajahati;"
    },
    {
      "id": "an10.167:6.4",
      "pali": "pāṇātipātā paccorohati."
    },
    {
      "id": "an10.167:7.1",
      "pali": "… ‘Adinnādānassa kho pāpako vipāko—"
    },
    {
      "id": "an10.167:7.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:7.3",
      "pali": "So iti paṭisaṅkhāya adinnādānaṁ pajahati;"
    },
    {
      "id": "an10.167:7.4",
      "pali": "adinnādānā paccorohati."
    },
    {
      "id": "an10.167:8.1",
      "pali": "… ‘Kāmesumicchācārassa kho pāpako vipāko—"
    },
    {
      "id": "an10.167:8.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:8.3",
      "pali": "So iti paṭisaṅkhāya kāmesumicchācāraṁ pajahati;"
    },
    {
      "id": "an10.167:8.4",
      "pali": "kāmesumicchācārā paccorohati."
    },
    {
      "id": "an10.167:9.1",
      "pali": "… ‘Musāvādassa kho pāpako vipāko—"
    },
    {
      "id": "an10.167:9.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:9.3",
      "pali": "So iti paṭisaṅkhāya musāvādaṁ pajahati;"
    },
    {
      "id": "an10.167:9.4",
      "pali": "musāvādā paccorohati."
    },
    {
      "id": "an10.167:10.1",
      "pali": "… ‘Pisuṇāya vācāya kho pāpako vipāko—"
    },
    {
      "id": "an10.167:10.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:10.3",
      "pali": "So iti paṭisaṅkhāya pisuṇaṁ vācaṁ pajahati;"
    },
    {
      "id": "an10.167:10.4",
      "pali": "pisuṇāya vācāya paccorohati."
    },
    {
      "id": "an10.167:11.1",
      "pali": "… ‘Pharusāya vācāya kho pāpako vipāko—"
    },
    {
      "id": "an10.167:11.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:11.3",
      "pali": "So iti paṭisaṅkhāya pharusaṁ vācaṁ pajahati;"
    },
    {
      "id": "an10.167:11.4",
      "pali": "pharusāya vācāya paccorohati."
    },
    {
      "id": "an10.167:12.1",
      "pali": "… ‘Samphappalāpassa kho pāpako vipāko—"
    },
    {
      "id": "an10.167:12.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:12.3",
      "pali": "So iti paṭisaṅkhāya samphappalāpaṁ pajahati;"
    },
    {
      "id": "an10.167:12.4",
      "pali": "samphappalāpā paccorohati."
    },
    {
      "id": "an10.167:13.1",
      "pali": "… ‘Abhijjhāya kho pāpako vipāko—"
    },
    {
      "id": "an10.167:13.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:13.3",
      "pali": "So iti paṭisaṅkhāya abhijjhaṁ pajahati;"
    },
    {
      "id": "an10.167:13.4",
      "pali": "abhijjhāya paccorohati."
    },
    {
      "id": "an10.167:14.1",
      "pali": "… ‘Byāpādassa kho pāpako vipāko—"
    },
    {
      "id": "an10.167:14.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:14.3",
      "pali": "So iti paṭisaṅkhāya byāpādaṁ pajahati;"
    },
    {
      "id": "an10.167:14.4",
      "pali": "byāpādā paccorohati."
    },
    {
      "id": "an10.167:15.1",
      "pali": "… ‘Micchādiṭṭhiyā kho pāpako vipāko—"
    },
    {
      "id": "an10.167:15.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.167:15.3",
      "pali": "So iti paṭisaṅkhāya micchādiṭṭhiṁ pajahati;"
    },
    {
      "id": "an10.167:15.4",
      "pali": "micchādiṭṭhiyā paccorohati."
    },
    {
      "id": "an10.167:15.5",
      "pali": "Evaṁ kho, brāhmaṇa, ariyassa vinaye paccorohaṇī hotī”ti."
    },
    {
      "id": "an10.167:16.1",
      "pali": "“Aññathā kho, bho gotama, brāhmaṇānaṁ paccorohaṇī hoti, aññathā ca pana ariyassa vinaye paccorohaṇī hoti."
    },
    {
      "id": "an10.167:16.2",
      "pali": "Imissā, bho gotama, ariyassa vinaye paccorohaṇiyā brāhmaṇānaṁ paccorohaṇī kalaṁ nāgghati soḷasiṁ."
    },
    {
      "id": "an10.167:16.3",
      "pali": "Abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "an10.167:16.4",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    },
    {
      "id": "an10.167:16.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
