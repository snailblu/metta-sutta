{
  "uid": "an7.64",
  "title": "Kodhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.64:1.1",
      "pali": "“Sattime, bhikkhave, dhammā sapattakantā sapattakaraṇā kodhanaṁ āgacchanti itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.64:1.3",
      "pali": "Idha, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:1.4",
      "pali": "‘aho vatāyaṁ dubbaṇṇo assā’ti."
    },
    {
      "id": "an7.64:1.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:1.6",
      "pali": "Na, bhikkhave, sapatto sapattassa vaṇṇavatāya nandati."
    },
    {
      "id": "an7.64:1.7",
      "pali": "Kodhanoyaṁ, bhikkhave, purisapuggalo kodhābhibhūto kodhapareto, kiñcāpi so hoti sunhāto suvilitto kappitakesamassu odātavatthavasano;"
    },
    {
      "id": "an7.64:1.8",
      "pali": "atha kho so dubbaṇṇova hoti kodhābhibhūto."
    },
    {
      "id": "an7.64:1.9",
      "pali": "Ayaṁ, bhikkhave, paṭhamo dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:2.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:2.2",
      "pali": "‘aho vatāyaṁ dukkhaṁ sayeyyā’ti."
    },
    {
      "id": "an7.64:2.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:2.4",
      "pali": "Na, bhikkhave, sapatto sapattassa sukhaseyyāya nandati."
    },
    {
      "id": "an7.64:2.5",
      "pali": "Kodhanoyaṁ, bhikkhave, purisapuggalo kodhābhibhūto kodhapareto, kiñcāpi so pallaṅke seti gonakatthate paṭalikatthate kadalimigapavarapaccattharaṇe sauttaracchade ubhatolohitakūpadhāne;"
    },
    {
      "id": "an7.64:2.6",
      "pali": "atha kho so dukkhaññeva seti kodhābhibhūto."
    },
    {
      "id": "an7.64:2.7",
      "pali": "Ayaṁ, bhikkhave, dutiyo dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:3.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:3.2",
      "pali": "‘aho vatāyaṁ na pacurattho assā’ti."
    },
    {
      "id": "an7.64:3.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:3.4",
      "pali": "Na, bhikkhave, sapatto sapattassa pacuratthatāya nandati."
    },
    {
      "id": "an7.64:3.5",
      "pali": "Kodhanoyaṁ, bhikkhave, purisapuggalo kodhābhibhūto kodhapareto, anatthampi gahetvā ‘attho me gahito’ti maññati, atthampi gahetvā ‘anattho me gahito’ti maññati."
    },
    {
      "id": "an7.64:3.6",
      "pali": "Tassime dhammā aññamaññaṁ vipaccanīkā gahitā dīgharattaṁ ahitāya dukkhāya saṁvattanti kodhābhibhūtassa."
    },
    {
      "id": "an7.64:3.7",
      "pali": "Ayaṁ, bhikkhave, tatiyo dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:4.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:4.2",
      "pali": "‘aho vatāyaṁ na bhogavā assā’ti."
    },
    {
      "id": "an7.64:4.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:4.4",
      "pali": "Na, bhikkhave, sapatto sapattassa bhogavatāya nandati."
    },
    {
      "id": "an7.64:4.5",
      "pali": "Kodhanassa, bhikkhave, purisapuggalassa kodhābhibhūtassa kodhaparetassa, yepissa te honti bhogā uṭṭhānavīriyādhigatā bāhābalaparicitā sedāvakkhittā dhammikā dhammaladdhā, tepi rājāno rājakosaṁ pavesenti kodhābhibhūtassa."
    },
    {
      "id": "an7.64:4.6",
      "pali": "Ayaṁ, bhikkhave, catuttho dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:5.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:5.2",
      "pali": "‘aho vatāyaṁ na yasavā assā’ti."
    },
    {
      "id": "an7.64:5.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:5.4",
      "pali": "Na, bhikkhave, sapatto sapattassa yasavatāya nandati."
    },
    {
      "id": "an7.64:5.5",
      "pali": "Kodhanoyaṁ, bhikkhave, purisapuggalo kodhābhibhūto kodhapareto, yopissa so hoti yaso appamādādhigato, tamhāpi dhaṁsati kodhābhibhūto."
    },
    {
      "id": "an7.64:5.6",
      "pali": "Ayaṁ, bhikkhave, pañcamo dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:6.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:6.2",
      "pali": "‘aho vatāyaṁ na mittavā assā’ti."
    },
    {
      "id": "an7.64:6.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:6.4",
      "pali": "Na, bhikkhave, sapatto sapattassa mittavatāya nandati."
    },
    {
      "id": "an7.64:6.5",
      "pali": "Kodhanaṁ, bhikkhave, purisapuggalaṁ kodhābhibhūtaṁ kodhaparetaṁ, yepissa te honti mittāmaccā ñātisālohitā, tepi ārakā parivajjanti kodhābhibhūtaṁ."
    },
    {
      "id": "an7.64:6.6",
      "pali": "Ayaṁ, bhikkhave, chaṭṭho dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:7.1",
      "pali": "Puna caparaṁ, bhikkhave, sapatto sapattassa evaṁ icchati:"
    },
    {
      "id": "an7.64:7.2",
      "pali": "‘aho vatāyaṁ kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjeyyā’ti."
    },
    {
      "id": "an7.64:7.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an7.64:7.4",
      "pali": "Na, bhikkhave, sapatto sapattassa sugatigamane nandati."
    },
    {
      "id": "an7.64:7.5",
      "pali": "Kodhanoyaṁ, bhikkhave, purisapuggalo kodhābhibhūto kodhapareto kāyena duccaritaṁ carati, vācāya duccaritaṁ carati, manasā duccaritaṁ carati."
    },
    {
      "id": "an7.64:7.6",
      "pali": "So kāyena duccaritaṁ caritvā vācāya …pe…"
    },
    {
      "id": "an7.64:7.7",
      "pali": "kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjati kodhābhibhūto."
    },
    {
      "id": "an7.64:7.8",
      "pali": "Ayaṁ, bhikkhave, sattamo dhammo sapattakanto sapattakaraṇo kodhanaṁ āgacchati itthiṁ vā purisaṁ vā."
    },
    {
      "id": "an7.64:8.1",
      "pali": "Ime kho, bhikkhave, satta dhammā sapattakantā sapattakaraṇā kodhanaṁ āgacchanti itthiṁ vā purisaṁ vāti."
    },
    {
      "id": "an7.64:9.1",
      "pali": "Kodhano dubbaṇṇo hoti,"
    },
    {
      "id": "an7.64:9.2",
      "pali": "atho dukkhampi seti so;"
    },
    {
      "id": "an7.64:9.3",
      "pali": "Atho atthaṁ gahetvāna,"
    },
    {
      "id": "an7.64:9.4",
      "pali": "anatthaṁ adhipajjati."
    },
    {
      "id": "an7.64:10.1",
      "pali": "Tato kāyena vācāya,"
    },
    {
      "id": "an7.64:10.2",
      "pali": "vadhaṁ katvāna kodhano;"
    },
    {
      "id": "an7.64:10.3",
      "pali": "Kodhābhibhūto puriso,"
    },
    {
      "id": "an7.64:10.4",
      "pali": "dhanajāniṁ nigacchati."
    },
    {
      "id": "an7.64:11.1",
      "pali": "Kodhasammadasammatto,"
    },
    {
      "id": "an7.64:11.2",
      "pali": "āyasakyaṁ nigacchati;"
    },
    {
      "id": "an7.64:11.3",
      "pali": "Ñātimittā suhajjā ca,"
    },
    {
      "id": "an7.64:11.4",
      "pali": "parivajjanti kodhanaṁ."
    },
    {
      "id": "an7.64:12.1",
      "pali": "Anatthajanano kodho,"
    },
    {
      "id": "an7.64:12.2",
      "pali": "kodho cittappakopano;"
    },
    {
      "id": "an7.64:12.3",
      "pali": "Bhayamantarato jātaṁ,"
    },
    {
      "id": "an7.64:12.4",
      "pali": "taṁ jano nāvabujjhati."
    },
    {
      "id": "an7.64:13.1",
      "pali": "Kuddho atthaṁ na jānāti,"
    },
    {
      "id": "an7.64:13.2",
      "pali": "kuddho dhammaṁ na passati;"
    },
    {
      "id": "an7.64:13.3",
      "pali": "Andhatamaṁ tadā hoti,"
    },
    {
      "id": "an7.64:13.4",
      "pali": "yaṁ kodho sahate naraṁ."
    },
    {
      "id": "an7.64:14.1",
      "pali": "Yaṁ kuddho uparodheti,"
    },
    {
      "id": "an7.64:14.2",
      "pali": "sukaraṁ viya dukkaraṁ;"
    },
    {
      "id": "an7.64:14.3",
      "pali": "Pacchā so vigate kodhe,"
    },
    {
      "id": "an7.64:14.4",
      "pali": "aggidaḍḍhova tappati."
    },
    {
      "id": "an7.64:15.1",
      "pali": "Dummaṅkuyaṁ padasseti,"
    },
    {
      "id": "an7.64:15.2",
      "pali": "dhūmaṁ dhūmīva pāvako;"
    },
    {
      "id": "an7.64:15.3",
      "pali": "Yato patāyati kodho,"
    },
    {
      "id": "an7.64:15.4",
      "pali": "yena kujjhanti mānavā."
    },
    {
      "id": "an7.64:16.1",
      "pali": "Nāssa hirī na ottappaṁ,"
    },
    {
      "id": "an7.64:16.2",
      "pali": "na vāco hoti gāravo;"
    },
    {
      "id": "an7.64:16.3",
      "pali": "Kodhena abhibhūtassa,"
    },
    {
      "id": "an7.64:16.4",
      "pali": "na dīpaṁ hoti kiñcanaṁ."
    },
    {
      "id": "an7.64:17.1",
      "pali": "Tapanīyāni kammāni,"
    },
    {
      "id": "an7.64:17.2",
      "pali": "yāni dhammehi ārakā;"
    },
    {
      "id": "an7.64:17.3",
      "pali": "Tāni ārocayissāmi,"
    },
    {
      "id": "an7.64:17.4",
      "pali": "taṁ suṇātha yathā tathaṁ."
    },
    {
      "id": "an7.64:18.1",
      "pali": "Kuddho hi pitaraṁ hanti,"
    },
    {
      "id": "an7.64:18.2",
      "pali": "hanti kuddho samātaraṁ;"
    },
    {
      "id": "an7.64:18.3",
      "pali": "Kuddho hi brāhmaṇaṁ hanti,"
    },
    {
      "id": "an7.64:18.4",
      "pali": "hanti kuddho puthujjanaṁ."
    },
    {
      "id": "an7.64:19.1",
      "pali": "Yāya mātu bhato poso,"
    },
    {
      "id": "an7.64:19.2",
      "pali": "imaṁ lokaṁ avekkhati;"
    },
    {
      "id": "an7.64:19.3",
      "pali": "Tampi pāṇadadiṁ santiṁ,"
    },
    {
      "id": "an7.64:19.4",
      "pali": "hanti kuddho puthujjano."
    },
    {
      "id": "an7.64:20.1",
      "pali": "Attūpamā hi te sattā,"
    },
    {
      "id": "an7.64:20.2",
      "pali": "attā hi paramo piyo;"
    },
    {
      "id": "an7.64:20.3",
      "pali": "Hanti kuddho puthuttānaṁ,"
    },
    {
      "id": "an7.64:20.4",
      "pali": "nānārūpesu mucchito."
    },
    {
      "id": "an7.64:21.1",
      "pali": "Asinā hanti attānaṁ,"
    },
    {
      "id": "an7.64:21.2",
      "pali": "visaṁ khādanti mucchitā;"
    },
    {
      "id": "an7.64:21.3",
      "pali": "Rajjuyā bajjha mīyanti,"
    },
    {
      "id": "an7.64:21.4",
      "pali": "pabbatāmapi kandare."
    },
    {
      "id": "an7.64:22.1",
      "pali": "Bhūnahaccāni kammāni,"
    },
    {
      "id": "an7.64:22.2",
      "pali": "attamāraṇiyāni ca;"
    },
    {
      "id": "an7.64:22.3",
      "pali": "Karontā nāvabujjhanti,"
    },
    {
      "id": "an7.64:22.4",
      "pali": "kodhajāto parābhavo."
    },
    {
      "id": "an7.64:23.1",
      "pali": "Itāyaṁ kodharūpena,"
    },
    {
      "id": "an7.64:23.2",
      "pali": "maccupāso guhāsayo;"
    },
    {
      "id": "an7.64:23.3",
      "pali": "Taṁ damena samucchinde,"
    },
    {
      "id": "an7.64:23.4",
      "pali": "paññāvīriyena diṭṭhiyā."
    },
    {
      "id": "an7.64:24.1",
      "pali": "Yathā metaṁ akusalaṁ,"
    },
    {
      "id": "an7.64:24.2",
      "pali": "samucchindetha paṇḍito;"
    },
    {
      "id": "an7.64:24.3",
      "pali": "Tatheva dhamme sikkhetha,"
    },
    {
      "id": "an7.64:24.4",
      "pali": "mā no dummaṅkuyaṁ ahu."
    },
    {
      "id": "an7.64:25.1",
      "pali": "Vītakodhā anāyāsā,"
    },
    {
      "id": "an7.64:25.2",
      "pali": "Vītalobhā anussukā;"
    },
    {
      "id": "an7.64:25.3",
      "pali": "Dantā kodhaṁ pahantvāna,"
    },
    {
      "id": "an7.64:25.4",
      "pali": "Parinibbanti anāsavā”ti."
    },
    {
      "id": "an7.64:25.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an7.64:25.6",
      "pali": "Abyākatavaggo chaṭṭho."
    },
    {
      "id": "an7.64:26.1",
      "pali": "Abyākato purisagati,"
    },
    {
      "id": "an7.64:26.2",
      "pali": "Tissa sīha arakkhiyaṁ;"
    },
    {
      "id": "an7.64:26.3",
      "pali": "Kimilaṁ satta pacalā,"
    },
    {
      "id": "an7.64:26.4",
      "pali": "Mettā bhariyā kodhekādasāti."
    }
  ]
}
