{
  "uid": "an10.112",
  "title": "Dutiyaasekhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.112:1.1",
      "pali": "“Dasayime, bhikkhave, asekhiyā dhammā."
    },
    {
      "id": "an10.112:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.112:1.3",
      "pali": "Asekhā sammādiṭṭhi, asekho sammāsaṅkappo, asekhā sammāvācā, asekho sammākammanto, asekho sammāājīvo, asekho sammāvāyāmo, asekhā sammāsati, asekho sammāsamādhi, asekhaṁ sammāñāṇaṁ, asekhā sammāvimutti—"
    },
    {
      "id": "an10.112:1.4",
      "pali": "ime kho, bhikkhave, dasa asekhiyā dhammā”ti."
    },
    {
      "id": "an10.112:1.5",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "an10.112:1.6",
      "pali": "Samaṇasaññāvaggo paṭhamo."
    },
    {
      "id": "an10.112:2.1",
      "pali": "Saññā bojjhaṅgā micchattaṁ,"
    },
    {
      "id": "an10.112:2.2",
      "pali": "bījaṁ vijjāya nijjaraṁ;"
    },
    {
      "id": "an10.112:2.3",
      "pali": "Dhovanaṁ tikicchā vamanaṁ,"
    },
    {
      "id": "an10.112:2.4",
      "pali": "niddhamanaṁ dve asekhāti."
    }
  ]
}
