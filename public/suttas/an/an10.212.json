{
  "uid": "an10.212",
  "title": "Dutiyanirayasaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.212:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgato yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an10.212:1.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.212:1.3",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātī hoti luddo lohitapāṇi hatapahate niviṭṭho adayāpanno sabbapāṇabhūtesu."
    },
    {
      "id": "an10.212:2.1",
      "pali": "Adinnādāyī hoti …"
    },
    {
      "id": "an10.212:2.2",
      "pali": "kāmesumicchācārī hoti …"
    },
    {
      "id": "an10.212:2.3",
      "pali": "musāvādī hoti …"
    },
    {
      "id": "an10.212:2.4",
      "pali": "pisuṇavāco hoti …"
    },
    {
      "id": "an10.212:2.5",
      "pali": "pharusavāco hoti …"
    },
    {
      "id": "an10.212:2.6",
      "pali": "samphappalāpī hoti …"
    },
    {
      "id": "an10.212:2.7",
      "pali": "abhijjhālu hoti …"
    },
    {
      "id": "an10.212:2.8",
      "pali": "byāpannacitto hoti …"
    },
    {
      "id": "an10.212:2.9",
      "pali": "micchādiṭṭhiko hoti viparītadassano:"
    },
    {
      "id": "an10.212:2.10",
      "pali": "‘natthi dinnaṁ …pe…"
    },
    {
      "id": "an10.212:2.11",
      "pali": "sayaṁ abhiññā sacchikatvā pavedentī’ti."
    },
    {
      "id": "an10.212:2.12",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an10.212:3.1",
      "pali": "Dasahi, bhikkhave, dhammehi samannāgato yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "an10.212:3.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.212:3.3",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātaṁ pahāya pāṇātipātā paṭivirato hoti nihitadaṇḍo nihitasattho lajjī dayāpanno, sabbapāṇabhūtahitānukampī viharati."
    },
    {
      "id": "an10.212:4.1",
      "pali": "Adinnādānaṁ pahāya adinnādānā paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.2",
      "pali": "kāmesumicchācāraṁ pahāya kāmesumicchācārā paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.3",
      "pali": "musāvādaṁ pahāya musāvādā paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.4",
      "pali": "pisuṇaṁ vācaṁ pahāya pisuṇāya vācāya paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.5",
      "pali": "pharusaṁ vācaṁ pahāya pharusāya vācāya paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.6",
      "pali": "samphappalāpaṁ pahāya samphappalāpā paṭivirato hoti …"
    },
    {
      "id": "an10.212:4.7",
      "pali": "anabhijjhālu hoti …"
    },
    {
      "id": "an10.212:4.8",
      "pali": "abyāpannacitto hoti …"
    },
    {
      "id": "an10.212:4.9",
      "pali": "sammādiṭṭhiko hoti aviparītadassano:"
    },
    {
      "id": "an10.212:4.10",
      "pali": "‘atthi dinnaṁ …pe… ye imañca lokaṁ parañca lokaṁ sayaṁ abhiññā sacchikatvā pavedentī’ti."
    },
    {
      "id": "an10.212:4.11",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "an10.212:4.12",
      "pali": "Dutiyaṁ."
    }
  ]
}
