{
  "uid": "an6.38",
  "title": "Attakārīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.38:1.1",
      "pali": "Atha kho aññataro brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "an6.38:1.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho so brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "an6.38:1.3",
      "pali": "“ahañhi, bho gotama, evaṁvādī evaṁdiṭṭhi:"
    },
    {
      "id": "an6.38:1.4",
      "pali": "‘natthi attakāro, natthi parakāro’”ti."
    },
    {
      "id": "an6.38:1.5",
      "pali": "“Māhaṁ, brāhmaṇa, evaṁvādiṁ evaṁdiṭṭhiṁ addasaṁ vā assosiṁ vā."
    },
    {
      "id": "an6.38:1.6",
      "pali": "Kathañhi nāma sayaṁ abhikkamanto, sayaṁ paṭikkamanto evaṁ vakkhati:"
    },
    {
      "id": "an6.38:1.7",
      "pali": "‘natthi attakāro, natthi parakāro’ti."
    },
    {
      "id": "an6.38:2.1",
      "pali": "Taṁ kiṁ maññasi, brāhmaṇa, atthi ārabbhadhātū”ti?"
    },
    {
      "id": "an6.38:2.2",
      "pali": "“Evaṁ, bho”."
    },
    {
      "id": "an6.38:2.3",
      "pali": "“Ārabbhadhātuyā sati ārabbhavanto sattā paññāyantī”ti?"
    },
    {
      "id": "an6.38:2.4",
      "pali": "“Evaṁ, bho”."
    },
    {
      "id": "an6.38:2.5",
      "pali": "“Yaṁ kho, brāhmaṇa, ārabbhadhātuyā sati ārabbhavanto sattā paññāyanti, ayaṁ sattānaṁ attakāro ayaṁ parakāro."
    },
    {
      "id": "an6.38:3.1",
      "pali": "Taṁ kiṁ maññasi, brāhmaṇa, atthi nikkamadhātu …pe…"
    },
    {
      "id": "an6.38:3.2",
      "pali": "atthi parakkamadhātu …"
    },
    {
      "id": "an6.38:3.3",
      "pali": "atthi thāmadhātu …"
    },
    {
      "id": "an6.38:3.4",
      "pali": "atthi ṭhitidhātu …"
    },
    {
      "id": "an6.38:3.5",
      "pali": "atthi upakkamadhātū”ti?"
    },
    {
      "id": "an6.38:3.6",
      "pali": "“Evaṁ, bho”."
    },
    {
      "id": "an6.38:3.7",
      "pali": "“Upakkamadhātuyā sati upakkamavanto sattā paññāyantī”ti?"
    },
    {
      "id": "an6.38:3.8",
      "pali": "“Evaṁ, bho”."
    },
    {
      "id": "an6.38:3.9",
      "pali": "“Yaṁ kho, brāhmaṇa, upakkamadhātuyā sati upakkamavanto sattā paññāyanti, ayaṁ sattānaṁ attakāro ayaṁ parakāro."
    },
    {
      "id": "an6.38:4.1",
      "pali": "Māhaṁ, brāhmaṇa, evaṁvādiṁ evaṁdiṭṭhiṁ addasaṁ vā assosiṁ vā."
    },
    {
      "id": "an6.38:4.2",
      "pali": "Kathañhi nāma sayaṁ abhikkamanto sayaṁ paṭikkamanto evaṁ vakkhati:"
    },
    {
      "id": "an6.38:4.3",
      "pali": "‘natthi attakāro natthi parakāro’”ti."
    },
    {
      "id": "an6.38:5.1",
      "pali": "“Abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "an6.38:5.2",
      "pali": "ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    },
    {
      "id": "an6.38:5.3",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
