{
  "uid": "an4.232",
  "title": "Saṅkhittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.232:1.1",
      "pali": "“Cattārimāni, bhikkhave, kammāni mayā sayaṁ abhiññā sacchikatvā paveditāni."
    },
    {
      "id": "an4.232:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.232:1.3",
      "pali": "Atthi, bhikkhave, kammaṁ kaṇhaṁ kaṇhavipākaṁ;"
    },
    {
      "id": "an4.232:1.4",
      "pali": "atthi, bhikkhave, kammaṁ sukkaṁ sukkavipākaṁ;"
    },
    {
      "id": "an4.232:1.5",
      "pali": "atthi, bhikkhave, kammaṁ kaṇhasukkaṁ kaṇhasukkavipākaṁ;"
    },
    {
      "id": "an4.232:1.6",
      "pali": "atthi, bhikkhave, kammaṁ akaṇhaasukkaṁ akaṇhaasukkavipākaṁ kammakkhayāya saṁvattati."
    },
    {
      "id": "an4.232:1.7",
      "pali": "Imāni kho, bhikkhave, cattāri kammāni mayā sayaṁ abhiññā sacchikatvā paveditānī”ti."
    },
    {
      "id": "an4.232:1.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
