{
  "uid": "an4.56",
  "title": "Dutiyasamajīvīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.56:1.1",
      "pali": "“Ākaṅkheyyuñce, bhikkhave, ubho jānipatayo diṭṭhe ceva dhamme aññamaññaṁ passituṁ abhisamparāyañca aññamaññaṁ passituṁ ubhova assu samasaddhā samasīlā samacāgā samapaññā, te diṭṭhe ceva dhamme aññamaññaṁ passanti abhisamparāyañca aññamaññaṁ passantīti."
    },
    {
      "id": "an4.56:2.1",
      "pali": "Ubho saddhā vadaññū ca,"
    },
    {
      "id": "an4.56:2.2",
      "pali": "saññatā dhammajīvino;"
    },
    {
      "id": "an4.56:2.3",
      "pali": "Te honti jānipatayo,"
    },
    {
      "id": "an4.56:2.4",
      "pali": "aññamaññaṁ piyaṁvadā."
    },
    {
      "id": "an4.56:3.1",
      "pali": "Atthāsaṁ pacurā honti,"
    },
    {
      "id": "an4.56:3.2",
      "pali": "phāsukaṁ upajāyati;"
    },
    {
      "id": "an4.56:3.3",
      "pali": "Amittā dummanā honti,"
    },
    {
      "id": "an4.56:3.4",
      "pali": "ubhinnaṁ samasīlinaṁ."
    },
    {
      "id": "an4.56:4.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "an4.56:4.2",
      "pali": "samasīlabbatā ubho;"
    },
    {
      "id": "an4.56:4.3",
      "pali": "Nandino devalokasmiṁ,"
    },
    {
      "id": "an4.56:4.4",
      "pali": "modanti kāmakāmino”ti."
    },
    {
      "id": "an4.56:4.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
