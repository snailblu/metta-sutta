{
  "uid": "an4.152",
  "title": "Saddhābalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.152:1.1",
      "pali": "“Cattārimāni, bhikkhave, balāni."
    },
    {
      "id": "an4.152:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.152:1.3",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ—"
    },
    {
      "id": "an4.152:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri balānī”ti."
    },
    {
      "id": "an4.152:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
