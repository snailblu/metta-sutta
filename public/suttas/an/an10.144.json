{
  "uid": "an10.144",
  "title": "Dukkhavipākasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.144:1.1",
      "pali": "“Dukkhavipākañca vo, bhikkhave, dhammaṁ desessāmi sukhavipākañca."
    },
    {
      "id": "an10.144:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.144:1.3",
      "pali": "katamo ca, bhikkhave, dukkhavipāko dhammo?"
    },
    {
      "id": "an10.144:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.144:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhavipāko dhammo."
    },
    {
      "id": "an10.144:1.6",
      "pali": "Katamo ca, bhikkhave, sukhavipāko dhammo?"
    },
    {
      "id": "an10.144:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.144:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, sukhavipāko dhammo”ti."
    },
    {
      "id": "an10.144:1.9",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an10.144:1.10",
      "pali": "Sādhuvaggo catuttho."
    }
  ]
}
