{
  "uid": "an5.92",
  "title": "Dutiyasampadāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.92:1.1",
      "pali": "“Pañcimā, bhikkhave, sampadā."
    },
    {
      "id": "an5.92:1.2",
      "pali": "Katamā pañca?"
    },
    {
      "id": "an5.92:1.3",
      "pali": "Sīlasampadā, samādhisampadā, paññāsampadā, vimuttisampadā, vimuttiñāṇadassanasampadā—"
    },
    {
      "id": "an5.92:1.4",
      "pali": "imā kho, bhikkhave, pañca sampadā”ti."
    },
    {
      "id": "an5.92:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
