{
  "uid": "an10.180",
  "title": "Kusalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.180:1.1",
      "pali": "“Kusalañca vo, bhikkhave, desessāmi akusalañca."
    },
    {
      "id": "an10.180:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.180:1.3",
      "pali": "katamañca, bhikkhave, akusalaṁ?"
    },
    {
      "id": "an10.180:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.180:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.180:1.6",
      "pali": "idaṁ vuccati, bhikkhave, akusalaṁ."
    },
    {
      "id": "an10.180:2.1",
      "pali": "Katamañca, bhikkhave, kusalaṁ?"
    },
    {
      "id": "an10.180:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.180:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.180:2.4",
      "pali": "idaṁ vuccati, bhikkhave, kusalan”ti."
    },
    {
      "id": "an10.180:2.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
