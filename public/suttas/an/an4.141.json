{
  "uid": "an4.141",
  "title": "Ābhāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.141:1.1",
      "pali": "“Catasso imā, bhikkhave, ābhā."
    },
    {
      "id": "an4.141:1.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.141:1.3",
      "pali": "Candābhā, sūriyābhā, aggābhā, paññābhā—"
    },
    {
      "id": "an4.141:1.4",
      "pali": "imā kho, bhikkhave, catasso ābhā."
    },
    {
      "id": "an4.141:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ catunnaṁ ābhānaṁ yadidaṁ paññābhā”ti."
    },
    {
      "id": "an4.141:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
