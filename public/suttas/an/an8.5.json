{
  "uid": "an8.5",
  "title": "Paṭhamalokadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.5:1.1",
      "pali": "“Aṭṭhime, bhikkhave, lokadhammā lokaṁ anuparivattanti, loko ca aṭṭha lokadhamme anuparivattati."
    },
    {
      "id": "an8.5:1.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.5:1.3",
      "pali": "Lābho ca, alābho ca, yaso ca, ayaso ca, nindā ca, pasaṁsā ca, sukhañca, dukkhañca."
    },
    {
      "id": "an8.5:1.4",
      "pali": "Ime kho, bhikkhave, aṭṭha lokadhammā lokaṁ anuparivattanti, loko ca ime aṭṭha lokadhamme anuparivattatīti."
    },
    {
      "id": "an8.5:2.1",
      "pali": "Lābho alābho ca yasāyaso ca,"
    },
    {
      "id": "an8.5:2.2",
      "pali": "Nindā pasaṁsā ca sukhaṁ dukhañca;"
    },
    {
      "id": "an8.5:2.3",
      "pali": "Ete aniccā manujesu dhammā,"
    },
    {
      "id": "an8.5:2.4",
      "pali": "Asassatā vipariṇāmadhammā."
    },
    {
      "id": "an8.5:3.1",
      "pali": "Ete ca ñatvā satimā sumedho,"
    },
    {
      "id": "an8.5:3.2",
      "pali": "Avekkhati vipariṇāmadhamme;"
    },
    {
      "id": "an8.5:3.3",
      "pali": "Iṭṭhassa dhammā na mathenti cittaṁ,"
    },
    {
      "id": "an8.5:3.4",
      "pali": "Aniṭṭhato no paṭighātameti."
    },
    {
      "id": "an8.5:4.1",
      "pali": "Tassānurodhā atha vā virodhā,"
    },
    {
      "id": "an8.5:4.2",
      "pali": "Vidhūpitā atthaṅgatā na santi;"
    },
    {
      "id": "an8.5:4.3",
      "pali": "Padañca ñatvā virajaṁ asokaṁ,"
    },
    {
      "id": "an8.5:4.4",
      "pali": "Sammappajānāti bhavassa pāragū”ti."
    },
    {
      "id": "an8.5:4.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
