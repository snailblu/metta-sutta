{
  "uid": "an4.208",
  "title": "Dutiyapāpadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.208:1.1",
      "pali": "“Pāpañca vo, bhikkhave, desessāmi, pāpena pāpatarañca;"
    },
    {
      "id": "an4.208:1.2",
      "pali": "kalyāṇañca, kalyāṇena kalyāṇatarañca."
    },
    {
      "id": "an4.208:1.3",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an4.208:2.1",
      "pali": "“Katamo ca, bhikkhave, pāpo?"
    },
    {
      "id": "an4.208:2.2",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāñāṇī hoti, micchāvimutti hoti."
    },
    {
      "id": "an4.208:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpo."
    },
    {
      "id": "an4.208:3.1",
      "pali": "Katamo ca, bhikkhave, pāpena pāpataro?"
    },
    {
      "id": "an4.208:3.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca micchādiṭṭhiko hoti, parañca micchādiṭṭhiyā samādapeti …pe… attanā ca micchāñāṇī hoti, parañca micchāñāṇe samādapeti;"
    },
    {
      "id": "an4.208:3.3",
      "pali": "attanā ca micchāvimutti hoti, parañca micchāvimuttiyā samādapeti."
    },
    {
      "id": "an4.208:3.4",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpena pāpataro."
    },
    {
      "id": "an4.208:4.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇo?"
    },
    {
      "id": "an4.208:4.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāñāṇī hoti, sammāvimutti hoti."
    },
    {
      "id": "an4.208:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇo."
    },
    {
      "id": "an4.208:5.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇena kalyāṇataro?"
    },
    {
      "id": "an4.208:5.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca sammādiṭṭhiko hoti, parañca sammādiṭṭhiyā samādapeti …pe… attanā ca sammāñāṇī hoti, parañca sammāñāṇe samādapeti;"
    },
    {
      "id": "an4.208:5.3",
      "pali": "attanā ca sammāvimutti hoti, parañca sammāvimuttiyā samādapeti."
    },
    {
      "id": "an4.208:5.4",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇena kalyāṇataro”ti."
    },
    {
      "id": "an4.208:5.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
