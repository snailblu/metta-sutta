{
  "uid": "an5.93",
  "title": "Byākaraṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.93:1.1",
      "pali": "“Pañcimāni, bhikkhave, aññābyākaraṇāni."
    },
    {
      "id": "an5.93:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.93:1.3",
      "pali": "Mandattā momūhattā aññaṁ byākaroti;"
    },
    {
      "id": "an5.93:1.4",
      "pali": "pāpiccho icchāpakato aññaṁ byākaroti;"
    },
    {
      "id": "an5.93:1.5",
      "pali": "ummādā cittakkhepā aññaṁ byākaroti;"
    },
    {
      "id": "an5.93:1.6",
      "pali": "adhimānena aññaṁ byākaroti;"
    },
    {
      "id": "an5.93:1.7",
      "pali": "sammadeva aññaṁ byākaroti."
    },
    {
      "id": "an5.93:1.8",
      "pali": "Imāni kho, bhikkhave, pañca aññābyākaraṇānī”ti."
    },
    {
      "id": "an5.93:1.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
