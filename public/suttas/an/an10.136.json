{
  "uid": "an10.136",
  "title": "Akusalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.136:1.1",
      "pali": "“Akusalañca vo, bhikkhave, desessāmi kusalañca."
    },
    {
      "id": "an10.136:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.136:1.3",
      "pali": "katamañca, bhikkhave, akusalaṁ?"
    },
    {
      "id": "an10.136:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.136:1.5",
      "pali": "idaṁ vuccati, bhikkhave, akusalaṁ."
    },
    {
      "id": "an10.136:1.6",
      "pali": "Katamañca, bhikkhave, kusalaṁ?"
    },
    {
      "id": "an10.136:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.136:1.8",
      "pali": "idaṁ vuccati, bhikkhave, kusalan”ti."
    },
    {
      "id": "an10.136:1.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
