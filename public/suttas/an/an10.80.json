{
  "uid": "an10.80",
  "title": "Āghātapaṭivinayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.80:1.1",
      "pali": "“Dasayime, bhikkhave, āghātapaṭivinayā."
    },
    {
      "id": "an10.80:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.80:1.3",
      "pali": "‘Anatthaṁ me acari, taṁ kutettha labbhā’ti āghātaṁ paṭivineti,"
    },
    {
      "id": "an10.80:1.4",
      "pali": "‘anatthaṁ me carati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti,"
    },
    {
      "id": "an10.80:1.5",
      "pali": "‘anatthaṁ me carissati, taṁ kutettha labbhā’ti āghātaṁ paṭivineti,"
    },
    {
      "id": "an10.80:1.6",
      "pali": "piyassa me manāpassa anatthaṁ acari …pe…"
    },
    {
      "id": "an10.80:1.7",
      "pali": "carati …pe…"
    },
    {
      "id": "an10.80:1.8",
      "pali": "carissati, taṁ kutettha labbhāti āghātaṁ paṭivineti, appiyassa me amanāpassa atthaṁ acari …pe…"
    },
    {
      "id": "an10.80:1.9",
      "pali": "atthaṁ carati …pe…"
    },
    {
      "id": "an10.80:1.10",
      "pali": "atthaṁ carissati, taṁ kutettha labbhāti āghātaṁ paṭivineti,"
    },
    {
      "id": "an10.80:1.11",
      "pali": "aṭṭhāne ca na kuppati—"
    },
    {
      "id": "an10.80:1.12",
      "pali": "ime kho, bhikkhave, dasa āghātapaṭivinayā”ti."
    },
    {
      "id": "an10.80:1.13",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an10.80:1.14",
      "pali": "Ākaṅkhavaggo tatiyo."
    },
    {
      "id": "an10.80:2.1",
      "pali": "Ākaṅkho kaṇṭako iṭṭhā,"
    },
    {
      "id": "an10.80:2.2",
      "pali": "vaḍḍhi ca migasālāya;"
    },
    {
      "id": "an10.80:2.3",
      "pali": "Tayo dhammā ca kāko ca,"
    },
    {
      "id": "an10.80:2.4",
      "pali": "nigaṇṭhā dve ca āghātāti."
    }
  ]
}
