{
  "uid": "an5.60",
  "title": "Dutiyavuḍḍhapabbajitasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.60:1.1",
      "pali": "Pañcahi, bhikkhave, dhammehi samannāgato dullabho vuḍḍhapabbajito."
    },
    {
      "id": "an5.60:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.60:1.3",
      "pali": "Dullabho, bhikkhave, vuḍḍhapabbajito suvaco, dullabho suggahitaggāhī, dullabho padakkhiṇaggāhī, dullabho dhammakathiko, dullabho vinayadharo."
    },
    {
      "id": "an5.60:1.4",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato dullabho vuḍḍhapabbajito”ti."
    },
    {
      "id": "an5.60:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.60:1.6",
      "pali": "Nīvaraṇavaggo paṭhamo."
    },
    {
      "id": "an5.60:2.1",
      "pali": "Āvaraṇaṁ rāsi aṅgāni,"
    },
    {
      "id": "an5.60:2.2",
      "pali": "samayaṁ mātuputtikā;"
    },
    {
      "id": "an5.60:2.3",
      "pali": "Upajjhā ṭhānā licchavi,"
    },
    {
      "id": "an5.60:2.4",
      "pali": "kumārā aparā duveti."
    }
  ]
}
