{
  "uid": "an10.190",
  "title": "Kaṇhamaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.190:1.1",
      "pali": "“Kaṇhamaggañca vo, bhikkhave, desessāmi sukkamaggañca."
    },
    {
      "id": "an10.190:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.190:1.3",
      "pali": "katamo ca, bhikkhave, kaṇho maggo?"
    },
    {
      "id": "an10.190:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.190:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.190:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, kaṇho maggo."
    },
    {
      "id": "an10.190:2.1",
      "pali": "Katamo ca, bhikkhave, sukko maggo?"
    },
    {
      "id": "an10.190:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.190:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.190:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, sukko maggo”ti."
    },
    {
      "id": "an10.190:2.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
