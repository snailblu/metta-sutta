{
  "uid": "an5.306",
  "title": "~",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.306:1.1",
      "pali": "“Rāgassa, bhikkhave, abhiññāya pañca dhammā bhāvetabbā."
    },
    {
      "id": "an5.306:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.306:1.3",
      "pali": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—"
    },
    {
      "id": "an5.306:1.4",
      "pali": "rāgassa, bhikkhave, abhiññāya ime pañca dhammā bhāvetabbā”ti."
    }
  ]
}
