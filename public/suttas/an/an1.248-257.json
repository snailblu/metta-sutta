{
  "uid": "an1.248-257",
  "title": "an1.248-257",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.248:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ upāsakānaṁ paṭhamaṁ saraṇaṁ gacchantānaṁ yadidaṁ tapussabhallikā vāṇijā."
    },
    {
      "id": "an1.249:1.1",
      "pali": "… Dāyakānaṁ yadidaṁ sudatto gahapati anāthapiṇḍiko."
    },
    {
      "id": "an1.250:1.1",
      "pali": "… Dhammakathikānaṁ yadidaṁ citto gahapati macchikāsaṇḍiko."
    },
    {
      "id": "an1.251:1.1",
      "pali": "… Catūhi saṅgahavatthūhi parisaṁ saṅgaṇhantānaṁ yadidaṁ hatthako āḷavako."
    },
    {
      "id": "an1.252:1.1",
      "pali": "… Paṇītadāyakānaṁ yadidaṁ mahānāmo sakko."
    },
    {
      "id": "an1.253:1.1",
      "pali": "… Manāpadāyakānaṁ yadidaṁ uggo gahapati vesāliko."
    },
    {
      "id": "an1.254:1.1",
      "pali": "… Saṅghupaṭṭhākānaṁ yadidaṁ hatthigāmako uggato gahapati."
    },
    {
      "id": "an1.255:1.1",
      "pali": "… Aveccappasannānaṁ yadidaṁ sūrambaṭṭho."
    },
    {
      "id": "an1.256:1.1",
      "pali": "… Puggalappasannānaṁ yadidaṁ jīvako komārabhacco."
    },
    {
      "id": "an1.257:1.1",
      "pali": "… Vissāsakānaṁ yadidaṁ nakulapitā gahapatī”ti."
    },
    {
      "id": "an1.257:1.2",
      "pali": "Vaggo chaṭṭho."
    }
  ]
}
