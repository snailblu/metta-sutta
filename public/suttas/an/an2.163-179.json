{
  "uid": "an2.163-179",
  "title": "an2.163-179",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.163:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.163:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.163:1.3",
      "pali": "Samāpattikusalatā ca samāpattivuṭṭhānakusalatā ca."
    },
    {
      "id": "an2.163:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.164:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.164:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.164:1.3",
      "pali": "Ajjavañca maddavañca."
    },
    {
      "id": "an2.164:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.165:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.165:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.165:1.3",
      "pali": "Khanti ca soraccañca."
    },
    {
      "id": "an2.165:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.166:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.166:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.166:1.3",
      "pali": "Sākhalyañca paṭisanthāro ca."
    },
    {
      "id": "an2.166:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.167:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.167:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.167:1.3",
      "pali": "Avihiṁsā ca soceyyañca."
    },
    {
      "id": "an2.167:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.168:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.168:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.168:1.3",
      "pali": "Indriyesu aguttadvāratā ca bhojane amattaññutā ca."
    },
    {
      "id": "an2.168:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.169:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.169:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.169:1.3",
      "pali": "Indriyesu guttadvāratā ca bhojane mattaññutā ca."
    },
    {
      "id": "an2.169:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.170:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.170:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.170:1.3",
      "pali": "Paṭisaṅkhānabalañca bhāvanābalañca."
    },
    {
      "id": "an2.170:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.171:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.171:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.171:1.3",
      "pali": "Satibalañca samādhibalañca."
    },
    {
      "id": "an2.171:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.172:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.172:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.172:1.3",
      "pali": "Samatho ca vipassanā ca."
    },
    {
      "id": "an2.172:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.173:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.173:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.173:1.3",
      "pali": "Sīlavipatti ca diṭṭhivipatti ca."
    },
    {
      "id": "an2.173:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.174:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.174:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.174:1.3",
      "pali": "Sīlasampadā ca diṭṭhisampadā ca."
    },
    {
      "id": "an2.174:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.175:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.175:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.175:1.3",
      "pali": "Sīlavisuddhi ca diṭṭhivisuddhi ca."
    },
    {
      "id": "an2.175:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.176:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.176:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.176:1.3",
      "pali": "Diṭṭhivisuddhi ca yathādiṭṭhissa ca padhānaṁ."
    },
    {
      "id": "an2.176:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.177:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.177:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.177:1.3",
      "pali": "Asantuṭṭhitā ca kusalesu dhammesu, appaṭivānitā ca padhānasmiṁ."
    },
    {
      "id": "an2.177:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.178:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.178:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.178:1.3",
      "pali": "Muṭṭhassaccañca asampajaññañca."
    },
    {
      "id": "an2.178:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”."
    },
    {
      "id": "an2.179:1.1",
      "pali": "“Dveme, bhikkhave, dhammā."
    },
    {
      "id": "an2.179:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.179:1.3",
      "pali": "Sati ca sampajaññañca."
    },
    {
      "id": "an2.179:1.4",
      "pali": "Ime kho, bhikkhave, dve dhammā”ti."
    },
    {
      "id": "an2.179:1.5",
      "pali": "Samāpattivaggo pañcamo."
    },
    {
      "id": "an2.179:1.6",
      "pali": "Tatiyo paṇṇāsako samatto."
    }
  ]
}
