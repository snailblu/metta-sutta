{
  "uid": "an5.42",
  "title": "Sappurisasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.42:1.1",
      "pali": "“Sappuriso, bhikkhave, kule jāyamāno bahuno janassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:1.2",
      "pali": "mātāpitūnaṁ atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:1.3",
      "pali": "puttadārassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:1.4",
      "pali": "dāsakammakaraporisassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:1.5",
      "pali": "mittāmaccānaṁ atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:1.6",
      "pali": "samaṇabrāhmaṇānaṁ atthāya hitāya sukhāya hoti."
    },
    {
      "id": "an5.42:2.1",
      "pali": "Seyyathāpi, bhikkhave, mahāmegho sabbasassāni sampādento bahuno janassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.2",
      "pali": "evamevaṁ kho, bhikkhave, sappuriso kule jāyamāno bahuno janassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.3",
      "pali": "mātāpitūnaṁ atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.4",
      "pali": "puttadārassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.5",
      "pali": "dāsakammakaraporisassa atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.6",
      "pali": "mittāmaccānaṁ atthāya hitāya sukhāya hoti;"
    },
    {
      "id": "an5.42:2.7",
      "pali": "samaṇabrāhmaṇānaṁ atthāya hitāya sukhāya hotīti."
    },
    {
      "id": "an5.42:3.1",
      "pali": "Hito bahunnaṁ paṭipajja bhoge,"
    },
    {
      "id": "an5.42:3.2",
      "pali": "Taṁ devatā rakkhati dhammaguttaṁ;"
    },
    {
      "id": "an5.42:3.3",
      "pali": "Bahussutaṁ sīlavatūpapannaṁ,"
    },
    {
      "id": "an5.42:3.4",
      "pali": "Dhamme ṭhitaṁ na vijahati kitti."
    },
    {
      "id": "an5.42:4.1",
      "pali": "Dhammaṭṭhaṁ sīlasampannaṁ,"
    },
    {
      "id": "an5.42:4.2",
      "pali": "saccavādiṁ hirīmanaṁ;"
    },
    {
      "id": "an5.42:4.3",
      "pali": "Nekkhaṁ jambonadasseva,"
    },
    {
      "id": "an5.42:4.4",
      "pali": "ko taṁ ninditumarahati;"
    },
    {
      "id": "an5.42:4.5",
      "pali": "Devāpi naṁ pasaṁsanti,"
    },
    {
      "id": "an5.42:4.6",
      "pali": "brahmunāpi pasaṁsito”ti."
    },
    {
      "id": "an5.42:4.7",
      "pali": "Dutiyaṁ."
    }
  ]
}
