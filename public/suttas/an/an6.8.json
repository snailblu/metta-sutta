{
  "uid": "an6.8",
  "title": "Anuttariyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.8:1.1",
      "pali": "“Chayimāni, bhikkhave, anuttariyāni."
    },
    {
      "id": "an6.8:1.2",
      "pali": "Katamāni cha?"
    },
    {
      "id": "an6.8:1.3",
      "pali": "Dassanānuttariyaṁ, savanānuttariyaṁ, lābhānuttariyaṁ, sikkhānuttariyaṁ, pāricariyānuttariyaṁ, anussatānuttariyaṁ."
    },
    {
      "id": "an6.8:1.4",
      "pali": "Imāni kho, bhikkhave, cha anuttariyānī”ti."
    },
    {
      "id": "an6.8:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
