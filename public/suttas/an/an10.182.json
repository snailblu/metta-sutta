{
  "uid": "an10.182",
  "title": "Dhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.182:1.1",
      "pali": "“Dhammañca vo, bhikkhave, desessāmi adhammañca."
    },
    {
      "id": "an10.182:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.182:1.3",
      "pali": "katamo ca, bhikkhave, adhammo?"
    },
    {
      "id": "an10.182:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.182:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.182:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, adhammo."
    },
    {
      "id": "an10.182:2.1",
      "pali": "Katamo ca, bhikkhave, dhammo?"
    },
    {
      "id": "an10.182:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.182:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.182:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, dhammo”ti."
    },
    {
      "id": "an10.182:2.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
