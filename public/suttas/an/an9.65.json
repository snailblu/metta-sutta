{
  "uid": "an9.65",
  "title": "Kāmaguṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.65:1.1",
      "pali": "“Pañcime, bhikkhave, kāmaguṇā."
    },
    {
      "id": "an9.65:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an9.65:1.3",
      "pali": "Cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā,"
    },
    {
      "id": "an9.65:1.4",
      "pali": "sotaviññeyyā saddā …pe…"
    },
    {
      "id": "an9.65:1.5",
      "pali": "ghānaviññeyyā gandhā …"
    },
    {
      "id": "an9.65:1.6",
      "pali": "jivhāviññeyyā rasā …"
    },
    {
      "id": "an9.65:1.7",
      "pali": "kāyaviññeyyā phoṭṭhabbā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "an9.65:1.8",
      "pali": "Ime kho, bhikkhave, pañca kāmaguṇā."
    },
    {
      "id": "an9.65:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ kāmaguṇānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.65:2.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
