{
  "uid": "an10.192",
  "title": "Sappurisadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.192:1.1",
      "pali": "“Sappurisadhammañca vo, bhikkhave, desessāmi asappurisadhammañca."
    },
    {
      "id": "an10.192:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.192:1.3",
      "pali": "katamo ca, bhikkhave, asappurisadhammo?"
    },
    {
      "id": "an10.192:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.192:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.192:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, asappurisadhammo."
    },
    {
      "id": "an10.192:2.1",
      "pali": "Katamo ca, bhikkhave, sappurisadhammo?"
    },
    {
      "id": "an10.192:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.192:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.192:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, sappurisadhammo”ti."
    },
    {
      "id": "an10.192:2.5",
      "pali": "Catutthaṁ."
    }
  ]
}
