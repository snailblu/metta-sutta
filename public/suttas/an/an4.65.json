{
  "uid": "an4.65",
  "title": "Rūpasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.65:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.65:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.65:1.3",
      "pali": "Rūpappamāṇo rūpappasanno, ghosappamāṇo ghosappasanno, lūkhappamāṇo lūkhappasanno, dhammappamāṇo dhammappasanno—"
    },
    {
      "id": "an4.65:1.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasminti."
    },
    {
      "id": "an4.65:2.1",
      "pali": "Ye ca rūpe pamāṇiṁsu,"
    },
    {
      "id": "an4.65:2.2",
      "pali": "ye ca ghosena anvagū;"
    },
    {
      "id": "an4.65:2.3",
      "pali": "Chandarāgavasūpetā,"
    },
    {
      "id": "an4.65:2.4",
      "pali": "nābhijānanti te janā."
    },
    {
      "id": "an4.65:3.1",
      "pali": "Ajjhattañca na jānāti,"
    },
    {
      "id": "an4.65:3.2",
      "pali": "bahiddhā ca na passati;"
    },
    {
      "id": "an4.65:3.3",
      "pali": "Samantāvaraṇo bālo,"
    },
    {
      "id": "an4.65:3.4",
      "pali": "sa ve ghosena vuyhati."
    },
    {
      "id": "an4.65:4.1",
      "pali": "Ajjhattañca na jānāti,"
    },
    {
      "id": "an4.65:4.2",
      "pali": "bahiddhā ca vipassati;"
    },
    {
      "id": "an4.65:4.3",
      "pali": "Bahiddhā phaladassāvī,"
    },
    {
      "id": "an4.65:4.4",
      "pali": "sopi ghosena vuyhati."
    },
    {
      "id": "an4.65:5.1",
      "pali": "Ajjhattañca pajānāti,"
    },
    {
      "id": "an4.65:5.2",
      "pali": "bahiddhā ca vipassati;"
    },
    {
      "id": "an4.65:5.3",
      "pali": "Vinīvaraṇadassāvī,"
    },
    {
      "id": "an4.65:5.4",
      "pali": "na so ghosena vuyhatī”ti."
    },
    {
      "id": "an4.65:5.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
