{
  "uid": "an8.60",
  "title": "Dutiyapuggalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.60:1.1",
      "pali": "“Aṭṭhime, bhikkhave, puggalā āhuneyyā …pe… anuttaraṁ puññakkhettaṁ lokassa."
    },
    {
      "id": "an8.60:1.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.60:1.3",
      "pali": "Sotāpanno, sotāpattiphalasacchikiriyāya paṭipanno …pe… arahā, arahattāya paṭipanno."
    },
    {
      "id": "an8.60:1.4",
      "pali": "Ime kho, bhikkhave, aṭṭha puggalā āhuneyyā …pe… anuttaraṁ puññakkhettaṁ lokassāti."
    },
    {
      "id": "an8.60:2.1",
      "pali": "Cattāro ca paṭipannā,"
    },
    {
      "id": "an8.60:2.2",
      "pali": "cattāro ca phale ṭhitā;"
    },
    {
      "id": "an8.60:2.3",
      "pali": "Esa saṅgho samukkaṭṭho,"
    },
    {
      "id": "an8.60:2.4",
      "pali": "sattānaṁ aṭṭha puggalā."
    },
    {
      "id": "an8.60:3.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "an8.60:3.2",
      "pali": "puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "an8.60:3.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "an8.60:3.4",
      "pali": "ettha dinnaṁ mahapphalan”ti."
    },
    {
      "id": "an8.60:3.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an8.60:3.6",
      "pali": "Gotamīvaggo paṭhamo."
    },
    {
      "id": "an8.60:4.1",
      "pali": "Gotamī ovādaṁ saṅkhittaṁ,"
    },
    {
      "id": "an8.60:4.2",
      "pali": "dīghajāṇu ca ujjayo;"
    },
    {
      "id": "an8.60:4.3",
      "pali": "Bhayā dve āhuneyyā ca,"
    },
    {
      "id": "an8.60:4.4",
      "pali": "dve ca aṭṭha puggalāti."
    }
  ]
}
