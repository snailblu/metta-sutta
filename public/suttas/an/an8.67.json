{
  "uid": "an8.67",
  "title": "Anariyavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.67:1.1",
      "pali": "“Aṭṭhime, bhikkhave, anariyavohārā."
    },
    {
      "id": "an8.67:1.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.67:1.3",
      "pali": "Adiṭṭhe diṭṭhavāditā, asute sutavāditā, amute mutavāditā, aviññāte viññātavāditā, diṭṭhe adiṭṭhavāditā, sute asutavāditā, mute amutavāditā, viññāte aviññātavāditā."
    },
    {
      "id": "an8.67:1.4",
      "pali": "Ime kho, bhikkhave, aṭṭha anariyavohārā”ti."
    },
    {
      "id": "an8.67:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
