{
  "uid": "an3.85",
  "title": "Sekkhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.85:1.1",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "an3.85:2.1",
      "pali": "“‘Sekho, sekho’ti, bhante, vuccati."
    },
    {
      "id": "an3.85:2.2",
      "pali": "Kittāvatā nu kho, bhante, sekho hotī”ti?"
    },
    {
      "id": "an3.85:2.3",
      "pali": "“Sikkhatīti kho, bhikkhu, tasmā sekhoti vuccati."
    },
    {
      "id": "an3.85:2.4",
      "pali": "Kiñca sikkhati?"
    },
    {
      "id": "an3.85:2.5",
      "pali": "Adhisīlampi sikkhati, adhicittampi sikkhati, adhipaññampi sikkhati."
    },
    {
      "id": "an3.85:2.6",
      "pali": "Sikkhatīti kho, bhikkhu, tasmā sekhoti vuccatīti."
    },
    {
      "id": "an3.85:3.1",
      "pali": "Sekhassa sikkhamānassa,"
    },
    {
      "id": "an3.85:3.2",
      "pali": "ujumaggānusārino;"
    },
    {
      "id": "an3.85:3.3",
      "pali": "Khayasmiṁ paṭhamaṁ ñāṇaṁ,"
    },
    {
      "id": "an3.85:3.4",
      "pali": "tato aññā anantarā."
    },
    {
      "id": "an3.85:4.1",
      "pali": "Tato aññāvimuttassa,"
    },
    {
      "id": "an3.85:4.2",
      "pali": "ñāṇaṁ ve hoti tādino;"
    },
    {
      "id": "an3.85:4.3",
      "pali": "Akuppā me vimuttīti,"
    },
    {
      "id": "an3.85:4.4",
      "pali": "bhavasaṁyojanakkhaye”ti."
    },
    {
      "id": "an3.85:4.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
