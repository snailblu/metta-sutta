{
  "uid": "an4.18",
  "title": "Dutiyaagatisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.18:1.1",
      "pali": "“Cattārimāni, bhikkhave, nāgatigamanāni."
    },
    {
      "id": "an4.18:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.18:1.3",
      "pali": "Na chandāgatiṁ gacchati, na dosāgatiṁ gacchati, na mohāgatiṁ gacchati, na bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.18:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri nāgatigamanānīti."
    },
    {
      "id": "an4.18:2.1",
      "pali": "Chandā dosā bhayā mohā,"
    },
    {
      "id": "an4.18:2.2",
      "pali": "yo dhammaṁ nātivattati;"
    },
    {
      "id": "an4.18:2.3",
      "pali": "Āpūrati tassa yaso,"
    },
    {
      "id": "an4.18:2.4",
      "pali": "sukkapakkheva candimā”ti."
    },
    {
      "id": "an4.18:2.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
