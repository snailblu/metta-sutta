{
  "uid": "an10.100",
  "title": "Abhabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.100:1.1",
      "pali": "“Dasayime, bhikkhave, dhamme appahāya abhabbo arahattaṁ sacchikātuṁ."
    },
    {
      "id": "an10.100:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.100:1.3",
      "pali": "Rāgaṁ, dosaṁ, mohaṁ, kodhaṁ, upanāhaṁ, makkhaṁ, paḷāsaṁ, issaṁ, macchariyaṁ, mānaṁ—"
    },
    {
      "id": "an10.100:1.4",
      "pali": "ime kho, bhikkhave, dasa dhamme appahāya abhabbo arahattaṁ sacchikātuṁ."
    },
    {
      "id": "an10.100:2.1",
      "pali": "Dasayime, bhikkhave, dhamme pahāya bhabbo arahattaṁ sacchikātuṁ."
    },
    {
      "id": "an10.100:2.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.100:2.3",
      "pali": "Rāgaṁ, dosaṁ, mohaṁ, kodhaṁ, upanāhaṁ, makkhaṁ, paḷāsaṁ, issaṁ, macchariyaṁ, mānaṁ—"
    },
    {
      "id": "an10.100:2.4",
      "pali": "ime kho, bhikkhave, dasa dhamme pahāya bhabbo arahattaṁ sacchikātun”ti."
    },
    {
      "id": "an10.100:2.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an10.100:2.6",
      "pali": "Upālivaggo pañcamo."
    },
    {
      "id": "an10.100:3.1",
      "pali": "Kāmabhogī bhayaṁ diṭṭhi,"
    },
    {
      "id": "an10.100:3.2",
      "pali": "vajjiyamāhituttiyā;"
    },
    {
      "id": "an10.100:3.3",
      "pali": "Kokanudo āhuneyyo,"
    },
    {
      "id": "an10.100:3.4",
      "pali": "thero upāli abhabboti."
    },
    {
      "id": "an10.100:3.5",
      "pali": "Dutiyo paṇṇāsako samatto."
    }
  ]
}
