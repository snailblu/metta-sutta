{
  "uid": "an4.132",
  "title": "Paṭibhānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.132:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.132:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.132:1.3",
      "pali": "Yuttappaṭibhāno, no muttappaṭibhāno;"
    },
    {
      "id": "an4.132:1.4",
      "pali": "muttappaṭibhāno, no yuttappaṭibhāno;"
    },
    {
      "id": "an4.132:1.5",
      "pali": "yuttappaṭibhāno ca muttappaṭibhāno ca;"
    },
    {
      "id": "an4.132:1.6",
      "pali": "neva yuttappaṭibhāno na muttappaṭibhāno—"
    },
    {
      "id": "an4.132:1.7",
      "pali": "ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.132:1.8",
      "pali": "Dutiyaṁ."
    }
  ]
}
