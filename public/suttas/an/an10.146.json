{
  "uid": "an10.146",
  "title": "Kaṇhamaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.146:1.1",
      "pali": "“Kaṇhamaggañca vo, bhikkhave, dhammaṁ desessāmi sukkamaggañca."
    },
    {
      "id": "an10.146:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.146:1.3",
      "pali": "katamo ca, bhikkhave, kaṇhamaggo?"
    },
    {
      "id": "an10.146:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.146:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, kaṇhamaggo."
    },
    {
      "id": "an10.146:1.6",
      "pali": "Katamo ca, bhikkhave, sukkamaggo?"
    },
    {
      "id": "an10.146:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.146:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, sukkamaggo”ti."
    },
    {
      "id": "an10.146:1.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
