{
  "uid": "an6.118",
  "title": "Dhammānupassīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.118:1.1",
      "pali": "“Cha, bhikkhave, dhamme appahāya abhabbo ajjhattaṁ kāye …pe…"
    },
    {
      "id": "an6.118:1.2",
      "pali": "bahiddhā kāye …pe…"
    },
    {
      "id": "an6.118:1.3",
      "pali": "ajjhattabahiddhā kāye …pe…"
    },
    {
      "id": "an6.118:1.4",
      "pali": "ajjhattaṁ vedanāsu …pe…"
    },
    {
      "id": "an6.118:1.5",
      "pali": "bahiddhā vedanāsu …pe…"
    },
    {
      "id": "an6.118:1.6",
      "pali": "ajjhattabahiddhā vedanāsu …pe…"
    },
    {
      "id": "an6.118:1.7",
      "pali": "ajjhattaṁ citte …pe…"
    },
    {
      "id": "an6.118:1.8",
      "pali": "bahiddhā citte …pe…"
    },
    {
      "id": "an6.118:1.9",
      "pali": "ajjhattabahiddhā citte …pe…"
    },
    {
      "id": "an6.118:1.10",
      "pali": "ajjhattaṁ dhammesu …pe…"
    },
    {
      "id": "an6.118:1.11",
      "pali": "bahiddhā dhammesu …pe…"
    },
    {
      "id": "an6.118:1.12",
      "pali": "ajjhattabahiddhā dhammesu dhammānupassī viharituṁ."
    },
    {
      "id": "an6.118:1.13",
      "pali": "Katame cha?"
    },
    {
      "id": "an6.118:1.14",
      "pali": "Kammārāmataṁ, bhassārāmataṁ, niddārāmataṁ, saṅgaṇikārāmataṁ, indriyesu aguttadvārataṁ, bhojane amattaññutaṁ."
    },
    {
      "id": "an6.118:1.15",
      "pali": "Ime kho, bhikkhave, cha dhamme pahāya bhabbo ajjhattabahiddhā dhammesu dhammānupassī viharitun”ti."
    },
    {
      "id": "an6.118:1.16",
      "pali": "Dutiyaṁ."
    }
  ]
}
