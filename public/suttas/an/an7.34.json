{
  "uid": "an7.34",
  "title": "Paṭhamasovacassatāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.34:1.1",
      "pali": "“Imaṁ, bhikkhave, rattiṁ aññatarā devatā …pe… maṁ etadavoca:"
    },
    {
      "id": "an7.34:1.2",
      "pali": "‘sattime, bhante, dhammā bhikkhuno aparihānāya saṁvattanti."
    },
    {
      "id": "an7.34:1.3",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.34:1.4",
      "pali": "Satthugāravatā, dhammagāravatā, saṅghagāravatā, sikkhāgāravatā, samādhigāravatā, sovacassatā, kalyāṇamittatā."
    },
    {
      "id": "an7.34:1.5",
      "pali": "Ime kho, bhante, satta dhammā bhikkhuno aparihānāya saṁvattantī’ti."
    },
    {
      "id": "an7.34:1.6",
      "pali": "Idamavoca, bhikkhave, sā devatā."
    },
    {
      "id": "an7.34:1.7",
      "pali": "Idaṁ vatvā maṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyīti."
    },
    {
      "id": "an7.34:2.1",
      "pali": "Satthugaru dhammagaru,"
    },
    {
      "id": "an7.34:2.2",
      "pali": "saṅghe ca tibbagāravo;"
    },
    {
      "id": "an7.34:2.3",
      "pali": "Samādhigaru ātāpī,"
    },
    {
      "id": "an7.34:2.4",
      "pali": "sikkhāya tibbagāravo."
    },
    {
      "id": "an7.34:3.1",
      "pali": "Kalyāṇamitto suvaco,"
    },
    {
      "id": "an7.34:3.2",
      "pali": "sappatisso sagāravo;"
    },
    {
      "id": "an7.34:3.3",
      "pali": "Abhabbo parihānāya,"
    },
    {
      "id": "an7.34:3.4",
      "pali": "nibbānasseva santike”ti."
    },
    {
      "id": "an7.34:3.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
