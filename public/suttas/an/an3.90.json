{
  "uid": "an3.90",
  "title": "Dutiyasikkhattayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.90:1.1",
      "pali": "“Tisso imā, bhikkhave, sikkhā."
    },
    {
      "id": "an3.90:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.90:1.3",
      "pali": "Adhisīlasikkhā, adhicittasikkhā, adhipaññāsikkhā."
    },
    {
      "id": "an3.90:2.1",
      "pali": "Katamā ca, bhikkhave, adhisīlasikkhā?"
    },
    {
      "id": "an3.90:2.2",
      "pali": "Idha, bhikkhave, bhikkhu sīlavā hoti …pe… samādāya sikkhati sikkhāpadesu."
    },
    {
      "id": "an3.90:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, adhisīlasikkhā."
    },
    {
      "id": "an3.90:3.1",
      "pali": "Katamā ca, bhikkhave, adhicittasikkhā?"
    },
    {
      "id": "an3.90:3.2",
      "pali": "Idha, bhikkhave, bhikkhu vivicceva kāmehi …pe… catutthaṁ jhānaṁ upasampajja viharati."
    },
    {
      "id": "an3.90:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, adhicittasikkhā."
    },
    {
      "id": "an3.90:4.1",
      "pali": "Katamā ca, bhikkhave, adhipaññāsikkhā?"
    },
    {
      "id": "an3.90:4.2",
      "pali": "Idha, bhikkhave, bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati."
    },
    {
      "id": "an3.90:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, adhipaññāsikkhā."
    },
    {
      "id": "an3.90:4.4",
      "pali": "Imā kho, bhikkhave, tisso sikkhāti."
    },
    {
      "id": "an3.90:5.1",
      "pali": "Adhisīlaṁ adhicittaṁ,"
    },
    {
      "id": "an3.90:5.2",
      "pali": "adhipaññañca vīriyavā;"
    },
    {
      "id": "an3.90:5.3",
      "pali": "Thāmavā dhitimā jhāyī,"
    },
    {
      "id": "an3.90:5.4",
      "pali": "sato guttindriyo care."
    },
    {
      "id": "an3.90:6.1",
      "pali": "Yathā pure tathā pacchā,"
    },
    {
      "id": "an3.90:6.2",
      "pali": "yathā pacchā tathā pure;"
    },
    {
      "id": "an3.90:6.3",
      "pali": "Yathā adho tathā uddhaṁ,"
    },
    {
      "id": "an3.90:6.4",
      "pali": "yathā uddhaṁ tathā adho."
    },
    {
      "id": "an3.90:7.1",
      "pali": "Yathā divā tathā rattiṁ,"
    },
    {
      "id": "an3.90:7.2",
      "pali": "yathā rattiṁ tathā divā;"
    },
    {
      "id": "an3.90:7.3",
      "pali": "Abhibhuyya disā sabbā,"
    },
    {
      "id": "an3.90:7.4",
      "pali": "appamāṇasamādhinā."
    },
    {
      "id": "an3.90:8.1",
      "pali": "Tamāhu sekhaṁ paṭipadaṁ,"
    },
    {
      "id": "an3.90:8.2",
      "pali": "atho saṁsuddhacāriyaṁ;"
    },
    {
      "id": "an3.90:8.3",
      "pali": "Tamāhu loke sambuddhaṁ,"
    },
    {
      "id": "an3.90:8.4",
      "pali": "dhīraṁ paṭipadantaguṁ."
    },
    {
      "id": "an3.90:9.1",
      "pali": "Viññāṇassa nirodhena,"
    },
    {
      "id": "an3.90:9.2",
      "pali": "taṇhākkhayavimuttino;"
    },
    {
      "id": "an3.90:9.3",
      "pali": "Pajjotasseva nibbānaṁ,"
    },
    {
      "id": "an3.90:9.4",
      "pali": "vimokkho hoti cetaso”ti."
    },
    {
      "id": "an3.90:9.5",
      "pali": "Dasamaṁ."
    }
  ]
}
