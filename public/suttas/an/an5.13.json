{
  "uid": "an5.13",
  "title": "Saṅkhittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.13:1.1",
      "pali": "“Pañcimāni, bhikkhave, balāni."
    },
    {
      "id": "an5.13:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.13:1.3",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—"
    },
    {
      "id": "an5.13:1.4",
      "pali": "imāni kho, bhikkhave, pañca balānī”ti."
    },
    {
      "id": "an5.13:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
