{
  "uid": "an4.206",
  "title": "Dasamaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.206:1.1",
      "pali": "“Asappurisañca vo, bhikkhave, desessāmi, asappurisena asappurisatarañca;"
    },
    {
      "id": "an4.206:1.2",
      "pali": "sappurisañca, sappurisena sappurisatarañca. Taṁ suṇātha …pe…."
    },
    {
      "id": "an4.206:2.1",
      "pali": "“Katamo ca, bhikkhave, asappuriso?"
    },
    {
      "id": "an4.206:2.2",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāñāṇī hoti, micchāvimutti hoti."
    },
    {
      "id": "an4.206:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asappuriso."
    },
    {
      "id": "an4.206:3.1",
      "pali": "Katamo ca, bhikkhave, asappurisena asappurisataro?"
    },
    {
      "id": "an4.206:3.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca micchādiṭṭhiko hoti, parañca micchādiṭṭhiyā samādapeti …pe… attanā ca micchāñāṇī hoti, parañca micchāñāṇe samādapeti;"
    },
    {
      "id": "an4.206:3.3",
      "pali": "attanā ca micchāvimutti hoti, parañca micchāvimuttiyā samādapeti."
    },
    {
      "id": "an4.206:3.4",
      "pali": "Ayaṁ vuccati, bhikkhave, asappurisena asappurisataro."
    },
    {
      "id": "an4.206:4.1",
      "pali": "Katamo ca, bhikkhave, sappuriso?"
    },
    {
      "id": "an4.206:4.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāñāṇī hoti, sammāvimutti hoti."
    },
    {
      "id": "an4.206:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, sappuriso."
    },
    {
      "id": "an4.206:5.1",
      "pali": "Katamo ca, bhikkhave, sappurisena sappurisataro?"
    },
    {
      "id": "an4.206:5.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca sammādiṭṭhiko hoti, parañca sammādiṭṭhiyā samādapeti …pe… attanā ca sammāñāṇī hoti, parañca sammāñāṇe samādapeti;"
    },
    {
      "id": "an4.206:5.3",
      "pali": "attanā ca sammāvimutti hoti, parañca sammāvimuttiyā samādapeti."
    },
    {
      "id": "an4.206:5.4",
      "pali": "Ayaṁ vuccati, bhikkhave, sappurisena sappurisataro”ti."
    },
    {
      "id": "an4.206:5.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
