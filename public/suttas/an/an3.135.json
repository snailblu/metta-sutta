{
  "uid": "an3.135",
  "title": "Mittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.135:1.1",
      "pali": "“Tīhi, bhikkhave, aṅgehi samannāgato mitto sevitabbo."
    },
    {
      "id": "an3.135:1.2",
      "pali": "Katamehi tīhi? (…)"
    },
    {
      "id": "an3.135:1.3",
      "pali": "Duddadaṁ dadāti, dukkaraṁ karoti, dukkhamaṁ khamati—"
    },
    {
      "id": "an3.135:1.4",
      "pali": "imehi kho, bhikkhave, tīhi aṅgehi samannāgato mitto sevitabbo”ti."
    },
    {
      "id": "an3.135:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
