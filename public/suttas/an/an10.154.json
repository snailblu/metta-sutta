{
  "uid": "an10.154",
  "title": "Sacchikātabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.154:1.1",
      "pali": "“Sacchikātabbañca vo, bhikkhave, dhammaṁ desessāmi na sacchikātabbañca."
    },
    {
      "id": "an10.154:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.154:1.3",
      "pali": "katamo ca, bhikkhave, na sacchikātabbo dhammo?"
    },
    {
      "id": "an10.154:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.154:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, na sacchikātabbo dhammo."
    },
    {
      "id": "an10.154:1.6",
      "pali": "Katamo ca, bhikkhave, sacchikātabbo dhammo?"
    },
    {
      "id": "an10.154:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.154:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, sacchikātabbo dhammo”ti."
    },
    {
      "id": "an10.154:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an10.154:1.10",
      "pali": "Ariyavaggo pañcamo."
    },
    {
      "id": "an10.154:1.11",
      "pali": "Tatiyo paṇṇāsako samatto."
    }
  ]
}
