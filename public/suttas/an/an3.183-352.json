    },
    {
      "id": "an3.183-352:3.26",
      "pali": "paṭinissaggāya ime tayo dhammā bhāvetabbā”ti."
    },
    {
      "id": "an3.183-352:4.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "an3.183-352:4.2",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "an3.183-352:4.3",
      "pali": "Rāgapeyyālaṁ niṭṭhitaṁ."
    },
    {
      "id": "an3.183-352:5.1",
      "pali": "Rāgaṁ dosañca mohañca,"
    },
    {
      "id": "an3.183-352:5.2",
      "pali": "kodhūpanāhapañcamaṁ;"
    },
    {
      "id": "an3.183-352:5.3",
      "pali": "Makkhapaḷāsaissā ca,"
    },
    {
      "id": "an3.183-352:5.4",
      "pali": "maccharimāyāsāṭheyyā."
    },
    {
      "id": "an3.183-352:6.1",
      "pali": "Thambhasārambhamānañca,"
    },
    {
      "id": "an3.183-352:6.2",
      "pali": "atimānamadassa ca;"
    },
    {
      "id": "an3.183-352:6.3",
      "pali": "Pamādā sattarasa vuttā,"
    },
    {
      "id": "an3.183-352:6.4",
      "pali": "rāgapeyyālanissitā."
    },
    {
      "id": "an3.183-352:7.1",
      "pali": "Ete opammayuttena,"
    },
    {
      "id": "an3.183-352:7.2",
      "pali": "āpādena abhiññāya;"
    },
    {
      "id": "an3.183-352:7.3",
      "pali": "Pariññāya parikkhayā,"
    },
    {
      "id": "an3.183-352:7.4",
      "pali": "pahānakkhayabbayena;"
    },
    {
      "id": "an3.183-352:7.5",
      "pali": "Virāganirodhacāgaṁ,"
    },
    {
      "id": "an3.183-352:7.6",
      "pali": "paṭinissagge ime dasa."
    },
    {
      "id": "an3.183-352:8.1",
      "pali": "Suññato animitto ca,"
    },
    {
      "id": "an3.183-352:8.2",
      "pali": "appaṇihito ca tayo;"
    },
    {
      "id": "an3.183-352:8.3",
      "pali": "Samādhimūlakā peyyā—"
    },
    {
      "id": "an3.183-352:8.4",
      "pali": "lesupi vavatthitā cāti."
    },
    {
      "id": "an3.183-352:8.5",
      "pali": "Tatiyo paṇṇāsako niṭṭhito."
    },
    {
      "id": "an3.183-352:8.6",
      "pali": "Tikanipātapāḷi niṭṭhitā."
    }
  ]
}
