  "segments": [
    {
      "id": "an3.183-352:1.1",
      "pali": "“Rāgassa, bhikkhave, abhiññāya tayo dhammā bhāvetabbā."
    },
    {
      "id": "an3.183-352:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an3.183-352:1.3",
      "pali": "Suññato samādhi, animitto samādhi, appaṇihito samādhi—"
    },
    {
      "id": "an3.183-352:1.4",
      "pali": "rāgassa, bhikkhave, abhiññāya ime tayo dhammā bhāvetabbā. (…)"
    },
    {
      "id": "an3.183-352:2.1",
