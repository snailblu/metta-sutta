{
  "uid": "an4.16",
  "title": "Sokhummasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.16:1.1",
      "pali": "“Cattārimāni, bhikkhave, sokhummāni."
    },
    {
      "id": "an4.16:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.16:1.3",
      "pali": "Idha, bhikkhave, bhikkhu rūpasokhummena samannāgato hoti paramena;"
    },
    {
      "id": "an4.16:1.4",
      "pali": "tena ca rūpasokhummena aññaṁ rūpasokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na samanupassati;"
    },
    {
      "id": "an4.16:1.5",
      "pali": "tena ca rūpasokhummena aññaṁ rūpasokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na pattheti."
    },
    {
      "id": "an4.16:1.6",
      "pali": "Vedanāsokhummena samannāgato hoti paramena;"
    },
    {
      "id": "an4.16:1.7",
      "pali": "tena ca vedanāsokhummena aññaṁ vedanāsokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na samanupassati;"
    },
    {
      "id": "an4.16:1.8",
      "pali": "tena ca vedanāsokhummena aññaṁ vedanāsokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na pattheti."
    },
    {
      "id": "an4.16:1.9",
      "pali": "Saññāsokhummena samannāgato hoti paramena;"
    },
    {
      "id": "an4.16:1.10",
      "pali": "tena ca saññāsokhummena aññaṁ saññāsokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na samanupassati;"
    },
    {
      "id": "an4.16:1.11",
      "pali": "tena ca saññāsokhummena aññaṁ saññāsokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na pattheti."
    },
    {
      "id": "an4.16:1.12",
      "pali": "Saṅkhārasokhummena samannāgato hoti paramena;"
    },
    {
      "id": "an4.16:1.13",
      "pali": "tena ca saṅkhārasokhummena aññaṁ saṅkhārasokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na samanupassati;"
    },
    {
      "id": "an4.16:1.14",
      "pali": "tena ca saṅkhārasokhummena aññaṁ saṅkhārasokhummaṁ uttaritaraṁ vā paṇītataraṁ vā na pattheti."
    },
    {
      "id": "an4.16:1.15",
      "pali": "Imāni kho, bhikkhave, cattāri sokhummānīti."
    },
    {
      "id": "an4.16:2.1",
      "pali": "Rūpasokhummataṁ ñatvā,"
    },
    {
      "id": "an4.16:2.2",
      "pali": "vedanānañca sambhavaṁ;"
    },
    {
      "id": "an4.16:2.3",
      "pali": "Saññā yato samudeti,"
    },
    {
      "id": "an4.16:2.4",
      "pali": "atthaṁ gacchati yattha ca;"
    },
    {
      "id": "an4.16:2.5",
      "pali": "Saṅkhāre parato ñatvā,"
    },
    {
      "id": "an4.16:2.6",
      "pali": "dukkhato no ca attato."
    },
    {
      "id": "an4.16:3.1",
      "pali": "Sa ve sammaddaso bhikkhu,"
    },
    {
      "id": "an4.16:3.2",
      "pali": "santo santipade rato;"
    },
    {
      "id": "an4.16:3.3",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "an4.16:3.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "an4.16:3.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
