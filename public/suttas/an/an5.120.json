{
  "uid": "an5.120",
  "title": "Micchāvāyāmasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.120:1.1",
      "pali": "“Pañcahi, bhikkhave, dhammehi samannāgatā bhikkhunī yathābhataṁ nikkhittā evaṁ niraye."
    },
    {
      "id": "an5.120:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.120:1.3",
      "pali": "Ananuvicca apariyogāhetvā avaṇṇārahassa vaṇṇaṁ bhāsati,"
    },
    {
      "id": "an5.120:1.4",
      "pali": "ananuvicca apariyogāhetvā vaṇṇārahassa avaṇṇaṁ bhāsati,"
    },
    {
      "id": "an5.120:1.5",
      "pali": "micchāvāyāmā ca hoti,"
    },
    {
      "id": "an5.120:1.6",
      "pali": "micchāsatinī ca,"
    },
    {
      "id": "an5.120:1.7",
      "pali": "saddhādeyyaṁ vinipāteti."
    },
    {
      "id": "an5.120:1.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgatā bhikkhunī yathābhataṁ nikkhittā evaṁ niraye."
    },
    {
      "id": "an5.120:2.1",
      "pali": "Pañcahi, bhikkhave, dhammehi samannāgatā bhikkhunī yathābhataṁ nikkhittā evaṁ sagge."
    },
    {
      "id": "an5.120:2.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.120:2.3",
      "pali": "Anuvicca pariyogāhetvā avaṇṇārahassa avaṇṇaṁ bhāsati,"
    },
    {
      "id": "an5.120:2.4",
      "pali": "anuvicca pariyogāhetvā vaṇṇārahassa vaṇṇaṁ bhāsati,"
    },
    {
      "id": "an5.120:2.5",
      "pali": "sammāvāyāmā ca hoti,"
    },
    {
      "id": "an5.120:2.6",
      "pali": "sammāsatinī ca,"
    },
    {
      "id": "an5.120:2.7",
      "pali": "saddhādeyyaṁ na vinipāteti."
    },
    {
      "id": "an5.120:2.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgatā bhikkhunī yathābhataṁ nikkhittā evaṁ sagge”ti."
    },
    {
      "id": "an5.120:2.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.120:2.10",
      "pali": "Andhakavindavaggo dutiyo."
    },
    {
      "id": "an5.120:3.1",
      "pali": "Kulūpako pacchāsamaṇo,"
    },
    {
      "id": "an5.120:3.2",
      "pali": "samādhiandhakavindaṁ;"
    },
    {
      "id": "an5.120:3.3",
      "pali": "Maccharī vaṇṇanā issā,"
    },
    {
      "id": "an5.120:3.4",
      "pali": "diṭṭhivācāya vāyamāti."
    }
  ]
}
