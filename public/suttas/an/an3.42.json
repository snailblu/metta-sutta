{
  "uid": "an3.42",
  "title": "Tiṭhānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.42:1.1",
      "pali": "“Tīhi, bhikkhave, ṭhānehi saddho pasanno veditabbo."
    },
    {
      "id": "an3.42:1.2",
      "pali": "Katamehi tīhi?"
    },
    {
      "id": "an3.42:1.3",
      "pali": "Sīlavantānaṁ dassanakāmo hoti, saddhammaṁ sotukāmo hoti, vigatamalamaccherena cetasā agāraṁ ajjhāvasati muttacāgo payatapāṇi vossaggarato yācayogo dānasaṁvibhāgarato."
    },
    {
      "id": "an3.42:1.4",
      "pali": "Imehi kho, bhikkhave, tīhi ṭhānehi saddho pasanno veditabbo."
    },
    {
      "id": "an3.42:2.1",
      "pali": "Dassanakāmo sīlavataṁ,"
    },
    {
      "id": "an3.42:2.2",
      "pali": "saddhammaṁ sotumicchati;"
    },
    {
      "id": "an3.42:2.3",
      "pali": "Vinaye maccheramalaṁ,"
    },
    {
      "id": "an3.42:2.4",
      "pali": "sa ve saddhoti vuccatī”ti."
    },
    {
      "id": "an3.42:2.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
