{
  "uid": "an3.115",
  "title": "Appameyyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.115:1.1",
      "pali": "“Tayome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an3.115:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an3.115:1.3",
      "pali": "Suppameyyo, duppameyyo, appameyyo."
    },
    {
      "id": "an3.115:1.4",
      "pali": "Katamo ca, bhikkhave, puggalo suppameyyo?"
    },
    {
      "id": "an3.115:1.5",
      "pali": "Idha, bhikkhave, ekacco puggalo uddhato hoti unnaḷo capalo mukharo vikiṇṇavāco muṭṭhassati asampajāno asamāhito vibbhantacitto pākatindriyo."
    },
    {
      "id": "an3.115:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo suppameyyo."
    },
    {
      "id": "an3.115:2.1",
      "pali": "Katamo ca, bhikkhave, puggalo duppameyyo?"
    },
    {
      "id": "an3.115:2.2",
      "pali": "Idha, bhikkhave, ekacco puggalo anuddhato hoti anunnaḷo acapalo amukharo avikiṇṇavāco upaṭṭhitassati sampajāno samāhito ekaggacitto saṁvutindriyo."
    },
    {
      "id": "an3.115:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo duppameyyo."
    },
    {
      "id": "an3.115:3.1",
      "pali": "Katamo ca, bhikkhave, puggalo appameyyo?"
    },
    {
      "id": "an3.115:3.2",
      "pali": "Idha, bhikkhave, bhikkhu arahaṁ hoti khīṇāsavo."
    },
    {
      "id": "an3.115:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo appameyyo."
    },
    {
      "id": "an3.115:3.4",
      "pali": "Ime kho, bhikkhave, tayo puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an3.115:3.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
