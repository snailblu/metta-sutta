{
  "uid": "an5.245",
  "title": "Dutiyaduccaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.245:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā duccarite."
    },
    {
      "id": "an5.245:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.245:1.3",
      "pali": "Attāpi attānaṁ upavadati;"
    },
    {
      "id": "an5.245:1.4",
      "pali": "anuvicca viññū garahanti;"
    },
    {
      "id": "an5.245:1.5",
      "pali": "pāpako kittisaddo abbhuggacchati;"
    },
    {
      "id": "an5.245:1.6",
      "pali": "saddhammā vuṭṭhāti;"
    },
    {
      "id": "an5.245:1.7",
      "pali": "asaddhamme patiṭṭhāti."
    },
    {
      "id": "an5.245:1.8",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā duccarite."
    },
    {
      "id": "an5.245:2.1",
      "pali": "Pañcime, bhikkhave, ānisaṁsā sucarite."
    },
    {
      "id": "an5.245:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.245:2.3",
      "pali": "Attāpi attānaṁ na upavadati;"
    },
    {
      "id": "an5.245:2.4",
      "pali": "anuvicca viññū pasaṁsanti;"
    },
    {
      "id": "an5.245:2.5",
      "pali": "kalyāṇo kittisaddo abbhuggacchati;"
    },
    {
      "id": "an5.245:2.6",
      "pali": "asaddhammā vuṭṭhāti;"
    },
    {
      "id": "an5.245:2.7",
      "pali": "saddhamme patiṭṭhāti."
    },
    {
      "id": "an5.245:2.8",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā sucarite”ti."
    },
    {
      "id": "an5.245:2.9",
      "pali": "Pañcamaṁ."
    }
  ]
}
