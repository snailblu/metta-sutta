{
  "uid": "an10.66",
  "title": "Dutiyasukhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.66:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā sāriputto magadhesu viharati nālakagāmake."
    },
    {
      "id": "an10.66:1.2",
      "pali": "Atha kho sāmaṇḍakāni paribbājako yenāyasmā sāriputto tenupasaṅkami; upasaṅkamitvā āyasmatā sāriputtena saddhiṁ sammodi."
    },
    {
      "id": "an10.66:1.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho sāmaṇḍakāni paribbājako āyasmantaṁ sāriputtaṁ etadavoca:"
    },
    {
      "id": "an10.66:2.1",
      "pali": "“Kiṁ nu kho, āvuso, sāriputta, imasmiṁ dhammavinaye sukhaṁ, kiṁ dukkhan”ti?"
    },
    {
      "id": "an10.66:2.2",
      "pali": "“Anabhirati kho, āvuso, imasmiṁ dhammavinaye dukkhā, abhirati sukhā."
    },
    {
      "id": "an10.66:2.3",
      "pali": "Anabhiratiyā, āvuso, sati idaṁ dukkhaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "an10.66:2.4",
      "pali": "gacchantopi sukhaṁ sātaṁ nādhigacchati,"
    },
    {
      "id": "an10.66:2.5",
      "pali": "ṭhitopi …"
    },
    {
      "id": "an10.66:2.6",
      "pali": "nisinnopi …"
    },
    {
      "id": "an10.66:2.7",
      "pali": "sayānopi …"
    },
    {
      "id": "an10.66:2.8",
      "pali": "gāmagatopi …"
    },
    {
      "id": "an10.66:2.9",
      "pali": "araññagatopi …"
    },
    {
      "id": "an10.66:2.10",
      "pali": "rukkhamūlagatopi …"
    },
    {
      "id": "an10.66:2.11",
      "pali": "suññāgāragatopi …"
    },
    {
      "id": "an10.66:2.12",
      "pali": "abbhokāsagatopi …"
    },
    {
      "id": "an10.66:2.13",
      "pali": "bhikkhumajjhagatopi sukhaṁ sātaṁ nādhigacchati."
    },
    {
      "id": "an10.66:2.14",
      "pali": "Anabhiratiyā, āvuso, sati idaṁ dukkhaṁ pāṭikaṅkhaṁ."
    },
    {
      "id": "an10.66:3.1",
      "pali": "Abhiratiyā, āvuso, sati idaṁ sukhaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "an10.66:3.2",
      "pali": "gacchantopi sukhaṁ sātaṁ adhigacchati,"
    },
    {
      "id": "an10.66:3.3",
      "pali": "ṭhitopi …"
    },
    {
      "id": "an10.66:3.4",
      "pali": "nisinnopi …"
    },
    {
      "id": "an10.66:3.5",
      "pali": "sayānopi …"
    },
    {
      "id": "an10.66:3.6",
      "pali": "gāmagatopi …"
    },
    {
      "id": "an10.66:3.7",
      "pali": "araññagatopi …"
    },
    {
      "id": "an10.66:3.8",
      "pali": "rukkhamūlagatopi …"
    },
    {
      "id": "an10.66:3.9",
      "pali": "suññāgāragatopi …"
    },
    {
      "id": "an10.66:3.10",
      "pali": "abbhokāsagatopi …"
    },
    {
      "id": "an10.66:3.11",
      "pali": "bhikkhumajjhagatopi sukhaṁ sātaṁ adhigacchati."
    },
    {
      "id": "an10.66:3.12",
      "pali": "Abhiratiyā, āvuso, sati idaṁ sukhaṁ pāṭikaṅkhan”ti."
    },
    {
      "id": "an10.66:3.13",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
