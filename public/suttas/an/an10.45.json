{
  "uid": "an10.45",
  "title": "Rājantepurappavesanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.45:1.1",
      "pali": "“Dasayime, bhikkhave, ādīnavā rājantepurappavesane."
    },
    {
      "id": "an10.45:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.45:1.3",
      "pali": "Idha, bhikkhave, rājā mahesiyā saddhiṁ nisinno hoti."
    },
    {
      "id": "an10.45:1.4",
      "pali": "Tatra bhikkhu pavisati."
    },
    {
      "id": "an10.45:1.5",
      "pali": "Mahesī vā bhikkhuṁ disvā sitaṁ pātukaroti, bhikkhu vā mahesiṁ disvā sitaṁ pātukaroti."
    },
    {
      "id": "an10.45:1.6",
      "pali": "Tattha rañño evaṁ hoti:"
    },
    {
      "id": "an10.45:1.7",
      "pali": "‘addhā imesaṁ kataṁ vā karissanti vā’ti."
    },
    {
      "id": "an10.45:1.8",
      "pali": "Ayaṁ, bhikkhave, paṭhamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:2.1",
      "pali": "Puna caparaṁ, bhikkhave, rājā bahukicco bahukaraṇīyo aññataraṁ itthiṁ gantvā na sarati:"
    },
    {
      "id": "an10.45:2.2",
      "pali": "‘sā tena gabbhaṁ gaṇhāti’."
    },
    {
      "id": "an10.45:2.3",
      "pali": "Tattha rañño evaṁ hoti:"
    },
    {
      "id": "an10.45:2.4",
      "pali": "‘na kho idha añño koci pavisati, aññatra pabbajitena."
    },
    {
      "id": "an10.45:2.5",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:2.6",
      "pali": "Ayaṁ, bhikkhave, dutiyo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:3.1",
      "pali": "Puna caparaṁ, bhikkhave, rañño antepure aññataraṁ ratanaṁ nassati."
    },
    {
      "id": "an10.45:3.2",
      "pali": "Tattha rañño evaṁ hoti:"
    },
    {
      "id": "an10.45:3.3",
      "pali": "‘na kho idha añño koci pavisati, aññatra pabbajitena."
    },
    {
      "id": "an10.45:3.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:3.5",
      "pali": "Ayaṁ, bhikkhave, tatiyo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:4.1",
      "pali": "Puna caparaṁ, bhikkhave, rañño antepure abbhantarā guyhamantā bahiddhā sambhedaṁ gacchanti."
    },
    {
      "id": "an10.45:4.2",
      "pali": "Tattha rañño evaṁ hoti:"
    },
    {
      "id": "an10.45:4.3",
      "pali": "‘na kho idha añño koci pavisati, aññatra pabbajitena."
    },
    {
      "id": "an10.45:4.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:4.5",
      "pali": "Ayaṁ, bhikkhave, catuttho ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:5.1",
      "pali": "Puna caparaṁ, bhikkhave, rañño antepure pitā vā puttaṁ pattheti putto vā pitaraṁ pattheti."
    },
    {
      "id": "an10.45:5.2",
      "pali": "Tesaṁ evaṁ hoti:"
    },
    {
      "id": "an10.45:5.3",
      "pali": "‘na kho idha añño koci pavisati, aññatra pabbajitena."
    },
    {
      "id": "an10.45:5.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:5.5",
      "pali": "Ayaṁ, bhikkhave, pañcamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:6.1",
      "pali": "Puna caparaṁ, bhikkhave, rājā nīcaṭṭhāniyaṁ ucce ṭhāne ṭhapeti."
    },
    {
      "id": "an10.45:6.2",
      "pali": "Yesaṁ taṁ amanāpaṁ tesaṁ evaṁ hoti:"
    },
    {
      "id": "an10.45:6.3",
      "pali": "‘rājā kho pabbajitena saṁsaṭṭho."
    },
    {
      "id": "an10.45:6.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:6.5",
      "pali": "Ayaṁ, bhikkhave, chaṭṭho ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:7.1",
      "pali": "Puna caparaṁ, bhikkhave, rājā uccaṭṭhāniyaṁ nīce ṭhāne ṭhapeti."
    },
    {
      "id": "an10.45:7.2",
      "pali": "Yesaṁ taṁ amanāpaṁ tesaṁ evaṁ hoti:"
    },
    {
      "id": "an10.45:7.3",
      "pali": "‘rājā kho pabbajitena saṁsaṭṭho."
    },
    {
      "id": "an10.45:7.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:7.5",
      "pali": "Ayaṁ, bhikkhave, sattamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:8.1",
      "pali": "Puna caparaṁ, bhikkhave, rājā akāle senaṁ uyyojeti."
    },
    {
      "id": "an10.45:8.2",
      "pali": "Yesaṁ taṁ amanāpaṁ tesaṁ evaṁ hoti:"
    },
    {
      "id": "an10.45:8.3",
      "pali": "‘rājā kho pabbajitena saṁsaṭṭho."
    },
    {
      "id": "an10.45:8.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:8.5",
      "pali": "Ayaṁ, bhikkhave, aṭṭhamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:9.1",
      "pali": "Puna caparaṁ, bhikkhave, rājā kāle senaṁ uyyojetvā antarāmaggato nivattāpeti."
    },
    {
      "id": "an10.45:9.2",
      "pali": "Yesaṁ taṁ amanāpaṁ tesaṁ evaṁ hoti:"
    },
    {
      "id": "an10.45:9.3",
      "pali": "‘rājā kho pabbajitena saṁsaṭṭho."
    },
    {
      "id": "an10.45:9.4",
      "pali": "Siyā nu kho pabbajitassa kamman’ti."
    },
    {
      "id": "an10.45:9.5",
      "pali": "Ayaṁ, bhikkhave, navamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:10.1",
      "pali": "Puna caparaṁ, bhikkhave, rañño antepuraṁ hatthisammaddaṁ assasammaddaṁ rathasammaddaṁ rajanīyāni rūpasaddagandharasaphoṭṭhabbāni, yāni na pabbajitassa sāruppāni."
    },
    {
      "id": "an10.45:10.2",
      "pali": "Ayaṁ, bhikkhave, dasamo ādīnavo rājantepurappavesane."
    },
    {
      "id": "an10.45:10.3",
      "pali": "Ime kho, bhikkhave, dasa ādīnavā rājantepurappavesane”ti."
    },
    {
      "id": "an10.45:10.4",
      "pali": "Pañcamaṁ."
    }
  ]
}
