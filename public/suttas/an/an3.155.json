{
  "uid": "an3.155",
  "title": "Pubbaṇhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.155:1.1",
      "pali": "“Ye, bhikkhave, sattā pubbaṇhasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, supubbaṇho, bhikkhave, tesaṁ sattānaṁ."
    },
    {
      "id": "an3.155:2.1",
      "pali": "Ye, bhikkhave, sattā majjhanhikasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, sumajjhanhiko, bhikkhave, tesaṁ sattānaṁ."
    },
    {
      "id": "an3.155:3.1",
      "pali": "Ye, bhikkhave, sattā sāyanhasamayaṁ kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti, susāyanho, bhikkhave, tesaṁ sattānanti."
    },
    {
      "id": "an3.155:4.1",
      "pali": "Sunakkhattaṁ sumaṅgalaṁ,"
    },
    {
      "id": "an3.155:4.2",
      "pali": "suppabhātaṁ suhuṭṭhitaṁ;"
    },
    {
      "id": "an3.155:4.3",
      "pali": "Sukhaṇo sumuhutto ca,"
    },
    {
      "id": "an3.155:4.4",
      "pali": "suyiṭṭhaṁ brahmacārisu."
    },
    {
      "id": "an3.155:5.1",
      "pali": "Padakkhiṇaṁ kāyakammaṁ,"
    },
    {
      "id": "an3.155:5.2",
      "pali": "vācākammaṁ padakkhiṇaṁ;"
    },
    {
      "id": "an3.155:5.3",
      "pali": "Padakkhiṇaṁ manokammaṁ,"
    },
    {
      "id": "an3.155:5.4",
      "pali": "paṇīdhi te padakkhiṇe;"
    },
    {
      "id": "an3.155:5.5",
      "pali": "Padakkhiṇāni katvāna,"
    },
    {
      "id": "an3.155:5.6",
      "pali": "labhantatthe padakkhiṇe."
    },
    {
      "id": "an3.155:6.1",
      "pali": "Te atthaladdhā sukhitā,"
    },
    {
      "id": "an3.155:6.2",
      "pali": "viruḷhā buddhasāsane;"
    },
    {
      "id": "an3.155:6.3",
      "pali": "Arogā sukhitā hotha,"
    },
    {
      "id": "an3.155:6.4",
      "pali": "saha sabbehi ñātibhī”ti."
    },
    {
      "id": "an3.155:6.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an3.155:6.6",
      "pali": "Maṅgalavaggo pañcamo."
    },
    {
      "id": "an3.155:7.1",
      "pali": "Akusalañca sāvajjaṁ,"
    },
    {
      "id": "an3.155:7.2",
      "pali": "visamāsucinā saha;"
    },
    {
      "id": "an3.155:7.3",
      "pali": "Caturo khatā vandanā,"
    },
    {
      "id": "an3.155:7.4",
      "pali": "pubbaṇhena ca te dasāti."
    },
    {
      "id": "an3.155:7.5",
      "pali": "Tatiyo paṇṇāsako samatto."
    }
  ]
}
