{
  "uid": "an7.46",
  "title": "Paṭhamaaggisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.46:1.1",
      "pali": "“Sattime, bhikkhave, aggī."
    },
    {
      "id": "an7.46:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.46:1.3",
      "pali": "Rāgaggi, dosaggi, mohaggi, āhuneyyaggi, gahapataggi, dakkhiṇeyyaggi, kaṭṭhaggi—"
    },
    {
      "id": "an7.46:1.4",
      "pali": "ime kho, bhikkhave, satta aggī”ti."
    },
    {
      "id": "an7.46:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
