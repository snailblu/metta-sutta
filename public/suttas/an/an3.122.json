{
  "uid": "an3.122",
  "title": "Moneyyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.122:1.1",
      "pali": "“Tīṇimāni, bhikkhave, moneyyāni."
    },
    {
      "id": "an3.122:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.122:1.3",
      "pali": "Kāyamoneyyaṁ, vacīmoneyyaṁ, manomoneyyaṁ."
    },
    {
      "id": "an3.122:1.4",
      "pali": "Katamañca, bhikkhave, kāyamoneyyaṁ?"
    },
    {
      "id": "an3.122:1.5",
      "pali": "Idha, bhikkhave, bhikkhu pāṇātipātā paṭivirato hoti, adinnādānā paṭivirato hoti, abrahmacariyā paṭivirato hoti."
    },
    {
      "id": "an3.122:1.6",
      "pali": "Idaṁ vuccati, bhikkhave, kāyamoneyyaṁ."
    },
    {
      "id": "an3.122:2.1",
      "pali": "Katamañca, bhikkhave, vacīmoneyyaṁ?"
    },
    {
      "id": "an3.122:2.2",
      "pali": "Idha, bhikkhave, bhikkhu musāvādā paṭivirato hoti, pisuṇāya vācāya paṭivirato hoti, pharusāya vācāya paṭivirato hoti, samphappalāpā paṭivirato hoti."
    },
    {
      "id": "an3.122:2.3",
      "pali": "Idaṁ vuccati, bhikkhave, vacīmoneyyaṁ."
    },
    {
      "id": "an3.122:3.1",
      "pali": "Katamañca, bhikkhave, manomoneyyaṁ?"
    },
    {
      "id": "an3.122:3.2",
      "pali": "Idha, bhikkhave, bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati."
    },
    {
      "id": "an3.122:3.3",
      "pali": "Idaṁ vuccati, bhikkhave, manomoneyyaṁ."
    },
    {
      "id": "an3.122:3.4",
      "pali": "Imāni kho, bhikkhave, tīṇi moneyyānīti."
    },
    {
      "id": "an3.122:4.1",
      "pali": "Kāyamuniṁ vacīmuniṁ,"
    },
    {
      "id": "an3.122:4.2",
      "pali": "cetomuniṁ anāsavaṁ;"
    },
    {
      "id": "an3.122:4.3",
      "pali": "Muniṁ moneyyasampannaṁ,"
    },
    {
      "id": "an3.122:4.4",
      "pali": "āhu sabbappahāyinan”ti."
    },
    {
      "id": "an3.122:4.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an3.122:4.6",
      "pali": "Āpāyikavaggo dutiyo."
    },
    {
      "id": "an3.122:5.1",
      "pali": "Āpāyiko dullabho appameyyaṁ,"
    },
    {
      "id": "an3.122:5.2",
      "pali": "Āneñjavipattisampadā;"
    },
    {
      "id": "an3.122:5.3",
      "pali": "Apaṇṇako ca kammanto,"
    },
    {
      "id": "an3.122:5.4",
      "pali": "Dve soceyyāni moneyyanti."
    }
  ]
}
