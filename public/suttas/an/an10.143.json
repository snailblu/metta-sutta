{
  "uid": "an10.143",
  "title": "Dukkhudrayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.143:1.1",
      "pali": "“Dukkhudrayañca vo, bhikkhave, dhammaṁ desessāmi sukhudrayañca."
    },
    {
      "id": "an10.143:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.143:1.3",
      "pali": "katamo ca, bhikkhave, dukkhudrayo dhammo?"
    },
    {
      "id": "an10.143:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.143:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhudrayo dhammo."
    },
    {
      "id": "an10.143:1.6",
      "pali": "Katamo ca, bhikkhave, sukhudrayo dhammo?"
    },
    {
      "id": "an10.143:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.143:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, sukhudrayo dhammo”ti."
    },
    {
      "id": "an10.143:1.9",
      "pali": "Dasamaṁ."
    }
  ]
}
