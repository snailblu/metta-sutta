{
  "uid": "an4.44",
  "title": "Dutiyakodhagarusutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.44:1.1",
      "pali": "“Cattārome, bhikkhave, asaddhammā."
    },
    {
      "id": "an4.44:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.44:1.3",
      "pali": "Kodhagarutā na saddhammagarutā, makkhagarutā na saddhammagarutā, lābhagarutā na saddhammagarutā, sakkāragarutā na saddhammagarutā."
    },
    {
      "id": "an4.44:1.4",
      "pali": "Ime kho, bhikkhave, cattāro asaddhammā."
    },
    {
      "id": "an4.44:2.1",
      "pali": "Cattārome, bhikkhave, saddhammā."
    },
    {
      "id": "an4.44:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.44:2.3",
      "pali": "Saddhammagarutā na kodhagarutā, saddhammagarutā na makkhagarutā, saddhammagarutā na lābhagarutā, saddhammagarutā na sakkāragarutā."
    },
    {
      "id": "an4.44:2.4",
      "pali": "Ime kho, bhikkhave, cattāro saddhammāti."
    },
    {
      "id": "an4.44:3.1",
      "pali": "Kodhamakkhagaru bhikkhu,"
    },
    {
      "id": "an4.44:3.2",
      "pali": "lābhasakkāragāravo;"
    },
    {
      "id": "an4.44:3.3",
      "pali": "Sukhette pūtibījaṁva,"
    },
    {
      "id": "an4.44:3.4",
      "pali": "saddhamme na virūhati."
    },
    {
      "id": "an4.44:4.1",
      "pali": "Ye ca saddhammagaruno,"
    },
    {
      "id": "an4.44:4.2",
      "pali": "vihaṁsu viharanti ca;"
    },
    {
      "id": "an4.44:4.3",
      "pali": "Te ve dhamme virūhanti,"
    },
    {
      "id": "an4.44:4.4",
      "pali": "snehānvayamivosadhā”ti."
    },
    {
      "id": "an4.44:4.5",
      "pali": "Catutthaṁ."
    }
  ]
}
