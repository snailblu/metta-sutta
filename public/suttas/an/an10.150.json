{
  "uid": "an10.150",
  "title": "Āsevitabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.150:1.1",
      "pali": "“Āsevitabbañca vo, bhikkhave, dhammaṁ desessāmi na āsevitabbañca."
    },
    {
      "id": "an10.150:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.150:1.3",
      "pali": "katamo ca, bhikkhave, na āsevitabbo dhammo?"
    },
    {
      "id": "an10.150:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.150:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, na āsevitabbo dhammo."
    },
    {
      "id": "an10.150:1.6",
      "pali": "Katamo ca, bhikkhave, āsevitabbo dhammo?"
    },
    {
      "id": "an10.150:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.150:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, āsevitabbo dhammo”ti."
    },
    {
      "id": "an10.150:1.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
