{
  "uid": "an10.142",
  "title": "Ācayagāmisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.142:1.1",
      "pali": "“Ācayagāmiñca vo, bhikkhave, dhammaṁ desessāmi apacayagāmiñca."
    },
    {
      "id": "an10.142:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.142:1.3",
      "pali": "katamo ca, bhikkhave, ācayagāmī dhammo?"
    },
    {
      "id": "an10.142:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.142:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, ācayagāmī dhammo."
    },
    {
      "id": "an10.142:1.6",
      "pali": "Katamo ca, bhikkhave, apacayagāmī dhammo?"
    },
    {
      "id": "an10.142:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.142:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, apacayagāmī dhammo”ti."
    },
    {
      "id": "an10.142:1.9",
      "pali": "Navamaṁ."
    }
  ]
}
