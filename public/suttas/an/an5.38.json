{
  "uid": "an5.38",
  "title": "Saddhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.38:1.1",
      "pali": "“Pañcime, bhikkhave, saddhe kulaputte ānisaṁsā."
    },
    {
      "id": "an5.38:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.38:1.3",
      "pali": "Ye te, bhikkhave, loke santo sappurisā te saddhaññeva paṭhamaṁ anukampantā anukampanti, no tathā assaddhaṁ;"
    },
    {
      "id": "an5.38:1.4",
      "pali": "saddhaññeva paṭhamaṁ upasaṅkamantā upasaṅkamanti, no tathā assaddhaṁ;"
    },
    {
      "id": "an5.38:1.5",
      "pali": "saddhaññeva paṭhamaṁ paṭiggaṇhantā paṭiggaṇhanti, no tathā assaddhaṁ;"
    },
    {
      "id": "an5.38:1.6",
      "pali": "saddhaññeva paṭhamaṁ dhammaṁ desentā desenti, no tathā assaddhaṁ;"
    },
    {
      "id": "an5.38:1.7",
      "pali": "saddho kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati."
    },
    {
      "id": "an5.38:1.8",
      "pali": "Ime kho, bhikkhave, pañca saddhe kulaputte ānisaṁsā."
    },
    {
      "id": "an5.38:2.1",
      "pali": "Seyyathāpi, bhikkhave, subhūmiyaṁ catumahāpathe mahānigrodho samantā pakkhīnaṁ paṭisaraṇaṁ hoti;"
    },
    {
      "id": "an5.38:2.2",
      "pali": "evamevaṁ kho, bhikkhave, saddho kulaputto bahuno janassa paṭisaraṇaṁ hoti bhikkhūnaṁ bhikkhunīnaṁ upāsakānaṁ upāsikānanti."
    },
    {
      "id": "an5.38:3.1",
      "pali": "Sākhāpattaphalūpeto,"
    },
    {
      "id": "an5.38:3.2",
      "pali": "khandhimāva mahādumo;"
    },
    {
      "id": "an5.38:3.3",
      "pali": "Mūlavā phalasampanno,"
    },
    {
      "id": "an5.38:3.4",
      "pali": "patiṭṭhā hoti pakkhinaṁ."
    },
    {
      "id": "an5.38:4.1",
      "pali": "Manorame āyatane,"
    },
    {
      "id": "an5.38:4.2",
      "pali": "sevanti naṁ vihaṅgamā;"
    },
    {
      "id": "an5.38:4.3",
      "pali": "Chāyaṁ chāyatthikā yanti,"
    },
    {
      "id": "an5.38:4.4",
      "pali": "phalatthā phalabhojino."
    },
    {
      "id": "an5.38:5.1",
      "pali": "Tatheva sīlasampannaṁ,"
    },
    {
      "id": "an5.38:5.2",
      "pali": "saddhaṁ purisapuggalaṁ;"
    },
    {
      "id": "an5.38:5.3",
      "pali": "Nivātavuttiṁ atthaddhaṁ,"
    },
    {
      "id": "an5.38:5.4",
      "pali": "sorataṁ sakhilaṁ muduṁ."
    },
    {
      "id": "an5.38:6.1",
      "pali": "Vītarāgā vītadosā,"
    },
    {
      "id": "an5.38:6.2",
      "pali": "vītamohā anāsavā;"
    },
    {
      "id": "an5.38:6.3",
      "pali": "Puññakkhettāni lokasmiṁ,"
    },
    {
      "id": "an5.38:6.4",
      "pali": "sevanti tādisaṁ naraṁ."
    },
    {
      "id": "an5.38:7.1",
      "pali": "Te tassa dhammaṁ desenti,"
    },
    {
      "id": "an5.38:7.2",
      "pali": "Sabbadukkhāpanūdanaṁ;"
    },
    {
      "id": "an5.38:7.3",
      "pali": "Yaṁ so dhammaṁ idhaññāya,"
    },
    {
      "id": "an5.38:7.4",
      "pali": "Parinibbāti anāsavo”ti."
    },
    {
      "id": "an5.38:7.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
