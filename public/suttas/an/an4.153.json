{
  "uid": "an4.153",
  "title": "Paññābalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.153:1.1",
      "pali": "“Cattārimāni, bhikkhave, balāni."
    },
    {
      "id": "an4.153:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.153:1.3",
      "pali": "Paññābalaṁ, vīriyabalaṁ, anavajjabalaṁ, saṅgahabalaṁ—"
    },
    {
      "id": "an4.153:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri balānī”ti."
    },
    {
      "id": "an4.153:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
