{
  "uid": "an8.1",
  "title": "Mettāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "an8.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an8.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "an8.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "an8.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "an8.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an8.1:2.1",
      "pali": "“Mettāya, bhikkhave, cetovimuttiyā āsevitāya bhāvitāya bahulīkatāya yānīkatāya vatthukatāya anuṭṭhitāya paricitāya susamāraddhāya aṭṭhānisaṁsā pāṭikaṅkhā."
    },
    {
      "id": "an8.1:2.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.1:2.3",
      "pali": "Sukhaṁ supati, sukhaṁ paṭibujjhati, na pāpakaṁ supinaṁ passati, manussānaṁ piyo hoti, amanussānaṁ piyo hoti, devatā rakkhanti, nāssa aggi vā visaṁ vā satthaṁ vā kamati, uttariṁ appaṭivijjhanto brahmalokūpago hoti."
    },
    {
      "id": "an8.1:2.4",
      "pali": "Mettāya, bhikkhave, cetovimuttiyā āsevitāya bhāvitāya bahulīkatāya yānīkatāya vatthukatāya anuṭṭhitāya paricitāya susamāraddhāya ime aṭṭhānisaṁsā pāṭikaṅkhāti."
    },
    {
      "id": "an8.1:3.1",
      "pali": "Yo ca mettaṁ bhāvayati,"
    },
    {
      "id": "an8.1:3.2",
      "pali": "appamāṇaṁ paṭissato;"
    },
    {
      "id": "an8.1:3.3",
      "pali": "Tanū saṁyojanā honti,"
    },
    {
      "id": "an8.1:3.4",
      "pali": "passato upadhikkhayaṁ."
    },
    {
      "id": "an8.1:4.1",
      "pali": "Ekampi ce pāṇamaduṭṭhacitto,"
    },
    {
      "id": "an8.1:4.2",
      "pali": "Mettāyati kusalī tena hoti;"
    },
    {
      "id": "an8.1:4.3",
      "pali": "Sabbe ca pāṇe manasānukampī,"
    },
    {
      "id": "an8.1:4.4",
      "pali": "Pahūtamariyo pakaroti puññaṁ."
    },
    {
      "id": "an8.1:5.1",
      "pali": "Ye sattasaṇḍaṁ pathaviṁ vijetvā,"
    },
    {
      "id": "an8.1:5.2",
      "pali": "Rājisayo yajamānā anupariyagā;"
    },
    {
      "id": "an8.1:5.3",
      "pali": "Assamedhaṁ purisamedhaṁ,"
    },
    {
      "id": "an8.1:5.4",
      "pali": "Sammāpāsaṁ vājapeyyaṁ niraggaḷaṁ."
    },
    {
      "id": "an8.1:6.1",
      "pali": "Mettassa cittassa subhāvitassa,"
    },
    {
      "id": "an8.1:6.2",
      "pali": "Kalampi te nānubhavanti soḷasiṁ;"
    },
    {
      "id": "an8.1:6.3",
      "pali": "Candappabhā tāragaṇāva sabbe,"
    },
    {
      "id": "an8.1:6.4",
      "pali": "Yathā na agghanti kalampi soḷasiṁ."
    },
    {
      "id": "an8.1:7.1",
      "pali": "Yo na hanti na ghāteti,"
    },
    {
      "id": "an8.1:7.2",
      "pali": "na jināti na jāpaye;"
    },
    {
      "id": "an8.1:7.3",
      "pali": "Mettaṁso sabbabhūtānaṁ,"
    },
    {
      "id": "an8.1:7.4",
      "pali": "veraṁ tassa na kenacī”ti."
    },
    {
      "id": "an8.1:7.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
