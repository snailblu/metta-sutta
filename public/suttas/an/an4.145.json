{
  "uid": "an4.145",
  "title": "Pajjotasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.145:1.1",
      "pali": "“Cattārome, bhikkhave, pajjotā."
    },
    {
      "id": "an4.145:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.145:1.3",
      "pali": "Candapajjoto, sūriyapajjoto, aggipajjoto, paññāpajjoto—"
    },
    {
      "id": "an4.145:1.4",
      "pali": "Ime kho, bhikkhave, cattāro pajjotā."
    },
    {
      "id": "an4.145:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ pajjotānaṁ yadidaṁ paññāpajjoto”ti."
    },
    {
      "id": "an4.145:1.6",
      "pali": "Pañcamaṁ."
    }
  ]
}
