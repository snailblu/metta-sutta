{
  "uid": "an3.57",
  "title": "Vacchagottasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.57:1.1",
      "pali": "Atha kho vacchagotto paribbājako yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "an3.57:1.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho vacchagotto paribbājako bhagavantaṁ etadavoca:"
    },
    {
      "id": "an3.57:1.3",
      "pali": "“sutaṁ metaṁ, bho gotama, samaṇo gotamo evamāha:"
    },
    {
      "id": "an3.57:1.4",
      "pali": "‘mayhameva dānaṁ dātabbaṁ, nāññesaṁ dānaṁ dātabbaṁ;"
    },
    {
      "id": "an3.57:1.5",
      "pali": "mayhameva sāvakānaṁ dānaṁ dātabbaṁ, nāññesaṁ sāvakānaṁ dānaṁ dātabbaṁ;"
    },
    {
      "id": "an3.57:1.6",
      "pali": "mayhameva dinnaṁ mahapphalaṁ, nāññesaṁ dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "an3.57:1.7",
      "pali": "mayhameva sāvakānaṁ dinnaṁ mahapphalaṁ, nāññesaṁ sāvakānaṁ dinnaṁ mahapphalan’ti."
    },
    {
      "id": "an3.57:1.8",
      "pali": "Ye te, bho gotama, evamāhaṁsu ‘samaṇo gotamo evamāha:"
    },
    {
      "id": "an3.57:1.9",
      "pali": "“mayhameva dānaṁ dātabbaṁ, nāññesaṁ dānaṁ dātabbaṁ."
    },
    {
      "id": "an3.57:1.10",
      "pali": "Mayhameva sāvakānaṁ dānaṁ dātabbaṁ, nāññesaṁ sāvakānaṁ dānaṁ dātabbaṁ."
    },
    {
      "id": "an3.57:1.11",
      "pali": "Mayhameva dinnaṁ mahapphalaṁ, nāññesaṁ dinnaṁ mahapphalaṁ."
    },
    {
      "id": "an3.57:1.12",
      "pali": "Mayhameva sāvakānaṁ dinnaṁ mahapphalaṁ, nāññesaṁ sāvakānaṁ dinnaṁ mahapphalan”’ti."
    },
    {
      "id": "an3.57:1.13",
      "pali": "Kacci te bhoto gotamassa vuttavādino na ca bhavantaṁ gotamaṁ abhūtena abbhācikkhanti, dhammassa cānudhammaṁ byākaronti, na ca koci sahadhammiko vādānupāto gārayhaṁ ṭhānaṁ āgacchati?"
    },
    {
      "id": "an3.57:1.14",
      "pali": "Anabbhakkhātukāmā hi mayaṁ bhavantaṁ gotaman”ti."
    },
    {
      "id": "an3.57:2.1",
      "pali": "“Ye te, vaccha, evamāhaṁsu:"
    },
    {
      "id": "an3.57:2.2",
      "pali": "‘samaṇo gotamo evamāha:"
    },
    {
      "id": "an3.57:2.3",
      "pali": "“mayhameva dānaṁ dātabbaṁ …pe…"
    },
    {
      "id": "an3.57:2.4",
      "pali": "nāññesaṁ sāvakānaṁ dinnaṁ mahapphalan”’ti"
    },
    {
      "id": "an3.57:2.5",
      "pali": "na me te vuttavādino. Abbhācikkhanti ca pana maṁ asatā abhūtena."
    },
    {
      "id": "an3.57:2.6",
      "pali": "Yo kho, vaccha, paraṁ dānaṁ dadantaṁ vāreti so tiṇṇaṁ antarāyakaro hoti, tiṇṇaṁ pāripanthiko."
    },
    {
      "id": "an3.57:2.7",
      "pali": "Katamesaṁ tiṇṇaṁ?"
    },
    {
      "id": "an3.57:2.8",
      "pali": "Dāyakassa puññantarāyakaro hoti, paṭiggāhakānaṁ lābhantarāyakaro hoti, pubbeva kho panassa attā khato ca hoti upahato ca."
    },
    {
      "id": "an3.57:2.9",
      "pali": "Yo kho, vaccha, paraṁ dānaṁ dadantaṁ vāreti so imesaṁ tiṇṇaṁ antarāyakaro hoti, tiṇṇaṁ pāripanthiko."
    },
    {
      "id": "an3.57:3.1",
      "pali": "Ahaṁ kho pana, vaccha, evaṁ vadāmi:"
    },
    {
      "id": "an3.57:3.2",
      "pali": "‘ye hi te candanikāya vā oligalle vā pāṇā, tatrapi yo thālidhovanaṁ vā sarāvadhovanaṁ vā chaḍḍeti:"
    },
    {
      "id": "an3.57:3.3",
      "pali": "“ye tattha pāṇā te tena yāpentū”’ti, tato nidānampāhaṁ, vaccha, puññassa āgamaṁ vadāmi."
    },
    {
      "id": "an3.57:3.4",
      "pali": "Ko pana vādo manussabhūte."
    },
    {
      "id": "an3.57:3.5",
      "pali": "Api cāhaṁ, vaccha, sīlavato dinnaṁ mahapphalaṁ vadāmi, no tathā dussīlassa, so ca hoti pañcaṅgavippahīno pañcaṅgasamannāgato."
    },
    {
      "id": "an3.57:4.1",
      "pali": "Katamāni pañcaṅgāni pahīnāni honti?"
    },
    {
      "id": "an3.57:4.2",
      "pali": "Kāmacchando pahīno hoti, byāpādo pahīno hoti, thinamiddhaṁ pahīnaṁ hoti, uddhaccakukkuccaṁ pahīnaṁ hoti, vicikicchā pahīnā hoti."
    },
    {
      "id": "an3.57:4.3",
      "pali": "Imāni pañcaṅgāni vippahīnāni honti."
    },
    {
      "id": "an3.57:5.1",
      "pali": "Katamehi pañcahi aṅgehi samannāgato hoti?"
    },
    {
      "id": "an3.57:5.2",
      "pali": "Asekkhena sīlakkhandhena samannāgato hoti, asekkhena samādhikkhandhena samannāgato hoti, asekkhena paññākkhandhena samannāgato hoti, asekkhena vimuttikkhandhena samannāgato hoti, asekkhena vimuttiñāṇadassanakkhandhena samannāgato hoti;"
    },
    {
      "id": "an3.57:5.3",
      "pali": "imehi pañcahi aṅgehi samannāgato hoti."
    },
    {
      "id": "an3.57:5.4",
      "pali": "Iti pañcaṅgavippahīne pañcaṅgasamannāgate dinnaṁ mahapphalanti vadāmīti."
    },
    {
      "id": "an3.57:6.1",
      "pali": "Iti kaṇhāsu setāsu,"
    },
    {
      "id": "an3.57:6.2",
      "pali": "rohiṇīsu harīsu vā;"
    },
    {
      "id": "an3.57:6.3",
      "pali": "Kammāsāsu sarūpāsu,"
    },
    {
      "id": "an3.57:6.4",
      "pali": "gosu pārevatāsu vā."
    },
    {
      "id": "an3.57:7.1",
      "pali": "Yāsu kāsuci etāsu,"
    },
    {
      "id": "an3.57:7.2",
      "pali": "danto jāyati puṅgavo;"
    },
    {
      "id": "an3.57:7.3",
      "pali": "Dhorayho balasampanno,"
    },
    {
      "id": "an3.57:7.4",
      "pali": "kalyāṇajavanikkamo;"
    },
    {
      "id": "an3.57:7.5",
      "pali": "Tameva bhāre yuñjanti,"
    },
    {
      "id": "an3.57:7.6",
      "pali": "nāssa vaṇṇaṁ parikkhare."
    },
    {
      "id": "an3.57:8.1",
      "pali": "Evamevaṁ manussesu,"
    },
    {
      "id": "an3.57:8.2",
      "pali": "yasmiṁ kasmiñci jātiye;"
    },
    {
      "id": "an3.57:8.3",
      "pali": "Khattiye brāhmaṇe vesse,"
    },
    {
      "id": "an3.57:8.4",
      "pali": "sudde caṇḍālapukkuse."
    },
    {
      "id": "an3.57:9.1",
      "pali": "Yāsu kāsuci etāsu,"
    },
    {
      "id": "an3.57:9.2",
      "pali": "danto jāyati subbato;"
    },
    {
      "id": "an3.57:9.3",
      "pali": "Dhammaṭṭho sīlasampanno,"
    },
    {
      "id": "an3.57:9.4",
      "pali": "saccavādī hirīmano."
    },
    {
      "id": "an3.57:10.1",
      "pali": "Pahīnajātimaraṇo,"
    },
    {
      "id": "an3.57:10.2",
      "pali": "brahmacariyassa kevalī;"
    },
    {
      "id": "an3.57:10.3",
      "pali": "Pannabhāro visaṁyutto,"
    },
    {
      "id": "an3.57:10.4",
      "pali": "katakicco anāsavo."
    },
    {
      "id": "an3.57:11.1",
      "pali": "Pāragū sabbadhammānaṁ,"
    },
    {
      "id": "an3.57:11.2",
      "pali": "anupādāya nibbuto;"
    },
    {
      "id": "an3.57:11.3",
      "pali": "Tasmiṁyeva viraje khette,"
    },
    {
      "id": "an3.57:11.4",
      "pali": "vipulā hoti dakkhiṇā."
    },
    {
      "id": "an3.57:12.1",
      "pali": "Bālā ca avijānantā,"
    },
    {
      "id": "an3.57:12.2",
      "pali": "dummedhā assutāvino;"
    },
    {
      "id": "an3.57:12.3",
      "pali": "Bahiddhā denti dānāni,"
    },
    {
      "id": "an3.57:12.4",
      "pali": "na hi sante upāsare."
    },
    {
      "id": "an3.57:13.1",
      "pali": "Ye ca sante upāsanti,"
    },
    {
      "id": "an3.57:13.2",
      "pali": "sappaññe dhīrasammate;"
    },
    {
      "id": "an3.57:13.3",
      "pali": "Saddhā ca nesaṁ sugate,"
    },
    {
      "id": "an3.57:13.4",
      "pali": "mūlajātā patiṭṭhitā."
    },
    {
      "id": "an3.57:14.1",
      "pali": "Devalokañca te yanti,"
    },
    {
      "id": "an3.57:14.2",
      "pali": "kule vā idha jāyare;"
    },
    {
      "id": "an3.57:14.3",
      "pali": "Anupubbena nibbānaṁ,"
    },
    {
      "id": "an3.57:14.4",
      "pali": "adhigacchanti paṇḍitā”ti."
    },
    {
      "id": "an3.57:14.5",
      "pali": "Sattamaṁ."
    }
  ]
}
