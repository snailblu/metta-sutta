{
  "uid": "an4.211",
  "title": "Parisāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.211:1.1",
      "pali": "“Cattārome, bhikkhave, parisadūsanā."
    },
    {
      "id": "an4.211:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.211:1.3",
      "pali": "Bhikkhu, bhikkhave, dussīlo pāpadhammo parisadūsano;"
    },
    {
      "id": "an4.211:1.4",
      "pali": "bhikkhunī, bhikkhave, dussīlā pāpadhammā parisadūsanā;"
    },
    {
      "id": "an4.211:1.5",
      "pali": "upāsako, bhikkhave, dussīlo pāpadhammo parisadūsano;"
    },
    {
      "id": "an4.211:1.6",
      "pali": "upāsikā, bhikkhave, dussīlā pāpadhammā parisadūsanā."
    },
    {
      "id": "an4.211:1.7",
      "pali": "Ime kho, bhikkhave, cattāro parisadūsanā."
    },
    {
      "id": "an4.211:2.1",
      "pali": "Cattārome, bhikkhave, parisasobhanā."
    },
    {
      "id": "an4.211:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.211:2.3",
      "pali": "Bhikkhu, bhikkhave, sīlavā kalyāṇadhammo parisasobhano;"
    },
    {
      "id": "an4.211:2.4",
      "pali": "bhikkhunī, bhikkhave, sīlavatī kalyāṇadhammā parisasobhanā;"
    },
    {
      "id": "an4.211:2.5",
      "pali": "upāsako, bhikkhave, sīlavā kalyāṇadhammo parisasobhano;"
    },
    {
      "id": "an4.211:2.6",
      "pali": "upāsikā, bhikkhave, sīlavatī kalyāṇadhammā parisasobhanā."
    },
    {
      "id": "an4.211:2.7",
      "pali": "Ime kho, bhikkhave, cattāro parisasobhanā”ti."
    },
    {
      "id": "an4.211:2.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
