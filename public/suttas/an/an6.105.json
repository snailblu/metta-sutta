{
  "uid": "an6.105",
  "title": "Bhavasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.105:1.1",
      "pali": "“Tayome, bhikkhave, bhavā pahātabbā, tīsu sikkhāsu sikkhitabbaṁ."
    },
    {
      "id": "an6.105:1.2",
      "pali": "Katame tayo bhavā pahātabbā?"
    },
    {
      "id": "an6.105:1.3",
      "pali": "Kāmabhavo, rūpabhavo, arūpabhavo—"
    },
    {
      "id": "an6.105:1.4",
      "pali": "ime tayo bhavā pahātabbā."
    },
    {
      "id": "an6.105:1.5",
      "pali": "Katamāsu tīsu sikkhāsu sikkhitabbaṁ?"
    },
    {
      "id": "an6.105:1.6",
      "pali": "Adhisīlasikkhāya, adhicittasikkhāya, adhipaññāsikkhāya—"
    },
    {
      "id": "an6.105:1.7",
      "pali": "imāsu tīsu sikkhāsu sikkhitabbaṁ."
    },
    {
      "id": "an6.105:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno ime tayo bhavā pahīnā honti, imāsu ca tīsu sikkhāsu sikkhitasikkho hoti—"
    },
    {
      "id": "an6.105:1.9",
      "pali": "ayaṁ vuccati, bhikkhave, bhikkhu acchecchi taṇhaṁ, vivattayi saṁyojanaṁ, sammā mānābhisamayā antamakāsi dukkhassā”ti."
    },
    {
      "id": "an6.105:1.10",
      "pali": "Dasamaṁ."
    }
  ]
}
