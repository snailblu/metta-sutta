{
  "uid": "an5.231",
  "title": "Āvāsikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.231:1.1",
      "pali": "“Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu abhāvanīyo hoti."
    },
    {
      "id": "an5.231:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.231:1.3",
      "pali": "Na ākappasampanno hoti na vattasampanno;"
    },
    {
      "id": "an5.231:1.4",
      "pali": "na bahussuto hoti na sutadharo;"
    },
    {
      "id": "an5.231:1.5",
      "pali": "na paṭisallekhitā hoti na paṭisallānārāmo;"
    },
    {
      "id": "an5.231:1.6",
      "pali": "na kalyāṇavāco hoti na kalyāṇavākkaraṇo;"
    },
    {
      "id": "an5.231:1.7",
      "pali": "duppañño hoti jaḷo eḷamūgo."
    },
    {
      "id": "an5.231:1.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu abhāvanīyo hoti."
    },
    {
      "id": "an5.231:2.1",
      "pali": "Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu bhāvanīyo hoti."
    },
    {
      "id": "an5.231:2.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.231:2.3",
      "pali": "Ākappasampanno hoti vattasampanno;"
    },
    {
      "id": "an5.231:2.4",
      "pali": "bahussuto hoti sutadharo;"
    },
    {
      "id": "an5.231:2.5",
      "pali": "paṭisallekhitā hoti paṭisallānārāmo;"
    },
    {
      "id": "an5.231:2.6",
      "pali": "kalyāṇavāco hoti kalyāṇavākkaraṇo;"
    },
    {
      "id": "an5.231:2.7",
      "pali": "paññavā hoti ajaḷo aneḷamūgo."
    },
    {
      "id": "an5.231:2.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu bhāvanīyo hotī”ti."
    },
    {
      "id": "an5.231:2.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
