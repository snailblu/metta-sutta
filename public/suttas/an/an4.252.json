{
  "uid": "an4.252",
  "title": "Tatiyavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.252:1.1",
      "pali": "“Cattārome, bhikkhave, anariyavohārā."
    },
    {
      "id": "an4.252:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.252:1.3",
      "pali": "Diṭṭhe adiṭṭhavāditā, sute asutavāditā, mute amutavāditā, viññāte aviññātavāditā—"
    },
    {
      "id": "an4.252:1.4",
      "pali": "Ime kho, bhikkhave, cattāro anariyavohārā”ti."
    },
    {
      "id": "an4.252:1.5",
      "pali": "Dasamaṁ."
    }
  ]
}
