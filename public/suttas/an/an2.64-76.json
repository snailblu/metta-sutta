{
  "uid": "an2.64-76",
  "title": "an2.64-76",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.64:1.1",
      "pali": "“Dvemāni, bhikkhave, sukhāni."
    },
    {
      "id": "an2.64:1.2",
      "pali": "Katamāni dve?"
    },
    {
      "id": "an2.64:1.3",
      "pali": "Gihisukhañca pabbajitasukhañca."
    },
    {
      "id": "an2.64:1.4",
      "pali": "Imāni kho, bhikkhave, dve sukhāni."
    },
    {
      "id": "an2.64:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ dvinnaṁ sukhānaṁ yadidaṁ pabbajitasukhan”ti."
    },
    {
      "id": "an2.65:1.1",
