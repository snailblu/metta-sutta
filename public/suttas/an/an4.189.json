{
  "uid": "an4.189",
  "title": "Sacchikaraṇīyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.189:1.1",
      "pali": "“Cattārome, bhikkhave, sacchikaraṇīyā dhammā."
    },
    {
      "id": "an4.189:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.189:1.3",
      "pali": "Atthi, bhikkhave, dhammā kāyena sacchikaraṇīyā;"
    },
    {
      "id": "an4.189:1.4",
      "pali": "atthi, bhikkhave, dhammā satiyā sacchikaraṇīyā;"
    },
    {
      "id": "an4.189:1.5",
      "pali": "atthi, bhikkhave, dhammā cakkhunā sacchikaraṇīyā;"
    },
    {
      "id": "an4.189:1.6",
      "pali": "atthi, bhikkhave, dhammā paññāya sacchikaraṇīyā."
    },
    {
      "id": "an4.189:1.7",
      "pali": "Katame ca, bhikkhave, dhammā kāyena sacchikaraṇīyā?"
    },
    {
      "id": "an4.189:1.8",
      "pali": "Aṭṭha vimokkhā, bhikkhave, kāyena sacchikaraṇīyā."
    },
    {
      "id": "an4.189:2.1",
      "pali": "Katame ca, bhikkhave, dhammā satiyā sacchikaraṇīyā?"
    },
    {
      "id": "an4.189:2.2",
      "pali": "Pubbenivāso, bhikkhave, satiyā sacchikaraṇīyo."
    },
    {
      "id": "an4.189:3.1",
      "pali": "Katame ca, bhikkhave, dhammā cakkhunā sacchikaraṇīyā?"
    },
    {
      "id": "an4.189:3.2",
      "pali": "Sattānaṁ cutūpapāto, bhikkhave, cakkhunā sacchikaraṇīyo."
    },
    {
      "id": "an4.189:4.1",
      "pali": "Katame ca, bhikkhave, dhammā paññāya sacchikaraṇīyā?"
    },
    {
      "id": "an4.189:4.2",
      "pali": "Āsavānaṁ khayo, bhikkhave, paññāya sacchikaraṇīyo."
    },
    {
      "id": "an4.189:4.3",
      "pali": "Ime kho, bhikkhave, cattāro sacchikaraṇīyā dhammā”ti."
    },
    {
      "id": "an4.189:4.4",
      "pali": "Navamaṁ."
    }
  ]
}
