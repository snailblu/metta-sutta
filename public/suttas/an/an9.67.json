{
  "uid": "an9.67",
  "title": "Orambhāgiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.67:1.1",
      "pali": "“Pañcimāni, bhikkhave, orambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an9.67:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an9.67:1.3",
      "pali": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—"
    },
    {
      "id": "an9.67:1.4",
      "pali": "imāni kho, bhikkhave, pañcorambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an9.67:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.67:2.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
