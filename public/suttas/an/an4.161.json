{
  "uid": "an4.161",
  "title": "Saṅkhittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.161:1.1",
      "pali": "“Catasso imā, bhikkhave, paṭipadā."
    },
    {
      "id": "an4.161:1.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.161:1.3",
      "pali": "Dukkhā paṭipadā dandhābhiññā,"
    },
    {
      "id": "an4.161:1.4",
      "pali": "dukkhā paṭipadā khippābhiññā,"
    },
    {
      "id": "an4.161:1.5",
      "pali": "sukhā paṭipadā dandhābhiññā,"
    },
    {
      "id": "an4.161:1.6",
      "pali": "sukhā paṭipadā khippābhiññā—"
    },
    {
      "id": "an4.161:1.7",
      "pali": "imā kho, bhikkhave, catasso paṭipadā”ti."
    },
    {
      "id": "an4.161:1.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
