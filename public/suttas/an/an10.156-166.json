{
  "uid": "an10.156-166",
  "title": "Bhajitabbādisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.156-166:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgato puggalo na bhajitabbo …pe…"
    },
    {
      "id": "an10.156-166:1.2",
      "pali": "bhajitabbo …pe…"
    },
    {
      "id": "an10.156-166:1.3",
      "pali": "na payirupāsitabbo …"
    },
    {
      "id": "an10.156-166:1.4",
      "pali": "payirupāsitabbo …pe…"
    },
    {
      "id": "an10.156-166:1.5",
      "pali": "na pujjo hoti …"
    },
    {
      "id": "an10.156-166:1.6",
      "pali": "pujjo hoti …pe…"
    },
    {
      "id": "an10.156-166:1.7",
      "pali": "na pāsaṁso hoti …"
    },
    {
      "id": "an10.156-166:1.8",
      "pali": "pāsaṁso hoti …pe…"
    },
    {
      "id": "an10.156-166:1.9",
      "pali": "agāravo hoti …"
    },
    {
      "id": "an10.156-166:1.10",
      "pali": "sagāravo hoti …pe…"
    },
    {
      "id": "an10.156-166:1.11",
      "pali": "appatisso hoti …"
    },
    {
      "id": "an10.156-166:1.12",
      "pali": "sappatisso hoti …pe…"
    },
    {
      "id": "an10.156-166:1.13",
      "pali": "na ārādhako hoti …"
    },
    {
      "id": "an10.156-166:1.14",
      "pali": "ārādhako hoti …pe…"
    },
    {
      "id": "an10.156-166:1.15",
      "pali": "na visujjhati …"
    },
    {
      "id": "an10.156-166:1.16",
      "pali": "visujjhati …pe…"
    },
    {
      "id": "an10.156-166:1.17",
      "pali": "mānaṁ nādhibhoti …"
    },
    {
      "id": "an10.156-166:1.18",
      "pali": "mānaṁ adhibhoti …pe…"
    },
    {
      "id": "an10.156-166:1.19",
      "pali": "paññāya na vaḍḍhati …"
    },
    {
      "id": "an10.156-166:1.20",
      "pali": "paññāya vaḍḍhati …pe…."
    },
    {
      "id": "an10.156-166:2.1",
      "pali": "Bahuṁ apuññaṁ pasavati …"
    },
    {
      "id": "an10.156-166:2.2",
      "pali": "bahuṁ puññaṁ pasavati."
    },
    {
      "id": "an10.156-166:2.3",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.156-166:2.4",
      "pali": "Sammādiṭṭhiko hoti, sammāsaṅkappo hoti, sammāvāco hoti, sammākammanto hoti, sammāājīvo hoti, sammāvāyāmo hoti, sammāsati hoti, sammāsamādhi hoti, sammāñāṇī hoti, sammāvimutti hoti—"
    },
    {
      "id": "an10.156-166:2.5",
      "pali": "imehi kho, bhikkhave, dasahi dhammehi samannāgato puggalo bahuṁ puññaṁ pasavatī”ti."
    },
    {
      "id": "an10.156-166:2.6",
      "pali": "Puggalavaggo paṭhamo."
    }
  ]
}
