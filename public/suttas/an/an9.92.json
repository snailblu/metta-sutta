{
  "uid": "an9.92",
  "title": "Cetasovinibandhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.92:1.1",
      "pali": "“Pañcime, bhikkhave, cetasovinibandhā."
    },
    {
      "id": "an9.92:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an9.92:1.3",
      "pali": "Idha, bhikkhave, bhikkhu kāmesu avītarāgo hoti …pe…"
    },
    {
      "id": "an9.92:1.4",
      "pali": "ime kho, bhikkhave, pañca cetasovinibandhā."
    },
    {
      "id": "an9.92:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ cetasovinibandhānaṁ pahānāya ime cattāro iddhipādā bhāvetabbā."
    },
    {
      "id": "an9.92:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an9.92:2.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "an9.92:2.4",
      "pali": "vīriyasamādhi …"
    },
    {
      "id": "an9.92:2.5",
      "pali": "cittasamādhi …"
    },
    {
      "id": "an9.92:2.6",
      "pali": "vīmaṁsāsamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "an9.92:2.7",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ cetasovinibandhānaṁ pahānāya ime cattāro iddhipādā bhāvetabbā”ti."
    },
    {
      "id": "an9.92:2.8",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an9.92:2.9",
      "pali": "Iddhipādavaggo catuttho."
    },
    {
      "id": "an9.92:3.1",
      "pali": "Yatheva satipaṭṭhānā,"
    },
    {
      "id": "an9.92:3.2",
      "pali": "padhānā caturopi ca;"
    },
    {
      "id": "an9.92:3.3",
      "pali": "Cattāro iddhipādā ca,"
    },
    {
      "id": "an9.92:3.4",
      "pali": "tatheva sampayojayeti."
    }
  ]
}
