{
  "uid": "an7.27",
  "title": "Saññāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.27:1.1",
      "pali": "“Satta vo, bhikkhave, aparihāniye dhamme desessāmi."
    },
    {
      "id": "an7.27:1.2",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha …pe…."
    },
    {
      "id": "an7.27:1.3",
      "pali": "Katame ca, bhikkhave, satta aparihāniyā dhammā?"
    },
    {
      "id": "an7.27:1.4",
      "pali": "Yāvakīvañca, bhikkhave, bhikkhū aniccasaññaṁ bhāvessanti; vuddhiyeva, bhikkhave, bhikkhūnaṁ pāṭikaṅkhā, no parihāni."
    },
    {
      "id": "an7.27:2.1",
      "pali": "Yāvakīvañca, bhikkhave, bhikkhū anattasaññaṁ bhāvessanti …pe…"
    },
    {
      "id": "an7.27:2.2",
      "pali": "asubhasaññaṁ bhāvessanti …"
    },
    {
      "id": "an7.27:2.3",
      "pali": "ādīnavasaññaṁ bhāvessanti …"
    },
    {
      "id": "an7.27:2.4",
      "pali": "pahānasaññaṁ bhāvessanti …"
    },
    {
      "id": "an7.27:2.5",
      "pali": "virāgasaññaṁ bhāvessanti …"
    },
    {
      "id": "an7.27:2.6",
      "pali": "nirodhasaññaṁ bhāvessanti;"
    },
    {
      "id": "an7.27:3.1",
      "pali": "vuddhiyeva, bhikkhave, bhikkhūnaṁ pāṭikaṅkhā, no parihāni. Yāvakīvañca, bhikkhave, ime satta aparihāniyā dhammā bhikkhūsu ṭhassanti, imesu ca sattasu aparihāniyesu dhammesu, bhikkhū sandississanti; vuddhiyeva, bhikkhave, bhikkhūnaṁ pāṭikaṅkhā, no parihānī”ti."
    },
    {
      "id": "an7.27:3.2",
      "pali": "Sattamaṁ."
    }
  ]
}
