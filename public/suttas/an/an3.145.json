{
  "uid": "an3.145",
  "title": "Tatiyamoranivāpasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.145:1.1",
      "pali": "“Tīhi, bhikkhave, dhammehi samannāgato bhikkhu accantaniṭṭho hoti accantayogakkhemī accantabrahmacārī accantapariyosāno seṭṭho devamanussānaṁ."
    },
    {
      "id": "an3.145:1.2",
      "pali": "Katamehi tīhi?"
    },
    {
      "id": "an3.145:1.3",
      "pali": "Sammādiṭṭhiyā, sammāñāṇena, sammāvimuttiyā—"
    },
    {
      "id": "an3.145:1.4",
      "pali": "Imehi kho, bhikkhave, tīhi dhammehi samannāgato bhikkhu accantaniṭṭho hoti accantayogakkhemī accantabrahmacārī accantapariyosāno seṭṭho devamanussānan”ti."
    },
    {
      "id": "an3.145:1.5",
      "pali": "Terasamaṁ."
    },
    {
      "id": "an3.145:1.6",
      "pali": "Yodhājīvavaggo cuddasamo."
    },
    {
      "id": "an3.145:2.1",
      "pali": "Yodho parisamittañca,"
    },
    {
      "id": "an3.145:2.2",
      "pali": "uppādā kesakambalo;"
    },
    {
      "id": "an3.145:2.3",
      "pali": "Sampadā vuddhi tayo assā,"
    },
    {
      "id": "an3.145:2.4",
      "pali": "tayo moranivāpinoti."
    }
  ]
}
