{
  "uid": "an5.160",
  "title": "Duppaṭivinodayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.160:1.1",
      "pali": "“Pañcime, bhikkhave, uppannā duppaṭivinodayā."
    },
    {
      "id": "an5.160:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.160:1.3",
      "pali": "Uppanno rāgo duppaṭivinodayo, uppanno doso duppaṭivinodayo, uppanno moho duppaṭivinodayo, uppannaṁ paṭibhānaṁ duppaṭivinodayaṁ, uppannaṁ gamikacittaṁ duppaṭivinodayaṁ."
    },
    {
      "id": "an5.160:1.4",
      "pali": "Ime kho, bhikkhave, pañca uppannā duppaṭivinodayā”ti."
    },
    {
      "id": "an5.160:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.160:1.6",
      "pali": "Saddhammavaggo paṭhamo."
    },
    {
      "id": "an5.160:2.1",
      "pali": "Tayo sammattaniyāmā,"
    },
    {
      "id": "an5.160:2.2",
      "pali": "tayo saddhammasammosā;"
    },
    {
      "id": "an5.160:2.3",
      "pali": "Dukkathā ceva sārajjaṁ,"
    },
    {
      "id": "an5.160:2.4",
      "pali": "udāyidubbinodayāti."
    }
  ]
}
