{
  "uid": "an10.151",
  "title": "Bhāvetabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.151:1.1",
      "pali": "“Bhāvetabbañca vo, bhikkhave, dhammaṁ desessāmi na bhāvetabbañca."
    },
    {
      "id": "an10.151:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.151:1.3",
      "pali": "katamo ca, bhikkhave, na bhāvetabbo dhammo?"
    },
    {
      "id": "an10.151:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.151:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, na bhāvetabbo dhammo."
    },
    {
      "id": "an10.151:1.6",
      "pali": "Katamo ca, bhikkhave, bhāvetabbo dhammo?"
    },
    {
      "id": "an10.151:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.151:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, bhāvetabbo dhammo”ti."
    },
    {
      "id": "an10.151:1.9",
      "pali": "Sattamaṁ."
    }
  ]
}
