{
  "uid": "an4.63",
  "title": "Brahmasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.63:1.1",
      "pali": "“Sabrahmakāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "an4.63:1.2",
      "pali": "Sapubbācariyakāni, bhikkhave, tāni kulāni, yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "an4.63:1.3",
      "pali": "Sapubbadevatāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "an4.63:1.4",
      "pali": "Sāhuneyyakāni, bhikkhave, tāni kulāni yesaṁ puttānaṁ mātāpitaro ajjhāgāre pūjitā honti."
    },
    {
      "id": "an4.63:2.1",
      "pali": "Brahmāti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "an4.63:2.2",
      "pali": "Pubbācariyāti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "an4.63:2.3",
      "pali": "Pubbadevatāti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "an4.63:2.4",
      "pali": "Āhuneyyāti, bhikkhave, mātāpitūnaṁ etaṁ adhivacanaṁ."
    },
    {
      "id": "an4.63:2.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an4.63:2.6",
      "pali": "Bahukārā, bhikkhave, mātāpitaro, puttānaṁ āpādakā posakā imassa lokassa dassetāroti."
    },
    {
      "id": "an4.63:3.1",
      "pali": "Brahmāti mātāpitaro,"
    },
    {
      "id": "an4.63:3.2",
      "pali": "pubbācariyāti vuccare;"
    },
    {
      "id": "an4.63:3.3",
      "pali": "Āhuneyyā ca puttānaṁ,"
    },
    {
      "id": "an4.63:3.4",
      "pali": "pajāya anukampakā."
    },
    {
      "id": "an4.63:4.1",
      "pali": "Tasmā hi ne namasseyya,"
    },
    {
      "id": "an4.63:4.2",
      "pali": "sakkareyya ca paṇḍito;"
    },
    {
      "id": "an4.63:4.3",
      "pali": "Annena atha pānena,"
    },
    {
      "id": "an4.63:4.4",
      "pali": "vatthena sayanena ca;"
    },
    {
      "id": "an4.63:4.5",
      "pali": "Ucchādanena nhāpanena,"
    },
    {
      "id": "an4.63:4.6",
      "pali": "pādānaṁ dhovanena ca."
    },
    {
      "id": "an4.63:5.1",
      "pali": "Tāya naṁ pāricariyāya,"
    },
    {
      "id": "an4.63:5.2",
      "pali": "mātāpitūsu paṇḍitā;"
    },
    {
      "id": "an4.63:5.3",
      "pali": "Idheva naṁ pasaṁsanti,"
    },
    {
      "id": "an4.63:5.4",
      "pali": "pecca sagge pamodatī”ti."
    },
    {
      "id": "an4.63:5.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
