{
  "uid": "an10.184",
  "title": "Vajjasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.184:1.1",
      "pali": "“Sāvajjañca vo, bhikkhave, dhammaṁ desessāmi anavajjañca."
    },
    {
      "id": "an10.184:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.184:1.3",
      "pali": "katamo ca, bhikkhave, sāvajjo dhammo?"
    },
    {
      "id": "an10.184:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.184:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.184:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, sāvajjo dhammo."
    },
    {
      "id": "an10.184:2.1",
      "pali": "Katamo ca, bhikkhave, anavajjo dhammo?"
    },
    {
      "id": "an10.184:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.184:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.184:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, anavajjo dhammo”ti."
    },
    {
      "id": "an10.184:2.5",
      "pali": "Sattamaṁ."
    }
  ]
}
