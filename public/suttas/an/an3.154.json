{
  "uid": "an3.154",
  "title": "Vandanāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.154:1.1",
      "pali": "“Tisso imā, bhikkhave, vandanā."
    },
    {
      "id": "an3.154:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.154:1.3",
      "pali": "Kāyena, vācāya, manasā—"
    },
    {
      "id": "an3.154:1.4",
      "pali": "imā kho, bhikkhave, tisso vandanā”ti."
    },
    {
      "id": "an3.154:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
