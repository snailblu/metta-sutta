{
  "uid": "an10.173",
  "title": "Tatiyaadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.173:1.1",
      "pali": "“Adhammo ca, bhikkhave, veditabbo dhammo ca;"
    },
    {
      "id": "an10.173:1.2",
      "pali": "anattho ca veditabbo attho ca."
    },
    {
      "id": "an10.173:1.3",
      "pali": "Adhammañca viditvā dhammañca, anatthañca viditvā atthañca yathā dhammo yathā attho tathā paṭipajjitabbaṁ."
    },
    {
      "id": "an10.173:2.1",
      "pali": "Katamo ca, bhikkhave, adhammo, katamo ca dhammo;"
    },
    {
      "id": "an10.173:2.2",
      "pali": "katamo ca anattho, katamo ca attho?"
    },
    {
      "id": "an10.173:2.3",
      "pali": "Pāṇātipāto, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:2.4",
      "pali": "pāṇātipātā veramaṇī dhammo;"
    },
    {
      "id": "an10.173:2.5",
      "pali": "ye ca pāṇātipātapaccayā aneke pāpakā akusalā dhammā sambhavanti, ayaṁ anattho;"
    },
    {
      "id": "an10.173:2.6",
      "pali": "pāṇātipātā veramaṇipaccayā ca aneke kusalā dhammā bhāvanāpāripūriṁ gacchanti, ayaṁ attho."
    },
    {
      "id": "an10.173:3.1",
      "pali": "Adinnādānaṁ, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.2",
      "pali": "adinnādānā veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.3",
      "pali": "kāmesumicchācāro, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.4",
      "pali": "kāmesumicchācārā veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.5",
      "pali": "musāvādo, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.6",
      "pali": "musāvādā veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.7",
      "pali": "pisuṇā vācā, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.8",
      "pali": "pisuṇāya vācāya veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.9",
      "pali": "pharusā vācā, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.10",
      "pali": "pharusāya vācāya veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.11",
      "pali": "samphappalāpo, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.12",
      "pali": "samphappalāpā veramaṇī dhammo …"
    },
    {
      "id": "an10.173:3.13",
      "pali": "abhijjhā, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.14",
      "pali": "anabhijjhā dhammo …"
    },
    {
      "id": "an10.173:3.15",
      "pali": "byāpādo, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:3.16",
      "pali": "abyāpādo dhammo …."
    },
    {
      "id": "an10.173:4.1",
      "pali": "Micchādiṭṭhi, bhikkhave, adhammo;"
    },
    {
      "id": "an10.173:4.2",
      "pali": "sammādiṭṭhi dhammo;"
    },
    {
      "id": "an10.173:4.3",
      "pali": "ye ca micchādiṭṭhipaccayā aneke pāpakā akusalā dhammā sambhavanti, ayaṁ anattho;"
    },
    {
      "id": "an10.173:4.4",
      "pali": "sammādiṭṭhipaccayā ca aneke kusalā dhammā bhāvanāpāripūriṁ gacchanti, ayaṁ attho."
    },
    {
      "id": "an10.173:5.1",
      "pali": "‘Adhammo ca, bhikkhave, veditabbo dhammo ca;"
    },
    {
      "id": "an10.173:5.2",
      "pali": "anattho ca veditabbo attho ca."
    },
    {
      "id": "an10.173:5.3",
      "pali": "Adhammañca viditvā dhammañca, anatthañca viditvā atthañca yathā dhammo yathā attho tathā paṭipajjitabban’ti,"
    },
    {
      "id": "an10.173:5.4",
      "pali": "iti yaṁ taṁ vuttaṁ, idametaṁ paṭicca vuttan”ti."
    },
    {
      "id": "an10.173:5.5",
      "pali": "Sattamaṁ."
    }
  ]
}
