{
  "uid": "an5.184",
  "title": "Sosānikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.184:1.1",
      "pali": "“Pañcime, bhikkhave, sosānikā."
    },
    {
      "id": "an5.184:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.184:1.3",
      "pali": "Mandattā momūhattā sosāniko hoti …pe… idamatthitaṁyeva nissāya sosāniko hoti."
    },
    {
      "id": "an5.184:1.4",
      "pali": "Ime kho, bhikkhave, pañca sosānikā”ti."
    },
    {
      "id": "an5.184:1.5",
      "pali": "Catutthaṁ."
    }
  ]
}
