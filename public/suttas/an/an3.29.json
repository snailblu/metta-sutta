{
  "uid": "an3.29",
  "title": "Andhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.29:1.1",
      "pali": "“Tayome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an3.29:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an3.29:1.3",
      "pali": "Andho, ekacakkhu, dvicakkhu."
    },
    {
      "id": "an3.29:1.4",
      "pali": "Katamo ca, bhikkhave, puggalo andho?"
    },
    {
      "id": "an3.29:1.5",
      "pali": "Idha, bhikkhave, ekaccassa puggalassa tathārūpaṁ cakkhu na hoti yathārūpena cakkhunā anadhigataṁ vā bhogaṁ adhigaccheyya adhigataṁ vā bhogaṁ phātiṁ kareyya;"
    },
    {
      "id": "an3.29:1.6",
      "pali": "tathārūpampissa cakkhu na hoti yathārūpena cakkhunā kusalākusale dhamme jāneyya, sāvajjānavajje dhamme jāneyya, hīnappaṇīte dhamme jāneyya, kaṇhasukkasappaṭibhāge dhamme jāneyya."
    },
    {
      "id": "an3.29:1.7",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo andho."
    },
    {
      "id": "an3.29:2.1",
      "pali": "Katamo ca, bhikkhave, puggalo ekacakkhu?"
    },
    {
      "id": "an3.29:2.2",
      "pali": "Idha, bhikkhave, ekaccassa puggalassa tathārūpaṁ cakkhu hoti yathārūpena cakkhunā anadhigataṁ vā bhogaṁ adhigaccheyya adhigataṁ vā bhogaṁ phātiṁ kareyya;"
    },
    {
      "id": "an3.29:2.3",
      "pali": "tathārūpaṁ panassa cakkhu na hoti yathārūpena cakkhunā kusalākusale dhamme jāneyya, sāvajjānavajje dhamme jāneyya, hīnappaṇīte dhamme jāneyya, kaṇhasukkasappaṭibhāge dhamme jāneyya."
    },
    {
      "id": "an3.29:2.4",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo ekacakkhu."
    },
    {
      "id": "an3.29:3.1",
      "pali": "Katamo ca, bhikkhave, puggalo dvicakkhu?"
    },
    {
      "id": "an3.29:3.2",
      "pali": "Idha, bhikkhave, ekaccassa puggalassa tathārūpaṁ cakkhu hoti yathārūpena cakkhunā anadhigataṁ vā bhogaṁ adhigaccheyya, adhigataṁ vā bhogaṁ phātiṁ kareyya;"
    },
    {
      "id": "an3.29:3.3",
      "pali": "tathārūpampissa cakkhu hoti yathārūpena cakkhunā kusalākusale dhamme jāneyya;"
    },
    {
      "id": "an3.29:3.4",
      "pali": "sāvajjānavajje dhamme jāneyya, hīnappaṇīte dhamme jāneyya, kaṇhasukkasappaṭibhāge dhamme jāneyya."
    },
    {
      "id": "an3.29:3.5",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo dvicakkhu."
    },
    {
      "id": "an3.29:3.6",
      "pali": "Ime kho, bhikkhave, tayo puggalā santo saṁvijjamānā lokasminti."
    },
    {
      "id": "an3.29:4.1",
      "pali": "Na ceva bhogā tathārūpā,"
    },
    {
      "id": "an3.29:4.2",
      "pali": "na ca puññāni kubbati;"
    },
    {
      "id": "an3.29:4.3",
      "pali": "Ubhayattha kaliggāho,"
    },
    {
      "id": "an3.29:4.4",
      "pali": "andhassa hatacakkhuno."
    },
    {
      "id": "an3.29:5.1",
      "pali": "Athāparāyaṁ akkhāto,"
    },
    {
      "id": "an3.29:5.2",
      "pali": "Ekacakkhu ca puggalo;"
    },
    {
      "id": "an3.29:5.3",
      "pali": "Dhammādhammena saṭhoso,"
    },
    {
      "id": "an3.29:5.4",
      "pali": "Bhogāni pariyesati."
    },
    {
      "id": "an3.29:6.1",
      "pali": "Theyyena kūṭakammena,"
    },
    {
      "id": "an3.29:6.2",
      "pali": "musāvādena cūbhayaṁ;"
    },
    {
      "id": "an3.29:6.3",
      "pali": "Kusalo hoti saṅghātuṁ,"
    },
    {
      "id": "an3.29:6.4",
      "pali": "kāmabhogī ca mānavo;"
    },
    {
      "id": "an3.29:6.5",
      "pali": "Ito so nirayaṁ gantvā,"
    },
    {
      "id": "an3.29:6.6",
      "pali": "ekacakkhu vihaññati."
    },
    {
      "id": "an3.29:7.1",
      "pali": "Dvicakkhu pana akkhāto,"
    },
    {
      "id": "an3.29:7.2",
      "pali": "seṭṭho purisapuggalo;"
    },
    {
      "id": "an3.29:7.3",
      "pali": "Dhammaladdhehi bhogehi,"
    },
    {
      "id": "an3.29:7.4",
      "pali": "uṭṭhānādhigataṁ dhanaṁ."
    },
    {
      "id": "an3.29:8.1",
      "pali": "Dadāti seṭṭhasaṅkappo,"
    },
    {
      "id": "an3.29:8.2",
      "pali": "abyaggamānaso naro;"
    },
    {
      "id": "an3.29:8.3",
      "pali": "Upeti bhaddakaṁ ṭhānaṁ,"
    },
    {
      "id": "an3.29:8.4",
      "pali": "yattha gantvā na socati."
    },
    {
      "id": "an3.29:9.1",
      "pali": "Andhañca ekacakkhuñca,"
    },
    {
      "id": "an3.29:9.2",
      "pali": "ārakā parivajjaye;"
    },
    {
      "id": "an3.29:9.3",
      "pali": "Dvicakkhuṁ pana sevetha,"
    },
    {
      "id": "an3.29:9.4",
      "pali": "seṭṭhaṁ purisapuggalan”ti."
    },
    {
      "id": "an3.29:9.5",
      "pali": "Navamaṁ."
    }
  ]
}
