{
  "uid": "an3.108",
  "title": "Atittisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.108:1.1",
      "pali": "“Tiṇṇaṁ, bhikkhave, paṭisevanāya natthi titti."
    },
    {
      "id": "an3.108:1.2",
      "pali": "Katamesaṁ tiṇṇaṁ?"
    },
    {
      "id": "an3.108:1.3",
      "pali": "Soppassa, bhikkhave, paṭisevanāya natthi titti."
    },
    {
      "id": "an3.108:1.4",
      "pali": "Surāmerayapānassa, bhikkhave, paṭisevanāya natthi titti."
    },
    {
      "id": "an3.108:1.5",
      "pali": "Methunadhammasamāpattiyā, bhikkhave, paṭisevanāya natthi titti."
    },
    {
      "id": "an3.108:1.6",
      "pali": "Imesaṁ, bhikkhave, tiṇṇaṁ paṭisevanāya natthi tittī”ti."
    },
    {
      "id": "an3.108:1.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
