{
  "uid": "an4.276",
  "title": "Iddhipādasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.276:1.1",
      "pali": "“Rāgassa, bhikkhave, abhiññāya cattāro dhammā bhāvetabbā."
    },
    {
      "id": "an4.276:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.276:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti;"
    },
    {
      "id": "an4.276:1.4",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "an4.276:1.5",
      "pali": "cittasamādhi …pe…"
    },
    {
      "id": "an4.276:1.6",
      "pali": "vīmaṁsāsamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "an4.276:1.7",
      "pali": "Rāgassa, bhikkhave, abhiññāya ime cattāro dhammā bhāvetabbā”ti."
    },
    {
      "id": "an4.276:1.8",
      "pali": "Tatiyaṁ."
    }
  ]
}
