{
  "uid": "an8.47",
  "title": "Dutiyavisākhāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.47:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati pubbārāme migāramātupāsāde."
    },
    {
      "id": "an8.47:1.2",
      "pali": "Atha kho visākhā migāramātā …pe…"
    },
    {
      "id": "an8.47:1.3",
      "pali": "ekamantaṁ nisinnaṁ kho visākhaṁ migāramātaraṁ bhagavā etadavoca:"
    },
    {
      "id": "an8.47:2.1",
      "pali": "“Aṭṭhahi kho, visākhe, dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā manāpakāyikānaṁ devānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "an8.47:2.2",
      "pali": "Katamehi aṭṭhahi?"
    },
    {
      "id": "an8.47:2.3",
      "pali": "Idha, visākhe, mātugāmo yassa mātāpitaro bhattuno denti atthakāmā hitesino anukampakā anukampaṁ upādāya tassa hoti pubbuṭṭhāyinī pacchānipātinī kiṅkārapaṭissāvinī manāpacārinī piyavādinī …pe…."
    },
    {
      "id": "an8.47:3.1",
      "pali": "Cāgavatī kho pana hoti."
    },
    {
      "id": "an8.47:3.2",
      "pali": "Vigatamalamaccherena cetasā agāraṁ ajjhāvasati muttacāgā payatapāṇinī vossaggaratā yācayogā dānasaṁvibhāgaratā."
    },
    {
      "id": "an8.47:3.3",
      "pali": "Imehi kho, visākhe, aṭṭhahi dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā manāpakāyikānaṁ devānaṁ sahabyataṁ upapajjatīti."
    },
    {
      "id": "an8.47:4.1",
      "pali": "Yo naṁ bharati sabbadā,"
    },
    {
      "id": "an8.47:4.2",
      "pali": "niccaṁ ātāpi ussuko;"
    },
    {
      "id": "an8.47:4.3",
      "pali": "Taṁ sabbakāmadaṁ posaṁ,"
    },
    {
      "id": "an8.47:4.4",
      "pali": "bhattāraṁ nātimaññati."
    },
    {
      "id": "an8.47:5.1",
      "pali": "Na cāpi sotthi bhattāraṁ,"
    },
    {
      "id": "an8.47:5.2",
      "pali": "issāvādena rosaye;"
    },
    {
      "id": "an8.47:5.3",
      "pali": "Bhattu ca garuno sabbe,"
    },
    {
      "id": "an8.47:5.4",
      "pali": "paṭipūjeti paṇḍitā."
    },
    {
      "id": "an8.47:6.1",
      "pali": "Uṭṭhāhikā analasā,"
    },
    {
      "id": "an8.47:6.2",
      "pali": "saṅgahitaparijjanā;"
    },
    {
      "id": "an8.47:6.3",
      "pali": "Bhattu manāpaṁ carati,"
    },
    {
      "id": "an8.47:6.4",
      "pali": "sambhataṁ anurakkhati."
    },
    {
      "id": "an8.47:7.1",
      "pali": "Yā evaṁ vattati nārī,"
    },
    {
      "id": "an8.47:7.2",
      "pali": "bhattu chandavasānugā;"
    },
    {
      "id": "an8.47:7.3",
      "pali": "Manāpā nāma te devā,"
    },
    {
      "id": "an8.47:7.4",
      "pali": "yattha sā upapajjatī”ti."
    },
    {
      "id": "an8.47:7.5",
      "pali": "Sattamaṁ."
    }
  ]
}
