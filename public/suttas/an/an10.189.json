{
  "uid": "an10.189",
  "title": "Ariyamaggasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.189:1.1",
      "pali": "“Ariyamaggañca vo, bhikkhave, desessāmi anariyamaggañca."
    },
    {
      "id": "an10.189:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.189:1.3",
      "pali": "katamo ca, bhikkhave, anariyo maggo?"
    },
    {
      "id": "an10.189:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.189:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.189:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, anariyo maggo."
    },
    {
      "id": "an10.189:2.1",
      "pali": "Katamo ca, bhikkhave, ariyo maggo?"
    },
    {
      "id": "an10.189:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.189:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.189:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, ariyo maggo”ti."
    },
    {
      "id": "an10.189:2.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
