{
  "uid": "an3.139",
  "title": "Vuddhisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.139:1.1",
      "pali": "“Tisso imā, bhikkhave, vuddhiyo."
    },
    {
      "id": "an3.139:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.139:1.3",
      "pali": "Saddhāvuddhi, sīlavuddhi, paññāvuddhi—"
    },
    {
      "id": "an3.139:1.4",
      "pali": "imā kho, bhikkhave, tisso vuddhiyo”ti."
    },
    {
      "id": "an3.139:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
