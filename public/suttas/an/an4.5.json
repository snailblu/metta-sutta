{
  "uid": "an4.5",
  "title": "Anusotasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.5:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.5:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.5:1.3",
      "pali": "Anusotagāmī puggalo, paṭisotagāmī puggalo, ṭhitatto puggalo, tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo."
    },
    {
      "id": "an4.5:1.4",
      "pali": "Katamo ca, bhikkhave, anusotagāmī puggalo?"
    },
    {
      "id": "an4.5:1.5",
      "pali": "Idha, bhikkhave, ekacco puggalo kāme ca paṭisevati, pāpañca kammaṁ karoti."
    },
    {
      "id": "an4.5:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, anusotagāmī puggalo."
    },
    {
      "id": "an4.5:2.1",
      "pali": "Katamo ca, bhikkhave, paṭisotagāmī puggalo?"
    },
    {
      "id": "an4.5:2.2",
      "pali": "Idha, bhikkhave, ekacco puggalo kāme ca nappaṭisevati, pāpañca kammaṁ na karoti, sahāpi dukkhena sahāpi domanassena assumukhopi rudamāno paripuṇṇaṁ parisuddhaṁ brahmacariyaṁ carati."
    },
    {
      "id": "an4.5:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, paṭisotagāmī puggalo."
    },
    {
      "id": "an4.5:3.1",
      "pali": "Katamo ca, bhikkhave, ṭhitatto puggalo?"
    },
    {
      "id": "an4.5:3.2",
      "pali": "Idha, bhikkhave, ekacco puggalo pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ parikkhayā opapātiko hoti, tattha parinibbāyī, anāvattidhammo tasmā lokā."
    },
    {
      "id": "an4.5:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, ṭhitatto puggalo."
    },
    {
      "id": "an4.5:4.1",
      "pali": "Katamo ca, bhikkhave, puggalo tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo?"
    },
    {
      "id": "an4.5:4.2",
      "pali": "Idha, bhikkhave, ekacco puggalo āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharati."
    },
    {
      "id": "an4.5:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, puggalo tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo."
    },
    {
      "id": "an4.5:4.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasminti."
    },
    {
      "id": "an4.5:5.1",
      "pali": "Ye keci kāmesu asaññatā janā,"
    },
    {
      "id": "an4.5:5.2",
      "pali": "Avītarāgā idha kāmabhogino;"
    },
    {
      "id": "an4.5:5.3",
      "pali": "Punappunaṁ jātijarūpagāmi te,"
    },
    {
      "id": "an4.5:5.4",
      "pali": "Taṇhādhipannā anusotagāmino."
    },
    {
      "id": "an4.5:6.1",
      "pali": "Tasmā hi dhīro idhupaṭṭhitassatī,"
    },
    {
      "id": "an4.5:6.2",
      "pali": "Kāme ca pāpe ca asevamāno;"
    },
    {
      "id": "an4.5:6.3",
      "pali": "Sahāpi dukkhena jaheyya kāme,"
    },
    {
      "id": "an4.5:6.4",
      "pali": "Paṭisotagāmīti tamāhu puggalaṁ."
    },
    {
      "id": "an4.5:7.1",
      "pali": "Yo ve kilesāni pahāya pañca,"
    },
    {
      "id": "an4.5:7.2",
      "pali": "Paripuṇṇasekho aparihānadhammo;"
    },
    {
      "id": "an4.5:7.3",
      "pali": "Cetovasippatto samāhitindriyo,"
    },
    {
      "id": "an4.5:7.4",
      "pali": "Sa ve ṭhitattoti naro pavuccati."
    },
    {
      "id": "an4.5:8.1",
      "pali": "Paroparā yassa samecca dhammā,"
    },
    {
      "id": "an4.5:8.2",
      "pali": "Vidhūpitā atthagatā na santi;"
    },
    {
      "id": "an4.5:8.3",
      "pali": "Sa ve muni vusitabrahmacariyo,"
    },
    {
      "id": "an4.5:8.4",
      "pali": "Lokantagū pāragatoti vuccatī”ti."
    },
    {
      "id": "an4.5:8.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
