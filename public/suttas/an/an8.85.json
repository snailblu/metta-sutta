{
  "uid": "an8.85",
  "title": "Samaṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.85:1.1",
      "pali": "“‘Samaṇo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.2",
      "pali": "‘Brāhmaṇo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.3",
      "pali": "‘Vedagū’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.4",
      "pali": "‘Bhisakko’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.5",
      "pali": "‘Nimmalo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.6",
      "pali": "‘Vimalo’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.7",
      "pali": "‘Ñāṇī’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "an8.85:1.8",
      "pali": "‘Vimutto’ti, bhikkhave, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassāti."
    },
    {
      "id": "an8.85:2.1",
      "pali": "Yaṁ samaṇena pattabbaṁ,"
    },
    {
      "id": "an8.85:2.2",
      "pali": "brāhmaṇena vusīmatā;"
    },
    {
      "id": "an8.85:2.3",
      "pali": "Yaṁ vedagunā pattabbaṁ,"
    },
    {
      "id": "an8.85:2.4",
      "pali": "bhisakkena anuttaraṁ."
    },
    {
      "id": "an8.85:3.1",
      "pali": "Yaṁ nimmalena pattabbaṁ,"
    },
    {
      "id": "an8.85:3.2",
      "pali": "vimalena sucīmatā;"
    },
    {
      "id": "an8.85:3.3",
      "pali": "Yaṁ ñāṇinā ca pattabbaṁ,"
    },
    {
      "id": "an8.85:3.4",
      "pali": "vimuttena anuttaraṁ."
    },
    {
      "id": "an8.85:4.1",
      "pali": "Sohaṁ vijitasaṅgāmo,"
    },
    {
      "id": "an8.85:4.2",
      "pali": "mutto mocemi bandhanā;"
    },
    {
      "id": "an8.85:4.3",
      "pali": "Nāgomhi paramadanto,"
    },
    {
      "id": "an8.85:4.4",
      "pali": "asekho parinibbuto”ti."
    },
    {
      "id": "an8.85:4.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
