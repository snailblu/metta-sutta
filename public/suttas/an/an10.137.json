{
  "uid": "an10.137",
  "title": "Atthasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.137:1.1",
      "pali": "“Atthañca vo, bhikkhave, desessāmi anatthañca."
    },
    {
      "id": "an10.137:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.137:1.3",
      "pali": "katamo ca, bhikkhave, anattho?"
    },
    {
      "id": "an10.137:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.137:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, anattho."
    },
    {
      "id": "an10.137:1.6",
      "pali": "Katamo ca, bhikkhave, attho?"
    },
    {
      "id": "an10.137:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.137:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, attho”ti."
    },
    {
      "id": "an10.137:1.9",
      "pali": "Catutthaṁ."
    }
  ]
}
