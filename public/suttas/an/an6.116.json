{
  "uid": "an6.116",
  "title": "Uddhaccasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.116:1.1",
      "pali": "“Tayome, bhikkhave, dhammā."
    },
    {
      "id": "an6.116:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.116:1.3",
      "pali": "Uddhaccaṁ, asaṁvaro, pamādo."
    },
    {
      "id": "an6.116:1.4",
      "pali": "Ime kho, bhikkhave, tayo dhammā."
    },
    {
      "id": "an6.116:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā."
    },
    {
      "id": "an6.116:1.6",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.116:1.7",
      "pali": "Uddhaccassa pahānāya samatho bhāvetabbo, asaṁvarassa pahānāya saṁvaro bhāvetabbo, pamādassa pahānāya appamādo bhāvetabbo."
    },
    {
      "id": "an6.116:1.8",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti."
    },
    {
      "id": "an6.116:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an6.116:1.10",
      "pali": "Tikavaggo ekādasamo."
    },
    {
      "id": "an6.116:2.1",
      "pali": "Rāgaduccaritavitakka,"
    },
    {
      "id": "an6.116:2.2",
      "pali": "Saññā dhātūti vuccati;"
    },
    {
      "id": "an6.116:2.3",
      "pali": "Assādaaratituṭṭhi,"
    },
    {
      "id": "an6.116:2.4",
      "pali": "Duve ca uddhaccena vaggoti."
    }
  ]
}
