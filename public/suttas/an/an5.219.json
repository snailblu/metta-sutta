{
  "uid": "an5.219",
  "title": "Aggisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.219:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā aggismiṁ."
    },
    {
      "id": "an5.219:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.219:1.3",
      "pali": "Acakkhusso, dubbaṇṇakaraṇo, dubbalakaraṇo, saṅgaṇikāpavaḍḍhano, tiracchānakathāpavattaniko hoti."
    },
    {
      "id": "an5.219:1.4",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā aggismin”ti."
    },
    {
      "id": "an5.219:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
