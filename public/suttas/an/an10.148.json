{
  "uid": "an10.148",
  "title": "Sappurisadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.148:1.1",
      "pali": "“Sappurisadhammañca vo, bhikkhave, desessāmi asappurisadhammañca."
    },
    {
      "id": "an10.148:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.148:1.3",
      "pali": "katamo ca, bhikkhave, asappurisadhammo?"
    },
    {
      "id": "an10.148:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.148:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, asappurisadhammo."
    },
    {
      "id": "an10.148:1.6",
      "pali": "Katamo ca, bhikkhave, sappurisadhammo?"
    },
    {
      "id": "an10.148:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.148:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, sappurisadhammo”ti."
    },
    {
      "id": "an10.148:1.9",
      "pali": "Catutthaṁ."
    }
  ]
}
