{
  "uid": "an5.254",
  "title": "Pañcamacchariyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.254:1.1",
      "pali": "“Pañcimāni, bhikkhave, macchariyāni."
    },
    {
      "id": "an5.254:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.254:1.3",
      "pali": "Āvāsamacchariyaṁ, kulamacchariyaṁ, lābhamacchariyaṁ, vaṇṇamacchariyaṁ, dhammamacchariyaṁ—"
    },
    {
      "id": "an5.254:1.4",
      "pali": "imāni kho, bhikkhave, pañca macchariyāni."
    },
    {
      "id": "an5.254:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ macchariyānaṁ etaṁ paṭikuṭṭhaṁ, yadidaṁ dhammamacchariyan”ti."
    },
    {
      "id": "an5.254:1.6",
      "pali": "Catutthaṁ."
    }
  ]
}
