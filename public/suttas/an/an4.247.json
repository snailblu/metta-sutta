{
  "uid": "an4.247",
  "title": "Thūpārahasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.247:1.1",
      "pali": "“Cattārome, bhikkhave, thūpārahā."
    },
    {
      "id": "an4.247:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.247:1.3",
      "pali": "Tathāgato arahaṁ sammāsambuddho thūpāraho, paccekabuddho thūpāraho, tathāgatasāvako thūpāraho, rājā cakkavattī thūpāraho—"
    },
    {
      "id": "an4.247:1.4",
      "pali": "Ime kho, bhikkhave, cattāro thūpārahā”ti."
    },
    {
      "id": "an4.247:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
