{
  "uid": "an10.120",
  "title": "Dutiyapaccorohaṇīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.120:1.1",
      "pali": "“Ariyaṁ vo, bhikkhave, paccorohaṇiṁ desessāmi."
    },
    {
      "id": "an10.120:1.2",
      "pali": "Taṁ suṇātha …"
    },
    {
      "id": "an10.120:1.3",
      "pali": "katamā ca, bhikkhave, ariyā paccorohaṇī?"
    },
    {
      "id": "an10.120:1.4",
      "pali": "Idha, bhikkhave, ariyasāvako iti paṭisañcikkhati:"
    },
    {
      "id": "an10.120:1.5",
      "pali": "‘micchādiṭṭhiyā kho pāpako vipāko—"
    },
    {
      "id": "an10.120:1.6",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.120:1.7",
      "pali": "So iti paṭisaṅkhāya micchādiṭṭhiṁ pajahati;"
    },
    {
      "id": "an10.120:1.8",
      "pali": "micchādiṭṭhiyā paccorohati."
    },
    {
      "id": "an10.120:1.9",
      "pali": "Micchāsaṅkappassa kho pāpako vipāko …"
    },
    {
      "id": "an10.120:1.10",
      "pali": "micchāvācāya kho …"
    },
    {
      "id": "an10.120:1.11",
      "pali": "micchākammantassa kho …"
    },
    {
      "id": "an10.120:1.12",
      "pali": "micchāājīvassa kho …"
    },
    {
      "id": "an10.120:1.13",
      "pali": "micchāvāyāmassa kho …"
    },
    {
      "id": "an10.120:1.14",
      "pali": "micchāsatiyā kho …"
    },
    {
      "id": "an10.120:1.15",
      "pali": "micchāsamādhissa kho …"
    },
    {
      "id": "an10.120:1.16",
      "pali": "micchāñāṇassa kho …"
    },
    {
      "id": "an10.120:1.17",
      "pali": "micchāvimuttiyā kho pāpako vipāko—"
    },
    {
      "id": "an10.120:1.18",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcāti."
    },
    {
      "id": "an10.120:1.19",
      "pali": "So iti paṭisaṅkhāya micchāvimuttiṁ pajahati;"
    },
    {
      "id": "an10.120:1.20",
      "pali": "micchāvimuttiyā paccorohati."
    },
    {
      "id": "an10.120:1.21",
      "pali": "Ayaṁ vuccati, bhikkhave, ariyā paccorohaṇī”ti."
    },
    {
      "id": "an10.120:1.22",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
