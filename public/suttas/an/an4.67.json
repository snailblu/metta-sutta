{
  "uid": "an4.67",
  "title": "Ahirājasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.67:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an4.67:1.2",
      "pali": "Tena kho pana samayena sāvatthiyaṁ aññataro bhikkhu ahinā daṭṭho kālaṅkato hoti."
    },
    {
      "id": "an4.67:1.3",
      "pali": "Atha kho sambahulā bhikkhū yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdiṁsu. Ekamantaṁ nisinnā kho te bhikkhū bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "an4.67:1.4",
      "pali": "“idha, bhante, sāvatthiyaṁ aññataro bhikkhu ahinā daṭṭho kālaṅkato”ti."
    },
    {
      "id": "an4.67:2.1",
      "pali": "“Na hi nūna so, bhikkhave, bhikkhu cattāri ahirājakulāni mettena cittena phari."
    },
    {
      "id": "an4.67:2.2",
      "pali": "Sace hi so, bhikkhave, bhikkhu cattāri ahirājakulāni mettena cittena phareyya, na hi so, bhikkhave, bhikkhu ahinā daṭṭho kālaṁ kareyya."
    },
    {
      "id": "an4.67:3.1",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.67:3.2",
      "pali": "Virūpakkhaṁ ahirājakulaṁ, erāpathaṁ ahirājakulaṁ, chabyāputtaṁ ahirājakulaṁ, kaṇhāgotamakaṁ ahirājakulaṁ."
    },
    {
      "id": "an4.67:3.3",
      "pali": "Na hi nūna so, bhikkhave, bhikkhu imāni cattāri ahirājakulāni mettena cittena phari."
    },
    {
      "id": "an4.67:3.4",
      "pali": "Sace hi so, bhikkhave, bhikkhu imāni cattāri ahirājakulāni mettena cittena phareyya, na hi so, bhikkhave, bhikkhu ahinā daṭṭho kālaṁ kareyya."
    },
    {
      "id": "an4.67:4.1",
      "pali": "Anujānāmi, bhikkhave, imāni cattāri ahirājakulāni mettena cittena pharituṁ attaguttiyā attarakkhāya attaparittāyāti."
    },
    {
      "id": "an4.67:5.1",
      "pali": "Virūpakkhehi me mettaṁ,"
    },
    {
      "id": "an4.67:5.2",
      "pali": "Mettaṁ erāpathehi me;"
    },
    {
      "id": "an4.67:5.3",
      "pali": "Chabyāputtehi me mettaṁ,"
    },
    {
      "id": "an4.67:5.4",
      "pali": "Mettaṁ kaṇhāgotamakehi ca."
    },
    {
      "id": "an4.67:6.1",
      "pali": "Apādakehi me mettaṁ,"
    },
    {
      "id": "an4.67:6.2",
      "pali": "mettaṁ dvipādakehi me;"
    },
    {
      "id": "an4.67:6.3",
      "pali": "Catuppadehi me mettaṁ,"
    },
    {
      "id": "an4.67:6.4",
      "pali": "mettaṁ bahuppadehi me."
    },
    {
      "id": "an4.67:7.1",
      "pali": "Mā maṁ apādako hiṁsi,"
    },
    {
      "id": "an4.67:7.2",
      "pali": "mā maṁ hiṁsi dvipādako;"
    },
    {
      "id": "an4.67:7.3",
      "pali": "Mā maṁ catuppado hiṁsi,"
    },
    {
      "id": "an4.67:7.4",
      "pali": "mā maṁ hiṁsi bahuppado."
    },
    {
      "id": "an4.67:8.1",
      "pali": "Sabbe sattā sabbe pāṇā,"
    },
    {
      "id": "an4.67:8.2",
      "pali": "sabbe bhūtā ca kevalā;"
    },
    {
      "id": "an4.67:8.3",
      "pali": "Sabbe bhadrāni passantu,"
    },
    {
      "id": "an4.67:8.4",
      "pali": "mā kañci pāpamāgamā."
    },
    {
      "id": "an4.67:9.1",
      "pali": "Appamāṇo buddho,"
    },
    {
      "id": "an4.67:9.2",
      "pali": "Appamāṇo dhammo;"
    },
    {
      "id": "an4.67:9.3",
      "pali": "Appamāṇo saṅgho,"
    },
    {
      "id": "an4.67:9.4",
      "pali": "Pamāṇavantāni sarīsapāni."
    },
    {
      "id": "an4.67:10.1",
      "pali": "Ahivicchikā satapadī,"
    },
    {
      "id": "an4.67:10.2",
      "pali": "Uṇṇanābhī sarabū mūsikā;"
    },
    {
      "id": "an4.67:10.3",
      "pali": "Katā me rakkhā katā me parittā,"
    },
    {
      "id": "an4.67:10.4",
      "pali": "Paṭikkamantu bhūtāni;"
    },
    {
      "id": "an4.67:10.5",
      "pali": "Sohaṁ namo bhagavato,"
    },
    {
      "id": "an4.67:10.6",
      "pali": "Namo sattannaṁ sammāsambuddhānan”ti."
    },
    {
      "id": "an4.67:10.7",
      "pali": "Sattamaṁ."
    }
  ]
}
