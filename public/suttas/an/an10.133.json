{
  "uid": "an10.133",
  "title": "Ekādasamasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.133:1.1",
      "pali": "“Dasayime, bhikkhave, sammattā."
    },
    {
      "id": "an10.133:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.133:1.3",
      "pali": "Sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi, sammāñāṇaṁ, sammāvimutti—"
    },
    {
      "id": "an10.133:1.4",
      "pali": "ime kho, bhikkhave, dasa sammattā”ti."
    },
    {
      "id": "an10.133:1.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an10.133:1.6",
      "pali": "Parisuddhavaggo tatiyo."
    }
  ]
}
