{
  "uid": "an10.215",
  "title": "Visāradasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.215:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgatā upāsikā avisāradā agāraṁ ajjhāvasati."
    },
    {
      "id": "an10.215:1.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.215:1.3",
      "pali": "Pāṇātipātinī hoti …"
    },
    {
      "id": "an10.215:1.4",
      "pali": "adinnādāyinī hoti …"
    },
    {
      "id": "an10.215:1.5",
      "pali": "kāmesumicchācārinī hoti …"
    },
    {
      "id": "an10.215:1.6",
      "pali": "musāvādinī hoti …"
    },
    {
      "id": "an10.215:1.7",
      "pali": "pisuṇavācā hoti …"
    },
    {
      "id": "an10.215:1.8",
      "pali": "pharusavācā hoti …"
    },
    {
      "id": "an10.215:1.9",
      "pali": "samphappalāpinī hoti …"
    },
    {
      "id": "an10.215:1.10",
      "pali": "abhijjhālunī hoti …"
    },
    {
      "id": "an10.215:1.11",
      "pali": "byāpannacittā hoti …"
    },
    {
      "id": "an10.215:1.12",
      "pali": "micchādiṭṭhikā hoti …."
    },
    {
      "id": "an10.215:1.13",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgatā upāsikā avisāradā agāraṁ ajjhāvasati."
    },
    {
      "id": "an10.215:2.1",
      "pali": "Dasahi, bhikkhave, dhammehi samannāgatā upāsikā visāradā agāraṁ ajjhāvasati."
    },
    {
      "id": "an10.215:2.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.215:2.3",
      "pali": "Pāṇātipātā paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.4",
      "pali": "adinnādānā paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.5",
      "pali": "kāmesumicchācārā paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.6",
      "pali": "musāvādā paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.7",
      "pali": "pisuṇāya vācāya paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.8",
      "pali": "pharusāya vācāya paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.9",
      "pali": "samphappalāpā paṭiviratā hoti …"
    },
    {
      "id": "an10.215:2.10",
      "pali": "anabhijjhālunī hoti …"
    },
    {
      "id": "an10.215:2.11",
      "pali": "abyāpannacittā hoti …"
    },
    {
      "id": "an10.215:2.12",
      "pali": "sammādiṭṭhikā hoti …."
    },
    {
      "id": "an10.215:2.13",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgatā upāsikā visāradā agāraṁ ajjhāvasatī”ti."
    },
    {
      "id": "an10.215:2.14",
      "pali": "Pañcamaṁ."
    }
  ]
}
