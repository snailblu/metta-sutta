{
  "uid": "an7.37",
  "title": "Dutiyamittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.37:1.1",
      "pali": "“Sattahi, bhikkhave, dhammehi samannāgato bhikkhu mitto sevitabbo bhajitabbo payirupāsitabbo api panujjamānenapi."
    },
    {
      "id": "an7.37:1.2",
      "pali": "Katamehi sattahi?"
    },
    {
      "id": "an7.37:1.3",
      "pali": "Piyo ca hoti manāpo ca garu ca bhāvanīyo ca vattā ca vacanakkhamo ca gambhīrañca kathaṁ kattā hoti, no ca aṭṭhāne niyojeti."
    },
    {
      "id": "an7.37:1.4",
      "pali": "Imehi kho, bhikkhave, sattahi dhammehi samannāgato bhikkhu mitto sevitabbo bhajitabbo payirupāsitabbo api panujjamānenapīti."
    },
    {
      "id": "an7.37:2.1",
      "pali": "Piyo garu bhāvanīyo,"
    },
    {
      "id": "an7.37:2.2",
      "pali": "vattā ca vacanakkhamo;"
    },
    {
      "id": "an7.37:2.3",
      "pali": "Gambhīrañca kathaṁ kattā,"
    },
    {
      "id": "an7.37:2.4",
      "pali": "no caṭṭhāne niyojako."
    },
    {
      "id": "an7.37:3.1",
      "pali": "Yamhi etāni ṭhānāni,"
    },
    {
      "id": "an7.37:3.2",
      "pali": "saṁvijjantīdha puggale;"
    },
    {
      "id": "an7.37:3.3",
      "pali": "So mitto mittakāmena,"
    },
    {
      "id": "an7.37:3.4",
      "pali": "atthakāmānukampato;"
    },
    {
      "id": "an7.37:3.5",
      "pali": "Api nāsiyamānena,"
    },
    {
      "id": "an7.37:3.6",
      "pali": "bhajitabbo tathāvidho”ti."
    },
    {
      "id": "an7.37:3.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
