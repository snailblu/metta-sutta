{
  "uid": "an10.139",
  "title": "Sāsavasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.139:1.1",
      "pali": "“Sāsavañca vo, bhikkhave, dhammaṁ desessāmi anāsavañca."
    },
    {
      "id": "an10.139:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.139:1.3",
      "pali": "katamo ca, bhikkhave, sāsavo dhammo?"
    },
    {
      "id": "an10.139:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.139:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, sāsavo dhammo."
    },
    {
      "id": "an10.139:1.6",
      "pali": "Katamo ca, bhikkhave, anāsavo dhammo?"
    },
    {
      "id": "an10.139:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.139:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, anāsavo dhammo”ti."
    },
    {
      "id": "an10.139:1.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
