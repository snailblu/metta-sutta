{
  "uid": "an5.229",
  "title": "Paṭhamakaṇhasappasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.229:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā kaṇhasappe."
    },
    {
      "id": "an5.229:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.229:1.3",
      "pali": "Asuci, duggandho, sabhīru, sappaṭibhayo, mittadubbhī."
    },
    {
      "id": "an5.229:1.4",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā kaṇhasappe."
    },
    {
      "id": "an5.229:2.1",
      "pali": "Evamevaṁ kho, bhikkhave, pañcime ādīnavā mātugāme."
    },
    {
      "id": "an5.229:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.229:2.3",
      "pali": "Asuci, duggandho, sabhīru, sappaṭibhayo, mittadubbhī."
    },
    {
      "id": "an5.229:2.4",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā mātugāme”ti."
    },
    {
      "id": "an5.229:2.5",
      "pali": "Navamaṁ."
    }
  ]
}
