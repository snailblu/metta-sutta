{
  "uid": "an3.119",
  "title": "Kammantasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.119:1.1",
      "pali": "“Tisso imā, bhikkhave, vipattiyo."
    },
    {
      "id": "an3.119:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.119:1.3",
      "pali": "Kammantavipatti, ājīvavipatti, diṭṭhivipatti."
    },
    {
      "id": "an3.119:1.4",
      "pali": "Katamā ca, bhikkhave, kammantavipatti?"
    },
    {
      "id": "an3.119:1.5",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātī hoti …pe… samphappalāpī hoti."
    },
    {
      "id": "an3.119:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, kammantavipatti."
    },
    {
      "id": "an3.119:2.1",
      "pali": "Katamā ca, bhikkhave, ājīvavipatti?"
    },
    {
      "id": "an3.119:2.2",
      "pali": "Idha, bhikkhave, ekacco micchāājīvo hoti, micchāājīvena jīvikaṁ kappeti."
    },
    {
      "id": "an3.119:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, ājīvavipatti."
    },
    {
      "id": "an3.119:3.1",
      "pali": "Katamā ca, bhikkhave, diṭṭhivipatti?"
    },
    {
      "id": "an3.119:3.2",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti viparītadassano:"
    },
    {
      "id": "an3.119:3.3",
      "pali": "‘natthi dinnaṁ, natthi yiṭṭhaṁ …pe… ye imañca lokaṁ parañca lokaṁ sayaṁ abhiññā sacchikatvā pavedentī’ti."
    },
    {
      "id": "an3.119:3.4",
      "pali": "Ayaṁ vuccati, bhikkhave, diṭṭhivipatti."
    },
    {
      "id": "an3.119:3.5",
      "pali": "Imā kho, bhikkhave, tisso vipattiyoti."
    },
    {
      "id": "an3.119:4.1",
      "pali": "Tisso imā, bhikkhave, sampadā."
    },
    {
      "id": "an3.119:4.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.119:4.3",
      "pali": "Kammantasampadā, ājīvasampadā, diṭṭhisampadā."
    },
    {
      "id": "an3.119:4.4",
      "pali": "Katamā ca, bhikkhave, kammantasampadā?"
    },
    {
      "id": "an3.119:4.5",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātā paṭivirato hoti …pe… samphappalāpā paṭivirato hoti."
    },
    {
      "id": "an3.119:4.6",
      "pali": "Ayaṁ vuccati, bhikkhave, kammantasampadā."
    },
    {
      "id": "an3.119:5.1",
      "pali": "Katamā ca, bhikkhave, ājīvasampadā?"
    },
    {
      "id": "an3.119:5.2",
      "pali": "Idha, bhikkhave, ekacco sammāājīvo hoti, sammāājīvena jīvikaṁ kappeti."
    },
    {
      "id": "an3.119:5.3",
      "pali": "Ayaṁ vuccati, bhikkhave, ājīvasampadā."
    },
    {
      "id": "an3.119:6.1",
      "pali": "Katamā ca, bhikkhave, diṭṭhisampadā?"
    },
    {
      "id": "an3.119:6.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti aviparītadassano:"
    },
    {
      "id": "an3.119:6.3",
      "pali": "‘atthi dinnaṁ, atthi yiṭṭhaṁ …pe… ye imañca lokaṁ parañca lokaṁ sayaṁ abhiññā sacchikatvā pavedentī’ti."
    },
    {
      "id": "an3.119:6.4",
      "pali": "Ayaṁ vuccati, bhikkhave, diṭṭhisampadā."
    },
    {
      "id": "an3.119:6.5",
      "pali": "Imā kho, bhikkhave, tisso sampadā”ti."
    },
    {
      "id": "an3.119:6.6",
      "pali": "Sattamaṁ."
    }
  ]
}
