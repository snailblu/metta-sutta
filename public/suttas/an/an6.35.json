{
  "uid": "an6.35",
  "title": "Vijjābhāgiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.35:1.1",
      "pali": "“Chayime, bhikkhave, dhammā vijjābhāgiyā."
    },
    {
      "id": "an6.35:1.2",
      "pali": "Katame cha?"
    },
    {
      "id": "an6.35:1.3",
      "pali": "Aniccasaññā, anicce dukkhasaññā, dukkhe anattasaññā, pahānasaññā, virāgasaññā, nirodhasaññā—"
    },
    {
      "id": "an6.35:1.4",
      "pali": "ime kho, bhikkhave, cha dhammā vijjābhāgiyā”ti."
    },
    {
      "id": "an6.35:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
