{
  "uid": "an7.10",
  "title": "Macchariyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.10:1.1",
      "pali": "“Sattimāni, bhikkhave, saṁyojanāni."
    },
    {
      "id": "an7.10:1.2",
      "pali": "Katamāni satta?"
    },
    {
      "id": "an7.10:1.3",
      "pali": "Anunayasaṁyojanaṁ, paṭighasaṁyojanaṁ, diṭṭhisaṁyojanaṁ, vicikicchāsaṁyojanaṁ, mānasaṁyojanaṁ, issāsaṁyojanaṁ, macchariyasaṁyojanaṁ."
    },
    {
      "id": "an7.10:1.4",
      "pali": "Imāni kho, bhikkhave, satta saṁyojanānī”ti."
    },
    {
      "id": "an7.10:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an7.10:1.6",
      "pali": "Dhanavaggo paṭhamo."
    },
    {
      "id": "an7.10:2.1",
      "pali": "Dve piyāni balaṁ dhanaṁ,"
    },
    {
      "id": "an7.10:2.2",
      "pali": "Saṅkhittañceva vitthataṁ;"
    },
    {
      "id": "an7.10:2.3",
      "pali": "Uggaṁ saṁyojanañceva,"
    },
    {
      "id": "an7.10:2.4",
      "pali": "Pahānaṁ macchariyena cāti."
    }
  ]
}
