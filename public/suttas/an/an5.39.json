{
  "uid": "an5.39",
  "title": "Puttasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.39:1.1",
      "pali": "“Pañcimāni, bhikkhave, ṭhānāni sampassantā mātāpitaro puttaṁ icchanti kule jāyamānaṁ."
    },
    {
      "id": "an5.39:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.39:1.3",
      "pali": "Bhato vā no bharissati;"
    },
    {
      "id": "an5.39:1.4",
      "pali": "kiccaṁ vā no karissati;"
    },
    {
      "id": "an5.39:1.5",
      "pali": "kulavaṁso ciraṁ ṭhassati;"
    },
    {
      "id": "an5.39:1.6",
      "pali": "dāyajjaṁ paṭipajjissati;"
    },
    {
      "id": "an5.39:1.7",
      "pali": "atha vā pana petānaṁ kālaṅkatānaṁ dakkhiṇaṁ anuppadassatīti."
    },
    {
      "id": "an5.39:1.8",
      "pali": "Imāni kho, bhikkhave, pañca ṭhānāni sampassantā mātāpitaro puttaṁ icchanti kule jāyamānanti."
    },
    {
      "id": "an5.39:2.1",
      "pali": "Pañca ṭhānāni sampassaṁ,"
    },
    {
      "id": "an5.39:2.2",
      "pali": "puttaṁ icchanti paṇḍitā;"
    },
    {
      "id": "an5.39:2.3",
      "pali": "Bhato vā no bharissati,"
    },
    {
      "id": "an5.39:2.4",
      "pali": "kiccaṁ vā no karissati."
    },
    {
      "id": "an5.39:3.1",
      "pali": "Kulavaṁso ciraṁ tiṭṭhe,"
    },
    {
      "id": "an5.39:3.2",
      "pali": "dāyajjaṁ paṭipajjati;"
    },
    {
      "id": "an5.39:3.3",
      "pali": "Atha vā pana petānaṁ,"
    },
    {
      "id": "an5.39:3.4",
      "pali": "dakkhiṇaṁ anuppadassati."
    },
    {
      "id": "an5.39:4.1",
      "pali": "Ṭhānānetāni sampassaṁ,"
    },
    {
      "id": "an5.39:4.2",
      "pali": "puttaṁ icchanti paṇḍitā;"
    },
    {
      "id": "an5.39:4.3",
      "pali": "Tasmā santo sappurisā,"
    },
    {
      "id": "an5.39:4.4",
      "pali": "kataññū katavedino."
    },
    {
      "id": "an5.39:5.1",
      "pali": "Bharanti mātāpitaro,"
    },
    {
      "id": "an5.39:5.2",
      "pali": "pubbe katamanussaraṁ;"
    },
    {
      "id": "an5.39:5.3",
      "pali": "Karonti nesaṁ kiccāni,"
    },
    {
      "id": "an5.39:5.4",
      "pali": "yathā taṁ pubbakārinaṁ."
    },
    {
      "id": "an5.39:6.1",
      "pali": "Ovādakārī bhataposī,"
    },
    {
      "id": "an5.39:6.2",
      "pali": "kulavaṁsaṁ ahāpayaṁ;"
    },
    {
      "id": "an5.39:6.3",
      "pali": "Saddho sīlena sampanno,"
    },
    {
      "id": "an5.39:6.4",
      "pali": "putto hoti pasaṁsiyo”ti."
    },
    {
      "id": "an5.39:6.5",
      "pali": "Navamaṁ."
    }
  ]
}
