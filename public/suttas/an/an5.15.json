{
  "uid": "an5.15",
  "title": "Daṭṭhabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.15:1.1",
      "pali": "“Pañcimāni, bhikkhave, balāni."
    },
    {
      "id": "an5.15:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.15:1.3",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ."
    },
    {
      "id": "an5.15:1.4",
      "pali": "Kattha ca, bhikkhave, saddhābalaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "an5.15:1.5",
      "pali": "Catūsu sotāpattiyaṅgesu."
    },
    {
      "id": "an5.15:1.6",
      "pali": "Ettha saddhābalaṁ daṭṭhabbaṁ."
    },
    {
      "id": "an5.15:1.7",
      "pali": "Kattha ca, bhikkhave, vīriyabalaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "an5.15:1.8",
      "pali": "Catūsu sammappadhānesu."
    },
    {
      "id": "an5.15:1.9",
      "pali": "Ettha vīriyabalaṁ daṭṭhabbaṁ."
    },
    {
      "id": "an5.15:1.10",
      "pali": "Kattha ca, bhikkhave, satibalaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "an5.15:1.11",
      "pali": "Catūsu satipaṭṭhānesu."
    },
    {
      "id": "an5.15:1.12",
      "pali": "Ettha satibalaṁ daṭṭhabbaṁ."
    },
    {
      "id": "an5.15:1.13",
      "pali": "Kattha ca, bhikkhave, samādhibalaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "an5.15:1.14",
      "pali": "Catūsu jhānesu."
    },
    {
      "id": "an5.15:1.15",
      "pali": "Ettha samādhibalaṁ daṭṭhabbaṁ."
    },
    {
      "id": "an5.15:1.16",
      "pali": "Kattha ca, bhikkhave, paññābalaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "an5.15:1.17",
      "pali": "Catūsu ariyasaccesu."
    },
    {
      "id": "an5.15:1.18",
      "pali": "Ettha paññābalaṁ daṭṭhabbaṁ."
    },
    {
      "id": "an5.15:1.19",
      "pali": "Imāni kho, bhikkhave, pañca balānī”ti."
    },
    {
      "id": "an5.15:1.20",
      "pali": "Pañcamaṁ."
    }
  ]
}
