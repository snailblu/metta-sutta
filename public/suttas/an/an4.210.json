{
  "uid": "an4.210",
  "title": "Catutthapāpadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.210:1.1",
      "pali": "“Pāpadhammañca vo, bhikkhave, desessāmi, pāpadhammena pāpadhammatarañca;"
    },
    {
      "id": "an4.210:1.2",
      "pali": "kalyāṇadhammañca, kalyāṇadhammena kalyāṇadhammatarañca. Taṁ suṇātha …pe…."
    },
    {
      "id": "an4.210:2.1",
      "pali": "“Katamo ca, bhikkhave, pāpadhammo?"
    },
    {
      "id": "an4.210:2.2",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāñāṇī hoti, micchāvimutti hoti."
    },
    {
      "id": "an4.210:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpadhammo."
    },
    {
      "id": "an4.210:3.1",
      "pali": "Katamo ca, bhikkhave, pāpadhammena pāpadhammataro?"
    },
    {
      "id": "an4.210:3.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca micchādiṭṭhiko hoti, parañca micchādiṭṭhiyā samādapeti …pe… attanā ca micchāñāṇī hoti, parañca micchāñāṇe samādapeti;"
    },
    {
      "id": "an4.210:3.3",
      "pali": "attanā ca micchāvimutti hoti, parañca micchāvimuttiyā samādapeti."
    },
    {
      "id": "an4.210:3.4",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpadhammena pāpadhammataro."
    },
    {
      "id": "an4.210:4.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇadhammo?"
    },
    {
      "id": "an4.210:4.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāñāṇī hoti, sammāvimutti hoti."
    },
    {
      "id": "an4.210:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇadhammo."
    },
    {
      "id": "an4.210:5.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇadhammena kalyāṇadhammataro?"
    },
    {
      "id": "an4.210:5.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca sammādiṭṭhiko hoti, parañca sammādiṭṭhiyā samādapeti …pe… attanā ca sammāñāṇī hoti, parañca sammāñāṇe samādapeti;"
    },
    {
      "id": "an4.210:5.3",
      "pali": "attanā ca sammāvimutti hoti, parañca sammāvimuttiyā samādapeti."
    },
    {
      "id": "an4.210:5.4",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇadhammena kalyāṇadhammataro”ti."
    },
    {
      "id": "an4.210:5.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.210:5.6",
      "pali": "Sappurisavaggo paṭhamo."
    },
    {
      "id": "an4.210:6.1",
      "pali": "Sikkhāpadañca assaddhaṁ,"
    },
    {
      "id": "an4.210:6.2",
      "pali": "Sattakammaṁ atho ca dasakammaṁ;"
    },
    {
      "id": "an4.210:6.3",
      "pali": "Aṭṭhaṅgikañca dasamaggaṁ,"
    },
    {
      "id": "an4.210:6.4",
      "pali": "Dve pāpadhammā apare dveti."
    }
  ]
}
