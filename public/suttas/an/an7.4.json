{
  "uid": "an7.4",
  "title": "Vitthatabalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.4:1.1",
      "pali": "“Sattimāni, bhikkhave, balāni."
    },
    {
      "id": "an7.4:1.2",
      "pali": "Katamāni satta?"
    },
    {
      "id": "an7.4:1.3",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, hirībalaṁ, ottappabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ."
    },
    {
      "id": "an7.4:2.1",
      "pali": "Katamañca, bhikkhave, saddhābalaṁ?"
    },
    {
      "id": "an7.4:2.2",
      "pali": "Idha, bhikkhave, ariyasāvako saddho hoti, saddahati tathāgatassa bodhiṁ:"
    },
    {
      "id": "an7.4:2.3",
      "pali": "‘itipi so bhagavā arahaṁ sammāsambuddho …pe… satthā devamanussānaṁ buddho bhagavā’ti."
    },
    {
      "id": "an7.4:2.4",
      "pali": "Idaṁ vuccati, bhikkhave, saddhābalaṁ."
    },
    {
      "id": "an7.4:3.1",
      "pali": "Katamañca, bhikkhave, vīriyabalaṁ?"
    },
    {
      "id": "an7.4:3.2",
      "pali": "Idha, bhikkhave, ariyasāvako āraddhavīriyo viharati akusalānaṁ dhammānaṁ pahānāya, kusalānaṁ dhammānaṁ upasampadāya, thāmavā daḷhaparakkamo anikkhittadhuro kusalesu dhammesu."
    },
    {
      "id": "an7.4:3.3",
      "pali": "Idaṁ vuccati, bhikkhave, vīriyabalaṁ."
    },
    {
      "id": "an7.4:4.1",
      "pali": "Katamañca, bhikkhave, hirībalaṁ?"
    },
    {
      "id": "an7.4:4.2",
      "pali": "Idha, bhikkhave, ariyasāvako hirīmā hoti, hirīyati kāyaduccaritena vacīduccaritena manoduccaritena, hirīyati pāpakānaṁ akusalānaṁ dhammānaṁ samāpattiyā."
    },
    {
      "id": "an7.4:4.3",
      "pali": "Idaṁ vuccati, bhikkhave, hirībalaṁ."
    },
    {
      "id": "an7.4:5.1",
      "pali": "Katamañca, bhikkhave, ottappabalaṁ?"
    },
    {
      "id": "an7.4:5.2",
      "pali": "Idha, bhikkhave, ariyasāvako ottappī hoti, ottappati kāyaduccaritena vacīduccaritena manoduccaritena, ottappati pāpakānaṁ akusalānaṁ dhammānaṁ samāpattiyā."
    },
    {
      "id": "an7.4:5.3",
      "pali": "Idaṁ vuccati, bhikkhave, ottappabalaṁ."
    },
    {
      "id": "an7.4:6.1",
      "pali": "Katamañca, bhikkhave, satibalaṁ?"
    },
    {
      "id": "an7.4:6.2",
      "pali": "Idha, bhikkhave, ariyasāvako satimā hoti paramena satinepakkena samannāgato cirakatampi cirabhāsitampi saritā anussaritā."
    },
    {
      "id": "an7.4:6.3",
      "pali": "Idaṁ vuccati, bhikkhave, satibalaṁ."
    },
    {
      "id": "an7.4:7.1",
      "pali": "Katamañca, bhikkhave, samādhibalaṁ?"
    },
    {
      "id": "an7.4:7.2",
      "pali": "Idha, bhikkhave, ariyasāvako vivicceva kāmehi"
    },
    {
      "id": "an7.4:7.3",
      "pali": "…pe…"
    },
    {
      "id": "an7.4:7.4",
      "pali": "catutthaṁ jhānaṁ upasampajja viharati."
    },
    {
      "id": "an7.4:7.5",
      "pali": "Idaṁ vuccati, bhikkhave, samādhibalaṁ."
    },
    {
      "id": "an7.4:8.1",
      "pali": "Katamañca, bhikkhave, paññābalaṁ?"
    },
    {
      "id": "an7.4:8.2",
      "pali": "Idha, bhikkhave, ariyasāvako paññavā hoti udayatthagāminiyā paññāya samannāgato ariyāya nibbedhikāya sammā dukkhakkhayagāminiyā."
    },
    {
      "id": "an7.4:8.3",
      "pali": "Idaṁ vuccati, bhikkhave, paññābalaṁ."
    },
    {
      "id": "an7.4:9.1",
      "pali": "Imāni kho, bhikkhave, satta balānīti."
    },
    {
      "id": "an7.4:10.1",
      "pali": "Saddhābalaṁ vīriyañca,"
    },
    {
      "id": "an7.4:10.2",
      "pali": "hirī ottappiyaṁ balaṁ;"
    },
    {
      "id": "an7.4:10.3",
      "pali": "Satibalaṁ samādhi ca,"
    },
    {
      "id": "an7.4:10.4",
      "pali": "paññā ve sattamaṁ balaṁ;"
    },
    {
      "id": "an7.4:10.5",
      "pali": "Etehi balavā bhikkhu,"
    },
    {
      "id": "an7.4:10.6",
      "pali": "sukhaṁ jīvati paṇḍito."
    },
    {
      "id": "an7.4:11.1",
      "pali": "Yoniso vicine dhammaṁ,"
    },
    {
      "id": "an7.4:11.2",
      "pali": "paññāyatthaṁ vipassati;"
    },
    {
      "id": "an7.4:11.3",
      "pali": "Pajjotasseva nibbānaṁ,"
    },
    {
      "id": "an7.4:11.4",
      "pali": "vimokkho hoti cetaso”ti."
    },
    {
      "id": "an7.4:11.5",
      "pali": "Catutthaṁ."
    }
  ]
}
