{
  "uid": "an10.135",
  "title": "Ariyadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.135:1.1",
      "pali": "“Ariyadhammañca vo, bhikkhave, desessāmi anariyadhammañca."
    },
    {
      "id": "an10.135:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.135:1.3",
      "pali": "katamo ca, bhikkhave, anariyo dhammo?"
    },
    {
      "id": "an10.135:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.135:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, anariyo dhammo."
    },
    {
      "id": "an10.135:1.6",
      "pali": "Katamo ca, bhikkhave, ariyo dhammo?"
    },
    {
      "id": "an10.135:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.135:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, ariyo dhammo”ti."
    },
    {
      "id": "an10.135:1.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
