{
  "uid": "an4.64",
  "title": "Nirayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.64:1.1",
      "pali": "“Catūhi, bhikkhave, dhammehi samannāgato yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an4.64:1.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an4.64:1.3",
      "pali": "Pāṇātipātī hoti, adinnādāyī hoti, kāmesumicchācārī hoti, musāvādī hoti—"
    },
    {
      "id": "an4.64:1.4",
      "pali": "imehi kho, bhikkhave, catūhi dhammehi samannāgato yathābhataṁ nikkhitto evaṁ nirayeti."
    },
    {
      "id": "an4.64:2.1",
      "pali": "Pāṇātipāto adinnādānaṁ,"
    },
    {
      "id": "an4.64:2.2",
      "pali": "Musāvādo ca vuccati;"
    },
    {
      "id": "an4.64:2.3",
      "pali": "Paradāragamanañcāpi,"
    },
    {
      "id": "an4.64:2.4",
      "pali": "Nappasaṁsanti paṇḍitā”ti."
    },
    {
      "id": "an4.64:2.5",
      "pali": "Catutthaṁ."
    }
  ]
}
