{
  "uid": "an5.126",
  "title": "Dutiyaanāyussāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.126:1.1",
      "pali": "“Pañcime, bhikkhave, dhammā anāyussā."
    },
    {
      "id": "an5.126:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.126:1.3",
      "pali": "Asappāyakārī hoti, sappāye mattaṁ na jānāti, apariṇatabhojī ca hoti, dussīlo ca, pāpamitto ca."
    },
    {
      "id": "an5.126:1.4",
      "pali": "Ime kho, bhikkhave, pañca dhammā anāyussā."
    },
    {
      "id": "an5.126:2.1",
      "pali": "Pañcime, bhikkhave, dhammā āyussā."
    },
    {
      "id": "an5.126:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.126:2.3",
      "pali": "Sappāyakārī hoti, sappāye mattaṁ jānāti, pariṇatabhojī ca hoti, sīlavā ca, kalyāṇamitto ca."
    },
    {
      "id": "an5.126:2.4",
      "pali": "Ime kho, bhikkhave, pañca dhammā āyussā”ti."
    },
    {
      "id": "an5.126:2.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
