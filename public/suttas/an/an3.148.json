{
  "uid": "an3.148",
  "title": "Visamasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.148:1.1",
      "pali": "“Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.148:1.2",
      "pali": "visamena kāyakammena, visamena vacīkammena, visamena manokammena—"
    },
    {
      "id": "an3.148:1.3",
      "pali": "imehi kho …pe… evaṁ niraye."
    },
    {
      "id": "an3.148:2.1",
      "pali": "Tīhi, bhikkhave, dhammehi …pe…"
    },
    {
      "id": "an3.148:2.2",
      "pali": "samena kāyakammena, samena vacīkammena, samena manokammena—"
    },
    {
      "id": "an3.148:2.3",
      "pali": "imehi kho …pe… evaṁ sagge”ti."
    },
    {
      "id": "an3.148:2.4",
      "pali": "Tatiyaṁ."
    }
  ]
}
