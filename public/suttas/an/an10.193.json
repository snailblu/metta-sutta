{
  "uid": "an10.193",
  "title": "Uppādetabbadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.193:1.1",
      "pali": "“Uppādetabbañca vo, bhikkhave, dhammaṁ desessāmi na uppādetabbañca."
    },
    {
      "id": "an10.193:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.193:1.3",
      "pali": "katamo ca, bhikkhave, na uppādetabbo dhammo?"
    },
    {
      "id": "an10.193:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.193:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.193:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, na uppādetabbo dhammo."
    },
    {
      "id": "an10.193:2.1",
      "pali": "Katamo ca, bhikkhave, uppādetabbo dhammo?"
    },
    {
      "id": "an10.193:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.193:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.193:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, uppādetabbo dhammo”ti."
    },
    {
      "id": "an10.193:2.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
