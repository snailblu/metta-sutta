{
  "uid": "an10.147",
  "title": "Saddhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.147:1.1",
      "pali": "“Saddhammañca vo, bhikkhave, dhammaṁ desessāmi asaddhammañca."
    },
    {
      "id": "an10.147:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.147:1.3",
      "pali": "katamo ca, bhikkhave, asaddhammo?"
    },
    {
      "id": "an10.147:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.147:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, asaddhammo."
    },
    {
      "id": "an10.147:1.6",
      "pali": "Katamo ca, bhikkhave, saddhammo?"
    },
    {
      "id": "an10.147:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.147:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, saddhammo”ti."
    },
    {
      "id": "an10.147:1.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
