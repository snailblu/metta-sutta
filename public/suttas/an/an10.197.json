{
  "uid": "an10.197",
  "title": "Anussaritabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.197:1.1",
      "pali": "“Anussaritabbañca vo, bhikkhave, dhammaṁ desessāmi nānussaritabbañca."
    },
    {
      "id": "an10.197:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.197:1.3",
      "pali": "katamo ca, bhikkhave, nānussaritabbo dhammo?"
    },
    {
      "id": "an10.197:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.197:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.197:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, nānussaritabbo dhammo."
    },
    {
      "id": "an10.197:2.1",
      "pali": "Katamo ca, bhikkhave, anussaritabbo dhammo?"
    },
    {
      "id": "an10.197:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.197:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.197:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, anussaritabbo dhammo”ti."
    },
    {
      "id": "an10.197:2.5",
      "pali": "Navamaṁ."
    }
  ]
}
