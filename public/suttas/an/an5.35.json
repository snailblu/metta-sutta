{
  "uid": "an5.35",
  "title": "Dānānisaṁsasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.35:1.1",
      "pali": "“Pañcime, bhikkhave, dāne ānisaṁsā."
    },
    {
      "id": "an5.35:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.35:1.3",
      "pali": "Bahuno janassa piyo hoti manāpo;"
    },
    {
      "id": "an5.35:1.4",
      "pali": "santo sappurisā bhajanti;"
    },
    {
      "id": "an5.35:1.5",
      "pali": "kalyāṇo kittisaddo abbhuggacchati;"
    },
    {
      "id": "an5.35:1.6",
      "pali": "gihidhammā anapagato hoti;"
    },
    {
      "id": "an5.35:1.7",
      "pali": "kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati."
    },
    {
      "id": "an5.35:1.8",
      "pali": "Ime kho, bhikkhave, pañca dāne ānisaṁsāti."
    },
    {
      "id": "an5.35:2.1",
      "pali": "Dadamāno piyo hoti,"
    },
    {
      "id": "an5.35:2.2",
      "pali": "sataṁ dhammaṁ anukkamaṁ;"
    },
    {
      "id": "an5.35:2.3",
      "pali": "Santo naṁ sadā bhajanti,"
    },
    {
      "id": "an5.35:2.4",
      "pali": "saññatā brahmacārayo."
    },
    {
      "id": "an5.35:3.1",
      "pali": "Te tassa dhammaṁ desenti,"
    },
    {
      "id": "an5.35:3.2",
      "pali": "Sabbadukkhāpanūdanaṁ;"
    },
    {
      "id": "an5.35:3.3",
      "pali": "Yaṁ so dhammaṁ idhaññāya,"
    },
    {
      "id": "an5.35:3.4",
      "pali": "Parinibbāti anāsavo”ti."
    },
    {
      "id": "an5.35:3.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
