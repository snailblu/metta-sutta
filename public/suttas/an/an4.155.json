{
  "uid": "an4.155",
  "title": "Paṭisaṅkhānabalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.155:1.1",
      "pali": "“Cattārimāni, bhikkhave, balāni."
    },
    {
      "id": "an4.155:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.155:1.3",
      "pali": "Paṭisaṅkhānabalaṁ, bhāvanābalaṁ, anavajjabalaṁ, saṅgahabalaṁ—"
    },
    {
      "id": "an4.155:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri balānī”ti."
    },
    {
      "id": "an4.155:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
