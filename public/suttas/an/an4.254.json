{
  "uid": "an4.254",
  "title": "Abhiññāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.254:1.1",
      "pali": "“Cattārome, bhikkhave, dhammā."
    },
    {
      "id": "an4.254:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.254:1.3",
      "pali": "Atthi, bhikkhave, dhammā abhiññā pariññeyyā;"
    },
    {
      "id": "an4.254:1.4",
      "pali": "atthi, bhikkhave, dhammā abhiññā pahātabbā;"
    },
    {
      "id": "an4.254:1.5",
      "pali": "atthi, bhikkhave, dhammā abhiññā bhāvetabbā;"
    },
    {
      "id": "an4.254:1.6",
      "pali": "atthi, bhikkhave, dhammā abhiññā sacchikātabbā."
    },
    {
      "id": "an4.254:2.1",
      "pali": "Katame ca, bhikkhave, dhammā abhiññā pariññeyyā?"
    },
    {
      "id": "an4.254:2.2",
      "pali": "Pañcupādānakkhandhā—"
    },
    {
      "id": "an4.254:2.3",
      "pali": "ime vuccanti, bhikkhave, dhammā abhiññā pariññeyyā."
    },
    {
      "id": "an4.254:3.1",
      "pali": "Katame ca, bhikkhave, dhammā abhiññā pahātabbā?"
    },
    {
      "id": "an4.254:3.2",
      "pali": "Avijjā ca bhavataṇhā ca—"
    },
    {
      "id": "an4.254:3.3",
      "pali": "ime vuccanti, bhikkhave, dhammā abhiññā pahātabbā."
    },
    {
      "id": "an4.254:4.1",
      "pali": "Katame ca, bhikkhave, dhammā abhiññā bhāvetabbā?"
    },
    {
      "id": "an4.254:4.2",
      "pali": "Samatho ca vipassanā ca—"
    },
    {
      "id": "an4.254:4.3",
      "pali": "ime vuccanti, bhikkhave, dhammā abhiññā bhāvetabbā."
    },
    {
      "id": "an4.254:5.1",
      "pali": "Katame ca, bhikkhave, dhammā abhiññā sacchikātabbā?"
    },
    {
      "id": "an4.254:5.2",
      "pali": "Vijjā ca vimutti ca—"
    },
    {
      "id": "an4.254:5.3",
      "pali": "ime vuccanti, bhikkhave, dhammā abhiññā sacchikātabbā."
    },
    {
      "id": "an4.254:5.4",
      "pali": "Ime kho, bhikkhave, cattāro dhammā”ti."
    },
    {
      "id": "an4.254:5.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
