{
  "uid": "an4.140",
  "title": "Vādīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.140:1.1",
      "pali": "“Cattārome, bhikkhave, vādī."
    },
    {
      "id": "an4.140:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.140:1.3",
      "pali": "Atthi, bhikkhave, vādī atthato pariyādānaṁ gacchati, no byañjanato;"
    },
    {
      "id": "an4.140:1.4",
      "pali": "atthi, bhikkhave, vādī byañjanato pariyādānaṁ gacchati, no atthato;"
    },
    {
      "id": "an4.140:1.5",
      "pali": "atthi, bhikkhave, vādī atthato ca byañjanato ca pariyādānaṁ gacchati;"
    },
    {
      "id": "an4.140:1.6",
      "pali": "atthi, bhikkhave, vādī nevatthato no byañjanato pariyādānaṁ gacchati."
    },
    {
      "id": "an4.140:1.7",
      "pali": "Ime kho, bhikkhave, cattāro vādī."
    },
    {
      "id": "an4.140:1.8",
      "pali": "Aṭṭhānametaṁ, bhikkhave, anavakāso yaṁ catūhi paṭisambhidāhi samannāgato atthato vā byañjanato vā pariyādānaṁ gaccheyyā”ti."
    },
    {
      "id": "an4.140:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.140:1.10",
      "pali": "Puggalavaggo catuttho."
    },
    {
      "id": "an4.140:2.1",
      "pali": "Saṁyojanaṁ paṭibhāno,"
    },
    {
      "id": "an4.140:2.2",
      "pali": "ugghaṭitaññu uṭṭhānaṁ;"
    },
    {
      "id": "an4.140:2.3",
      "pali": "Sāvajjo dve ca sīlāni,"
    },
    {
      "id": "an4.140:2.4",
      "pali": "nikaṭṭha dhamma vādī cāti."
    }
  ]
}
