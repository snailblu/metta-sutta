{
  "uid": "an4.19",
  "title": "Tatiyaagatisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.19:1.1",
      "pali": "“Cattārimāni, bhikkhave, agatigamanāni."
    },
    {
      "id": "an4.19:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.19:1.3",
      "pali": "Chandāgatiṁ gacchati, dosāgatiṁ gacchati, mohāgatiṁ gacchati, bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.19:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri agatigamanāni."
    },
    {
      "id": "an4.19:2.1",
      "pali": "Cattārimāni, bhikkhave, nāgatigamanāni."
    },
    {
      "id": "an4.19:2.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.19:2.3",
      "pali": "Na chandāgatiṁ gacchati, na dosāgatiṁ gacchati, na mohāgatiṁ gacchati, na bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.19:2.4",
      "pali": "Imāni kho, bhikkhave, cattāri nāgatigamanānīti."
    },
    {
      "id": "an4.19:3.1",
      "pali": "Chandā dosā bhayā mohā,"
    },
    {
      "id": "an4.19:3.2",
      "pali": "yo dhammaṁ ativattati;"
    },
    {
      "id": "an4.19:3.3",
      "pali": "Nihīyati tassa yaso,"
    },
    {
      "id": "an4.19:3.4",
      "pali": "kāḷapakkheva candimā."
    },
    {
      "id": "an4.19:4.1",
      "pali": "Chandā dosā bhayā mohā,"
    },
    {
      "id": "an4.19:4.2",
      "pali": "yo dhammaṁ nātivattati;"
    },
    {
      "id": "an4.19:4.3",
      "pali": "Āpūrati tassa yaso,"
    },
    {
      "id": "an4.19:4.4",
      "pali": "sukkapakkheva candimā”ti."
    },
    {
      "id": "an4.19:4.5",
      "pali": "Navamaṁ."
    }
  ]
}
