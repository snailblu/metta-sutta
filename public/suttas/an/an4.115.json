{
  "uid": "an4.115",
  "title": "Ṭhānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.115:1.1",
      "pali": "“Cattārimāni, bhikkhave, ṭhānāni."
    },
    {
      "id": "an4.115:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.115:1.3",
      "pali": "Atthi, bhikkhave, ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:1.4",
      "pali": "tañca kayiramānaṁ anatthāya saṁvattati."
    },
    {
      "id": "an4.115:1.5",
      "pali": "Atthi, bhikkhave, ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:1.6",
      "pali": "tañca kayiramānaṁ atthāya saṁvattati."
    },
    {
      "id": "an4.115:1.7",
      "pali": "Atthi, bhikkhave, ṭhānaṁ manāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:1.8",
      "pali": "tañca kayiramānaṁ anatthāya saṁvattati."
    },
    {
      "id": "an4.115:1.9",
      "pali": "Atthi, bhikkhave, ṭhānaṁ manāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:1.10",
      "pali": "tañca kayiramānaṁ atthāya saṁvattati."
    },
    {
      "id": "an4.115:2.1",
      "pali": "Tatra, bhikkhave, yamidaṁ ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:2.2",
      "pali": "tañca kayiramānaṁ anatthāya saṁvattati—"
    },
    {
      "id": "an4.115:2.3",
      "pali": "idaṁ, bhikkhave, ṭhānaṁ ubhayeneva na kattabbaṁ maññati."
    },
    {
      "id": "an4.115:2.4",
      "pali": "Yampidaṁ ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:2.5",
      "pali": "imināpi naṁ na kattabbaṁ maññati."
    },
    {
      "id": "an4.115:2.6",
      "pali": "Yampidaṁ ṭhānaṁ kayiramānaṁ anatthāya saṁvattati;"
    },
    {
      "id": "an4.115:2.7",
      "pali": "imināpi naṁ na kattabbaṁ maññati."
    },
    {
      "id": "an4.115:2.8",
      "pali": "Idaṁ, bhikkhave, ṭhānaṁ ubhayeneva na kattabbaṁ maññati."
    },
    {
      "id": "an4.115:3.1",
      "pali": "Tatra, bhikkhave, yamidaṁ ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:3.2",
      "pali": "tañca kayiramānaṁ atthāya saṁvattati—"
    },
    {
      "id": "an4.115:3.3",
      "pali": "imasmiṁ, bhikkhave, ṭhāne bālo ca paṇḍito ca veditabbo purisathāme purisavīriye purisaparakkame."
    },
    {
      "id": "an4.115:3.4",
      "pali": "Na, bhikkhave, bālo iti paṭisañcikkhati:"
    },
    {
      "id": "an4.115:3.5",
      "pali": "‘kiñcāpi kho idaṁ ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:3.6",
      "pali": "atha carahidaṁ ṭhānaṁ kayiramānaṁ atthāya saṁvattatī’ti."
    },
    {
      "id": "an4.115:3.7",
      "pali": "So taṁ ṭhānaṁ na karoti."
    },
    {
      "id": "an4.115:3.8",
      "pali": "Tassa taṁ ṭhānaṁ akayiramānaṁ anatthāya saṁvattati."
    },
    {
      "id": "an4.115:3.9",
      "pali": "Paṇḍito ca kho, bhikkhave, iti paṭisañcikkhati:"
    },
    {
      "id": "an4.115:3.10",
      "pali": "‘kiñcāpi kho idaṁ ṭhānaṁ amanāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:3.11",
      "pali": "atha carahidaṁ ṭhānaṁ kayiramānaṁ atthāya saṁvattatī’ti."
    },
    {
      "id": "an4.115:3.12",
      "pali": "So taṁ ṭhānaṁ karoti."
    },
    {
      "id": "an4.115:3.13",
      "pali": "Tassa taṁ ṭhānaṁ kayiramānaṁ atthāya saṁvattati."
    },
    {
      "id": "an4.115:4.1",
      "pali": "Tatra, bhikkhave, yamidaṁ ṭhānaṁ manāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:4.2",
      "pali": "tañca kayiramānaṁ anatthāya saṁvattati—"
    },
    {
      "id": "an4.115:4.3",
      "pali": "imasmimpi, bhikkhave, ṭhāne bālo ca paṇḍito ca veditabbo purisathāme purisavīriye purisaparakkame."
    },
    {
      "id": "an4.115:4.4",
      "pali": "Na, bhikkhave, bālo iti paṭisañcikkhati:"
    },
    {
      "id": "an4.115:4.5",
      "pali": "‘kiñcāpi kho idaṁ ṭhānaṁ manāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:4.6",
      "pali": "atha carahidaṁ ṭhānaṁ kayiramānaṁ anatthāya saṁvattatī’ti."
    },
    {
      "id": "an4.115:4.7",
      "pali": "So taṁ ṭhānaṁ karoti."
    },
    {
      "id": "an4.115:4.8",
      "pali": "Tassa taṁ ṭhānaṁ kayiramānaṁ anatthāya saṁvattati."
    },
    {
      "id": "an4.115:4.9",
      "pali": "Paṇḍito ca kho, bhikkhave, iti paṭisañcikkhati:"
    },
    {
      "id": "an4.115:4.10",
      "pali": "‘kiñcāpi kho idaṁ ṭhānaṁ manāpaṁ kātuṁ;"
    },
    {
      "id": "an4.115:4.11",
      "pali": "atha carahidaṁ ṭhānaṁ kayiramānaṁ anatthāya saṁvattatī’ti."
    },
    {
      "id": "an4.115:4.12",
      "pali": "So taṁ ṭhānaṁ na karoti."
    },
    {
      "id": "an4.115:4.13",
      "pali": "Tassa taṁ ṭhānaṁ akayiramānaṁ atthāya saṁvattati."
    },
    {
      "id": "an4.115:5.1",
      "pali": "Tatra, bhikkhave, yamidaṁ ṭhānaṁ manāpaṁ kātuṁ, tañca kayiramānaṁ atthāya saṁvattati—"
    },
    {
      "id": "an4.115:5.2",
      "pali": "idaṁ, bhikkhave, ṭhānaṁ ubhayeneva kattabbaṁ maññati."
    },
    {
      "id": "an4.115:5.3",
      "pali": "Yampidaṁ ṭhānaṁ manāpaṁ kātuṁ, imināpi naṁ kattabbaṁ maññati;"
    },
    {
      "id": "an4.115:5.4",
      "pali": "yampidaṁ ṭhānaṁ kayiramānaṁ atthāya saṁvattati, imināpi naṁ kattabbaṁ maññati."
    },
    {
      "id": "an4.115:5.5",
      "pali": "Idaṁ, bhikkhave, ṭhānaṁ ubhayeneva kattabbaṁ maññati."
    },
    {
      "id": "an4.115:5.6",
      "pali": "Imāni kho, bhikkhave, cattāri ṭhānānī”ti."
    },
    {
      "id": "an4.115:5.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
