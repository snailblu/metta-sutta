{
  "uid": "an2.118-129",
  "title": "an2.118-129",
  "nikaya": "an",
  "segments": [
    {
      "id": "an2.118:1.1",
      "pali": "“Dvemā, bhikkhave, āsā duppajahā."
    },
    {
      "id": "an2.118:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.118:1.3",
      "pali": "Lābhāsā ca jīvitāsā ca."
    },
    {
      "id": "an2.118:1.4",
      "pali": "Imā kho, bhikkhave, dve āsā duppajahā”ti."
    },
    {
      "id": "an2.119:1.1",
      "pali": "“Dveme, bhikkhave, puggalā dullabhā lokasmiṁ."
    },
    {
      "id": "an2.119:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.119:1.3",
      "pali": "Yo ca pubbakārī, yo ca kataññū katavedī."
    },
    {
      "id": "an2.119:1.4",
      "pali": "Ime kho, bhikkhave, dve puggalā dullabhā lokasmin”ti."
    },
    {
      "id": "an2.120:1.1",
      "pali": "“Dveme, bhikkhave, puggalā dullabhā lokasmiṁ."
    },
    {
      "id": "an2.120:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.120:1.3",
      "pali": "Titto ca tappetā ca."
    },
    {
      "id": "an2.120:1.4",
      "pali": "Ime kho, bhikkhave, dve puggalā dullabhā lokasmin”ti."
    },
    {
      "id": "an2.121:1.1",
      "pali": "“Dveme, bhikkhave, puggalā duttappayā."
    },
    {
      "id": "an2.121:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.121:1.3",
      "pali": "Yo ca laddhaṁ laddhaṁ nikkhipati, yo ca laddhaṁ laddhaṁ vissajjeti."
    },
    {
      "id": "an2.121:1.4",
      "pali": "Ime kho, bhikkhave, dve puggalā duttappayā”ti."
    },
    {
      "id": "an2.122:1.1",
      "pali": "“Dveme, bhikkhave, puggalā sutappayā."
    },
    {
      "id": "an2.122:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.122:1.3",
      "pali": "Yo ca laddhaṁ laddhaṁ na nikkhipati, yo ca laddhaṁ laddhaṁ na vissajjeti."
    },
    {
      "id": "an2.122:1.4",
      "pali": "Ime kho, bhikkhave, dve puggalā sutappayā”ti."
    },
    {
      "id": "an2.123:1.1",
      "pali": "“Dveme, bhikkhave, paccayā rāgassa uppādāya."
    },
    {
      "id": "an2.123:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.123:1.3",
      "pali": "Subhanimittañca ayoniso ca manasikāro."
    },
    {
      "id": "an2.123:1.4",
      "pali": "Ime kho, bhikkhave, dve paccayā rāgassa uppādāyā”ti."
    },
    {
      "id": "an2.124:1.1",
      "pali": "“Dveme, bhikkhave, paccayā dosassa uppādāya."
    },
    {
      "id": "an2.124:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.124:1.3",
      "pali": "Paṭighanimittañca ayoniso ca manasikāro."
    },
    {
      "id": "an2.124:1.4",
      "pali": "Ime kho, bhikkhave, dve paccayā dosassa uppādāyā”ti."
    },
    {
      "id": "an2.125:1.1",
      "pali": "“Dveme, bhikkhave, paccayā micchādiṭṭhiyā uppādāya."
    },
    {
      "id": "an2.125:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.125:1.3",
      "pali": "Parato ca ghoso ayoniso ca manasikāro."
    },
    {
      "id": "an2.125:1.4",
      "pali": "Ime kho, bhikkhave, dve paccayā micchādiṭṭhiyā uppādāyā”ti."
    },
    {
      "id": "an2.126:1.1",
      "pali": "“Dveme, bhikkhave, paccayā sammādiṭṭhiyā uppādāya."
    },
    {
      "id": "an2.126:1.2",
      "pali": "Katame dve?"
    },
    {
      "id": "an2.126:1.3",
      "pali": "Parato ca ghoso, yoniso ca manasikāro."
    },
    {
      "id": "an2.126:1.4",
      "pali": "Ime kho, bhikkhave, dve paccayā sammādiṭṭhiyā uppādāyā”ti."
    },
    {
      "id": "an2.127:1.1",
      "pali": "“Dvemā, bhikkhave, āpattiyo."
    },
    {
      "id": "an2.127:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.127:1.3",
      "pali": "Lahukā ca āpatti, garukā ca āpatti."
    },
    {
      "id": "an2.127:1.4",
      "pali": "Imā kho, bhikkhave, dve āpattiyo”ti."
    },
    {
      "id": "an2.128:1.1",
      "pali": "“Dvemā, bhikkhave, āpattiyo."
    },
    {
      "id": "an2.128:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.128:1.3",
      "pali": "Duṭṭhullā ca āpatti, aduṭṭhullā ca āpatti."
    },
    {
      "id": "an2.128:1.4",
      "pali": "Imā kho, bhikkhave, dve āpattiyo”ti."
    },
    {
      "id": "an2.129:1.1",
      "pali": "“Dvemā, bhikkhave, āpattiyo."
    },
    {
      "id": "an2.129:1.2",
      "pali": "Katamā dve?"
    },
    {
      "id": "an2.129:1.3",
      "pali": "Sāvasesā ca āpatti, anavasesā ca āpatti."
    },
    {
      "id": "an2.129:1.4",
      "pali": "Imā kho, bhikkhave, dve āpattiyo”ti."
    },
    {
      "id": "an2.129:1.5",
      "pali": "Āsāduppajahavaggo paṭhamo."
    }
  ]
}
