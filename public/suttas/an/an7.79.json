{
  "uid": "an7.79",
  "title": "Paṭhamavinayadharasobhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.79:1.1",
      "pali": "“Sattahi, bhikkhave, dhammehi samannāgato vinayadharo sobhati."
    },
    {
      "id": "an7.79:1.2",
      "pali": "Katamehi sattahi?"
    },
    {
      "id": "an7.79:1.3",
      "pali": "Āpattiṁ jānāti,"
    },
    {
      "id": "an7.79:1.4",
      "pali": "anāpattiṁ jānāti,"
    },
    {
      "id": "an7.79:1.5",
      "pali": "lahukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.79:1.6",
      "pali": "garukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.79:1.7",
      "pali": "sīlavā hoti …pe… samādāya sikkhati sikkhāpadesu,"
    },
    {
      "id": "an7.79:1.8",
      "pali": "catunnaṁ jhānānaṁ ābhicetasikānaṁ nikāmalābhī hoti akicchalābhī akasiralābhī,"
    },
    {
      "id": "an7.79:1.9",
      "pali": "āsavānaṁ khayā …pe… sacchikatvā upasampajja viharati."
    },
    {
      "id": "an7.79:1.10",
      "pali": "Imehi kho, bhikkhave, sattahi dhammehi samannāgato vinayadharo sobhatī”ti."
    },
    {
      "id": "an7.79:1.11",
      "pali": "Pañcamaṁ."
    }
  ]
}
