{
  "uid": "an10.117",
  "title": "Saṅgāravasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.117:1.1",
      "pali": "Atha kho saṅgāravo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "an10.117:1.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho saṅgāravo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "an10.117:1.3",
      "pali": "“kiṁ nu kho, bho gotama, orimaṁ tīraṁ, kiṁ pārimaṁ tīran”ti?"
    },
    {
      "id": "an10.117:1.4",
      "pali": "“Micchādiṭṭhi kho, brāhmaṇa, orimaṁ tīraṁ, sammādiṭṭhi pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.5",
      "pali": "micchāsaṅkappo orimaṁ tīraṁ, sammāsaṅkappo pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.6",
      "pali": "micchāvācā orimaṁ tīraṁ, sammāvācā pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.7",
      "pali": "micchākammanto orimaṁ tīraṁ, sammākammanto pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.8",
      "pali": "micchāājīvo orimaṁ tīraṁ, sammāājīvo pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.9",
      "pali": "micchāvāyāmo orimaṁ tīraṁ, sammāvāyāmo pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.10",
      "pali": "micchāsati orimaṁ tīraṁ, sammāsati pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.11",
      "pali": "micchāsamādhi orimaṁ tīraṁ, sammāsamādhi pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.12",
      "pali": "micchāñāṇaṁ orimaṁ tīraṁ, sammāñāṇaṁ pārimaṁ tīraṁ;"
    },
    {
      "id": "an10.117:1.13",
      "pali": "micchāvimutti orimaṁ tīraṁ, sammāvimutti pārimaṁ tīranti."
    },
    {
      "id": "an10.117:1.14",
      "pali": "Idaṁ kho, brāhmaṇa, orimaṁ tīraṁ, idaṁ pārimaṁ tīranti."
    },
    {
      "id": "an10.117:2.1",
      "pali": "Appakā te manussesu,"
    },
    {
      "id": "an10.117:2.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "an10.117:2.3",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "an10.117:2.4",
      "pali": "tīramevānudhāvati."
    },
    {
      "id": "an10.117:3.1",
      "pali": "Ye ca kho sammadakkhāte,"
    },
    {
      "id": "an10.117:3.2",
      "pali": "dhamme dhammānuvattino;"
    },
    {
      "id": "an10.117:3.3",
      "pali": "Te janā pāramessanti,"
    },
    {
      "id": "an10.117:3.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "an10.117:4.1",
      "pali": "Kaṇhaṁ dhammaṁ vippahāya,"
    },
    {
      "id": "an10.117:4.2",
      "pali": "Sukkaṁ bhāvetha paṇḍito;"
    },
    {
      "id": "an10.117:4.3",
      "pali": "Okā anokamāgamma,"
    },
    {
      "id": "an10.117:4.4",
      "pali": "Viveke yattha dūramaṁ."
    },
    {
      "id": "an10.117:5.1",
      "pali": "Tatrābhiratimiccheyya,"
    },
    {
      "id": "an10.117:5.2",
      "pali": "hitvā kāme akiñcano;"
    },
    {
      "id": "an10.117:5.3",
      "pali": "Pariyodapeyya attānaṁ,"
    },
    {
      "id": "an10.117:5.4",
      "pali": "cittaklesehi paṇḍito."
    },
    {
      "id": "an10.117:6.1",
      "pali": "Yesaṁ sambodhiyaṅgesu,"
    },
    {
      "id": "an10.117:6.2",
      "pali": "sammā cittaṁ subhāvitaṁ;"
    },
    {
      "id": "an10.117:6.3",
      "pali": "Ādānapaṭinissagge,"
    },
    {
      "id": "an10.117:6.4",
      "pali": "anupādāya ye ratā;"
    },
    {
      "id": "an10.117:6.5",
      "pali": "Khīṇāsavā jutimanto,"
    },
    {
      "id": "an10.117:6.6",
      "pali": "te loke parinibbutā”ti."
    },
    {
      "id": "an10.117:6.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
