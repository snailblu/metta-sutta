{
  "uid": "an4.242",
  "title": "Sappurisānisaṁsasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.242:1.1",
      "pali": "“Sappurisaṁ, bhikkhave, nissāya cattāro ānisaṁsā pāṭikaṅkhā."
    },
    {
      "id": "an4.242:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.242:1.3",
      "pali": "Ariyena sīlena vaḍḍhati, ariyena samādhinā vaḍḍhati, ariyāya paññāya vaḍḍhati, ariyāya vimuttiyā vaḍḍhati—"
    },
    {
      "id": "an4.242:1.4",
      "pali": "sappurisaṁ, bhikkhave, nissāya ime cattāro ānisaṁsā pāṭikaṅkhā”ti."
    },
    {
      "id": "an4.242:1.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an4.242:1.6",
      "pali": "Kammavaggo catuttho."
    },
    {
      "id": "an4.242:2.1",
      "pali": "Saṅkhitta vitthāra soṇakāyana,"
    },
    {
      "id": "an4.242:2.2",
      "pali": "Sikkhāpadaṁ ariyamaggo bojjhaṅgaṁ;"
    },
    {
      "id": "an4.242:2.3",
      "pali": "Sāvajjañceva abyābajjhaṁ,"
    },
    {
      "id": "an4.242:2.4",
      "pali": "Samaṇo ca sappurisānisaṁsoti."
    }
  ]
}
