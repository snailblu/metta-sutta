{
  "uid": "an9.70",
  "title": "Uddhambhāgiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.70:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an9.70:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an9.70:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "an9.70:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an9.70:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.70:2.2",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
