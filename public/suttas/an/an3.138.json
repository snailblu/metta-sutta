{
  "uid": "an3.138",
  "title": "Sampadāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.138:1.1",
      "pali": "“Tisso imā, bhikkhave, sampadā."
    },
    {
      "id": "an3.138:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.138:1.3",
      "pali": "Saddhāsampadā, sīlasampadā, paññāsampadā—"
    },
    {
      "id": "an3.138:1.4",
      "pali": "imā kho, bhikkhave, tisso sampadā”ti."
    },
    {
      "id": "an3.138:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
