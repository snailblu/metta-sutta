{
  "uid": "an4.17",
  "title": "Paṭhamaagatisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.17:1.1",
      "pali": "“Cattārimāni, bhikkhave, agatigamanāni."
    },
    {
      "id": "an4.17:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.17:1.3",
      "pali": "Chandāgatiṁ gacchati, dosāgatiṁ gacchati, mohāgatiṁ gacchati, bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.17:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri agatigamanānīti."
    },
    {
      "id": "an4.17:2.1",
      "pali": "Chandā dosā bhayā mohā,"
    },
    {
      "id": "an4.17:2.2",
      "pali": "yo dhammaṁ ativattati;"
    },
    {
      "id": "an4.17:2.3",
      "pali": "Nihīyati tassa yaso,"
    },
    {
      "id": "an4.17:2.4",
      "pali": "kāḷapakkheva candimā”ti."
    },
    {
      "id": "an4.17:2.5",
      "pali": "Sattamaṁ."
    }
  ]
}
