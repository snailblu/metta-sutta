{
  "uid": "an10.191",
  "title": "Saddhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.191:1.1",
      "pali": "“Saddhammañca vo, bhikkhave, desessāmi asaddhammañca."
    },
    {
      "id": "an10.191:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.191:1.3",
      "pali": "katamo ca, bhikkhave, asaddhammo?"
    },
    {
      "id": "an10.191:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.191:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.191:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, asaddhammo."
    },
    {
      "id": "an10.191:2.1",
      "pali": "Katamo ca, bhikkhave, saddhammo?"
    },
    {
      "id": "an10.191:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.191:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.191:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, saddhammo”ti."
    },
    {
      "id": "an10.191:2.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
