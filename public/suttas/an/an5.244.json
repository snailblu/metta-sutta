{
  "uid": "an5.244",
  "title": "Paṭhamamanoduccaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.244:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā manoduccarite …pe… ānisaṁsā manosucarite."
    },
    {
      "id": "an5.244:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.244:1.3",
      "pali": "Attāpi attānaṁ na upavadati;"
    },
    {
      "id": "an5.244:1.4",
      "pali": "anuvicca viññū pasaṁsanti;"
    },
    {
      "id": "an5.244:1.5",
      "pali": "kalyāṇo kittisaddo abbhuggacchati;"
    },
    {
      "id": "an5.244:1.6",
      "pali": "asammūḷho kālaṁ karoti;"
    },
    {
      "id": "an5.244:1.7",
      "pali": "kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjati."
    },
    {
      "id": "an5.244:1.8",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā manosucarite”ti."
    },
    {
      "id": "an5.244:1.9",
      "pali": "Catutthaṁ."
    }
  ]
}
