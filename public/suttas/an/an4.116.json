{
  "uid": "an4.116",
  "title": "Appamādasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.116:1.1",
      "pali": "“Catūhi, bhikkhave, ṭhānehi appamādo karaṇīyo."
    },
    {
      "id": "an4.116:1.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an4.116:1.3",
      "pali": "Kāyaduccaritaṁ, bhikkhave, pajahatha, kāyasucaritaṁ bhāvetha;"
    },
    {
      "id": "an4.116:1.4",
      "pali": "tattha ca mā pamādattha."
    },
    {
      "id": "an4.116:1.5",
      "pali": "Vacīduccaritaṁ, bhikkhave, pajahatha, vacīsucaritaṁ bhāvetha;"
    },
    {
      "id": "an4.116:1.6",
      "pali": "tattha ca mā pamādattha."
    },
    {
      "id": "an4.116:1.7",
      "pali": "Manoduccaritaṁ, bhikkhave, pajahatha, manosucaritaṁ bhāvetha;"
    },
    {
      "id": "an4.116:1.8",
      "pali": "tattha ca mā pamādattha."
    },
    {
      "id": "an4.116:1.9",
      "pali": "Micchādiṭṭhiṁ, bhikkhave, pajahatha, sammādiṭṭhiṁ bhāvetha;"
    },
    {
      "id": "an4.116:1.10",
      "pali": "tattha ca mā pamādattha."
    },
    {
      "id": "an4.116:2.1",
      "pali": "Yato kho, bhikkhave, bhikkhuno kāyaduccaritaṁ pahīnaṁ hoti kāyasucaritaṁ bhāvitaṁ, vacīduccaritaṁ pahīnaṁ hoti vacīsucaritaṁ bhāvitaṁ, manoduccaritaṁ pahīnaṁ hoti manosucaritaṁ bhāvitaṁ, micchādiṭṭhi pahīnā hoti sammādiṭṭhi bhāvitā, so na bhāyati samparāyikassa maraṇassā”ti."
    },
    {
      "id": "an4.116:2.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
