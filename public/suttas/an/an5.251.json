{
  "uid": "an5.251",
  "title": "Upasampādetabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.251:1.1",
      "pali": "“Pañcahi, bhikkhave, dhammehi samannāgatena bhikkhunā upasampādetabbaṁ."
    },
    {
      "id": "an5.251:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.251:1.3",
      "pali": "Idha, bhikkhave, bhikkhu asekhena sīlakkhandhena samannāgato hoti;"
    },
    {
      "id": "an5.251:1.4",
      "pali": "asekhena samādhikkhandhena samannāgato hoti;"
    },
    {
      "id": "an5.251:1.5",
      "pali": "asekhena paññākkhandhena samannāgato hoti;"
    },
    {
      "id": "an5.251:1.6",
      "pali": "asekhena vimuttikkhandhena samannāgato hoti;"
    },
    {
      "id": "an5.251:1.7",
      "pali": "asekhena vimuttiñāṇadassanakkhandhena samannāgato hoti."
    },
    {
      "id": "an5.251:1.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgatena bhikkhunā upasampādetabban”ti."
    },
    {
      "id": "an5.251:1.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
