{
  "uid": "an10.187",
  "title": "Dukkhudrayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.187:1.1",
      "pali": "“Dukkhudrayañca vo, bhikkhave, dhammaṁ desessāmi sukhudrayañca."
    },
    {
      "id": "an10.187:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.187:1.3",
      "pali": "katamo ca, bhikkhave, dukkhudrayo dhammo?"
    },
    {
      "id": "an10.187:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.187:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.187:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhudrayo dhammo."
    },
    {
      "id": "an10.187:2.1",
      "pali": "Katamo ca, bhikkhave, sukhudrayo dhammo?"
    },
    {
      "id": "an10.187:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.187:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.187:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, sukhudrayo dhammo”ti."
    },
    {
      "id": "an10.187:2.5",
      "pali": "Dasamaṁ."
    }
  ]
}
