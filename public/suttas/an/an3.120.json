{
  "uid": "an3.120",
  "title": "Paṭhamasoceyyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.120:1.1",
      "pali": "“Tīṇimāni, bhikkhave, soceyyāni."
    },
    {
      "id": "an3.120:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.120:1.3",
      "pali": "Kāyasoceyyaṁ, vacīsoceyyaṁ, manosoceyyaṁ."
    },
    {
      "id": "an3.120:1.4",
      "pali": "Katamañca, bhikkhave, kāyasoceyyaṁ?"
    },
    {
      "id": "an3.120:1.5",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātā paṭivirato hoti, adinnādānā paṭivirato hoti, kāmesumicchācārā paṭivirato hoti."
    },
    {
      "id": "an3.120:1.6",
      "pali": "Idaṁ vuccati, bhikkhave, kāyasoceyyaṁ."
    },
    {
      "id": "an3.120:2.1",
      "pali": "Katamañca, bhikkhave, vacīsoceyyaṁ?"
    },
    {
      "id": "an3.120:2.2",
      "pali": "Idha, bhikkhave, ekacco musāvādā paṭivirato hoti, pisuṇāya vācāya paṭivirato hoti, pharusāya vācāya paṭivirato hoti, samphappalāpā paṭivirato hoti."
    },
    {
      "id": "an3.120:2.3",
      "pali": "Idaṁ vuccati, bhikkhave, vacīsoceyyaṁ."
    },
    {
      "id": "an3.120:3.1",
      "pali": "Katamañca, bhikkhave, manosoceyyaṁ?"
    },
    {
      "id": "an3.120:3.2",
      "pali": "Idha, bhikkhave, ekacco anabhijjhālu hoti abyāpannacitto sammādiṭṭhiko."
    },
    {
      "id": "an3.120:3.3",
      "pali": "Idaṁ vuccati, bhikkhave, manosoceyyaṁ."
    },
    {
      "id": "an3.120:3.4",
      "pali": "Imāni kho, bhikkhave, tīṇi soceyyānī”ti."
    },
    {
      "id": "an3.120:3.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
