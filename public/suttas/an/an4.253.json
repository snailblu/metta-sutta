{
  "uid": "an4.253",
  "title": "Catutthavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.253:1.1",
      "pali": "“Cattārome, bhikkhave, ariyavohārā."
    },
    {
      "id": "an4.253:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.253:1.3",
      "pali": "Diṭṭhe diṭṭhavāditā, sute sutavāditā, mute mutavāditā, viññāte viññātavāditā—"
    },
    {
      "id": "an4.253:1.4",
      "pali": "Ime kho, bhikkhave, cattāro ariyavohārā”ti."
    },
    {
      "id": "an4.253:1.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an4.253:1.6",
      "pali": "Āpattibhayavaggo pañcamo."
    },
    {
      "id": "an4.253:2.1",
      "pali": "Bhedaāpatti sikkhā ca,"
    },
    {
      "id": "an4.253:2.2",
      "pali": "seyyā thūpārahena ca;"
    },
    {
      "id": "an4.253:2.3",
      "pali": "Paññāvuddhi bahukārā,"
    },
    {
      "id": "an4.253:2.4",
      "pali": "vohārā caturo ṭhitāti."
    },
    {
      "id": "an4.253:2.5",
      "pali": "Pañcamo paṇṇāsako samatto."
    }
  ]
}
