{
  "uid": "an5.147",
  "title": "Asappurisadānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.147:1.1",
      "pali": "“Pañcimāni, bhikkhave, asappurisadānāni."
    },
    {
      "id": "an5.147:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.147:1.3",
      "pali": "Asakkaccaṁ deti, acittīkatvā deti, asahatthā deti, apaviddhaṁ deti, anāgamanadiṭṭhiko deti."
    },
    {
      "id": "an5.147:1.4",
      "pali": "Imāni kho, bhikkhave, pañca asappurisadānāni."
    },
    {
      "id": "an5.147:2.1",
      "pali": "Pañcimāni, bhikkhave, sappurisadānāni."
    },
    {
      "id": "an5.147:2.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.147:2.3",
      "pali": "Sakkaccaṁ deti, cittīkatvā deti, sahatthā deti, anapaviddhaṁ deti, āgamanadiṭṭhiko deti."
    },
    {
      "id": "an5.147:2.4",
      "pali": "Imāni kho, bhikkhave, pañca sappurisadānānī”ti."
    },
    {
      "id": "an5.147:2.5",
      "pali": "Sattamaṁ."
    }
  ]
}
