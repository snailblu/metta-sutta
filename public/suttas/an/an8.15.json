{
  "uid": "an8.15",
  "title": "Malasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.15:1.1",
      "pali": "“Aṭṭhimāni, bhikkhave, malāni."
    },
    {
      "id": "an8.15:1.2",
      "pali": "Katamāni aṭṭha?"
    },
    {
      "id": "an8.15:1.3",
      "pali": "Asajjhāyamalā, bhikkhave, mantā;"
    },
    {
      "id": "an8.15:1.4",
      "pali": "anuṭṭhānamalā, bhikkhave, gharā;"
    },
    {
      "id": "an8.15:1.5",
      "pali": "malaṁ, bhikkhave, vaṇṇassa kosajjaṁ;"
    },
    {
      "id": "an8.15:1.6",
      "pali": "pamādo, bhikkhave, rakkhato malaṁ;"
    },
    {
      "id": "an8.15:1.7",
      "pali": "malaṁ, bhikkhave, itthiyā duccaritaṁ;"
    },
    {
      "id": "an8.15:1.8",
      "pali": "maccheraṁ, bhikkhave, dadato malaṁ;"
    },
    {
      "id": "an8.15:1.9",
      "pali": "malā, bhikkhave, pāpakā akusalā dhammā asmiṁ loke paramhi ca;"
    },
    {
      "id": "an8.15:1.10",
      "pali": "tato, bhikkhave, malā malataraṁ avijjā paramaṁ malaṁ."
    },
    {
      "id": "an8.15:1.11",
      "pali": "Imāni kho, bhikkhave, aṭṭha malānīti."
    },
    {
      "id": "an8.15:2.1",
      "pali": "Asajjhāyamalā mantā,"
    },
    {
      "id": "an8.15:2.2",
      "pali": "anuṭṭhānamalā gharā;"
    },
    {
      "id": "an8.15:2.3",
      "pali": "Malaṁ vaṇṇassa kosajjaṁ,"
    },
    {
      "id": "an8.15:2.4",
      "pali": "pamādo rakkhato malaṁ."
    },
    {
      "id": "an8.15:3.1",
      "pali": "Malitthiyā duccaritaṁ,"
    },
    {
      "id": "an8.15:3.2",
      "pali": "maccheraṁ dadato malaṁ;"
    },
    {
      "id": "an8.15:3.3",
      "pali": "Malā ve pāpakā dhammā,"
    },
    {
      "id": "an8.15:3.4",
      "pali": "asmiṁ loke paramhi ca;"
    },
    {
      "id": "an8.15:3.5",
      "pali": "Tato malā malataraṁ,"
    },
    {
      "id": "an8.15:3.6",
      "pali": "avijjā paramaṁ malan”ti."
    },
    {
      "id": "an8.15:3.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
