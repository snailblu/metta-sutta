{
  "uid": "an7.615",
  "title": "~",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.615:1.1",
      "pali": "“Rāgassa, bhikkhave, abhiññāya satta dhammā bhāvetabbā."
    },
    {
      "id": "an7.615:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.615:1.3",
      "pali": "Satisambojjhaṅgo …pe…"
    },
    {
      "id": "an7.615:1.4",
      "pali": "upekkhāsambojjhaṅgo—"
    },
    {
      "id": "an7.615:1.5",
      "pali": "rāgassa, bhikkhave, abhiññāya ime satta dhammā bhāvetabbā”ti."
    }
  ]
}
