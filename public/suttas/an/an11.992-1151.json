    },
    {
      "id": "an11.992-1151:1.25",
      "pali": "paṭinissaggāya ime ekādasa dhammā bhāvetabbā”ti."
    },
    {
      "id": "an11.992-1151:2.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "an11.992-1151:2.2",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "an11.992-1151:2.3",
      "pali": "Rāgapeyyālaṁ niṭṭhitaṁ."
    },
    {
      "id": "an11.992-1151:3.1",
      "pali": "Nava suttasahassāni,"
    },
    {
      "id": "an11.992-1151:3.2",
      "pali": "bhiyyo pañcasatāni ca;"
    },
    {
      "id": "an11.992-1151:3.3",
      "pali": "Sattapaññāsa suttantā,"
    },
    {
      "id": "an11.992-1151:3.4",
      "pali": "aṅguttarasamāyutāti."
    },
    {
      "id": "an11.992-1151:3.5",
      "pali": "Ekādasakanipātapāḷi niṭṭhitā."
    },
    {
      "id": "an11.992-1151:3.6",
      "pali": "Aṅguttaranikāyo samatto."
    }
  ]
}
