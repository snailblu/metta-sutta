{
  "uid": "an4.223",
  "title": "Akataññutāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.223:1.1",
      "pali": "“Catūhi, bhikkhave, dhammehi samannāgato bālo abyatto asappuriso khataṁ upahataṁ attānaṁ pariharati, sāvajjo ca hoti sānuvajjo viññūnaṁ, bahuñca apuññaṁ pasavati."
    },
    {
      "id": "an4.223:1.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an4.223:1.3",
      "pali": "Kāyaduccaritena, vacīduccaritena, manoduccaritena, akataññutā akataveditā—"
    },
    {
      "id": "an4.223:1.4",
      "pali": "imehi …pe… kāyasucaritena, vacīsucaritena, manosucaritena kataññutākataveditā …pe…."
    },
    {
      "id": "an4.223:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
