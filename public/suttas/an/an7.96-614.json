      "id": "an7.96-614:12.14",
      "pali": "lokassā”ti."
    },
    {
      "id": "an7.96-614:13.1",
      "pali": "“Chadvārārammaṇesvettha,"
    },
    {
      "id": "an7.96-614:13.2",
      "pali": "viññāṇesu ca phassesu;"
    },
    {
      "id": "an7.96-614:13.3",
      "pali": "Vedanāsu ca dvārassa,"
    },
    {
      "id": "an7.96-614:13.4",
      "pali": "suttā honti visuṁ aṭṭha."
    },
    {
      "id": "an7.96-614:14.1",
      "pali": "Saññā sañcetanā taṇhā,"
    },
    {
      "id": "an7.96-614:14.2",
      "pali": "vitakkesu vicāre ca;"
    },
    {
      "id": "an7.96-614:14.3",
      "pali": "Gocarassa visuṁ aṭṭha,"
    },
    {
      "id": "an7.96-614:14.4",
      "pali": "pañcakkhandhe ca pacceke."
    },
    {
      "id": "an7.96-614:15.1",
      "pali": "Soḷasasvettha mūlesu,"
    },
    {
      "id": "an7.96-614:15.2",
      "pali": "aniccaṁ dukkhamanattā;"
    },
    {
      "id": "an7.96-614:15.3",
      "pali": "Khayā vayā virāgā ca,"
    },
    {
      "id": "an7.96-614:15.4",
      "pali": "nirodhā paṭinissaggā."
    },
    {
      "id": "an7.96-614:16.1",
      "pali": "Kamaṁ aṭṭhānupassanā,"
    },
    {
      "id": "an7.96-614:16.2",
      "pali": "yojetvāna visuṁ visuṁ;"
    },
    {
      "id": "an7.96-614:16.3",
      "pali": "Sampiṇḍitesu sabbesu,"
    },
    {
      "id": "an7.96-614:16.4",
      "pali": "honti pañca satāni ca;"
    },
    {
      "id": "an7.96-614:16.5",
      "pali": "Aṭṭhavīsati suttāni,"
    },
    {
      "id": "an7.96-614:16.6",
      "pali": "āhuneyye ca vaggike”."
    },
    {
      "id": "an7.96-614:16.7",
      "pali": "Āhuneyyavaggo dasamo."
    }
  ]
}
