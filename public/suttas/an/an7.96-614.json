    {
      "id": "an7.96-614:1.1",
      "pali": "“Sattime, bhikkhave, puggalā āhuneyyā pāhuneyyā …pe… anuttaraṁ puññakkhettaṁ lokassa."
    },
    {
      "id": "an7.96-614:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.96-614:1.3",
