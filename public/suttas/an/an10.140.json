{
  "uid": "an10.140",
  "title": "Sāvajjasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.140:1.1",
      "pali": "“Sāvajjañca vo, bhikkhave, dhammaṁ desessāmi anavajjañca."
    },
    {
      "id": "an10.140:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.140:1.3",
      "pali": "katamo ca, bhikkhave, sāvajjo dhammo?"
    },
    {
      "id": "an10.140:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.140:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, sāvajjo dhammo."
    },
    {
      "id": "an10.140:1.6",
      "pali": "Katamo ca, bhikkhave, anavajjo dhammo?"
    },
    {
      "id": "an10.140:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.140:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, anavajjo dhammo”ti."
    },
    {
      "id": "an10.140:1.9",
      "pali": "Sattamaṁ."
    }
  ]
}
