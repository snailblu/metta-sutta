{
  "uid": "an4.248",
  "title": "Paññāvuddhisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.248:1.1",
      "pali": "“Cattārome, bhikkhave, dhammā paññāvuddhiyā saṁvattanti."
    },
    {
      "id": "an4.248:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.248:1.3",
      "pali": "Sappurisasaṁsevo, saddhammasavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—"
    },
    {
      "id": "an4.248:1.4",
      "pali": "Ime kho, bhikkhave, cattāro dhammā paññāvuddhiyā saṁvattantī”ti."
    },
    {
      "id": "an4.248:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
