{
  "uid": "an4.250",
  "title": "Paṭhamavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.250:1.1",
      "pali": "“Cattārome, bhikkhave, anariyavohārā."
    },
    {
      "id": "an4.250:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.250:1.3",
      "pali": "Adiṭṭhe diṭṭhavāditā, asute sutavāditā, amute mutavāditā, aviññāte viññātavāditā—"
    },
    {
      "id": "an4.250:1.4",
      "pali": "Ime kho, bhikkhave, cattāro anariyavohārā”ti."
    },
    {
      "id": "an4.250:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
