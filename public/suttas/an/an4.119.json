{
  "uid": "an4.119",
  "title": "Paṭhamabhayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.119:1.1",
      "pali": "“Cattārimāni, bhikkhave, bhayāni."
    },
    {
      "id": "an4.119:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.119:1.3",
      "pali": "Jātibhayaṁ, jarābhayaṁ, byādhibhayaṁ, maraṇabhayaṁ—"
    },
    {
      "id": "an4.119:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri bhayānī”ti."
    },
    {
      "id": "an4.119:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
