{
  "uid": "an5.220",
  "title": "Madhurāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.220:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā madhurāyaṁ."
    },
    {
      "id": "an5.220:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.220:1.3",
      "pali": "Visamā, bahurajā, caṇḍasunakhā, vāḷayakkhā, dullabhapiṇḍā."
    },
    {
      "id": "an5.220:1.4",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā madhurāyan”ti."
    },
    {
      "id": "an5.220:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.220:1.6",
      "pali": "Akkosakavaggo dutiyo."
    },
    {
      "id": "an5.220:2.1",
      "pali": "Akkosabhaṇḍanasīlaṁ,"
    },
    {
      "id": "an5.220:2.2",
      "pali": "bahubhāṇī dve akhantiyo;"
    },
    {
      "id": "an5.220:2.3",
      "pali": "Apāsādikā dve vuttā,"
    },
    {
      "id": "an5.220:2.4",
      "pali": "aggismiṁ madhurena cāti."
    }
  ]
}
