{
  "uid": "an4.98",
  "title": "Attahitasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.98:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.98:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.98:1.3",
      "pali": "Attahitāya paṭipanno no parahitāya,"
    },
    {
      "id": "an4.98:1.4",
      "pali": "parahitāya paṭipanno no attahitāya,"
    },
    {
      "id": "an4.98:1.5",
      "pali": "nevattahitāya paṭipanno no parahitāya,"
    },
    {
      "id": "an4.98:1.6",
      "pali": "attahitāya ceva paṭipanno parahitāya ca."
    },
    {
      "id": "an4.98:1.7",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.98:1.8",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
