{
  "uid": "an7.31",
  "title": "Parābhavasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.31:1.1",
      "pali": "“Sattime, bhikkhave, upāsakassa parābhavā …pe…"
    },
    {
      "id": "an7.31:1.2",
      "pali": "sattime, bhikkhave, upāsakassa sambhavā."
    },
    {
      "id": "an7.31:1.3",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.31:1.4",
      "pali": "Bhikkhudassanaṁ na hāpeti,"
    },
    {
      "id": "an7.31:1.5",
      "pali": "saddhammassavanaṁ nappamajjati,"
    },
    {
      "id": "an7.31:1.6",
      "pali": "adhisīle sikkhati,"
    },
    {
      "id": "an7.31:1.7",
      "pali": "pasādabahulo hoti,"
    },
    {
      "id": "an7.31:1.8",
      "pali": "bhikkhūsu theresu ceva navesu ca majjhimesu ca anupārambhacitto dhammaṁ suṇāti na randhagavesī,"
    },
    {
      "id": "an7.31:1.9",
      "pali": "na ito bahiddhā dakkhiṇeyyaṁ gavesati,"
    },
    {
      "id": "an7.31:1.10",
      "pali": "idha ca pubbakāraṁ karoti."
    },
    {
      "id": "an7.31:1.11",
      "pali": "Ime kho, bhikkhave, satta upāsakassa sambhavāti."
    },
    {
      "id": "an7.31:2.1",
      "pali": "Dassanaṁ bhāvitattānaṁ,"
    },
    {
      "id": "an7.31:2.2",
      "pali": "Yo hāpeti upāsako;"
    },
    {
      "id": "an7.31:2.3",
      "pali": "Savanañca ariyadhammānaṁ,"
    },
    {
      "id": "an7.31:2.4",
      "pali": "Adhisīle na sikkhati."
    },
    {
      "id": "an7.31:3.1",
      "pali": "Appasādo ca bhikkhūsu,"
    },
    {
      "id": "an7.31:3.2",
      "pali": "bhiyyo bhiyyo pavaḍḍhati;"
    },
    {
      "id": "an7.31:3.3",
      "pali": "Upārambhakacitto ca,"
    },
    {
      "id": "an7.31:3.4",
      "pali": "saddhammaṁ sotumicchati."
    },
    {
      "id": "an7.31:4.1",
      "pali": "Ito ca bahiddhā aññaṁ,"
    },
    {
      "id": "an7.31:4.2",
      "pali": "dakkhiṇeyyaṁ gavesati;"
    },
    {
      "id": "an7.31:4.3",
      "pali": "Tattheva ca pubbakāraṁ,"
    },
    {
      "id": "an7.31:4.4",
      "pali": "yo karoti upāsako."
    },
    {
      "id": "an7.31:5.1",
      "pali": "Ete kho parihāniye,"
    },
    {
      "id": "an7.31:5.2",
      "pali": "satta dhamme sudesite;"
    },
    {
      "id": "an7.31:5.3",
      "pali": "Upāsako sevamāno,"
    },
    {
      "id": "an7.31:5.4",
      "pali": "saddhammā parihāyati."
    },
    {
      "id": "an7.31:6.1",
      "pali": "Dassanaṁ bhāvitattānaṁ,"
    },
    {
      "id": "an7.31:6.2",
      "pali": "Yo na hāpeti upāsako;"
    },
    {
      "id": "an7.31:6.3",
      "pali": "Savanañca ariyadhammānaṁ,"
    },
    {
      "id": "an7.31:6.4",
      "pali": "Adhisīle ca sikkhati."
    },
    {
      "id": "an7.31:7.1",
      "pali": "Pasādo cassa bhikkhūsu,"
    },
    {
      "id": "an7.31:7.2",
      "pali": "bhiyyo bhiyyo pavaḍḍhati;"
    },
    {
      "id": "an7.31:7.3",
      "pali": "Anupārambhacitto ca,"
    },
    {
      "id": "an7.31:7.4",
      "pali": "saddhammaṁ sotumicchati."
    },
    {
      "id": "an7.31:8.1",
      "pali": "Na ito bahiddhā aññaṁ,"
    },
    {
      "id": "an7.31:8.2",
      "pali": "dakkhiṇeyyaṁ gavesati;"
    },
    {
      "id": "an7.31:8.3",
      "pali": "Idheva ca pubbakāraṁ,"
    },
    {
      "id": "an7.31:8.4",
      "pali": "yo karoti upāsako."
    },
    {
      "id": "an7.31:9.1",
      "pali": "Ete kho aparihāniye,"
    },
    {
      "id": "an7.31:9.2",
      "pali": "Satta dhamme sudesite;"
    },
    {
      "id": "an7.31:9.3",
      "pali": "Upāsako sevamāno,"
    },
    {
      "id": "an7.31:9.4",
      "pali": "Saddhammā na parihāyatī”ti."
    },
    {
      "id": "an7.31:9.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an7.31:9.6",
      "pali": "Vajjisattakavaggo tatiyo."
    },
    {
      "id": "an7.31:10.1",
      "pali": "Sāranda vassakāro ca,"
    },
    {
      "id": "an7.31:10.2",
      "pali": "tisattakāni bhikkhukā;"
    },
    {
      "id": "an7.31:10.3",
      "pali": "Bodhisaññā dve ca hāni,"
    },
    {
      "id": "an7.31:10.4",
      "pali": "vipatti ca parābhavoti."
    }
  ]
}
