{
  "uid": "an5.40",
  "title": "Mahāsālaputtasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.40:1.1",
      "pali": "“Himavantaṁ, bhikkhave, pabbatarājaṁ nissāya mahāsālā pañcahi vaḍḍhīhi vaḍḍhanti."
    },
    {
      "id": "an5.40:1.2",
      "pali": "Katamāhi pañcahi?"
    },
    {
      "id": "an5.40:1.3",
      "pali": "Sākhāpattapalāsena vaḍḍhanti;"
    },
    {
      "id": "an5.40:1.4",
      "pali": "tacena vaḍḍhanti;"
    },
    {
      "id": "an5.40:1.5",
      "pali": "papaṭikāya vaḍḍhanti;"
    },
    {
      "id": "an5.40:1.6",
      "pali": "pheggunā vaḍḍhanti;"
    },
    {
      "id": "an5.40:1.7",
      "pali": "sārena vaḍḍhanti."
    },
    {
      "id": "an5.40:1.8",
      "pali": "Himavantaṁ, bhikkhave, pabbatarājaṁ nissāya mahāsālā imāhi pañcahi vaḍḍhīhi vaḍḍhanti."
    },
    {
      "id": "an5.40:1.9",
      "pali": "Evamevaṁ kho, bhikkhave, saddhaṁ kulaputtaṁ nissāya antojano pañcahi vaḍḍhīhi vaḍḍhati."
    },
    {
      "id": "an5.40:1.10",
      "pali": "Katamāhi pañcahi?"
    },
    {
      "id": "an5.40:1.11",
      "pali": "Saddhāya vaḍḍhati;"
    },
    {
      "id": "an5.40:1.12",
      "pali": "sīlena vaḍḍhati;"
    },
    {
      "id": "an5.40:1.13",
      "pali": "sutena vaḍḍhati;"
    },
    {
      "id": "an5.40:1.14",
      "pali": "cāgena vaḍḍhati;"
    },
    {
      "id": "an5.40:1.15",
      "pali": "paññāya vaḍḍhati."
    },
    {
      "id": "an5.40:1.16",
      "pali": "Saddhaṁ, bhikkhave, kulaputtaṁ nissāya antojano imāhi pañcahi vaḍḍhīhi vaḍḍhatīti."
    },
    {
      "id": "an5.40:2.1",
      "pali": "Yathā hi pabbato selo,"
    },
    {
      "id": "an5.40:2.2",
      "pali": "araññasmiṁ brahāvane;"
    },
    {
      "id": "an5.40:2.3",
      "pali": "Taṁ rukkhā upanissāya,"
    },
    {
      "id": "an5.40:2.4",
      "pali": "vaḍḍhante te vanappatī."
    },
    {
      "id": "an5.40:3.1",
      "pali": "Tatheva sīlasampannaṁ,"
    },
    {
      "id": "an5.40:3.2",
      "pali": "Saddhaṁ kulaputtaṁ imaṁ;"
    },
    {
      "id": "an5.40:3.3",
      "pali": "Upanissāya vaḍḍhanti,"
    },
    {
      "id": "an5.40:3.4",
      "pali": "Puttadārā ca bandhavā;"
    },
    {
      "id": "an5.40:3.5",
      "pali": "Amaccā ñātisaṅghā ca,"
    },
    {
      "id": "an5.40:3.6",
      "pali": "Ye cassa anujīvino."
    },
    {
      "id": "an5.40:4.1",
      "pali": "Tyassa sīlavato sīlaṁ,"
    },
    {
      "id": "an5.40:4.2",
      "pali": "cāgaṁ sucaritāni ca;"
    },
    {
      "id": "an5.40:4.3",
      "pali": "Passamānānukubbanti,"
    },
    {
      "id": "an5.40:4.4",
      "pali": "ye bhavanti vicakkhaṇā."
    },
    {
      "id": "an5.40:5.1",
      "pali": "Idha dhammaṁ caritvāna,"
    },
    {
      "id": "an5.40:5.2",
      "pali": "maggaṁ sugatigāminaṁ;"
    },
    {
      "id": "an5.40:5.3",
      "pali": "Nandino devalokasmiṁ,"
    },
    {
      "id": "an5.40:5.4",
      "pali": "modanti kāmakāmino”ti."
    },
    {
      "id": "an5.40:5.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.40:5.6",
      "pali": "Sumanavaggo catuttho."
    },
    {
      "id": "an5.40:6.1",
      "pali": "Sumanā cundī uggaho,"
    },
    {
      "id": "an5.40:6.2",
      "pali": "sīho dānānisaṁsako;"
    },
    {
      "id": "an5.40:6.3",
      "pali": "Kālabhojanasaddhā ca,"
    },
    {
      "id": "an5.40:6.4",
      "pali": "puttasālehi te dasāti."
    }
  ]
}
