{
  "uid": "an8.53",
  "title": "Saṅkhittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.53:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā vesāliyaṁ viharati mahāvane kūṭāgārasālāyaṁ."
    },
    {
      "id": "an8.53:1.2",
      "pali": "Atha kho mahāpajāpatī gotamī yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhitā kho sā mahāpajāpatī gotamī bhagavantaṁ etadavoca:"
    },
    {
      "id": "an8.53:2.1",
      "pali": "“Sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu, yamahaṁ bhagavato dhammaṁ sutvā ekā vūpakaṭṭhā appamattā ātāpinī pahitattā vihareyyan”ti."
    },
    {
      "id": "an8.53:2.2",
      "pali": "“Ye kho tvaṁ, gotami, dhamme jāneyyāsi:"
    },
    {
      "id": "an8.53:2.3",
      "pali": "‘ime dhammā sarāgāya saṁvattanti, no virāgāya;"
    },
    {
      "id": "an8.53:2.4",
      "pali": "saṁyogāya saṁvattanti, no visaṁyogāya;"
    },
    {
      "id": "an8.53:2.5",
      "pali": "ācayāya saṁvattanti, no apacayāya;"
    },
    {
      "id": "an8.53:2.6",
      "pali": "mahicchatāya saṁvattanti, no appicchatāya;"
    },
    {
      "id": "an8.53:2.7",
      "pali": "asantuṭṭhiyā saṁvattanti, no santuṭṭhiyā;"
    },
    {
      "id": "an8.53:2.8",
      "pali": "saṅgaṇikāya saṁvattanti, no pavivekāya;"
    },
    {
      "id": "an8.53:2.9",
      "pali": "kosajjāya saṁvattanti, no vīriyārambhāya;"
    },
    {
      "id": "an8.53:2.10",
      "pali": "dubbharatāya saṁvattanti, no subharatāyā’ti,"
    },
    {
      "id": "an8.53:2.11",
      "pali": "ekaṁsena, gotami, dhāreyyāsi:"
    },
    {
      "id": "an8.53:2.12",
      "pali": "‘neso dhammo, neso vinayo, netaṁ satthusāsanan’ti."
    },
    {
      "id": "an8.53:3.1",
      "pali": "Ye ca kho tvaṁ, gotami, dhamme jāneyyāsi:"
    },
    {
      "id": "an8.53:3.2",
      "pali": "‘ime dhammā virāgāya saṁvattanti, no sarāgāya;"
    },
    {
      "id": "an8.53:3.3",
      "pali": "visaṁyogāya saṁvattanti, no saṁyogāya;"
    },
    {
      "id": "an8.53:3.4",
      "pali": "apacayāya saṁvattanti, no ācayāya;"
    },
    {
      "id": "an8.53:3.5",
      "pali": "appicchatāya saṁvattanti, no mahicchatāya;"
    },
    {
      "id": "an8.53:3.6",
      "pali": "santuṭṭhiyā saṁvattanti, no asantuṭṭhiyā;"
    },
    {
      "id": "an8.53:3.7",
      "pali": "pavivekāya saṁvattanti, no saṅgaṇikāya;"
    },
    {
      "id": "an8.53:3.8",
      "pali": "vīriyārambhāya saṁvattanti, no kosajjāya;"
    },
    {
      "id": "an8.53:3.9",
      "pali": "subharatāya saṁvattanti, no dubbharatāyā’ti,"
    },
    {
      "id": "an8.53:3.10",
      "pali": "ekaṁsena, gotami, dhāreyyāsi:"
    },
    {
      "id": "an8.53:3.11",
      "pali": "‘eso dhammo, eso vinayo, etaṁ satthusāsanan’”ti."
    },
    {
      "id": "an8.53:3.12",
      "pali": "Tatiyaṁ."
    }
  ]
}
