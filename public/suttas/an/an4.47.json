{
  "uid": "an4.47",
  "title": "Suvidūrasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.47:1.1",
      "pali": "“Cattārimāni, bhikkhave, suvidūravidūrāni."
    },
    {
      "id": "an4.47:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.47:1.3",
      "pali": "Nabhañca, bhikkhave, pathavī ca;"
    },
    {
      "id": "an4.47:1.4",
      "pali": "idaṁ paṭhamaṁ suvidūravidūre."
    },
    {
      "id": "an4.47:1.5",
      "pali": "Orimañca, bhikkhave, tīraṁ samuddassa pārimañca;"
    },
    {
      "id": "an4.47:1.6",
      "pali": "idaṁ dutiyaṁ suvidūravidūre."
    },
    {
      "id": "an4.47:1.7",
      "pali": "Yato ca, bhikkhave, verocano abbhudeti yattha ca atthameti;"
    },
    {
      "id": "an4.47:1.8",
      "pali": "idaṁ tatiyaṁ suvidūravidūre."
    },
    {
      "id": "an4.47:1.9",
      "pali": "Satañca, bhikkhave, dhammo asatañca dhammo;"
    },
    {
      "id": "an4.47:1.10",
      "pali": "idaṁ catutthaṁ suvidūravidūre."
    },
    {
      "id": "an4.47:1.11",
      "pali": "Imāni kho, bhikkhave, cattāri suvidūravidūrānīti."
    },
    {
      "id": "an4.47:2.1",
      "pali": "Nabhañca dūre pathavī ca dūre,"
    },
    {
      "id": "an4.47:2.2",
      "pali": "Pāraṁ samuddassa tadāhu dūre;"
    },
    {
      "id": "an4.47:2.3",
      "pali": "Yato ca verocano abbhudeti,"
    },
    {
      "id": "an4.47:2.4",
      "pali": "Pabhaṅkaro yattha ca atthameti;"
    },
    {
      "id": "an4.47:2.5",
      "pali": "Tato have dūrataraṁ vadanti,"
    },
    {
      "id": "an4.47:2.6",
      "pali": "Satañca dhammaṁ asatañca dhammaṁ."
    },
    {
      "id": "an4.47:3.1",
      "pali": "Abyāyiko hoti sataṁ samāgamo,"
    },
    {
      "id": "an4.47:3.2",
      "pali": "Yāvāpi tiṭṭheyya tatheva hoti;"
    },
    {
      "id": "an4.47:3.3",
      "pali": "Khippañhi veti asataṁ samāgamo,"
    },
    {
      "id": "an4.47:3.4",
      "pali": "Tasmā sataṁ dhammo asabbhi ārakā”ti."
    },
    {
      "id": "an4.47:3.5",
      "pali": "Sattamaṁ."
    }
  ]
}
