{
  "uid": "an6.45",
  "title": "Iṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.45:1.1",
      "pali": "“Dāliddiyaṁ, bhikkhave, dukkhaṁ lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:1.2",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:2.1",
      "pali": "“Yampi, bhikkhave, daliddo assako anāḷhiko iṇaṁ ādiyati, iṇādānampi, bhikkhave, dukkhaṁ lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:2.2",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:3.1",
      "pali": "“Yampi, bhikkhave, daliddo assako anāḷhiko iṇaṁ ādiyitvā vaḍḍhiṁ paṭissuṇāti, vaḍḍhipi, bhikkhave, dukkhā lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:3.2",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:4.1",
      "pali": "“Yampi, bhikkhave, daliddo assako anāḷhiko vaḍḍhiṁ paṭissuṇitvā kālābhataṁ vaḍḍhiṁ na deti, codentipi naṁ;"
    },
    {
      "id": "an6.45:4.2",
      "pali": "codanāpi, bhikkhave, dukkhā lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:4.3",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:5.1",
      "pali": "“Yampi, bhikkhave, daliddo assako anāḷhiko codiyamāno na deti, anucarantipi naṁ;"
    },
    {
      "id": "an6.45:5.2",
      "pali": "anucariyāpi, bhikkhave, dukkhā lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:5.3",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:6.1",
      "pali": "“Yampi, bhikkhave, daliddo assako anāḷhiko anucariyamāno na deti, bandhantipi naṁ;"
    },
    {
      "id": "an6.45:6.2",
      "pali": "bandhanampi, bhikkhave, dukkhaṁ lokasmiṁ kāmabhogino”ti?"
    },
    {
      "id": "an6.45:6.3",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "an6.45:7.1",
      "pali": "“Iti kho, bhikkhave, dāliddiyampi dukkhaṁ lokasmiṁ kāmabhogino, iṇādānampi dukkhaṁ lokasmiṁ kāmabhogino, vaḍḍhipi dukkhā lokasmiṁ kāmabhogino, codanāpi dukkhā lokasmiṁ kāmabhogino, anucariyāpi dukkhā lokasmiṁ kāmabhogino, bandhanampi dukkhaṁ lokasmiṁ kāmabhogino;"
    },
    {
      "id": "an6.45:7.2",
      "pali": "evamevaṁ kho, bhikkhave, yassa kassaci saddhā natthi kusalesu dhammesu, hirī natthi kusalesu dhammesu, ottappaṁ natthi kusalesu dhammesu, vīriyaṁ natthi kusalesu dhammesu, paññā natthi kusalesu dhammesu—"
    },
    {
      "id": "an6.45:7.3",
      "pali": "ayaṁ vuccati, bhikkhave, ariyassa vinaye daliddo assako anāḷhiko."
    },
    {
      "id": "an6.45:8.1",
      "pali": "Sa kho so, bhikkhave, daliddo assako anāḷhiko saddhāya asati kusalesu dhammesu, hiriyā asati kusalesu dhammesu, ottappe asati kusalesu dhammesu, vīriye asati kusalesu dhammesu, paññāya asati kusalesu dhammesu, kāyena duccaritaṁ carati, vācāya duccaritaṁ carati, manasā duccaritaṁ carati."
    },
    {
      "id": "an6.45:8.2",
      "pali": "Idamassa iṇādānasmiṁ vadāmi."
    },
    {
      "id": "an6.45:9.1",
      "pali": "So tassa kāyaduccaritassa paṭicchādanahetu pāpikaṁ icchaṁ paṇidahati."
    },
    {
      "id": "an6.45:9.2",
      "pali": "‘Mā maṁ jaññū’ti icchati, ‘mā maṁ jaññū’ti saṅkappati, ‘mā maṁ jaññū’ti vācaṁ bhāsati, ‘mā maṁ jaññū’ti kāyena parakkamati. So tassa vacīduccaritassa paṭicchādanahetu …pe… so tassa manoduccaritassa paṭicchādanahetu …pe… ‘mā maṁ jaññū’ti kāyena parakkamati."
    },
    {
      "id": "an6.45:9.3",
      "pali": "Idamassa vaḍḍhiyā vadāmi."
    },
    {
      "id": "an6.45:10.1",
      "pali": "Tamenaṁ pesalā sabrahmacārī evamāhaṁsu:"
    },
    {
      "id": "an6.45:10.2",
      "pali": "‘ayañca so āyasmā evaṅkārī evaṁsamācāro’ti."
    },
    {
      "id": "an6.45:10.3",
      "pali": "Idamassa codanāya vadāmi."
    },
    {
      "id": "an6.45:11.1",
      "pali": "Tamenaṁ araññagataṁ vā rukkhamūlagataṁ vā suññāgāragataṁ vā vippaṭisārasahagatā pāpakā akusalavitakkā samudācaranti."
    },
    {
      "id": "an6.45:11.2",
      "pali": "Idamassa anucariyāya vadāmi."
    },
    {
      "id": "an6.45:12.1",
      "pali": "Sa kho so, bhikkhave, daliddo assako anāḷhiko kāyena duccaritaṁ caritvā vācāya duccaritaṁ caritvā manasā duccaritaṁ caritvā kāyassa bhedā paraṁ maraṇā nirayabandhane vā bajjhati tiracchānayonibandhane vā."
    },
    {
      "id": "an6.45:12.2",
      "pali": "Nāhaṁ, bhikkhave, aññaṁ ekabandhanampi samanupassāmi evaṁdāruṇaṁ evaṅkaṭukaṁ evaṁantarāyakaraṁ anuttarassa yogakkhemassa adhigamāya, yathayidaṁ, bhikkhave, nirayabandhanaṁ vā tiracchānayonibandhanaṁ vāti."
    },
    {
      "id": "an6.45:13.1",
      "pali": "Dāliddiyaṁ dukkhaṁ loke,"
    },
    {
      "id": "an6.45:13.2",
      "pali": "iṇādānañca vuccati;"
    },
    {
      "id": "an6.45:13.3",
      "pali": "Daliddo iṇamādāya,"
    },
    {
      "id": "an6.45:13.4",
      "pali": "bhuñjamāno vihaññati."
    },
    {
      "id": "an6.45:14.1",
      "pali": "Tato anucaranti naṁ,"
    },
    {
      "id": "an6.45:14.2",
      "pali": "bandhanampi nigacchati;"
    },
    {
      "id": "an6.45:14.3",
      "pali": "Etañhi bandhanaṁ dukkhaṁ,"
    },
    {
      "id": "an6.45:14.4",
      "pali": "kāmalābhābhijappinaṁ."
    },
    {
      "id": "an6.45:15.1",
      "pali": "Tatheva ariyavinaye,"
    },
    {
      "id": "an6.45:15.2",
      "pali": "saddhā yassa na vijjati;"
    },
    {
      "id": "an6.45:15.3",
      "pali": "Ahirīko anottappī,"
    },
    {
      "id": "an6.45:15.4",
      "pali": "pāpakammavinibbayo."
    },
    {
      "id": "an6.45:16.1",
      "pali": "Kāyaduccaritaṁ katvā,"
    },
    {
      "id": "an6.45:16.2",
      "pali": "vacīduccaritāni ca;"
    },
    {
      "id": "an6.45:16.3",
      "pali": "Manoduccaritaṁ katvā,"
    },
    {
      "id": "an6.45:16.4",
      "pali": "‘mā maṁ jaññū’ti icchati."
    },
    {
      "id": "an6.45:17.1",
      "pali": "So saṁsappati kāyena,"
    },
    {
      "id": "an6.45:17.2",
      "pali": "vācāya uda cetasā;"
    },
    {
      "id": "an6.45:17.3",
      "pali": "Pāpakammaṁ pavaḍḍhento,"
    },
    {
      "id": "an6.45:17.4",
      "pali": "tattha tattha punappunaṁ."
    },
    {
      "id": "an6.45:18.1",
      "pali": "So pāpakammo dummedho,"
    },
    {
      "id": "an6.45:18.2",
      "pali": "jānaṁ dukkaṭamattano;"
    },
    {
      "id": "an6.45:18.3",
      "pali": "Daliddo iṇamādāya,"
    },
    {
      "id": "an6.45:18.4",
      "pali": "bhuñjamāno vihaññati."
    },
    {
      "id": "an6.45:19.1",
      "pali": "Tato anucaranti naṁ,"
    },
    {
      "id": "an6.45:19.2",
      "pali": "saṅkappā mānasā dukhā;"
    },
    {
      "id": "an6.45:19.3",
      "pali": "Gāme vā yadi vāraññe,"
    },
    {
      "id": "an6.45:19.4",
      "pali": "yassa vippaṭisārajā."
    },
    {
      "id": "an6.45:20.1",
      "pali": "So pāpakammo dummedho,"
    },
    {
      "id": "an6.45:20.2",
      "pali": "jānaṁ dukkaṭamattano;"
    },
    {
      "id": "an6.45:20.3",
      "pali": "Yonimaññataraṁ gantvā,"
    },
    {
      "id": "an6.45:20.4",
      "pali": "niraye vāpi bajjhati."
    },
    {
      "id": "an6.45:21.1",
      "pali": "Etañhi bandhanaṁ dukkhaṁ,"
    },
    {
      "id": "an6.45:21.2",
      "pali": "yamhā dhīro pamuccati;"
    },
    {
      "id": "an6.45:21.3",
      "pali": "Dhammaladdhehi bhogehi,"
    },
    {
      "id": "an6.45:21.4",
      "pali": "dadaṁ cittaṁ pasādayaṁ."
    },
    {
      "id": "an6.45:22.1",
      "pali": "Ubhayattha kaṭaggāho,"
    },
    {
      "id": "an6.45:22.2",
      "pali": "saddhassa gharamesino;"
    },
    {
      "id": "an6.45:22.3",
      "pali": "Diṭṭhadhammahitatthāya,"
    },
    {
      "id": "an6.45:22.4",
      "pali": "samparāyasukhāya ca;"
    },
    {
      "id": "an6.45:22.5",
      "pali": "Evametaṁ gahaṭṭhānaṁ,"
    },
    {
      "id": "an6.45:22.6",
      "pali": "cāgo puññaṁ pavaḍḍhati."
    },
    {
      "id": "an6.45:23.1",
      "pali": "Tatheva ariyavinaye,"
    },
    {
      "id": "an6.45:23.2",
      "pali": "saddhā yassa patiṭṭhitā;"
    },
    {
      "id": "an6.45:23.3",
      "pali": "Hirīmano ca ottappī,"
    },
    {
      "id": "an6.45:23.4",
      "pali": "paññavā sīlasaṁvuto."
    },
    {
      "id": "an6.45:24.1",
      "pali": "Eso kho ariyavinaye,"
    },
    {
      "id": "an6.45:24.2",
      "pali": "‘sukhajīvī’ti vuccati;"
    },
    {
      "id": "an6.45:24.3",
      "pali": "Nirāmisaṁ sukhaṁ laddhā,"
    },
    {
      "id": "an6.45:24.4",
      "pali": "upekkhaṁ adhitiṭṭhati."
    },
    {
      "id": "an6.45:25.1",
      "pali": "Pañca nīvaraṇe hitvā,"
    },
    {
      "id": "an6.45:25.2",
      "pali": "niccaṁ āraddhavīriyo;"
    },
    {
      "id": "an6.45:25.3",
      "pali": "Jhānāni upasampajja,"
    },
    {
      "id": "an6.45:25.4",
      "pali": "ekodi nipako sato."
    },
    {
      "id": "an6.45:26.1",
      "pali": "Evaṁ ñatvā yathābhūtaṁ,"
    },
    {
      "id": "an6.45:26.2",
      "pali": "sabbasaṁyojanakkhaye;"
    },
    {
      "id": "an6.45:26.3",
      "pali": "Sabbaso anupādāya,"
    },
    {
      "id": "an6.45:26.4",
      "pali": "sammā cittaṁ vimuccati."
    },
    {
      "id": "an6.45:27.1",
      "pali": "Tassa sammā vimuttassa,"
    },
    {
      "id": "an6.45:27.2",
      "pali": "ñāṇañce hoti tādino;"
    },
    {
      "id": "an6.45:27.3",
      "pali": "‘Akuppā me vimuttī’ti,"
    },
    {
      "id": "an6.45:27.4",
      "pali": "bhavasaṁyojanakkhaye."
    },
    {
      "id": "an6.45:28.1",
      "pali": "Etaṁ kho paramaṁ ñāṇaṁ,"
    },
    {
      "id": "an6.45:28.2",
      "pali": "etaṁ sukhamanuttaraṁ;"
    },
    {
      "id": "an6.45:28.3",
      "pali": "Asokaṁ virajaṁ khemaṁ,"
    },
    {
      "id": "an6.45:28.4",
      "pali": "etaṁ ānaṇyamuttaman”ti."
    },
    {
      "id": "an6.45:28.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
