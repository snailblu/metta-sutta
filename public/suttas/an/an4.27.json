{
  "uid": "an4.27",
  "title": "Santuṭṭhisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.27:1.1",
      "pali": "“Cattārimāni, bhikkhave, appāni ca sulabhāni ca, tāni ca anavajjāni."
    },
    {
      "id": "an4.27:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.27:1.3",
      "pali": "Paṁsukūlaṁ, bhikkhave, cīvarānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "an4.27:1.4",
      "pali": "Piṇḍiyālopo, bhikkhave, bhojanānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "an4.27:1.5",
      "pali": "Rukkhamūlaṁ, bhikkhave, senāsanānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "an4.27:1.6",
      "pali": "Pūtimuttaṁ, bhikkhave, bhesajjānaṁ appañca sulabhañca, tañca anavajjaṁ."
    },
    {
      "id": "an4.27:1.7",
      "pali": "Imāni kho, bhikkhave, cattāri appāni ca sulabhāni ca, tāni ca anavajjāni."
    },
    {
      "id": "an4.27:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhu appena ca tuṭṭho hoti sulabhena ca, idamassāhaṁ aññataraṁ sāmaññaṅganti vadāmīti."
    },
    {
      "id": "an4.27:2.1",
      "pali": "Anavajjena tuṭṭhassa,"
    },
    {
      "id": "an4.27:2.2",
      "pali": "appena sulabhena ca;"
    },
    {
      "id": "an4.27:2.3",
      "pali": "Na senāsanamārabbha,"
    },
    {
      "id": "an4.27:2.4",
      "pali": "cīvaraṁ pānabhojanaṁ;"
    },
    {
      "id": "an4.27:2.5",
      "pali": "Vighāto hoti cittassa,"
    },
    {
      "id": "an4.27:2.6",
      "pali": "disā nappaṭihaññati."
    },
    {
      "id": "an4.27:3.1",
      "pali": "Ye cassa dhammā akkhātā,"
    },
    {
      "id": "an4.27:3.2",
      "pali": "sāmaññassānulomikā;"
    },
    {
      "id": "an4.27:3.3",
      "pali": "Adhiggahitā tuṭṭhassa,"
    },
    {
      "id": "an4.27:3.4",
      "pali": "appamattassa sikkhato”ti."
    },
    {
      "id": "an4.27:3.5",
      "pali": "Sattamaṁ."
    }
  ]
}
