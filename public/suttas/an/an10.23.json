{
  "uid": "an10.23",
  "title": "Kāyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.23:1.1",
      "pali": "“Atthi, bhikkhave, dhammā kāyena pahātabbā, no vācāya."
    },
    {
      "id": "an10.23:1.2",
      "pali": "Atthi, bhikkhave, dhammā vācāya pahātabbā, no kāyena."
    },
    {
      "id": "an10.23:1.3",
      "pali": "Atthi, bhikkhave, dhammā neva kāyena pahātabbā no vācāya, paññāya disvā pahātabbā."
    },
    {
      "id": "an10.23:2.1",
      "pali": "Katame ca, bhikkhave, dhammā kāyena pahātabbā, no vācāya?"
    },
    {
      "id": "an10.23:2.2",
      "pali": "Idha, bhikkhave, bhikkhu akusalaṁ āpanno hoti kiñci desaṁ kāyena."
    },
    {
      "id": "an10.23:2.3",
      "pali": "Tamenaṁ anuvicca viññū sabrahmacārī evamāhaṁsu:"
    },
    {
      "id": "an10.23:2.4",
      "pali": "‘āyasmā kho akusalaṁ āpanno kiñci desaṁ kāyena."
    },
    {
      "id": "an10.23:2.5",
      "pali": "Sādhu vatāyasmā kāyaduccaritaṁ pahāya kāyasucaritaṁ bhāvetū’ti."
    },
    {
      "id": "an10.23:2.6",
      "pali": "So anuvicca viññūhi sabrahmacārīhi vuccamāno kāyaduccaritaṁ pahāya kāyasucaritaṁ bhāveti."
    },
    {
      "id": "an10.23:2.7",
      "pali": "Ime vuccanti, bhikkhave, dhammā kāyena pahātabbā, no vācāya."
    },
    {
      "id": "an10.23:3.1",
      "pali": "Katame ca, bhikkhave, dhammā vācāya pahātabbā, no kāyena?"
    },
    {
      "id": "an10.23:3.2",
      "pali": "Idha, bhikkhave, bhikkhu akusalaṁ āpanno hoti kiñci desaṁ vācāya."
    },
    {
      "id": "an10.23:3.3",
      "pali": "Tamenaṁ anuvicca viññū sabrahmacārī evamāhaṁsu:"
    },
    {
      "id": "an10.23:3.4",
      "pali": "‘āyasmā kho akusalaṁ āpanno kiñci desaṁ vācāya."
    },
    {
      "id": "an10.23:3.5",
      "pali": "Sādhu vatāyasmā vacīduccaritaṁ pahāya vacīsucaritaṁ bhāvetū’ti."
    },
    {
      "id": "an10.23:3.6",
      "pali": "So anuvicca viññūhi sabrahmacārīhi vuccamāno vacīduccaritaṁ pahāya vacīsucaritaṁ bhāveti."
    },
    {
      "id": "an10.23:3.7",
      "pali": "Ime vuccanti, bhikkhave, dhammā vācāya pahātabbā, no kāyena."
    },
    {
      "id": "an10.23:4.1",
      "pali": "Katame ca, bhikkhave, dhammā neva kāyena pahātabbā no vācāya, paññāya disvā pahātabbā?"
    },
    {
      "id": "an10.23:4.2",
      "pali": "Lobho, bhikkhave, neva kāyena pahātabbo no vācāya, paññāya disvā pahātabbo."
    },
    {
      "id": "an10.23:4.3",
      "pali": "Doso, bhikkhave …pe…"
    },
    {
      "id": "an10.23:4.4",
      "pali": "moho …"
    },
    {
      "id": "an10.23:4.5",
      "pali": "kodho …"
    },
    {
      "id": "an10.23:4.6",
      "pali": "upanāho …"
    },
    {
      "id": "an10.23:4.7",
      "pali": "makkho …"
    },
    {
      "id": "an10.23:4.8",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.23:4.9",
      "pali": "macchariyaṁ, bhikkhave, neva kāyena pahātabbaṁ no vācāya, paññāya disvā pahātabbaṁ."
    },
    {
      "id": "an10.23:5.1",
      "pali": "Pāpikā, bhikkhave, issā neva kāyena pahātabbā no vācāya, paññāya disvā pahātabbā."
    },
    {
      "id": "an10.23:5.2",
      "pali": "Katamā ca, bhikkhave, pāpikā issā?"
    },
    {
      "id": "an10.23:5.3",
      "pali": "Idha, bhikkhave, ijjhati gahapatissa vā gahapatiputtassa vā dhanena vā dhaññena vā rajatena vā jātarūpena vā."
    },
    {
      "id": "an10.23:5.4",
      "pali": "Tatrāññatarassa dāsassa vā upavāsassa vā evaṁ hoti:"
    },
    {
      "id": "an10.23:5.5",
      "pali": "‘aho vatimassa gahapatissa vā gahapatiputtassa vā na ijjheyya dhanena vā dhaññena vā rajatena vā jātarūpena vā’ti."
    },
    {
      "id": "an10.23:5.6",
      "pali": "Samaṇo vā pana brāhmaṇo vā lābhī hoti cīvarapiṇḍapātasenāsanagilānapaccayabhesajjaparikkhārānaṁ."
    },
    {
      "id": "an10.23:5.7",
      "pali": "Tatrāññatarassa samaṇassa vā brāhmaṇassa vā evaṁ hoti:"
    },
    {
      "id": "an10.23:5.8",
      "pali": "‘aho vata ayamāyasmā na lābhī assa cīvarapiṇḍapātasenāsanagilānapaccayabhesajjaparikkhārānan’ti."
    },
    {
      "id": "an10.23:5.9",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpikā issā."
    },
    {
      "id": "an10.23:6.1",
      "pali": "Pāpikā, bhikkhave, icchā neva kāyena pahātabbā no vācāya, paññāya disvā pahātabbā."
    },
    {
      "id": "an10.23:6.2",
      "pali": "Katamā ca, bhikkhave, pāpikā icchā?"
    },
    {
      "id": "an10.23:6.3",
      "pali": "Idha, bhikkhave, ekacco assaddho samāno ‘saddhoti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.4",
      "pali": "dussīlo samāno ‘sīlavāti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.5",
      "pali": "appassuto samāno ‘bahussutoti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.6",
      "pali": "saṅgaṇikārāmo samāno ‘pavivittoti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.7",
      "pali": "kusīto samāno ‘āraddhavīriyoti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.8",
      "pali": "muṭṭhassati samāno ‘upaṭṭhitassatīti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.9",
      "pali": "asamāhito samāno ‘samāhitoti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.10",
      "pali": "duppañño samāno ‘paññavāti maṁ jāneyyun’ti icchati;"
    },
    {
      "id": "an10.23:6.11",
      "pali": "akhīṇāsavo samāno ‘khīṇāsavoti maṁ jāneyyun’ti icchati."
    },
    {
      "id": "an10.23:6.12",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpikā icchā."
    },
    {
      "id": "an10.23:6.13",
      "pali": "Ime vuccanti, bhikkhave, dhammā neva kāyena pahātabbā no vācāya, paññāya disvā pahātabbā."
    },
    {
      "id": "an10.23:7.1",
      "pali": "Tañce, bhikkhave, bhikkhuṁ lobho abhibhuyya iriyati,"
    },
    {
      "id": "an10.23:7.2",
      "pali": "doso …"
    },
    {
      "id": "an10.23:7.3",
      "pali": "moho …"
    },
    {
      "id": "an10.23:7.4",
      "pali": "kodho …"
    },
    {
      "id": "an10.23:7.5",
      "pali": "upanāho …"
    },
    {
      "id": "an10.23:7.6",
      "pali": "makkho …"
    },
    {
      "id": "an10.23:7.7",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.23:7.8",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.23:7.9",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.23:7.10",
      "pali": "pāpikā icchā abhibhuyya iriyati."
    },
    {
      "id": "an10.23:7.11",
      "pali": "So evamassa veditabbo:"
    },
    {
      "id": "an10.23:7.12",
      "pali": "‘nāyamāyasmā tathā pajānāti yathā pajānato lobho na hoti, tathāhimaṁ āyasmantaṁ lobho abhibhuyya iriyati;"
    },
    {
      "id": "an10.23:7.13",
      "pali": "nāyamāyasmā tathā pajānāti yathā pajānato doso na hoti …"
    },
    {
      "id": "an10.23:7.14",
      "pali": "moho …"
    },
    {
      "id": "an10.23:7.15",
      "pali": "kodho …"
    },
    {
      "id": "an10.23:7.16",
      "pali": "upanāho …"
    },
    {
      "id": "an10.23:7.17",
      "pali": "makkho …"
    },
    {
      "id": "an10.23:7.18",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.23:7.19",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.23:7.20",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.23:7.21",
      "pali": "pāpikā icchā na hoti, tathāhimaṁ āyasmantaṁ pāpikā icchā abhibhuyya iriyatī’ti."
    },
    {
      "id": "an10.23:8.1",
      "pali": "Tañce, bhikkhave, bhikkhuṁ lobho nābhibhuyya iriyati,"
    },
    {
      "id": "an10.23:8.2",
      "pali": "doso …"
    },
    {
      "id": "an10.23:8.3",
      "pali": "moho …"
    },
    {
      "id": "an10.23:8.4",
      "pali": "kodho …"
    },
    {
      "id": "an10.23:8.5",
      "pali": "upanāho …"
    },
    {
      "id": "an10.23:8.6",
      "pali": "makkho …"
    },
    {
      "id": "an10.23:8.7",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.23:8.8",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.23:8.9",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.23:8.10",
      "pali": "pāpikā icchā nābhibhuyya iriyati,"
    },
    {
      "id": "an10.23:8.11",
      "pali": "so evamassa veditabbo:"
    },
    {
      "id": "an10.23:8.12",
      "pali": "‘tathā ayamāyasmā pajānāti yathā pajānato lobho na hoti, tathāhimaṁ āyasmantaṁ lobho nābhibhuyya iriyati;"
    },
    {
      "id": "an10.23:8.13",
      "pali": "tathā ayamāyasmā pajānāti yathā pajānato doso na hoti …"
    },
    {
      "id": "an10.23:8.14",
      "pali": "moho …"
    },
    {
      "id": "an10.23:8.15",
      "pali": "kodho …"
    },
    {
      "id": "an10.23:8.16",
      "pali": "upanāho …"
    },
    {
      "id": "an10.23:8.17",
      "pali": "makkho …"
    },
    {
      "id": "an10.23:8.18",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.23:8.19",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.23:8.20",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.23:8.21",
      "pali": "pāpikā icchā na hoti, tathāhimaṁ āyasmantaṁ pāpikā icchā nābhibhuyya iriyatī’”ti."
    },
    {
      "id": "an10.23:8.22",
      "pali": "Tatiyaṁ."
    }
  ]
}
