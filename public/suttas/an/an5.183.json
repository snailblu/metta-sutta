{
  "uid": "an5.183",
  "title": "Rukkhamūlikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.183:1.1",
      "pali": "“Pañcime, bhikkhave, rukkhamūlikā."
    },
    {
      "id": "an5.183:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.183:1.3",
      "pali": "Mandattā momūhattā rukkhamūliko hoti …pe… idamatthitaṁyeva nissāya rukkhamūliko hoti."
    },
    {
      "id": "an5.183:1.4",
      "pali": "Ime kho, bhikkhave, pañca rukkhamūlikā”ti."
    },
    {
      "id": "an5.183:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
