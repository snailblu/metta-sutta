{
  "uid": "an6.23",
  "title": "Bhayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.23:1.1",
      "pali": "“‘Bhayan’ti, bhikkhave, kāmānametaṁ adhivacanaṁ;"
    },
    {
      "id": "an6.23:1.2",
      "pali": "‘dukkhan’ti, bhikkhave, kāmānametaṁ adhivacanaṁ;"
    },
    {
      "id": "an6.23:1.3",
      "pali": "‘rogo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ;"
    },
    {
      "id": "an6.23:1.4",
      "pali": "‘gaṇḍo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ;"
    },
    {
      "id": "an6.23:1.5",
      "pali": "‘saṅgo’ti, bhikkhave, kāmānametaṁ adhivacanaṁ;"
    },
    {
      "id": "an6.23:1.6",
      "pali": "‘paṅko’ti, bhikkhave, kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an6.23:2.1",
      "pali": "Kasmā ca, bhikkhave, ‘bhayan’ti kāmānametaṁ adhivacanaṁ?"
    },
    {
      "id": "an6.23:2.2",
      "pali": "Kāmarāgarattāyaṁ, bhikkhave, chandarāgavinibaddho diṭṭhadhammikāpi bhayā na parimuccati, samparāyikāpi bhayā na parimuccati, tasmā ‘bhayan’ti kāmānametaṁ adhivacanaṁ."
    },
    {
      "id": "an6.23:2.3",
      "pali": "Kasmā ca, bhikkhave, dukkhanti …pe…"
    },
    {
      "id": "an6.23:2.4",
      "pali": "rogoti …"
    },
    {
      "id": "an6.23:2.5",
      "pali": "gaṇḍoti …"
    },
    {
      "id": "an6.23:2.6",
      "pali": "saṅgoti …"
    },
    {
      "id": "an6.23:2.7",
      "pali": "paṅkoti kāmānametaṁ adhivacanaṁ?"
    },
    {
      "id": "an6.23:2.8",
      "pali": "Kāmarāgarattāyaṁ, bhikkhave, chandarāgavinibaddho diṭṭhadhammikāpi paṅkā na parimuccati, samparāyikāpi paṅkā na parimuccati, tasmā ‘paṅko’ti kāmānametaṁ adhivacananti."
    },
    {
      "id": "an6.23:3.1",
      "pali": "Bhayaṁ dukkhaṁ rogo gaṇḍo,"
    },
    {
      "id": "an6.23:3.2",
      "pali": "saṅgo paṅko ca ubhayaṁ;"
    },
    {
      "id": "an6.23:3.3",
      "pali": "Ete kāmā pavuccanti,"
    },
    {
      "id": "an6.23:3.4",
      "pali": "yattha satto puthujjano."
    },
    {
      "id": "an6.23:4.1",
      "pali": "Upādāne bhayaṁ disvā,"
    },
    {
      "id": "an6.23:4.2",
      "pali": "jātimaraṇasambhave;"
    },
    {
      "id": "an6.23:4.3",
      "pali": "Anupādā vimuccanti,"
    },
    {
      "id": "an6.23:4.4",
      "pali": "jātimaraṇasaṅkhaye."
    },
    {
      "id": "an6.23:5.1",
      "pali": "Te khemappattā sukhino,"
    },
    {
      "id": "an6.23:5.2",
      "pali": "diṭṭhadhammābhinibbutā;"
    },
    {
      "id": "an6.23:5.3",
      "pali": "Sabbaverabhayātītā,"
    },
    {
      "id": "an6.23:5.4",
      "pali": "sabbadukkhaṁ upaccagun”ti."
    },
    {
      "id": "an6.23:5.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
