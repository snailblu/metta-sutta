{
  "uid": "an4.15",
  "title": "Paññattisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.15:1.1",
      "pali": "“Catasso imā, bhikkhave, aggapaññattiyo."
    },
    {
      "id": "an4.15:1.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.15:1.3",
      "pali": "Etadaggaṁ, bhikkhave, attabhāvīnaṁ yadidaṁ—"
    },
    {
      "id": "an4.15:1.4",
      "pali": "rāhu asurindo."
    },
    {
      "id": "an4.15:1.5",
      "pali": "Etadaggaṁ, bhikkhave, kāmabhogīnaṁ yadidaṁ—"
    },
    {
      "id": "an4.15:1.6",
      "pali": "rājā mandhātā."
    },
    {
      "id": "an4.15:1.7",
      "pali": "Etadaggaṁ, bhikkhave, ādhipateyyānaṁ yadidaṁ—"
    },
    {
      "id": "an4.15:1.8",
      "pali": "māro pāpimā."
    },
    {
      "id": "an4.15:1.9",
      "pali": "Sadevake, bhikkhave, loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya tathāgato aggamakkhāyati arahaṁ sammāsambuddho."
    },
    {
      "id": "an4.15:1.10",
      "pali": "Imā kho, bhikkhave, catasso aggapaññattiyoti."
    },
    {
      "id": "an4.15:2.1",
      "pali": "Rāhuggaṁ attabhāvīnaṁ,"
    },
    {
      "id": "an4.15:2.2",
      "pali": "mandhātā kāmabhoginaṁ;"
    },
    {
      "id": "an4.15:2.3",
      "pali": "Māro ādhipateyyānaṁ,"
    },
    {
      "id": "an4.15:2.4",
      "pali": "iddhiyā yasasā jalaṁ."
    },
    {
      "id": "an4.15:3.1",
      "pali": "Uddhaṁ tiriyaṁ apācīnaṁ,"
    },
    {
      "id": "an4.15:3.2",
      "pali": "yāvatājagatogati;"
    },
    {
      "id": "an4.15:3.3",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "an4.15:3.4",
      "pali": "buddho aggo pavuccatī”ti."
    },
    {
      "id": "an4.15:3.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
