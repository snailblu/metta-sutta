{
  "uid": "an6.100",
  "title": "Anattasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.100:1.1",
      "pali": "“So vata, bhikkhave, bhikkhu kañci dhammaṁ attato samanupassanto …pe…"
    },
    {
      "id": "an6.100:1.2",
      "pali": "sabbadhamme anattato samanupassanto …pe…"
    },
    {
      "id": "an6.100:1.3",
      "pali": "ṭhānametaṁ vijjati”."
    },
    {
      "id": "an6.100:1.4",
      "pali": "Pañcamaṁ."
    }
  ]
}
