{
  "uid": "an9.69",
  "title": "Macchariyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.69:1.1",
      "pali": "“Pañcimāni, bhikkhave, macchariyāni."
    },
    {
      "id": "an9.69:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an9.69:1.3",
      "pali": "Āvāsamacchariyaṁ, kulamacchariyaṁ, lābhamacchariyaṁ, vaṇṇamacchariyaṁ, dhammamacchariyaṁ—"
    },
    {
      "id": "an9.69:1.4",
      "pali": "imāni kho, bhikkhave, pañca macchariyāni."
    },
    {
      "id": "an9.69:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ macchariyānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.69:2.2",
      "pali": "Sattamaṁ."
    }
  ]
}
