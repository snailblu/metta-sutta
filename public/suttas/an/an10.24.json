      "id": "an10.24:4.22",
      "pali": "pāpikā icchā na hoti, tathāhimaṁ āyasmantaṁ pāpikā icchā abhibhuyya tiṭṭhatī’ti."
    },
    {
      "id": "an10.24:5.1",
      "pali": "Seyyathāpi, āvuso, puriso daliddova samāno aḍḍhavādaṁ vadeyya, adhanova samāno dhanavāvādaṁ vadeyya, abhogova samāno bhogavāvādaṁ vadeyya."
    },
    {
      "id": "an10.24:5.2",
      "pali": "So kismiñcideva dhanakaraṇīye samuppanne na sakkuṇeyya upanīhātuṁ dhanaṁ vā dhaññaṁ vā rajataṁ vā jātarūpaṁ vā."
    },
    {
      "id": "an10.24:5.3",
      "pali": "Tamenaṁ evaṁ jāneyyuṁ:"
    },
    {
      "id": "an10.24:5.4",
      "pali": "‘daliddova ayamāyasmā samāno aḍḍhavādaṁ vadeti, adhanova ayamāyasmā samāno dhanavāvādaṁ vadeti, abhogavāva ayamāyasmā samāno bhogavāvādaṁ vadeti."
    },
    {
      "id": "an10.24:5.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an10.24:5.6",
      "pali": "Tathā hi ayamāyasmā kismiñcideva dhanakaraṇīye samuppanne na sakkoti upanīhātuṁ dhanaṁ vā dhaññaṁ vā rajataṁ vā jātarūpaṁ vā’ti."
    },
    {
      "id": "an10.24:6.1",
      "pali": "Evamevaṁ kho, āvuso, ñāṇavādañca bhikkhu vadamāno bhāvanāvādañca:"
    },
    {
      "id": "an10.24:6.2",
