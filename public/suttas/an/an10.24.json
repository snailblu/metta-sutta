    },
    {
      "id": "an10.24:9.22",
      "pali": "pāpikā icchā na hoti, tathāhimaṁ āyasmantaṁ pāpikā icchā nābhibhuyya tiṭṭhatī’ti."
    },
    {
      "id": "an10.24:10.1",
      "pali": "Seyyathāpi, āvuso, puriso aḍḍhova samāno aḍḍhavādaṁ vadeyya, dhanavāva samāno dhanavāvādaṁ vadeyya, bhogavāva samāno bhogavāvādaṁ vadeyya."
    },
    {
      "id": "an10.24:10.2",
      "pali": "So kismiñcideva dhanakaraṇīye samuppanne sakkuṇeyya upanīhātuṁ dhanaṁ vā dhaññaṁ vā rajataṁ vā jātarūpaṁ vā."
    },
    {
      "id": "an10.24:10.3",
      "pali": "Tamenaṁ evaṁ jāneyyuṁ:"
    },
    {
      "id": "an10.24:10.4",
      "pali": "‘aḍḍhova ayamāyasmā samāno aḍḍhavādaṁ vadeti, dhanavāva ayamāyasmā samāno dhanavāvādaṁ vadeti, bhogavāva ayamāyasmā samāno bhogavāvādaṁ vadeti."
    },
    {
      "id": "an10.24:10.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "an10.24:10.6",
      "pali": "Tathā hi ayamāyasmā kismiñcideva dhanakaraṇīye samuppanne sakkoti upanīhātuṁ dhanaṁ vā dhaññaṁ vā rajataṁ vā jātarūpaṁ vā’ti."
    },
    {
      "id": "an10.24:11.1",
      "pali": "Evamevaṁ kho, āvuso, ñāṇavādañca bhikkhu vadamāno bhāvanāvādañca:"
    },
    {
      "id": "an10.24:11.2",
      "pali": "‘jānāmimaṁ dhammaṁ, passāmimaṁ dhammaṁ, bhāvitakāyomhi bhāvitasīlo bhāvitacitto bhāvitapañño’ti."
    },
    {
      "id": "an10.24:11.3",
      "pali": "Tañce, āvuso, bhikkhuṁ lobho nābhibhuyya tiṭṭhati,"
    },
    {
      "id": "an10.24:11.4",
      "pali": "doso …"
    },
    {
      "id": "an10.24:11.5",
      "pali": "moho …"
    },
    {
      "id": "an10.24:11.6",
      "pali": "kodho …"
    },
    {
      "id": "an10.24:11.7",
      "pali": "upanāho …"
    },
    {
      "id": "an10.24:11.8",
      "pali": "makkho …"
    },
    {
      "id": "an10.24:11.9",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.24:11.10",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.24:11.11",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.24:11.12",
      "pali": "pāpikā icchā nābhibhuyya tiṭṭhati, so evamassa veditabbo:"
    },
    {
      "id": "an10.24:11.13",
      "pali": "‘tathā ayamāyasmā pajānāti yathā pajānato lobho na hoti, tathāhimaṁ āyasmantaṁ lobho nābhibhuyya tiṭṭhati;"
    },
    {
      "id": "an10.24:11.14",
      "pali": "tathā ayamāyasmā pajānāti yathā pajānato doso na hoti …"
    },
    {
      "id": "an10.24:11.15",
      "pali": "moho …"
    },
    {
      "id": "an10.24:11.16",
      "pali": "kodho …"
    },
    {
      "id": "an10.24:11.17",
      "pali": "upanāho …"
    },
    {
      "id": "an10.24:11.18",
      "pali": "makkho …"
    },
    {
      "id": "an10.24:11.19",
      "pali": "paḷāso …"
    },
    {
      "id": "an10.24:11.20",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "an10.24:11.21",
      "pali": "pāpikā issā …"
    },
    {
      "id": "an10.24:11.22",
      "pali": "pāpikā icchā na hoti, tathāhimaṁ āyasmantaṁ pāpikā icchā nābhibhuyya tiṭṭhatī’”ti."
    },
    {
      "id": "an10.24:11.23",
      "pali": "Catutthaṁ."
    }
  ]
}
