{
  "uid": "an10.24",
  "title": "Mahācundasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.24:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā mahācundo cetīsu viharati sahajātiyaṁ."
    },
    {
      "id": "an10.24:1.2",
      "pali": "Tatra kho āyasmā mahācundo bhikkhū āmantesi:"
    },
    {
      "id": "an10.24:1.3",
      "pali": "“āvuso bhikkhave”ti."
    },
    {
      "id": "an10.24:1.4",
      "pali": "“Āvuso”ti kho te bhikkhū āyasmato mahācundassa paccassosuṁ."
    },
    {
      "id": "an10.24:1.5",
      "pali": "Āyasmā mahācundo etadavoca:"
    },
    {
      "id": "an10.24:2.1",
      "pali": "“Ñāṇavādaṁ, āvuso, bhikkhu vadamāno:"
    },
    {
      "id": "an10.24:2.2",
      "pali": "‘jānāmimaṁ dhammaṁ, passāmimaṁ dhamman’ti."
    },
    {
      "id": "an10.24:2.3",
      "pali": "Tañce, āvuso, bhikkhuṁ lobho abhibhuyya tiṭṭhati,"
    },
    {
      "id": "an10.24:2.4",
      "pali": "doso …"
    },
    {
      "id": "an10.24:2.5",
      "pali": "moho …"
    },
    {
      "id": "an10.24:2.6",
      "pali": "kodho …"
