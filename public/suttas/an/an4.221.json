{
  "uid": "an4.221",
  "title": "Duccaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.221:1.1",
      "pali": "“Cattārimāni, bhikkhave, vacīduccaritāni."
    },
    {
      "id": "an4.221:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.221:1.3",
      "pali": "Musāvādo, pisuṇā vācā, pharusā vācā, samphappalāpo—"
    },
    {
      "id": "an4.221:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri vacīduccaritāni."
    },
    {
      "id": "an4.221:1.5",
      "pali": "Cattārimāni, bhikkhave, vacīsucaritāni."
    },
    {
      "id": "an4.221:1.6",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.221:1.7",
      "pali": "Saccavācā, apisuṇā vācā, saṇhā vācā, mantavācā—"
    },
    {
      "id": "an4.221:1.8",
      "pali": "Imāni kho, bhikkhave, cattāri vacīsucaritānī”ti."
    },
    {
      "id": "an4.221:1.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
