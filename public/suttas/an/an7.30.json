{
  "uid": "an7.30",
  "title": "Vipattisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.30:1.1",
      "pali": "Sattimā, bhikkhave, upāsakassa vipattiyo …pe…"
    },
    {
      "id": "an7.30:1.2",
      "pali": "sattimā, bhikkhave, upāsakassa sampadā …pe…."
    },
    {
      "id": "an7.30:1.3",
      "pali": "Dasamaṁ."
    }
  ]
}
