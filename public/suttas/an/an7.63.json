{
  "uid": "an7.63",
  "title": "Bhariyāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.63:1.1",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya yena anāthapiṇḍikassa gahapatissa nivesanaṁ tenupasaṅkami; upasaṅkamitvā paññatte āsane nisīdi."
    },
    {
      "id": "an7.63:1.2",
      "pali": "Tena kho pana samayena anāthapiṇḍikassa gahapatissa nivesane manussā uccāsaddā mahāsaddā honti."
    },
    {
      "id": "an7.63:1.3",
      "pali": "Atha kho anāthapiṇḍiko gahapati yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinnaṁ kho anāthapiṇḍikaṁ gahapatiṁ bhagavā etadavoca:"
    },
    {
      "id": "an7.63:2.1",
      "pali": "“Kiṁ nu te, gahapati, nivesane manussā uccāsaddā mahāsaddā kevaṭṭā maññe macchavilope”ti?"
    },
    {
      "id": "an7.63:2.2",
      "pali": "“Ayaṁ, bhante, sujātā gharasuṇhā aḍḍhakulā ānītā."
    },
    {
      "id": "an7.63:2.3",
      "pali": "Sā neva sassuṁ ādiyati, na sasuraṁ ādiyati, na sāmikaṁ ādiyati, bhagavantampi na sakkaroti na garuṁ karoti na māneti na pūjetī”ti."
    },
    {
      "id": "an7.63:3.1",
      "pali": "Atha kho bhagavā sujātaṁ gharasuṇhaṁ āmantesi:"
    },
    {
      "id": "an7.63:3.2",
      "pali": "“ehi, sujāte”ti."
    },
    {
      "id": "an7.63:3.3",
      "pali": "“Evaṁ, bhante”ti kho sujātā gharasuṇhā bhagavato paṭissutvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinnaṁ kho sujātaṁ gharasuṇhaṁ bhagavā etadavoca:"
    },
    {
      "id": "an7.63:4.1",
      "pali": "“Satta kho imā, sujāte, purisassa bhariyāyo."
    },
    {
      "id": "an7.63:4.2",
      "pali": "Katamā satta?"
    },
    {
      "id": "an7.63:4.3",
      "pali": "Vadhakasamā, corīsamā, ayyasamā, mātāsamā, bhaginīsamā, sakhīsamā, dāsīsamā."
    },
    {
      "id": "an7.63:4.4",
      "pali": "Imā kho, sujāte, satta purisassa bhariyāyo."
    },
    {
      "id": "an7.63:4.5",
      "pali": "Tāsaṁ tvaṁ katamā”ti?"
    },
    {
      "id": "an7.63:4.6",
      "pali": "“Na kho ahaṁ, bhante, imassa bhagavatā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāmi."
    },
    {
      "id": "an7.63:4.7",
      "pali": "Sādhu me, bhante, bhagavā tathā dhammaṁ desetu yathāhaṁ imassa bhagavatā saṅkhittena bhāsitassa vitthārena atthaṁ jāneyyan”ti."
    },
    {
      "id": "an7.63:4.8",
      "pali": "“Tena hi, sujāte, suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "an7.63:4.9",
      "pali": "“Evaṁ, bhante”ti kho sujātā gharasuṇhā bhagavato paccassosi."
    },
    {
      "id": "an7.63:4.10",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an7.63:5.1",
      "pali": "“Paduṭṭhacittā ahitānukampinī,"
    },
    {
      "id": "an7.63:5.2",
      "pali": "Aññesu rattā atimaññate patiṁ;"
    },
    {
      "id": "an7.63:5.3",
      "pali": "Dhanena kītassa vadhāya ussukā,"
    },
    {
      "id": "an7.63:5.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:5.5",
      "pali": "‘Vadhā ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:6.1",
      "pali": "Yaṁ itthiyā vindati sāmiko dhanaṁ,"
    },
    {
      "id": "an7.63:6.2",
      "pali": "Sippaṁ vaṇijjañca kasiṁ adhiṭṭhahaṁ;"
    },
    {
      "id": "an7.63:6.3",
      "pali": "Appampi tassa apahātumicchati,"
    },
    {
      "id": "an7.63:6.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:6.5",
      "pali": "‘Corī ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:7.1",
      "pali": "Akammakāmā alasā mahagghasā,"
    },
    {
      "id": "an7.63:7.2",
      "pali": "Pharusā ca caṇḍī duruttavādinī;"
    },
    {
      "id": "an7.63:7.3",
      "pali": "Uṭṭhāyakānaṁ abhibhuyya vattati,"
    },
    {
      "id": "an7.63:7.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:7.5",
      "pali": "‘Ayyā ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:8.1",
      "pali": "Yā sabbadā hoti hitānukampinī,"
    },
    {
      "id": "an7.63:8.2",
      "pali": "Mātāva puttaṁ anurakkhate patiṁ;"
    },
    {
      "id": "an7.63:8.3",
      "pali": "Tato dhanaṁ sambhatamassa rakkhati,"
    },
    {
      "id": "an7.63:8.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:8.5",
      "pali": "‘Mātā ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:9.1",
      "pali": "Yathāpi jeṭṭhā bhaginī kaniṭṭhakā,"
    },
    {
      "id": "an7.63:9.2",
      "pali": "Sagāravā hoti sakamhi sāmike;"
    },
    {
      "id": "an7.63:9.3",
      "pali": "Hirīmanā bhattuvasānuvattinī,"
    },
    {
      "id": "an7.63:9.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:9.5",
      "pali": "‘Bhaginī ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:10.1",
      "pali": "Yācīdha disvāna patiṁ pamodati,"
    },
    {
      "id": "an7.63:10.2",
      "pali": "Sakhī sakhāraṁva cirassamāgataṁ;"
    },
    {
      "id": "an7.63:10.3",
      "pali": "Koleyyakā sīlavatī patibbatā,"
    },
    {
      "id": "an7.63:10.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:10.5",
      "pali": "‘Sakhī ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:11.1",
      "pali": "Akkuddhasantā vadhadaṇḍatajjitā,"
    },
    {
      "id": "an7.63:11.2",
      "pali": "Aduṭṭhacittā patino titikkhati;"
    },
    {
      "id": "an7.63:11.3",
      "pali": "Akkodhanā bhattuvasānuvattinī,"
    },
    {
      "id": "an7.63:11.4",
      "pali": "Yā evarūpā purisassa bhariyā;"
    },
    {
      "id": "an7.63:11.5",
      "pali": "‘Dāsī ca bhariyā’ti ca sā pavuccati."
    },
    {
      "id": "an7.63:12.1",
      "pali": "Yācīdha bhariyā vadhakāti vuccati,"
    },
    {
      "id": "an7.63:12.2",
      "pali": "‘Corī ca ayyā’ti ca yā pavuccati;"
    },
    {
      "id": "an7.63:12.3",
      "pali": "Dussīlarūpā pharusā anādarā,"
    },
    {
      "id": "an7.63:12.4",
      "pali": "Kāyassa bhedā nirayaṁ vajanti tā."
    },
    {
      "id": "an7.63:13.1",
      "pali": "Yācīdha mātā bhaginī sakhīti ca,"
    },
    {
      "id": "an7.63:13.2",
      "pali": "‘Dāsī ca bhariyā’ti ca sā pavuccati;"
    },
    {
      "id": "an7.63:13.3",
      "pali": "Sīle ṭhitattā cirarattasaṁvutā,"
    },
    {
      "id": "an7.63:13.4",
      "pali": "Kāyassa bhedā sugatiṁ vajanti tāti."
    },
    {
      "id": "an7.63:14.1",
      "pali": "Imā kho, sujāte, satta purisassa bhariyāyo."
    },
    {
      "id": "an7.63:14.2",
      "pali": "Tāsaṁ tvaṁ katamā”ti?"
    },
    {
      "id": "an7.63:14.3",
      "pali": "“Ajjatagge maṁ, bhante, bhagavā dāsīsamaṁ sāmikassa bhariyaṁ dhāretū”ti."
    },
    {
      "id": "an7.63:14.4",
      "pali": "Dasamaṁ."
    }
  ]
}
