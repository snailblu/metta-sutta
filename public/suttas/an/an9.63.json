{
  "uid": "an9.63",
  "title": "Sikkhādubbalyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.63:1.1",
      "pali": "“Pañcimāni, bhikkhave, sikkhādubbalyāni."
    },
    {
      "id": "an9.63:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an9.63:1.3",
      "pali": "Pāṇātipāto, adinnādānaṁ, kāmesumicchācāro, musāvādo, surāmerayamajjapamādaṭṭhānaṁ—"
    },
    {
      "id": "an9.63:1.4",
      "pali": "imāni kho, bhikkhave, pañca sikkhādubbalyāni."
    },
    {
      "id": "an9.63:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ sikkhādubbalyānaṁ pahānāya cattāro satipaṭṭhānā bhāvetabbā."
    },
    {
      "id": "an9.63:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an9.63:2.3",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "an9.63:2.4",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "an9.63:2.5",
      "pali": "citte …"
    },
    {
      "id": "an9.63:2.6",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "an9.63:2.7",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ sikkhādubbalyānaṁ pahānāya ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.63:2.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
