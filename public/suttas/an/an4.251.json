{
  "uid": "an4.251",
  "title": "Dutiyavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.251:1.1",
      "pali": "“Cattārome, bhikkhave, ariyavohārā."
    },
    {
      "id": "an4.251:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.251:1.3",
      "pali": "Adiṭṭhe adiṭṭhavāditā, asute asutavāditā, amute amutavāditā, aviññāte aviññātavāditā—"
    },
    {
      "id": "an4.251:1.4",
      "pali": "Ime kho, bhikkhave, cattāro ariyavohārā”ti."
    },
    {
      "id": "an4.251:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
