{
  "uid": "an4.86",
  "title": "Oṇatoṇatasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.86:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.86:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.86:1.3",
      "pali": "Oṇatoṇato,"
    },
    {
      "id": "an4.86:1.4",
      "pali": "oṇatuṇṇato,"
    },
    {
      "id": "an4.86:1.5",
      "pali": "uṇṇatoṇato,"
    },
    {
      "id": "an4.86:1.6",
      "pali": "uṇṇatuṇṇato."
    },
    {
      "id": "an4.86:1.7",
      "pali": "… Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.86:1.8",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
