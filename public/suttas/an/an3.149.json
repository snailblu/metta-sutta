{
  "uid": "an3.149",
  "title": "Asucisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.149:1.1",
      "pali": "“Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.149:1.2",
      "pali": "asucinā kāyakammena, asucinā vacīkammena, asucinā manokammena—"
    },
    {
      "id": "an3.149:1.3",
      "pali": "imehi kho …pe… evaṁ niraye."
    },
    {
      "id": "an3.149:2.1",
      "pali": "Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.149:2.2",
      "pali": "sucinā kāyakammena, sucinā vacīkammena, sucinā manokammena—"
    },
    {
      "id": "an3.149:2.3",
      "pali": "Imehi kho, bhikkhave, tīhi dhammehi samannāgato yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "an3.149:2.4",
      "pali": "Catutthaṁ."
    }
  ]
}
