{
  "uid": "an4.144",
  "title": "Obhāsasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.144:1.1",
      "pali": "“Cattārome, bhikkhave, obhāsā."
    },
    {
      "id": "an4.144:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.144:1.3",
      "pali": "Candobhāso, sūriyobhāso, aggobhāso, paññobhāso—"
    },
    {
      "id": "an4.144:1.4",
      "pali": "Ime kho, bhikkhave, cattāro obhāsā."
    },
    {
      "id": "an4.144:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imesaṁ catunnaṁ obhāsānaṁ yadidaṁ paññobhāso”ti."
    },
    {
      "id": "an4.144:1.6",
      "pali": "Catutthaṁ."
    }
  ]
}
