{
  "uid": "an10.181",
  "title": "Atthasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.181:1.1",
      "pali": "“Atthañca vo, bhikkhave, desessāmi anatthañca."
    },
    {
      "id": "an10.181:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.181:1.3",
      "pali": "katamo ca, bhikkhave, anattho?"
    },
    {
      "id": "an10.181:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.181:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.181:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, anattho."
    },
    {
      "id": "an10.181:2.1",
      "pali": "Katamo ca, bhikkhave, attho?"
    },
    {
      "id": "an10.181:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.181:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.181:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, attho”ti."
    },
    {
      "id": "an10.181:2.5",
      "pali": "Catutthaṁ."
    }
  ]
}
