{
  "uid": "an10.168",
  "title": "Ariyapaccorohaṇīsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.168:1.1",
      "pali": "“Ariyaṁ vo, bhikkhave, paccorohaṇiṁ desessāmi."
    },
    {
      "id": "an10.168:1.2",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "an10.168:1.3",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "an10.168:1.4",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an10.168:2.1",
      "pali": "“Katamā ca, bhikkhave, ariyā paccorohaṇī?"
    },
    {
      "id": "an10.168:2.2",
      "pali": "Idha, bhikkhave, ariyasāvako iti paṭisañcikkhati:"
    },
    {
      "id": "an10.168:2.3",
      "pali": "‘pāṇātipātassa kho pāpako vipāko—"
    },
    {
      "id": "an10.168:2.4",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.168:2.5",
      "pali": "So iti paṭisaṅkhāya pāṇātipātaṁ pajahati;"
    },
    {
      "id": "an10.168:2.6",
      "pali": "pāṇātipātā paccorohati."
    },
    {
      "id": "an10.168:3.1",
      "pali": "… ‘Adinnādānassa kho pāpako vipāko—"
    },
    {
      "id": "an10.168:3.2",
      "pali": "diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.168:3.3",
      "pali": "So iti paṭisaṅkhāya adinnādānaṁ pajahati;"
    },
    {
      "id": "an10.168:3.4",
      "pali": "adinnādānā paccorohati."
    },
    {
      "id": "an10.168:4.1",
      "pali": "… ‘Kāmesumicchācārassa kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:4.2",
      "pali": "kāmesumicchācārā paccorohati."
    },
    {
      "id": "an10.168:5.1",
      "pali": "… ‘Musāvādassa kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:5.2",
      "pali": "musāvādā paccorohati."
    },
    {
      "id": "an10.168:6.1",
      "pali": "… ‘Pisuṇāya vācāya kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:6.2",
      "pali": "pisuṇāya vācāya paccorohati."
    },
    {
      "id": "an10.168:7.1",
      "pali": "… ‘Pharusāya vācāya kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:7.2",
      "pali": "pharusāya vācāya paccorohati."
    },
    {
      "id": "an10.168:8.1",
      "pali": "… ‘Samphappalāpassa kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:8.2",
      "pali": "samphappalāpā paccorohati."
    },
    {
      "id": "an10.168:9.1",
      "pali": "… ‘Abhijjhāya kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:9.2",
      "pali": "abhijjhāya paccorohati."
    },
    {
      "id": "an10.168:10.1",
      "pali": "… ‘Byāpādassa kho pāpako vipāko …pe…"
    },
    {
      "id": "an10.168:10.2",
      "pali": "byāpādā paccorohati."
    },
    {
      "id": "an10.168:11.1",
      "pali": "… ‘Micchādiṭṭhiyā kho pāpako vipāko diṭṭhe ceva dhamme abhisamparāyañcā’ti."
    },
    {
      "id": "an10.168:11.2",
      "pali": "So iti paṭisaṅkhāya micchādiṭṭhiṁ pajahati;"
    },
    {
      "id": "an10.168:11.3",
      "pali": "micchādiṭṭhiyā paccorohati."
    },
    {
      "id": "an10.168:11.4",
      "pali": "Ayaṁ vuccati, bhikkhave, ariyā paccorohaṇī”ti."
    },
    {
      "id": "an10.168:11.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
