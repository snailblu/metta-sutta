{
  "uid": "an5.240",
  "title": "Dutiyamacchariyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.240:1.1",
      "pali": "“Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an5.240:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.240:1.3",
      "pali": "Āvāsamaccharī hoti;"
    },
    {
      "id": "an5.240:1.4",
      "pali": "kulamaccharī hoti;"
    },
    {
      "id": "an5.240:1.5",
      "pali": "lābhamaccharī hoti;"
    },
    {
      "id": "an5.240:1.6",
      "pali": "vaṇṇamaccharī hoti;"
    },
    {
      "id": "an5.240:1.7",
      "pali": "dhammamaccharī hoti."
    },
    {
      "id": "an5.240:1.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an5.240:2.1",
      "pali": "Pañcahi, bhikkhave, dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "an5.240:2.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "an5.240:2.3",
      "pali": "Na āvāsamaccharī hoti;"
    },
    {
      "id": "an5.240:2.4",
      "pali": "na kulamaccharī hoti;"
    },
    {
      "id": "an5.240:2.5",
      "pali": "na lābhamaccharī hoti;"
    },
    {
      "id": "an5.240:2.6",
      "pali": "na vaṇṇamaccharī hoti;"
    },
    {
      "id": "an5.240:2.7",
      "pali": "na dhammamaccharī hoti."
    },
    {
      "id": "an5.240:2.8",
      "pali": "Imehi kho, bhikkhave, pañcahi dhammehi samannāgato āvāsiko bhikkhu yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "an5.240:2.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.240:2.10",
      "pali": "Āvāsikavaggo catuttho."
    },
    {
      "id": "an5.240:3.1",
      "pali": "Āvāsiko piyo ca sobhano,"
    },
    {
      "id": "an5.240:3.2",
      "pali": "Bahūpakāro anukampako ca;"
    },
    {
      "id": "an5.240:3.3",
      "pali": "Tayo avaṇṇārahā ceva,"
    },
    {
      "id": "an5.240:3.4",
      "pali": "Macchariyā duvepi cāti."
    }
  ]
}
