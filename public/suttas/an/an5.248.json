{
  "uid": "an5.248",
  "title": "Dutiyamanoduccaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.248:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā manoduccarite …pe… ānisaṁsā manosucarite."
    },
    {
      "id": "an5.248:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.248:1.3",
      "pali": "Attāpi attānaṁ na upavadati;"
    },
    {
      "id": "an5.248:1.4",
      "pali": "anuvicca viññū pasaṁsanti;"
    },
    {
      "id": "an5.248:1.5",
      "pali": "kalyāṇo kittisaddo abbhuggacchati;"
    },
    {
      "id": "an5.248:1.6",
      "pali": "asaddhammā vuṭṭhāti;"
    },
    {
      "id": "an5.248:1.7",
      "pali": "saddhamme patiṭṭhāti."
    },
    {
      "id": "an5.248:1.8",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā manosucarite”ti."
    },
    {
      "id": "an5.248:1.9",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
