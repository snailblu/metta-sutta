{
  "uid": "an4.207",
  "title": "Paṭhamapāpadhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.207:1.1",
      "pali": "“Pāpañca vo, bhikkhave, desessāmi, pāpena pāpatarañca;"
    },
    {
      "id": "an4.207:1.2",
      "pali": "kalyāṇañca, kalyāṇena kalyāṇatarañca. Taṁ suṇātha …pe…."
    },
    {
      "id": "an4.207:2.1",
      "pali": "Katamo ca, bhikkhave, pāpo?"
    },
    {
      "id": "an4.207:2.2",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātī hoti …pe… micchādiṭṭhiko hoti."
    },
    {
      "id": "an4.207:2.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpo."
    },
    {
      "id": "an4.207:3.1",
      "pali": "Katamo ca, bhikkhave, pāpena pāpataro?"
    },
    {
      "id": "an4.207:3.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca pāṇātipātī hoti, parañca pāṇātipāte samādapeti …pe… attanā ca micchādiṭṭhiko hoti, parañca micchādiṭṭhiyā samādapeti."
    },
    {
      "id": "an4.207:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, pāpena pāpataro."
    },
    {
      "id": "an4.207:4.1",
      "pali": "Katamo ca, bhikkhave, kalyāṇo?"
    },
    {
      "id": "an4.207:4.2",
      "pali": "Idha, bhikkhave, ekacco pāṇātipātā paṭivirato hoti …pe… sammādiṭṭhiko hoti."
    },
    {
      "id": "an4.207:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇo."
    },
    {
      "id": "an4.207:5.1",
      "pali": "“Katamo ca, bhikkhave, kalyāṇena kalyāṇataro?"
    },
    {
      "id": "an4.207:5.2",
      "pali": "Idha, bhikkhave, ekacco attanā ca pāṇātipātā paṭivirato hoti, parañca pāṇātipātā veramaṇiyā samādapeti …pe… attanā ca sammādiṭṭhiko hoti, parañca sammādiṭṭhiyā samādapeti."
    },
    {
      "id": "an4.207:5.3",
      "pali": "Ayaṁ vuccati, bhikkhave, kalyāṇena kalyāṇataro”ti."
    },
    {
      "id": "an4.207:5.4",
      "pali": "Sattamaṁ."
    }
  ]
}
