{
  "uid": "an4.23",
  "title": "Lokasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.23:1.1",
      "pali": "“Loko, bhikkhave, tathāgatena abhisambuddho."
    },
    {
      "id": "an4.23:1.2",
      "pali": "Lokasmā tathāgato visaṁyutto."
    },
    {
      "id": "an4.23:1.3",
      "pali": "Lokasamudayo, bhikkhave, tathāgatena abhisambuddho."
    },
    {
      "id": "an4.23:1.4",
      "pali": "Lokasamudayo tathāgatassa pahīno."
    },
    {
      "id": "an4.23:1.5",
      "pali": "Lokanirodho, bhikkhave, tathāgatena abhisambuddho."
    },
    {
      "id": "an4.23:1.6",
      "pali": "Lokanirodho tathāgatassa sacchikato."
    },
    {
      "id": "an4.23:1.7",
      "pali": "Lokanirodhagāminī paṭipadā, bhikkhave, tathāgatena abhisambuddhā."
    },
    {
      "id": "an4.23:1.8",
      "pali": "Lokanirodhagāminī paṭipadā tathāgatassa bhāvitā."
    },
    {
      "id": "an4.23:2.1",
      "pali": "Yaṁ, bhikkhave, sadevakassa lokassa samārakassa sabrahmakassa sassamaṇabrāhmaṇiyā pajāya sadevamanussāya diṭṭhaṁ sutaṁ mutaṁ viññātaṁ pattaṁ pariyesitaṁ anuvicaritaṁ manasā, sabbaṁ taṁ tathāgatena abhisambuddhaṁ."
    },
    {
      "id": "an4.23:2.2",
      "pali": "Tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "an4.23:3.1",
      "pali": "Yañca, bhikkhave, rattiṁ tathāgato anuttaraṁ sammāsambodhiṁ abhisambujjhati yañca rattiṁ anupādisesāya nibbānadhātuyā parinibbāyati, yaṁ etasmiṁ antare bhāsati lapati niddisati sabbaṁ taṁ tatheva hoti, no aññathā."
    },
    {
      "id": "an4.23:3.2",
      "pali": "Tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "an4.23:4.1",
      "pali": "Yathāvādī, bhikkhave, tathāgato tathākārī, yathākārī tathāvādī."
    },
    {
      "id": "an4.23:4.2",
      "pali": "Iti yathāvādī tathākārī, yathākārī tathāvādī."
    },
    {
      "id": "an4.23:4.3",
      "pali": "Tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "an4.23:5.1",
      "pali": "Sadevake, bhikkhave, loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya tathāgato abhibhū anabhibhūto aññadatthu daso vasavattī."
    },
    {
      "id": "an4.23:5.2",
      "pali": "Tasmā ‘tathāgato’ti vuccati."
    },
    {
      "id": "an4.23:6.1",
      "pali": "Sabbaṁ lokaṁ abhiññāya,"
    },
    {
      "id": "an4.23:6.2",
      "pali": "sabbaṁ loke yathātathaṁ;"
    },
    {
      "id": "an4.23:6.3",
      "pali": "Sabbaṁ lokaṁ visaṁyutto,"
    },
    {
      "id": "an4.23:6.4",
      "pali": "sabbaloke anūpayo."
    },
    {
      "id": "an4.23:7.1",
      "pali": "Sa ve sabbābhibhū dhīro,"
    },
    {
      "id": "an4.23:7.2",
      "pali": "sabbaganthappamocano;"
    },
    {
      "id": "an4.23:7.3",
      "pali": "Phuṭṭha’ssa paramā santi,"
    },
    {
      "id": "an4.23:7.4",
      "pali": "nibbānaṁ akutobhayaṁ."
    },
    {
      "id": "an4.23:8.1",
      "pali": "Esa khīṇāsavo buddho,"
    },
    {
      "id": "an4.23:8.2",
      "pali": "anīgho chinnasaṁsayo;"
    },
    {
      "id": "an4.23:8.3",
      "pali": "Sabbakammakkhayaṁ patto,"
    },
    {
      "id": "an4.23:8.4",
      "pali": "vimutto upadhisaṅkhaye."
    },
    {
      "id": "an4.23:9.1",
      "pali": "Esa so bhagavā buddho,"
    },
    {
      "id": "an4.23:9.2",
      "pali": "esa sīho anuttaro;"
    },
    {
      "id": "an4.23:9.3",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "an4.23:9.4",
      "pali": "brahmacakkaṁ pavattayī."
    },
    {
      "id": "an4.23:10.1",
      "pali": "Iti devā manussā ca,"
    },
    {
      "id": "an4.23:10.2",
      "pali": "ye buddhaṁ saraṇaṁ gatā;"
    },
    {
      "id": "an4.23:10.3",
      "pali": "Saṅgamma taṁ namassanti,"
    },
    {
      "id": "an4.23:10.4",
      "pali": "mahantaṁ vītasāradaṁ."
    },
    {
      "id": "an4.23:11.1",
      "pali": "Danto damayataṁ seṭṭho,"
    },
    {
      "id": "an4.23:11.2",
      "pali": "santo samayataṁ isi;"
    },
    {
      "id": "an4.23:11.3",
      "pali": "Mutto mocayataṁ aggo,"
    },
    {
      "id": "an4.23:11.4",
      "pali": "tiṇṇo tārayataṁ varo."
    },
    {
      "id": "an4.23:12.1",
      "pali": "Iti hetaṁ namassanti,"
    },
    {
      "id": "an4.23:12.2",
      "pali": "mahantaṁ vītasāradaṁ;"
    },
    {
      "id": "an4.23:12.3",
      "pali": "Sadevakasmiṁ lokasmiṁ,"
    },
    {
      "id": "an4.23:12.4",
      "pali": "natthi me paṭipuggalo”ti."
    },
    {
      "id": "an4.23:12.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
