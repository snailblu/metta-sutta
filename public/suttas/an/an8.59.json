{
  "uid": "an8.59",
  "title": "Paṭhamapuggalasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.59:1.1",
      "pali": "“Aṭṭhime, bhikkhave, puggalā āhuneyyā pāhuneyyā dakkhiṇeyyā añjalikaraṇīyā anuttaraṁ puññakkhettaṁ lokassa?"
    },
    {
      "id": "an8.59:1.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.59:1.3",
      "pali": "Sotāpanno, sotāpattiphalasacchikiriyāya paṭipanno, sakadāgāmī, sakadāgāmiphalasacchikiriyāya paṭipanno, anāgāmī, anāgāmiphalasacchikiriyāya paṭipanno, arahā, arahattāya paṭipanno."
    },
    {
      "id": "an8.59:1.4",
      "pali": "Ime kho, bhikkhave, aṭṭha puggalā āhuneyyā …pe… anuttaraṁ puññakkhettaṁ lokassāti."
    },
    {
      "id": "an8.59:2.1",
      "pali": "Cattāro ca paṭipannā,"
    },
    {
      "id": "an8.59:2.2",
      "pali": "cattāro ca phale ṭhitā;"
    },
    {
      "id": "an8.59:2.3",
      "pali": "Esa saṅgho ujubhūto,"
    },
    {
      "id": "an8.59:2.4",
      "pali": "paññāsīlasamāhito."
    },
    {
      "id": "an8.59:3.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "an8.59:3.2",
      "pali": "Puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "an8.59:3.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "an8.59:3.4",
      "pali": "Saṅghe dinnaṁ mahapphalan”ti."
    },
    {
      "id": "an8.59:3.5",
      "pali": "Navamaṁ."
    }
  ]
}
