{
  "uid": "an10.25",
  "title": "Kasiṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.25:1.1",
      "pali": "“Dasayimāni, bhikkhave, kasiṇāyatanāni."
    },
    {
      "id": "an10.25:1.2",
      "pali": "Katamāni dasa?"
    },
    {
      "id": "an10.25:1.3",
      "pali": "Pathavīkasiṇameko sañjānāti uddhaṁ adho tiriyaṁ advayaṁ appamāṇaṁ;"
    },
    {
      "id": "an10.25:1.4",
      "pali": "āpokasiṇameko sañjānāti …pe…"
    },
    {
      "id": "an10.25:1.5",
      "pali": "tejokasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.6",
      "pali": "vāyokasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.7",
      "pali": "nīlakasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.8",
      "pali": "pītakasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.9",
      "pali": "lohitakasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.10",
      "pali": "odātakasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.11",
      "pali": "ākāsakasiṇameko sañjānāti …"
    },
    {
      "id": "an10.25:1.12",
      "pali": "viññāṇakasiṇameko sañjānāti uddhaṁ adho tiriyaṁ advayaṁ appamāṇaṁ."
    },
    {
      "id": "an10.25:1.13",
      "pali": "Imāni kho, bhikkhave, dasa kasiṇāyatanānī”ti."
    },
    {
      "id": "an10.25:1.14",
      "pali": "Pañcamaṁ."
    }
  ]
}
