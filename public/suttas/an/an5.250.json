{
  "uid": "an5.250",
  "title": "Puggalappasādasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.250:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā puggalappasāde."
    },
    {
      "id": "an5.250:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.250:1.3",
      "pali": "Yasmiṁ, bhikkhave, puggale puggalo abhippasanno hoti, so tathārūpaṁ āpattiṁ āpanno hoti yathārūpāya āpattiyā saṅgho ukkhipati."
    },
    {
      "id": "an5.250:1.4",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "an5.250:1.5",
      "pali": "‘yo kho myāyaṁ puggalo piyo manāpo so saṅghena ukkhitto’ti."
    },
    {
      "id": "an5.250:1.6",
      "pali": "Bhikkhūsu appasādabahulo hoti."
    },
    {
      "id": "an5.250:1.7",
      "pali": "Bhikkhūsu appasādabahulo samāno aññe bhikkhū na bhajati."
    },
    {
      "id": "an5.250:1.8",
      "pali": "Aññe bhikkhū abhajanto saddhammaṁ na suṇāti."
    },
    {
      "id": "an5.250:1.9",
      "pali": "Saddhammaṁ asuṇanto saddhammā parihāyati."
    },
    {
      "id": "an5.250:1.10",
      "pali": "Ayaṁ, bhikkhave, paṭhamo ādīnavo puggalappasāde."
    },
    {
      "id": "an5.250:2.1",
      "pali": "Puna caparaṁ, bhikkhave, yasmiṁ puggale puggalo abhippasanno hoti, so tathārūpaṁ āpattiṁ āpanno hoti yathārūpāya āpattiyā saṅgho ante nisīdāpeti."
    },
    {
      "id": "an5.250:2.2",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "an5.250:2.3",
      "pali": "‘yo kho myāyaṁ puggalo piyo manāpo so saṅghena ante nisīdāpito’ti."
    },
    {
      "id": "an5.250:2.4",
      "pali": "Bhikkhūsu appasādabahulo hoti."
    },
    {
      "id": "an5.250:2.5",
      "pali": "Bhikkhūsu appasādabahulo samāno aññe bhikkhū na bhajati."
    },
    {
      "id": "an5.250:2.6",
      "pali": "Aññe bhikkhū abhajanto saddhammaṁ na suṇāti."
    },
    {
      "id": "an5.250:2.7",
      "pali": "Saddhammaṁ asuṇanto saddhammā parihāyati."
    },
    {
      "id": "an5.250:2.8",
      "pali": "Ayaṁ, bhikkhave, dutiyo ādīnavo puggalappasāde."
    },
    {
      "id": "an5.250:3.1",
      "pali": "Puna caparaṁ, bhikkhave, yasmiṁ puggale puggalo abhippasanno hoti, so disāpakkanto hoti …pe… so vibbhanto hoti …pe… so kālaṅkato hoti."
    },
    {
      "id": "an5.250:3.2",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "an5.250:3.3",
      "pali": "‘yo kho myāyaṁ puggalo piyo manāpo so kālaṅkato’ti."
    },
    {
      "id": "an5.250:3.4",
      "pali": "Aññe bhikkhū na bhajati."
    },
    {
      "id": "an5.250:3.5",
      "pali": "Aññe bhikkhū abhajanto saddhammaṁ na suṇāti."
    },
    {
      "id": "an5.250:3.6",
      "pali": "Saddhammaṁ asuṇanto saddhammā parihāyati."
    },
    {
      "id": "an5.250:3.7",
      "pali": "Ayaṁ, bhikkhave, pañcamo ādīnavo puggalappasāde."
    },
    {
      "id": "an5.250:3.8",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā puggalappasāde”ti."
    },
    {
      "id": "an5.250:3.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.250:3.10",
      "pali": "Duccaritavaggo pañcamo."
    },
    {
      "id": "an5.250:4.1",
      "pali": "Duccaritaṁ kāyaduccaritaṁ,"
    },
    {
      "id": "an5.250:4.2",
      "pali": "Vacīduccaritaṁ manoduccaritaṁ;"
    },
    {
      "id": "an5.250:4.3",
      "pali": "Catūhi pare dve sivathikā,"
    },
    {
      "id": "an5.250:4.4",
      "pali": "Puggalappasādena cāti."
    },
    {
      "id": "an5.250:4.5",
      "pali": "Pañcamo paṇṇāsako samatto."
    }
  ]
}
