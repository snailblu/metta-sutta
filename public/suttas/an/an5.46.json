{
  "uid": "an5.46",
  "title": "Sampadāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.46:1.1",
      "pali": "“Pañcimā, bhikkhave, sampadā."
    },
    {
      "id": "an5.46:1.2",
      "pali": "Katamā pañca?"
    },
    {
      "id": "an5.46:1.3",
      "pali": "Saddhāsampadā, sīlasampadā, sutasampadā, cāgasampadā, paññāsampadā—"
    },
    {
      "id": "an5.46:1.4",
      "pali": "imā kho, bhikkhave, pañca sampadā”ti."
    },
    {
      "id": "an5.46:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
