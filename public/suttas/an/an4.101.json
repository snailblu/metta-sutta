{
  "uid": "an4.101",
  "title": "Paṭhamavalāhakasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.101:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "an4.101:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an4.101:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "an4.101:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "an4.101:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "an4.101:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an4.101:2.1",
      "pali": "“Cattārome, bhikkhave, valāhakā."
    },
    {
      "id": "an4.101:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.101:2.3",
      "pali": "Gajjitā no vassitā,"
    },
    {
      "id": "an4.101:2.4",
      "pali": "vassitā no gajjitā,"
    },
    {
      "id": "an4.101:2.5",
      "pali": "neva gajjitā no vassitā,"
    },
    {
      "id": "an4.101:2.6",
      "pali": "gajjitā ca vassitā ca."
    },
    {
      "id": "an4.101:2.7",
      "pali": "Ime kho, bhikkhave, cattāro valāhakā."
    },
    {
      "id": "an4.101:2.8",
      "pali": "Evamevaṁ kho, bhikkhave, cattāro valāhakūpamā puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.101:2.9",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.101:2.10",
      "pali": "Gajjitā no vassitā,"
    },
    {
      "id": "an4.101:2.11",
      "pali": "vassitā no gajjitā,"
    },
    {
      "id": "an4.101:2.12",
      "pali": "neva gajjitā no vassitā,"
    },
    {
      "id": "an4.101:2.13",
      "pali": "gajjitā ca vassitā ca."
    },
    {
      "id": "an4.101:3.1",
      "pali": "Kathañca, bhikkhave, puggalo gajjitā hoti no vassitā?"
    },
    {
      "id": "an4.101:3.2",
      "pali": "Idha, bhikkhave, ekacco puggalo bhāsitā hoti, no kattā."
    },
    {
      "id": "an4.101:3.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo gajjitā hoti, no vassitā."
    },
    {
      "id": "an4.101:3.4",
      "pali": "Seyyathāpi so, bhikkhave, valāhako gajjitā, no vassitā;"
    },
    {
      "id": "an4.101:3.5",
      "pali": "tathūpamāhaṁ, bhikkhave, imaṁ puggalaṁ vadāmi."
    },
    {
      "id": "an4.101:4.1",
      "pali": "Kathañca, bhikkhave, puggalo vassitā hoti, no gajjitā?"
    },
    {
      "id": "an4.101:4.2",
      "pali": "Idha, bhikkhave, ekacco puggalo kattā hoti, no bhāsitā."
    },
    {
      "id": "an4.101:4.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo vassitā hoti, no gajjitā."
    },
    {
      "id": "an4.101:4.4",
      "pali": "Seyyathāpi so, bhikkhave, valāhako vassitā, no gajjitā;"
    },
    {
      "id": "an4.101:4.5",
      "pali": "tathūpamāhaṁ, bhikkhave, imaṁ puggalaṁ vadāmi."
    },
    {
      "id": "an4.101:5.1",
      "pali": "Kathañca, bhikkhave, puggalo neva gajjitā hoti, no vassitā?"
    },
    {
      "id": "an4.101:5.2",
      "pali": "Idha, bhikkhave, ekacco puggalo neva bhāsitā hoti, no kattā."
    },
    {
      "id": "an4.101:5.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo neva gajjitā hoti, no vassitā."
    },
    {
      "id": "an4.101:5.4",
      "pali": "Seyyathāpi so, bhikkhave, valāhako neva gajjitā, no vassitā;"
    },
    {
      "id": "an4.101:5.5",
      "pali": "tathūpamāhaṁ, bhikkhave, imaṁ puggalaṁ vadāmi."
    },
    {
      "id": "an4.101:6.1",
      "pali": "Kathañca, bhikkhave, puggalo gajjitā ca hoti vassitā ca?"
    },
    {
      "id": "an4.101:6.2",
      "pali": "Idha, bhikkhave, ekacco puggalo bhāsitā ca hoti kattā ca."
    },
    {
      "id": "an4.101:6.3",
      "pali": "Evaṁ kho, bhikkhave, puggalo gajjitā ca hoti vassitā ca."
    },
    {
      "id": "an4.101:6.4",
      "pali": "Seyyathāpi so, bhikkhave, valāhako gajjitā ca vassitā ca;"
    },
    {
      "id": "an4.101:6.5",
      "pali": "tathūpamāhaṁ, bhikkhave, imaṁ puggalaṁ vadāmi."
    },
    {
      "id": "an4.101:6.6",
      "pali": "Ime kho, bhikkhave, cattāro valāhakūpamā puggalā santo saṁvijjamānā lokasmin”ti."
    },
    {
      "id": "an4.101:6.7",
      "pali": "Paṭhamaṁ."
    }
  ]
}
