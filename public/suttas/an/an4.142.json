{
  "uid": "an4.142",
  "title": "Pabhāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.142:1.1",
      "pali": "“Catasso imā, bhikkhave, pabhā."
    },
    {
      "id": "an4.142:1.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.142:1.3",
      "pali": "Candappabhā, sūriyappabhā, aggippabhā, paññāpabhā—"
    },
    {
      "id": "an4.142:1.4",
      "pali": "imā kho, bhikkhave, catasso pabhā."
    },
    {
      "id": "an4.142:1.5",
      "pali": "Etadaggaṁ, bhikkhave, imāsaṁ catunnaṁ pabhānaṁ yadidaṁ paññāpabhā”ti."
    },
    {
      "id": "an4.142:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
