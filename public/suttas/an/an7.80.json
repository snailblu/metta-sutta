{
  "uid": "an7.80",
  "title": "Dutiyavinayadharasobhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.80:1.1",
      "pali": "“Sattahi, bhikkhave, dhammehi samannāgato vinayadharo sobhati."
    },
    {
      "id": "an7.80:1.2",
      "pali": "Katamehi sattahi?"
    },
    {
      "id": "an7.80:1.3",
      "pali": "Āpattiṁ jānāti,"
    },
    {
      "id": "an7.80:1.4",
      "pali": "anāpattiṁ jānāti,"
    },
    {
      "id": "an7.80:1.5",
      "pali": "lahukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.80:1.6",
      "pali": "garukaṁ āpattiṁ jānāti,"
    },
    {
      "id": "an7.80:1.7",
      "pali": "ubhayāni kho panassa pātimokkhāni vitthārena svāgatāni honti suvibhattāni suppavattīni suvinicchitāni suttaso anubyañjanaso,"
    },
    {
      "id": "an7.80:1.8",
      "pali": "catunnaṁ jhānānaṁ …pe… akasiralābhī,"
    },
    {
      "id": "an7.80:1.9",
      "pali": "āsavānaṁ khayā …pe… sacchikatvā upasampajja viharati."
    },
    {
      "id": "an7.80:1.10",
      "pali": "Imehi kho, bhikkhave, sattahi dhammehi samannāgato vinayadharo sobhatī”ti."
    },
    {
      "id": "an7.80:1.11",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
