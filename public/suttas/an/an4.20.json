{
  "uid": "an4.20",
  "title": "Bhattuddesakasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.20:1.1",
      "pali": "“Catūhi, bhikkhave, dhammehi samannāgato bhattuddesako yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an4.20:1.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an4.20:1.3",
      "pali": "Chandāgatiṁ gacchati, dosāgatiṁ gacchati, mohāgatiṁ gacchati, bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.20:1.4",
      "pali": "imehi kho, bhikkhave, catūhi dhammehi samannāgato bhattuddesako yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an4.20:2.1",
      "pali": "Catūhi, bhikkhave, dhammehi samannāgato bhattuddesako yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "an4.20:2.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "an4.20:2.3",
      "pali": "Na chandāgatiṁ gacchati, na dosāgatiṁ gacchati, na mohāgatiṁ gacchati, na bhayāgatiṁ gacchati—"
    },
    {
      "id": "an4.20:2.4",
      "pali": "imehi kho, bhikkhave, catūhi dhammehi samannāgato bhattuddesako yathābhataṁ nikkhitto evaṁ saggeti."
    },
    {
      "id": "an4.20:3.1",
      "pali": "Ye keci kāmesu asaññatā janā,"
    },
    {
      "id": "an4.20:3.2",
      "pali": "Adhammikā honti adhammagāravā;"
    },
    {
      "id": "an4.20:3.3",
      "pali": "Chandā dosā mohā ca bhayā gāmino,"
    },
    {
      "id": "an4.20:3.4",
      "pali": "Parisākasaṭo ca panesa vuccati."
    },
    {
      "id": "an4.20:4.1",
      "pali": "Evañhi vuttaṁ samaṇena jānatā,"
    },
    {
      "id": "an4.20:4.2",
      "pali": "Tasmā hi te sappurisā pasaṁsiyā;"
    },
    {
      "id": "an4.20:4.3",
      "pali": "Dhamme ṭhitā ye na karonti pāpakaṁ,"
    },
    {
      "id": "an4.20:4.4",
      "pali": "Na chandā na dosā na mohā na bhayā ca gāmino;"
    },
    {
      "id": "an4.20:4.5",
      "pali": "Parisāya maṇḍo ca panesa vuccati,"
    },
    {
      "id": "an4.20:4.6",
      "pali": "Evañhi vuttaṁ samaṇena jānatā”ti."
    },
    {
      "id": "an4.20:4.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.20:4.8",
      "pali": "Caravaggo dutiyo."
    },
    {
      "id": "an4.20:5.1",
      "pali": "Caraṁ sīlaṁ padhānāni,"
    },
    {
      "id": "an4.20:5.2",
      "pali": "saṁvaraṁ paññatti pañcamaṁ;"
    },
    {
      "id": "an4.20:5.3",
      "pali": "Sokhummaṁ tayo agatī,"
    },
    {
      "id": "an4.20:5.4",
      "pali": "bhattuddesena te dasāti."
    }
  ]
}
