{
  "uid": "an10.174",
  "title": "Kammanidānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.174:1.1",
      "pali": "“Pāṇātipātampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:1.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:2.1",
      "pali": "Adinnādānampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:2.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:3.1",
      "pali": "Kāmesumicchācārampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:3.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:4.1",
      "pali": "Musāvādampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:4.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:5.1",
      "pali": "Pisuṇavācampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:5.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:6.1",
      "pali": "Pharusavācampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:6.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:7.1",
      "pali": "Samphappalāpampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:7.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:8.1",
      "pali": "Abhijjhampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:8.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:9.1",
      "pali": "Byāpādampāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:9.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:10.1",
      "pali": "Micchādiṭṭhimpāhaṁ, bhikkhave, tividhaṁ vadāmi—"
    },
    {
      "id": "an10.174:10.2",
      "pali": "lobhahetukampi, dosahetukampi, mohahetukampi."
    },
    {
      "id": "an10.174:10.3",
      "pali": "Iti kho, bhikkhave, lobho kammanidānasambhavo, doso kammanidānasambhavo, moho kammanidānasambhavo."
    },
    {
      "id": "an10.174:10.4",
      "pali": "Lobhakkhayā kammanidānasaṅkhayo, dosakkhayā kammanidānasaṅkhayo, mohakkhayā kammanidānasaṅkhayo”ti."
    },
    {
      "id": "an10.174:10.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
