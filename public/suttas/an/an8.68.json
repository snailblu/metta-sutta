{
  "uid": "an8.68",
  "title": "Ariyavohārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.68:1.1",
      "pali": "“Aṭṭhime, bhikkhave, ariyavohārā."
    },
    {
      "id": "an8.68:1.2",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "an8.68:1.3",
      "pali": "Adiṭṭhe adiṭṭhavāditā, asute asutavāditā, amute amutavāditā, aviññāte aviññātavāditā, diṭṭhe diṭṭhavāditā, sute sutavāditā, mute mutavāditā, viññāte viññātavāditā."
    },
    {
      "id": "an8.68:1.4",
      "pali": "Ime kho, bhikkhave, aṭṭha ariyavohārā”ti."
    },
    {
      "id": "an8.68:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
