{
  "uid": "an6.106",
  "title": "Taṇhāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.106:1.1",
      "pali": "“Tisso imā, bhikkhave, taṇhā pahātabbā, tayo ca mānā."
    },
    {
      "id": "an6.106:1.2",
      "pali": "Katamā tisso taṇhā pahātabbā?"
    },
    {
      "id": "an6.106:1.3",
      "pali": "Kāmataṇhā, bhavataṇhā, vibhavataṇhā—"
    },
    {
      "id": "an6.106:1.4",
      "pali": "imā tisso taṇhā pahātabbā."
    },
    {
      "id": "an6.106:1.5",
      "pali": "Katame tayo mānā pahātabbā?"
    },
    {
      "id": "an6.106:1.6",
      "pali": "Māno, omāno, atimāno—"
    },
    {
      "id": "an6.106:1.7",
      "pali": "ime tayo mānā pahātabbā."
    },
    {
      "id": "an6.106:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno imā tisso taṇhā pahīnā honti, ime ca tayo mānā;"
    },
    {
      "id": "an6.106:1.9",
      "pali": "ayaṁ vuccati, bhikkhave, bhikkhu acchecchi taṇhaṁ, vivattayi saṁyojanaṁ, sammā mānābhisamayā antamakāsi dukkhassā”ti."
    },
    {
      "id": "an6.106:1.10",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "an6.106:1.11",
      "pali": "Ānisaṁsavaggo dasamo."
    },
    {
      "id": "an6.106:2.1",
      "pali": "Pātubhāvo ānisaṁso,"
    },
    {
      "id": "an6.106:2.2",
      "pali": "aniccadukkhaanattato;"
    },
    {
      "id": "an6.106:2.3",
      "pali": "Nibbānaṁ anavatthi,"
    },
    {
      "id": "an6.106:2.4",
      "pali": "ukkhittāsi atammayo;"
    },
    {
      "id": "an6.106:2.5",
      "pali": "Bhavā taṇhāyekā dasāti."
    },
    {
      "id": "an6.106:2.6",
      "pali": "Dutiyo paṇṇāsako samatto."
    }
  ]
}
