{
  "uid": "an6.113",
  "title": "Aratisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.113:1.1",
      "pali": "“Tayome, bhikkhave, dhammā."
    },
    {
      "id": "an6.113:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.113:1.3",
      "pali": "Arati, vihiṁsā, adhammacariyā."
    },
    {
      "id": "an6.113:1.4",
      "pali": "Ime kho, bhikkhave, tayo dhammā."
    },
    {
      "id": "an6.113:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya tayo dhammā bhāvetabbā."
    },
    {
      "id": "an6.113:1.6",
      "pali": "Katame tayo?"
    },
    {
      "id": "an6.113:1.7",
      "pali": "Aratiyā pahānāya muditā bhāvetabbā, vihiṁsāya pahānāya avihiṁsā bhāvetabbā, adhammacariyāya pahānāya dhammacariyā bhāvetabbā."
    },
    {
      "id": "an6.113:1.8",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇaṁ dhammānaṁ pahānāya ime tayo dhammā bhāvetabbā”ti."
    },
    {
      "id": "an6.113:1.9",
      "pali": "Sattamaṁ."
    }
  ]
}
