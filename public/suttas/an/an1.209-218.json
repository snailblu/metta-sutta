{
  "uid": "an1.209-218",
  "title": "an1.209-218",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.209:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ sikkhākāmānaṁ yadidaṁ rāhulo."
    },
    {
      "id": "an1.210:1.1",
      "pali": "… Saddhāpabbajitānaṁ yadidaṁ raṭṭhapālo."
    },
    {
      "id": "an1.211:1.1",
      "pali": "… Paṭhamaṁ salākaṁ gaṇhantānaṁ yadidaṁ kuṇḍadhāno."
    },
    {
      "id": "an1.212:1.1",
      "pali": "… Paṭibhānavantānaṁ yadidaṁ vaṅgīso."
    },
    {
      "id": "an1.213:1.1",
      "pali": "… Samantapāsādikānaṁ yadidaṁ upaseno vaṅgantaputto."
    },
    {
      "id": "an1.214:1.1",
      "pali": "… Senāsanapaññāpakānaṁ yadidaṁ dabbo mallaputto."
    },
    {
      "id": "an1.215:1.1",
      "pali": "… devatānaṁ piyamanāpānaṁ yadidaṁ pilindavaccho."
    },
    {
      "id": "an1.216:1.1",
      "pali": "… Khippābhiññānaṁ yadidaṁ bāhiyo dārucīriyo."
    },
    {
      "id": "an1.217:1.1",
      "pali": "… Cittakathikānaṁ yadidaṁ kumārakassapo."
    },
    {
      "id": "an1.218:1.1",
      "pali": "… Paṭisambhidāpattānaṁ yadidaṁ mahākoṭṭhito”ti."
    },
    {
      "id": "an1.218:1.2",
      "pali": "Vaggo tatiyo."
    }
  ]
}
