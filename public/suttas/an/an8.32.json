{
  "uid": "an8.32",
  "title": "Dutiyadānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.32:1.1",
      "pali": "“Saddhā hiriyaṁ kusalañca dānaṁ,"
    },
    {
      "id": "an8.32:1.2",
      "pali": "Dhammā ete sappurisānuyātā;"
    },
    {
      "id": "an8.32:1.3",
      "pali": "Etañhi maggaṁ diviyaṁ vadanti,"
    },
    {
      "id": "an8.32:1.4",
      "pali": "Etena hi gacchati devalokan”ti."
    },
    {
      "id": "an8.32:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
