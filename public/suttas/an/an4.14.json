{
  "uid": "an4.14",
  "title": "Saṁvarasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.14:1.1",
      "pali": "“Cattārimāni, bhikkhave, padhānāni."
    },
    {
      "id": "an4.14:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.14:1.3",
      "pali": "Saṁvarappadhānaṁ, pahānappadhānaṁ, bhāvanāppadhānaṁ, anurakkhaṇāppadhānaṁ."
    },
    {
      "id": "an4.14:1.4",
      "pali": "Katamañca, bhikkhave, saṁvarappadhānaṁ?"
    },
    {
      "id": "an4.14:1.5",
      "pali": "Idha, bhikkhave, bhikkhu cakkhunā rūpaṁ disvā na nimittaggāhī hoti nānubyañjanaggāhī."
    },
    {
      "id": "an4.14:1.6",
      "pali": "Yatvādhikaraṇamenaṁ cakkhundriyaṁ asaṁvutaṁ viharantaṁ abhijjhādomanassā pāpakā akusalā dhammā anvāssaveyyuṁ, tassa saṁvarāya paṭipajjati, rakkhati cakkhundriyaṁ, cakkhundriye saṁvaraṁ āpajjati."
    },
    {
      "id": "an4.14:1.7",
      "pali": "Sotena saddaṁ sutvā …"
    },
    {
      "id": "an4.14:1.8",
      "pali": "ghānena gandhaṁ ghāyitvā …"
    },
    {
      "id": "an4.14:1.9",
      "pali": "jivhāya rasaṁ sāyitvā …"
    },
    {
      "id": "an4.14:1.10",
      "pali": "kāyena phoṭṭhabbaṁ phusitvā …"
    },
    {
      "id": "an4.14:1.11",
      "pali": "manasā dhammaṁ viññāya na nimittaggāhī hoti nānubyañjanaggāhī,"
    },
    {
      "id": "an4.14:1.12",
      "pali": "yatvādhikaraṇamenaṁ manindriyaṁ asaṁvutaṁ viharantaṁ abhijjhādomanassā pāpakā akusalā dhammā anvāssaveyyuṁ, tassa saṁvarāya paṭipajjati, rakkhati manindriyaṁ, manindriye saṁvaraṁ āpajjati."
    },
    {
      "id": "an4.14:1.13",
      "pali": "Idaṁ vuccati, bhikkhave, saṁvarappadhānaṁ."
    },
    {
      "id": "an4.14:2.1",
      "pali": "Katamañca, bhikkhave, pahānappadhānaṁ?"
    },
    {
      "id": "an4.14:2.2",
      "pali": "Idha, bhikkhave, bhikkhu uppannaṁ kāmavitakkaṁ nādhivāseti pajahati vinodeti byantīkaroti anabhāvaṁ gameti;"
    },
    {
      "id": "an4.14:2.3",
      "pali": "uppannaṁ byāpādavitakkaṁ …pe…"
    },
    {
      "id": "an4.14:2.4",
      "pali": "uppannaṁ vihiṁsāvitakkaṁ …pe…"
    },
    {
      "id": "an4.14:2.5",
      "pali": "uppannuppanne pāpake akusale dhamme nādhivāseti pajahati vinodeti byantīkaroti anabhāvaṁ gameti."
    },
    {
      "id": "an4.14:2.6",
      "pali": "Idaṁ vuccati, bhikkhave, pahānappadhānaṁ."
    },
    {
      "id": "an4.14:3.1",
      "pali": "Katamañca, bhikkhave, bhāvanāppadhānaṁ?"
    },
    {
      "id": "an4.14:3.2",
      "pali": "Idha, bhikkhave, bhikkhu satisambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ,"
    },
    {
      "id": "an4.14:3.3",
      "pali": "dhammavicayasambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an4.14:3.4",
      "pali": "vīriyasambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an4.14:3.5",
      "pali": "pītisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an4.14:3.6",
      "pali": "passaddhisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an4.14:3.7",
      "pali": "samādhisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an4.14:3.8",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "an4.14:3.9",
      "pali": "Idaṁ vuccati, bhikkhave, bhāvanāppadhānaṁ."
    },
    {
      "id": "an4.14:4.1",
      "pali": "Katamañca, bhikkhave, anurakkhaṇāppadhānaṁ?"
    },
    {
      "id": "an4.14:4.2",
      "pali": "Idha, bhikkhave, bhikkhu uppannaṁ bhaddakaṁ samādhinimittaṁ anurakkhati aṭṭhikasaññaṁ puḷavakasaññaṁ vinīlakasaññaṁ vicchiddakasaññaṁ uddhumātakasaññaṁ."
    },
    {
      "id": "an4.14:4.3",
      "pali": "Idaṁ vuccati, bhikkhave, anurakkhaṇāppadhānaṁ."
    },
    {
      "id": "an4.14:4.4",
      "pali": "Imāni kho, bhikkhave, cattāri padhānānīti."
    },
    {
      "id": "an4.14:5.1",
      "pali": "Saṁvaro ca pahānañca,"
    },
    {
      "id": "an4.14:5.2",
      "pali": "bhāvanā anurakkhaṇā;"
    },
    {
      "id": "an4.14:5.3",
      "pali": "Ete padhānā cattāro,"
    },
    {
      "id": "an4.14:5.4",
      "pali": "desitādiccabandhunā;"
    },
    {
      "id": "an4.14:5.5",
      "pali": "Yehi bhikkhu idhātāpī,"
    },
    {
      "id": "an4.14:5.6",
      "pali": "khayaṁ dukkhassa pāpuṇe”ti."
    },
    {
      "id": "an4.14:5.7",
      "pali": "Catutthaṁ."
    }
  ]
}
