{
  "uid": "an4.256",
  "title": "Saṅgahavatthusutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.256:1.1",
      "pali": "“Cattārimāni, bhikkhave, saṅgahavatthūni."
    },
    {
      "id": "an4.256:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.256:1.3",
      "pali": "Dānaṁ, peyyavajjaṁ, atthacariyā, samānattatā—"
    },
    {
      "id": "an4.256:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri saṅgahavatthūnī”ti."
    },
    {
      "id": "an4.256:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
