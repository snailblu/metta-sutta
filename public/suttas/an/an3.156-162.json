{
  "uid": "an3.156-162",
  "title": "an3.156-162",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.156:1.1",
      "pali": "“Tisso imā, bhikkhave, paṭipadā."
    },
    {
      "id": "an3.156:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.156:1.3",
      "pali": "Āgāḷhā paṭipadā, nijjhāmā paṭipadā, majjhimā paṭipadā."
    },
    {
      "id": "an3.156:1.4",
      "pali": "Katamā ca, bhikkhave, āgāḷhā paṭipadā?"
    },
    {
      "id": "an3.156:1.5",
      "pali": "Idha, bhikkhave, ekacco evaṁvādī hoti evaṁdiṭṭhi:"
    },
    {
      "id": "an3.156:1.6",
      "pali": "‘natthi kāmesu doso’ti."
    },
    {
      "id": "an3.156:1.7",
      "pali": "So kāmesu pātabyataṁ āpajjati."
    },
    {
      "id": "an3.156:1.8",
      "pali": "Ayaṁ vuccati, bhikkhave, āgāḷhā paṭipadā."
    },
    {
      "id": "an3.156:2.1",
      "pali": "Katamā ca, bhikkhave, nijjhāmā paṭipadā?"
    },
    {
      "id": "an3.156:2.2",
      "pali": "Idha, bhikkhave, ekacco acelako hoti muttācāro, hatthāpalekhano, naehibhadantiko, natiṭṭhabhadantiko, nābhihaṭaṁ na uddissakataṁ na nimantanaṁ sādiyati."
    },
    {
      "id": "an3.156:2.3",
      "pali": "So na kumbhimukhā paṭiggaṇhāti, na kaḷopimukhā paṭiggaṇhāti na eḷakamantaraṁ na daṇḍamantaraṁ na musalamantaraṁ na dvinnaṁ bhuñjamānānaṁ na gabbhiniyā na pāyamānāya na purisantaragatāya na saṅkittīsu na yattha sā upaṭṭhito hoti na yattha makkhikā saṇḍasaṇḍacārinī na macchaṁ na maṁsaṁ na suraṁ na merayaṁ, na thusodakaṁ pivati."
    },
    {
      "id": "an3.156:2.4",
      "pali": "So ekāgāriko vā hoti ekālopiko, dvāgāriko vā hoti dvālopiko … sattāgāriko vā hoti sattālopiko;"
    },
    {
      "id": "an3.156:2.5",
      "pali": "ekissāpi dattiyā yāpeti, dvīhipi dattīhi yāpeti … sattahipi dattīhi yāpeti;"
    },
    {
      "id": "an3.156:2.6",
      "pali": "ekāhikampi āhāraṁ āhāreti, dvāhikampi āhāraṁ āhāreti … sattāhikampi āhāraṁ āhāreti—iti evarūpaṁ addhamāsikampi pariyāyabhattabhojanānuyogamanuyutto viharati."
    },
    {
      "id": "an3.156:3.1",
      "pali": "So sākabhakkhopi hoti, sāmākabhakkhopi hoti, nīvārabhakkhopi hoti, daddulabhakkhopi hoti, haṭabhakkhopi hoti, kaṇabhakkhopi hoti, ācāmabhakkhopi hoti, piññākabhakkhopi hoti, tiṇabhakkhopi hoti, gomayabhakkhopi hoti, vanamūlaphalāhāro yāpeti pavattaphalabhojī."
    },
    {
      "id": "an3.156:4.1",
      "pali": "So sāṇānipi dhāreti, masāṇānipi dhāreti, chavadussānipi dhāreti, paṁsukūlānipi dhāreti, tirīṭānipi dhāreti, ajinampi dhāreti, ajinakkhipampi dhāreti, kusacīrampi dhāreti, vākacīrampi dhāreti, phalakacīrampi dhāreti, kesakambalampi dhāreti, vāḷakambalampi dhāreti, ulūkapakkhikampi dhāreti,"
    },
    {
      "id": "an3.156:4.2",
      "pali": "kesamassulocakopi hoti kesamassulocanānuyogamanuyutto,"
    },
    {
      "id": "an3.156:4.3",
      "pali": "ubbhaṭṭhakopi hoti āsanapaṭikkhitto,"
    },
    {
      "id": "an3.156:4.4",
      "pali": "ukkuṭikopi hoti ukkuṭikappadhānamanuyutto,"
    },
    {
      "id": "an3.156:4.5",
      "pali": "kaṇṭakāpassayikopi hoti kaṇṭakāpassaye seyyaṁ kappeti,"
    },
    {
      "id": "an3.156:4.6",
      "pali": "sāyatatiyakampi udakorohanānuyogamanuyutto viharati—"
    },
    {
      "id": "an3.156:4.7",
      "pali": "iti evarūpaṁ anekavihitaṁ kāyassa ātāpanaparitāpanānuyogamanuyutto viharati."
    },
    {
      "id": "an3.156:4.8",
      "pali": "Ayaṁ vuccati, bhikkhave, nijjhāmā paṭipadā."
    },
    {
      "id": "an3.156:5.1",
      "pali": "Katamā ca, bhikkhave, majjhimā paṭipadā?"
    },
    {
      "id": "an3.156:5.2",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "an3.156:5.3",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "an3.156:5.4",
      "pali": "citte …pe…"
    },
    {
      "id": "an3.156:5.5",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "an3.156:5.6",
      "pali": "Ayaṁ vuccati, bhikkhave, majjhimā paṭipadā."
    },
    {
      "id": "an3.156:5.7",
      "pali": "Imā kho, bhikkhave, tisso paṭipadāti."
    },
    {
      "id": "an3.157:1.1",
      "pali": "Tisso imā, bhikkhave, paṭipadā."
    },
    {
      "id": "an3.157:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "an3.157:1.3",
      "pali": "Āgāḷhā paṭipadā, nijjhāmā paṭipadā, majjhimā paṭipadā."
    },
    {
      "id": "an3.157:1.4",
      "pali": "Katamā ca, bhikkhave, āgāḷhā paṭipadā …pe…"
    },
    {
      "id": "an3.157:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, āgāḷhā paṭipadā."
    },
    {
      "id": "an3.157:2.1",
      "pali": "Katamā ca, bhikkhave, nijjhāmā paṭipadā …pe…"
    },
    {
      "id": "an3.157:2.2",
      "pali": "ayaṁ vuccati, bhikkhave, nijjhāmā paṭipadā."
    },
    {
      "id": "an3.157:3.1",
      "pali": "Katamā ca, bhikkhave, majjhimā paṭipadā?"
    },
    {
      "id": "an3.157:3.2",
      "pali": "Idha, bhikkhave, bhikkhu anuppannānaṁ pāpakānaṁ akusalānaṁ dhammānaṁ anuppādāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati;"
    },
    {
      "id": "an3.157:3.3",
      "pali": "uppannānaṁ pāpakānaṁ akusalānaṁ dhammānaṁ pahānāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati;"
    },
    {
      "id": "an3.157:3.4",
      "pali": "anuppannānaṁ kusalānaṁ dhammānaṁ uppādāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati;"
    },
    {
      "id": "an3.157:3.5",
      "pali": "uppannānaṁ kusalānaṁ dhammānaṁ ṭhitiyā asammosāya bhiyyobhāvāya vepullāya bhāvanāya pāripūriyā chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati …."
    },
    {
      "id": "an3.158:1.1",
      "pali": "Chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti"
    },
    {
      "id": "an3.158:1.2",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "an3.158:1.3",
      "pali": "cittasamādhi …pe…"
    },
    {
      "id": "an3.158:1.4",
      "pali": "vīmaṁsāsamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti …pe…."
    },
    {
      "id": "an3.159:1.1",
      "pali": "Saddhindriyaṁ bhāveti …"
    },
    {
      "id": "an3.159:1.2",
      "pali": "vīriyindriyaṁ bhāveti …"
    },
    {
      "id": "an3.159:1.3",
      "pali": "satindriyaṁ bhāveti …"
    },
    {
      "id": "an3.159:1.4",
      "pali": "samādhindriyaṁ bhāveti …"
    },
    {
      "id": "an3.159:1.5",
      "pali": "paññindriyaṁ bhāveti …pe…."
    },
    {
      "id": "an3.160:1.1",
      "pali": "Saddhābalaṁ bhāveti …"
    },
    {
      "id": "an3.160:1.2",
      "pali": "vīriyabalaṁ bhāveti …"
    },
    {
      "id": "an3.160:1.3",
      "pali": "satibalaṁ bhāveti …"
    },
    {
      "id": "an3.160:1.4",
      "pali": "samādhibalaṁ bhāveti …"
    },
    {
      "id": "an3.160:1.5",
      "pali": "paññābalaṁ bhāveti …pe…."
    },
    {
      "id": "an3.161:1.1",
      "pali": "Satisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.2",
      "pali": "dhammavicayasambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.3",
      "pali": "vīriyasambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.4",
      "pali": "pītisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.5",
      "pali": "passaddhisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.6",
      "pali": "samādhisambojjhaṅgaṁ bhāveti …"
    },
    {
      "id": "an3.161:1.7",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti …pe…."
    },
    {
      "id": "an3.162:1.1",
      "pali": "Sammādiṭṭhiṁ bhāveti …"
    },
    {
      "id": "an3.162:1.2",
      "pali": "sammāsaṅkappaṁ bhāveti …"
    },
    {
      "id": "an3.162:1.3",
      "pali": "sammāvācaṁ bhāveti …"
    },
    {
      "id": "an3.162:1.4",
      "pali": "sammākammantaṁ bhāveti …"
    },
    {
      "id": "an3.162:1.5",
      "pali": "sammāājīvaṁ bhāveti …"
    },
    {
      "id": "an3.162:1.6",
      "pali": "sammāvāyāmaṁ bhāveti …"
    },
    {
      "id": "an3.162:1.7",
      "pali": "sammāsatiṁ bhāveti …"
    },
    {
      "id": "an3.162:1.8",
      "pali": "sammāsamādhiṁ bhāveti …."
    },
    {
      "id": "an3.162:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, majjhimā paṭipadā."
    },
    {
      "id": "an3.162:1.10",
      "pali": "Imā kho, bhikkhave, tisso paṭipadā”ti."
    },
    {
      "id": "an3.162:1.11",
      "pali": "Acelakavaggo chaṭṭho."
    },
    {
      "id": "an3.162:2.1",
      "pali": "Satipaṭṭhānaṁ sammappadhānaṁ,"
    },
    {
      "id": "an3.162:2.2",
      "pali": "Iddhipādindriyena ca;"
    },
    {
      "id": "an3.162:2.3",
      "pali": "Balaṁ bojjhaṅgo maggo ca,"
    },
    {
      "id": "an3.162:2.4",
      "pali": "Paṭipadāya yojayeti."
    }
  ]
}
