{
  "uid": "an10.186",
  "title": "Ācayagāmisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.186:1.1",
      "pali": "“Ācayagāmiñca vo, bhikkhave, dhammaṁ desessāmi apacayagāmiñca."
    },
    {
      "id": "an10.186:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.186:1.3",
      "pali": "katamo ca, bhikkhave, ācayagāmī dhammo?"
    },
    {
      "id": "an10.186:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.186:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.186:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, ācayagāmī dhammo."
    },
    {
      "id": "an10.186:2.1",
      "pali": "Katamo ca, bhikkhave, apacayagāmī dhammo?"
    },
    {
      "id": "an10.186:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.186:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.186:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, apacayagāmī dhammo”ti."
    },
    {
      "id": "an10.186:2.5",
      "pali": "Navamaṁ."
    }
  ]
}
