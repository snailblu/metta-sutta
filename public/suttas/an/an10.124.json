{
  "uid": "an10.124",
  "title": "Dutiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.124:1.1",
      "pali": "“Dasayime, bhikkhave, dhammā anuppannā uppajjanti, nāññatra sugatavinayā."
    },
    {
      "id": "an10.124:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.124:1.3",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.124:1.4",
      "pali": "ime kho, bhikkhave, dasa dhammā anuppannā uppajjanti, nāññatra sugatavinayā”ti."
    },
    {
      "id": "an10.124:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
