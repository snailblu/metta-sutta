{
  "uid": "an4.66",
  "title": "Sarāgasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.66:1.1",
      "pali": "“Cattārome, bhikkhave, puggalā santo saṁvijjamānā lokasmiṁ."
    },
    {
      "id": "an4.66:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.66:1.3",
      "pali": "Sarāgo, sadoso, samoho, samāno—"
    },
    {
      "id": "an4.66:1.4",
      "pali": "Ime kho, bhikkhave, cattāro puggalā santo saṁvijjamānā lokasminti."
    },
    {
      "id": "an4.66:2.1",
      "pali": "Sārattā rajanīyesu,"
    },
    {
      "id": "an4.66:2.2",
      "pali": "Piyarūpābhinandino;"
    },
    {
      "id": "an4.66:2.3",
      "pali": "Mohena āvutā sattā,"
    },
    {
      "id": "an4.66:2.4",
      "pali": "Baddhā vaḍḍhenti bandhanaṁ."
    },
    {
      "id": "an4.66:3.1",
      "pali": "Rāgajaṁ dosajañcāpi,"
    },
    {
      "id": "an4.66:3.2",
      "pali": "mohajaṁ cāpaviddasū;"
    },
    {
      "id": "an4.66:3.3",
      "pali": "Karontākusalaṁ kammaṁ,"
    },
    {
      "id": "an4.66:3.4",
      "pali": "savighātaṁ dukhudrayaṁ."
    },
    {
      "id": "an4.66:4.1",
      "pali": "Avijjānivutā posā,"
    },
    {
      "id": "an4.66:4.2",
      "pali": "andhabhūtā acakkhukā;"
    },
    {
      "id": "an4.66:4.3",
      "pali": "Yathā dhammā tathā santā,"
    },
    {
      "id": "an4.66:4.4",
      "pali": "na tassevanti maññare”ti."
    },
    {
      "id": "an4.66:4.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
