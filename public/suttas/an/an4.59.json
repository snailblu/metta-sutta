{
  "uid": "an4.59",
  "title": "Bhojanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.59:1.1",
      "pali": "“Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ cattāri ṭhānāni deti."
    },
    {
      "id": "an4.59:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.59:1.3",
      "pali": "Āyuṁ deti, vaṇṇaṁ deti, sukhaṁ deti, balaṁ deti."
    },
    {
      "id": "an4.59:1.4",
      "pali": "Āyuṁ kho pana datvā āyussa bhāgī hoti dibbassa vā mānusassa vā."
    },
    {
      "id": "an4.59:1.5",
      "pali": "Vaṇṇaṁ datvā … sukhaṁ datvā … balaṁ datvā balassa bhāgī hoti dibbassa vā mānusassa vā."
    },
    {
      "id": "an4.59:1.6",
      "pali": "Bhojanaṁ, bhikkhave, dadamāno dāyako paṭiggāhakānaṁ imāni cattāri ṭhānāni detīti."
    },
    {
      "id": "an4.59:2.1",
      "pali": "Yo saññatānaṁ paradattabhojinaṁ,"
    },
    {
      "id": "an4.59:2.2",
      "pali": "Kālena sakkacca dadāti bhojanaṁ;"
    },
    {
      "id": "an4.59:2.3",
      "pali": "Cattāri ṭhānāni anuppavecchati,"
    },
    {
      "id": "an4.59:2.4",
      "pali": "Āyuñca vaṇṇañca sukhaṁ balañca."
    },
    {
      "id": "an4.59:3.1",
      "pali": "So āyudāyī vaṇṇadāyī,"
    },
    {
      "id": "an4.59:3.2",
      "pali": "sukhaṁ balaṁ dado naro;"
    },
    {
      "id": "an4.59:3.3",
      "pali": "Dīghāyu yasavā hoti,"
    },
    {
      "id": "an4.59:3.4",
      "pali": "yattha yatthūpapajjatī”ti."
    },
    {
      "id": "an4.59:3.5",
      "pali": "Navamaṁ."
    }
  ]
}
