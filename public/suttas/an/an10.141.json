{
  "uid": "an10.141",
  "title": "Tapanīyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.141:1.1",
      "pali": "“Tapanīyañca vo, bhikkhave, dhammaṁ desessāmi atapanīyañca."
    },
    {
      "id": "an10.141:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.141:1.3",
      "pali": "katamo ca, bhikkhave, tapanīyo dhammo?"
    },
    {
      "id": "an10.141:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.141:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, tapanīyo dhammo."
    },
    {
      "id": "an10.141:1.6",
      "pali": "Katamo ca, bhikkhave, atapanīyo dhammo?"
    },
    {
      "id": "an10.141:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.141:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, atapanīyo dhammo”ti."
    },
    {
      "id": "an10.141:1.9",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
