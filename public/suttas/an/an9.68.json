{
  "uid": "an9.68",
  "title": "Gatisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.68:1.1",
      "pali": "“Pañcimā, bhikkhave, gatiyo."
    },
    {
      "id": "an9.68:1.2",
      "pali": "Katamā pañca?"
    },
    {
      "id": "an9.68:1.3",
      "pali": "Nirayo, tiracchānayoni, pettivisayo, manussā, devā—"
    },
    {
      "id": "an9.68:1.4",
      "pali": "imā kho, bhikkhave, pañca gatiyo."
    },
    {
      "id": "an9.68:2.1",
      "pali": "Imāsaṁ kho, bhikkhave, pañcannaṁ gatīnaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.68:2.2",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
