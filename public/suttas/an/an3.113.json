{
  "uid": "an3.113",
  "title": "Āpāyikasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.113:1.1",
      "pali": "“Tayome, bhikkhave, āpāyikā nerayikā idamappahāya."
    },
    {
      "id": "an3.113:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "an3.113:1.3",
      "pali": "Yo ca abrahmacārī brahmacāripaṭiñño,"
    },
    {
      "id": "an3.113:1.4",
      "pali": "yo ca suddhaṁ brahmacariyaṁ carantaṁ amūlakena abrahmacariyena anuddhaṁseti,"
    },
    {
      "id": "an3.113:1.5",
      "pali": "yo cāyaṁ evaṁvādī evaṁdiṭṭhi: ‘natthi kāmesu doso’ti, so tāya kāmesu pātabyataṁ āpajjati."
    },
    {
      "id": "an3.113:1.6",
      "pali": "Ime kho, bhikkhave, tayo āpāyikā nerayikā idamappahāyā”ti."
    },
    {
      "id": "an3.113:1.7",
      "pali": "Paṭhamaṁ."
    }
  ]
}
