{
  "uid": "an10.39",
  "title": "Paṭhamaānandasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.39:1.1",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā ānando bhagavantaṁ etadavoca:"
    },
    {
      "id": "an10.39:1.2",
      "pali": "“‘saṅghabhedo saṅghabhedo’ti, bhante, vuccati."
    },
    {
      "id": "an10.39:1.3",
      "pali": "Kittāvatā nu kho, bhante, saṅgho bhinno hotī”ti?"
    },
    {
      "id": "an10.39:1.4",
      "pali": "“Idhānanda, bhikkhū adhammaṁ dhammoti dīpenti, dhammaṁ adhammoti dīpenti, avinayaṁ vinayoti dīpenti …pe…"
    },
    {
      "id": "an10.39:1.5",
      "pali": "paññattaṁ tathāgatena apaññattaṁ tathāgatenāti dīpenti."
    },
    {
      "id": "an10.39:1.6",
      "pali": "Te imehi dasahi vatthūhi avakassanti apakassanti āveni kammāni karonti āveni pātimokkhaṁ uddisanti."
    },
    {
      "id": "an10.39:1.7",
      "pali": "Ettāvatā kho, ānanda, saṅgho bhinno hotī”ti."
    },
    {
      "id": "an10.39:2.1",
      "pali": "“Samaggaṁ pana, bhante, saṅghaṁ bhinditvā kiṁ so pasavatī”ti?"
    },
    {
      "id": "an10.39:2.2",
      "pali": "“Kappaṭṭhikaṁ, ānanda, kibbisaṁ pasavatī”ti."
    },
    {
      "id": "an10.39:2.3",
      "pali": "“Kiṁ pana, bhante, kappaṭṭhikaṁ kibbisan”ti?"
    },
    {
      "id": "an10.39:2.4",
      "pali": "“Kappaṁ, ānanda, nirayamhi paccatīti—"
    },
    {
      "id": "an10.39:3.1",
      "pali": "Āpāyiko nerayiko,"
    },
    {
      "id": "an10.39:3.2",
      "pali": "Kappaṭṭho saṅghabhedako;"
    },
    {
      "id": "an10.39:3.3",
      "pali": "Vaggarato adhammaṭṭho,"
    },
    {
      "id": "an10.39:3.4",
      "pali": "Yogakkhemā padhaṁsati;"
    },
    {
      "id": "an10.39:3.5",
      "pali": "Saṅghaṁ samaggaṁ bhinditvā,"
    },
    {
      "id": "an10.39:3.6",
      "pali": "Kappaṁ nirayamhi paccatī”ti."
    },
    {
      "id": "an10.39:3.7",
      "pali": "Navamaṁ."
    }
  ]
}
