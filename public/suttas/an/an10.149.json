{
  "uid": "an10.149",
  "title": "Uppādetabbasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.149:1.1",
      "pali": "“Uppādetabbañca vo, bhikkhave, dhammaṁ desessāmi na uppādetabbañca."
    },
    {
      "id": "an10.149:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.149:1.3",
      "pali": "katamo ca, bhikkhave, na uppādetabbo dhammo?"
    },
    {
      "id": "an10.149:1.4",
      "pali": "Micchādiṭṭhi …pe… micchāvimutti—"
    },
    {
      "id": "an10.149:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, na uppādetabbo dhammo."
    },
    {
      "id": "an10.149:1.6",
      "pali": "Katamo ca, bhikkhave, uppādetabbo dhammo?"
    },
    {
      "id": "an10.149:1.7",
      "pali": "Sammādiṭṭhi …pe… sammāvimutti—"
    },
    {
      "id": "an10.149:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, uppādetabbo dhammo”ti."
    },
    {
      "id": "an10.149:1.9",
      "pali": "Pañcamaṁ."
    }
  ]
}
