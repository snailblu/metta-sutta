{
  "uid": "an10.122",
  "title": "Āsavakkhayasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.122:1.1",
      "pali": "“Dasayime, bhikkhave, dhammā bhāvitā bahulīkatā āsavānaṁ khayāya saṁvattanti."
    },
    {
      "id": "an10.122:1.2",
      "pali": "Katame dasa?"
    },
    {
      "id": "an10.122:1.3",
      "pali": "Sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi, sammāñāṇaṁ, sammāvimutti—"
    },
    {
      "id": "an10.122:1.4",
      "pali": "ime kho, bhikkhave, dasa dhammā bhāvitā bahulīkatā āsavānaṁ khayāya saṁvattantī”ti."
    },
    {
      "id": "an10.122:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an10.122:1.6",
      "pali": "Paccorohaṇivaggo dutiyo."
    },
    {
      "id": "an10.122:2.1",
      "pali": "Tayo adhammā ajito,"
    },
    {
      "id": "an10.122:2.2",
      "pali": "Saṅgāravo ca orimaṁ;"
    },
    {
      "id": "an10.122:2.3",
      "pali": "Dve ceva paccorohaṇī,"
    },
    {
      "id": "an10.122:2.4",
      "pali": "Pubbaṅgamaṁ āsavakkhayoti."
    }
  ]
}
