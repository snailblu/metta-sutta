{
  "uid": "an5.1",
  "title": "Saṅkhittasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "an5.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an5.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "an5.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "an5.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "an5.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "an5.1:2.1",
      "pali": "“Pañcimāni, bhikkhave, sekhabalāni."
    },
    {
      "id": "an5.1:2.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an5.1:2.3",
      "pali": "Saddhābalaṁ, hirībalaṁ, ottappabalaṁ, vīriyabalaṁ, paññābalaṁ—"
    },
    {
      "id": "an5.1:2.4",
      "pali": "imāni kho, bhikkhave, pañca sekhabalāni."
    },
    {
      "id": "an5.1:3.1",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "an5.1:3.2",
      "pali": "‘saddhābalena samannāgatā bhavissāma sekhabalena, hirībalena samannāgatā bhavissāma sekhabalena, ottappabalena samannāgatā bhavissāma sekhabalena, vīriyabalena samannāgatā bhavissāma sekhabalena, paññābalena samannāgatā bhavissāma sekhabalenā’ti."
    },
    {
      "id": "an5.1:3.3",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "an5.1:3.4",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "an5.1:3.5",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "an5.1:3.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
