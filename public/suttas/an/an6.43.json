{
  "uid": "an6.43",
  "title": "Nāgasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.43:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an6.43:1.2",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiyaṁ piṇḍāya pāvisi."
    },
    {
      "id": "an6.43:1.3",
      "pali": "Sāvatthiyaṁ piṇḍāya caritvā pacchābhattaṁ piṇḍapātapaṭikkanto āyasmantaṁ ānandaṁ āmantesi:"
    },
    {
      "id": "an6.43:1.4",
      "pali": "“āyāmānanda, yena pubbārāmo migāramātupāsādo tenupasaṅkamissāma divāvihārāyā”ti."
    },
    {
      "id": "an6.43:1.5",
      "pali": "“Evaṁ, bhante”ti kho āyasmā ānando bhagavato paccassosi."
    },
    {
      "id": "an6.43:2.1",
      "pali": "Atha kho bhagavā āyasmatā ānandena saddhiṁ yena pubbārāmo migāramātupāsādo tenupasaṅkami."
    },
    {
      "id": "an6.43:2.2",
      "pali": "Atha kho bhagavā sāyanhasamayaṁ paṭisallānā vuṭṭhito āyasmantaṁ ānandaṁ āmantesi:"
    },
    {
      "id": "an6.43:2.3",
      "pali": "“āyāmānanda, yena pubbakoṭṭhako tenupasaṅkamissāma gattāni parisiñcitun”ti."
    },
    {
      "id": "an6.43:2.4",
      "pali": "“Evaṁ, bhante”ti kho āyasmā ānando bhagavato paccassosi."
    },
    {
      "id": "an6.43:2.5",
      "pali": "Atha kho bhagavā āyasmatā ānandena saddhiṁ yena pubbakoṭṭhako tenupasaṅkami gattāni parisiñcituṁ."
    },
    {
      "id": "an6.43:2.6",
      "pali": "Pubbakoṭṭhake gattāni parisiñcitvā paccuttaritvā ekacīvaro aṭṭhāsi gattāni pubbāpayamāno."
    },
    {
      "id": "an6.43:3.1",
      "pali": "Tena kho pana samayena rañño pasenadissa kosalassa seto nāma nāgo mahātūriyatāḷitavāditena pubbakoṭṭhakā paccuttarati."
    },
    {
      "id": "an6.43:3.2",
      "pali": "Apissu taṁ jano disvā evamāha:"
    },
    {
      "id": "an6.43:3.3",
      "pali": "“abhirūpo vata bho rañño nāgo; dassanīyo vata bho rañño nāgo; pāsādiko vata, bho, rañño nāgo, kāyupapanno vata bho rañño nāgo”ti."
    },
    {
      "id": "an6.43:3.4",
      "pali": "Evaṁ vutte, āyasmā udāyī bhagavantaṁ etadavoca:"
    },
    {
      "id": "an6.43:3.5",
      "pali": "“hatthimeva nu kho, bhante, mahantaṁ brahantaṁ kāyupapannaṁ jano disvā evamāha:"
    },
    {
      "id": "an6.43:3.6",
      "pali": "‘nāgo vata bho nāgo’ti, udāhu aññampi kañci mahantaṁ brahantaṁ kāyupapannaṁ jano disvā evamāha: ‘nāgo vata bho nāgo’”ti?"
    },
    {
      "id": "an6.43:3.7",
      "pali": "“Hatthimpi kho, udāyi, mahantaṁ brahantaṁ kāyupapannaṁ jano disvā evamāha:"
    },
    {
      "id": "an6.43:3.8",
      "pali": "‘nāgo vata bho nāgo’ti."
    },
    {
      "id": "an6.43:3.9",
      "pali": "Assampi kho, udāyi, mahantaṁ brahantaṁ …pe…"
    },
    {
      "id": "an6.43:3.10",
      "pali": "goṇampi kho, udāyi, mahantaṁ brahantaṁ …pe…"
    },
    {
      "id": "an6.43:3.11",
      "pali": "uragampi kho, udāyi, mahantaṁ brahantaṁ …pe…"
    },
    {
      "id": "an6.43:3.12",
      "pali": "rukkhampi kho, udāyi, mahantaṁ brahantaṁ …pe…"
    },
    {
      "id": "an6.43:3.13",
      "pali": "manussampi kho, udāyi, mahantaṁ brahantaṁ kāyupapannaṁ jano disvā evamāha:"
    },
    {
      "id": "an6.43:3.14",
      "pali": "‘nāgo vata, bho, nāgo’ti."
    },
    {
      "id": "an6.43:3.15",
      "pali": "Api ca, udāyi, yo sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya āguṁ na karoti kāyena vācāya manasā, tamahaṁ ‘nāgo’ti brūmī”ti."
    },
    {
      "id": "an6.43:4.1",
      "pali": "“Acchariyaṁ, bhante, abbhutaṁ, bhante."
    },
    {
      "id": "an6.43:4.2",
      "pali": "Yāva subhāsitañcidaṁ, bhante, bhagavatā—"
    },
    {
      "id": "an6.43:4.3",
      "pali": "api ca, udāyi, yo sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya āguṁ na karoti kāyena vācāya manasā, tamahaṁ ‘nāgo’ti brūmīti."
    },
    {
      "id": "an6.43:4.4",
      "pali": "Idañca panāhaṁ, bhante, bhagavatā subhāsitaṁ imāhi gāthāhi anumodāmi—"
    },
    {
      "id": "an6.43:5.1",
      "pali": "Manussabhūtaṁ sambuddhaṁ,"
    },
    {
      "id": "an6.43:5.2",
      "pali": "attadantaṁ samāhitaṁ;"
    },
    {
      "id": "an6.43:5.3",
      "pali": "Iriyamānaṁ brahmapathe,"
    },
    {
      "id": "an6.43:5.4",
      "pali": "cittassūpasame rataṁ."
    },
    {
      "id": "an6.43:6.1",
      "pali": "Yaṁ manussā namassanti,"
    },
    {
      "id": "an6.43:6.2",
      "pali": "sabbadhammāna pāraguṁ;"
    },
    {
      "id": "an6.43:6.3",
      "pali": "Devāpi taṁ namassanti,"
    },
    {
      "id": "an6.43:6.4",
      "pali": "iti me arahato sutaṁ."
    },
    {
      "id": "an6.43:7.1",
      "pali": "Sabbasaṁyojanātītaṁ,"
    },
    {
      "id": "an6.43:7.2",
      "pali": "vanā nibbanamāgataṁ;"
    },
    {
      "id": "an6.43:7.3",
      "pali": "Kāmehi nekkhammarataṁ,"
    },
    {
      "id": "an6.43:7.4",
      "pali": "muttaṁ selāva kañcanaṁ."
    },
    {
      "id": "an6.43:8.1",
      "pali": "Sabbe accarucī nāgo,"
    },
    {
      "id": "an6.43:8.2",
      "pali": "himavāññe siluccaye;"
    },
    {
      "id": "an6.43:8.3",
      "pali": "Sabbesaṁ nāganāmānaṁ,"
    },
    {
      "id": "an6.43:8.4",
      "pali": "saccanāmo anuttaro."
    },
    {
      "id": "an6.43:9.1",
      "pali": "Nāgaṁ vo kittayissāmi,"
    },
    {
      "id": "an6.43:9.2",
      "pali": "na hi āguṁ karoti so;"
    },
    {
      "id": "an6.43:9.3",
      "pali": "Soraccaṁ avihiṁsā ca,"
    },
    {
      "id": "an6.43:9.4",
      "pali": "pādā nāgassa te duve."
    },
    {
      "id": "an6.43:10.1",
      "pali": "Tapo ca brahmacariyaṁ,"
    },
    {
      "id": "an6.43:10.2",
      "pali": "caraṇā nāgassa tyāpare;"
    },
    {
      "id": "an6.43:10.3",
      "pali": "Saddhāhattho mahānāgo,"
    },
    {
      "id": "an6.43:10.4",
      "pali": "upekkhāsetadantavā."
    },
    {
      "id": "an6.43:11.1",
      "pali": "Sati gīvā siro paññā,"
    },
    {
      "id": "an6.43:11.2",
      "pali": "vīmaṁsā dhammacintanā;"
    },
    {
      "id": "an6.43:11.3",
      "pali": "Dhammakucchisamātapo,"
    },
    {
      "id": "an6.43:11.4",
      "pali": "viveko tassa vāladhi."
    },
    {
      "id": "an6.43:12.1",
      "pali": "So jhāyī assāsarato,"
    },
    {
      "id": "an6.43:12.2",
      "pali": "ajjhattaṁ susamāhito;"
    },
    {
      "id": "an6.43:12.3",
      "pali": "Gacchaṁ samāhito nāgo,"
    },
    {
      "id": "an6.43:12.4",
      "pali": "ṭhito nāgo samāhito."
    },
    {
      "id": "an6.43:13.1",
      "pali": "Seyyaṁ samāhito nāgo,"
    },
    {
      "id": "an6.43:13.2",
      "pali": "nisinnopi samāhito;"
    },
    {
      "id": "an6.43:13.3",
      "pali": "Sabbattha saṁvuto nāgo,"
    },
    {
      "id": "an6.43:13.4",
      "pali": "esā nāgassa sampadā."
    },
    {
      "id": "an6.43:14.1",
      "pali": "Bhuñjati anavajjāni,"
    },
    {
      "id": "an6.43:14.2",
      "pali": "sāvajjāni na bhuñjati;"
    },
    {
      "id": "an6.43:14.3",
      "pali": "Ghāsamacchādanaṁ laddhā,"
    },
    {
      "id": "an6.43:14.4",
      "pali": "sannidhiṁ parivajjayaṁ."
    },
    {
      "id": "an6.43:15.1",
      "pali": "Saṁyojanaṁ aṇuṁ thūlaṁ,"
    },
    {
      "id": "an6.43:15.2",
      "pali": "sabbaṁ chetvāna bandhanaṁ;"
    },
    {
      "id": "an6.43:15.3",
      "pali": "Yena yeneva gacchati,"
    },
    {
      "id": "an6.43:15.4",
      "pali": "anapekkhova gacchati."
    },
    {
      "id": "an6.43:16.1",
      "pali": "Yathāpi udake jātaṁ,"
    },
    {
      "id": "an6.43:16.2",
      "pali": "puṇḍarīkaṁ pavaḍḍhati;"
    },
    {
      "id": "an6.43:16.3",
      "pali": "Nupalippati toyena,"
    },
    {
      "id": "an6.43:16.4",
      "pali": "sucigandhaṁ manoramaṁ."
    },
    {
      "id": "an6.43:17.1",
      "pali": "Tatheva loke sujāto,"
    },
    {
      "id": "an6.43:17.2",
      "pali": "buddho loke viharati;"
    },
    {
      "id": "an6.43:17.3",
      "pali": "Nupalippati lokena,"
    },
    {
      "id": "an6.43:17.4",
      "pali": "toyena padumaṁ yathā."
    },
    {
      "id": "an6.43:18.1",
      "pali": "Mahāginīva jalito,"
    },
    {
      "id": "an6.43:18.2",
      "pali": "anāhārūpasammati;"
    },
    {
      "id": "an6.43:18.3",
      "pali": "Saṅkhāresūpasantesu,"
    },
    {
      "id": "an6.43:18.4",
      "pali": "nibbutoti pavuccati."
    },
    {
      "id": "an6.43:19.1",
      "pali": "Atthassāyaṁ viññāpanī,"
    },
    {
      "id": "an6.43:19.2",
      "pali": "upamā viññūhi desitā;"
    },
    {
      "id": "an6.43:19.3",
      "pali": "Viññassanti mahānāgā,"
    },
    {
      "id": "an6.43:19.4",
      "pali": "nāgaṁ nāgena desitaṁ."
    },
    {
      "id": "an6.43:20.1",
      "pali": "Vītarāgo vītadoso,"
    },
    {
      "id": "an6.43:20.2",
      "pali": "Vītamoho anāsavo;"
    },
    {
      "id": "an6.43:20.3",
      "pali": "Sarīraṁ vijahaṁ nāgo,"
    },
    {
      "id": "an6.43:20.4",
      "pali": "Parinibbissati anāsavo”ti."
    },
    {
      "id": "an6.43:20.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
