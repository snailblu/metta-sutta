{
  "uid": "an5.230",
  "title": "Dutiyakaṇhasappasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.230:1.1",
      "pali": "“Pañcime, bhikkhave, ādīnavā kaṇhasappe."
    },
    {
      "id": "an5.230:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.230:1.3",
      "pali": "Kodhano, upanāhī, ghoraviso, dujjivho, mittadubbhī."
    },
    {
      "id": "an5.230:1.4",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā kaṇhasappe."
    },
    {
      "id": "an5.230:2.1",
      "pali": "Evamevaṁ kho, bhikkhave, pañcime ādīnavā mātugāme."
    },
    {
      "id": "an5.230:2.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.230:2.3",
      "pali": "Kodhano, upanāhī, ghoraviso, dujjivho, mittadubbhī."
    },
    {
      "id": "an5.230:2.4",
      "pali": "Tatridaṁ, bhikkhave, mātugāmassa ghoravisatā—"
    },
    {
      "id": "an5.230:2.5",
      "pali": "yebhuyyena, bhikkhave, mātugāmo tibbarāgo."
    },
    {
      "id": "an5.230:2.6",
      "pali": "Tatridaṁ, bhikkhave, mātugāmassa dujjivhatā—"
    },
    {
      "id": "an5.230:2.7",
      "pali": "yebhuyyena, bhikkhave, mātugāmo pisuṇavāco."
    },
    {
      "id": "an5.230:2.8",
      "pali": "Tatridaṁ, bhikkhave, mātugāmassa mittadubbhitā—"
    },
    {
      "id": "an5.230:2.9",
      "pali": "yebhuyyena, bhikkhave, mātugāmo aticārinī."
    },
    {
      "id": "an5.230:2.10",
      "pali": "Ime kho, bhikkhave, pañca ādīnavā mātugāme”ti."
    },
    {
      "id": "an5.230:2.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an5.230:2.12",
      "pali": "Dīghacārikavaggo tatiyo."
    },
    {
      "id": "an5.230:3.1",
      "pali": "Dve dīghacārikā vuttā,"
    },
    {
      "id": "an5.230:3.2",
      "pali": "atinivāsamaccharī;"
    },
    {
      "id": "an5.230:3.3",
      "pali": "Dve ca kulūpakā bhogā,"
    },
    {
      "id": "an5.230:3.4",
      "pali": "bhattaṁ sappāpare duveti."
    }
  ]
}
