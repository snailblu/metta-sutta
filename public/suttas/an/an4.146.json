{
  "uid": "an4.146",
  "title": "Paṭhamakālasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.146:1.1",
      "pali": "“Cattārome, bhikkhave, kālā."
    },
    {
      "id": "an4.146:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.146:1.3",
      "pali": "Kālena dhammassavanaṁ, kālena dhammasākacchā, kālena sammasanā, kālena vipassanā—"
    },
    {
      "id": "an4.146:1.4",
      "pali": "Ime kho, bhikkhave, cattāro kālā”ti."
    },
    {
      "id": "an4.146:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
