{
  "uid": "an10.79",
  "title": "Āghātavatthusutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.79:1.1",
      "pali": "“Dasayimāni, bhikkhave, āghātavatthūni."
    },
    {
      "id": "an10.79:1.2",
      "pali": "Katamāni dasa?"
    },
    {
      "id": "an10.79:1.3",
      "pali": "‘Anatthaṁ me acarī’ti āghātaṁ bandhati;"
    },
    {
      "id": "an10.79:1.4",
      "pali": "‘anatthaṁ me caratī’ti āghātaṁ bandhati;"
    },
    {
      "id": "an10.79:1.5",
      "pali": "‘anatthaṁ me carissatī’ti āghātaṁ bandhati;"
    },
    {
      "id": "an10.79:1.6",
      "pali": "‘piyassa me manāpassa anatthaṁ acarī’ti …pe…"
    },
    {
      "id": "an10.79:1.7",
      "pali": "‘anatthaṁ caratī’ti …pe…"
    },
    {
      "id": "an10.79:1.8",
      "pali": "‘anatthaṁ carissatī’ti āghātaṁ bandhati,"
    },
    {
      "id": "an10.79:1.9",
      "pali": "‘appiyassa me amanāpassa atthaṁ acarī’ti …pe…"
    },
    {
      "id": "an10.79:1.10",
      "pali": "‘atthaṁ caratī’ti …pe…"
    },
    {
      "id": "an10.79:1.11",
      "pali": "‘atthaṁ carissatī’ti āghātaṁ bandhati;"
    },
    {
      "id": "an10.79:1.12",
      "pali": "aṭṭhāne ca kuppati—"
    },
    {
      "id": "an10.79:1.13",
      "pali": "imāni kho, bhikkhave, dasa āghātavatthūnī”ti."
    },
    {
      "id": "an10.79:1.14",
      "pali": "Navamaṁ."
    }
  ]
}
