{
  "uid": "an5.182",
  "title": "Cīvarasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.182:1.1",
      "pali": "“Pañcime, bhikkhave, paṁsukūlikā."
    },
    {
      "id": "an5.182:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.182:1.3",
      "pali": "Mandattā momūhattā paṁsukūliko hoti …pe… idamatthitaṁyeva nissāya paṁsukūliko hoti."
    },
    {
      "id": "an5.182:1.4",
      "pali": "Ime kho, bhikkhave, pañca paṁsukūlikā”ti."
    },
    {
      "id": "an5.182:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
