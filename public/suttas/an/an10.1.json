{
  "uid": "an10.1",
  "title": "Kimatthiyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "an10.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "an10.1:1.3",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā ānando bhagavantaṁ etadavoca:"
    },
    {
      "id": "an10.1:2.1",
      "pali": "“Kimatthiyāni, bhante, kusalāni sīlāni kimānisaṁsānī”ti?"
    },
    {
      "id": "an10.1:2.2",
      "pali": "“Avippaṭisāratthāni kho, ānanda, kusalāni sīlāni avippaṭisārānisaṁsānī”ti."
    },
    {
      "id": "an10.1:3.1",
      "pali": "“Avippaṭisāro pana, bhante, kimatthiyo kimānisaṁso”ti?"
    },
    {
      "id": "an10.1:3.2",
      "pali": "“Avippaṭisāro kho, ānanda, pāmojjattho pāmojjānisaṁso”ti."
    },
    {
      "id": "an10.1:4.1",
      "pali": "“Pāmojjaṁ pana, bhante, kimatthiyaṁ kimānisaṁsan”ti?"
    },
    {
      "id": "an10.1:4.2",
      "pali": "“Pāmojjaṁ kho, ānanda, pītatthaṁ pītānisaṁsan”ti."
    },
    {
      "id": "an10.1:5.1",
      "pali": "“Pīti pana, bhante, kimatthiyā kimānisaṁsā”ti?"
    },
    {
      "id": "an10.1:5.2",
      "pali": "“Pīti kho, ānanda, passaddhatthā passaddhānisaṁsā”ti."
    },
    {
      "id": "an10.1:6.1",
      "pali": "“Passaddhi pana, bhante, kimatthiyā kimānisaṁsā”ti?"
    },
    {
      "id": "an10.1:6.2",
      "pali": "“Passaddhi kho, ānanda, sukhatthā sukhānisaṁsā”ti."
    },
    {
      "id": "an10.1:7.1",
      "pali": "“Sukhaṁ pana, bhante, kimatthiyaṁ kimānisaṁsan”ti?"
    },
    {
      "id": "an10.1:7.2",
      "pali": "“Sukhaṁ kho, ānanda, samādhatthaṁ samādhānisaṁsan”ti."
    },
    {
      "id": "an10.1:8.1",
      "pali": "“Samādhi pana, bhante, kimatthiyo kimānisaṁso”ti?"
    },
    {
      "id": "an10.1:8.2",
      "pali": "“Samādhi kho, ānanda, yathābhūtañāṇadassanattho yathābhūtañāṇadassanānisaṁso”ti."
    },
    {
      "id": "an10.1:9.1",
      "pali": "“Yathābhūtañāṇadassanaṁ pana, bhante, kimatthiyaṁ kimānisaṁsan”ti?"
    },
    {
      "id": "an10.1:9.2",
      "pali": "“Yathābhūtañāṇadassanaṁ kho, ānanda, nibbidāvirāgatthaṁ nibbidāvirāgānisaṁsan”ti."
    },
    {
      "id": "an10.1:10.1",
      "pali": "“Nibbidāvirāgo pana, bhante, kimatthiyo kimānisaṁso”ti?"
    },
    {
      "id": "an10.1:10.2",
      "pali": "“Nibbidāvirāgo kho, ānanda, vimuttiñāṇadassanattho vimuttiñāṇadassanānisaṁso."
    },
    {
      "id": "an10.1:11.1",
      "pali": "Iti kho, ānanda, kusalāni sīlāni avippaṭisāratthāni avippaṭisārānisaṁsāni;"
    },
    {
      "id": "an10.1:11.2",
      "pali": "avippaṭisāro pāmojjattho pāmojjānisaṁso;"
    },
    {
      "id": "an10.1:11.3",
      "pali": "pāmojjaṁ pītatthaṁ pītānisaṁsaṁ;"
    },
    {
      "id": "an10.1:11.4",
      "pali": "pīti passaddhatthā passaddhānisaṁsā;"
    },
    {
      "id": "an10.1:11.5",
      "pali": "passaddhi sukhatthā sukhānisaṁsā;"
    },
    {
      "id": "an10.1:11.6",
      "pali": "sukhaṁ samādhatthaṁ samādhānisaṁsaṁ;"
    },
    {
      "id": "an10.1:11.7",
      "pali": "samādhi yathābhūtañāṇadassanattho yathābhūtañāṇadassanānisaṁso;"
    },
    {
      "id": "an10.1:11.8",
      "pali": "yathābhūtañāṇadassanaṁ nibbidāvirāgatthaṁ nibbidāvirāgānisaṁsaṁ;"
    },
    {
      "id": "an10.1:11.9",
      "pali": "nibbidāvirāgo vimuttiñāṇadassanattho vimuttiñāṇadassanānisaṁso."
    },
    {
      "id": "an10.1:11.10",
      "pali": "Iti kho, ānanda, kusalāni sīlāni anupubbena aggāya parentī”ti."
    },
    {
      "id": "an10.1:11.11",
      "pali": "Paṭhamaṁ."
    }
  ]
}
