{
  "uid": "an3.152",
  "title": "Tatiyakhatasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.152:1.1",
      "pali": "“Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.152:1.2",
      "pali": "visamena kāyakammena, visamena vacīkammena, visamena manokammena …pe…."
    },
    {
      "id": "an3.152:2.1",
      "pali": "Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.152:2.2",
      "pali": "samena kāyakammena, samena vacīkammena, samena manokammena …pe…."
    },
    {
      "id": "an3.152:2.3",
      "pali": "Sattamaṁ."
    }
  ]
}
