{
  "uid": "an7.62",
  "title": "Mettasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.62:1.1",
      "pali": "“Mā, bhikkhave, puññānaṁ bhāyittha."
    },
    {
      "id": "an7.62:1.2",
      "pali": "Sukhassetaṁ, bhikkhave, adhivacanaṁ yadidaṁ puññāni."
    },
    {
      "id": "an7.62:1.3",
      "pali": "Abhijānāmi kho panāhaṁ, bhikkhave, dīgharattaṁ katānaṁ puññānaṁ dīgharattaṁ iṭṭhaṁ kantaṁ manāpaṁ vipākaṁ paccanubhūtaṁ."
    },
    {
      "id": "an7.62:1.4",
      "pali": "Satta vassāni mettacittaṁ bhāvesiṁ."
    },
    {
      "id": "an7.62:1.5",
      "pali": "Satta vassāni mettacittaṁ bhāvetvā satta saṁvaṭṭavivaṭṭakappe nayimaṁ lokaṁ punāgamāsiṁ."
    },
    {
      "id": "an7.62:1.6",
      "pali": "Saṁvaṭṭamāne sudāhaṁ, bhikkhave, loke ābhassarūpago homi,"
    },
    {
      "id": "an7.62:1.7",
      "pali": "vivaṭṭamāne loke suññaṁ brahmavimānaṁ upapajjāmi."
    },
    {
      "id": "an7.62:2.1",
      "pali": "Tatra sudaṁ, bhikkhave, brahmā homi mahābrahmā abhibhū anabhibhūto aññadatthudaso vasavattī."
    },
    {
      "id": "an7.62:2.2",
      "pali": "Chattiṁsakkhattuṁ kho panāhaṁ, bhikkhave, sakko ahosiṁ devānamindo;"
    },
    {
      "id": "an7.62:2.3",
      "pali": "anekasatakkhattuṁ rājā ahosiṁ cakkavattī dhammiko dhammarājā cāturanto vijitāvī janapadatthāvariyappatto sattaratanasamannāgato."
    },
    {
      "id": "an7.62:2.4",
      "pali": "Tassa mayhaṁ, bhikkhave, imāni satta ratanāni ahesuṁ, seyyathidaṁ—"
    },
    {
      "id": "an7.62:2.5",
      "pali": "cakkaratanaṁ, hatthiratanaṁ, assaratanaṁ, maṇiratanaṁ, itthiratanaṁ, gahapatiratanaṁ, pariṇāyakaratanameva sattamaṁ."
    },
    {
      "id": "an7.62:2.6",
      "pali": "Parosahassaṁ kho pana me, bhikkhave, puttā ahesuṁ sūrā vīraṅgarūpā parasenappamaddanā."
    },
    {
      "id": "an7.62:2.7",
      "pali": "So imaṁ pathaviṁ sāgarapariyantaṁ adaṇḍena asatthena dhammena abhivijiya ajjhāvasinti."
    },
    {
      "id": "an7.62:3.1",
      "pali": "Passa puññānaṁ vipākaṁ,"
    },
    {
      "id": "an7.62:3.2",
      "pali": "Kusalānaṁ sukhesino;"
    },
    {
      "id": "an7.62:3.3",
      "pali": "Mettaṁ cittaṁ vibhāvetvā,"
    },
    {
      "id": "an7.62:3.4",
      "pali": "Satta vassāni bhikkhavo;"
    },
    {
      "id": "an7.62:3.5",
      "pali": "Sattasaṁvaṭṭavivaṭṭakappe,"
    },
    {
      "id": "an7.62:3.6",
      "pali": "Nayimaṁ lokaṁ punāgamiṁ."
    },
    {
      "id": "an7.62:4.1",
      "pali": "Saṁvaṭṭamāne lokamhi,"
    },
    {
      "id": "an7.62:4.2",
      "pali": "homi ābhassarūpago;"
    },
    {
      "id": "an7.62:4.3",
      "pali": "Vivaṭṭamāne lokasmiṁ,"
    },
    {
      "id": "an7.62:4.4",
      "pali": "suññabrahmūpago ahuṁ."
    },
    {
      "id": "an7.62:5.1",
      "pali": "Sattakkhattuṁ mahābrahmā,"
    },
    {
      "id": "an7.62:5.2",
      "pali": "vasavattī tadā ahuṁ;"
    },
    {
      "id": "an7.62:5.3",
      "pali": "Chattiṁsakkhattuṁ devindo,"
    },
    {
      "id": "an7.62:5.4",
      "pali": "devarajjamakārayiṁ."
    },
    {
      "id": "an7.62:6.1",
      "pali": "Cakkavattī ahuṁ rājā,"
    },
    {
      "id": "an7.62:6.2",
      "pali": "jambumaṇḍassa issaro;"
    },
    {
      "id": "an7.62:6.3",
      "pali": "Muddhāvasitto khattiyo,"
    },
    {
      "id": "an7.62:6.4",
      "pali": "manussādhipatī ahuṁ."
    },
    {
      "id": "an7.62:7.1",
      "pali": "Adaṇḍena asatthena,"
    },
    {
      "id": "an7.62:7.2",
      "pali": "vijeyya pathaviṁ imaṁ;"
    },
    {
      "id": "an7.62:7.3",
      "pali": "Asāhasena kammena,"
    },
    {
      "id": "an7.62:7.4",
      "pali": "samena manusāsi taṁ."
    },
    {
      "id": "an7.62:8.1",
      "pali": "Dhammena rajjaṁ kāretvā,"
    },
    {
      "id": "an7.62:8.2",
      "pali": "asmiṁ pathavimaṇḍale;"
    },
    {
      "id": "an7.62:8.3",
      "pali": "Mahaddhane mahābhoge,"
    },
    {
      "id": "an7.62:8.4",
      "pali": "aḍḍhe ajāyihaṁ kule."
    },
    {
      "id": "an7.62:9.1",
      "pali": "Sabbakāmehi sampanne,"
    },
    {
      "id": "an7.62:9.2",
      "pali": "ratanehi ca sattahi;"
    },
    {
      "id": "an7.62:9.3",
      "pali": "Buddhā saṅgāhakā loke,"
    },
    {
      "id": "an7.62:9.4",
      "pali": "tehi etaṁ sudesitaṁ."
    },
    {
      "id": "an7.62:10.1",
      "pali": "Eso hetu mahantassa,"
    },
    {
      "id": "an7.62:10.2",
      "pali": "pathabyo me na vipajjati;"
    },
    {
      "id": "an7.62:10.3",
      "pali": "Pahūtavittūpakaraṇo,"
    },
    {
      "id": "an7.62:10.4",
      "pali": "rājā hoti patāpavā."
    },
    {
      "id": "an7.62:11.1",
      "pali": "Iddhimā yasavā hoti,"
    },
    {
      "id": "an7.62:11.2",
      "pali": "jambumaṇḍassa issaro;"
    },
    {
      "id": "an7.62:11.3",
      "pali": "Ko sutvā nappasīdeyya,"
    },
    {
      "id": "an7.62:11.4",
      "pali": "api kaṇhābhijātiyo."
    },
    {
      "id": "an7.62:12.1",
      "pali": "Tasmā hi attakāmena,"
    },
    {
      "id": "an7.62:12.2",
      "pali": "mahattamabhikaṅkhatā;"
    },
    {
      "id": "an7.62:12.3",
      "pali": "Saddhammo garukātabbo,"
    },
    {
      "id": "an7.62:12.4",
      "pali": "saraṁ buddhānasāsanan”ti."
    },
    {
      "id": "an7.62:12.5",
      "pali": "Navamaṁ."
    }
  ]
}
