{
  "uid": "an8.18",
  "title": "Dutiyabandhanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.18:1.1",
      "pali": "“Aṭṭhahi, bhikkhave, ākārehi puriso itthiṁ bandhati."
    },
    {
      "id": "an8.18:1.2",
      "pali": "Katamehi aṭṭhahi?"
    },
    {
      "id": "an8.18:1.3",
      "pali": "Ruṇṇena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.4",
      "pali": "hasitena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.5",
      "pali": "bhaṇitena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.6",
      "pali": "ākappena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.7",
      "pali": "vanabhaṅgena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.8",
      "pali": "gandhena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.9",
      "pali": "rasena, bhikkhave, puriso itthiṁ bandhati;"
    },
    {
      "id": "an8.18:1.10",
      "pali": "phassena, bhikkhave, puriso itthiṁ bandhati."
    },
    {
      "id": "an8.18:1.11",
      "pali": "Imehi kho, bhikkhave, aṭṭhahākārehi puriso itthiṁ bandhati."
    },
    {
      "id": "an8.18:1.12",
      "pali": "Te, bhikkhave, sattā subaddhā, ye phassena baddhā”ti."
    },
    {
      "id": "an8.18:1.13",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
