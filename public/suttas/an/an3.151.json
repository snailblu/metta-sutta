{
  "uid": "an3.151",
  "title": "Dutiyakhatasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.151:1.1",
      "pali": "“Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.151:1.2",
      "pali": "sāvajjena kāyakammena, sāvajjena vacīkammena, sāvajjena manokammena …pe…."
    },
    {
      "id": "an3.151:2.1",
      "pali": "Tīhi, bhikkhave …pe…"
    },
    {
      "id": "an3.151:2.2",
      "pali": "anavajjena kāyakammena, anavajjena vacīkammena, anavajjena manokammena …pe…."
    },
    {
      "id": "an3.151:2.3",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
