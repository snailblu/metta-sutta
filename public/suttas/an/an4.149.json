{
  "uid": "an4.149",
  "title": "Sucaritasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.149:1.1",
      "pali": "“Cattārimāni, bhikkhave, vacīsucaritāni."
    },
    {
      "id": "an4.149:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.149:1.3",
      "pali": "Saccavācā, apisuṇā vācā, saṇhā vācā, mantabhāsā—"
    },
    {
      "id": "an4.149:1.4",
      "pali": "Imāni kho, bhikkhave, cattāri vacīsucaritānī”ti."
    },
    {
      "id": "an4.149:1.5",
      "pali": "Navamaṁ."
    }
  ]
}
