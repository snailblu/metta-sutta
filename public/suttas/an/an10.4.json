{
  "uid": "an10.4",
  "title": "Dutiyaupanisasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.4:1.1",
      "pali": "Tatra kho āyasmā sāriputto bhikkhū āmantesi …pe…"
    },
    {
      "id": "an10.4:1.2",
      "pali": "“dussīlassa, āvuso, sīlavipannassa hatūpaniso hoti avippaṭisāro;"
    },
    {
      "id": "an10.4:1.3",
      "pali": "avippaṭisāre asati avippaṭisāravipannassa hatūpanisaṁ hoti …pe…"
    },
    {
      "id": "an10.4:1.4",
      "pali": "vimuttiñāṇadassanaṁ."
    },
    {
      "id": "an10.4:1.5",
      "pali": "Seyyathāpi, āvuso, rukkho sākhāpalāsavipanno. Tassa papaṭikāpi na pāripūriṁ gacchati, tacopi … pheggupi … sāropi na pāripūriṁ gacchati."
    },
    {
      "id": "an10.4:1.6",
      "pali": "Evamevaṁ kho, āvuso, dussīlassa sīlavipannassa hatūpaniso hoti avippaṭisāro;"
    },
    {
      "id": "an10.4:1.7",
      "pali": "avippaṭisāre asati avippaṭisāravipannassa hatūpanisaṁ hoti …pe…"
    },
    {
      "id": "an10.4:1.8",
      "pali": "vimuttiñāṇadassanaṁ."
    },
    {
      "id": "an10.4:2.1",
      "pali": "Sīlavato, āvuso, sīlasampannassa upanisasampanno hoti avippaṭisāro;"
    },
    {
      "id": "an10.4:2.2",
      "pali": "avippaṭisāre sati avippaṭisārasampannassa upanisasampannaṁ hoti …pe…"
    },
    {
      "id": "an10.4:2.3",
      "pali": "vimuttiñāṇadassanaṁ."
    },
    {
      "id": "an10.4:2.4",
      "pali": "Seyyathāpi, āvuso, rukkho sākhāpalāsasampanno. Tassa papaṭikāpi pāripūriṁ gacchati, tacopi … pheggupi … sāropi pāripūriṁ gacchati."
    },
    {
      "id": "an10.4:2.5",
      "pali": "Evamevaṁ kho, āvuso, sīlavato sīlasampannassa upanisasampanno hoti avippaṭisāro;"
    },
    {
      "id": "an10.4:2.6",
      "pali": "avippaṭisāre sati avippaṭisārasampannassa upanisasampannaṁ hoti …pe…"
    },
    {
      "id": "an10.4:2.7",
      "pali": "vimuttiñāṇadassanan”ti."
    },
    {
      "id": "an10.4:2.8",
      "pali": "Catutthaṁ."
    }
  ]
}
