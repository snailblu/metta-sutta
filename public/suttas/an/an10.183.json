{
  "uid": "an10.183",
  "title": "Āsavasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.183:1.1",
      "pali": "“Sāsavañca vo, bhikkhave, dhammaṁ desessāmi anāsavañca."
    },
    {
      "id": "an10.183:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.183:1.3",
      "pali": "katamo ca, bhikkhave, sāsavo dhammo?"
    },
    {
      "id": "an10.183:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.183:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.183:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, sāsavo dhammo."
    },
    {
      "id": "an10.183:2.1",
      "pali": "Katamo ca, bhikkhave, anāsavo dhammo?"
    },
    {
      "id": "an10.183:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.183:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.183:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, anāsavo dhammo”ti."
    },
    {
      "id": "an10.183:2.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
