{
  "uid": "an5.308-1152",
  "title": "~",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.308-1152:1.1",
      "pali": "“Rāgassa, bhikkhave, pariññāya … parikkhayāya … pahānāya … khayāya … vayāya … virāgāya … nirodhāya … cāgāya … paṭinissaggāya pañca dhammā bhāvetabbā."
    },
    {
      "id": "an5.308-1152:1.2",
      "pali": "Dosassa … mohassa … kodhassa … upanāhassa … makkhassa … paḷāsassa … issāya … macchariyassa … māyāya … sāṭheyyassa … thambhassa … sārambhassa … mānassa … atimānassa … madassa … pamādassa abhiññāya … pariññāya … parikkhayāya … pahānāya … khayāya … vayāya … virāgāya … nirodhāya … cāgāya … paṭinissaggāya pañca dhammā bhāvetabbā."
    },
    {
      "id": "an5.308-1152:2.1",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.308-1152:2.2",
      "pali": "Saddhābalaṁ, vīriyabalaṁ, satibalaṁ, samādhibalaṁ, paññābalaṁ—"
    },
    {
      "id": "an5.308-1152:2.3",
      "pali": "pamādassa, bhikkhave, paṭinissaggāya ime pañca dhammā bhāvetabbā”ti."
    },
    {
      "id": "an5.308-1152:2.4",
      "pali": "Rāgapeyyālaṁ niṭṭhitaṁ."
    },
    {
      "id": "an5.308-1152:3.1",
      "pali": "Abhiññāya pariññāya parikkhayāya,"
    },
    {
      "id": "an5.308-1152:3.2",
      "pali": "Pahānāya khayāya vayena ca;"
    },
    {
      "id": "an5.308-1152:3.3",
      "pali": "Virāganirodhā cāgañca,"
    },
    {
      "id": "an5.308-1152:3.4",
      "pali": "Paṭinissaggo ime dasāti."
    },
    {
      "id": "an5.308-1152:3.5",
      "pali": "Pañcakanipāto niṭṭhito."
    },
    {
      "id": "an5.308-1152:4.1",
      "pali": "Sekhabalaṁ balañceva,"
    },
    {
      "id": "an5.308-1152:4.2",
      "pali": "Pañcaṅgikañca sumanaṁ;"
    },
    {
      "id": "an5.308-1152:4.3",
      "pali": "Muṇḍanīvaraṇañca saññañca,"
    },
    {
      "id": "an5.308-1152:4.4",
      "pali": "Yodhājīvañca aṭṭhamaṁ;"
    },
    {
      "id": "an5.308-1152:4.5",
      "pali": "Theraṁ kakudhaphāsuñca,"
    },
    {
      "id": "an5.308-1152:4.6",
      "pali": "Andhakavindadvādasaṁ;"
    },
    {
      "id": "an5.308-1152:4.7",
      "pali": "Gilānarājatikaṇḍaṁ,"
    },
    {
      "id": "an5.308-1152:4.8",
      "pali": "Saddhammāghātupāsakaṁ;"
    },
    {
      "id": "an5.308-1152:4.9",
      "pali": "Araññabrāhmaṇañceva,"
    },
    {
      "id": "an5.308-1152:4.10",
      "pali": "Kimilakkosakaṁ tathā;"
    },
    {
      "id": "an5.308-1152:4.11",
      "pali": "Dīghācārāvāsikañca,"
    },
    {
      "id": "an5.308-1152:4.12",
      "pali": "Duccaritūpasampadanti."
    },
    {
      "id": "an5.308-1152:4.13",
      "pali": "Pañcakanipātapāḷi niṭṭhitā."
    }
  ]
}
