{
  "uid": "an7.94",
  "title": "Saddhammasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an7.94:1.1",
      "pali": "“Sattime, bhikkhave, saddhammā."
    },
    {
      "id": "an7.94:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "an7.94:1.3",
      "pali": "Saddho hoti, hirīmā hoti, ottappī hoti, bahussuto hoti, āraddhavīriyo hoti, satimā hoti, paññavā hoti."
    },
    {
      "id": "an7.94:1.4",
      "pali": "Ime kho, bhikkhave, satta saddhammā”ti."
    },
    {
      "id": "an7.94:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an7.94:1.6",
      "pali": "Samaṇavaggo navamo."
    },
    {
      "id": "an7.94:2.1",
      "pali": "Bhikkhuṁ samaṇo brāhmaṇo,"
    },
    {
      "id": "an7.94:2.2",
      "pali": "sottiyo ceva nhātako;"
    },
    {
      "id": "an7.94:2.3",
      "pali": "Vedagū ariyo arahā,"
    },
    {
      "id": "an7.94:2.4",
      "pali": "asaddhammā ca saddhammāti."
    }
  ]
}
