{
  "uid": "an5.177",
  "title": "Vaṇijjāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.177:1.1",
      "pali": "“Pañcimā, bhikkhave, vaṇijjā upāsakena akaraṇīyā."
    },
    {
      "id": "an5.177:1.2",
      "pali": "Katamā pañca?"
    },
    {
      "id": "an5.177:1.3",
      "pali": "Satthavaṇijjā, sattavaṇijjā, maṁsavaṇijjā, majjavaṇijjā, visavaṇijjā—"
    },
    {
      "id": "an5.177:1.4",
      "pali": "imā kho, bhikkhave, pañca vaṇijjā upāsakena akaraṇīyā”ti."
    },
    {
      "id": "an5.177:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
