{
  "uid": "an10.213",
  "title": "Mātugāmasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.213:1.1",
      "pali": "“Dasahi, bhikkhave, dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an10.213:1.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.213:1.3",
      "pali": "Pāṇātipātī hoti …pe…"
    },
    {
      "id": "an10.213:1.4",
      "pali": "adinnādāyī hoti …"
    },
    {
      "id": "an10.213:1.5",
      "pali": "kāmesumicchācārī hoti …"
    },
    {
      "id": "an10.213:1.6",
      "pali": "musāvādī hoti …"
    },
    {
      "id": "an10.213:1.7",
      "pali": "pisuṇavāco hoti …"
    },
    {
      "id": "an10.213:1.8",
      "pali": "pharusavāco hoti …"
    },
    {
      "id": "an10.213:1.9",
      "pali": "samphappalāpī hoti …"
    },
    {
      "id": "an10.213:1.10",
      "pali": "abhijjhālu hoti …"
    },
    {
      "id": "an10.213:1.11",
      "pali": "byāpannacitto hoti …"
    },
    {
      "id": "an10.213:1.12",
      "pali": "micchādiṭṭhiko hoti …."
    },
    {
      "id": "an10.213:1.13",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ niraye."
    },
    {
      "id": "an10.213:2.1",
      "pali": "Dasahi, bhikkhave, dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ sagge."
    },
    {
      "id": "an10.213:2.2",
      "pali": "Katamehi dasahi?"
    },
    {
      "id": "an10.213:2.3",
      "pali": "Pāṇātipātā paṭivirato hoti …pe…"
    },
    {
      "id": "an10.213:2.4",
      "pali": "adinnādānā paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.5",
      "pali": "kāmesumicchācārā paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.6",
      "pali": "musāvādā paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.7",
      "pali": "pisuṇāya vācāya paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.8",
      "pali": "pharusāya vācāya paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.9",
      "pali": "samphappalāpā paṭivirato hoti …"
    },
    {
      "id": "an10.213:2.10",
      "pali": "anabhijjhālu hoti …"
    },
    {
      "id": "an10.213:2.11",
      "pali": "abyāpannacitto hoti …"
    },
    {
      "id": "an10.213:2.12",
      "pali": "sammādiṭṭhiko hoti …."
    },
    {
      "id": "an10.213:2.13",
      "pali": "Imehi kho, bhikkhave, dasahi dhammehi samannāgato mātugāmo yathābhataṁ nikkhitto evaṁ sagge”ti."
    },
    {
      "id": "an10.213:2.14",
      "pali": "Tatiyaṁ."
    }
  ]
}
