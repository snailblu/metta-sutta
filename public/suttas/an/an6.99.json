{
  "uid": "an6.99",
  "title": "Dukkhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.99:1.1",
      "pali": "“So vata, bhikkhave, bhikkhu kañci saṅkhāraṁ sukhato samanupassanto …pe…"
    },
    {
      "id": "an6.99:1.2",
      "pali": "sabbasaṅkhāre dukkhato samanupassanto …pe…"
    },
    {
      "id": "an6.99:1.3",
      "pali": "ṭhānametaṁ vijjati”."
    },
    {
      "id": "an6.99:1.4",
      "pali": "Catutthaṁ."
    }
  ]
}
