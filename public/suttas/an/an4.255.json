{
  "uid": "an4.255",
  "title": "Pariyesanāsutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.255:1.1",
      "pali": "“Catasso imā, bhikkhave, anariyapariyesanā."
    },
    {
      "id": "an4.255:1.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.255:1.3",
      "pali": "Idha, bhikkhave, ekacco attanā jarādhammo samāno jarādhammaṁyeva pariyesati;"
    },
    {
      "id": "an4.255:1.4",
      "pali": "attanā byādhidhammo samāno byādhidhammaṁyeva pariyesati;"
    },
    {
      "id": "an4.255:1.5",
      "pali": "attanā maraṇadhammo samāno maraṇadhammaṁyeva pariyesati;"
    },
    {
      "id": "an4.255:1.6",
      "pali": "attanā saṅkilesadhammo samāno saṅkilesadhammaṁyeva pariyesati."
    },
    {
      "id": "an4.255:1.7",
      "pali": "Imā kho, bhikkhave, catasso anariyapariyesanā."
    },
    {
      "id": "an4.255:2.1",
      "pali": "Catasso imā, bhikkhave, ariyapariyesanā."
    },
    {
      "id": "an4.255:2.2",
      "pali": "Katamā catasso?"
    },
    {
      "id": "an4.255:2.3",
      "pali": "Idha, bhikkhave, ekacco attanā jarādhammo samāno jarādhamme ādīnavaṁ viditvā ajaraṁ anuttaraṁ yogakkhemaṁ nibbānaṁ pariyesati;"
    },
    {
      "id": "an4.255:2.4",
      "pali": "attanā byādhidhammo samāno byādhidhamme ādīnavaṁ viditvā abyādhiṁ anuttaraṁ yogakkhemaṁ nibbānaṁ pariyesati;"
    },
    {
      "id": "an4.255:2.5",
      "pali": "attanā maraṇadhammo samāno maraṇadhamme ādīnavaṁ viditvā amataṁ anuttaraṁ yogakkhemaṁ nibbānaṁ pariyesati;"
    },
    {
      "id": "an4.255:2.6",
      "pali": "attanā saṅkilesadhammo samāno saṅkilesadhamme ādīnavaṁ viditvā asaṅkiliṭṭhaṁ anuttaraṁ yogakkhemaṁ nibbānaṁ pariyesati."
    },
    {
      "id": "an4.255:2.7",
      "pali": "Imā kho, bhikkhave, catasso ariyapariyesanā”ti."
    },
    {
      "id": "an4.255:2.8",
      "pali": "Dutiyaṁ."
    }
  ]
}
