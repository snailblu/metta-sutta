{
  "uid": "an9.83",
  "title": "Sikkhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.83:1.1",
      "pali": "“Pañcimāni, bhikkhave, sikkhādubbalyāni."
    },
    {
      "id": "an9.83:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "an9.83:1.3",
      "pali": "Pāṇātipāto …pe… surāmerayamajjapamādaṭṭhānaṁ—"
    },
    {
      "id": "an9.83:1.4",
      "pali": "imāni kho, bhikkhave, pañca sikkhādubbalyāni."
    },
    {
      "id": "an9.83:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ sikkhādubbalyānaṁ pahānāya cattāro iddhipādā bhāvetabbā."
    },
    {
      "id": "an9.83:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an9.83:2.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "an9.83:2.4",
      "pali": "vīriyasamādhi …"
    },
    {
      "id": "an9.83:2.5",
      "pali": "cittasamādhi …"
    },
    {
      "id": "an9.83:2.6",
      "pali": "vīmaṁsāsamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "an9.83:2.7",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ sikkhādubbalyānaṁ pahānāya ime cattāro iddhipādā bhāvetabbā”ti."
    },
    {
      "id": "an9.83:2.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
