{
  "uid": "an4.150",
  "title": "Sārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.150:1.1",
      "pali": "“Cattārome, bhikkhave, sārā."
    },
    {
      "id": "an4.150:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "an4.150:1.3",
      "pali": "Sīlasāro, samādhisāro, paññāsāro, vimuttisāro—"
    },
    {
      "id": "an4.150:1.4",
      "pali": "Ime kho, bhikkhave, cattāro sārā”ti."
    },
    {
      "id": "an4.150:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "an4.150:1.6",
      "pali": "Ābhāvaggo pañcamo."
    },
    {
      "id": "an4.150:2.1",
      "pali": "Ābhā pabhā ca ālokā,"
    },
    {
      "id": "an4.150:2.2",
      "pali": "obhāsā ceva pajjotā;"
    },
    {
      "id": "an4.150:2.3",
      "pali": "Dve kālā caritā dve ca,"
    },
    {
      "id": "an4.150:2.4",
      "pali": "honti sārena te dasāti."
    },
    {
      "id": "an4.150:2.5",
      "pali": "Tatiyo paṇṇāsako samatto."
    }
  ]
}
