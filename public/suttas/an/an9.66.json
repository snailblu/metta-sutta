{
  "uid": "an9.66",
  "title": "Upādānakkhandhasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.66:1.1",
      "pali": "“Pañcime, bhikkhave, upādānakkhandhā."
    },
    {
      "id": "an9.66:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an9.66:1.3",
      "pali": "Rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho—"
    },
    {
      "id": "an9.66:1.4",
      "pali": "ime kho, bhikkhave, pañcupādānakkhandhā."
    },
    {
      "id": "an9.66:2.1",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ upādānakkhandhānaṁ pahānāya …pe… ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "an9.66:2.2",
      "pali": "Catutthaṁ."
    }
  ]
}
