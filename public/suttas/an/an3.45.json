{
  "uid": "an3.45",
  "title": "Paṇḍitasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an3.45:1.1",
      "pali": "“Tīṇimāni, bhikkhave, paṇḍitapaññattāni sappurisapaññattāni."
    },
    {
      "id": "an3.45:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "an3.45:1.3",
      "pali": "Dānaṁ, bhikkhave, paṇḍitapaññattaṁ sappurisapaññattaṁ."
    },
    {
      "id": "an3.45:1.4",
      "pali": "Pabbajjā, bhikkhave, paṇḍitapaññattā sappurisapaññattā."
    },
    {
      "id": "an3.45:1.5",
      "pali": "Mātāpitūnaṁ, bhikkhave, upaṭṭhānaṁ paṇḍitapaññattaṁ sappurisapaññattaṁ."
    },
    {
      "id": "an3.45:1.6",
      "pali": "Imāni kho, bhikkhave, tīṇi paṇḍitapaññattāni sappurisapaññattānīti."
    },
    {
      "id": "an3.45:2.1",
      "pali": "Sabbhi dānaṁ upaññattaṁ,"
    },
    {
      "id": "an3.45:2.2",
      "pali": "ahiṁsā saṁyamo damo;"
    },
    {
      "id": "an3.45:2.3",
      "pali": "Mātāpitu upaṭṭhānaṁ,"
    },
    {
      "id": "an3.45:2.4",
      "pali": "santānaṁ brahmacārinaṁ."
    },
    {
      "id": "an3.45:3.1",
      "pali": "Sataṁ etāni ṭhānāni,"
    },
    {
      "id": "an3.45:3.2",
      "pali": "yāni sevetha paṇḍito;"
    },
    {
      "id": "an3.45:3.3",
      "pali": "Ariyo dassanasampanno,"
    },
    {
      "id": "an3.45:3.4",
      "pali": "sa lokaṁ bhajate sivan”ti."
    },
    {
      "id": "an3.45:3.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
