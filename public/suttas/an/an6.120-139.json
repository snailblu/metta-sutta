{
  "uid": "an6.120-139",
  "title": "Bhallikādisutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an6.120-139:1.1",
      "pali": "“Chahi, bhikkhave, dhammehi samannāgato bhalliko gahapati …pe…"
    },
    {
      "id": "an6.120-139:1.2",
      "pali": "sudatto gahapati anāthapiṇḍiko …"
    },
    {
      "id": "an6.120-139:1.3",
      "pali": "citto gahapati macchikāsaṇḍiko …"
    },
    {
      "id": "an6.120-139:1.4",
      "pali": "hatthako āḷavako …"
    },
    {
      "id": "an6.120-139:1.5",
      "pali": "mahānāmo sakko …"
    },
    {
      "id": "an6.120-139:1.6",
      "pali": "uggo gahapati vesāliko …"
    },
    {
      "id": "an6.120-139:1.7",
      "pali": "uggato gahapati …"
    },
    {
      "id": "an6.120-139:1.8",
      "pali": "sūrambaṭṭho …"
    },
    {
      "id": "an6.120-139:1.9",
      "pali": "jīvako komārabhacco …"
    },
    {
      "id": "an6.120-139:1.10",
      "pali": "nakulapitā gahapati …"
    },
    {
      "id": "an6.120-139:1.11",
      "pali": "tavakaṇṇiko gahapati …"
    },
    {
      "id": "an6.120-139:1.12",
      "pali": "pūraṇo gahapati …"
    },
    {
      "id": "an6.120-139:1.13",
      "pali": "isidatto gahapati …"
    },
    {
      "id": "an6.120-139:1.14",
      "pali": "sandhāno gahapati …"
    },
    {
      "id": "an6.120-139:1.15",
      "pali": "vicayo gahapati …"
    },
    {
      "id": "an6.120-139:1.16",
      "pali": "vijayamāhiko gahapati …"
    },
    {
      "id": "an6.120-139:1.17",
      "pali": "meṇḍako gahapati …"
    },
    {
      "id": "an6.120-139:1.18",
      "pali": "vāseṭṭho upāsako …"
    },
    {
      "id": "an6.120-139:1.19",
      "pali": "ariṭṭho upāsako …"
    },
    {
      "id": "an6.120-139:1.20",
      "pali": "sāraggo upāsako tathāgate niṭṭhaṅgato amataddaso amataṁ sacchikatvā iriyati."
    },
    {
      "id": "an6.120-139:1.21",
      "pali": "Katamehi chahi?"
    },
    {
      "id": "an6.120-139:1.22",
      "pali": "Buddhe aveccappasādena, dhamme aveccappasādena, saṅghe aveccappasādena, ariyena sīlena, ariyena ñāṇena, ariyāya vimuttiyā."
    },
    {
      "id": "an6.120-139:1.23",
      "pali": "Imehi kho, bhikkhave, chahi dhammehi samannāgato sāraggo upāsako tathāgate niṭṭhaṅgato amataddaso amataṁ sacchikatvā iriyatī”ti."
    },
    {
      "id": "an6.120-139:1.24",
      "pali": "Tevīsatimaṁ."
    },
    {
      "id": "an6.120-139:1.25",
      "pali": "Sāmaññavaggo dvādasamo."
    }
  ]
}
