{
  "uid": "an1.219-234",
  "title": "an1.219-234",
  "nikaya": "an",
  "segments": [
    {
      "id": "an1.219:1.1",
      "pali": "“Etadaggaṁ, bhikkhave, mama sāvakānaṁ bhikkhūnaṁ bahussutānaṁ yadidaṁ ānando."
    },
    {
      "id": "an1.220:1.1",
      "pali": "… Satimantānaṁ yadidaṁ ānando."
    },
    {
      "id": "an1.221:1.1",
      "pali": "… Gatimantānaṁ yadidaṁ ānando."
    },
    {
      "id": "an1.222:1.1",
      "pali": "… Dhitimantānaṁ yadidaṁ ānando."
    },
    {
      "id": "an1.223:1.1",
      "pali": "… Upaṭṭhākānaṁ yadidaṁ ānando."
    },
    {
      "id": "an1.224:1.1",
      "pali": "… Mahāparisānaṁ yadidaṁ uruvelakassapo."
    },
    {
      "id": "an1.225:1.1",
      "pali": "… Kulappasādakānaṁ yadidaṁ kāḷudāyī."
    },
    {
      "id": "an1.226:1.1",
      "pali": "… Appābādhānaṁ yadidaṁ bākulo."
    },
    {
      "id": "an1.227:1.1",
      "pali": "… Pubbenivāsaṁ anussarantānaṁ yadidaṁ sobhito."
    },
    {
      "id": "an1.228:1.1",
      "pali": "… Vinayadharānaṁ yadidaṁ upāli."
    },
    {
      "id": "an1.229:1.1",
      "pali": "… Bhikkhunovādakānaṁ yadidaṁ nandako."
    },
    {
      "id": "an1.230:1.1",
      "pali": "… Indriyesu guttadvārānaṁ yadidaṁ nando."
    },
    {
      "id": "an1.231:1.1",
      "pali": "… Bhikkhuovādakānaṁ yadidaṁ mahākappino."
    },
    {
      "id": "an1.232:1.1",
      "pali": "… Tejodhātukusalānaṁ yadidaṁ sāgato."
    },
    {
      "id": "an1.233:1.1",
      "pali": "… Paṭibhāneyyakānaṁ yadidaṁ rādho."
    },
    {
      "id": "an1.234:1.1",
      "pali": "… Lūkhacīvaradharānaṁ yadidaṁ mogharājā”ti."
    },
    {
      "id": "an1.234:1.2",
      "pali": "Vaggo catuttho."
    }
  ]
}
