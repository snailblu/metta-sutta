{
  "uid": "an8.37",
  "title": "Sappurisadānasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an8.37:1.1",
      "pali": "“Aṭṭhimāni, bhikkhave, sappurisadānāni."
    },
    {
      "id": "an8.37:1.2",
      "pali": "Katamāni aṭṭha?"
    },
    {
      "id": "an8.37:1.3",
      "pali": "Suciṁ deti, paṇītaṁ deti, kālena deti, kappiyaṁ deti, viceyya deti, abhiṇhaṁ deti, dadaṁ cittaṁ pasādeti, datvā attamano hoti."
    },
    {
      "id": "an8.37:1.4",
      "pali": "Imāni kho, bhikkhave, aṭṭha sappurisadānānīti."
    },
    {
      "id": "an8.37:2.1",
      "pali": "Suciṁ paṇītaṁ kālena,"
    },
    {
      "id": "an8.37:2.2",
      "pali": "kappiyaṁ pānabhojanaṁ;"
    },
    {
      "id": "an8.37:2.3",
      "pali": "Abhiṇhaṁ dadāti dānaṁ,"
    },
    {
      "id": "an8.37:2.4",
      "pali": "sukhettesu brahmacārisu."
    },
    {
      "id": "an8.37:3.1",
      "pali": "Neva vippaṭisārissa,"
    },
    {
      "id": "an8.37:3.2",
      "pali": "cajitvā āmisaṁ bahuṁ;"
    },
    {
      "id": "an8.37:3.3",
      "pali": "Evaṁ dinnāni dānāni,"
    },
    {
      "id": "an8.37:3.4",
      "pali": "vaṇṇayanti vipassino."
    },
    {
      "id": "an8.37:4.1",
      "pali": "Evaṁ yajitvā medhāvī,"
    },
    {
      "id": "an8.37:4.2",
      "pali": "saddho muttena cetasā;"
    },
    {
      "id": "an8.37:4.3",
      "pali": "Abyābajjhaṁ sukhaṁ lokaṁ,"
    },
    {
      "id": "an8.37:4.4",
      "pali": "paṇḍito upapajjatī”ti."
    },
    {
      "id": "an8.37:4.5",
      "pali": "Sattamaṁ."
    }
  ]
}
