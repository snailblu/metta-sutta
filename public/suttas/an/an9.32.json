{
  "uid": "an9.32",
  "title": "Anupubbavihārasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an9.32:1.1",
      "pali": "“Navayime, bhikkhave, anupubbavihārā."
    },
    {
      "id": "an9.32:1.2",
      "pali": "Katame nava?"
    },
    {
      "id": "an9.32:1.3",
      "pali": "Paṭhamaṁ jhānaṁ, dutiyaṁ jhānaṁ, tatiyaṁ jhānaṁ, catutthaṁ jhānaṁ, ākāsānañcāyatanaṁ, viññāṇañcāyatanaṁ, ākiñcaññāyatanaṁ, nevasaññānāsaññāyatanaṁ, saññāvedayitanirodho—"
    },
    {
      "id": "an9.32:1.4",
      "pali": "ime kho, bhikkhave, nava anupubbavihārā”ti."
    },
    {
      "id": "an9.32:1.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
