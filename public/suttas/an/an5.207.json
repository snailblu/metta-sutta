{
  "uid": "an5.207",
  "title": "Yāgusutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an5.207:1.1",
      "pali": "“Pañcime, bhikkhave, ānisaṁsā yāguyā."
    },
    {
      "id": "an5.207:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "an5.207:1.3",
      "pali": "Khuddaṁ paṭihanati, pipāsaṁ paṭivineti, vātaṁ anulometi, vatthiṁ sodheti, āmāvasesaṁ pāceti."
    },
    {
      "id": "an5.207:1.4",
      "pali": "Ime kho, bhikkhave, pañca ānisaṁsā yāguyā”ti."
    },
    {
      "id": "an5.207:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
