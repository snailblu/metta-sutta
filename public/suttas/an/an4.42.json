{
  "uid": "an4.42",
  "title": "Pañhabyākaraṇasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an4.42:1.1",
      "pali": "“Cattārimāni, bhikkhave, pañhabyākaraṇāni."
    },
    {
      "id": "an4.42:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "an4.42:1.3",
      "pali": "Atthi, bhikkhave, pañho ekaṁsabyākaraṇīyo;"
    },
    {
      "id": "an4.42:1.4",
      "pali": "atthi, bhikkhave, pañho vibhajjabyākaraṇīyo;"
    },
    {
      "id": "an4.42:1.5",
      "pali": "atthi, bhikkhave, pañho paṭipucchābyākaraṇīyo;"
    },
    {
      "id": "an4.42:1.6",
      "pali": "atthi, bhikkhave, pañho ṭhapanīyo."
    },
    {
      "id": "an4.42:1.7",
      "pali": "Imāni kho, bhikkhave, cattāri pañhabyākaraṇānīti."
    },
    {
      "id": "an4.42:2.1",
      "pali": "Ekaṁsavacanaṁ ekaṁ,"
    },
    {
      "id": "an4.42:2.2",
      "pali": "vibhajjavacanāparaṁ;"
    },
    {
      "id": "an4.42:2.3",
      "pali": "Tatiyaṁ paṭipuccheyya,"
    },
    {
      "id": "an4.42:2.4",
      "pali": "catutthaṁ pana ṭhāpaye."
    },
    {
      "id": "an4.42:3.1",
      "pali": "Yo ca tesaṁ tattha tattha,"
    },
    {
      "id": "an4.42:3.2",
      "pali": "jānāti anudhammataṁ;"
    },
    {
      "id": "an4.42:3.3",
      "pali": "Catupañhassa kusalo,"
    },
    {
      "id": "an4.42:3.4",
      "pali": "āhu bhikkhuṁ tathāvidhaṁ."
    },
    {
      "id": "an4.42:4.1",
      "pali": "Durāsado duppasaho,"
    },
    {
      "id": "an4.42:4.2",
      "pali": "gambhīro duppadhaṁsiyo;"
    },
    {
      "id": "an4.42:4.3",
      "pali": "Atho atthe anatthe ca,"
    },
    {
      "id": "an4.42:4.4",
      "pali": "ubhayassa hoti kovido."
    },
    {
      "id": "an4.42:5.1",
      "pali": "Anatthaṁ parivajjeti,"
    },
    {
      "id": "an4.42:5.2",
      "pali": "atthaṁ gaṇhāti paṇḍito;"
    },
    {
      "id": "an4.42:5.3",
      "pali": "Atthābhisamayā dhīro,"
    },
    {
      "id": "an4.42:5.4",
      "pali": "paṇḍitoti pavuccatī”ti."
    },
    {
      "id": "an4.42:5.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
