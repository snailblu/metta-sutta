{
  "uid": "an10.185",
  "title": "Tapanīyasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.185:1.1",
      "pali": "“Tapanīyañca vo, bhikkhave, dhammaṁ desessāmi atapanīyañca."
    },
    {
      "id": "an10.185:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "an10.185:1.3",
      "pali": "katamo ca, bhikkhave, tapanīyo dhammo?"
    },
    {
      "id": "an10.185:1.4",
      "pali": "Pāṇātipāto …pe…"
    },
    {
      "id": "an10.185:1.5",
      "pali": "micchādiṭṭhi—"
    },
    {
      "id": "an10.185:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, tapanīyo dhammo."
    },
    {
      "id": "an10.185:2.1",
      "pali": "Katamo ca, bhikkhave, atapanīyo dhammo?"
    },
    {
      "id": "an10.185:2.2",
      "pali": "Pāṇātipātā veramaṇī …pe…"
    },
    {
      "id": "an10.185:2.3",
      "pali": "sammādiṭṭhi—"
    },
    {
      "id": "an10.185:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, atapanīyo dhammo”ti."
    },
    {
      "id": "an10.185:2.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
