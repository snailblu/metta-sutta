{
  "uid": "an10.13",
  "title": "Saṁyojanasutta",
  "nikaya": "an",
  "segments": [
    {
      "id": "an10.13:1.1",
      "pali": "“Dasayimāni, bhikkhave, saṁyojanāni."
    },
    {
      "id": "an10.13:1.2",
      "pali": "Katamāni dasa?"
    },
    {
      "id": "an10.13:1.3",
      "pali": "Pañcorambhāgiyāni saṁyojanāni, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an10.13:1.4",
      "pali": "Katamāni pañcorambhāgiyāni saṁyojanāni?"
    },
    {
      "id": "an10.13:1.5",
      "pali": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—"
    },
    {
      "id": "an10.13:1.6",
      "pali": "imāni pañcorambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an10.13:2.1",
      "pali": "Katamāni pañcuddhambhāgiyāni saṁyojanāni?"
    },
    {
      "id": "an10.13:2.2",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "an10.13:2.3",
      "pali": "imāni pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "an10.13:2.4",
      "pali": "Imāni kho, bhikkhave, dasa saṁyojanānī”ti."
    },
    {
      "id": "an10.13:2.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
