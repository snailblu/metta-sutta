{
  "uid": "sn12.72-81",
  "title": "Jātisuttādidasaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.72-81:1.1",
      "pali": "“Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.72-81:1.2",
      "pali": "Jātiṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:2.1",
      "pali": "“Bhavaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:3.1",
      "pali": "“Upādānaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:4.1",
      "pali": "“Taṇhaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:5.1",
      "pali": "“Vedanaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:6.1",
      "pali": "“Phassaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:7.1",
      "pali": "“Saḷāyatanaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:8.1",
      "pali": "“Nāmarūpaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:9.1",
      "pali": "“Viññāṇaṁ nappajānanti …pe…."
    },
    {
      "id": "sn12.72-81:10.1",
      "pali": "“Saṅkhāre nappajānanti, saṅkhārasamudayaṁ nappajānanti, saṅkhāranirodhaṁ nappajānanti, saṅkhāranirodhagāminiṁ paṭipadaṁ nappajānanti …pe…"
    },
    {
      "id": "sn12.72-81:10.2",
      "pali": "pajānanti …pe…"
    },
    {
      "id": "sn12.72-81:10.3",
      "pali": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn12.72-81:10.4",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn12.72-81:10.5",
      "pali": "Samaṇabrāhmaṇavaggo aṭṭhamo."
    },
    {
      "id": "sn12.72-81:11.1",
      "pali": "Paccayekādasa vuttā,"
    },
    {
      "id": "sn12.72-81:11.2",
      "pali": "catusaccavibhajjanā;"
    },
    {
      "id": "sn12.72-81:11.3",
      "pali": "Samaṇabrāhmaṇavaggo,"
    },
    {
      "id": "sn12.72-81:11.4",
      "pali": "nidāne bhavati aṭṭhamo."
    },
    {
      "id": "sn12.72-81:12.1",
      "pali": "Buddho āhāro dasabalo,"
    },
    {
      "id": "sn12.72-81:12.2",
      "pali": "Kaḷāro gahapatipañcamo;"
    },
    {
      "id": "sn12.72-81:12.3",
      "pali": "Dukkhavaggo mahāvaggo,"
    },
    {
      "id": "sn12.72-81:12.4",
      "pali": "Aṭṭhamo samaṇabrāhmaṇoti."
    }
  ]
}
