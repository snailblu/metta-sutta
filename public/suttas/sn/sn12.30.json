{
  "uid": "sn12.30",
  "title": "Dutiyasamaṇabrāhmaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.30:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.30:1.2",
      "pali": "“Tatra kho …pe…"
    },
    {
      "id": "sn12.30:1.3",
      "pali": "ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā jarāmaraṇaṁ nappajānanti, jarāmaraṇasamudayaṁ nappajānanti, jarāmaraṇanirodhaṁ nappajānanti, jarāmaraṇanirodhagāminiṁ paṭipadaṁ nappajānanti te vata jarāmaraṇaṁ samatikkamma ṭhassantīti netaṁ ṭhānaṁ vijjati."
    },
    {
      "id": "sn12.30:1.4",
      "pali": "Jātiṁ nappajānanti …pe…"
    },
    {
      "id": "sn12.30:1.5",
      "pali": "bhavaṁ …"
    },
    {
      "id": "sn12.30:1.6",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.30:1.7",
      "pali": "taṇhaṁ …"
    },
    {
      "id": "sn12.30:1.8",
      "pali": "vedanaṁ …"
    },
    {
      "id": "sn12.30:1.9",
      "pali": "phassaṁ …"
    },
    {
      "id": "sn12.30:1.10",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.30:1.11",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.30:1.12",
      "pali": "viññāṇaṁ …"
    },
    {
      "id": "sn12.30:1.13",
      "pali": "saṅkhāre nappajānanti, saṅkhārasamudayaṁ nappajānanti, saṅkhāranirodhaṁ nappajānanti, saṅkhāranirodhagāminiṁ paṭipadaṁ nappajānanti te vata saṅkhāre samatikkamma ṭhassantīti netaṁ ṭhānaṁ vijjati."
    },
    {
      "id": "sn12.30:2.1",
      "pali": "Ye ca kho keci, bhikkhave, samaṇā vā brāhmaṇā vā jarāmaraṇaṁ pajānanti, jarāmaraṇasamudayaṁ pajānanti, jarāmaraṇanirodhaṁ pajānanti, jarāmaraṇanirodhagāminiṁ paṭipadaṁ pajānanti te vata jarāmaraṇaṁ samatikkamma ṭhassantīti ṭhānametaṁ vijjati."
    },
    {
      "id": "sn12.30:2.2",
      "pali": "Jātiṁ pajānanti …pe…"
    },
    {
      "id": "sn12.30:2.3",
      "pali": "bhavaṁ …"
    },
    {
      "id": "sn12.30:2.4",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.30:2.5",
      "pali": "taṇhaṁ …"
    },
    {
      "id": "sn12.30:2.6",
      "pali": "vedanaṁ …"
    },
    {
      "id": "sn12.30:2.7",
      "pali": "phassaṁ …"
    },
    {
      "id": "sn12.30:2.8",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.30:2.9",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.30:2.10",
      "pali": "viññāṇaṁ …"
    },
    {
      "id": "sn12.30:2.11",
      "pali": "saṅkhāre pajānanti, saṅkhārasamudayaṁ pajānanti, saṅkhāranirodhaṁ pajānanti, saṅkhāranirodhagāminiṁ paṭipadaṁ pajānanti."
    },
    {
      "id": "sn12.30:2.12",
      "pali": "Te vata saṅkhāre samatikkamma ṭhassantīti ṭhānametaṁ vijjatī”ti."
    },
    {
      "id": "sn12.30:2.13",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn12.30:2.14",
      "pali": "Dasabalavaggo tatiyo."
    },
    {
      "id": "sn12.30:3.1",
      "pali": "Dve dasabalā upanisā ca,"
    },
    {
      "id": "sn12.30:3.2",
      "pali": "Aññatitthiyabhūmijo;"
    },
    {
      "id": "sn12.30:3.3",
      "pali": "Upavāṇo paccayo bhikkhu,"
    },
    {
      "id": "sn12.30:3.4",
      "pali": "Dve ca samaṇabrāhmaṇāti."
    }
  ]
}
