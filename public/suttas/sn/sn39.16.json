{
  "uid": "sn39.16",
  "title": "Dukkarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn39.16:1.1",
      "pali": "“Kiṁ nu kho, āvuso sāriputta, imasmiṁ dhammavinaye dukkaran”ti?"
    },
    {
      "id": "sn39.16:1.2",
      "pali": "“Pabbajjā kho, āvuso, imasmiṁ dhammavinaye dukkarā”ti."
    },
    {
      "id": "sn39.16:1.3",
      "pali": "“Pabbajitena panāvuso, kiṁ dukkaran”ti?"
    },
    {
      "id": "sn39.16:1.4",
      "pali": "“Pabbajitena kho, āvuso, abhirati dukkarā”ti."
    },
    {
      "id": "sn39.16:1.5",
      "pali": "“Abhiratena panāvuso, kiṁ dukkaran”ti?"
    },
    {
      "id": "sn39.16:1.6",
      "pali": "“Abhiratena kho, āvuso, dhammānudhammappaṭipatti dukkarā”ti."
    },
    {
      "id": "sn39.16:1.7",
      "pali": "“Kīvaciraṁ panāvuso, dhammānudhammappaṭipanno bhikkhu arahaṁ assā”ti?"
    },
    {
      "id": "sn39.16:1.8",
      "pali": "“Naciraṁ, āvuso”ti."
    },
    {
      "id": "sn39.16:1.9",
      "pali": "Soḷasamaṁ."
    },
    {
      "id": "sn39.16:1.10",
      "pali": "(Purimakasadisaṁ uddānaṁ.)"
    },
    {
      "id": "sn39.16:1.11",
      "pali": "Sāmaṇḍakasaṁyuttaṁ samattaṁ."
    }
  ]
}
