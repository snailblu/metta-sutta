{
  "uid": "sn1.31",
  "title": "Sabbhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.31:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.31:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.31:1.3",
      "pali": "Atha kho sambahulā satullapakāyikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.31:1.4",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:2.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:2.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:2.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:2.4",
      "pali": "seyyo hoti na pāpiyo”ti."
    },
    {
      "id": "sn1.31:3.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:4.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:4.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:4.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:4.4",
      "pali": "paññā labbhati nāññato”ti."
    },
    {
      "id": "sn1.31:5.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:6.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:6.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:6.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:6.4",
      "pali": "sokamajjhe na socatī”ti."
    },
    {
      "id": "sn1.31:7.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:8.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:8.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:8.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:8.4",
      "pali": "ñātimajjhe virocatī”ti."
    },
    {
      "id": "sn1.31:9.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:10.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:10.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:10.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:10.4",
      "pali": "sattā gacchanti suggatin”ti."
    },
    {
      "id": "sn1.31:11.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.31:12.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:12.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:12.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:12.4",
      "pali": "sattā tiṭṭhanti sātatan”ti."
    },
    {
      "id": "sn1.31:13.1",
      "pali": "Atha kho aparā devatā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn1.31:13.2",
      "pali": "“kassa nu kho, bhagavā, subhāsitan”ti?"
    },
    {
      "id": "sn1.31:14.1",
      "pali": "“Sabbāsaṁ vo subhāsitaṁ pariyāyena, api ca mamapi suṇātha—"
    },
    {
      "id": "sn1.31:15.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn1.31:15.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn1.31:15.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn1.31:15.4",
      "pali": "sabbadukkhā pamuccatī”ti."
    },
    {
      "id": "sn1.31:16.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn1.31:16.2",
      "pali": "Attamanā tā devatāyo bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyiṁsūti."
    }
  ]
}
