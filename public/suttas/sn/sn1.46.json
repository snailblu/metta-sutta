{
  "uid": "sn1.46",
  "title": "Accharāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.46:1.1",
      "pali": "“Accharāgaṇasaṅghuṭṭhaṁ,"
    },
    {
      "id": "sn1.46:1.2",
      "pali": "pisācagaṇasevitaṁ;"
    },
    {
      "id": "sn1.46:1.3",
      "pali": "Vanantaṁ mohanaṁ nāma,"
    },
    {
      "id": "sn1.46:1.4",
      "pali": "kathaṁ yātrā bhavissatī”ti."
    },
    {
      "id": "sn1.46:2.1",
      "pali": "“Ujuko nāma so maggo,"
    },
    {
      "id": "sn1.46:2.2",
      "pali": "abhayā nāma sā disā;"
    },
    {
      "id": "sn1.46:2.3",
      "pali": "Ratho akūjano nāma,"
    },
    {
      "id": "sn1.46:2.4",
      "pali": "dhammacakkehi saṁyuto."
    },
    {
      "id": "sn1.46:3.1",
      "pali": "Hirī tassa apālambo,"
    },
    {
      "id": "sn1.46:3.2",
      "pali": "satyassa parivāraṇaṁ;"
    },
    {
      "id": "sn1.46:3.3",
      "pali": "Dhammāhaṁ sārathiṁ brūmi,"
    },
    {
      "id": "sn1.46:3.4",
      "pali": "sammādiṭṭhipurejavaṁ."
    },
    {
      "id": "sn1.46:4.1",
      "pali": "Yassa etādisaṁ yānaṁ,"
    },
    {
      "id": "sn1.46:4.2",
      "pali": "itthiyā purisassa vā;"
    },
    {
      "id": "sn1.46:4.3",
      "pali": "Sa ve etena yānena,"
    },
    {
      "id": "sn1.46:4.4",
      "pali": "nibbānasseva santike”ti."
    }
  ]
}
