{
  "uid": "sn38.14",
  "title": "Dukkhapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.14:1.1",
      "pali": "“‘Dukkhaṁ, dukkhan’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.14:1.2",
      "pali": "Katamaṁ nu kho, āvuso, dukkhan”ti?"
    },
    {
      "id": "sn38.14:1.3",
      "pali": "“Tisso imā, āvuso, dukkhatā."
    },
    {
      "id": "sn38.14:1.4",
      "pali": "Dukkhadukkhatā, saṅkhāradukkhatā, vipariṇāmadukkhatā—"
    },
    {
      "id": "sn38.14:1.5",
      "pali": "imā kho, āvuso, tisso dukkhatā”ti."
    },
    {
      "id": "sn38.14:1.6",
      "pali": "“Atthi panāvuso maggo atthi paṭipadā, etāsaṁ dukkhatānaṁ pariññāyā”ti?"
    },
    {
      "id": "sn38.14:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā, etāsaṁ dukkhatānaṁ pariññāyā”ti."
    },
    {
      "id": "sn38.14:1.8",
      "pali": "“Katamo panāvuso, maggo katamā paṭipadā, etāsaṁ dukkhatānaṁ pariññāyā”ti?"
    },
    {
      "id": "sn38.14:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etāsaṁ dukkhatānaṁ pariññāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.14:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.14:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etāsaṁ dukkhatānaṁ pariññāyā”ti."
    },
    {
      "id": "sn38.14:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etāsaṁ dukkhatānaṁ pariññāya."
    },
    {
      "id": "sn38.14:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.14:1.14",
      "pali": "Cuddasamaṁ."
    }
  ]
}
