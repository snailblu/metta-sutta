{
  "uid": "snp4.6",
  "title": "Jarāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.6:1.1",
      "pali": "Appaṁ vata jīvitaṁ idaṁ,"
    },
    {
      "id": "snp4.6:1.2",
      "pali": "Oraṁ vassasatāpi miyyati;"
    },
    {
      "id": "snp4.6:1.3",
      "pali": "Yo cepi aticca jīvati,"
    },
    {
      "id": "snp4.6:1.4",
      "pali": "Atha kho so jarasāpi miyyati."
    },
    {
      "id": "snp4.6:2.1",
      "pali": "Socanti janā mamāyite,"
    },
    {
      "id": "snp4.6:2.2",
      "pali": "Na hi santi niccā pariggahā;"
    },
    {
      "id": "snp4.6:2.3",
      "pali": "Vinābhāvasantamevidaṁ,"
    },
    {
      "id": "snp4.6:2.4",
      "pali": "Iti disvā nāgāramāvase."
    },
    {
      "id": "snp4.6:3.1",
      "pali": "Maraṇenapi taṁ pahīyati,"
    },
    {
      "id": "snp4.6:3.2",
      "pali": "Yaṁ puriso mamidanti maññati;"
    },
    {
      "id": "snp4.6:3.3",
      "pali": "Etampi viditvā paṇḍito,"
    },
    {
      "id": "snp4.6:3.4",
      "pali": "Na mamattāya nametha māmako."
    },
    {
      "id": "snp4.6:4.1",
      "pali": "Supinena yathāpi saṅgataṁ,"
    },
    {
      "id": "snp4.6:4.2",
      "pali": "Paṭibuddho puriso na passati;"
    },
    {
      "id": "snp4.6:4.3",
      "pali": "Evampi piyāyitaṁ janaṁ,"
    },
    {
      "id": "snp4.6:4.4",
      "pali": "Petaṁ kālaṅkataṁ na passati."
    },
    {
      "id": "snp4.6:5.1",
      "pali": "Diṭṭhāpi sutāpi te janā,"
    },
    {
      "id": "snp4.6:5.2",
      "pali": "Yesaṁ nāmamidaṁ pavuccati;"
    },
    {
      "id": "snp4.6:5.3",
      "pali": "Nāmaṁyevāvasissati,"
    },
    {
      "id": "snp4.6:5.4",
      "pali": "Akkheyyaṁ petassa jantuno."
    },
    {
      "id": "snp4.6:6.1",
      "pali": "Sokapparidevamaccharaṁ,"
    },
    {
      "id": "snp4.6:6.2",
      "pali": "Na jahanti giddhā mamāyite;"
    },
    {
      "id": "snp4.6:6.3",
      "pali": "Tasmā munayo pariggahaṁ,"
    },
    {
      "id": "snp4.6:6.4",
      "pali": "Hitvā acariṁsu khemadassino."
    },
    {
      "id": "snp4.6:7.1",
      "pali": "Patilīnacarassa bhikkhuno,"
    },
    {
      "id": "snp4.6:7.2",
      "pali": "Bhajamānassa vivittamāsanaṁ;"
    },
    {
      "id": "snp4.6:7.3",
      "pali": "Sāmaggiyamāhu tassa taṁ,"
    },
    {
      "id": "snp4.6:7.4",
      "pali": "Yo attānaṁ bhavane na dassaye."
    },
    {
      "id": "snp4.6:8.1",
      "pali": "Sabbattha munī anissito,"
    },
    {
      "id": "snp4.6:8.2",
      "pali": "Na piyaṁ kubbati nopi appiyaṁ;"
    },
    {
      "id": "snp4.6:8.3",
      "pali": "Tasmiṁ paridevamaccharaṁ,"
    },
    {
      "id": "snp4.6:8.4",
      "pali": "Paṇṇe vāri yathā na limpati."
    },
    {
      "id": "snp4.6:9.1",
      "pali": "Udabindu yathāpi pokkhare,"
    },
    {
      "id": "snp4.6:9.2",
      "pali": "Padume vāri yathā na limpati;"
    },
    {
      "id": "snp4.6:9.3",
      "pali": "Evaṁ muni nopalimpati,"
    },
    {
      "id": "snp4.6:9.4",
      "pali": "Yadidaṁ diṭṭhasutaṁ mutesu vā."
    },
    {
      "id": "snp4.6:10.1",
      "pali": "Dhono na hi tena maññati,"
    },
    {
      "id": "snp4.6:10.2",
      "pali": "Yadidaṁ diṭṭhasutaṁ mutesu vā;"
    },
    {
      "id": "snp4.6:10.3",
      "pali": "Nāññena visuddhimicchati,"
    },
    {
      "id": "snp4.6:10.4",
      "pali": "Na hi so rajjati no virajjatīti."
    },
    {
      "id": "snp4.6:10.5",
      "pali": "Jarāsuttaṁ chaṭṭhaṁ."
    }
  ]
}
