{
  "uid": "sn22.46",
  "title": "Dutiyaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.46:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.46:1.2",
      "pali": "“Rūpaṁ, bhikkhave, aniccaṁ."
    },
    {
      "id": "sn22.46:1.3",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.46:1.4",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.46:1.5",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.46:1.6",
      "pali": "Vedanā aniccā …"
    },
    {
      "id": "sn22.46:1.7",
      "pali": "saññā aniccā …"
    },
    {
      "id": "sn22.46:1.8",
      "pali": "saṅkhārā aniccā …"
    },
    {
      "id": "sn22.46:1.9",
      "pali": "viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn22.46:1.10",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.46:1.11",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.46:1.12",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.46:2.1",
      "pali": "Evametaṁ yathābhūtaṁ sammappaññāya passato pubbantānudiṭṭhiyo na honti."
    },
    {
      "id": "sn22.46:2.2",
      "pali": "Pubbantānudiṭṭhīnaṁ asati, aparantānudiṭṭhiyo na honti."
    },
    {
      "id": "sn22.46:2.3",
      "pali": "Aparantānudiṭṭhīnaṁ asati, thāmaso parāmāso na hoti."
    },
    {
      "id": "sn22.46:2.4",
      "pali": "Thāmase parāmāse asati rūpasmiṁ …"
    },
    {
      "id": "sn22.46:2.5",
      "pali": "vedanāya …"
    },
    {
      "id": "sn22.46:2.6",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.46:2.7",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn22.46:2.8",
      "pali": "viññāṇasmiṁ cittaṁ virajjati vimuccati anupādāya āsavehi."
    },
    {
      "id": "sn22.46:2.9",
      "pali": "Vimuttattā ṭhitaṁ. Ṭhitattā santusitaṁ. Santusitattā na paritassati. Aparitassaṁ paccattaññeva parinibbāyati."
    },
    {
      "id": "sn22.46:2.10",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.46:2.11",
      "pali": "Catutthaṁ."
    }
  ]
}
