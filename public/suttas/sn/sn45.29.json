{
  "uid": "sn45.29",
  "title": "Vedanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.29:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.29:1.2",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn45.29:1.3",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.29:1.4",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn45.29:1.5",
      "pali": "imā kho, bhikkhave, tisso vedanā."
    },
    {
      "id": "sn45.29:1.6",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ vedanānaṁ pariññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.29:1.7",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.29:1.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.29:1.9",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ vedanānaṁ pariññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.29:1.10",
      "pali": "Navamaṁ."
    }
  ]
}
