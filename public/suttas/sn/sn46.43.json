{
  "uid": "sn46.43",
  "title": "Mārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.43:1.1",
      "pali": "“Mārasenappamaddanaṁ vo, bhikkhave, maggaṁ desessāmi;"
    },
    {
      "id": "sn46.43:1.2",
      "pali": "taṁ suṇātha."
    },
    {
      "id": "sn46.43:1.3",
      "pali": "Katamo ca, bhikkhave, mārasenappamaddano maggo?"
    },
    {
      "id": "sn46.43:1.4",
      "pali": "Yadidaṁ—"
    },
    {
      "id": "sn46.43:1.5",
      "pali": "satta bojjhaṅgā."
    },
    {
      "id": "sn46.43:1.6",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.43:1.7",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.43:1.8",
      "pali": "ayaṁ kho, bhikkhave, mārasenappamaddano maggo”ti."
    },
    {
      "id": "sn46.43:1.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
