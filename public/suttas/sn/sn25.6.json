{
  "uid": "sn25.6",
  "title": "Rūpasaññāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.6:1.2",
      "pali": "“Rūpasaññā, bhikkhave, aniccā vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.6:1.3",
      "pali": "saddasaññā …"
    },
    {
      "id": "sn25.6:1.4",
      "pali": "gandhasaññā …"
    },
    {
      "id": "sn25.6:1.5",
      "pali": "rasasaññā …"
    },
    {
      "id": "sn25.6:1.6",
      "pali": "phoṭṭhabbasaññā …"
    },
    {
      "id": "sn25.6:1.7",
      "pali": "dhammasaññā aniccā vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.6:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.6:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.6:1.10",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
