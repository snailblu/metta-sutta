{
  "uid": "sn47.73-84",
  "title": "Balādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.73-84:1.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci balakaraṇīyā kammantā karīyantī”ti"
    },
    {
      "id": "sn47.73-84:1.2",
      "pali": "vitthāretabbaṁ."
    },
    {
      "id": "sn47.73-84:1.3",
      "pali": "Balakaraṇīyavaggo aṭṭhamo."
    },
    {
      "id": "sn47.73-84:2.1",
      "pali": "Balaṁ bījañca nāgo ca,"
    },
    {
      "id": "sn47.73-84:2.2",
      "pali": "rukkho kumbhena sūkiyā;"
    },
    {
      "id": "sn47.73-84:2.3",
      "pali": "Ākāsena ca dve meghā,"
    },
    {
      "id": "sn47.73-84:2.4",
      "pali": "nāvā āgantukā nadīti."
    }
  ]
}
