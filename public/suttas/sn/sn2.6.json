{
  "uid": "sn2.6",
  "title": "Kāmadasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.6:1.2",
      "pali": "Ekamantaṁ ṭhito kho kāmado devaputto bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn2.6:1.3",
      "pali": "“dukkaraṁ, bhagavā, sudukkaraṁ, bhagavā”ti."
    },
    {
      "id": "sn2.6:2.1",
      "pali": "“Dukkaraṁ vāpi karonti,"
    },
    {
      "id": "sn2.6:2.2",
      "pali": "(kāmadāti bhagavā)"
    },
    {
      "id": "sn2.6:2.3",
      "pali": "Sekhā sīlasamāhitā;"
    },
    {
      "id": "sn2.6:2.4",
      "pali": "Ṭhitattā anagāriyupetassa,"
    },
    {
      "id": "sn2.6:2.5",
      "pali": "Tuṭṭhi hoti sukhāvahā”ti."
    },
    {
      "id": "sn2.6:3.1",
      "pali": "“Dullabhā, bhagavā, yadidaṁ tuṭṭhī”ti."
    },
    {
      "id": "sn2.6:4.1",
      "pali": "“Dullabhaṁ vāpi labhanti,"
    },
    {
      "id": "sn2.6:4.2",
      "pali": "(kāmadāti bhagavā)"
    },
    {
      "id": "sn2.6:4.3",
      "pali": "Cittavūpasame ratā;"
    },
    {
      "id": "sn2.6:4.4",
      "pali": "Yesaṁ divā ca ratto ca,"
    },
    {
      "id": "sn2.6:4.5",
      "pali": "Bhāvanāya rato mano”ti."
    },
    {
      "id": "sn2.6:5.1",
      "pali": "“Dussamādahaṁ, bhagavā, yadidaṁ cittan”ti."
    },
    {
      "id": "sn2.6:6.1",
      "pali": "“Dussamādahaṁ vāpi samādahanti,"
    },
    {
      "id": "sn2.6:6.2",
      "pali": "(kāmadāti bhagavā)"
    },
    {
      "id": "sn2.6:6.3",
      "pali": "Indriyūpasame ratā;"
    },
    {
      "id": "sn2.6:6.4",
      "pali": "Te chetvā maccuno jālaṁ,"
    },
    {
      "id": "sn2.6:6.5",
      "pali": "Ariyā gacchanti kāmadā”ti."
    },
    {
      "id": "sn2.6:7.1",
      "pali": "“Duggamo, bhagavā, visamo maggo”ti."
    },
    {
      "id": "sn2.6:8.1",
      "pali": "“Duggame visame vāpi,"
    },
    {
      "id": "sn2.6:8.2",
      "pali": "Ariyā gacchanti kāmada;"
    },
    {
      "id": "sn2.6:8.3",
      "pali": "Anariyā visame magge,"
    },
    {
      "id": "sn2.6:8.4",
      "pali": "Papatanti avaṁsirā;"
    },
    {
      "id": "sn2.6:8.5",
      "pali": "Ariyānaṁ samo maggo,"
    },
    {
      "id": "sn2.6:8.6",
      "pali": "Ariyā hi visame samā”ti."
    }
  ]
}
