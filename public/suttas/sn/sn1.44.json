{
  "uid": "sn1.44",
  "title": "Ekamūlasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.44:1.1",
      "pali": "“Ekamūlaṁ dvirāvaṭṭaṁ,"
    },
    {
      "id": "sn1.44:1.2",
      "pali": "timalaṁ pañcapattharaṁ;"
    },
    {
      "id": "sn1.44:1.3",
      "pali": "Samuddaṁ dvādasāvaṭṭaṁ,"
    },
    {
      "id": "sn1.44:1.4",
      "pali": "pātālaṁ atarī isī”ti."
    }
  ]
}
