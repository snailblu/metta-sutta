{
  "uid": "snp3.8",
  "title": "Sallasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp3.8:1.1",
      "pali": "Animittamanaññātaṁ,"
    },
    {
      "id": "snp3.8:1.2",
      "pali": "maccānaṁ idha jīvitaṁ;"
    },
    {
      "id": "snp3.8:1.3",
      "pali": "Kasirañca parittañca,"
    },
    {
      "id": "snp3.8:1.4",
      "pali": "tañca dukkhena saṁyutaṁ."
    },
    {
      "id": "snp3.8:2.1",
      "pali": "Na hi so upakkamo atthi,"
    },
    {
      "id": "snp3.8:2.2",
      "pali": "yena jātā na miyyare;"
    },
    {
      "id": "snp3.8:2.3",
      "pali": "Jarampi patvā maraṇaṁ,"
    },
    {
      "id": "snp3.8:2.4",
      "pali": "evaṁdhammā hi pāṇino."
    },
    {
      "id": "snp3.8:3.1",
      "pali": "Phalānamiva pakkānaṁ,"
    },
    {
      "id": "snp3.8:3.2",
      "pali": "pāto patanato bhayaṁ;"
    },
    {
      "id": "snp3.8:3.3",
      "pali": "Evaṁ jātāna maccānaṁ,"
    },
    {
      "id": "snp3.8:3.4",
      "pali": "niccaṁ maraṇato bhayaṁ."
    },
    {
      "id": "snp3.8:4.1",
      "pali": "Yathāpi kumbhakārassa,"
    },
    {
      "id": "snp3.8:4.2",
      "pali": "katā mattikabhājanā;"
    },
    {
      "id": "snp3.8:4.3",
      "pali": "Sabbe bhedanapariyantā,"
    },
    {
      "id": "snp3.8:4.4",
      "pali": "evaṁ maccāna jīvitaṁ."
    },
    {
      "id": "snp3.8:5.1",
      "pali": "Daharā ca mahantā ca,"
    },
    {
      "id": "snp3.8:5.2",
      "pali": "ye bālā ye ca paṇḍitā;"
    },
    {
      "id": "snp3.8:5.3",
      "pali": "Sabbe maccuvasaṁ yanti,"
    },
    {
      "id": "snp3.8:5.4",
      "pali": "sabbe maccuparāyaṇā."
    },
    {
      "id": "snp3.8:6.1",
      "pali": "Tesaṁ maccuparetānaṁ,"
    },
    {
      "id": "snp3.8:6.2",
      "pali": "gacchataṁ paralokato;"
    },
    {
      "id": "snp3.8:6.3",
      "pali": "Na pitā tāyate puttaṁ,"
    },
    {
      "id": "snp3.8:6.4",
      "pali": "ñātī vā pana ñātake."
    },
    {
      "id": "snp3.8:7.1",
      "pali": "Pekkhataṁyeva ñātīnaṁ,"
    },
    {
      "id": "snp3.8:7.2",
      "pali": "passa lālapataṁ puthu;"
    },
    {
      "id": "snp3.8:7.3",
      "pali": "Ekamekova maccānaṁ,"
    },
    {
      "id": "snp3.8:7.4",
      "pali": "govajjho viya nīyati."
    },
    {
      "id": "snp3.8:8.1",
      "pali": "Evamabbhāhato loko,"
    },
    {
      "id": "snp3.8:8.2",
      "pali": "Maccunā ca jarāya ca;"
    },
    {
      "id": "snp3.8:8.3",
      "pali": "Tasmā dhīrā na socanti,"
    },
    {
      "id": "snp3.8:8.4",
      "pali": "Viditvā lokapariyāyaṁ."
    },
    {
      "id": "snp3.8:9.1",
      "pali": "Yassa maggaṁ na jānāsi,"
    },
    {
      "id": "snp3.8:9.2",
      "pali": "āgatassa gatassa vā;"
    },
    {
      "id": "snp3.8:9.3",
      "pali": "Ubho ante asampassaṁ,"
    },
    {
      "id": "snp3.8:9.4",
      "pali": "niratthaṁ paridevasi."
    },
    {
      "id": "snp3.8:10.1",
      "pali": "Paridevayamāno ce,"
    },
    {
      "id": "snp3.8:10.2",
      "pali": "Kiñcidatthaṁ udabbahe;"
    },
    {
      "id": "snp3.8:10.3",
      "pali": "Sammūḷho hiṁsamattānaṁ,"
    },
    {
      "id": "snp3.8:10.4",
      "pali": "Kayirā ce naṁ vicakkhaṇo."
    },
    {
      "id": "snp3.8:11.1",
      "pali": "Na hi ruṇṇena sokena,"
    },
    {
      "id": "snp3.8:11.2",
      "pali": "Santiṁ pappoti cetaso;"
    },
    {
      "id": "snp3.8:11.3",
      "pali": "Bhiyyassuppajjate dukkhaṁ,"
    },
    {
      "id": "snp3.8:11.4",
      "pali": "Sarīraṁ cupahaññati."
    },
    {
      "id": "snp3.8:12.1",
      "pali": "Kiso vivaṇṇo bhavati,"
    },
    {
      "id": "snp3.8:12.2",
      "pali": "Hiṁsamattānamattanā;"
    },
    {
      "id": "snp3.8:12.3",
      "pali": "Na tena petā pālenti,"
    },
    {
      "id": "snp3.8:12.4",
      "pali": "Niratthā paridevanā."
    },
    {
      "id": "snp3.8:13.1",
      "pali": "Sokamappajahaṁ jantu,"
    },
    {
      "id": "snp3.8:13.2",
      "pali": "Bhiyyo dukkhaṁ nigacchati;"
    },
    {
      "id": "snp3.8:13.3",
      "pali": "Anutthunanto kālaṅkataṁ,"
    },
    {
      "id": "snp3.8:13.4",
      "pali": "Sokassa vasamanvagū."
    },
    {
      "id": "snp3.8:14.1",
      "pali": "Aññepi passa gamine,"
    },
    {
      "id": "snp3.8:14.2",
      "pali": "Yathākammupage nare;"
    },
    {
      "id": "snp3.8:14.3",
      "pali": "Maccuno vasamāgamma,"
    },
    {
      "id": "snp3.8:14.4",
      "pali": "Phandantevidha pāṇino."
    },
    {
      "id": "snp3.8:15.1",
      "pali": "Yena yena hi maññanti,"
    },
    {
      "id": "snp3.8:15.2",
      "pali": "Tato taṁ hoti aññathā;"
    },
    {
      "id": "snp3.8:15.3",
      "pali": "Etādiso vinābhāvo,"
    },
    {
      "id": "snp3.8:15.4",
      "pali": "Passa lokassa pariyāyaṁ."
    },
    {
      "id": "snp3.8:16.1",
      "pali": "Api vassasataṁ jīve,"
    },
    {
      "id": "snp3.8:16.2",
      "pali": "Bhiyyo vā pana māṇavo;"
    },
    {
      "id": "snp3.8:16.3",
      "pali": "Ñātisaṅghā vinā hoti,"
    },
    {
      "id": "snp3.8:16.4",
      "pali": "Jahāti idha jīvitaṁ."
    },
    {
      "id": "snp3.8:17.1",
      "pali": "Tasmā arahato sutvā,"
    },
    {
      "id": "snp3.8:17.2",
      "pali": "Vineyya paridevitaṁ;"
    },
    {
      "id": "snp3.8:17.3",
      "pali": "Petaṁ kālaṅkataṁ disvā,"
    },
    {
      "id": "snp3.8:17.4",
      "pali": "Neso labbhā mayā iti."
    },
    {
      "id": "snp3.8:18.1",
      "pali": "Yathā saraṇamādittaṁ,"
    },
    {
      "id": "snp3.8:18.2",
      "pali": "Vārinā parinibbaye;"
    },
    {
      "id": "snp3.8:18.3",
      "pali": "Evampi dhīro sapañño,"
    },
    {
      "id": "snp3.8:18.4",
      "pali": "Paṇḍito kusalo naro;"
    },
    {
      "id": "snp3.8:18.5",
      "pali": "Khippamuppatitaṁ sokaṁ,"
    },
    {
      "id": "snp3.8:18.6",
      "pali": "Vāto tūlaṁva dhaṁsaye."
    },
    {
      "id": "snp3.8:19.1",
      "pali": "Paridevaṁ pajappañca,"
    },
    {
      "id": "snp3.8:19.2",
      "pali": "Domanassañca attano;"
    },
    {
      "id": "snp3.8:19.3",
      "pali": "Attano sukhamesāno,"
    },
    {
      "id": "snp3.8:19.4",
      "pali": "Abbahe sallamattano."
    },
    {
      "id": "snp3.8:20.1",
      "pali": "Abbūḷhasallo asito,"
    },
    {
      "id": "snp3.8:20.2",
      "pali": "santiṁ pappuyya cetaso;"
    },
    {
      "id": "snp3.8:20.3",
      "pali": "Sabbasokaṁ atikkanto,"
    },
    {
      "id": "snp3.8:20.4",
      "pali": "asoko hoti nibbutoti."
    },
    {
      "id": "snp3.8:20.5",
      "pali": "Sallasuttaṁ aṭṭhamaṁ."
    }
  ]
}
