{
  "uid": "sn1.74",
  "title": "Vuṭṭhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.74:1.1",
      "pali": "“Kiṁsu uppatataṁ seṭṭhaṁ,"
    },
    {
      "id": "sn1.74:1.2",
      "pali": "kiṁsu nipatataṁ varaṁ;"
    },
    {
      "id": "sn1.74:1.3",
      "pali": "Kiṁsu pavajamānānaṁ,"
    },
    {
      "id": "sn1.74:1.4",
      "pali": "kiṁsu pavadataṁ varan”ti."
    },
    {
      "id": "sn1.74:2.1",
      "pali": "“Bījaṁ uppatataṁ seṭṭhaṁ,"
    },
    {
      "id": "sn1.74:2.2",
      "pali": "vuṭṭhi nipatataṁ varā;"
    },
    {
      "id": "sn1.74:2.3",
      "pali": "Gāvo pavajamānānaṁ,"
    },
    {
      "id": "sn1.74:2.4",
      "pali": "putto pavadataṁ varo”ti."
    },
    {
      "id": "sn1.74:3.1",
      "pali": "“Vijjā uppatataṁ seṭṭhā,"
    },
    {
      "id": "sn1.74:3.2",
      "pali": "avijjā nipatataṁ varā;"
    },
    {
      "id": "sn1.74:3.3",
      "pali": "Saṅgho pavajamānānaṁ,"
    },
    {
      "id": "sn1.74:3.4",
      "pali": "buddho pavadataṁ varo”ti."
    }
  ]
}
