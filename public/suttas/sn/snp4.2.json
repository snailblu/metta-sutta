{
  "uid": "snp4.2",
  "title": "Guhaṭṭhakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.2:1.1",
      "pali": "Satto guhāyaṁ bahunābhichanno,"
    },
    {
      "id": "snp4.2:1.2",
      "pali": "Tiṭṭhaṁ naro mohanasmiṁ pagāḷho;"
    },
    {
      "id": "snp4.2:1.3",
      "pali": "Dūre vivekā hi tathāvidho so,"
    },
    {
      "id": "snp4.2:1.4",
      "pali": "Kāmā hi loke na hi suppahāyā."
    },
    {
      "id": "snp4.2:2.1",
      "pali": "Icchānidānā bhavasātabaddhā,"
    },
    {
      "id": "snp4.2:2.2",
      "pali": "Te duppamuñcā na hi aññamokkhā;"
    },
    {
      "id": "snp4.2:2.3",
      "pali": "Pacchā pure vāpi apekkhamānā,"
    },
    {
      "id": "snp4.2:2.4",
      "pali": "Ime va kāme purime va jappaṁ."
    },
    {
      "id": "snp4.2:3.1",
      "pali": "Kāmesu giddhā pasutā pamūḷhā,"
    },
    {
      "id": "snp4.2:3.2",
      "pali": "Avadāniyā te visame niviṭṭhā;"
    },
    {
      "id": "snp4.2:3.3",
      "pali": "Dukkhūpanītā paridevayanti,"
    },
    {
      "id": "snp4.2:3.4",
      "pali": "Kiṁsū bhavissāma ito cutāse."
    },
    {
      "id": "snp4.2:4.1",
      "pali": "Tasmā hi sikkhetha idheva jantu,"
    },
    {
      "id": "snp4.2:4.2",
      "pali": "Yaṁ kiñci jaññā visamanti loke;"
    },
    {
      "id": "snp4.2:4.3",
      "pali": "Na tassa hetū visamaṁ careyya,"
    },
    {
      "id": "snp4.2:4.4",
      "pali": "Appañhidaṁ jīvitamāhu dhīrā."
    },
    {
      "id": "snp4.2:5.1",
      "pali": "Passāmi loke pariphandamānaṁ,"
    },
    {
      "id": "snp4.2:5.2",
      "pali": "Pajaṁ imaṁ taṇhagataṁ bhavesu;"
    },
    {
      "id": "snp4.2:5.3",
      "pali": "Hīnā narā maccumukhe lapanti,"
    },
    {
      "id": "snp4.2:5.4",
      "pali": "Avītataṇhāse bhavābhavesu."
    },
    {
      "id": "snp4.2:6.1",
      "pali": "Mamāyite passatha phandamāne,"
    },
    {
      "id": "snp4.2:6.2",
      "pali": "Maccheva appodake khīṇasote;"
    },
    {
      "id": "snp4.2:6.3",
      "pali": "Etampi disvā amamo careyya,"
    },
    {
      "id": "snp4.2:6.4",
      "pali": "Bhavesu āsattimakubbamāno."
    },
    {
      "id": "snp4.2:7.1",
      "pali": "Ubhosu antesu vineyya chandaṁ,"
    },
    {
      "id": "snp4.2:7.2",
      "pali": "Phassaṁ pariññāya anānugiddho;"
    },
    {
      "id": "snp4.2:7.3",
      "pali": "Yadattagarahī tadakubbamāno,"
    },
    {
      "id": "snp4.2:7.4",
      "pali": "Na lippatī diṭṭhasutesu dhīro."
    },
    {
      "id": "snp4.2:8.1",
      "pali": "Saññaṁ pariññā vitareyya oghaṁ,"
    },
    {
      "id": "snp4.2:8.2",
      "pali": "Pariggahesu muni nopalitto;"
    },
    {
      "id": "snp4.2:8.3",
      "pali": "Abbūḷhasallo caramappamatto,"
    },
    {
      "id": "snp4.2:8.4",
      "pali": "Nāsīsatī lokamimaṁ parañcāti."
    },
    {
      "id": "snp4.2:8.5",
      "pali": "Guhaṭṭhakasuttaṁ dutiyaṁ."
    }
  ]
}
