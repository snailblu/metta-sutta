{
  "uid": "sn1.30",
  "title": "Eṇijaṅghasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.30:1.1",
      "pali": "“Eṇijaṅghaṁ kisaṁ vīraṁ,"
    },
    {
      "id": "sn1.30:1.2",
      "pali": "appāhāraṁ alolupaṁ;"
    },
    {
      "id": "sn1.30:1.3",
      "pali": "Sīhaṁvekacaraṁ nāgaṁ,"
    },
    {
      "id": "sn1.30:1.4",
      "pali": "kāmesu anapekkhinaṁ;"
    },
    {
      "id": "sn1.30:1.5",
      "pali": "Upasaṅkamma pucchāma,"
    },
    {
      "id": "sn1.30:1.6",
      "pali": "kathaṁ dukkhā pamuccatī”ti."
    },
    {
      "id": "sn1.30:2.1",
      "pali": "“Pañca kāmaguṇā loke,"
    },
    {
      "id": "sn1.30:2.2",
      "pali": "manochaṭṭhā paveditā;"
    },
    {
      "id": "sn1.30:2.3",
      "pali": "Ettha chandaṁ virājetvā,"
    },
    {
      "id": "sn1.30:2.4",
      "pali": "evaṁ dukkhā pamuccatī”ti."
    },
    {
      "id": "sn1.30:2.5",
      "pali": "Sattivaggo tatiyo."
    },
    {
      "id": "sn1.30:3.1",
      "pali": "Sattiyā phusati ceva,"
    },
    {
      "id": "sn1.30:3.2",
      "pali": "jaṭā manonivāraṇā;"
    },
    {
      "id": "sn1.30:3.3",
      "pali": "Arahantena pajjoto,"
    },
    {
      "id": "sn1.30:3.4",
      "pali": "sarā mahaddhanena ca;"
    },
    {
      "id": "sn1.30:3.5",
      "pali": "Catucakkena navamaṁ,"
    },
    {
      "id": "sn1.30:3.6",
      "pali": "eṇijaṅghena te dasāti."
    }
  ]
}
