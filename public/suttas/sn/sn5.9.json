{
  "uid": "sn5.9",
  "title": "Selāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.9:1.2",
      "pali": "Atha kho selā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.9:1.3",
      "pali": "aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.9:1.4",
      "pali": "Atha kho māro pāpimā selāya bhikkhuniyā bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo …pe…"
    },
    {
      "id": "sn5.9:1.5",
      "pali": "selaṁ bhikkhuniṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn5.9:2.1",
      "pali": "“Kenidaṁ pakataṁ bimbaṁ,"
    },
    {
      "id": "sn5.9:2.2",
      "pali": "kvanu bimbassa kārako;"
    },
    {
      "id": "sn5.9:2.3",
      "pali": "Kvanu bimbaṁ samuppannaṁ,"
    },
    {
      "id": "sn5.9:2.4",
      "pali": "kvanu bimbaṁ nirujjhatī”ti."
    },
    {
      "id": "sn5.9:3.1",
      "pali": "Atha kho selāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.9:3.2",
      "pali": "“ko nu khvāyaṁ manusso vā amanusso vā gāthaṁ bhāsatī”ti?"
    },
    {
      "id": "sn5.9:3.3",
      "pali": "Atha kho selāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.9:3.4",
      "pali": "“māro kho ayaṁ pāpimā mama bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo gāthaṁ bhāsatī”ti."
    },
    {
      "id": "sn5.9:3.5",
      "pali": "Atha kho selā bhikkhunī “māro ayaṁ pāpimā” iti viditvā māraṁ pāpimantaṁ gāthāhi paccabhāsi:"
    },
    {
      "id": "sn5.9:4.1",
      "pali": "“Nayidaṁ attakataṁ bimbaṁ,"
    },
    {
      "id": "sn5.9:4.2",
      "pali": "nayidaṁ parakataṁ aghaṁ;"
    },
    {
      "id": "sn5.9:4.3",
      "pali": "Hetuṁ paṭicca sambhūtaṁ,"
    },
    {
      "id": "sn5.9:4.4",
      "pali": "hetubhaṅgā nirujjhati."
    },
    {
      "id": "sn5.9:5.1",
      "pali": "Yathā aññataraṁ bījaṁ,"
    },
    {
      "id": "sn5.9:5.2",
      "pali": "khette vuttaṁ virūhati;"
    },
    {
      "id": "sn5.9:5.3",
      "pali": "Pathavīrasañcāgamma,"
    },
    {
      "id": "sn5.9:5.4",
      "pali": "sinehañca tadūbhayaṁ."
    },
    {
      "id": "sn5.9:6.1",
      "pali": "Evaṁ khandhā ca dhātuyo,"
    },
    {
      "id": "sn5.9:6.2",
      "pali": "cha ca āyatanā ime;"
    },
    {
      "id": "sn5.9:6.3",
      "pali": "Hetuṁ paṭicca sambhūtā,"
    },
    {
      "id": "sn5.9:6.4",
      "pali": "hetubhaṅgā nirujjhare”ti."
    },
    {
      "id": "sn5.9:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ selā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
