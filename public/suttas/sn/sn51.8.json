{
  "uid": "sn51.8",
  "title": "Buddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.8:1.1",
      "pali": "“Cattārome, bhikkhave, iddhipādā."
    },
    {
      "id": "sn51.8:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.8:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.8:1.4",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.8:1.5",
      "pali": "cittasamādhi …pe…"
    },
    {
      "id": "sn51.8:1.6",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn51.8:1.7",
      "pali": "Ime kho, bhikkhave, cattāro iddhipādā."
    },
    {
      "id": "sn51.8:1.8",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ iddhipādānaṁ bhāvitattā bahulīkatattā tathāgato ‘arahaṁ sammāsambuddho’ti vuccatī”ti."
    },
    {
      "id": "sn51.8:1.9",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
