{
  "uid": "sn31.23-112",
  "title": "Sāragandhādidānūpakārasuttanavutika",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn31.23-112:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn31.23-112:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn31.23-112:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā sāragandhe adhivatthānaṁ devānaṁ …pe…"
    },
    {
      "id": "sn31.23-112:1.4",
      "pali": "pheggugandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.5",
      "pali": "tacagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.6",
      "pali": "papaṭikagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.7",
      "pali": "pattagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.8",
      "pali": "pupphagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.9",
      "pali": "phalagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.10",
      "pali": "rasagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.23-112:1.11",
      "pali": "gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn31.23-112:1.12",
      "pali": "“Idha, bhikkhu, ekacco kāyena sucaritaṁ carati, vācāya sucaritaṁ carati, manasā sucaritaṁ carati."
    },
    {
      "id": "sn31.23-112:1.13",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn31.23-112:1.14",
      "pali": "‘gandhagandhe adhivatthā devā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn31.23-112:1.15",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn31.23-112:1.16",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn31.23-112:1.17",
      "pali": "So annaṁ deti …pe…"
    },
    {
      "id": "sn31.23-112:1.18",
      "pali": "pānaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.19",
      "pali": "vatthaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.20",
      "pali": "yānaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.21",
      "pali": "mālaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.22",
      "pali": "gandhaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.23",
      "pali": "vilepanaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.24",
      "pali": "seyyaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.25",
      "pali": "āvasathaṁ deti …"
    },
    {
      "id": "sn31.23-112:1.26",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn31.23-112:1.27",
      "pali": "So kāyassa bhedā paraṁ maraṇā gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn31.23-112:1.28",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn31.23-112:1.29",
      "pali": "Dvādasasatimaṁ."
    },
    {
      "id": "sn31.23-112:2.1",
      "pali": "(Evaṁ piṇḍakena ekasatañca dvādasa ca suttantā honti.)"
    },
    {
      "id": "sn31.23-112:2.2",
      "pali": "Gandhabbavaggo paṭhamo."
    },
    {
      "id": "sn31.23-112:3.1",
      "pali": "Suddhikañca sucaritaṁ,"
    },
    {
      "id": "sn31.23-112:3.2",
      "pali": "dātā hi apare dasa;"
    },
    {
      "id": "sn31.23-112:3.3",
      "pali": "Dānūpakārā satadhā,"
    },
    {
      "id": "sn31.23-112:3.4",
      "pali": "gandhabbe suppakāsitāti."
    },
    {
      "id": "sn31.23-112:3.5",
      "pali": "Gandhabbakāyasaṁyuttaṁ samattaṁ."
    }
  ]
}
