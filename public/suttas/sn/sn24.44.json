{
  "uid": "sn24.44",
  "title": "Adukkhamasukhīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.44:1.1",
      "pali": "“Adukkhamasukhī attā hoti arogo paraṁ maraṇā”ti?"
    },
    {
      "id": "sn24.44:1.2",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.44:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.44:2.2",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.44:2.3",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn24.44:2.4",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.44:2.5",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.44:2.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.44:2.7",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.44:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave, rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.44:3.2",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.44:3.3",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.44:3.4",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.44:3.5",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.44:3.6",
      "pali": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.44:3.7",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.44:3.8",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn24.44:3.9",
      "pali": "saññā …"
    },
    {
      "id": "sn24.44:3.10",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.44:3.11",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.44:3.12",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.44:3.13",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.44:3.14",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.44:3.15",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.44:3.16",
      "pali": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.44:3.17",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.44:3.18",
      "pali": "Chabbīsatimaṁ."
    },
    {
      "id": "sn24.44:3.19",
      "pali": "Dutiyapeyyālo."
    },
    {
      "id": "sn24.44:4.1",
      "pali": "Vātaṁ etaṁ mama so,"
    },
    {
      "id": "sn24.44:4.2",
      "pali": "attā no ca me siyā;"
    },
    {
      "id": "sn24.44:4.3",
      "pali": "Natthi karoto hetu ca,"
    },
    {
      "id": "sn24.44:4.4",
      "pali": "mahādiṭṭhena aṭṭhamaṁ."
    },
    {
      "id": "sn24.44:5.1",
      "pali": "Sassato asassato ceva,"
    },
    {
      "id": "sn24.44:5.2",
      "pali": "antānantavā ca vuccati;"
    },
    {
      "id": "sn24.44:5.3",
      "pali": "Taṁ jīvaṁ aññaṁ jīvañca,"
    },
    {
      "id": "sn24.44:5.4",
      "pali": "tathāgatena cattāro."
    },
    {
      "id": "sn24.44:6.1",
      "pali": "Rūpī attā hoti arūpī ca attā hoti,"
    },
    {
      "id": "sn24.44:6.2",
      "pali": "Rūpī ca arūpī ca attā hoti;"
    },
    {
      "id": "sn24.44:6.3",
      "pali": "Neva rūpī nārūpī attā hoti,"
    },
    {
      "id": "sn24.44:6.4",
      "pali": "Ekantasukhī attā hoti."
    },
    {
      "id": "sn24.44:7.1",
      "pali": "Ekantadukkhī attā hoti,"
    },
    {
      "id": "sn24.44:7.2",
      "pali": "Sukhadukkhī attā hoti;"
    },
    {
      "id": "sn24.44:7.3",
      "pali": "Adukkhamasukhī attā hoti,"
    },
    {
      "id": "sn24.44:7.4",
      "pali": "Arogo paraṁ maraṇāti;"
    },
    {
      "id": "sn24.44:7.5",
      "pali": "Ime chabbīsati suttā,"
    },
    {
      "id": "sn24.44:7.6",
      "pali": "Dutiyavārena desitā."
    }
  ]
}
