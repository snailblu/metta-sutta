{
  "uid": "sn35.73",
  "title": "Tatiyachaphassāyatanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.73:1.1",
      "pali": "“Yo hi koci, bhikkhave, bhikkhu channaṁ phassāyatanānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn35.73:1.2",
      "pali": "Avusitaṁ tena brahmacariyaṁ, ārakā so imasmā dhammavinayā”ti."
    },
    {
      "id": "sn35.73:2.1",
      "pali": "Evaṁ vutte, aññataro bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn35.73:2.2",
      "pali": "“etthāhaṁ, bhante, anassasaṁ panassasaṁ."
    },
    {
      "id": "sn35.73:2.3",
      "pali": "Ahañhi, bhante, channaṁ phassāyatanānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāmī”ti."
    },
    {
      "id": "sn35.73:3.1",
      "pali": "“Taṁ kiṁ maññasi, bhikkhu,"
    },
    {
      "id": "sn35.73:3.2",
      "pali": "cakkhu niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.73:4.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.73:5.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.73:6.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.73:7.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.73:7.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.73:8.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.73:9.1",
      "pali": "“Sotaṁ …"
    },
    {
      "id": "sn35.73:9.2",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn35.73:9.3",
      "pali": "jivhā …"
    },
    {
      "id": "sn35.73:9.4",
      "pali": "kāyo …"
    },
    {
      "id": "sn35.73:9.5",
      "pali": "mano nicco vā anicco vā”ti?"
    },
    {
      "id": "sn35.73:10.1",
      "pali": "“Anicco, bhante”."
    },
    {
      "id": "sn35.73:11.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.73:12.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.73:13.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.73:13.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.73:14.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.73:15.1",
      "pali": "“Evaṁ passaṁ, bhikkhu, sutavā ariyasāvako cakkhusmimpi nibbindati, sotasmimpi nibbindati, ghānasmimpi nibbindati, jivhāyapi nibbindati, kāyasmimpi nibbindati, manasmimpi nibbindati."
    },
    {
      "id": "sn35.73:15.2",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn35.73:15.3",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.73:15.4",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn35.73:15.5",
      "pali": "Migajālavaggo dutiyo."
    },
    {
      "id": "sn35.73:16.1",
      "pali": "Migajālena dve vuttā,"
    },
    {
      "id": "sn35.73:16.2",
      "pali": "Cattāro ca samiddhinā;"
    },
    {
      "id": "sn35.73:16.3",
      "pali": "Upaseno upavāṇo,"
    },
    {
      "id": "sn35.73:16.4",
      "pali": "Chaphassāyatanikā tayoti."
    }
  ]
}
