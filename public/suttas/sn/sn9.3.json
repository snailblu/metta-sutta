{
  "uid": "sn9.3",
  "title": "Kassapagottasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.3:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā kassapagotto kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.3:1.2",
      "pali": "Tena kho pana samayena āyasmā kassapagotto divāvihāragato aññataraṁ chetaṁ ovadati."
    },
    {
      "id": "sn9.3:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā āyasmantaṁ kassapagottaṁ saṁvejetukāmā yenāyasmā kassapagotto tenupasaṅkami; upasaṅkamitvā āyasmantaṁ kassapagottaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn9.3:2.1",
      "pali": "“Giriduggacaraṁ chetaṁ,"
    },
    {
      "id": "sn9.3:2.2",
      "pali": "appapaññaṁ acetasaṁ;"
    },
    {
      "id": "sn9.3:2.3",
      "pali": "Akāle ovadaṁ bhikkhu,"
    },
    {
      "id": "sn9.3:2.4",
      "pali": "mandova paṭibhāti maṁ."
    },
    {
      "id": "sn9.3:3.1",
      "pali": "Suṇāti na vijānāti,"
    },
    {
      "id": "sn9.3:3.2",
      "pali": "Āloketi na passati;"
    },
    {
      "id": "sn9.3:3.3",
      "pali": "Dhammasmiṁ bhaññamānasmiṁ,"
    },
    {
      "id": "sn9.3:3.4",
      "pali": "Atthaṁ bālo na bujjhati."
    },
    {
      "id": "sn9.3:4.1",
      "pali": "Sacepi dasa pajjote,"
    },
    {
      "id": "sn9.3:4.2",
      "pali": "dhārayissasi kassapa;"
    },
    {
      "id": "sn9.3:4.3",
      "pali": "Neva dakkhati rūpāni,"
    },
    {
      "id": "sn9.3:4.4",
      "pali": "cakkhu hissa na vijjatī”ti."
    },
    {
      "id": "sn9.3:5.1",
      "pali": "Atha kho āyasmā kassapagotto tāya devatāya saṁvejito saṁvegamāpādīti."
    }
  ]
}
