{
  "uid": "sn5.6",
  "title": "Cālāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.6:1.2",
      "pali": "Atha kho cālā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.6:1.3",
      "pali": "aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.6:1.4",
      "pali": "Atha kho māro pāpimā yena cālā bhikkhunī tenupasaṅkami; upasaṅkamitvā cālaṁ bhikkhuniṁ etadavoca:"
    },
    {
      "id": "sn5.6:1.5",
      "pali": "“kiṁ nu tvaṁ, bhikkhuni, na rocesī”ti?"
    },
    {
      "id": "sn5.6:1.6",
      "pali": "“Jātiṁ khvāhaṁ, āvuso, na rocemī”ti."
    },
    {
      "id": "sn5.6:2.1",
      "pali": "“Kiṁ nu jātiṁ na rocesi,"
    },
    {
      "id": "sn5.6:2.2",
      "pali": "jāto kāmāni bhuñjati;"
    },
    {
      "id": "sn5.6:2.3",
      "pali": "Ko nu taṁ idamādapayi,"
    },
    {
      "id": "sn5.6:2.4",
      "pali": "jātiṁ mā roca bhikkhunī”ti."
    },
    {
      "id": "sn5.6:3.1",
      "pali": "“Jātassa maraṇaṁ hoti,"
    },
    {
      "id": "sn5.6:3.2",
      "pali": "jāto dukkhāni phussati;"
    },
    {
      "id": "sn5.6:3.3",
      "pali": "Bandhaṁ vadhaṁ pariklesaṁ,"
    },
    {
      "id": "sn5.6:3.4",
      "pali": "tasmā jātiṁ na rocaye."
    },
    {
      "id": "sn5.6:4.1",
      "pali": "Buddho dhammamadesesi,"
    },
    {
      "id": "sn5.6:4.2",
      "pali": "jātiyā samatikkamaṁ;"
    },
    {
      "id": "sn5.6:4.3",
      "pali": "Sabbadukkhappahānāya,"
    },
    {
      "id": "sn5.6:4.4",
      "pali": "so maṁ sacce nivesayi."
    },
    {
      "id": "sn5.6:5.1",
      "pali": "Ye ca rūpūpagā sattā,"
    },
    {
      "id": "sn5.6:5.2",
      "pali": "ye ca arūpaṭṭhāyino;"
    },
    {
      "id": "sn5.6:5.3",
      "pali": "Nirodhaṁ appajānantā,"
    },
    {
      "id": "sn5.6:5.4",
      "pali": "āgantāro punabbhavan”ti."
    },
    {
      "id": "sn5.6:6.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ cālā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
