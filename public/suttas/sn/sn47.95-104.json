{
  "uid": "sn47.95-104",
  "title": "Uddhambhāgiyādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.95-104:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn47.95-104:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn47.95-104:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn47.95-104:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn47.95-104:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya cattāro satipaṭṭhānā bhāvetabbā."
    },
    {
      "id": "sn47.95-104:2.1",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn47.95-104:2.2",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.95-104:2.3",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.95-104:2.4",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.95-104:2.5",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.95-104:2.6",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "sn47.95-104:2.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn47.95-104:3.1",
      "pali": "(Yathā maggasaṁyuttaṁ tathā satipaṭṭhānasaṁyuttaṁ vitthāretabbaṁ.)"
    },
    {
      "id": "sn47.95-104:3.2",
      "pali": "Oghavaggo dasamo."
    },
    {
      "id": "sn47.95-104:4.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn47.95-104:4.2",
      "pali": "ganthā anusayena ca;"
    },
    {
      "id": "sn47.95-104:4.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn47.95-104:4.4",
      "pali": "khandhā oruddhambhāgiyāti."
    },
    {
      "id": "sn47.95-104:4.5",
      "pali": "Satipaṭṭhānasaṁyuttaṁ tatiyaṁ."
    }
  ]
}
