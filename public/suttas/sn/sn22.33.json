{
  "uid": "sn22.33",
  "title": "Natumhākasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.33:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.33:1.2",
      "pali": "“Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:1.3",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:1.4",
      "pali": "Kiñca, bhikkhave, na tumhākaṁ?"
    },
    {
      "id": "sn22.33:1.5",
      "pali": "Rūpaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:1.6",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:1.7",
      "pali": "Vedanā na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:1.8",
      "pali": "Sā vo pahīnā hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:1.9",
      "pali": "Saññā na tumhākaṁ …"
    },
    {
      "id": "sn22.33:1.10",
      "pali": "saṅkhārā na tumhākaṁ, te pajahatha."
    },
    {
      "id": "sn22.33:1.11",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn22.33:1.12",
      "pali": "Viññāṇaṁ na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:1.13",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:2.1",
      "pali": "Seyyathāpi, bhikkhave, yaṁ imasmiṁ jetavane tiṇakaṭṭhasākhāpalāsaṁ taṁ jano hareyya vā ḍaheyya vā yathāpaccayaṁ vā kareyya."
    },
    {
      "id": "sn22.33:2.2",
      "pali": "Api nu tumhākaṁ evamassa:"
    },
    {
      "id": "sn22.33:2.3",
      "pali": "‘amhe jano harati vā ḍahati vā yathāpaccayaṁ vā karotī’”ti?"
    },
    {
      "id": "sn22.33:2.4",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.33:2.5",
      "pali": "“Taṁ kissa hetu”?"
    },
    {
      "id": "sn22.33:2.6",
      "pali": "“Na hi no etaṁ, bhante, attā vā attaniyaṁ vā”ti."
    },
    {
      "id": "sn22.33:2.7",
      "pali": "“Evameva kho, bhikkhave, rūpaṁ na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:2.8",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:2.9",
      "pali": "Vedanā na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:2.10",
      "pali": "Sā vo pahīnā hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.33:2.11",
      "pali": "Saññā na tumhākaṁ …"
    },
    {
      "id": "sn22.33:2.12",
      "pali": "saṅkhārā na tumhākaṁ …"
    },
    {
      "id": "sn22.33:2.13",
      "pali": "viññāṇaṁ na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.33:2.14",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissatī”ti."
    },
    {
      "id": "sn22.33:2.15",
      "pali": "Paṭhamaṁ."
    }
  ]
}
