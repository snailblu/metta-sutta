{
  "uid": "sn12.34",
  "title": "Dutiyañāṇavatthusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.34:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.34:1.2",
      "pali": "“Sattasattari vo, bhikkhave, ñāṇavatthūni desessāmi."
    },
    {
      "id": "sn12.34:1.3",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.34:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.34:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.34:2.1",
      "pali": "“Katamāni, bhikkhave, sattasattari ñāṇavatthūni?"
    },
    {
      "id": "sn12.34:2.2",
      "pali": "Jātipaccayā jarāmaraṇanti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:2.3",
      "pali": "asati jātiyā natthi jarāmaraṇanti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:2.4",
      "pali": "atītampi addhānaṁ jātipaccayā jarāmaraṇanti ñāṇaṁ, asati jātiyā natthi jarāmaraṇanti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:2.5",
      "pali": "anāgatampi addhānaṁ jātipaccayā jarāmaraṇanti ñāṇaṁ, asati jātiyā natthi jarāmaraṇanti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:2.6",
      "pali": "yampissa taṁ dhammaṭṭhitiñāṇaṁ tampi khayadhammaṁ vayadhammaṁ virāgadhammaṁ nirodhadhammanti ñāṇaṁ."
    },
    {
      "id": "sn12.34:3.1",
      "pali": "Bhavapaccayā jātīti ñāṇaṁ …pe…"
    },
    {
      "id": "sn12.34:3.2",
      "pali": "upādānapaccayā bhavoti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.3",
      "pali": "taṇhāpaccayā upādānanti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.4",
      "pali": "vedanāpaccayā taṇhāti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.5",
      "pali": "phassapaccayā vedanāti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.6",
      "pali": "saḷāyatanapaccayā phassoti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.7",
      "pali": "nāmarūpapaccayā saḷāyatananti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.8",
      "pali": "viññāṇapaccayā nāmarūpanti ñāṇaṁ …"
    },
    {
      "id": "sn12.34:3.9",
      "pali": "saṅkhārapaccayā viññāṇanti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:3.10",
      "pali": "avijjāpaccayā saṅkhārāti ñāṇaṁ, asati avijjāya natthi saṅkhārāti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:3.11",
      "pali": "atītampi addhānaṁ avijjāpaccayā saṅkhārāti ñāṇaṁ, asati avijjāya natthi saṅkhārāti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:3.12",
      "pali": "anāgatampi addhānaṁ avijjāpaccayā saṅkhārāti ñāṇaṁ, asati avijjāya natthi saṅkhārāti ñāṇaṁ;"
    },
    {
      "id": "sn12.34:3.13",
      "pali": "yampissa taṁ dhammaṭṭhitiñāṇaṁ tampi khayadhammaṁ vayadhammaṁ virāgadhammaṁ nirodhadhammanti ñāṇaṁ."
    },
    {
      "id": "sn12.34:3.14",
      "pali": "Imāni vuccanti, bhikkhave, sattasattari ñāṇavatthūnī”ti."
    },
    {
      "id": "sn12.34:3.15",
      "pali": "Catutthaṁ."
    }
  ]
}
