{
  "uid": "sn22.153",
  "title": "Nocamesiyāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.153:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.153:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.153:1.3",
      "pali": "‘no cassaṁ, no ca me siyā, nābhavissa, na me bhavissatī’”ti?"
    },
    {
      "id": "sn22.153:1.4",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.153:1.5",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.153:1.6",
      "pali": "‘no cassaṁ, no ca me siyā, nābhavissa, na me bhavissatī’ti."
    },
    {
      "id": "sn22.153:1.7",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn22.153:1.8",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn22.153:1.9",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn22.153:1.10",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa, evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.153:1.11",
      "pali": "‘no cassaṁ, no ca me siyā, nābhavissa, na me bhavissatī’ti."
    },
    {
      "id": "sn22.153:1.12",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.153:1.13",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.153:1.14",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.15",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.153:1.16",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.17",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn22.153:1.18",
      "pali": "‘no cassaṁ, no ca me siyā, nābhavissa, na me bhavissatī’”ti?"
    },
    {
      "id": "sn22.153:1.19",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.20",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn22.153:1.21",
      "pali": "saññā …"
    },
    {
      "id": "sn22.153:1.22",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.153:1.23",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.153:1.24",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.25",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.153:1.26",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.27",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn22.153:1.28",
      "pali": "‘no cassaṁ, no ca me siyā, nābhavissa, na me bhavissatī’”ti?"
    },
    {
      "id": "sn22.153:1.29",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.153:1.30",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.153:1.31",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.153:1.32",
      "pali": "Catutthaṁ."
    }
  ]
}
