{
  "uid": "sn45.38",
  "title": "Dutiyabrahmaññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.38:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.38:1.2",
      "pali": "“Brahmaññañca vo, bhikkhave, desessāmi, brahmaññatthañca."
    },
    {
      "id": "sn45.38:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.38:1.4",
      "pali": "Katamañca, bhikkhave, brahmaññaṁ?"
    },
    {
      "id": "sn45.38:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.38:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.38:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, brahmaññaṁ."
    },
    {
      "id": "sn45.38:1.8",
      "pali": "Katamo ca, bhikkhave, brahmaññattho?"
    },
    {
      "id": "sn45.38:1.9",
      "pali": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.38:1.10",
      "pali": "ayaṁ vuccati, bhikkhave, brahmaññattho”ti."
    },
    {
      "id": "sn45.38:1.11",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
