{
  "uid": "sn3.16",
  "title": "Mallikāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn3.16:1.2",
      "pali": "Atha kho rājā pasenadi kosalo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi."
    },
    {
      "id": "sn3.16:1.3",
      "pali": "Atha kho aññataro puriso yena rājā pasenadi kosalo tenupasaṅkami; upasaṅkamitvā rañño pasenadissa kosalassa upakaṇṇake ārocesi:"
    },
    {
      "id": "sn3.16:1.4",
      "pali": "“mallikā, deva, devī dhītaraṁ vijātā”ti."
    },
    {
      "id": "sn3.16:1.5",
      "pali": "Evaṁ vutte, rājā pasenadi kosalo anattamano ahosi."
    },
    {
      "id": "sn3.16:2.1",
      "pali": "Atha kho bhagavā rājānaṁ pasenadiṁ kosalaṁ anattamanataṁ viditvā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn3.16:3.1",
      "pali": "“Itthīpi hi ekacciyā,"
    },
    {
      "id": "sn3.16:3.2",
      "pali": "seyyā posa janādhipa;"
    },
    {
      "id": "sn3.16:3.3",
      "pali": "Medhāvinī sīlavatī,"
    },
    {
      "id": "sn3.16:3.4",
      "pali": "sassudevā patibbatā."
    },
    {
      "id": "sn3.16:4.1",
      "pali": "Tassā yo jāyati poso,"
    },
    {
      "id": "sn3.16:4.2",
      "pali": "sūro hoti disampati;"
    },
    {
      "id": "sn3.16:4.3",
      "pali": "Tādisā subhagiyā putto,"
    },
    {
      "id": "sn3.16:4.4",
      "pali": "rajjampi anusāsatī”ti."
    }
  ]
}
