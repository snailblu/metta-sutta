{
  "uid": "sn35.15",
  "title": "Paṭhamaassādapariyesanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.15:1.1",
      "pali": "“Cakkhussāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.2",
      "pali": "Yo cakkhussa assādo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.3",
      "pali": "Yāvatā cakkhussa assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.4",
      "pali": "Cakkhussāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.5",
      "pali": "Yo cakkhussa ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.6",
      "pali": "Yāvatā cakkhussa ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.7",
      "pali": "Cakkhussāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.8",
      "pali": "Yaṁ cakkhussa nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.9",
      "pali": "Yāvatā cakkhussa nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn35.15:1.10",
      "pali": "Sotassāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.15:1.11",
      "pali": "ghānassāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.15:1.12",
      "pali": "jivhāyāhaṁ bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.13",
      "pali": "Yo jivhāya assādo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.14",
      "pali": "Yāvatā jivhāya assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.15",
      "pali": "Jivhāyāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.16",
      "pali": "Yo jivhāya ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.17",
      "pali": "Yāvatā jivhāya ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.18",
      "pali": "Jivhāyāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.19",
      "pali": "Yaṁ jivhāya nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.20",
      "pali": "Yāvatā jivhāya nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ …pe…"
    },
    {
      "id": "sn35.15:1.21",
      "pali": "manassāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.22",
      "pali": "Yo manassa assādo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.23",
      "pali": "Yāvatā manassa assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.24",
      "pali": "Manassāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.25",
      "pali": "Yo manassa ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.26",
      "pali": "Yāvatā manassa ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.15:1.27",
      "pali": "Manassāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.15:1.28",
      "pali": "Yaṁ manassa nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn35.15:1.29",
      "pali": "Yāvatā manassa nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn35.15:2.1",
      "pali": "Yāvakīvañcāhaṁ, bhikkhave, imesaṁ channaṁ ajjhattikānaṁ āyatanānaṁ assādañca assādato, ādīnavañca ādīnavato, nissaraṇañca nissaraṇato yathābhūtaṁ nābbhaññāsiṁ …pe…"
    },
    {
      "id": "sn35.15:2.2",
      "pali": "paccaññāsiṁ."
    },
    {
      "id": "sn35.15:2.3",
      "pali": "Ñāṇañca pana me dassanaṁ udapādi:"
    },
    {
      "id": "sn35.15:2.4",
      "pali": "‘akuppā me vimutti, ayamantimā jāti, natthi dāni punabbhavo’”ti."
    },
    {
      "id": "sn35.15:2.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
