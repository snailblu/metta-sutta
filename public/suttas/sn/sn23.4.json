{
  "uid": "sn23.4",
  "title": "Pariññeyyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.4:1.2",
      "pali": "Āyasmā rādho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinnaṁ kho āyasmantaṁ rādhaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn23.4:2.1",
      "pali": "“Pariññeyye ca, rādha, dhamme desessāmi pariññañca pariññātāviṁ puggalañca."
    },
    {
      "id": "sn23.4:2.2",
      "pali": "Taṁ suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "sn23.4:2.3",
      "pali": "“Evaṁ, bhante”ti kho āyasmā rādho bhagavato paccassosi."
    },
    {
      "id": "sn23.4:2.4",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn23.4:2.5",
      "pali": "“katame ca, rādha, pariññeyyā dhammā?"
    },
    {
      "id": "sn23.4:2.6",
      "pali": "Rūpaṁ kho, rādha, pariññeyyo dhammo, vedanā pariññeyyo dhammo, saññā pariññeyyo dhammo, saṅkhārā pariññeyyo dhammo, viññāṇaṁ pariññeyyo dhammo."
    },
    {
      "id": "sn23.4:2.7",
      "pali": "Ime vuccanti, rādha, pariññeyyā dhammā."
    },
    {
      "id": "sn23.4:2.8",
      "pali": "Katamā ca, rādha, pariññā?"
    },
    {
      "id": "sn23.4:2.9",
      "pali": "Yo kho, rādha, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn23.4:2.10",
      "pali": "ayaṁ vuccati, rādha, pariññā."
    },
    {
      "id": "sn23.4:2.11",
      "pali": "Katamo ca, rādha, pariññātāvī puggalo?"
    },
    {
      "id": "sn23.4:2.12",
      "pali": "‘Arahā’tissa vacanīyaṁ."
    },
    {
      "id": "sn23.4:2.13",
      "pali": "Yvāyaṁ āyasmā evaṁnāmo evaṅgotto—"
    },
    {
      "id": "sn23.4:2.14",
      "pali": "ayaṁ vuccati, rādha, pariññātāvī puggalo”ti."
    },
    {
      "id": "sn23.4:2.15",
      "pali": "Catutthaṁ."
    }
  ]
}
