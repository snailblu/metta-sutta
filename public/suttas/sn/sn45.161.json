{
  "uid": "sn45.161",
  "title": "Esanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.161:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.161:1.2",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:1.3",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:1.4",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:1.5",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:1.6",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.161:1.7",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.161:1.8",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti vivekanissitaṁ …pe… sammāsamādhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn45.161:1.9",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:2.1",
      "pali": "Tisso imā kho, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:2.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:2.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:2.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.161:2.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.161:2.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti …pe… sammāsamādhiṁ bhāveti rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ."
    },
    {
      "id": "sn45.161:2.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:3.1",
      "pali": "Tisso imā kho, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:3.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:3.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:3.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:3.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.161:3.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.161:3.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti …pe… sammāsamādhiṁ bhāveti amatogadhaṁ amataparāyanaṁ amatapariyosānaṁ."
    },
    {
      "id": "sn45.161:3.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:4.1",
      "pali": "Tisso imā kho, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:4.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:4.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:4.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:4.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.161:4.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.161:4.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti …pe… sammāsamādhiṁ bhāveti nibbānaninnaṁ nibbānapoṇaṁ nibbānapabbhāraṁ."
    },
    {
      "id": "sn45.161:4.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:5.1",
      "pali": "Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:5.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:5.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:5.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:5.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ pariññāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:5.6",
      "pali": "(Yadapi abhiññā, tadapi pariññāya vitthāretabbaṁ.)"
    },
    {
      "id": "sn45.161:6.1",
      "pali": "Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:6.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:6.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:6.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:6.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ parikkhayāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.161:6.6",
      "pali": "(Yadapi abhiññā, tadapi parikkhayāya vitthāretabbaṁ.)"
    },
    {
      "id": "sn45.161:7.1",
      "pali": "Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn45.161:7.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.161:7.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn45.161:7.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn45.161:7.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ pahānāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.161:7.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.161:7.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti …pe… sammāsamādhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ …"
    },
    {
      "id": "sn45.161:7.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ pahānāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.161:7.9",
      "pali": "(Yadapi abhiññā, tadapi pahānāya vitthāretabbaṁ.)"
    },
    {
      "id": "sn45.161:7.10",
      "pali": "Paṭhamaṁ."
    }
  ]
}
