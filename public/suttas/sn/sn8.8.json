{
  "uid": "sn8.8",
  "title": "Parosahassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.8:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme mahatā bhikkhusaṅghena saddhiṁ aḍḍhatelasehi bhikkhusatehi."
    },
    {
      "id": "sn8.8:1.2",
      "pali": "Tena kho pana samayena bhagavā bhikkhū nibbānapaṭisaṁyuttāya dhammiyā kathāya sandasseti samādapeti samuttejeti sampahaṁseti."
    },
    {
      "id": "sn8.8:1.3",
      "pali": "Te ca bhikkhū aṭṭhiṁ katvā manasi katvā sabbacetasā samannāharitvā ohitasotā dhammaṁ suṇanti."
    },
    {
      "id": "sn8.8:1.4",
      "pali": "Atha kho āyasmato vaṅgīsassa etadahosi:"
    },
    {
      "id": "sn8.8:1.5",
      "pali": "“ayaṁ kho bhagavā bhikkhū nibbānapaṭisaṁyuttāya dhammiyā kathāya sandasseti samādapeti samuttejeti sampahaṁseti."
    },
    {
      "id": "sn8.8:1.6",
      "pali": "Te ca bhikkhū aṭṭhiṁ katvā manasi katvā sabbacetasā samannāharitvā ohitasotā dhammaṁ suṇanti."
    },
    {
      "id": "sn8.8:1.7",
      "pali": "Yannūnāhaṁ bhagavantaṁ sammukhā sāruppāhi gāthāhi abhitthaveyyan”ti."
    },
    {
      "id": "sn8.8:2.1",
      "pali": "Atha kho āyasmā vaṅgīso uṭṭhāyāsanā ekaṁsaṁ uttarāsaṅgaṁ karitvā yena bhagavā tenañjaliṁ paṇāmetvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn8.8:2.2",
      "pali": "“paṭibhāti maṁ, bhagavā, paṭibhāti maṁ, sugatā”ti."
    },
    {
      "id": "sn8.8:2.3",
      "pali": "“Paṭibhātu taṁ, vaṅgīsā”ti bhagavā avoca."
    },
    {
      "id": "sn8.8:2.4",
      "pali": "Atha kho āyasmā vaṅgīso bhagavantaṁ sammukhā sāruppāhi gāthāhi abhitthavi:"
    },
    {
      "id": "sn8.8:3.1",
      "pali": "“Parosahassaṁ bhikkhūnaṁ,"
    },
    {
      "id": "sn8.8:3.2",
      "pali": "sugataṁ payirupāsati;"
    },
    {
      "id": "sn8.8:3.3",
      "pali": "Desentaṁ virajaṁ dhammaṁ,"
    },
    {
      "id": "sn8.8:3.4",
      "pali": "nibbānaṁ akutobhayaṁ."
    },
    {
      "id": "sn8.8:4.1",
      "pali": "Suṇanti dhammaṁ vimalaṁ,"
    },
    {
      "id": "sn8.8:4.2",
      "pali": "sammāsambuddhadesitaṁ;"
    },
    {
      "id": "sn8.8:4.3",
      "pali": "Sobhati vata sambuddho,"
    },
    {
      "id": "sn8.8:4.4",
      "pali": "bhikkhusaṅghapurakkhato."
    },
    {
      "id": "sn8.8:5.1",
      "pali": "Nāganāmosi bhagavā,"
    },
    {
      "id": "sn8.8:5.2",
      "pali": "isīnaṁ isisattamo;"
    },
    {
      "id": "sn8.8:5.3",
      "pali": "Mahāmeghova hutvāna,"
    },
    {
      "id": "sn8.8:5.4",
      "pali": "sāvake abhivassati."
    },
    {
      "id": "sn8.8:6.1",
      "pali": "Divāvihārā nikkhamma,"
    },
    {
      "id": "sn8.8:6.2",
      "pali": "satthudassanakamyatā;"
    },
    {
      "id": "sn8.8:6.3",
      "pali": "Sāvako te mahāvīra,"
    },
    {
      "id": "sn8.8:6.4",
      "pali": "pāde vandati vaṅgiso”ti."
    },
    {
      "id": "sn8.8:7.1",
      "pali": "“Kiṁ nu te, vaṅgīsa, imā gāthāyo pubbe parivitakkitā, udāhu ṭhānasova taṁ paṭibhantī”ti?"
    },
    {
      "id": "sn8.8:7.2",
      "pali": "“Na kho me, bhante, imā gāthāyo pubbe parivitakkitā, atha kho ṭhānasova maṁ paṭibhantī”ti."
    },
    {
      "id": "sn8.8:7.3",
      "pali": "“Tena hi taṁ, vaṅgīsa, bhiyyoso mattāya pubbe aparivitakkitā gāthāyo paṭibhantū”ti."
    },
    {
      "id": "sn8.8:7.4",
      "pali": "“Evaṁ, bhante”ti kho āyasmā vaṅgīso bhagavato paṭissutvā bhiyyoso mattāya bhagavantaṁ pubbe aparivitakkitāhi gāthāhi abhitthavi:"
    },
    {
      "id": "sn8.8:8.1",
      "pali": "“Ummaggapathaṁ mārassa abhibhuyya,"
    },
    {
      "id": "sn8.8:8.2",
      "pali": "Carasi pabhijja khilāni;"
    },
    {
      "id": "sn8.8:8.3",
      "pali": "Taṁ passatha bandhapamuñcakaraṁ,"
    },
    {
      "id": "sn8.8:8.4",
      "pali": "Asitaṁ bhāgaso pavibhajaṁ."
    },
    {
      "id": "sn8.8:9.1",
      "pali": "Oghassa nittharaṇatthaṁ,"
    },
    {
      "id": "sn8.8:9.2",
      "pali": "Anekavihitaṁ maggaṁ akkhāsi;"
    },
    {
      "id": "sn8.8:9.3",
      "pali": "Tasmiñce amate akkhāte,"
    },
    {
      "id": "sn8.8:9.4",
      "pali": "Dhammaddasā ṭhitā asaṁhīrā."
    },
    {
      "id": "sn8.8:10.1",
      "pali": "Pajjotakaro ativijjha,"
    },
    {
      "id": "sn8.8:10.2",
      "pali": "Sabbaṭṭhitīnaṁ atikkamamaddasa;"
    },
    {
      "id": "sn8.8:10.3",
      "pali": "Ñatvā ca sacchikatvā ca,"
    },
    {
      "id": "sn8.8:10.4",
      "pali": "Aggaṁ so desayi dasaddhānaṁ."
    },
    {
      "id": "sn8.8:11.1",
      "pali": "Evaṁ sudesite dhamme,"
    },
    {
      "id": "sn8.8:11.2",
      "pali": "Ko pamādo vijānataṁ dhammaṁ;"
    },
    {
      "id": "sn8.8:11.3",
      "pali": "Tasmā hi tassa bhagavato sāsane,"
    },
    {
      "id": "sn8.8:11.4",
      "pali": "Appamatto sadā namassamanusikkhe”ti."
    }
  ]
}
