{
  "uid": "sn14.38",
  "title": "Dutiyasamaṇabrāhmaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.38:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.38:1.2",
      "pali": "“Catasso imā, bhikkhave, dhātuyo."
    },
    {
      "id": "sn14.38:1.3",
      "pali": "Katamā catasso?"
    },
    {
      "id": "sn14.38:1.4",
      "pali": "Pathavīdhātu, āpodhātu, tejodhātu, vāyodhātu."
    },
    {
      "id": "sn14.38:1.5",
      "pali": "Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā imāsaṁ catunnaṁ dhātūnaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe…"
    },
    {
      "id": "sn14.38:1.6",
      "pali": "(vitthāretabbaṁ)"
    },
    {
      "id": "sn14.38:1.7",
      "pali": "pajānanti …pe…"
    },
    {
      "id": "sn14.38:1.8",
      "pali": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn14.38:1.9",
      "pali": "Navamaṁ."
    }
  ]
}
