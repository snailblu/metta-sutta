{
  "uid": "sn43.13",
  "title": "Anatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.13:1.1",
      "pali": "“Anatañca vo, bhikkhave, desessāmi, anatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.13:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.13:1.3",
      "pali": "Katamañca, bhikkhave, anataṁ …pe…”."
    },
    {
      "id": "sn43.13:1.4",
      "pali": "(Yathā asaṅkhataṁ tathā vitthāretabbaṁ.)"
    },
    {
      "id": "sn43.13:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
