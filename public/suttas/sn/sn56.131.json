{
  "uid": "sn56.131",
  "title": "Pettidevapettivisayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.131:1.1",
      "pali": "… “Evameva kho, bhikkhave, appakā te sattā ye pettivisayā cutā devesu paccājāyanti; atha kho eteva bahutarā sattā ye pettivisayā cutā pettivisaye paccājāyanti."
    },
    {
      "id": "sn56.131:1.2",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn56.131:1.3",
      "pali": "Adiṭṭhattā, bhikkhave, catunnaṁ ariyasaccānaṁ."
    },
    {
      "id": "sn56.131:1.4",
      "pali": "Katamesaṁ catunnaṁ?"
    },
    {
      "id": "sn56.131:1.5",
      "pali": "Dukkhassa ariyasaccassa, dukkhasamudayassa ariyasaccassa, dukkhanirodhassa ariyasaccassa, dukkhanirodhagāminiyā paṭipadāya ariyasaccassa."
    },
    {
      "id": "sn56.131:2.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo, ‘ayaṁ dukkhasamudayo’ti yogo karaṇīyo, ‘ayaṁ dukkhanirodho’ti yogo karaṇīyo, ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.131:3.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn56.131:3.2",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "sn56.131:3.3",
      "pali": "Tiṁsatimaṁ."
    },
    {
      "id": "sn56.131:3.4",
      "pali": "Pañcagatipeyyālavaggo ekādasamo."
    },
    {
      "id": "sn56.131:4.1",
      "pali": "Manussato cutā chāpi,"
    },
    {
      "id": "sn56.131:4.2",
      "pali": "devā cutā nirayato;"
    },
    {
      "id": "sn56.131:4.3",
      "pali": "Tiracchānapettivisayā,"
    },
    {
      "id": "sn56.131:4.4",
      "pali": "tiṁsamatto gativaggoti."
    },
    {
      "id": "sn56.131:4.5",
      "pali": "Saccasaṁyuttaṁ dvādasamaṁ."
    },
    {
      "id": "sn56.131:4.6",
      "pali": "Mahāvaggo pañcamo."
    },
    {
      "id": "sn56.131:5.1",
      "pali": "Maggabojjhaṅgaṁ satiyā,"
    },
    {
      "id": "sn56.131:5.2",
      "pali": "indriyaṁ sammappadhānaṁ;"
    },
    {
      "id": "sn56.131:5.3",
      "pali": "Baliddhipādānuruddhā,"
    },
    {
      "id": "sn56.131:5.4",
      "pali": "jhānānāpānasaṁyutaṁ;"
    },
    {
      "id": "sn56.131:5.5",
      "pali": "Sotāpatti saccañcāti,"
    },
    {
      "id": "sn56.131:5.6",
      "pali": "mahāvaggoti vuccatīti."
    },
    {
      "id": "sn56.131:5.7",
      "pali": "Mahāvaggasaṁyuttapāḷi niṭṭhitā."
    },
    {
      "id": "sn56.131:5.8",
      "pali": "Saṁyuttanikāyo samatto."
    }
  ]
}
