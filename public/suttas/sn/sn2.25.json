{
  "uid": "sn2.25",
  "title": "Jantusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.25:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn2.25:1.2",
      "pali": "ekaṁ samayaṁ sambahulā bhikkhū, kosalesu viharanti himavantapasse araññakuṭikāya uddhatā unnaḷā capalā mukharā vikiṇṇavācā muṭṭhassatino asampajānā asamāhitā vibbhantacittā pākatindriyā."
    },
    {
      "id": "sn2.25:2.1",
      "pali": "Atha kho jantu devaputto tadahuposathe pannarase yena te bhikkhū tenupasaṅkami; upasaṅkamitvā te bhikkhū gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn2.25:3.1",
      "pali": "“Sukhajīvino pure āsuṁ,"
    },
    {
      "id": "sn2.25:3.2",
      "pali": "bhikkhū gotamasāvakā;"
    },
    {
      "id": "sn2.25:3.3",
      "pali": "Anicchā piṇḍamesanā,"
    },
    {
      "id": "sn2.25:3.4",
      "pali": "anicchā sayanāsanaṁ;"
    },
    {
      "id": "sn2.25:3.5",
      "pali": "Loke aniccataṁ ñatvā,"
    },
    {
      "id": "sn2.25:3.6",
      "pali": "dukkhassantaṁ akaṁsu te."
    },
    {
      "id": "sn2.25:4.1",
      "pali": "Dupposaṁ katvā attānaṁ,"
    },
    {
      "id": "sn2.25:4.2",
      "pali": "gāme gāmaṇikā viya;"
    },
    {
      "id": "sn2.25:4.3",
      "pali": "Bhutvā bhutvā nipajjanti,"
    },
    {
      "id": "sn2.25:4.4",
      "pali": "parāgāresu mucchitā."
    },
    {
      "id": "sn2.25:5.1",
      "pali": "Saṅghassa añjaliṁ katvā,"
    },
    {
      "id": "sn2.25:5.2",
      "pali": "idhekacce vadāmahaṁ;"
    },
    {
      "id": "sn2.25:5.3",
      "pali": "Apaviddhā anāthā te,"
    },
    {
      "id": "sn2.25:5.4",
      "pali": "yathā petā tatheva te."
    },
    {
      "id": "sn2.25:6.1",
      "pali": "Ye kho pamattā viharanti,"
    },
    {
      "id": "sn2.25:6.2",
      "pali": "te me sandhāya bhāsitaṁ;"
    },
    {
      "id": "sn2.25:6.3",
      "pali": "Ye appamattā viharanti,"
    },
    {
      "id": "sn2.25:6.4",
      "pali": "namo tesaṁ karomahan”ti."
    }
  ]
}
