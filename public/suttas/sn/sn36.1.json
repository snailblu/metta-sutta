{
  "uid": "sn36.1",
  "title": "Samādhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.1:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn36.1:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn36.1:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn36.1:1.4",
      "pali": "imā kho, bhikkhave, tisso vedanāti."
    },
    {
      "id": "sn36.1:2.1",
      "pali": "Samāhito sampajāno,"
    },
    {
      "id": "sn36.1:2.2",
      "pali": "sato buddhassa sāvako;"
    },
    {
      "id": "sn36.1:2.3",
      "pali": "Vedanā ca pajānāti,"
    },
    {
      "id": "sn36.1:2.4",
      "pali": "vedanānañca sambhavaṁ."
    },
    {
      "id": "sn36.1:3.1",
      "pali": "Yattha cetā nirujjhanti,"
    },
    {
      "id": "sn36.1:3.2",
      "pali": "maggañca khayagāminaṁ;"
    },
    {
      "id": "sn36.1:3.3",
      "pali": "Vedanānaṁ khayā bhikkhu,"
    },
    {
      "id": "sn36.1:3.4",
      "pali": "nicchāto parinibbuto”ti."
    },
    {
      "id": "sn36.1:3.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
