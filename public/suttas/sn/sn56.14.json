{
  "uid": "sn56.14",
  "title": "Ajjhattikāyatanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.14:1.1",
      "pali": "“Cattārimāni, bhikkhave, ariyasaccāni."
    },
    {
      "id": "sn56.14:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "sn56.14:1.3",
      "pali": "Dukkhaṁ ariyasaccaṁ, dukkhasamudayaṁ ariyasaccaṁ, dukkhanirodhaṁ ariyasaccaṁ, dukkhanirodhagāminī paṭipadā ariyasaccaṁ."
    },
    {
      "id": "sn56.14:2.1",
      "pali": "Katamañca, bhikkhave, dukkhaṁ ariyasaccaṁ?"
    },
    {
      "id": "sn56.14:2.2",
      "pali": "‘Cha ajjhattikāni āyatanānī’tissa vacanīyaṁ."
    },
    {
      "id": "sn56.14:2.3",
      "pali": "Katamāni cha?"
    },
    {
      "id": "sn56.14:2.4",
      "pali": "Cakkhāyatanaṁ …pe… manāyatanaṁ—"
    },
    {
      "id": "sn56.14:2.5",
      "pali": "idaṁ vuccati, bhikkhave, dukkhaṁ ariyasaccaṁ."
    },
    {
      "id": "sn56.14:3.1",
      "pali": "Katamañca, bhikkhave, dukkhasamudayaṁ ariyasaccaṁ?"
    },
    {
      "id": "sn56.14:3.2",
      "pali": "Yāyaṁ taṇhā ponobbhavikā nandirāgasahagatā tatratatrābhinandinī, seyyathidaṁ—kāmataṇhā, bhavataṇhā, vibhavataṇhā—"
    },
    {
      "id": "sn56.14:3.3",
      "pali": "idaṁ vuccati, bhikkhave, dukkhasamudayaṁ ariyasaccaṁ."
    },
    {
      "id": "sn56.14:4.1",
      "pali": "Katamañca, bhikkhave, dukkhanirodhaṁ ariyasaccaṁ?"
    },
    {
      "id": "sn56.14:4.2",
      "pali": "Yo tassāyeva taṇhāya asesavirāganirodho cāgo paṭinissaggo mutti anālayo—"
    },
    {
      "id": "sn56.14:4.3",
      "pali": "idaṁ vuccati, bhikkhave, dukkhanirodhaṁ ariyasaccaṁ."
    },
    {
      "id": "sn56.14:5.1",
      "pali": "Katamañca, bhikkhave, dukkhanirodhagāminī paṭipadā ariyasaccaṁ?"
    },
    {
      "id": "sn56.14:5.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn56.14:5.3",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi—"
    },
    {
      "id": "sn56.14:5.4",
      "pali": "idaṁ vuccati, bhikkhave, dukkhanirodhagāminī paṭipadā ariyasaccaṁ."
    },
    {
      "id": "sn56.14:5.5",
      "pali": "Imāni kho, bhikkhave, cattāri ariyasaccāni."
    },
    {
      "id": "sn56.14:6.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.14:6.2",
      "pali": "Catutthaṁ."
    }
  ]
}
