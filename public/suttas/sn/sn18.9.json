{
  "uid": "sn18.9",
  "title": "Dhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.9:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.9:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.9:1.3",
      "pali": "pathavīdhātu niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.9:1.4",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.9:1.5",
      "pali": "“āpodhātu …pe…"
    },
    {
      "id": "sn18.9:1.6",
      "pali": "tejodhātu …"
    },
    {
      "id": "sn18.9:1.7",
      "pali": "vāyodhātu …"
    },
    {
      "id": "sn18.9:1.8",
      "pali": "ākāsadhātu …"
    },
    {
      "id": "sn18.9:1.9",
      "pali": "viññāṇadhātu niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.9:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.9:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako pathavīdhātuyāpi nibbindati …pe… āpodhātuyāpi nibbindati … tejodhātuyāpi nibbindati … vāyodhātuyāpi nibbindati … ākāsadhātuyāpi nibbindati … viññāṇadhātuyāpi nibbindati …pe…"
    },
    {
      "id": "sn18.9:1.12",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.9:1.13",
      "pali": "Navamaṁ."
    }
  ]
}
