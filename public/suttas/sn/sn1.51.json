{
  "uid": "sn1.51",
  "title": "Jarāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.51:1.1",
      "pali": "“Kiṁsu yāva jarā sādhu,"
    },
    {
      "id": "sn1.51:1.2",
      "pali": "kiṁsu sādhu patiṭṭhitaṁ;"
    },
    {
      "id": "sn1.51:1.3",
      "pali": "Kiṁsu narānaṁ ratanaṁ,"
    },
    {
      "id": "sn1.51:1.4",
      "pali": "kiṁsu corehi dūharan”ti."
    },
    {
      "id": "sn1.51:2.1",
      "pali": "“Sīlaṁ yāva jarā sādhu,"
    },
    {
      "id": "sn1.51:2.2",
      "pali": "saddhā sādhu patiṭṭhitā;"
    },
    {
      "id": "sn1.51:2.3",
      "pali": "Paññā narānaṁ ratanaṁ,"
    },
    {
      "id": "sn1.51:2.4",
      "pali": "puññaṁ corehi dūharan”ti."
    }
  ]
}
