{
  "uid": "sn35.137",
  "title": "Dutiyarūpārāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.137:1.1",
      "pali": "“Rūpārāmā, bhikkhave, devamanussā rūparatā rūpasammuditā."
    },
    {
      "id": "sn35.137:1.2",
      "pali": "Rūpavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti."
    },
    {
      "id": "sn35.137:1.3",
      "pali": "Saddārāmā …"
    },
    {
      "id": "sn35.137:1.4",
      "pali": "gandhārāmā …"
    },
    {
      "id": "sn35.137:1.5",
      "pali": "rasārāmā …"
    },
    {
      "id": "sn35.137:1.6",
      "pali": "phoṭṭhabbārāmā …"
    },
    {
      "id": "sn35.137:1.7",
      "pali": "dhammārāmā, bhikkhave, devamanussā dhammaratā dhammasammuditā."
    },
    {
      "id": "sn35.137:1.8",
      "pali": "Dhammavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti."
    },
    {
      "id": "sn35.137:1.9",
      "pali": "Tathāgato ca, bhikkhave, arahaṁ sammāsambuddho rūpānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na rūpārāmo na rūparato na rūpasammudito."
    },
    {
      "id": "sn35.137:1.10",
      "pali": "Rūpavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharati."
    },
    {
      "id": "sn35.137:1.11",
      "pali": "Saddānaṁ …"
    },
    {
      "id": "sn35.137:1.12",
      "pali": "gandhānaṁ …"
    },
    {
      "id": "sn35.137:1.13",
      "pali": "rasānaṁ …"
    },
    {
      "id": "sn35.137:1.14",
      "pali": "phoṭṭhabbānaṁ …"
    },
    {
      "id": "sn35.137:1.15",
      "pali": "dhammānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na dhammārāmo na dhammarato na dhammasammudito."
    },
    {
      "id": "sn35.137:1.16",
      "pali": "Dhammavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharatī”ti."
    },
    {
      "id": "sn35.137:1.17",
      "pali": "Catutthaṁ."
    }
  ]
}
