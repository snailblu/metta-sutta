{
  "uid": "sn26.9",
  "title": "Dhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn26.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn26.9:1.2",
      "pali": "“Yo kho, bhikkhave, pathavīdhātuyā uppādo ṭhiti abhinibbatti pātubhāvo …pe… jarāmaraṇassa pātubhāvo;"
    },
    {
      "id": "sn26.9:1.3",
      "pali": "yo āpodhātuyā …"
    },
    {
      "id": "sn26.9:1.4",
      "pali": "yo tejodhātuyā …"
    },
    {
      "id": "sn26.9:1.5",
      "pali": "yo vāyodhātuyā …"
    },
    {
      "id": "sn26.9:1.6",
      "pali": "yo ākāsadhātuyā …"
    },
    {
      "id": "sn26.9:1.7",
      "pali": "yo viññāṇadhātuyā uppādo ṭhiti abhinibbatti pātubhāvo, dukkhasseso uppādo, rogānaṁ ṭhiti, jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn26.9:1.8",
      "pali": "Yo ca kho, bhikkhave, pathavīdhātuyā nirodho …pe… jarāmaraṇassa atthaṅgamo;"
    },
    {
      "id": "sn26.9:1.9",
      "pali": "yo āpodhātuyā nirodho …"
    },
    {
      "id": "sn26.9:1.10",
      "pali": "yo tejodhātuyā nirodho …"
    },
    {
      "id": "sn26.9:1.11",
      "pali": "yo vāyodhātuyā nirodho …"
    },
    {
      "id": "sn26.9:1.12",
      "pali": "yo ākāsadhātuyā nirodho …"
    },
    {
      "id": "sn26.9:1.13",
      "pali": "yo viññāṇadhātuyā nirodho vūpasamo atthaṅgamo, dukkhasseso nirodho, rogānaṁ vūpasamo, jarāmaraṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn26.9:1.14",
      "pali": "Navamaṁ."
    }
  ]
}
