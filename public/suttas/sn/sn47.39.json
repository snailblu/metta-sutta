{
  "uid": "sn47.39",
  "title": "Bhāvanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.39:1.1",
      "pali": "“Catunnaṁ, bhikkhave, satipaṭṭhānānaṁ bhāvanaṁ desessāmi."
    },
    {
      "id": "sn47.39:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn47.39:1.3",
      "pali": "Katamā, bhikkhave, catunnaṁ satipaṭṭhānānaṁ bhāvanā?"
    },
    {
      "id": "sn47.39:1.4",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.39:1.5",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.39:1.6",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.39:1.7",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.39:1.8",
      "pali": "Ayaṁ kho, bhikkhave, catunnaṁ satipaṭṭhānānaṁ bhāvanā”ti."
    },
    {
      "id": "sn47.39:1.9",
      "pali": "Navamaṁ."
    }
  ]
}
