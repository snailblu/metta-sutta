{
  "uid": "sn1.58",
  "title": "Uppathasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.58:1.1",
      "pali": "“Kiṁsu uppatho akkhāto,"
    },
    {
      "id": "sn1.58:1.2",
      "pali": "kiṁsu rattindivakkhayo;"
    },
    {
      "id": "sn1.58:1.3",
      "pali": "Kiṁ malaṁ brahmacariyassa,"
    },
    {
      "id": "sn1.58:1.4",
      "pali": "kiṁ sinānamanodakan”ti."
    },
    {
      "id": "sn1.58:2.1",
      "pali": "“Rāgo uppatho akkhāto,"
    },
    {
      "id": "sn1.58:2.2",
      "pali": "Vayo rattindivakkhayo;"
    },
    {
      "id": "sn1.58:2.3",
      "pali": "Itthī malaṁ brahmacariyassa,"
    },
    {
      "id": "sn1.58:2.4",
      "pali": "Etthāyaṁ sajjate pajā;"
    },
    {
      "id": "sn1.58:2.5",
      "pali": "Tapo ca brahmacariyañca,"
    },
    {
      "id": "sn1.58:2.6",
      "pali": "Taṁ sinānamanodakan”ti."
    }
  ]
}
