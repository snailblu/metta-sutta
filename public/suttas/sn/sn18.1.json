{
  "uid": "sn18.1",
  "title": "Cakkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn18.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn18.1:1.3",
      "pali": "Atha kho āyasmā rāhulo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā rāhulo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn18.1:1.4",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu, yamahaṁ bhagavato dhammaṁ sutvā eko vūpakaṭṭho appamatto ātāpī pahitatto vihareyyan”ti."
    },
    {
      "id": "sn18.1:2.1",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.1:2.2",
      "pali": "cakkhuṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.1:2.3",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn18.1:2.4",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn18.1:2.5",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn18.1:2.6",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn18.1:2.7",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn18.1:2.8",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn18.1:3.1",
      "pali": "“Sotaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.1:3.2",
      "pali": "“Aniccaṁ, bhante” …pe…."
    },
    {
      "id": "sn18.1:3.3",
      "pali": "“Ghānaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.1:3.4",
      "pali": "“Aniccaṁ, bhante” …"
    },
    {
      "id": "sn18.1:3.5",
      "pali": "“Jivhā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.1:3.6",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.1:3.7",
      "pali": "“Kāyo nicco vā anicco vā”ti?"
    },
    {
      "id": "sn18.1:3.8",
      "pali": "“Anicco, bhante” …"
    },
    {
      "id": "sn18.1:3.9",
      "pali": "“Mano nicco vā anicco vā”ti?"
    },
    {
      "id": "sn18.1:3.10",
      "pali": "“Anicco, bhante”."
    },
    {
      "id": "sn18.1:3.11",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn18.1:3.12",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn18.1:3.13",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn18.1:3.14",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn18.1:3.15",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn18.1:4.1",
      "pali": "“Evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusmimpi nibbindati …pe… sotasmimpi nibbindati … ghānasmimpi nibbindati … jivhāyapi nibbindati … kāyasmimpi nibbindati … manasmimpi nibbindati;"
    },
    {
      "id": "sn18.1:4.2",
      "pali": "nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn18.1:4.3",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn18.1:4.4",
      "pali": "(Etena peyyālena dasa suttantā kātabbā.)"
    },
    {
      "id": "sn18.1:4.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
