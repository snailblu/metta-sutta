{
  "uid": "sn12.50",
  "title": "Dutiyaariyasāvakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.50:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.50:1.2",
      "pali": "“Na, bhikkhave, sutavato ariyasāvakassa evaṁ hoti:"
    },
    {
      "id": "sn12.50:1.3",
      "pali": "‘kiṁ nu kho kismiṁ sati kiṁ hoti, kissuppādā kiṁ uppajjati?"
    },
    {
      "id": "sn12.50:1.4",
      "pali": "Kismiṁ sati saṅkhārā honti, kismiṁ sati viññāṇaṁ hoti, kismiṁ sati nāmarūpaṁ hoti, kismiṁ sati saḷāyatanaṁ hoti, kismiṁ sati phasso hoti, kismiṁ sati vedanā hoti, kismiṁ sati taṇhā hoti, kismiṁ sati upādānaṁ hoti, kismiṁ sati bhavo hoti, kismiṁ sati jāti hoti, kismiṁ sati jarāmaraṇaṁ hotī’ti?"
    },
    {
      "id": "sn12.50:2.1",
      "pali": "Atha kho, bhikkhave, sutavato ariyasāvakassa aparappaccayā ñāṇamevettha hoti:"
    },
    {
      "id": "sn12.50:2.2",
      "pali": "‘imasmiṁ sati idaṁ hoti, imassuppādā idaṁ uppajjati."
    },
    {
      "id": "sn12.50:2.3",
      "pali": "Avijjāya sati saṅkhārā honti;"
    },
    {
      "id": "sn12.50:2.4",
      "pali": "saṅkhāresu sati viññāṇaṁ hoti;"
    },
    {
      "id": "sn12.50:2.5",
      "pali": "viññāṇe sati nāmarūpaṁ hoti;"
    },
    {
      "id": "sn12.50:2.6",
      "pali": "nāmarūpe sati saḷāyatanaṁ hoti;"
    },
    {
      "id": "sn12.50:2.7",
      "pali": "saḷāyatane sati phasso hoti;"
    },
    {
      "id": "sn12.50:2.8",
      "pali": "phasse sati vedanā hoti;"
    },
    {
      "id": "sn12.50:2.9",
      "pali": "vedanāya sati taṇhā hoti;"
    },
    {
      "id": "sn12.50:2.10",
      "pali": "taṇhāya sati upādānaṁ hoti;"
    },
    {
      "id": "sn12.50:2.11",
      "pali": "upādāne sati bhavo hoti;"
    },
    {
      "id": "sn12.50:2.12",
      "pali": "bhave sati jāti hoti;"
    },
    {
      "id": "sn12.50:2.13",
      "pali": "jātiyā sati jarāmaraṇaṁ hotī’ti."
    },
    {
      "id": "sn12.50:2.14",
      "pali": "So evaṁ pajānāti:"
    },
    {
      "id": "sn12.50:2.15",
      "pali": "‘evamayaṁ loko samudayatī’ti."
    },
    {
      "id": "sn12.50:3.1",
      "pali": "Na, bhikkhave, sutavato ariyasāvakassa evaṁ hoti:"
    },
    {
      "id": "sn12.50:3.2",
      "pali": "‘kiṁ nu kho kismiṁ asati kiṁ na hoti, kissa nirodhā kiṁ nirujjhati?"
    },
    {
      "id": "sn12.50:3.3",
      "pali": "Kismiṁ asati saṅkhārā na honti, kismiṁ asati viññāṇaṁ na hoti, kismiṁ asati nāmarūpaṁ na hoti, kismiṁ asati saḷāyatanaṁ na hoti, kismiṁ asati phasso na hoti, kismiṁ asati vedanā na hoti, kismiṁ asati taṇhā na hoti …pe…"
    },
    {
      "id": "sn12.50:3.4",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.50:3.5",
      "pali": "bhavo …"
    },
    {
      "id": "sn12.50:3.6",
      "pali": "jāti …"
    },
    {
      "id": "sn12.50:3.7",
      "pali": "kismiṁ asati jarāmaraṇaṁ na hotī’ti?"
    },
    {
      "id": "sn12.50:4.1",
      "pali": "Atha kho, bhikkhave, sutavato ariyasāvakassa aparappaccayā ñāṇamevettha hoti:"
    },
    {
      "id": "sn12.50:4.2",
      "pali": "‘imasmiṁ asati idaṁ na hoti, imassa nirodhā idaṁ nirujjhati."
    },
    {
      "id": "sn12.50:4.3",
      "pali": "Avijjāya asati saṅkhārā na honti;"
    },
    {
      "id": "sn12.50:4.4",
      "pali": "saṅkhāresu asati viññāṇaṁ na hoti;"
    },
    {
      "id": "sn12.50:4.5",
      "pali": "viññāṇe asati nāmarūpaṁ na hoti;"
    },
    {
      "id": "sn12.50:4.6",
      "pali": "nāmarūpe asati saḷāyatanaṁ na hoti …pe…"
    },
    {
      "id": "sn12.50:4.7",
      "pali": "jātiyā asati jarāmaraṇaṁ na hotī’ti."
    },
    {
      "id": "sn12.50:4.8",
      "pali": "So evaṁ pajānāti:"
    },
    {
      "id": "sn12.50:4.9",
      "pali": "‘evamayaṁ loko nirujjhatī’ti."
    },
    {
      "id": "sn12.50:5.1",
      "pali": "Yato kho, bhikkhave, ariyasāvako evaṁ lokassa samudayañca atthaṅgamañca yathābhūtaṁ pajānāti, ayaṁ vuccati, bhikkhave, ariyasāvako diṭṭhisampanno itipi, dassanasampanno itipi, āgato imaṁ saddhammaṁ itipi, passati imaṁ saddhammaṁ itipi, sekkhena ñāṇena samannāgato itipi, sekkhāya vijjāya samannāgato itipi, dhammasotaṁ samāpanno itipi, ariyo nibbedhikapañño itipi, amatadvāraṁ āhacca tiṭṭhati itipī”ti."
    },
    {
      "id": "sn12.50:5.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn12.50:5.3",
      "pali": "Gahapativaggo pañcamo."
    },
    {
      "id": "sn12.50:6.1",
      "pali": "Dve pañcaverabhayā vuttā,"
    },
    {
      "id": "sn12.50:6.2",
      "pali": "dukkhaṁ loko ca ñātikaṁ;"
    },
    {
      "id": "sn12.50:6.3",
      "pali": "Aññataraṁ jāṇussoṇi ca,"
    },
    {
      "id": "sn12.50:6.4",
      "pali": "lokāyatikena aṭṭhamaṁ;"
    },
    {
      "id": "sn12.50:6.5",
      "pali": "Dve ariyasāvakā vuttā,"
    },
    {
      "id": "sn12.50:6.6",
      "pali": "vaggo tena pavuccatīti."
    }
  ]
}
