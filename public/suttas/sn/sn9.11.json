{
  "uid": "sn9.11",
  "title": "Akusalavitakkasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.11:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.11:1.2",
      "pali": "Tena kho pana samayena so bhikkhu divāvihāragato pāpake akusale vitakke vitakketi, seyyathidaṁ—"
    },
    {
      "id": "sn9.11:1.3",
      "pali": "kāmavitakkaṁ, byāpādavitakkaṁ, vihiṁsāvitakkaṁ."
    },
    {
      "id": "sn9.11:1.4",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno anukampikā atthakāmā taṁ bhikkhuṁ saṁvejetukāmā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn9.11:2.1",
      "pali": "“Ayoniso manasikārā,"
    },
    {
      "id": "sn9.11:2.2",
      "pali": "so vitakkehi khajjasi;"
    },
    {
      "id": "sn9.11:2.3",
      "pali": "Ayoniso paṭinissajja,"
    },
    {
      "id": "sn9.11:2.4",
      "pali": "yoniso anucintaya."
    },
    {
      "id": "sn9.11:3.1",
      "pali": "Satthāraṁ dhammamārabbha,"
    },
    {
      "id": "sn9.11:3.2",
      "pali": "saṅghaṁ sīlāni attano;"
    },
    {
      "id": "sn9.11:3.3",
      "pali": "Adhigacchasi pāmojjaṁ,"
    },
    {
      "id": "sn9.11:3.4",
      "pali": "pītisukhamasaṁsayaṁ;"
    },
    {
      "id": "sn9.11:3.5",
      "pali": "Tato pāmojjabahulo,"
    },
    {
      "id": "sn9.11:3.6",
      "pali": "dukkhassantaṁ karissasī”ti."
    },
    {
      "id": "sn9.11:4.1",
      "pali": "Atha kho so bhikkhu tāya devatāya saṁvejito saṁvegamāpādīti."
    }
  ]
}
