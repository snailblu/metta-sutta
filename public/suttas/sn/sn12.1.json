{
  "uid": "sn12.1",
  "title": "Paṭiccasamuppādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn12.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn12.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn12.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn12.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.1:1.7",
      "pali": "“paṭiccasamuppādaṁ vo, bhikkhave, desessāmi."
    },
    {
      "id": "sn12.1:1.8",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.1:1.9",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.1:1.10",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.1:2.1",
      "pali": "“Katamo ca, bhikkhave, paṭiccasamuppādo?"
    },
    {
      "id": "sn12.1:2.2",
      "pali": "Avijjāpaccayā, bhikkhave, saṅkhārā;"
    },
    {
      "id": "sn12.1:2.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ;"
    },
    {
      "id": "sn12.1:2.4",
      "pali": "viññāṇapaccayā nāmarūpaṁ;"
    },
    {
      "id": "sn12.1:2.5",
      "pali": "nāmarūpapaccayā saḷāyatanaṁ;"
    },
    {
      "id": "sn12.1:2.6",
      "pali": "saḷāyatanapaccayā phasso;"
    },
    {
      "id": "sn12.1:2.7",
      "pali": "phassapaccayā vedanā;"
    },
    {
      "id": "sn12.1:2.8",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn12.1:2.9",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.1:2.10",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.1:2.11",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.1:2.12",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.1:2.13",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.1:2.14",
      "pali": "Ayaṁ vuccati, bhikkhave, paṭiccasamuppādo."
    },
    {
      "id": "sn12.1:3.1",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.1:3.2",
      "pali": "saṅkhāranirodhā viññāṇanirodho;"
    },
    {
      "id": "sn12.1:3.3",
      "pali": "viññāṇanirodhā nāmarūpanirodho;"
    },
    {
      "id": "sn12.1:3.4",
      "pali": "nāmarūpanirodhā saḷāyatananirodho;"
    },
    {
      "id": "sn12.1:3.5",
      "pali": "saḷāyatananirodhā phassanirodho;"
    },
    {
      "id": "sn12.1:3.6",
      "pali": "phassanirodhā vedanānirodho;"
    },
    {
      "id": "sn12.1:3.7",
      "pali": "vedanānirodhā taṇhānirodho;"
    },
    {
      "id": "sn12.1:3.8",
      "pali": "taṇhānirodhā upādānanirodho;"
    },
    {
      "id": "sn12.1:3.9",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.1:3.10",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.1:3.11",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.1:3.12",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.1:3.13",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn12.1:3.14",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "sn12.1:3.15",
      "pali": "Paṭhamaṁ."
    }
  ]
}
