{
  "uid": "sn22.133",
  "title": "Koṭṭhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.133:1.1",
      "pali": "Bārāṇasiyaṁ viharanti isipatane migadāye."
    },
    {
      "id": "sn22.133:1.2",
      "pali": "Atha kho āyasmā sāriputto sāyanhasamayaṁ …pe…"
    },
    {
      "id": "sn22.133:1.3",
      "pali": "ekamantaṁ nisinno kho āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca:"
    },
    {
      "id": "sn22.133:1.4",
      "pali": "“‘avijjā, avijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.133:1.5",
      "pali": "Katamā nu kho, āvuso, avijjā;"
    },
    {
      "id": "sn22.133:1.6",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.133:2.1",
      "pali": "“Idhāvuso, assutavā puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.133:2.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.133:2.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.133:2.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.133:2.5",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.133:2.6",
      "pali": "Ayaṁ vuccatāvuso, avijjā;"
    },
    {
      "id": "sn22.133:2.7",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.133:3.1",
      "pali": "Evaṁ vutte, āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca:"
    },
    {
      "id": "sn22.133:3.2",
      "pali": "“‘vijjā, vijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.133:3.3",
      "pali": "Katamā nu kho, āvuso, vijjā;"
    },
    {
      "id": "sn22.133:3.4",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.133:4.1",
      "pali": "“Idhāvuso, sutavā ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.133:4.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.133:4.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.133:4.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.133:4.5",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.133:4.6",
      "pali": "Ayaṁ vuccatāvuso, vijjā;"
    },
    {
      "id": "sn22.133:4.7",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.133:4.8",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
