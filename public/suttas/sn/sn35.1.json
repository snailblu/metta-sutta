{
  "uid": "sn35.1",
  "title": "Ajjhattāniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.1:1.1",
      "pali": "Evaṁ me sutaṁ."
    },
    {
      "id": "sn35.1:1.2",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn35.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn35.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn35.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn35.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn35.1:2.1",
      "pali": "“Cakkhuṁ, bhikkhave, aniccaṁ."
    },
    {
      "id": "sn35.1:2.2",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn35.1:2.3",
      "pali": "yaṁ dukkhaṁ tadanattā."
    },
    {
      "id": "sn35.1:2.4",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.1:2.5",
      "pali": "Sotaṁ aniccaṁ."
    },
    {
      "id": "sn35.1:2.6",
      "pali": "Yadaniccaṁ …pe…"
    },
    {
      "id": "sn35.1:2.7",
      "pali": "ghānaṁ aniccaṁ."
    },
    {
      "id": "sn35.1:2.8",
      "pali": "Yadaniccaṁ …pe…"
    },
    {
      "id": "sn35.1:2.9",
      "pali": "jivhā aniccā."
    },
    {
      "id": "sn35.1:2.10",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn35.1:2.11",
      "pali": "yaṁ dukkhaṁ tadanattā."
    },
    {
      "id": "sn35.1:2.12",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.1:2.13",
      "pali": "Kāyo anicco."
    },
    {
      "id": "sn35.1:2.14",
      "pali": "Yadaniccaṁ …pe…"
    },
    {
      "id": "sn35.1:2.15",
      "pali": "mano anicco."
    },
    {
      "id": "sn35.1:2.16",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn35.1:2.17",
      "pali": "yaṁ dukkhaṁ tadanattā."
    },
    {
      "id": "sn35.1:2.18",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.1:2.19",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako cakkhusmimpi nibbindati, sotasmimpi nibbindati, ghānasmimpi nibbindati, jivhāyapi nibbindati, kāyasmimpi nibbindati, manasmimpi nibbindati."
    },
    {
      "id": "sn35.1:2.20",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn35.1:2.21",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.1:2.22",
      "pali": "Paṭhamaṁ."
    }
  ]
}
