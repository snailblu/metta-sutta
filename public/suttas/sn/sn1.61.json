{
  "uid": "sn1.61",
  "title": "Nāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.61:1.1",
      "pali": "“Kiṁsu sabbaṁ addhabhavi,"
    },
    {
      "id": "sn1.61:1.2",
      "pali": "kismā bhiyyo na vijjati;"
    },
    {
      "id": "sn1.61:1.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn1.61:1.4",
      "pali": "sabbeva vasamanvagū”ti."
    },
    {
      "id": "sn1.61:2.1",
      "pali": "“Nāmaṁ sabbaṁ addhabhavi,"
    },
    {
      "id": "sn1.61:2.2",
      "pali": "nāmā bhiyyo na vijjati;"
    },
    {
      "id": "sn1.61:2.3",
      "pali": "Nāmassa ekadhammassa,"
    },
    {
      "id": "sn1.61:2.4",
      "pali": "sabbeva vasamanvagū”ti."
    }
  ]
}
