{
  "uid": "sn11.19",
  "title": "Satthāravandanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.19:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.19:1.2",
      "pali": "“Bhūtapubbaṁ, bhikkhave, sakko devānamindo mātaliṁ saṅgāhakaṁ āmantesi:"
    },
    {
      "id": "sn11.19:1.3",
      "pali": "‘yojehi, samma mātali, sahassayuttaṁ ājaññarathaṁ, uyyānabhūmiṁ gacchāma subhūmiṁ dassanāyā’ti."
    },
    {
      "id": "sn11.19:1.4",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, mātali saṅgāhako sakkassa devānamindassa paṭissutvā sahassayuttaṁ ājaññarathaṁ yojetvā sakkassa devānamindassa paṭivedesi:"
    },
    {
      "id": "sn11.19:1.5",
      "pali": "‘yutto kho te, mārisa, sahassayutto ājaññaratho."
    },
    {
      "id": "sn11.19:1.6",
      "pali": "Yassadāni kālaṁ maññasī’ti."
    },
    {
      "id": "sn11.19:1.7",
      "pali": "Atha kho, bhikkhave, sakko devānamindo vejayantapāsādā orohanto añjaliṁ katvā sudaṁ bhagavantaṁ namassati."
    },
    {
      "id": "sn11.19:1.8",
      "pali": "Atha kho, bhikkhave, mātali saṅgāhako sakkaṁ devānamindaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.19:2.1",
      "pali": "‘Yañhi devā manussā ca,"
    },
    {
      "id": "sn11.19:2.2",
      "pali": "taṁ namassanti vāsava;"
    },
    {
      "id": "sn11.19:2.3",
      "pali": "Atha ko nāma so yakkho,"
    },
    {
      "id": "sn11.19:2.4",
      "pali": "yaṁ tvaṁ sakka namassasī’ti."
    },
    {
      "id": "sn11.19:3.1",
      "pali": "‘Yo idha sammāsambuddho,"
    },
    {
      "id": "sn11.19:3.2",
      "pali": "asmiṁ loke sadevake;"
    },
    {
      "id": "sn11.19:3.3",
      "pali": "Anomanāmaṁ satthāraṁ,"
    },
    {
      "id": "sn11.19:3.4",
      "pali": "taṁ namassāmi mātali."
    },
    {
      "id": "sn11.19:4.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "sn11.19:4.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "sn11.19:4.3",
      "pali": "Khīṇāsavā arahanto,"
    },
    {
      "id": "sn11.19:4.4",
      "pali": "te namassāmi mātali."
    },
    {
      "id": "sn11.19:5.1",
      "pali": "Ye rāgadosavinayā,"
    },
    {
      "id": "sn11.19:5.2",
      "pali": "avijjāsamatikkamā;"
    },
    {
      "id": "sn11.19:5.3",
      "pali": "Sekkhā apacayārāmā,"
    },
    {
      "id": "sn11.19:5.4",
      "pali": "appamattānusikkhare;"
    },
    {
      "id": "sn11.19:5.5",
      "pali": "Te namassāmi mātalī’ti."
    },
    {
      "id": "sn11.19:6.1",
      "pali": "‘Seṭṭhā hi kira lokasmiṁ,"
    },
    {
      "id": "sn11.19:6.2",
      "pali": "ye tvaṁ sakka namassasi;"
    },
    {
      "id": "sn11.19:6.3",
      "pali": "Ahampi te namassāmi,"
    },
    {
      "id": "sn11.19:6.4",
      "pali": "ye namassasi vāsavā’ti."
    },
    {
      "id": "sn11.19:7.1",
      "pali": "Idaṁ vatvāna maghavā,"
    },
    {
      "id": "sn11.19:7.2",
      "pali": "devarājā sujampati;"
    },
    {
      "id": "sn11.19:7.3",
      "pali": "Bhagavantaṁ namassitvā,"
    },
    {
      "id": "sn11.19:7.4",
      "pali": "pamukho rathamāruhī”ti."
    }
  ]
}
