{
  "uid": "sn45.37",
  "title": "Paṭhamabrahmaññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.37:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.37:1.2",
      "pali": "“Brahmaññañca vo, bhikkhave, desessāmi, brahmaññaphalāni ca."
    },
    {
      "id": "sn45.37:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.37:1.4",
      "pali": "Katamañca kho, bhikkhave, brahmaññaṁ?"
    },
    {
      "id": "sn45.37:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.37:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.37:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, brahmaññaṁ."
    },
    {
      "id": "sn45.37:1.8",
      "pali": "Katamāni ca, bhikkhave, brahmaññaphalāni?"
    },
    {
      "id": "sn45.37:1.9",
      "pali": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—"
    },
    {
      "id": "sn45.37:1.10",
      "pali": "imāni vuccanti, bhikkhave, brahmaññaphalānī”ti."
    },
    {
      "id": "sn45.37:1.11",
      "pali": "Sattamaṁ."
    }
  ]
}
