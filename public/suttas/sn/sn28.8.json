{
  "uid": "sn28.8",
  "title": "Nevasaññānāsaññāyatanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn28.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn28.8:1.2",
      "pali": "Atha kho āyasmā sāriputto …pe…"
    },
    {
      "id": "sn28.8:1.3",
      "pali": "“idhāhaṁ, āvuso, ākiñcaññāyatanaṁ samatikkamma nevasaññānāsaññāyatanaṁ upasampajja viharāmi …pe…"
    },
    {
      "id": "sn28.8:1.4",
      "pali": "vuṭṭhitoti vā”ti."
    },
    {
      "id": "sn28.8:1.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
