{
  "uid": "sn5.5",
  "title": "Uppalavaṇṇāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.5:1.2",
      "pali": "Atha kho uppalavaṇṇā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.5:1.3",
      "pali": "aññatarasmiṁ supupphitasālarukkhamūle aṭṭhāsi."
    },
    {
      "id": "sn5.5:1.4",
      "pali": "Atha kho māro pāpimā uppalavaṇṇāya bhikkhuniyā bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo yena uppalavaṇṇā bhikkhunī tenupasaṅkami; upasaṅkamitvā uppalavaṇṇaṁ bhikkhuniṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn5.5:2.1",
      "pali": "“Supupphitaggaṁ upagamma bhikkhuni,"
    },
    {
      "id": "sn5.5:2.2",
      "pali": "Ekā tuvaṁ tiṭṭhasi sālamūle;"
    },
    {
      "id": "sn5.5:2.3",
      "pali": "Na catthi te dutiyā vaṇṇadhātu,"
    },
    {
      "id": "sn5.5:2.4",
      "pali": "Bāle na tvaṁ bhāyasi dhuttakānan”ti."
    },
    {
      "id": "sn5.5:3.1",
      "pali": "Atha kho uppalavaṇṇāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.5:3.2",
      "pali": "“ko nu khvāyaṁ manusso vā amanusso vā gāthaṁ bhāsatī”ti?"
    },
    {
      "id": "sn5.5:3.3",
      "pali": "Atha kho uppalavaṇṇāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.5:3.4",
      "pali": "“māro kho ayaṁ pāpimā mama bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo gāthaṁ bhāsatī”ti."
    },
    {
      "id": "sn5.5:3.5",
      "pali": "Atha kho uppalavaṇṇā bhikkhunī “māro ayaṁ pāpimā” iti viditvā māraṁ pāpimantaṁ gāthāhi paccabhāsi:"
    },
    {
      "id": "sn5.5:4.1",
      "pali": "“Sataṁ sahassānipi dhuttakānaṁ,"
    },
    {
      "id": "sn5.5:4.2",
      "pali": "Idhāgatā tādisakā bhaveyyuṁ;"
    },
    {
      "id": "sn5.5:4.3",
      "pali": "Lomaṁ na iñjāmi na santasāmi,"
    },
    {
      "id": "sn5.5:4.4",
      "pali": "Na māra bhāyāmi tamekikāpi."
    },
    {
      "id": "sn5.5:5.1",
      "pali": "Esā antaradhāyāmi,"
    },
    {
      "id": "sn5.5:5.2",
      "pali": "kucchiṁ vā pavisāmi te;"
    },
    {
      "id": "sn5.5:5.3",
      "pali": "Pakhumantarikāyampi,"
    },
    {
      "id": "sn5.5:5.4",
      "pali": "tiṭṭhantiṁ maṁ na dakkhasi."
    },
    {
      "id": "sn5.5:6.1",
      "pali": "Cittasmiṁ vasībhūtāmhi,"
    },
    {
      "id": "sn5.5:6.2",
      "pali": "iddhipādā subhāvitā;"
    },
    {
      "id": "sn5.5:6.3",
      "pali": "Sabbabandhanamuttāmhi,"
    },
    {
      "id": "sn5.5:6.4",
      "pali": "na taṁ bhāyāmi āvuso”ti."
    },
    {
      "id": "sn5.5:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ uppalavaṇṇā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
