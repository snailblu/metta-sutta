{
  "uid": "sn24.96",
  "title": "Adukkhamasukhīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.96:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.96:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.96:1.3",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.96:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…."
    },
    {
      "id": "sn24.96:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.96:2.2",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.96:2.3",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn24.96:2.4",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.96:2.5",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.96:2.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.96:2.7",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.96:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn24.96:3.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.96:3.3",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn24.96:3.4",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn24.96:3.5",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn24.96:3.6",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn24.96:3.7",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn24.96:3.8",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.96:3.9",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn24.96:3.10",
      "pali": "saññā …"
    },
    {
      "id": "sn24.96:3.11",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.96:3.12",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.96:3.13",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn24.96:3.14",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn24.96:3.15",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn24.96:3.16",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn24.96:3.17",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn24.96:3.18",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.96:4.1",
      "pali": "“Tasmātiha, bhikkhave, yaṁ kiñci rūpaṁ atītānāgatapaccuppannaṁ ajjhattaṁ vā bahiddhā vā oḷārikaṁ vā sukhumaṁ vā hīnaṁ vā paṇītaṁ vā yaṁ dūre santike vā, sabbaṁ rūpaṁ: ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn24.96:4.2",
      "pali": "Yā kāci vedanā …"
    },
    {
      "id": "sn24.96:4.3",
      "pali": "yā kāci saññā …"
    },
    {
      "id": "sn24.96:4.4",
      "pali": "ye keci saṅkhārā …"
    },
    {
      "id": "sn24.96:4.5",
      "pali": "yaṁ kiñci viññāṇaṁ atītānāgatapaccuppannaṁ ajjhattaṁ vā bahiddhā vā, oḷārikaṁ vā sukhumaṁ vā hīnaṁ vā paṇītaṁ vā yaṁ dūre santike vā, sabbaṁ viññāṇaṁ: ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn24.96:5.1",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako rūpasmimpi nibbindati, vedanāyapi nibbindati, saññāyapi nibbindati, saṅkhāresupi nibbindati, viññāṇasmimpi nibbindati."
    },
    {
      "id": "sn24.96:5.2",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati. Vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn24.96:5.3",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn24.96:5.4",
      "pali": "Catutthapeyyālo."
    },
    {
      "id": "sn24.96:6.1",
      "pali": "Purimagamane aṭṭhārasa veyyākaraṇā,"
    },
    {
      "id": "sn24.96:6.2",
      "pali": "Dutiyagamane chabbīsaṁ vitthāretabbāni;"
    },
    {
      "id": "sn24.96:6.3",
      "pali": "Tatiyagamane chabbīsaṁ vitthāretabbāni,"
    },
    {
      "id": "sn24.96:6.4",
      "pali": "Catutthagamane chabbīsaṁ vitthāretabbāni."
    },
    {
      "id": "sn24.96:6.5",
      "pali": "Diṭṭhisaṁyuttaṁ samattaṁ."
    }
  ]
}
