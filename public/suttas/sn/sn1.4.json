{
  "uid": "sn1.4",
  "title": "Accentisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.4:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.4:2.1",
      "pali": "“Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "sn1.4:2.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "sn1.4:2.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn1.4:2.4",
      "pali": "Puññāni kayirātha sukhāvahānī”ti."
    },
    {
      "id": "sn1.4:3.1",
      "pali": "“Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "sn1.4:3.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "sn1.4:3.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn1.4:3.4",
      "pali": "Lokāmisaṁ pajahe santipekkho”ti."
    }
  ]
}
