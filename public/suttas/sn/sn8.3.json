{
  "uid": "sn8.3",
  "title": "Pesalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.3:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā vaṅgīso āḷaviyaṁ viharati aggāḷave cetiye āyasmatā nigrodhakappena upajjhāyena saddhiṁ."
    },
    {
      "id": "sn8.3:1.2",
      "pali": "Tena kho pana samayena āyasmā vaṅgīso attano paṭibhānena aññe pesale bhikkhū atimaññati."
    },
    {
      "id": "sn8.3:1.3",
      "pali": "Atha kho āyasmato vaṅgīsassa etadahosi:"
    },
    {
      "id": "sn8.3:1.4",
      "pali": "“alābhā vata me, na vata me lābhā; dulladdhaṁ vata me, na vata me suladdhaṁ;"
    },
    {
      "id": "sn8.3:1.5",
      "pali": "yvāhaṁ attano paṭibhānena aññe pesale bhikkhū atimaññāmī”ti."
    },
    {
      "id": "sn8.3:1.6",
      "pali": "Atha kho āyasmā vaṅgīso attanāva attano vippaṭisāraṁ uppādetvā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn8.3:2.1",
      "pali": "“Mānaṁ pajahassu gotama,"
    },
    {
      "id": "sn8.3:2.2",
      "pali": "Mānapathañca pajahassu;"
    },
    {
      "id": "sn8.3:2.3",
      "pali": "Asesaṁ mānapathasmiṁ,"
    },
    {
      "id": "sn8.3:2.4",
      "pali": "Samucchito vippaṭisārīhuvā cirarattaṁ."
    },
    {
      "id": "sn8.3:3.1",
      "pali": "Makkhena makkhitā pajā,"
    },
    {
      "id": "sn8.3:3.2",
      "pali": "Mānahatā nirayaṁ papatanti;"
    },
    {
      "id": "sn8.3:3.3",
      "pali": "Socanti janā cirarattaṁ,"
    },
    {
      "id": "sn8.3:3.4",
      "pali": "Mānahatā nirayaṁ upapannā."
    },
    {
      "id": "sn8.3:4.1",
      "pali": "Na hi socati bhikkhu kadāci,"
    },
    {
      "id": "sn8.3:4.2",
      "pali": "Maggajino sammāpaṭipanno;"
    },
    {
      "id": "sn8.3:4.3",
      "pali": "Kittiñca sukhañca anubhoti,"
    },
    {
      "id": "sn8.3:4.4",
      "pali": "Dhammadasoti tamāhu pahitattaṁ."
    },
    {
      "id": "sn8.3:5.1",
      "pali": "Tasmā akhilodha padhānavā,"
    },
    {
      "id": "sn8.3:5.2",
      "pali": "Nīvaraṇāni pahāya visuddho;"
    },
    {
      "id": "sn8.3:5.3",
      "pali": "Mānañca pahāya asesaṁ,"
    },
    {
      "id": "sn8.3:5.4",
      "pali": "Vijjāyantakaro samitāvī”ti."
    }
  ]
}
