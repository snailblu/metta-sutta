{
  "uid": "sn2.27",
  "title": "Nandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.27:1.1",
      "pali": "Ekamantaṁ ṭhito kho nando devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.27:2.1",
      "pali": "“Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "sn2.27:2.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "sn2.27:2.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn2.27:2.4",
      "pali": "Puññāni kayirātha sukhāvahānī”ti."
    },
    {
      "id": "sn2.27:3.1",
      "pali": "“Accenti kālā tarayanti rattiyo,"
    },
    {
      "id": "sn2.27:3.2",
      "pali": "Vayoguṇā anupubbaṁ jahanti;"
    },
    {
      "id": "sn2.27:3.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn2.27:3.4",
      "pali": "Lokāmisaṁ pajahe santipekkho”ti."
    }
  ]
}
