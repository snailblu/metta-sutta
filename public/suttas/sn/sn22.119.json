{
  "uid": "sn22.119",
  "title": "Dutiyaparipucchitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.119:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.119:1.2",
      "pali": "“Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.119:1.3",
      "pali": "rūpaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti samanupassathā”ti?"
    },
    {
      "id": "sn22.119:1.4",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn22.119:1.5",
      "pali": "“Sādhu, bhikkhave."
    },
    {
      "id": "sn22.119:1.6",
      "pali": "Rūpaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.119:1.7",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.119:1.8",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.119:1.9",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.119:1.10",
      "pali": "viññāṇaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti samanupassathā”ti?"
    },
    {
      "id": "sn22.119:1.11",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn22.119:1.12",
      "pali": "“Sādhu, bhikkhave."
    },
    {
      "id": "sn22.119:1.13",
      "pali": "Viññāṇaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …"
    },
    {
      "id": "sn22.119:1.14",
      "pali": "evaṁ …pe…"
    },
    {
      "id": "sn22.119:1.15",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.119:1.16",
      "pali": "Sattamaṁ."
    }
  ]
}
