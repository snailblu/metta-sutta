{
  "uid": "sn22.109",
  "title": "Sotāpannasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.109:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.109:1.2",
      "pali": "“Pañcime, bhikkhave, upādānakkhandhā."
    },
    {
      "id": "sn22.109:1.3",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.109:1.4",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho …pe… viññāṇupādānakkhandho."
    },
    {
      "id": "sn22.109:1.5",
      "pali": "Yato kho, bhikkhave, ariyasāvako imesaṁ pañcannaṁ upādānakkhandhānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.109:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, ariyasāvako sotāpanno avinipātadhammo niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn22.109:1.7",
      "pali": "Sattamaṁ."
    }
  ]
}
