{
  "uid": "sn1.24",
  "title": "Manonivāraṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.24:1.1",
      "pali": "“Yato yato mano nivāraye,"
    },
    {
      "id": "sn1.24:1.2",
      "pali": "Na dukkhameti naṁ tato tato;"
    },
    {
      "id": "sn1.24:1.3",
      "pali": "Sa sabbato mano nivāraye,"
    },
    {
      "id": "sn1.24:1.4",
      "pali": "Sa sabbato dukkhā pamuccatī”ti."
    },
    {
      "id": "sn1.24:2.1",
      "pali": "“Na sabbato mano nivāraye,"
    },
    {
      "id": "sn1.24:2.2",
      "pali": "Na mano saṁyatattamāgataṁ;"
    },
    {
      "id": "sn1.24:2.3",
      "pali": "Yato yato ca pāpakaṁ,"
    },
    {
      "id": "sn1.24:2.4",
      "pali": "Tato tato mano nivāraye”ti."
    }
  ]
}
