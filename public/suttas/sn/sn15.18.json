{
  "uid": "sn15.18",
  "title": "Puttasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.18:1.1",
      "pali": "Sāvatthiyaṁ viharati …pe…"
    },
    {
      "id": "sn15.18:1.2",
      "pali": "“na so, bhikkhave, satto sulabharūpo yo naputtabhūtapubbo …pe…"
    },
    {
      "id": "sn15.18:1.3",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.18:1.4",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
