{
  "uid": "sn2.20",
  "title": "Anāthapiṇḍikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.20:1.1",
      "pali": "Ekamantaṁ ṭhito kho anāthapiṇḍiko devaputto bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.20:2.1",
      "pali": "“Idañhi taṁ jetavanaṁ,"
    },
    {
      "id": "sn2.20:2.2",
      "pali": "isisaṅghanisevitaṁ;"
    },
    {
      "id": "sn2.20:2.3",
      "pali": "Āvutthaṁ dhammarājena,"
    },
    {
      "id": "sn2.20:2.4",
      "pali": "pītisañjananaṁ mama."
    },
    {
      "id": "sn2.20:3.1",
      "pali": "Kammaṁ vijjā ca dhammo ca,"
    },
    {
      "id": "sn2.20:3.2",
      "pali": "sīlaṁ jīvitamuttamaṁ;"
    },
    {
      "id": "sn2.20:3.3",
      "pali": "Etena maccā sujjhanti,"
    },
    {
      "id": "sn2.20:3.4",
      "pali": "na gottena dhanena vā."
    },
    {
      "id": "sn2.20:4.1",
      "pali": "Tasmā hi paṇḍito poso,"
    },
    {
      "id": "sn2.20:4.2",
      "pali": "sampassaṁ atthamattano;"
    },
    {
      "id": "sn2.20:4.3",
      "pali": "Yoniso vicine dhammaṁ,"
    },
    {
      "id": "sn2.20:4.4",
      "pali": "evaṁ tattha visujjhati."
    },
    {
      "id": "sn2.20:5.1",
      "pali": "Sāriputtova paññāya,"
    },
    {
      "id": "sn2.20:5.2",
      "pali": "sīlena upasamena ca;"
    },
    {
      "id": "sn2.20:5.3",
      "pali": "Yopi pāraṅgato bhikkhu,"
    },
    {
      "id": "sn2.20:5.4",
      "pali": "etāvaparamo siyā”ti."
    },
    {
      "id": "sn2.20:6.1",
      "pali": "Idamavoca anāthapiṇḍiko devaputto."
    },
    {
      "id": "sn2.20:6.2",
      "pali": "Idaṁ vatvā bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyi."
    },
    {
      "id": "sn2.20:7.1",
      "pali": "Atha kho bhagavā tassā rattiyā accayena bhikkhū āmantesi:"
    },
    {
      "id": "sn2.20:7.2",
      "pali": "“imaṁ, bhikkhave, rattiṁ aññataro devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yenāhaṁ tenupasaṅkami; upasaṅkamitvā maṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.20:7.3",
      "pali": "Ekamantaṁ ṭhito kho, bhikkhave, so devaputto mama santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.20:8.1",
      "pali": "‘Idañhi taṁ jetavanaṁ,"
    },
    {
      "id": "sn2.20:8.2",
      "pali": "isisaṅghanisevitaṁ;"
    },
    {
      "id": "sn2.20:8.3",
      "pali": "Āvutthaṁ dhammarājena,"
    },
    {
      "id": "sn2.20:8.4",
      "pali": "pītisañjananaṁ mama."
    },
    {
      "id": "sn2.20:9.1",
      "pali": "Kammaṁ vijjā ca dhammo ca,"
    },
    {
      "id": "sn2.20:9.2",
      "pali": "sīlaṁ jīvitamuttamaṁ;"
    },
    {
      "id": "sn2.20:9.3",
      "pali": "Etena maccā sujjhanti,"
    },
    {
      "id": "sn2.20:9.4",
      "pali": "na gottena dhanena vā."
    },
    {
      "id": "sn2.20:10.1",
      "pali": "Tasmā hi paṇḍito poso,"
    },
    {
      "id": "sn2.20:10.2",
      "pali": "sampassaṁ atthamattano;"
    },
    {
      "id": "sn2.20:10.3",
      "pali": "Yoniso vicine dhammaṁ,"
    },
    {
      "id": "sn2.20:10.4",
      "pali": "evaṁ tattha visujjhati."
    },
    {
      "id": "sn2.20:11.1",
      "pali": "Sāriputtova paññāya,"
    },
    {
      "id": "sn2.20:11.2",
      "pali": "sīlena upasamena ca;"
    },
    {
      "id": "sn2.20:11.3",
      "pali": "Yopi pāraṅgato bhikkhu,"
    },
    {
      "id": "sn2.20:11.4",
      "pali": "etāvaparamo siyā’ti."
    },
    {
      "id": "sn2.20:12.1",
      "pali": "Idamavoca, bhikkhave, so devaputto."
    },
    {
      "id": "sn2.20:12.2",
      "pali": "Idaṁ vatvā maṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyī”ti."
    },
    {
      "id": "sn2.20:13.1",
      "pali": "Evaṁ vutte, āyasmā ānando bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn2.20:13.2",
      "pali": "“so hi nūna, bhante, anāthapiṇḍiko devaputto bhavissati."
    },
    {
      "id": "sn2.20:13.3",
      "pali": "Anāthapiṇḍiko gahapati āyasmante sāriputte abhippasanno ahosī”ti."
    },
    {
      "id": "sn2.20:13.4",
      "pali": "“Sādhu sādhu, ānanda, yāvatakaṁ kho, ānanda, takkāya pattabbaṁ anuppattaṁ taṁ tayā."
    },
    {
      "id": "sn2.20:13.5",
      "pali": "Anāthapiṇḍiko hi so, ānanda, devaputto”ti."
    },
    {
      "id": "sn2.20:13.6",
      "pali": "Anāthapiṇḍikavaggo dutiyo."
    },
    {
      "id": "sn2.20:14.1",
      "pali": "Candimaso ca veṇḍu ca,"
    },
    {
      "id": "sn2.20:14.2",
      "pali": "Dīghalaṭṭhi ca nandano;"
    },
    {
      "id": "sn2.20:14.3",
      "pali": "Candano vāsudatto ca,"
    },
    {
      "id": "sn2.20:14.4",
      "pali": "Subrahmā kakudhena ca;"
    },
    {
      "id": "sn2.20:14.5",
      "pali": "Uttaro navamo vutto,"
    },
    {
      "id": "sn2.20:14.6",
      "pali": "Dasamo anāthapiṇḍikoti."
    }
  ]
}
