{
  "uid": "sn51.77-86",
  "title": "Oghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.77-86:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn51.77-86:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn51.77-86:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn51.77-86:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn51.77-86:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya cattāro iddhipādā bhāvetabbā."
    },
    {
      "id": "sn51.77-86:1.6",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.77-86:1.7",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.77-86:1.8",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.77-86:1.9",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.77-86:1.10",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn51.77-86:1.11",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ime cattāro iddhipādā bhāvetabbā”ti."
    },
    {
      "id": "sn51.77-86:1.12",
      "pali": "(Yathā maggasaṁyuttaṁ tathā vitthāretabbaṁ.)"
    },
    {
      "id": "sn51.77-86:1.13",
      "pali": "Oghavaggo aṭṭhamo."
    },
    {
      "id": "sn51.77-86:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn51.77-86:2.2",
      "pali": "ganthā anusayena ca;"
    },
    {
      "id": "sn51.77-86:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn51.77-86:2.4",
      "pali": "khandhā oruddhambhāgiyāti."
    },
    {
      "id": "sn51.77-86:2.5",
      "pali": "Iddhipādasaṁyuttaṁ sattamaṁ."
    }
  ]
}
