{
  "uid": "sn22.130",
  "title": "Dutiyaassādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.130:1.1",
      "pali": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe…"
    },
    {
      "id": "sn22.130:1.2",
      "pali": "“‘vijja, vijjā’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn22.130:1.3",
      "pali": "Katamā nu kho, āvuso, vijjā;"
    },
    {
      "id": "sn22.130:1.4",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.130:2.1",
      "pali": "“Idhāvuso, sutavā ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.130:2.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.130:2.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.130:2.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.130:2.5",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.130:2.6",
      "pali": "Ayaṁ vuccatāvuso, vijjā;"
    },
    {
      "id": "sn22.130:2.7",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.130:2.8",
      "pali": "Pañcamaṁ."
    }
  ]
}
