{
  "uid": "sn14.18",
  "title": "Assaddhamūlakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.18:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.18:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.18:1.3",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:1.4",
      "pali": "ahirikā ahirikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:1.5",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:1.6",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:1.7",
      "pali": "hirimanā hirimanehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:1.8",
      "pali": "paññavanto paññavantehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.18:1.9",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu …pe…"
    },
    {
      "id": "sn14.18:1.10",
      "pali": "anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti …pe…."
    },
    {
      "id": "sn14.18:2.1",
      "pali": "Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.18:2.2",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:2.3",
      "pali": "ahirikā ahirikehi saddhiṁ saṁsandanti samenti, duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:2.4",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:2.5",
      "pali": "hirimanā hirimanehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:2.6",
      "pali": "paññavanto paññavantehi saddhiṁ saṁsandanti samentīti."
    },
    {
      "id": "sn14.18:3.1",
      "pali": "Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.18:3.2",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:3.3",
      "pali": "anottappino anottappīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:3.4",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:3.5",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:3.6",
      "pali": "ottappino ottappīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:3.7",
      "pali": "paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…"
    },
    {
      "id": "sn14.18:3.8",
      "pali": "paṭhamavāro viya vitthāretabbo."
    },
    {
      "id": "sn14.18:4.1",
      "pali": "Dhātusova, bhikkhave …pe…"
    },
    {
      "id": "sn14.18:4.2",
      "pali": "assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:4.3",
      "pali": "appassutā appassutehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:4.4",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:4.5",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti; bahussutā bahussutehi saddhiṁ saṁsandanti samenti, paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…."
    },
    {
      "id": "sn14.18:5.1",
      "pali": "Dhātusova, bhikkhave …pe…"
    },
    {
      "id": "sn14.18:5.2",
      "pali": "assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:5.3",
      "pali": "kusītā kusītehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:5.4",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:5.5",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:5.6",
      "pali": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samenti …pe…."
    },
    {
      "id": "sn14.18:6.1",
      "pali": "Dhātusova, bhikkhave …pe…"
    },
    {
      "id": "sn14.18:6.2",
      "pali": "assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:6.3",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:6.4",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:6.5",
      "pali": "saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.18:6.6",
      "pali": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti …pe…."
    },
    {
      "id": "sn14.18:6.7",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
