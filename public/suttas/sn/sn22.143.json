{
  "uid": "sn22.143",
  "title": "Anattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.143:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.143:1.2",
      "pali": "“Yo, bhikkhave, anattā; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.143:1.3",
      "pali": "Ko ca, bhikkhave, anattā?"
    },
    {
      "id": "sn22.143:1.4",
      "pali": "Rūpaṁ, bhikkhave, anattā; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.143:1.5",
      "pali": "Vedanā anattā …"
    },
    {
      "id": "sn22.143:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn22.143:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.143:1.8",
      "pali": "viññāṇaṁ anattā; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.143:1.9",
      "pali": "Yo, bhikkhave, anattā; tatra vo chando pahātabbo”ti."
    },
    {
      "id": "sn22.143:1.10",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
