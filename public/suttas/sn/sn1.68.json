{
  "uid": "sn1.68",
  "title": "Pihitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.68:1.1",
      "pali": "“Kenassu pihito loko,"
    },
    {
      "id": "sn1.68:1.2",
      "pali": "kismiṁ loko patiṭṭhito;"
    },
    {
      "id": "sn1.68:1.3",
      "pali": "Kenassu uḍḍito loko,"
    },
    {
      "id": "sn1.68:1.4",
      "pali": "kenassu parivārito”ti."
    },
    {
      "id": "sn1.68:2.1",
      "pali": "“Maccunā pihito loko,"
    },
    {
      "id": "sn1.68:2.2",
      "pali": "dukkhe loko patiṭṭhito;"
    },
    {
      "id": "sn1.68:2.3",
      "pali": "Taṇhāya uḍḍito loko,"
    },
    {
      "id": "sn1.68:2.4",
      "pali": "jarāya parivārito”ti."
    }
  ]
}
