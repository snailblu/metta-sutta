{
  "uid": "sn51.29",
  "title": "Paṭhamabhikkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.29:1.1",
      "pali": "Atha kho sambahulā bhikkhū yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdiṁsu. Ekamantaṁ nisinnā kho te bhikkhū bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn51.29:1.2",
      "pali": "“katamā nu kho, bhante, iddhi, katamo iddhipādo, katamā iddhipādabhāvanā, katamā iddhipādabhāvanāgāminī paṭipadā”ti?"
    },
    {
      "id": "sn51.29:2.1",
      "pali": "“Idha, bhikkhave, bhikkhu anekavihitaṁ iddhividhaṁ paccanubhoti—ekopi hutvā bahudhā hoti …pe… yāva brahmalokāpi kāyena vasaṁ vatteti—"
    },
    {
      "id": "sn51.29:2.2",
      "pali": "ayaṁ vuccati, bhikkhave, iddhi."
    },
    {
      "id": "sn51.29:3.1",
      "pali": "Katamo ca, bhikkhave, iddhipādo?"
    },
    {
      "id": "sn51.29:3.2",
      "pali": "Yo, bhikkhave, maggo, yā paṭipadā iddhilābhāya iddhipaṭilābhāya saṁvattati—"
    },
    {
      "id": "sn51.29:3.3",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādo."
    },
    {
      "id": "sn51.29:4.1",
      "pali": "Katamā ca, bhikkhave, iddhipādabhāvanā?"
    },
    {
      "id": "sn51.29:4.2",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.29:4.3",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.29:4.4",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.29:4.5",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.29:4.6",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādabhāvanā."
    },
    {
      "id": "sn51.29:5.1",
      "pali": "Katamā ca, bhikkhave, iddhipādabhāvanāgāminī paṭipadā?"
    },
    {
      "id": "sn51.29:5.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn51.29:5.3",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi—"
    },
    {
      "id": "sn51.29:5.4",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādabhāvanāgāminī paṭipadā”ti."
    },
    {
      "id": "sn51.29:5.5",
      "pali": "Navamaṁ."
    }
  ]
}
