{
  "uid": "sn17.34",
  "title": "Sukkadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.34:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.34:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko."
    },
    {
      "id": "sn17.34:1.3",
      "pali": "Lābhasakkārasilokena abhibhūtassa pariyādiṇṇacittassa, bhikkhave, devadattassa sukko dhammo samucchedamagamā."
    },
    {
      "id": "sn17.34:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.34:1.5",
      "pali": "sikkhitabban”ti."
    },
    {
      "id": "sn17.34:1.6",
      "pali": "Catutthaṁ."
    }
  ]
}
