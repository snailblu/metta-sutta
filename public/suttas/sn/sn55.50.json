{
  "uid": "sn55.50",
  "title": "Aṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.50:1.1",
      "pali": "“Cattārimāni, bhikkhave, sotāpattiyaṅgāni."
    },
    {
      "id": "sn55.50:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "sn55.50:1.3",
      "pali": "Sappurisasaṁsevo, saddhammassavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—"
    },
    {
      "id": "sn55.50:1.4",
      "pali": "imāni kho, bhikkhave, cattāri sotāpattiyaṅgānī”ti."
    },
    {
      "id": "sn55.50:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn55.50:1.6",
      "pali": "Sagāthakapuññābhisandavaggo pañcamo."
    },
    {
      "id": "sn55.50:2.1",
      "pali": "Abhisandā tayo vuttā,"
    },
    {
      "id": "sn55.50:2.2",
      "pali": "Duve mahaddhanena ca;"
    },
    {
      "id": "sn55.50:2.3",
      "pali": "Suddhaṁ nandiyaṁ bhaddiyaṁ,"
    },
    {
      "id": "sn55.50:2.4",
      "pali": "Mahānāmaṅgena te dasāti."
    }
  ]
}
