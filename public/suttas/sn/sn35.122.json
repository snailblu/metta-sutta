{
  "uid": "sn35.122",
  "title": "Saṁyojaniyadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.122:1.1",
      "pali": "“Saṁyojaniye ca, bhikkhave, dhamme desessāmi saṁyojanañca."
    },
    {
      "id": "sn35.122:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.122:1.3",
      "pali": "Katame ca, bhikkhave, saṁyojaniyā dhammā, katamañca saṁyojanaṁ?"
    },
    {
      "id": "sn35.122:1.4",
      "pali": "Santi, bhikkhave, cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.122:1.5",
      "pali": "Ime vuccanti, bhikkhave, saṁyojaniyā dhammā."
    },
    {
      "id": "sn35.122:1.6",
      "pali": "Yo tattha chandarāgo, taṁ tattha saṁyojanaṁ …pe…"
    },
    {
      "id": "sn35.122:1.7",
      "pali": "santi, bhikkhave, jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn35.122:1.8",
      "pali": "santi, bhikkhave, manoviññeyyā dhammā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.122:1.9",
      "pali": "Ime vuccanti, bhikkhave, saṁyojaniyā dhammā."
    },
    {
      "id": "sn35.122:1.10",
      "pali": "Yo tattha chandarāgo taṁ tattha saṁyojanan”ti."
    },
    {
      "id": "sn35.122:1.11",
      "pali": "Navamaṁ."
    }
  ]
}
