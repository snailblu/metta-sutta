{
  "uid": "sn56.80",
  "title": "Gandhavilepanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.80:1.1",
      "pali": "… “Evameva kho, bhikkhave, appakā te sattā ye mālāgandhavilepanadhāraṇamaṇḍanavibhūsanaṭṭhānā paṭiviratā; atha kho eteva bahutarā sattā ye mālāgandhavilepanadhāraṇamaṇḍanavibhūsanaṭṭhānā appaṭiviratā …pe…."
    },
    {
      "id": "sn56.80:1.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn56.80:1.3",
      "pali": "Dutiyaāmakadhaññapeyyālavaggo aṭṭhamo."
    },
    {
      "id": "sn56.80:2.1",
      "pali": "Pāṇaṁ adinnaṁ kāmesu,"
    },
    {
      "id": "sn56.80:2.2",
      "pali": "musāvādañca pesuññaṁ;"
    },
    {
      "id": "sn56.80:2.3",
      "pali": "Pharusaṁ samphappalāpaṁ,"
    },
    {
      "id": "sn56.80:2.4",
      "pali": "bījañca vikālaṁ gandhanti."
    }
  ]
}
