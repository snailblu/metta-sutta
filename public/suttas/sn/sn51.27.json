{
  "uid": "sn51.27",
  "title": "Paṭhamaānandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.27:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn51.27:1.2",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā ānando bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn51.27:2.1",
      "pali": "“Katamā nu kho, bhante, iddhi, katamo iddhipādo, katamā iddhipādabhāvanā, katamā iddhipādabhāvanāgāminī paṭipadā”ti?"
    },
    {
      "id": "sn51.27:2.2",
      "pali": "“Idhānanda, bhikkhu anekavihitaṁ iddhividhaṁ paccanubhoti—ekopi hutvā bahudhā hoti, bahudhāpi hutvā eko hoti …pe… yāva brahmalokāpi kāyena vasaṁ vatteti—"
    },
    {
      "id": "sn51.27:2.3",
      "pali": "ayaṁ vuccatānanda, iddhi."
    },
    {
      "id": "sn51.27:3.1",
      "pali": "Katamo cānanda, iddhipādo?"
    },
    {
      "id": "sn51.27:3.2",
      "pali": "Yo, ānanda, maggo yā paṭipadā iddhilābhāya iddhipaṭilābhāya saṁvattati—"
    },
    {
      "id": "sn51.27:3.3",
      "pali": "ayaṁ vuccatānanda, iddhipādo."
    },
    {
      "id": "sn51.27:4.1",
      "pali": "Katamā cānanda, iddhipādabhāvanā?"
    },
    {
      "id": "sn51.27:4.2",
      "pali": "Idhānanda, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.27:4.3",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.27:4.4",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.27:4.5",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.27:4.6",
      "pali": "ayaṁ vuccatānanda, iddhipādabhāvanā."
    },
    {
      "id": "sn51.27:5.1",
      "pali": "Katamā cānanda, iddhipādabhāvanāgāminī paṭipadā?"
    },
    {
      "id": "sn51.27:5.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn51.27:5.3",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi—"
    },
    {
      "id": "sn51.27:5.4",
      "pali": "ayaṁ vuccatānanda, iddhipādabhāvanāgāminī paṭipadā”ti."
    },
    {
      "id": "sn51.27:5.5",
      "pali": "Sattamaṁ."
    }
  ]
}
