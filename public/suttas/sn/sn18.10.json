{
  "uid": "sn18.10",
  "title": "Khandhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.10:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.10:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.10:1.3",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.10:1.4",
      "pali": "“Aniccaṁ, bhante” …"
    },
    {
      "id": "sn18.10:1.5",
      "pali": "“vedanā …pe…"
    },
    {
      "id": "sn18.10:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn18.10:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn18.10:1.8",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.10:1.9",
      "pali": "“Aniccaṁ, bhante” …"
    },
    {
      "id": "sn18.10:1.10",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasmimpi nibbindati …pe… vedanāyapi nibbindati … saññāyapi nibbindati … saṅkhāresupi nibbindati … viññāṇasmimpi nibbindati;"
    },
    {
      "id": "sn18.10:1.11",
      "pali": "nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn18.10:1.12",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn18.10:1.13",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn18.10:1.14",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn18.10:2.1",
      "pali": "Cakkhu rūpañca viññāṇaṁ,"
    },
    {
      "id": "sn18.10:2.2",
      "pali": "samphasso vedanāya ca;"
    },
    {
      "id": "sn18.10:2.3",
      "pali": "Saññā sañcetanā taṇhā,"
    },
    {
      "id": "sn18.10:2.4",
      "pali": "dhātu khandhena te dasāti."
    }
  ]
}
