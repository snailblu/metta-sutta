{
  "uid": "sn11.16",
  "title": "Yajamānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.16:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati gijjhakūṭe pabbate."
    },
    {
      "id": "sn11.16:1.2",
      "pali": "Atha kho sakko devānamindo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn11.16:1.3",
      "pali": "Ekamantaṁ ṭhito kho sakko devānamindo bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.16:2.1",
      "pali": "“Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "sn11.16:2.2",
      "pali": "puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "sn11.16:2.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "sn11.16:2.4",
      "pali": "kattha dinnaṁ mahapphalan”ti."
    },
    {
      "id": "sn11.16:3.1",
      "pali": "“Cattāro ca paṭipannā,"
    },
    {
      "id": "sn11.16:3.2",
      "pali": "cattāro ca phale ṭhitā;"
    },
    {
      "id": "sn11.16:3.3",
      "pali": "Esa saṅgho ujubhūto,"
    },
    {
      "id": "sn11.16:3.4",
      "pali": "paññāsīlasamāhito."
    },
    {
      "id": "sn11.16:4.1",
      "pali": "Yajamānānaṁ manussānaṁ,"
    },
    {
      "id": "sn11.16:4.2",
      "pali": "Puññapekkhāna pāṇinaṁ;"
    },
    {
      "id": "sn11.16:4.3",
      "pali": "Karotaṁ opadhikaṁ puññaṁ,"
    },
    {
      "id": "sn11.16:4.4",
      "pali": "Saṅghe dinnaṁ mahapphalan”ti."
    }
  ]
}
