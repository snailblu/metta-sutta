{
  "uid": "sn4.15",
  "title": "Mānasasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.15:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.15:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn4.15:1.3",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.15:2.1",
      "pali": "“Antalikkhacaro pāso,"
    },
    {
      "id": "sn4.15:2.2",
      "pali": "yvāyaṁ carati mānaso;"
    },
    {
      "id": "sn4.15:2.3",
      "pali": "Tena taṁ bādhayissāmi,"
    },
    {
      "id": "sn4.15:2.4",
      "pali": "na me samaṇa mokkhasī”ti."
    },
    {
      "id": "sn4.15:3.1",
      "pali": "“Rūpā saddā rasā gandhā,"
    },
    {
      "id": "sn4.15:3.2",
      "pali": "Phoṭṭhabbā ca manoramā;"
    },
    {
      "id": "sn4.15:3.3",
      "pali": "Ettha me vigato chando,"
    },
    {
      "id": "sn4.15:3.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "sn4.15:4.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
