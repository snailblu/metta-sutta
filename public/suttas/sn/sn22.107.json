{
  "uid": "sn22.107",
  "title": "Samaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.107:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.107:1.2",
      "pali": "“Pañcime, bhikkhave, upādānakkhandhā."
    },
    {
      "id": "sn22.107:1.3",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.107:1.4",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho …pe… viññāṇupādānakkhandho."
    },
    {
      "id": "sn22.107:1.5",
      "pali": "Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā imesaṁ pañcannaṁ upādānakkhandhānaṁ assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe…"
    },
    {
      "id": "sn22.107:1.6",
      "pali": "pajānanti, sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn22.107:1.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
