{
  "uid": "sn17.12",
  "title": "Rūpiyapātisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.12:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.12:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.12:1.3",
      "pali": "idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "sn17.12:1.4",
      "pali": "‘na cāyamāyasmā rūpiyapātiyāpi suvaṇṇacuṇṇaparipūrāya hetu sampajānamusā bhāseyyā’ti."
    },
    {
      "id": "sn17.12:1.5",
      "pali": "Tamenaṁ passāmi aparena samayena lābhasakkārasilokena abhibhūtaṁ pariyādiṇṇacittaṁ sampajānamusā bhāsantaṁ."
    },
    {
      "id": "sn17.12:1.6",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.12:1.7",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.12:1.8",
      "pali": "Dutiyaṁ."
    }
  ]
}
