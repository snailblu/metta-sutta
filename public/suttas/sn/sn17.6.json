{
  "uid": "sn17.6",
  "title": "Asanisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.6:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.6:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… adhigamāya."
    },
    {
      "id": "sn17.6:1.3",
      "pali": "Kaṁ, bhikkhave, asanivicakkaṁ āgacchatu, sekhaṁ appattamānasaṁ lābhasakkārasiloko anupāpuṇātu."
    },
    {
      "id": "sn17.6:2.1",
      "pali": "Asanivicakkanti kho, bhikkhave, lābhasakkārasilokassetaṁ adhivacanaṁ."
    },
    {
      "id": "sn17.6:2.2",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.6:2.3",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.6:2.4",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
