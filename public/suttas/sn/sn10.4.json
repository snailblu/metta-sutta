{
  "uid": "sn10.4",
  "title": "Maṇibhaddasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.4:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā magadhesu viharati maṇimālike cetiye maṇibhaddassa yakkhassa bhavane."
    },
    {
      "id": "sn10.4:1.2",
      "pali": "Atha kho maṇibhaddo yakkho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn10.4:2.1",
      "pali": "“Satīmato sadā bhaddaṁ,"
    },
    {
      "id": "sn10.4:2.2",
      "pali": "satimā sukhamedhati;"
    },
    {
      "id": "sn10.4:2.3",
      "pali": "Satīmato suve seyyo,"
    },
    {
      "id": "sn10.4:2.4",
      "pali": "verā ca parimuccatī”ti."
    },
    {
      "id": "sn10.4:3.1",
      "pali": "“Satīmato sadā bhaddaṁ,"
    },
    {
      "id": "sn10.4:3.2",
      "pali": "satimā sukhamedhati;"
    },
    {
      "id": "sn10.4:3.3",
      "pali": "Satīmato suve seyyo,"
    },
    {
      "id": "sn10.4:3.4",
      "pali": "verā na parimuccati."
    },
    {
      "id": "sn10.4:4.1",
      "pali": "Yassa sabbamahorattaṁ,"
    },
    {
      "id": "sn10.4:4.2",
      "pali": "ahiṁsāya rato mano;"
    },
    {
      "id": "sn10.4:4.3",
      "pali": "Mettaṁso sabbabhūtesu,"
    },
    {
      "id": "sn10.4:4.4",
      "pali": "veraṁ tassa na kenacī”ti."
    }
  ]
}
