{
  "uid": "sn19.18",
  "title": "Pāpabhikkhunīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.18:1.1",
      "pali": "“Addasaṁ bhikkhuniṁ vehāsaṁ gacchantiṁ."
    },
    {
      "id": "sn19.18:1.2",
      "pali": "Tassā saṅghāṭipi ādittā …pe…"
    },
    {
      "id": "sn19.18:1.3",
      "pali": "pāpabhikkhunī ahosi …pe…."
    },
    {
      "id": "sn19.18:1.4",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
