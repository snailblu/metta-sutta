{
  "uid": "sn22.85",
  "title": "Yamakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.85:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā sāriputto sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn22.85:1.2",
      "pali": "Tena kho pana samayena yamakassa nāma bhikkhuno evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ hoti:"
    },
    {
      "id": "sn22.85:1.3",
      "pali": "“tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā”ti."
    },
    {
      "id": "sn22.85:2.1",
      "pali": "Assosuṁ kho sambahulā bhikkhū yamakassa kira nāma bhikkhuno evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ hoti:"
    },
    {
      "id": "sn22.85:2.2",
      "pali": "“tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā”ti."
    },
    {
      "id": "sn22.85:2.3",
      "pali": "Atha kho te bhikkhū yenāyasmā yamako tenupasaṅkamiṁsu; upasaṅkamitvā āyasmatā yamakena saddhiṁ sammodiṁsu."
    },
    {
      "id": "sn22.85:2.4",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdiṁsu. Ekamantaṁ nisinnā kho te bhikkhū āyasmantaṁ yamakaṁ etadavocuṁ:"
    },
    {
      "id": "sn22.85:3.1",
      "pali": "“Saccaṁ kira te, āvuso yamaka, evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ:"
    },
    {
      "id": "sn22.85:3.2",
      "pali": "‘tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn22.85:3.3",
      "pali": "“Evaṁ khvāhaṁ, āvuso, bhagavatā dhammaṁ desitaṁ ājānāmi:"
    },
    {
      "id": "sn22.85:3.4",
      "pali": "‘khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’”ti."
    },
    {
      "id": "sn22.85:4.1",
      "pali": "“Mā, āvuso yamaka, evaṁ avaca, mā bhagavantaṁ abbhācikkhi. Na hi sādhu bhagavato abbhācikkhanaṁ. Na hi bhagavā evaṁ vadeyya:"
    },
    {
      "id": "sn22.85:4.2",
      "pali": "‘khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’”ti."
    },
    {
      "id": "sn22.85:4.3",
      "pali": "Evampi kho āyasmā yamako tehi bhikkhūhi vuccamāno tatheva taṁ pāpakaṁ diṭṭhigataṁ thāmasā parāmāsā abhinivissa voharati:"
    },
    {
      "id": "sn22.85:4.4",
      "pali": "“tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā”ti."
    },
    {
      "id": "sn22.85:5.1",
      "pali": "Yato kho te bhikkhū nāsakkhiṁsu āyasmantaṁ yamakaṁ etasmā pāpakā diṭṭhigatā vivecetuṁ, atha kho te bhikkhū uṭṭhāyāsanā yenāyasmā sāriputto tenupasaṅkamiṁsu; upasaṅkamitvā āyasmantaṁ sāriputtaṁ etadavocuṁ:"
    },
    {
      "id": "sn22.85:5.2",
      "pali": "“yamakassa nāma, āvuso sāriputta, bhikkhuno evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ:"
    },
    {
      "id": "sn22.85:5.3",
      "pali": "‘tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’ti."
    },
    {
      "id": "sn22.85:5.4",
      "pali": "Sādhāyasmā sāriputto yena yamako bhikkhu tenupasaṅkamatu anukampaṁ upādāyā”ti."
    },
    {
      "id": "sn22.85:5.5",
      "pali": "Adhivāsesi kho āyasmā sāriputto tuṇhībhāvena."
    },
    {
      "id": "sn22.85:5.6",
      "pali": "Atha kho āyasmā sāriputto sāyanhasamayaṁ paṭisallānā vuṭṭhito yenāyasmā yamako tenupasaṅkami; upasaṅkamitvā āyasmatā yamakena saddhiṁ sammodi …pe… ekamantaṁ nisinno kho āyasmā sāriputto āyasmantaṁ yamakaṁ etadavoca:"
    },
    {
      "id": "sn22.85:6.1",
      "pali": "“Saccaṁ kira te, āvuso yamaka, evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ:"
    },
    {
      "id": "sn22.85:6.2",
      "pali": "‘tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn22.85:6.3",
      "pali": "“Evaṁ khvāhaṁ, āvuso, bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā”ti."
    },
    {
      "id": "sn22.85:7.1",
      "pali": "“Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:7.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.85:7.3",
      "pali": "“Aniccaṁ, āvuso”."
    },
    {
      "id": "sn22.85:7.4",
      "pali": "“Vedanā niccā …"
    },
    {
      "id": "sn22.85:7.5",
      "pali": "saññā …"
    },
    {
      "id": "sn22.85:7.6",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.85:7.7",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.85:7.8",
      "pali": "“Aniccaṁ, āvuso”."
    },
    {
      "id": "sn22.85:7.9",
      "pali": "“Tasmātiha …pe…"
    },
    {
      "id": "sn22.85:7.10",
      "pali": "evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.85:7.11",
      "pali": "nāparaṁ itthattāyāti pajānāti."
    },
    {
      "id": "sn22.85:8.1",
      "pali": "Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:8.2",
      "pali": "rūpaṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:8.3",
      "pali": "“No hetaṁ, āvuso” …"
    },
    {
      "id": "sn22.85:8.4",
      "pali": "“vedanaṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:8.5",
      "pali": "“No hetaṁ, āvuso” …"
    },
    {
      "id": "sn22.85:8.6",
      "pali": "“saññaṁ …"
    },
    {
      "id": "sn22.85:8.7",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.85:8.8",
      "pali": "viññāṇaṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:8.9",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:9.1",
      "pali": "“Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:9.2",
      "pali": "rūpasmiṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:9.3",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:9.4",
      "pali": "“Aññatra rūpā tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:9.5",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:9.6",
      "pali": "“Vedanāya …"
    },
    {
      "id": "sn22.85:9.7",
      "pali": "aññatra vedanāya …pe…"
    },
    {
      "id": "sn22.85:9.8",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.85:9.9",
      "pali": "aññatra saññāya …"
    },
    {
      "id": "sn22.85:9.10",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn22.85:9.11",
      "pali": "aññatra saṅkhārehi …"
    },
    {
      "id": "sn22.85:9.12",
      "pali": "viññāṇasmiṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:9.13",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:9.14",
      "pali": "“Aññatra viññāṇā tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:9.15",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:10.1",
      "pali": "“Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:10.2",
      "pali": "rūpaṁ … vedanaṁ … saññaṁ … saṅkhāre … viññāṇaṁ tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:10.3",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:11.1",
      "pali": "“Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:11.2",
      "pali": "ayaṁ so arūpī … avedano … asaññī … asaṅkhāro … aviññāṇo tathāgatoti samanupassasī”ti?"
    },
    {
      "id": "sn22.85:11.3",
      "pali": "“No hetaṁ, āvuso”."
    },
    {
      "id": "sn22.85:11.4",
      "pali": "“Ettha ca te, āvuso yamaka, diṭṭheva dhamme saccato thetato tathāgate anupalabbhiyamāne, kallaṁ nu te taṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn22.85:11.5",
      "pali": "‘tathāhaṁ bhagavatā dhammaṁ desitaṁ ājānāmi, yathā khīṇāsavo bhikkhu kāyassa bhedā ucchijjati vinassati, na hoti paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn22.85:12.1",
      "pali": "“Ahu kho me taṁ, āvuso sāriputta, pubbe aviddasuno pāpakaṁ diṭṭhigataṁ;"
    },
    {
      "id": "sn22.85:12.2",
      "pali": "idañca panāyasmato sāriputtassa dhammadesanaṁ sutvā tañceva pāpakaṁ diṭṭhigataṁ pahīnaṁ, dhammo ca me abhisamito”ti."
    },
    {
      "id": "sn22.85:13.1",
      "pali": "“Sace taṁ, āvuso yamaka, evaṁ puccheyyuṁ:"
    },
    {
      "id": "sn22.85:13.2",
      "pali": "‘yo so, āvuso yamaka, bhikkhu arahaṁ khīṇāsavo so kāyassa bhedā paraṁ maraṇā kiṁ hotī’ti?"
    },
    {
      "id": "sn22.85:13.3",
      "pali": "Evaṁ puṭṭho tvaṁ, āvuso yamaka, kinti byākareyyāsī”ti?"
    },
    {
      "id": "sn22.85:13.4",
      "pali": "“Sace maṁ, āvuso, evaṁ puccheyyuṁ:"
    },
    {
      "id": "sn22.85:13.5",
      "pali": "‘yo so, āvuso yamaka, bhikkhu arahaṁ khīṇāsavo so kāyassa bhedā paraṁ maraṇā kiṁ hotī’ti?"
    },
    {
      "id": "sn22.85:13.6",
      "pali": "Evaṁ puṭṭhohaṁ, āvuso, evaṁ byākareyyaṁ:"
    },
    {
      "id": "sn22.85:13.7",
      "pali": "‘rūpaṁ kho, āvuso, aniccaṁ."
    },
    {
      "id": "sn22.85:13.8",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.85:13.9",
      "pali": "yaṁ dukkhaṁ taṁ niruddhaṁ tadatthaṅgataṁ."
    },
    {
      "id": "sn22.85:13.10",
      "pali": "Vedanā …"
    },
    {
      "id": "sn22.85:13.11",
      "pali": "saññā …"
    },
    {
      "id": "sn22.85:13.12",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.85:13.13",
      "pali": "viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn22.85:13.14",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.85:13.15",
      "pali": "yaṁ dukkhaṁ taṁ niruddhaṁ tadatthaṅgatan’ti."
    },
    {
      "id": "sn22.85:13.16",
      "pali": "Evaṁ puṭṭhohaṁ, āvuso, evaṁ byākareyyan”ti."
    },
    {
      "id": "sn22.85:14.1",
      "pali": "“Sādhu sādhu, āvuso yamaka."
    },
    {
      "id": "sn22.85:14.2",
      "pali": "Tena hāvuso yamaka, upamaṁ te karissāmi etasseva atthassa bhiyyoso mattāya ñāṇāya."
    },
    {
      "id": "sn22.85:14.3",
      "pali": "Seyyathāpi, āvuso yamaka, gahapati vā gahapatiputto vā aḍḍho mahaddhano mahābhogo;"
    },
    {
      "id": "sn22.85:14.4",
      "pali": "so ca ārakkhasampanno."
    },
    {
      "id": "sn22.85:14.5",
      "pali": "Tassa kocideva puriso uppajjeyya anatthakāmo ahitakāmo ayogakkhemakāmo jīvitā voropetukāmo."
    },
    {
      "id": "sn22.85:14.6",
      "pali": "Tassa evamassa:"
    },
    {
      "id": "sn22.85:14.7",
      "pali": "‘ayaṁ kho gahapati vā gahapatiputto vā aḍḍho mahaddhano mahābhogo;"
    },
    {
      "id": "sn22.85:14.8",
      "pali": "so ca ārakkhasampanno;"
    },
    {
      "id": "sn22.85:14.9",
      "pali": "nāyaṁ sukaro pasayha jīvitā voropetuṁ."
    },
    {
      "id": "sn22.85:14.10",
      "pali": "Yannūnāhaṁ anupakhajja jīvitā voropeyyan’ti."
    },
    {
      "id": "sn22.85:14.11",
      "pali": "So taṁ gahapatiṁ vā gahapatiputtaṁ vā upasaṅkamitvā evaṁ vadeyya:"
    },
    {
      "id": "sn22.85:14.12",
      "pali": "‘upaṭṭhaheyyaṁ taṁ, bhante’ti."
    },
    {
      "id": "sn22.85:14.13",
      "pali": "Tamenaṁ so gahapati vā gahapatiputto vā upaṭṭhāpeyya."
    },
    {
      "id": "sn22.85:14.14",
      "pali": "So upaṭṭhaheyya pubbuṭṭhāyī pacchānipātī kiṅkārapaṭissāvī manāpacārī piyavādī."
    },
    {
      "id": "sn22.85:14.15",
      "pali": "Tassa so gahapati vā gahapatiputto vā mittatopi naṁ saddaheyya;"
    },
    {
      "id": "sn22.85:14.16",
      "pali": "suhajjatopi naṁ saddaheyya;"
    },
    {
      "id": "sn22.85:14.17",
      "pali": "tasmiñca vissāsaṁ āpajjeyya."
    },
    {
      "id": "sn22.85:14.18",
      "pali": "Yadā kho, āvuso, tassa purisassa evamassa:"
    },
    {
      "id": "sn22.85:14.19",
      "pali": "‘saṁvissattho kho myāyaṁ gahapati vā gahapatiputto vā’ti, atha naṁ rahogataṁ viditvā tiṇhena satthena jīvitā voropeyya."
    },
    {
      "id": "sn22.85:15.1",
      "pali": "Taṁ kiṁ maññasi, āvuso yamaka,"
    },
    {
      "id": "sn22.85:15.2",
      "pali": "yadā hi so puriso amuṁ gahapatiṁ vā gahapatiputtaṁ vā upasaṅkamitvā evaṁ āha:"
    },
    {
      "id": "sn22.85:15.3",
      "pali": "‘upaṭṭhaheyyaṁ taṁ, bhante’ti, tadāpi so vadhakova."
    },
    {
      "id": "sn22.85:15.4",
      "pali": "Vadhakañca pana santaṁ na aññāsi:"
    },
    {
      "id": "sn22.85:15.5",
      "pali": "‘vadhako me’ti."
    },
    {
      "id": "sn22.85:15.6",
      "pali": "Yadāpi so upaṭṭhahati pubbuṭṭhāyī pacchānipātī kiṅkārapaṭissāvī manāpacārī piyavādī, tadāpi so vadhakova."
    },
    {
      "id": "sn22.85:15.7",
      "pali": "Vadhakañca pana santaṁ na aññāsi:"
    },
    {
      "id": "sn22.85:15.8",
      "pali": "‘vadhako me’ti."
    },
    {
      "id": "sn22.85:15.9",
      "pali": "Yadāpi naṁ rahogataṁ viditvā tiṇhena satthena jīvitā voropeti, tadāpi so vadhakova."
    },
    {
      "id": "sn22.85:15.10",
      "pali": "Vadhakañca pana santaṁ na aññāsi:"
    },
    {
      "id": "sn22.85:15.11",
      "pali": "‘vadhako me’”ti."
    },
    {
      "id": "sn22.85:15.12",
      "pali": "“Evamāvuso”ti."
    },
    {
      "id": "sn22.85:15.13",
      "pali": "“Evameva kho, āvuso, assutavā puthujjano ariyānaṁ adassāvī ariyadhammassa akovido ariyadhamme avinīto, sappurisānaṁ adassāvī sappurisadhammassa akovido sappurisadhamme avinīto"
    },
    {
      "id": "sn22.85:15.14",
      "pali": "rūpaṁ attato samanupassati, rūpavantaṁ vā attānaṁ; attani vā rūpaṁ, rūpasmiṁ vā attānaṁ."
    },
    {
      "id": "sn22.85:15.15",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.85:15.16",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.85:15.17",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.85:15.18",
      "pali": "viññāṇaṁ attato samanupassati, viññāṇavantaṁ vā attānaṁ; attani vā viññāṇaṁ, viññāṇasmiṁ vā attānaṁ."
    },
    {
      "id": "sn22.85:16.1",
      "pali": "So aniccaṁ rūpaṁ ‘aniccaṁ rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:16.2",
      "pali": "Aniccaṁ vedanaṁ ‘aniccā vedanā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:16.3",
      "pali": "Aniccaṁ saññaṁ ‘aniccā saññā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:16.4",
      "pali": "Anicce saṅkhāre ‘aniccā saṅkhārā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:16.5",
      "pali": "Aniccaṁ viññāṇaṁ ‘aniccaṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:17.1",
      "pali": "Dukkhaṁ rūpaṁ ‘dukkhaṁ rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:17.2",
      "pali": "Dukkhaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:17.3",
      "pali": "dukkhaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:17.4",
      "pali": "dukkhe saṅkhāre …"
    },
    {
      "id": "sn22.85:17.5",
      "pali": "dukkhaṁ viññāṇaṁ ‘dukkhaṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:18.1",
      "pali": "Anattaṁ rūpaṁ ‘anattā rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:18.2",
      "pali": "Anattaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:18.3",
      "pali": "anattaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:18.4",
      "pali": "anatte saṅkhāre …"
    },
    {
      "id": "sn22.85:18.5",
      "pali": "anattaṁ viññāṇaṁ ‘anattaṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:19.1",
      "pali": "Saṅkhataṁ rūpaṁ ‘saṅkhataṁ rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:19.2",
      "pali": "Saṅkhataṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:19.3",
      "pali": "saṅkhataṁ saññaṁ …"
    },
    {
      "id": "sn22.85:19.4",
      "pali": "saṅkhate saṅkhāre …"
    },
    {
      "id": "sn22.85:19.5",
      "pali": "saṅkhataṁ viññāṇaṁ ‘saṅkhataṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:20.1",
      "pali": "Vadhakaṁ rūpaṁ ‘vadhakaṁ rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:20.2",
      "pali": "Vadhakaṁ vedanaṁ ‘vadhakā vedanā’ti …"
    },
    {
      "id": "sn22.85:20.3",
      "pali": "vadhakaṁ saññaṁ ‘vadhakā saññā’ti …"
    },
    {
      "id": "sn22.85:20.4",
      "pali": "vadhake saṅkhāre ‘vadhakā saṅkhārā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:20.5",
      "pali": "Vadhakaṁ viññāṇaṁ ‘vadhakaṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.85:21.1",
      "pali": "So rūpaṁ upeti upādiyati adhiṭṭhāti ‘attā me’ti."
    },
    {
      "id": "sn22.85:21.2",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.85:21.3",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.85:21.4",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.85:21.5",
      "pali": "viññāṇaṁ upeti upādiyati adhiṭṭhāti ‘attā me’ti."
    },
    {
      "id": "sn22.85:21.6",
      "pali": "Tassime pañcupādānakkhandhā upetā upādinnā dīgharattaṁ ahitāya dukkhāya saṁvattanti."
    },
    {
      "id": "sn22.85:22.1",
      "pali": "Sutavā ca kho, āvuso, ariyasāvako ariyānaṁ dassāvī …pe… sappurisadhamme suvinīto"
    },
    {
      "id": "sn22.85:22.2",
      "pali": "na rūpaṁ attato samanupassati, na rūpavantaṁ attānaṁ; na attani rūpaṁ, na rūpasmiṁ attānaṁ."
    },
    {
      "id": "sn22.85:22.3",
      "pali": "Na vedanaṁ …"
    },
    {
      "id": "sn22.85:22.4",
      "pali": "na saññaṁ …"
    },
    {
      "id": "sn22.85:22.5",
      "pali": "na saṅkhāre …"
    },
    {
      "id": "sn22.85:22.6",
      "pali": "na viññāṇaṁ attato samanupassati, na viññāṇavantaṁ attānaṁ;"
    },
    {
      "id": "sn22.85:22.7",
      "pali": "na attani viññāṇaṁ, na viññāṇasmiṁ attānaṁ."
    },
    {
      "id": "sn22.85:23.1",
      "pali": "So aniccaṁ rūpaṁ ‘aniccaṁ rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:23.2",
      "pali": "Aniccaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:23.3",
      "pali": "aniccaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:23.4",
      "pali": "anicce saṅkhāre …"
    },
    {
      "id": "sn22.85:23.5",
      "pali": "aniccaṁ viññāṇaṁ ‘aniccaṁ viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:24.1",
      "pali": "Dukkhaṁ rūpaṁ ‘dukkhaṁ rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:24.2",
      "pali": "Dukkhaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:24.3",
      "pali": "dukkhaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:24.4",
      "pali": "dukkhe saṅkhāre …"
    },
    {
      "id": "sn22.85:24.5",
      "pali": "dukkhaṁ viññāṇaṁ ‘dukkhaṁ viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:25.1",
      "pali": "Anattaṁ rūpaṁ ‘anattā rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:25.2",
      "pali": "Anattaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:25.3",
      "pali": "anattaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:25.4",
      "pali": "anatte saṅkhāre …"
    },
    {
      "id": "sn22.85:25.5",
      "pali": "anattaṁ viññāṇaṁ ‘anattā viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:26.1",
      "pali": "Saṅkhataṁ rūpaṁ ‘saṅkhataṁ rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:26.2",
      "pali": "Saṅkhataṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:26.3",
      "pali": "saṅkhataṁ saññaṁ …"
    },
    {
      "id": "sn22.85:26.4",
      "pali": "saṅkhate saṅkhāre …"
    },
    {
      "id": "sn22.85:26.5",
      "pali": "saṅkhataṁ viññāṇaṁ ‘saṅkhataṁ viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:27.1",
      "pali": "Vadhakaṁ rūpaṁ ‘vadhakaṁ rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:27.2",
      "pali": "Vadhakaṁ vedanaṁ …"
    },
    {
      "id": "sn22.85:27.3",
      "pali": "vadhakaṁ saññaṁ …"
    },
    {
      "id": "sn22.85:27.4",
      "pali": "vadhake saṅkhāre ‘vadhakā saṅkhārā’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:27.5",
      "pali": "Vadhakaṁ viññāṇaṁ ‘vadhakaṁ viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.85:28.1",
      "pali": "So rūpaṁ na upeti, na upādiyati, nādhiṭṭhāti: ‘attā me’ti."
    },
    {
      "id": "sn22.85:28.2",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.85:28.3",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.85:28.4",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.85:28.5",
      "pali": "viññāṇaṁ na upeti, na upādiyati, nādhiṭṭhāti: ‘attā me’ti."
    },
    {
      "id": "sn22.85:28.6",
      "pali": "Tassime pañcupādānakkhandhā anupetā anupādinnā dīgharattaṁ hitāya sukhāya saṁvattantī”ti."
    },
    {
      "id": "sn22.85:28.7",
      "pali": "“Evametaṁ, āvuso sāriputta, hoti yesaṁ āyasmantānaṁ tādisā sabrahmacārino anukampakā atthakāmā ovādakā anusāsakā."
    },
    {
      "id": "sn22.85:28.8",
      "pali": "Idañca pana me āyasmato sāriputtassa dhammadesanaṁ sutvā anupādāya āsavehi cittaṁ vimuttan”ti."
    },
    {
      "id": "sn22.85:28.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
