{
  "uid": "sn22.108",
  "title": "Dutiyasamaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.108:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.108:1.2",
      "pali": "“Pañcime, bhikkhave, upādānakkhandhā."
    },
    {
      "id": "sn22.108:1.3",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.108:1.4",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho."
    },
    {
      "id": "sn22.108:1.5",
      "pali": "Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā imesaṁ pañcannaṁ upādānakkhandhānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe…"
    },
    {
      "id": "sn22.108:1.6",
      "pali": "pajānanti, sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn22.108:1.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
