{
  "uid": "sn2.11",
  "title": "Candimasasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.11:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.11:1.2",
      "pali": "Atha kho candimaso devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.11:1.3",
      "pali": "Ekamantaṁ ṭhito kho candimaso devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.11:2.1",
      "pali": "“Te hi sotthiṁ gamissanti,"
    },
    {
      "id": "sn2.11:2.2",
      "pali": "kacchevāmakase magā;"
    },
    {
      "id": "sn2.11:2.3",
      "pali": "Jhānāni upasampajja,"
    },
    {
      "id": "sn2.11:2.4",
      "pali": "ekodi nipakā satā”ti."
    },
    {
      "id": "sn2.11:3.1",
      "pali": "“Te hi pāraṁ gamissanti,"
    },
    {
      "id": "sn2.11:3.2",
      "pali": "chetvā jālaṁva ambujo;"
    },
    {
      "id": "sn2.11:3.3",
      "pali": "Jhānāni upasampajja,"
    },
    {
      "id": "sn2.11:3.4",
      "pali": "appamattā raṇañjahā”ti."
    }
  ]
}
