{
  "uid": "sn46.21",
  "title": "Bodhāyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.21:1.1",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn46.21:2.1",
      "pali": "“‘Bojjhaṅgā, bojjhaṅgā’ti, bhante, vuccanti."
    },
    {
      "id": "sn46.21:2.2",
      "pali": "Kittāvatā nu kho, bhante, ‘bojjhaṅgā’ti vuccantī”ti?"
    },
    {
      "id": "sn46.21:2.3",
      "pali": "“‘Bodhāya saṁvattantī’ti kho, bhikkhu, tasmā bojjhaṅgāti vuccanti."
    },
    {
      "id": "sn46.21:2.4",
      "pali": "Idha, bhikkhu, satisambojjhaṅgaṁ bhāveti vivekanissitaṁ …pe…"
    },
    {
      "id": "sn46.21:2.5",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn46.21:2.6",
      "pali": "‘Bodhāya saṁvattantī’ti kho, bhikkhu, tasmā ‘bojjhaṅgā’ti vuccantī”ti."
    },
    {
      "id": "sn46.21:2.7",
      "pali": "Paṭhamaṁ."
    }
  ]
}
