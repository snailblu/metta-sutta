{
  "uid": "sn7.10",
  "title": "Bahudhītarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.10:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn7.10:1.2",
      "pali": "Tena kho pana samayena aññatarassa bhāradvājagottassa brāhmaṇassa catuddasa balībaddā naṭṭhā honti."
    },
    {
      "id": "sn7.10:1.3",
      "pali": "Atha kho bhāradvājagotto brāhmaṇo te balībadde gavesanto yena so vanasaṇḍo tenupasaṅkami; upasaṅkamitvā addasa bhagavantaṁ tasmiṁ vanasaṇḍe nisinnaṁ pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā."
    },
    {
      "id": "sn7.10:1.4",
      "pali": "Disvāna yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn7.10:2.1",
      "pali": "“Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:2.2",
      "pali": "Balībaddā catuddasa;"
    },
    {
      "id": "sn7.10:2.3",
      "pali": "Ajjasaṭṭhiṁ na dissanti,"
    },
    {
      "id": "sn7.10:2.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:3.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:3.2",
      "pali": "Tilākhettasmi pāpakā;"
    },
    {
      "id": "sn7.10:3.3",
      "pali": "Ekapaṇṇā dupaṇṇā ca,"
    },
    {
      "id": "sn7.10:3.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:4.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:4.2",
      "pali": "Tucchakoṭṭhasmi mūsikā;"
    },
    {
      "id": "sn7.10:4.3",
      "pali": "Ussoḷhikāya naccanti,"
    },
    {
      "id": "sn7.10:4.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:5.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:5.2",
      "pali": "Santhāro sattamāsiko;"
    },
    {
      "id": "sn7.10:5.3",
      "pali": "Uppāṭakehi sañchanno,"
    },
    {
      "id": "sn7.10:5.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:6.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:6.2",
      "pali": "Vidhavā satta dhītaro;"
    },
    {
      "id": "sn7.10:6.3",
      "pali": "Ekaputtā duputtā ca,"
    },
    {
      "id": "sn7.10:6.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:7.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:7.2",
      "pali": "Piṅgalā tilakāhatā;"
    },
    {
      "id": "sn7.10:7.3",
      "pali": "Sottaṁ pādena bodheti,"
    },
    {
      "id": "sn7.10:7.4",
      "pali": "Tenāyaṁ samaṇo sukhī."
    },
    {
      "id": "sn7.10:8.1",
      "pali": "Na hi nūnimassa samaṇassa,"
    },
    {
      "id": "sn7.10:8.2",
      "pali": "Paccūsamhi iṇāyikā;"
    },
    {
      "id": "sn7.10:8.3",
      "pali": "Detha dethāti codenti,"
    },
    {
      "id": "sn7.10:8.4",
      "pali": "Tenāyaṁ samaṇo sukhī”ti."
    },
    {
      "id": "sn7.10:9.1",
      "pali": "“Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:9.2",
      "pali": "balībaddā catuddasa;"
    },
    {
      "id": "sn7.10:9.3",
      "pali": "Ajjasaṭṭhiṁ na dissanti,"
    },
    {
      "id": "sn7.10:9.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:10.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:10.2",
      "pali": "tilākhettasmi pāpakā;"
    },
    {
      "id": "sn7.10:10.3",
      "pali": "Ekapaṇṇā dupaṇṇā ca,"
    },
    {
      "id": "sn7.10:10.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:11.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:11.2",
      "pali": "tucchakoṭṭhasmi mūsikā;"
    },
    {
      "id": "sn7.10:11.3",
      "pali": "Ussoḷhikāya naccanti,"
    },
    {
      "id": "sn7.10:11.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:12.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:12.2",
      "pali": "santhāro sattamāsiko;"
    },
    {
      "id": "sn7.10:12.3",
      "pali": "Uppāṭakehi sañchanno,"
    },
    {
      "id": "sn7.10:12.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:13.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:13.2",
      "pali": "vidhavā satta dhītaro;"
    },
    {
      "id": "sn7.10:13.3",
      "pali": "Ekaputtā duputtā ca,"
    },
    {
      "id": "sn7.10:13.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:14.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:14.2",
      "pali": "piṅgalā tilakāhatā;"
    },
    {
      "id": "sn7.10:14.3",
      "pali": "Sottaṁ pādena bodheti,"
    },
    {
      "id": "sn7.10:14.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī."
    },
    {
      "id": "sn7.10:15.1",
      "pali": "Na hi mayhaṁ brāhmaṇa,"
    },
    {
      "id": "sn7.10:15.2",
      "pali": "paccūsamhi iṇāyikā;"
    },
    {
      "id": "sn7.10:15.3",
      "pali": "Detha dethāti codenti,"
    },
    {
      "id": "sn7.10:15.4",
      "pali": "tenāhaṁ brāhmaṇā sukhī”ti."
    },
    {
      "id": "sn7.10:16.1",
      "pali": "Evaṁ vutte, bhāradvājagotto brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.10:16.2",
      "pali": "“abhikkantaṁ, bho gotama, abhikkantaṁ, bho gotama."
    },
    {
      "id": "sn7.10:16.3",
      "pali": "Seyyathāpi, bho gotama, nikkujjitaṁ vā ukkujjeyya, paṭicchannaṁ vā vivareyya, mūḷhassa vā maggaṁ ācikkheyya, andhakāre vā telapajjotaṁ dhāreyya: ‘cakkhumanto rūpāni dakkhantī’ti; evameva bhotā gotamena anekapariyāyena dhammo pakāsito."
    },
    {
      "id": "sn7.10:16.4",
      "pali": "Esāhaṁ bhavantaṁ gotamaṁ saraṇaṁ gacchāmi dhammañca bhikkhusaṅghañca."
    },
    {
      "id": "sn7.10:16.5",
      "pali": "Labheyyāhaṁ bhoto gotamassa santike pabbajjaṁ, labheyyaṁ upasampadan”ti."
    },
    {
      "id": "sn7.10:17.1",
      "pali": "Alattha kho bhāradvājagotto brāhmaṇo bhagavato santike pabbajjaṁ, alattha upasampadaṁ."
    },
    {
      "id": "sn7.10:17.2",
      "pali": "Acirūpasampanno panāyasmā bhāradvājo eko vūpakaṭṭho appamatto ātāpī pahitatto viharanto nacirasseva—yassatthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti, tadanuttaraṁ—brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja vihāsi."
    },
    {
      "id": "sn7.10:17.3",
      "pali": "“Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā”ti abbhaññāsi."
    },
    {
      "id": "sn7.10:17.4",
      "pali": "Aññataro ca panāyasmā bhāradvājo arahataṁ ahosīti."
    },
    {
      "id": "sn7.10:17.5",
      "pali": "Arahantavaggo paṭhamo."
    },
    {
      "id": "sn7.10:18.1",
      "pali": "Dhanañjānī ca akkosaṁ,"
    },
    {
      "id": "sn7.10:18.2",
      "pali": "asurindaṁ bilaṅgikaṁ;"
    },
    {
      "id": "sn7.10:18.3",
      "pali": "Ahiṁsakaṁ jaṭā ceva,"
    },
    {
      "id": "sn7.10:18.4",
      "pali": "suddhikañceva aggikā;"
    },
    {
      "id": "sn7.10:18.5",
      "pali": "Sundarikaṁ bahudhīta—"
    },
    {
      "id": "sn7.10:18.6",
      "pali": "rena ca te dasāti."
    }
  ]
}
