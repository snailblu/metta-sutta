{
  "uid": "sn45.141-145",
  "title": "sn45.141-145",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.141:1.1",
      "pali": "“Seyyathāpi, bhikkhave, kūṭāgārassa yā kāci gopānasiyo sabbā tā kūṭaṅgamā kūṭaninnā kūṭasamosaraṇā; kūṭaṁ tāsaṁ aggamakkhāyati;"
    },
    {
      "id": "sn45.141:1.2",
      "pali": "evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn45.141:1.3",
      "pali": "(yathā heṭṭhimasuttantaṁ, evaṁ vitthāretabbaṁ.)"
    },
    {
      "id": "sn45.141:1.4",
      "pali": "Tatiyaṁ."
    },
    {
      "id": "sn45.142:2.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci mūlagandhā, kāḷānusāriyaṁ tesaṁ aggamakkhāyati;"
    },
    {
      "id": "sn45.142:2.2",
      "pali": "evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn45.142:2.3",
      "pali": "catutthaṁ."
    },
    {
      "id": "sn45.143:3.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci sāragandhā, lohitacandanaṁ tesaṁ aggamakkhāyati;"
    },
    {
      "id": "sn45.143:3.2",
      "pali": "evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn45.143:3.3",
      "pali": "pañcamaṁ."
    },
    {
      "id": "sn45.144:4.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci pupphagandhā, vassikaṁ tesaṁ aggamakkhāyati;"
    },
    {
      "id": "sn45.144:4.2",
      "pali": "evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn45.144:4.3",
      "pali": "chaṭṭhaṁ."
    },
    {
      "id": "sn45.145:5.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci kuṭṭarājāno, sabbe te rañño cakkavattissa anuyantā bhavanti, rājā tesaṁ cakkavatti aggamakkhāyati;"
    },
    {
      "id": "sn45.145:5.2",
      "pali": "evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn45.145:5.3",
      "pali": "sattamaṁ."
    }
  ]
}
