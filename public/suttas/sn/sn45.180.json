{
  "uid": "sn45.180",
  "title": "Uddhambhāgiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.180:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.180:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn45.180:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn45.180:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.180:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.180:1.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.180:1.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti vivekanissitaṁ …pe… sammāsamādhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn45.180:1.8",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabboti."
    },
    {
      "id": "sn45.180:2.1",
      "pali": "Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.180:2.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn45.180:2.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn45.180:2.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.180:2.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.180:2.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.180:2.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti …pe… sammāsamādhiṁ bhāveti rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ …"
    },
    {
      "id": "sn45.180:2.8",
      "pali": "amatogadhaṁ amataparāyanaṁ amatapariyosānaṁ …"
    },
    {
      "id": "sn45.180:2.9",
      "pali": "nibbānaninnaṁ nibbānapoṇaṁ nibbānapabbhāraṁ."
    },
    {
      "id": "sn45.180:2.10",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.180:2.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn45.180:2.12",
      "pali": "Oghavaggo aṭṭhamo."
    },
    {
      "id": "sn45.180:3.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn45.180:3.2",
      "pali": "ganthaṁ anusayena ca;"
    },
    {
      "id": "sn45.180:3.3",
      "pali": "Kāmaguṇā nīvaraṇaṁ,"
    },
    {
      "id": "sn45.180:3.4",
      "pali": "khandhā oruddhambhāgiyāti."
    },
    {
      "id": "sn45.180:4.1",
      "pali": "Avijjāvaggo paṭhamo,"
    },
    {
      "id": "sn45.180:4.2",
      "pali": "dutiyaṁ vihāraṁ vuccati;"
    },
    {
      "id": "sn45.180:4.3",
      "pali": "Micchattaṁ tatiyo vaggo,"
    },
    {
      "id": "sn45.180:4.4",
      "pali": "catutthaṁ paṭipanneneva."
    },
    {
      "id": "sn45.180:5.1",
      "pali": "Titthiyaṁ pañcamo vaggo,"
    },
    {
      "id": "sn45.180:5.2",
      "pali": "chaṭṭho sūriyena ca;"
    },
    {
      "id": "sn45.180:5.3",
      "pali": "Bahukate sattamo vaggo,"
    },
    {
      "id": "sn45.180:5.4",
      "pali": "uppādo aṭṭhamena ca."
    },
    {
      "id": "sn45.180:6.1",
      "pali": "Divasavaggo navamo,"
    },
    {
      "id": "sn45.180:6.2",
      "pali": "Dasamo appamādena ca;"
    },
    {
      "id": "sn45.180:6.3",
      "pali": "Ekādasabalavaggo,"
    },
    {
      "id": "sn45.180:6.4",
      "pali": "Dvādasa esanā pāḷiyaṁ;"
    },
    {
      "id": "sn45.180:6.5",
      "pali": "Oghavaggo bhavati terasāti."
    },
    {
      "id": "sn45.180:6.6",
      "pali": "Maggasaṁyuttaṁ paṭhamaṁ."
    }
  ]
}
