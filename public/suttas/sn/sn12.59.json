{
  "uid": "sn12.59",
  "title": "Viññāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.59:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.59:1.2",
      "pali": "“Saṁyojaniyesu, bhikkhave, dhammesu assādānupassino viharato viññāṇassa avakkanti hoti."
    },
    {
      "id": "sn12.59:1.3",
      "pali": "Viññāṇapaccayā nāmarūpaṁ …pe…"
    },
    {
      "id": "sn12.59:1.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.59:2.1",
      "pali": "Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.59:2.2",
      "pali": "Tassa yāni ceva mūlāni …pe…"
    },
    {
      "id": "sn12.59:2.3",
      "pali": "evameva kho, bhikkhave, saṁyojaniyesu dhammesu assādānupassino viharato viññāṇassa avakkanti hoti …pe…."
    },
    {
      "id": "sn12.59:3.1",
      "pali": "Saṁyojaniyesu, bhikkhave, dhammesu ādīnavānupassino viharato viññāṇassa avakkanti na hoti."
    },
    {
      "id": "sn12.59:3.2",
      "pali": "Viññāṇanirodhā nāmarūpanirodho …pe…"
    },
    {
      "id": "sn12.59:3.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.59:4.1",
      "pali": "Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.59:4.2",
      "pali": "Atha puriso āgaccheyya kuddālapiṭakaṁ ādāya …pe…"
    },
    {
      "id": "sn12.59:4.3",
      "pali": "āyatiṁ anuppādadhammo."
    },
    {
      "id": "sn12.59:4.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu ādīnavānupassino viharato viññāṇassa avakkanti na hoti."
    },
    {
      "id": "sn12.59:4.5",
      "pali": "Viññāṇassa nirodhā nāmarūpanirodho …pe…"
    },
    {
      "id": "sn12.59:4.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.59:4.7",
      "pali": "Navamaṁ."
    }
  ]
}
