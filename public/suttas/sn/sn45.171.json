{
  "uid": "sn45.171",
  "title": "Oghasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.171:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.171:1.2",
      "pali": "“Cattārome, bhikkhave, oghā."
    },
    {
      "id": "sn45.171:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn45.171:1.4",
      "pali": "Kāmogho, bhavogho, diṭṭhogho, avijjogho—"
    },
    {
      "id": "sn45.171:1.5",
      "pali": "ime kho, bhikkhave, cattāro oghā."
    },
    {
      "id": "sn45.171:1.6",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ oghānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.171:1.7",
      "pali": "(Yathā esanā, evaṁ vitthāretabbaṁ.)"
    },
    {
      "id": "sn45.171:1.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
