{
  "uid": "sn1.28",
  "title": "Mahaddhanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.28:1.1",
      "pali": "“Mahaddhanā mahābhogā,"
    },
    {
      "id": "sn1.28:1.2",
      "pali": "raṭṭhavantopi khattiyā;"
    },
    {
      "id": "sn1.28:1.3",
      "pali": "Aññamaññābhigijjhanti,"
    },
    {
      "id": "sn1.28:1.4",
      "pali": "kāmesu analaṅkatā."
    },
    {
      "id": "sn1.28:2.1",
      "pali": "Tesu ussukkajātesu,"
    },
    {
      "id": "sn1.28:2.2",
      "pali": "bhavasotānusārisu;"
    },
    {
      "id": "sn1.28:2.3",
      "pali": "Kedha taṇhaṁ pajahiṁsu,"
    },
    {
      "id": "sn1.28:2.4",
      "pali": "ke lokasmiṁ anussukā”ti."
    },
    {
      "id": "sn1.28:3.1",
      "pali": "“Hitvā agāraṁ pabbajitā,"
    },
    {
      "id": "sn1.28:3.2",
      "pali": "hitvā puttaṁ pasuṁ piyaṁ;"
    },
    {
      "id": "sn1.28:3.3",
      "pali": "Hitvā rāgañca dosañca,"
    },
    {
      "id": "sn1.28:3.4",
      "pali": "avijjañca virājiya;"
    },
    {
      "id": "sn1.28:3.5",
      "pali": "Khīṇāsavā arahanto,"
    },
    {
      "id": "sn1.28:3.6",
      "pali": "te lokasmiṁ anussukā”ti."
    }
  ]
}
