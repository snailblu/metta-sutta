{
  "uid": "sn22.120",
  "title": "Saṁyojaniyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.120:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.120:1.2",
      "pali": "“Saṁyojaniye ca, bhikkhave, dhamme desessāmi saṁyojanañca."
    },
    {
      "id": "sn22.120:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.120:1.4",
      "pali": "Katame ca, bhikkhave, saṁyojaniyā dhammā, katamaṁ saṁyojanaṁ?"
    },
    {
      "id": "sn22.120:1.5",
      "pali": "Rūpaṁ, bhikkhave, saṁyojaniyo dhammo;"
    },
    {
      "id": "sn22.120:1.6",
      "pali": "yo tattha chandarāgo, taṁ tattha saṁyojanaṁ."
    },
    {
      "id": "sn22.120:1.7",
      "pali": "Vedanā …pe…"
    },
    {
      "id": "sn22.120:1.8",
      "pali": "saññā …"
    },
    {
      "id": "sn22.120:1.9",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.120:1.10",
      "pali": "viññāṇaṁ saṁyojaniyo dhammo;"
    },
    {
      "id": "sn22.120:1.11",
      "pali": "yo tattha chandarāgo, taṁ tattha saṁyojanaṁ."
    },
    {
      "id": "sn22.120:1.12",
      "pali": "Ime vuccanti, bhikkhave, saṁyojaniyā dhammā, idaṁ saṁyojanan”ti."
    },
    {
      "id": "sn22.120:1.13",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
