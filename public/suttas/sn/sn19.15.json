{
  "uid": "sn19.15",
  "title": "Okilinīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.15:1.1",
      "pali": "“Idhāhaṁ, āvuso, gijjhakūṭā pabbatā orohanto addasaṁ itthiṁ uppakkaṁ okiliniṁ okiriniṁ vehāsaṁ gacchantiṁ."
    },
    {
      "id": "sn19.15:1.2",
      "pali": "Sā sudaṁ aṭṭassaraṁ karoti …pe…"
    },
    {
      "id": "sn19.15:1.3",
      "pali": "esā, bhikkhave, itthī kaliṅgassa rañño aggamahesī ahosi."
    },
    {
      "id": "sn19.15:1.4",
      "pali": "Sā issāpakatā sapattiṁ aṅgārakaṭāhena okiri …pe…."
    },
    {
      "id": "sn19.15:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
