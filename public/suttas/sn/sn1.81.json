{
  "uid": "sn1.81",
  "title": "Araṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.81:1.1",
      "pali": "“Kesūdha araṇā loke,"
    },
    {
      "id": "sn1.81:1.2",
      "pali": "kesaṁ vusitaṁ na nassati;"
    },
    {
      "id": "sn1.81:1.3",
      "pali": "Kedha icchaṁ parijānanti,"
    },
    {
      "id": "sn1.81:1.4",
      "pali": "kesaṁ bhojissiyaṁ sadā."
    },
    {
      "id": "sn1.81:2.1",
      "pali": "Kiṁsu mātā pitā bhātā,"
    },
    {
      "id": "sn1.81:2.2",
      "pali": "vandanti naṁ patiṭṭhitaṁ;"
    },
    {
      "id": "sn1.81:2.3",
      "pali": "Kiṁsu idha jātihīnaṁ,"
    },
    {
      "id": "sn1.81:2.4",
      "pali": "abhivādenti khattiyā”ti."
    },
    {
      "id": "sn1.81:3.1",
      "pali": "“Samaṇīdha araṇā loke,"
    },
    {
      "id": "sn1.81:3.2",
      "pali": "Samaṇānaṁ vusitaṁ na nassati;"
    },
    {
      "id": "sn1.81:3.3",
      "pali": "Samaṇā icchaṁ parijānanti,"
    },
    {
      "id": "sn1.81:3.4",
      "pali": "Samaṇānaṁ bhojissiyaṁ sadā."
    },
    {
      "id": "sn1.81:4.1",
      "pali": "Samaṇaṁ mātā pitā bhātā,"
    },
    {
      "id": "sn1.81:4.2",
      "pali": "vandanti naṁ patiṭṭhitaṁ;"
    },
    {
      "id": "sn1.81:4.3",
      "pali": "Samaṇīdha jātihīnaṁ,"
    },
    {
      "id": "sn1.81:4.4",
      "pali": "abhivādenti khattiyā”ti."
    },
    {
      "id": "sn1.81:4.5",
      "pali": "Chetvāvaggo aṭṭhamo."
    },
    {
      "id": "sn1.81:5.1",
      "pali": "Chetvā rathañca cittañca,"
    },
    {
      "id": "sn1.81:5.2",
      "pali": "vuṭṭhi bhītā najīrati;"
    },
    {
      "id": "sn1.81:5.3",
      "pali": "Issaraṁ kāmaṁ pātheyyaṁ,"
    },
    {
      "id": "sn1.81:5.4",
      "pali": "pajjoto araṇena cāti."
    },
    {
      "id": "sn1.81:5.5",
      "pali": "Devatāsaṁyuttaṁ samattaṁ."
    }
  ]
}
