{
  "uid": "sn50.99-108",
  "title": "Punaoghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn50.99-108:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn50.99-108:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn50.99-108:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ avijjā—"
    },
    {
      "id": "sn50.99-108:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn50.99-108:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya pañca balāni bhāvetabbāni."
    },
    {
      "id": "sn50.99-108:1.6",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn50.99-108:1.7",
      "pali": "Idha, bhikkhave, bhikkhu saddhābalaṁ bhāveti …pe… paññābalaṁ bhāveti rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ."
    },
    {
      "id": "sn50.99-108:1.8",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya imāni pañca balāni bhāvetabbānī”ti."
    },
    {
      "id": "sn50.99-108:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn50.99-108:1.10",
      "pali": "Oghavaggo dasamo."
    },
    {
      "id": "sn50.99-108:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn50.99-108:2.2",
      "pali": "ganthā anusayena ca;"
    },
    {
      "id": "sn50.99-108:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn50.99-108:2.4",
      "pali": "khandhā oruddhambhāgiyāti."
    },
    {
      "id": "sn50.99-108:2.5",
      "pali": "Balasaṁyuttaṁ chaṭṭhaṁ."
    }
  ]
}
