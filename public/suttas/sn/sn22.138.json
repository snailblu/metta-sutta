{
  "uid": "sn22.138",
  "title": "Dutiyaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.138:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.138:1.2",
      "pali": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo."
    },
    {
      "id": "sn22.138:1.3",
      "pali": "Kiñca, bhikkhave, aniccaṁ?"
    },
    {
      "id": "sn22.138:1.4",
      "pali": "Rūpaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo."
    },
    {
      "id": "sn22.138:1.5",
      "pali": "Vedanā aniccā …"
    },
    {
      "id": "sn22.138:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn22.138:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.138:1.8",
      "pali": "viññāṇaṁ aniccaṁ; tatra vo rāgo pahātabbo."
    },
    {
      "id": "sn22.138:1.9",
      "pali": "Yaṁ, bhikkhave, aniccaṁ; tatra vo rāgo pahātabbo”ti."
    },
    {
      "id": "sn22.138:1.10",
      "pali": "Tatiyaṁ."
    }
  ]
}
