{
  "uid": "sn35.145",
  "title": "Bāhirānattahetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.145:1.1",
      "pali": "“Rūpā, bhikkhave, anattā."
    },
    {
      "id": "sn35.145:1.2",
      "pali": "Yopi hetu, yopi paccayo rūpānaṁ uppādāya, sopi anattā."
    },
    {
      "id": "sn35.145:1.3",
      "pali": "Anattasambhūtā, bhikkhave, rūpā kuto attā bhavissanti."
    },
    {
      "id": "sn35.145:1.4",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.145:1.5",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.145:1.6",
      "pali": "rasā …"
    },
    {
      "id": "sn35.145:1.7",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.145:1.8",
      "pali": "dhammā anattā."
    },
    {
      "id": "sn35.145:1.9",
      "pali": "Yopi hetu, yopi paccayo dhammānaṁ uppādāya, sopi anattā."
    },
    {
      "id": "sn35.145:1.10",
      "pali": "Anattasambhūtā, bhikkhave, dhammā kuto attā bhavissanti."
    },
    {
      "id": "sn35.145:1.11",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako rūpesupi nibbindati, saddesupi … gandhesupi … rasesupi … phoṭṭhabbesupi … dhammesupi nibbindati."
    },
    {
      "id": "sn35.145:1.12",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn35.145:1.13",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.145:1.14",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn35.145:1.15",
      "pali": "Devadahavaggo catuttho."
    },
    {
      "id": "sn35.145:2.1",
      "pali": "Devadaho khaṇo rūpā,"
    },
    {
      "id": "sn35.145:2.2",
      "pali": "dve natumhākameva ca;"
    },
    {
      "id": "sn35.145:2.3",
      "pali": "Hetunāpi tayo vuttā,"
    },
    {
      "id": "sn35.145:2.4",
      "pali": "duve ajjhattabāhirāti."
    }
  ]
}
