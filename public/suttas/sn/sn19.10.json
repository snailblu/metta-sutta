{
  "uid": "sn19.10",
  "title": "Kumbhaṇḍasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.10:1.1",
      "pali": "“Idhāhaṁ, āvuso, gijjhakūṭā pabbatā orohanto addasaṁ kumbhaṇḍaṁ purisaṁ vehāsaṁ gacchantaṁ."
    },
    {
      "id": "sn19.10:1.2",
      "pali": "So gacchantopi teva aṇḍe khandhe āropetvā gacchati."
    },
    {
      "id": "sn19.10:1.3",
      "pali": "Nisīdantopi tesveva aṇḍesu nisīdati."
    },
    {
      "id": "sn19.10:1.4",
      "pali": "Tamenaṁ gijjhāpi kākāpi kulalāpi anupatitvā anupatitvā vitacchenti virājenti."
    },
    {
      "id": "sn19.10:1.5",
      "pali": "So sudaṁ aṭṭassaraṁ karoti …pe…"
    },
    {
      "id": "sn19.10:1.6",
      "pali": "eso, bhikkhave, satto imasmiṁyeva rājagahe gāmakūṭako ahosi …pe…."
    },
    {
      "id": "sn19.10:1.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn19.10:1.8",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn19.10:2.1",
      "pali": "Aṭṭhi pesi ubho gāvaghātakā,"
    },
    {
      "id": "sn19.10:2.2",
      "pali": "Piṇḍo sākuṇiyo nicchavorabbhi;"
    },
    {
      "id": "sn19.10:2.3",
      "pali": "Asi sūkariko sattimāgavi,"
    },
    {
      "id": "sn19.10:2.4",
      "pali": "Usu kāraṇiko sūci sārathi;"
    },
    {
      "id": "sn19.10:2.5",
      "pali": "Yo ca sibbiyati sūcako hi so,"
    },
    {
      "id": "sn19.10:2.6",
      "pali": "Aṇḍabhāri ahu gāmakūṭakoti."
    }
  ]
}
