{
  "uid": "sn35.210-212",
  "title": "Ajjhattātītādiyadanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.210-212:1.1",
      "pali": "“Cakkhu, bhikkhave, anattā atītaṁ anāgataṁ paccuppannaṁ."
    },
    {
      "id": "sn35.210-212:1.2",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe…"
    },
    {
      "id": "sn35.210-212:1.3",
      "pali": "jivhā anattā …pe…"
    },
    {
      "id": "sn35.210-212:1.4",
      "pali": "mano anattā atīto anāgato paccuppanno."
    },
    {
      "id": "sn35.210-212:1.5",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.210-212:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.210-212:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
