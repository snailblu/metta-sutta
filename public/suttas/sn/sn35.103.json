{
  "uid": "sn35.103",
  "title": "Udakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.103:1.1",
      "pali": "“Udako sudaṁ, bhikkhave, rāmaputto evaṁ vācaṁ bhāsati:"
    },
    {
      "id": "sn35.103:1.2",
      "pali": "‘idaṁ jātu vedagū,"
    },
    {
      "id": "sn35.103:1.3",
      "pali": "idaṁ jātu sabbajī,"
    },
    {
      "id": "sn35.103:1.4",
      "pali": "idaṁ jātu apalikhataṁ"
    },
    {
      "id": "sn35.103:1.5",
      "pali": "gaṇḍamūlaṁ palikhaṇin’ti."
    },
    {
      "id": "sn35.103:1.6",
      "pali": "Taṁ kho panetaṁ, bhikkhave, udako rāmaputto avedagūyeva samāno ‘vedagūsmī’ti bhāsati, asabbajīyeva samāno ‘sabbajīsmī’ti bhāsati, apalikhataṁyeva gaṇḍamūlaṁ ‘palikhataṁ me gaṇḍamūlan’ti bhāsati."
    },
    {
      "id": "sn35.103:1.7",
      "pali": "Idha kho taṁ, bhikkhave, bhikkhu sammā vadamāno vadeyya:"
    },
    {
      "id": "sn35.103:1.8",
      "pali": "‘idaṁ jātu vedagū,"
    },
    {
      "id": "sn35.103:1.9",
      "pali": "idaṁ jātu sabbajī,"
    },
    {
      "id": "sn35.103:1.10",
      "pali": "idaṁ jātu apalikhataṁ"
    },
    {
      "id": "sn35.103:1.11",
      "pali": "gaṇḍamūlaṁ palikhaṇin’ti."
    },
    {
      "id": "sn35.103:2.1",
      "pali": "Kathañca, bhikkhave, vedagū hoti?"
    },
    {
      "id": "sn35.103:2.2",
      "pali": "Yato kho, bhikkhave, bhikkhu channaṁ phassāyatanānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.103:2.3",
      "pali": "evaṁ kho, bhikkhave, bhikkhu vedagū hoti."
    },
    {
      "id": "sn35.103:3.1",
      "pali": "Kathañca, bhikkhave, bhikkhu sabbajī hoti?"
    },
    {
      "id": "sn35.103:3.2",
      "pali": "Yato kho, bhikkhave, bhikkhu channaṁ phassāyatanānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā anupādāvimutto hoti;"
    },
    {
      "id": "sn35.103:3.3",
      "pali": "evaṁ kho, bhikkhave, bhikkhu sabbajī hoti."
    },
    {
      "id": "sn35.103:4.1",
      "pali": "Kathañca, bhikkhave, bhikkhuno apalikhataṁ gaṇḍamūlaṁ palikhataṁ hoti?"
    },
    {
      "id": "sn35.103:4.2",
      "pali": "Gaṇḍoti kho, bhikkhave, imassetaṁ cātumahābhūtikassa kāyassa adhivacanaṁ mātāpettikasambhavassa odanakummāsūpacayassa aniccucchādanaparimaddanabhedanaviddhaṁsanadhammassa."
    },
    {
      "id": "sn35.103:4.3",
      "pali": "Gaṇḍamūlanti kho, bhikkhave, taṇhāyetaṁ adhivacanaṁ."
    },
    {
      "id": "sn35.103:4.4",
      "pali": "Yato kho, bhikkhave, bhikkhuno taṇhā pahīnā hoti ucchinnamūlā tālāvatthukatā anabhāvaṅkatā āyatiṁ anuppādadhammā;"
    },
    {
      "id": "sn35.103:4.5",
      "pali": "evaṁ kho, bhikkhave, bhikkhuno apalikhataṁ gaṇḍamūlaṁ palikhataṁ hoti."
    },
    {
      "id": "sn35.103:5.1",
      "pali": "Udako sudaṁ, bhikkhave, rāmaputto evaṁ vācaṁ bhāsati:"
    },
    {
      "id": "sn35.103:5.2",
      "pali": "‘idaṁ jātu vedagū,"
    },
    {
      "id": "sn35.103:5.3",
      "pali": "idaṁ jātu sabbajī,"
    },
    {
      "id": "sn35.103:5.4",
      "pali": "idaṁ jātu apalikhataṁ"
    },
    {
      "id": "sn35.103:5.5",
      "pali": "gaṇḍamūlaṁ palikhaṇin’ti."
    },
    {
      "id": "sn35.103:5.6",
      "pali": "Taṁ kho panetaṁ, bhikkhave, udako rāmaputto avedagūyeva samāno ‘vedagūsmī’ti bhāsati, asabbajīyeva samāno ‘sabbajīsmī’ti bhāsati; apalikhataṁyeva gaṇḍamūlaṁ ‘palikhataṁ me gaṇḍamūlan’ti bhāsati."
    },
    {
      "id": "sn35.103:5.7",
      "pali": "Idha kho taṁ, bhikkhave, bhikkhu sammā vadamāno vadeyya:"
    },
    {
      "id": "sn35.103:5.8",
      "pali": "‘idaṁ jātu vedagū,"
    },
    {
      "id": "sn35.103:5.9",
      "pali": "idaṁ jātu sabbajī,"
    },
    {
      "id": "sn35.103:5.10",
      "pali": "idaṁ jātu apalikhataṁ"
    },
    {
      "id": "sn35.103:5.11",
      "pali": "gaṇḍamūlaṁ palikhaṇin’ti."
    },
    {
      "id": "sn35.103:5.12",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.103:5.13",
      "pali": "Saḷavaggo pañcamo."
    },
    {
      "id": "sn35.103:6.1",
      "pali": "Dve saṅgayhā parihānaṁ,"
    },
    {
      "id": "sn35.103:6.2",
      "pali": "Pamādavihārī ca saṁvaro;"
    },
    {
      "id": "sn35.103:6.3",
      "pali": "Samādhi paṭisallānaṁ,"
    },
    {
      "id": "sn35.103:6.4",
      "pali": "Dve natumhākena uddakoti."
    },
    {
      "id": "sn35.103:6.5",
      "pali": "Saḷāyatanavagge dutiyapaṇṇāsako samatto."
    },
    {
      "id": "sn35.103:7.1",
      "pali": "Avijjā migajālañca,"
    },
    {
      "id": "sn35.103:7.2",
      "pali": "Gilānaṁ channaṁ catutthakaṁ;"
    },
    {
      "id": "sn35.103:7.3",
      "pali": "Saḷavaggena paññāsaṁ,"
    },
    {
      "id": "sn35.103:7.4",
      "pali": "Dutiyo paṇṇāsako ayanti."
    },
    {
      "id": "sn35.103:7.5",
      "pali": "Paṭhamasatakaṁ."
    }
  ]
}
