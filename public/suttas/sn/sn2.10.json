{
  "uid": "sn2.10",
  "title": "Sūriyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.10:1.2",
      "pali": "Tena kho pana samayena sūriyo devaputto rāhunā asurindena gahito hoti."
    },
    {
      "id": "sn2.10:1.3",
      "pali": "Atha kho sūriyo devaputto bhagavantaṁ anussaramāno tāyaṁ velāyaṁ imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.10:2.1",
      "pali": "“Namo te buddha vīratthu,"
    },
    {
      "id": "sn2.10:2.2",
      "pali": "vippamuttosi sabbadhi;"
    },
    {
      "id": "sn2.10:2.3",
      "pali": "Sambādhapaṭipannosmi,"
    },
    {
      "id": "sn2.10:2.4",
      "pali": "tassa me saraṇaṁ bhavā”ti."
    },
    {
      "id": "sn2.10:3.1",
      "pali": "Atha kho bhagavā sūriyaṁ devaputtaṁ ārabbha rāhuṁ asurindaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn2.10:4.1",
      "pali": "“Tathāgataṁ arahantaṁ,"
    },
    {
      "id": "sn2.10:4.2",
      "pali": "sūriyo saraṇaṁ gato;"
    },
    {
      "id": "sn2.10:4.3",
      "pali": "Rāhu sūriyaṁ pamuñcassu,"
    },
    {
      "id": "sn2.10:4.4",
      "pali": "buddhā lokānukampakā."
    },
    {
      "id": "sn2.10:5.1",
      "pali": "Yo andhakāre tamasi pabhaṅkaro,"
    },
    {
      "id": "sn2.10:5.2",
      "pali": "Verocano maṇḍalī uggatejo;"
    },
    {
      "id": "sn2.10:5.3",
      "pali": "Mā rāhu gilī caramantalikkhe,"
    },
    {
      "id": "sn2.10:5.4",
      "pali": "Pajaṁ mamaṁ rāhu pamuñca sūriyan”ti."
    },
    {
      "id": "sn2.10:6.1",
      "pali": "Atha kho rāhu asurindo sūriyaṁ devaputtaṁ muñcitvā taramānarūpo yena vepacitti asurindo tenupasaṅkami; upasaṅkamitvā saṁviggo lomahaṭṭhajāto ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.10:6.2",
      "pali": "Ekamantaṁ ṭhitaṁ kho rāhuṁ asurindaṁ vepacitti asurindo gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.10:7.1",
      "pali": "“Kiṁ nu santaramānova,"
    },
    {
      "id": "sn2.10:7.2",
      "pali": "rāhu sūriyaṁ pamuñcasi;"
    },
    {
      "id": "sn2.10:7.3",
      "pali": "Saṁviggarūpo āgamma,"
    },
    {
      "id": "sn2.10:7.4",
      "pali": "kiṁ nu bhītova tiṭṭhasī”ti."
    },
    {
      "id": "sn2.10:8.1",
      "pali": "“Sattadhā me phale muddhā,"
    },
    {
      "id": "sn2.10:8.2",
      "pali": "jīvanto na sukhaṁ labhe;"
    },
    {
      "id": "sn2.10:8.3",
      "pali": "Buddhagāthābhigītomhi,"
    },
    {
      "id": "sn2.10:8.4",
      "pali": "no ce muñceyya sūriyan”ti."
    },
    {
      "id": "sn2.10:8.5",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn2.10:9.1",
      "pali": "Dve kassapā ca māgho ca,"
    },
    {
      "id": "sn2.10:9.2",
      "pali": "Māgadho dāmali kāmado;"
    },
    {
      "id": "sn2.10:9.3",
      "pali": "Pañcālacaṇḍo tāyano,"
    },
    {
      "id": "sn2.10:9.4",
      "pali": "Candimasūriyena te dasāti."
    }
  ]
}
