{
  "uid": "snp5.12",
  "title": "Jatukaṇṇimāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.12:1.1",
      "pali": "“Sutvānahaṁ vīramakāmakāmiṁ,"
    },
    {
      "id": "snp5.12:1.2",
      "pali": "(iccāyasmā jatukaṇṇi)"
    },
    {
      "id": "snp5.12:1.3",
      "pali": "Oghātigaṁ puṭṭhumakāmamāgamaṁ;"
    },
    {
      "id": "snp5.12:1.4",
      "pali": "Santipadaṁ brūhi sahajanetta,"
    },
    {
      "id": "snp5.12:1.5",
      "pali": "Yathātacchaṁ bhagavā brūhi metaṁ."
    },
    {
      "id": "snp5.12:2.1",
      "pali": "Bhagavā hi kāme abhibhuyya iriyati,"
    },
    {
      "id": "snp5.12:2.2",
      "pali": "Ādiccova pathaviṁ tejī tejasā;"
    },
    {
      "id": "snp5.12:2.3",
      "pali": "Parittapaññassa me bhūripañña,"
    },
    {
      "id": "snp5.12:2.4",
      "pali": "Ācikkha dhammaṁ yamahaṁ vijaññaṁ;"
    },
    {
      "id": "snp5.12:2.5",
      "pali": "Jātijarāya idha vippahānaṁ”."
    },
    {
      "id": "snp5.12:3.1",
      "pali": "“Kāmesu vinaya gedhaṁ,"
    },
    {
      "id": "snp5.12:3.2",
      "pali": "(jatukaṇṇīti bhagavā)"
    },
    {
      "id": "snp5.12:3.3",
      "pali": "Nekkhammaṁ daṭṭhu khemato;"
    },
    {
      "id": "snp5.12:3.4",
      "pali": "Uggahītaṁ nirattaṁ vā,"
    },
    {
      "id": "snp5.12:3.5",
      "pali": "Mā te vijjittha kiñcanaṁ."
    },
    {
      "id": "snp5.12:4.1",
      "pali": "Yaṁ pubbe taṁ visosehi,"
    },
    {
      "id": "snp5.12:4.2",
      "pali": "pacchā te māhu kiñcanaṁ;"
    },
    {
      "id": "snp5.12:4.3",
      "pali": "Majjhe ce no gahessasi,"
    },
    {
      "id": "snp5.12:4.4",
      "pali": "upasanto carissasi."
    },
    {
      "id": "snp5.12:5.1",
      "pali": "Sabbaso nāmarūpasmiṁ,"
    },
    {
      "id": "snp5.12:5.2",
      "pali": "Vītagedhassa brāhmaṇa;"
    },
    {
      "id": "snp5.12:5.3",
      "pali": "Āsavāssa na vijjanti,"
    },
    {
      "id": "snp5.12:5.4",
      "pali": "Yehi maccuvasaṁ vaje”ti."
    },
    {
      "id": "snp5.12:5.5",
      "pali": "Jatukaṇṇimāṇavapucchā ekādasamā."
    }
  ]
}
