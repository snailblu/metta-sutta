{
  "uid": "sn22.118",
  "title": "Paripucchitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.118:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.118:1.2",
      "pali": "“Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.118:1.3",
      "pali": "rūpaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassathā”ti?"
    },
    {
      "id": "sn22.118:1.4",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.118:1.5",
      "pali": "“Sādhu, bhikkhave."
    },
    {
      "id": "sn22.118:1.6",
      "pali": "Rūpaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.118:1.7",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.118:1.8",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.118:1.9",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.118:1.10",
      "pali": "viññāṇaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassathā”ti?"
    },
    {
      "id": "sn22.118:1.11",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.118:1.12",
      "pali": "“Sādhu, bhikkhave."
    },
    {
      "id": "sn22.118:1.13",
      "pali": "Viññāṇaṁ, bhikkhave, ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe…"
    },
    {
      "id": "sn22.118:1.14",
      "pali": "evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.118:1.15",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.118:1.16",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
