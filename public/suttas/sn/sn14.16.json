{
  "uid": "sn14.16",
  "title": "Sagāthāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.16:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.16:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:1.3",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:1.4",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.16:1.5",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.16:2.1",
      "pali": "Anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti."
    },
    {
      "id": "sn14.16:2.2",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandissanti samessanti."
    },
    {
      "id": "sn14.16:3.1",
      "pali": "Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:3.2",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:4.1",
      "pali": "Seyyathāpi, bhikkhave, gūtho gūthena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:4.2",
      "pali": "muttaṁ muttena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:4.3",
      "pali": "kheḷo kheḷena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:4.4",
      "pali": "pubbo pubbena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:4.5",
      "pali": "lohitaṁ lohitena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:4.6",
      "pali": "evameva kho, bhikkhave, dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:4.7",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:4.8",
      "pali": "Atītampi kho addhānaṁ …pe…"
    },
    {
      "id": "sn14.16:4.9",
      "pali": "anāgatampi kho addhānaṁ …pe…"
    },
    {
      "id": "sn14.16:4.10",
      "pali": "etarahipi kho paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:4.11",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:5.1",
      "pali": "Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:5.2",
      "pali": "Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:5.3",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.16:5.4",
      "pali": "Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.16:6.1",
      "pali": "Anāgatampi kho, bhikkhave, addhānaṁ …pe…"
    },
    {
      "id": "sn14.16:6.2",
      "pali": "etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:6.3",
      "pali": "Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:7.1",
      "pali": "Seyyathāpi, bhikkhave, khīraṁ khīrena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:7.2",
      "pali": "telaṁ telena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:7.3",
      "pali": "sappi sappinā saṁsandati sameti;"
    },
    {
      "id": "sn14.16:7.4",
      "pali": "madhu madhunā saṁsandati sameti;"
    },
    {
      "id": "sn14.16:7.5",
      "pali": "phāṇitaṁ phāṇitena saṁsandati sameti;"
    },
    {
      "id": "sn14.16:7.6",
      "pali": "evameva kho, bhikkhave, dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:7.7",
      "pali": "Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.16:7.8",
      "pali": "Atītampi kho addhānaṁ …"
    },
    {
      "id": "sn14.16:7.9",
      "pali": "anāgatampi kho addhānaṁ …"
    },
    {
      "id": "sn14.16:7.10",
      "pali": "etarahipi kho paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.16:7.11",
      "pali": "Kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.16:8.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn14.16:8.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn14.16:9.1",
      "pali": "“Saṁsaggā vanatho jāto,"
    },
    {
      "id": "sn14.16:9.2",
      "pali": "asaṁsaggena chijjati;"
    },
    {
      "id": "sn14.16:9.3",
      "pali": "Parittaṁ dārumāruyha,"
    },
    {
      "id": "sn14.16:9.4",
      "pali": "yathā sīde mahaṇṇave."
    },
    {
      "id": "sn14.16:10.1",
      "pali": "Evaṁ kusītamāgamma,"
    },
    {
      "id": "sn14.16:10.2",
      "pali": "sādhujīvipi sīdati;"
    },
    {
      "id": "sn14.16:10.3",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "sn14.16:10.4",
      "pali": "kusītaṁ hīnavīriyaṁ."
    },
    {
      "id": "sn14.16:11.1",
      "pali": "Pavivittehi ariyehi,"
    },
    {
      "id": "sn14.16:11.2",
      "pali": "pahitattehi jhāyīhi;"
    },
    {
      "id": "sn14.16:11.3",
      "pali": "Niccaṁ āraddhavīriyehi,"
    },
    {
      "id": "sn14.16:11.4",
      "pali": "paṇḍitehi sahāvase”ti."
    },
    {
      "id": "sn14.16:11.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
