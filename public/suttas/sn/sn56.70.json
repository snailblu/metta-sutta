{
  "uid": "sn56.70",
  "title": "Pacāyikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.70:1.1",
      "pali": "… “Evameva kho, bhikkhave, appakā te sattā ye kule jeṭṭhāpacāyino; atha kho eteva bahutarā sattā ye kule ajeṭṭhāpacāyinoti …pe…."
    },
    {
      "id": "sn56.70:1.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn56.70:1.3",
      "pali": "Paṭhamaāmakadhaññapeyyālavaggo sattamo."
    },
    {
      "id": "sn56.70:2.1",
      "pali": "Aññatra paccantaṁ paññā,"
    },
    {
      "id": "sn56.70:2.2",
      "pali": "Surāmerayaodakā;"
    },
    {
      "id": "sn56.70:2.3",
      "pali": "Matteyya petteyyā cāpi,"
    },
    {
      "id": "sn56.70:2.4",
      "pali": "Sāmaññaṁ brahmapacāyikanti."
    }
  ]
}
