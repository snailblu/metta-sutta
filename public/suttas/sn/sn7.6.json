{
  "uid": "sn7.6",
  "title": "Jaṭāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.6:1.2",
      "pali": "Atha kho jaṭābhāradvājo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.6:1.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi."
    },
    {
      "id": "sn7.6:1.4",
      "pali": "Ekamantaṁ nisinno kho jaṭābhāradvājo brāhmaṇo bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.6:2.1",
      "pali": "“Antojaṭā bahijaṭā,"
    },
    {
      "id": "sn7.6:2.2",
      "pali": "Jaṭāya jaṭitā pajā;"
    },
    {
      "id": "sn7.6:2.3",
      "pali": "Taṁ taṁ gotama pucchāmi,"
    },
    {
      "id": "sn7.6:2.4",
      "pali": "Ko imaṁ vijaṭaye jaṭan”ti."
    },
    {
      "id": "sn7.6:3.1",
      "pali": "“Sīle patiṭṭhāya naro sapañño,"
    },
    {
      "id": "sn7.6:3.2",
      "pali": "Cittaṁ paññañca bhāvayaṁ;"
    },
    {
      "id": "sn7.6:3.3",
      "pali": "Ātāpī nipako bhikkhu,"
    },
    {
      "id": "sn7.6:3.4",
      "pali": "So imaṁ vijaṭaye jaṭaṁ."
    },
    {
      "id": "sn7.6:4.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "sn7.6:4.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "sn7.6:4.3",
      "pali": "Khīṇāsavā arahanto,"
    },
    {
      "id": "sn7.6:4.4",
      "pali": "tesaṁ vijaṭitā jaṭā."
    },
    {
      "id": "sn7.6:5.1",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "sn7.6:5.2",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "sn7.6:5.3",
      "pali": "Paṭighaṁ rūpasaññā ca,"
    },
    {
      "id": "sn7.6:5.4",
      "pali": "etthesā chijjate jaṭā”ti."
    },
    {
      "id": "sn7.6:6.1",
      "pali": "Evaṁ vutte, jaṭābhāradvājo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.6:6.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.6:6.3",
      "pali": "aññataro ca panāyasmā bhāradvājo arahataṁ ahosī”ti."
    }
  ]
}
