{
  "uid": "sn30.7-16",
  "title": "Aṇḍajadānūpakārasuttadasaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn30.7-16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn30.7-16:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn30.7-16:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ supaṇṇānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn30.7-16:1.4",
      "pali": "“Idha, bhikkhu, ekacco kāyena dvayakārī hoti, vācāya dvayakārī, manasā dvayakārī."
    },
    {
      "id": "sn30.7-16:1.5",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn30.7-16:1.6",
      "pali": "‘aṇḍajā supaṇṇā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn30.7-16:1.7",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn30.7-16:1.8",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ supaṇṇānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn30.7-16:1.9",
      "pali": "So annaṁ deti …pe…"
    },
    {
      "id": "sn30.7-16:1.10",
      "pali": "pānaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.11",
      "pali": "vatthaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.12",
      "pali": "yānaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.13",
      "pali": "mālaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.14",
      "pali": "gandhaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.15",
      "pali": "vilepanaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.16",
      "pali": "seyyaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.17",
      "pali": "āvasathaṁ deti …"
    },
    {
      "id": "sn30.7-16:1.18",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn30.7-16:1.19",
      "pali": "So kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ supaṇṇānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn30.7-16:1.20",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ supaṇṇānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn30.7-16:1.21",
      "pali": "Soḷasamaṁ."
    }
  ]
}
