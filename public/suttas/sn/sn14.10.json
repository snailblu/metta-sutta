{
  "uid": "sn14.10",
  "title": "Dutiyabāhiraphassanānattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.10:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.10:1.2",
      "pali": "“Dhātunānattaṁ, bhikkhave, paṭicca uppajjati saññānānattaṁ,"
    },
    {
      "id": "sn14.10:1.3",
      "pali": "saññānānattaṁ paṭicca uppajjati saṅkappanānattaṁ,"
    },
    {
      "id": "sn14.10:1.4",
      "pali": "phassa …"
    },
    {
      "id": "sn14.10:1.5",
      "pali": "vedanā …"
    },
    {
      "id": "sn14.10:1.6",
      "pali": "chanda …"
    },
    {
      "id": "sn14.10:1.7",
      "pali": "pariḷāha …"
    },
    {
      "id": "sn14.10:1.8",
      "pali": "pariyesanānānattaṁ paṭicca uppajjati lābhanānattaṁ;"
    },
    {
      "id": "sn14.10:1.9",
      "pali": "no lābhanānattaṁ paṭicca uppajjati pariyesanānānattaṁ,"
    },
    {
      "id": "sn14.10:1.10",
      "pali": "no pariyesanānānattaṁ paṭicca uppajjati pariḷāhanānattaṁ, no pariḷāhanānattaṁ paṭicca uppajjati …pe…"
    },
    {
      "id": "sn14.10:1.11",
      "pali": "chanda …"
    },
    {
      "id": "sn14.10:1.12",
      "pali": "vedanā …"
    },
    {
      "id": "sn14.10:1.13",
      "pali": "phassa …"
    },
    {
      "id": "sn14.10:1.14",
      "pali": "saṅkappa …"
    },
    {
      "id": "sn14.10:1.15",
      "pali": "saññānānattaṁ, no saññānānattaṁ paṭicca uppajjati dhātunānattaṁ."
    },
    {
      "id": "sn14.10:1.16",
      "pali": "Katamañca, bhikkhave, dhātunānattaṁ?"
    },
    {
      "id": "sn14.10:1.17",
      "pali": "Rūpadhātu …pe… dhammadhātu—"
    },
    {
      "id": "sn14.10:1.18",
      "pali": "idaṁ vuccati, bhikkhave, dhātunānattaṁ."
    },
    {
      "id": "sn14.10:2.1",
      "pali": "Kathañca, bhikkhave, dhātunānattaṁ paṭicca uppajjati saññānānattaṁ,"
    },
    {
      "id": "sn14.10:2.2",
      "pali": "saññānānattaṁ paṭicca uppajjati saṅkappanānattaṁ?"
    },
    {
      "id": "sn14.10:2.3",
      "pali": "Phassa …"
    },
    {
      "id": "sn14.10:2.4",
      "pali": "vedanā …"
    },
    {
      "id": "sn14.10:2.5",
      "pali": "chanda …"
    },
    {
      "id": "sn14.10:2.6",
      "pali": "pariḷāha …"
    },
    {
      "id": "sn14.10:2.7",
      "pali": "pariyesanā …"
    },
    {
      "id": "sn14.10:2.8",
      "pali": "lābha …"
    },
    {
      "id": "sn14.10:2.9",
      "pali": "no lābhanānattaṁ paṭicca uppajjati pariyesanānānattaṁ,"
    },
    {
      "id": "sn14.10:2.10",
      "pali": "no pariyesanānānattaṁ paṭicca uppajjati pariḷāha …"
    },
    {
      "id": "sn14.10:2.11",
      "pali": "chanda …"
    },
    {
      "id": "sn14.10:2.12",
      "pali": "vedanā …"
    },
    {
      "id": "sn14.10:2.13",
      "pali": "phassa …"
    },
    {
      "id": "sn14.10:2.14",
      "pali": "no saṅkappanānattaṁ paṭicca uppajjati saññānānattaṁ, no saññānānattaṁ paṭicca uppajjati dhātunānattaṁ?"
    },
    {
      "id": "sn14.10:3.1",
      "pali": "Rūpadhātuṁ, bhikkhave, paṭicca uppajjati rūpasaññā …pe…"
    },
    {
      "id": "sn14.10:3.2",
      "pali": "dhammadhātuṁ paṭicca uppajjati dhammasaññā, dhammasaññaṁ paṭicca uppajjati …pe…"
    },
    {
      "id": "sn14.10:3.3",
      "pali": "dhammapariyesanā, dhammapariyesanaṁ paṭicca uppajjati dhammalābho;"
    },
    {
      "id": "sn14.10:3.4",
      "pali": "no dhammalābhaṁ paṭicca uppajjati dhammapariyesanā, no dhammapariyesanaṁ paṭicca uppajjati dhammapariḷāho, no dhammapariḷāhaṁ paṭicca uppajjati dhammacchando, no dhammacchandaṁ paṭicca uppajjati dhammasamphassajā vedanā, no dhammasamphassajaṁ vedanaṁ paṭicca uppajjati dhammasamphasso, no dhammasamphassaṁ paṭicca uppajjati dhammasaṅkappo, no dhammasaṅkappaṁ paṭicca uppajjati dhammasaññā, no dhammasaññaṁ paṭicca uppajjati dhammadhātu."
    },
    {
      "id": "sn14.10:4.1",
      "pali": "Evaṁ kho, bhikkhave, dhātunānattaṁ paṭicca uppajjati saññānānattaṁ, saññānānattaṁ paṭicca uppajjati …pe…"
    },
    {
      "id": "sn14.10:4.2",
      "pali": "saṅkappa …"
    },
    {
      "id": "sn14.10:4.3",
      "pali": "phassa …"
    },
    {
      "id": "sn14.10:4.4",
      "pali": "vedanā …"
    },
    {
      "id": "sn14.10:4.5",
      "pali": "chanda …"
    },
    {
      "id": "sn14.10:4.6",
      "pali": "pariḷāha …"
    },
    {
      "id": "sn14.10:4.7",
      "pali": "pariyesanā …"
    },
    {
      "id": "sn14.10:4.8",
      "pali": "lābha …"
    },
    {
      "id": "sn14.10:4.9",
      "pali": "no lābhanānattaṁ paṭicca uppajjati pariyesanānānattaṁ, no pariyesanānānattaṁ paṭicca uppajjati pariḷāhanānattaṁ, no pariḷāhanānattaṁ paṭicca uppajjati chandanānattaṁ, no chandanānattaṁ paṭicca uppajjati vedanānānattaṁ, no vedanānānattaṁ paṭicca uppajjati phassanānattaṁ, no phassanānattaṁ paṭicca uppajjati saṅkappanānattaṁ, no saṅkappanānattaṁ paṭicca uppajjati saññānānattaṁ, no saññānānattaṁ paṭicca uppajjati dhātunānattan”ti."
    },
    {
      "id": "sn14.10:4.10",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn14.10:4.11",
      "pali": "Nānattavaggo paṭhamo."
    },
    {
      "id": "sn14.10:5.1",
      "pali": "Dhātuphassañca no cetaṁ,"
    },
    {
      "id": "sn14.10:5.2",
      "pali": "vedanā apare duve;"
    },
    {
      "id": "sn14.10:5.3",
      "pali": "Etaṁ ajjhattapañcakaṁ,"
    },
    {
      "id": "sn14.10:5.4",
      "pali": "dhātusaññañca no cetaṁ;"
    },
    {
      "id": "sn14.10:5.5",
      "pali": "Phassassa apare duve,"
    },
    {
      "id": "sn14.10:5.6",
      "pali": "etaṁ bāhirapañcakanti."
    }
  ]
}
