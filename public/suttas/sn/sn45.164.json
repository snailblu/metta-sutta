{
  "uid": "sn45.164",
  "title": "Bhavasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.164:1.1",
      "pali": "“Tayome, bhikkhave, bhavā."
    },
    {
      "id": "sn45.164:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "sn45.164:1.3",
      "pali": "Kāmabhavo, rūpabhavo, arūpabhavo—"
    },
    {
      "id": "sn45.164:1.4",
      "pali": "ime kho, bhikkhave, tayo bhavā."
    },
    {
      "id": "sn45.164:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ bhavānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.164:1.6",
      "pali": "Catutthaṁ."
    }
  ]
}
