{
  "uid": "sn45.19",
  "title": "Dutiyakukkuṭārāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.19:1.1",
      "pali": "Pāṭaliputtanidānaṁ."
    },
    {
      "id": "sn45.19:1.2",
      "pali": "“‘Brahmacariyaṁ, brahmacariyan’ti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.19:1.3",
      "pali": "Katamaṁ nu kho, āvuso, brahmacariyaṁ, katamaṁ brahmacariyapariyosānan”ti?"
    },
    {
      "id": "sn45.19:1.4",
      "pali": "“Sādhu sādhu, āvuso bhadda."
    },
    {
      "id": "sn45.19:1.5",
      "pali": "Bhaddako kho te, āvuso bhadda, ummaṅgo, bhaddakaṁ paṭibhānaṁ, kalyāṇī paripucchā."
    },
    {
      "id": "sn45.19:1.6",
      "pali": "Evañhi tvaṁ, āvuso bhadda, pucchasi:"
    },
    {
      "id": "sn45.19:1.7",
      "pali": "‘brahmacariyaṁ, brahmacariyanti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.19:1.8",
      "pali": "Katamaṁ nu kho, āvuso, brahmacariyaṁ, katamaṁ brahmacariyapariyosānan’”ti?"
    },
    {
      "id": "sn45.19:1.9",
      "pali": "“Evamāvuso”ti."
    },
    {
      "id": "sn45.19:1.10",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo brahmacariyaṁ, seyyathidaṁ—"
    },
    {
      "id": "sn45.19:1.11",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.19:1.12",
      "pali": "Yo kho, āvuso, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.19:1.13",
      "pali": "idaṁ brahmacariyapariyosānan”ti."
    },
    {
      "id": "sn45.19:1.14",
      "pali": "Navamaṁ."
    }
  ]
}
