{
  "uid": "sn49.35-44",
  "title": "Esanādisuttadasaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn49.35-44:1.1",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn49.35-44:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn49.35-44:1.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā—"
    },
    {
      "id": "sn49.35-44:1.4",
      "pali": "imā kho, bhikkhave, tisso esanā."
    },
    {
      "id": "sn49.35-44:1.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya pariññāya parikkhayāya pahānāya cattāro sammappadhānā bhāvetabbā."
    },
    {
      "id": "sn49.35-44:1.6",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn49.35-44:1.7",
      "pali": "Idha, bhikkhave, bhikkhu anuppannānaṁ …pe…"
    },
    {
      "id": "sn49.35-44:1.8",
      "pali": "uppannānaṁ kusalānaṁ dhammānaṁ ṭhitiyā asammosāya bhiyyobhāvāya vepullāya bhāvanāya pāripūriyā chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "sn49.35-44:1.9",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ esanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ime cattāro sammappadhānā bhāvetabbā”ti."
    },
    {
      "id": "sn49.35-44:1.10",
      "pali": "(Vitthāretabbaṁ.)"
    },
    {
      "id": "sn49.35-44:1.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn49.35-44:1.12",
      "pali": "Esanāvaggo catuttho."
    },
    {
      "id": "sn49.35-44:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn49.35-44:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn49.35-44:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn49.35-44:2.4",
      "pali": "Vedanā taṇhā tasinā cāti."
    }
  ]
}
