{
  "uid": "sn35.2",
  "title": "Ajjhattadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.2:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, dukkhaṁ."
    },
    {
      "id": "sn35.2:1.2",
      "pali": "Yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn35.2:1.3",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.2:1.4",
      "pali": "Sotaṁ dukkhaṁ …pe…"
    },
    {
      "id": "sn35.2:1.5",
      "pali": "ghānaṁ dukkhaṁ …"
    },
    {
      "id": "sn35.2:1.6",
      "pali": "jivhā dukkhā …"
    },
    {
      "id": "sn35.2:1.7",
      "pali": "kāyo dukkho …"
    },
    {
      "id": "sn35.2:1.8",
      "pali": "mano dukkho."
    },
    {
      "id": "sn35.2:1.9",
      "pali": "Yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn35.2:1.10",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.2:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.2:1.12",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn35.2:1.13",
      "pali": "Dutiyaṁ."
    }
  ]
}
