{
  "uid": "sn2.2",
  "title": "Dutiyakassapasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.2:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.2:1.2",
      "pali": "Ekamantaṁ ṭhito kho kassapo devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.2:2.1",
      "pali": "“Bhikkhu siyā jhāyī vimuttacitto,"
    },
    {
      "id": "sn2.2:2.2",
      "pali": "Ākaṅkhe ce hadayassānupattiṁ;"
    },
    {
      "id": "sn2.2:2.3",
      "pali": "Lokassa ñatvā udayabbayañca,"
    },
    {
      "id": "sn2.2:2.4",
      "pali": "Sucetaso anissito tadānisaṁso”ti."
    }
  ]
}
