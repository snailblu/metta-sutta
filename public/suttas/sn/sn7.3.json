{
  "uid": "sn7.3",
  "title": "Asurindakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.3:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn7.3:1.2",
      "pali": "Assosi kho asurindakabhāradvājo brāhmaṇo:"
    },
    {
      "id": "sn7.3:1.3",
      "pali": "“bhāradvājagotto brāhmaṇo kira samaṇassa gotamassa santike agārasmā anagāriyaṁ pabbajito”ti kupito anattamano yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ asabbhāhi pharusāhi vācāhi akkosati paribhāsati."
    },
    {
      "id": "sn7.3:1.4",
      "pali": "Evaṁ vutte, bhagavā tuṇhī ahosi."
    },
    {
      "id": "sn7.3:1.5",
      "pali": "Atha kho asurindakabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.3:1.6",
      "pali": "“jitosi, samaṇa, jitosi, samaṇā”ti."
    },
    {
      "id": "sn7.3:2.1",
      "pali": "“Jayaṁ ve maññati bālo,"
    },
    {
      "id": "sn7.3:2.2",
      "pali": "vācāya pharusaṁ bhaṇaṁ;"
    },
    {
      "id": "sn7.3:2.3",
      "pali": "Jayañcevassa taṁ hoti,"
    },
    {
      "id": "sn7.3:2.4",
      "pali": "yā titikkhā vijānato."
    },
    {
      "id": "sn7.3:3.1",
      "pali": "Tasseva tena pāpiyo,"
    },
    {
      "id": "sn7.3:3.2",
      "pali": "yo kuddhaṁ paṭikujjhati;"
    },
    {
      "id": "sn7.3:3.3",
      "pali": "Kuddhaṁ appaṭikujjhanto,"
    },
    {
      "id": "sn7.3:3.4",
      "pali": "saṅgāmaṁ jeti dujjayaṁ."
    },
    {
      "id": "sn7.3:4.1",
      "pali": "Ubhinnamatthaṁ carati,"
    },
    {
      "id": "sn7.3:4.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn7.3:4.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "sn7.3:4.4",
      "pali": "yo sato upasammati."
    },
    {
      "id": "sn7.3:5.1",
      "pali": "Ubhinnaṁ tikicchantānaṁ,"
    },
    {
      "id": "sn7.3:5.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn7.3:5.3",
      "pali": "Janā maññanti bāloti,"
    },
    {
      "id": "sn7.3:5.4",
      "pali": "ye dhammassa akovidā”ti."
    },
    {
      "id": "sn7.3:6.1",
      "pali": "Evaṁ vutte, asurindakabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.3:6.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.3:6.3",
      "pali": "abbhaññāsi."
    },
    {
      "id": "sn7.3:6.4",
      "pali": "Aññataro ca panāyasmā bhāradvājo arahataṁ ahosīti."
    }
  ]
}
