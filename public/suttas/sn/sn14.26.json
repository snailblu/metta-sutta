{
  "uid": "sn14.26",
  "title": "Sattakammapathasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.26:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.26:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.26:1.3",
      "pali": "Pāṇātipātino pāṇātipātīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.4",
      "pali": "adinnādāyino adinnādāyīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.5",
      "pali": "kāmesumicchācārino kāmesumicchācārīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.6",
      "pali": "musāvādino musāvādīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.7",
      "pali": "pisuṇavācā pisuṇavācehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.8",
      "pali": "pharusavācā pharusavācehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:1.9",
      "pali": "samphappalāpino samphappalāpīhi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.26:2.1",
      "pali": "Pāṇātipātā paṭiviratā …pe…"
    },
    {
      "id": "sn14.26:2.2",
      "pali": "adinnādānā paṭiviratā …"
    },
    {
      "id": "sn14.26:2.3",
      "pali": "kāmesumicchācārā paṭiviratā …"
    },
    {
      "id": "sn14.26:2.4",
      "pali": "musāvādā paṭiviratā …"
    },
    {
      "id": "sn14.26:2.5",
      "pali": "pisuṇāya vācāya paṭiviratā pisuṇāya vācāya paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:2.6",
      "pali": "pharusāya vācāya paṭiviratā pharusāya vācāya paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.26:2.7",
      "pali": "samphappalāpā paṭiviratā samphappalāpā paṭiviratehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.26:2.8",
      "pali": "Catutthaṁ."
    }
  ]
}
