{
  "uid": "sn1.70",
  "title": "Lokasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.70:1.1",
      "pali": "“Kismiṁ loko samuppanno,"
    },
    {
      "id": "sn1.70:1.2",
      "pali": "kismiṁ kubbati santhavaṁ;"
    },
    {
      "id": "sn1.70:1.3",
      "pali": "Kissa loko upādāya,"
    },
    {
      "id": "sn1.70:1.4",
      "pali": "kismiṁ loko vihaññatī”ti."
    },
    {
      "id": "sn1.70:2.1",
      "pali": "“Chasu loko samuppanno,"
    },
    {
      "id": "sn1.70:2.2",
      "pali": "chasu kubbati santhavaṁ;"
    },
    {
      "id": "sn1.70:2.3",
      "pali": "Channameva upādāya,"
    },
    {
      "id": "sn1.70:2.4",
      "pali": "chasu loko vihaññatī”ti."
    },
    {
      "id": "sn1.70:2.5",
      "pali": "Addhavaggo sattamo."
    },
    {
      "id": "sn1.70:3.1",
      "pali": "Nāmaṁ cittañca taṇhā ca,"
    },
    {
      "id": "sn1.70:3.2",
      "pali": "saṁyojanañca bandhanā;"
    },
    {
      "id": "sn1.70:3.3",
      "pali": "Abbhāhatuḍḍito pihito,"
    },
    {
      "id": "sn1.70:3.4",
      "pali": "icchā lokena te dasāti."
    }
  ]
}
