{
  "uid": "sn3.5",
  "title": "Attarakkhitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn3.5:1.2",
      "pali": "Ekamantaṁ nisinno kho rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.5:1.3",
      "pali": "“idha mayhaṁ, bhante, rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "sn3.5:1.4",
      "pali": "‘kesaṁ nu kho rakkhito attā, kesaṁ arakkhito attā’ti?"
    },
    {
      "id": "sn3.5:1.5",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn3.5:1.6",
      "pali": "‘ye kho keci kāyena duccaritaṁ caranti, vācāya duccaritaṁ caranti, manasā duccaritaṁ caranti;"
    },
    {
      "id": "sn3.5:1.7",
      "pali": "tesaṁ arakkhito attā."
    },
    {
      "id": "sn3.5:1.8",
      "pali": "Kiñcāpi te hatthikāyo vā rakkheyya, assakāyo vā rakkheyya, rathakāyo vā rakkheyya, pattikāyo vā rakkheyya;"
    },
    {
      "id": "sn3.5:1.9",
      "pali": "atha kho tesaṁ arakkhito attā."
    },
    {
      "id": "sn3.5:1.10",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.5:1.11",
      "pali": "Bāhirā hesā rakkhā, nesā rakkhā ajjhattikā;"
    },
    {
      "id": "sn3.5:1.12",
      "pali": "tasmā tesaṁ arakkhito attā."
    },
    {
      "id": "sn3.5:1.13",
      "pali": "Ye ca kho keci kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti;"
    },
    {
      "id": "sn3.5:1.14",
      "pali": "tesaṁ rakkhito attā."
    },
    {
      "id": "sn3.5:1.15",
      "pali": "Kiñcāpi te neva hatthikāyo rakkheyya, na assakāyo rakkheyya, na rathakāyo rakkheyya, na pattikāyo rakkheyya;"
    },
    {
      "id": "sn3.5:1.16",
      "pali": "atha kho tesaṁ rakkhito attā."
    },
    {
      "id": "sn3.5:1.17",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.5:1.18",
      "pali": "Ajjhattikā hesā rakkhā, nesā rakkhā bāhirā;"
    },
    {
      "id": "sn3.5:1.19",
      "pali": "tasmā tesaṁ rakkhito attā’”ti."
    },
    {
      "id": "sn3.5:2.1",
      "pali": "“Evametaṁ, mahārāja, evametaṁ, mahārāja."
    },
    {
      "id": "sn3.5:2.2",
      "pali": "Ye hi keci, mahārāja, kāyena duccaritaṁ caranti …pe…"
    },
    {
      "id": "sn3.5:2.3",
      "pali": "tesaṁ arakkhito attā."
    },
    {
      "id": "sn3.5:2.4",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.5:2.5",
      "pali": "Bāhirā hesā, mahārāja, rakkhā, nesā rakkhā ajjhattikā;"
    },
    {
      "id": "sn3.5:2.6",
      "pali": "tasmā tesaṁ arakkhito attā."
    },
    {
      "id": "sn3.5:2.7",
      "pali": "Ye hi keci, mahārāja, kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti;"
    },
    {
      "id": "sn3.5:2.8",
      "pali": "tesaṁ rakkhito attā."
    },
    {
      "id": "sn3.5:2.9",
      "pali": "Kiñcāpi te neva hatthikāyo rakkheyya, na assakāyo rakkheyya, na rathakāyo rakkheyya, na pattikāyo rakkheyya;"
    },
    {
      "id": "sn3.5:2.10",
      "pali": "atha kho tesaṁ rakkhito attā."
    },
    {
      "id": "sn3.5:2.11",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.5:2.12",
      "pali": "Ajjhattikā hesā, mahārāja, rakkhā, nesā rakkhā bāhirā;"
    },
    {
      "id": "sn3.5:2.13",
      "pali": "tasmā tesaṁ rakkhito attā”ti."
    },
    {
      "id": "sn3.5:2.14",
      "pali": "Idamavoca …pe…"
    },
    {
      "id": "sn3.5:3.1",
      "pali": "“Kāyena saṁvaro sādhu,"
    },
    {
      "id": "sn3.5:3.2",
      "pali": "sādhu vācāya saṁvaro;"
    },
    {
      "id": "sn3.5:3.3",
      "pali": "Manasā saṁvaro sādhu,"
    },
    {
      "id": "sn3.5:3.4",
      "pali": "sādhu sabbattha saṁvaro;"
    },
    {
      "id": "sn3.5:3.5",
      "pali": "Sabbattha saṁvuto lajjī,"
    },
    {
      "id": "sn3.5:3.6",
      "pali": "rakkhitoti pavuccatī”ti."
    }
  ]
}
