{
  "uid": "sn1.23",
  "title": "Jaṭāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.23:1.1",
      "pali": "“Antojaṭā bahijaṭā,"
    },
    {
      "id": "sn1.23:1.2",
      "pali": "Jaṭāya jaṭitā pajā;"
    },
    {
      "id": "sn1.23:1.3",
      "pali": "Taṁ taṁ gotama pucchāmi,"
    },
    {
      "id": "sn1.23:1.4",
      "pali": "Ko imaṁ vijaṭaye jaṭan”ti."
    },
    {
      "id": "sn1.23:2.1",
      "pali": "“Sīle patiṭṭhāya naro sapañño,"
    },
    {
      "id": "sn1.23:2.2",
      "pali": "Cittaṁ paññañca bhāvayaṁ;"
    },
    {
      "id": "sn1.23:2.3",
      "pali": "Ātāpī nipako bhikkhu,"
    },
    {
      "id": "sn1.23:2.4",
      "pali": "So imaṁ vijaṭaye jaṭaṁ."
    },
    {
      "id": "sn1.23:3.1",
      "pali": "Yesaṁ rāgo ca doso ca,"
    },
    {
      "id": "sn1.23:3.2",
      "pali": "avijjā ca virājitā;"
    },
    {
      "id": "sn1.23:3.3",
      "pali": "Khīṇāsavā arahanto,"
    },
    {
      "id": "sn1.23:3.4",
      "pali": "tesaṁ vijaṭitā jaṭā."
    },
    {
      "id": "sn1.23:4.1",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "sn1.23:4.2",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "sn1.23:4.3",
      "pali": "Paṭighaṁ rūpasaññā ca,"
    },
    {
      "id": "sn1.23:4.4",
      "pali": "etthesā chijjate jaṭā”ti."
    }
  ]
}
