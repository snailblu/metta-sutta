{
  "uid": "sn4.7",
  "title": "Supatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.7:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn4.7:1.2",
      "pali": "Atha kho bhagavā bahudevarattiṁ abbhokāse caṅkamitvā rattiyā paccūsasamayaṁ pāde pakkhāletvā vihāraṁ pavisitvā"
    },
    {
      "id": "sn4.7:1.3",
      "pali": "dakkhiṇena passena sīhaseyyaṁ kappesi pāde pādaṁ accādhāya sato sampajāno uṭṭhānasaññaṁ manasi karitvā."
    },
    {
      "id": "sn4.7:1.4",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.7:2.1",
      "pali": "“Kiṁ soppasi kiṁ nu soppasi,"
    },
    {
      "id": "sn4.7:2.2",
      "pali": "Kimidaṁ soppasi dubbhago viya;"
    },
    {
      "id": "sn4.7:2.3",
      "pali": "Suññamagāranti soppasi,"
    },
    {
      "id": "sn4.7:2.4",
      "pali": "Kimidaṁ soppasi sūriye uggate”ti."
    },
    {
      "id": "sn4.7:3.1",
      "pali": "“Yassa jālinī visattikā,"
    },
    {
      "id": "sn4.7:3.2",
      "pali": "Taṇhā natthi kuhiñci netave;"
    },
    {
      "id": "sn4.7:3.3",
      "pali": "Sabbūpadhiparikkhayā buddho,"
    },
    {
      "id": "sn4.7:3.4",
      "pali": "Soppati kiṁ tavettha mārā”ti."
    },
    {
      "id": "sn4.7:4.1",
      "pali": "Atha kho māro pāpimā …pe… tatthevantaradhāyīti."
    }
  ]
}
