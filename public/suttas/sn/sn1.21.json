{
  "uid": "sn1.21",
  "title": "Sattisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.21:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.21:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.21:2.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "sn1.21:2.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "sn1.21:2.3",
      "pali": "Kāmarāgappahānāya,"
    },
    {
      "id": "sn1.21:2.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "sn1.21:3.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "sn1.21:3.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "sn1.21:3.3",
      "pali": "Sakkāyadiṭṭhippahānāya,"
    },
    {
      "id": "sn1.21:3.4",
      "pali": "sato bhikkhu paribbaje”ti."
    }
  ]
}
