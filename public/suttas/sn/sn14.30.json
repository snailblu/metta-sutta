{
  "uid": "sn14.30",
  "title": "Catudhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.30:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme …"
    },
    {
      "id": "sn14.30:1.2",
      "pali": "“catasso imā, bhikkhave, dhātuyo."
    },
    {
      "id": "sn14.30:1.3",
      "pali": "Katamā catasso?"
    },
    {
      "id": "sn14.30:1.4",
      "pali": "Pathavīdhātu, āpodhātu, tejodhātu, vāyodhātu—"
    },
    {
      "id": "sn14.30:1.5",
      "pali": "imā kho, bhikkhave, catasso dhātuyo”ti."
    },
    {
      "id": "sn14.30:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
