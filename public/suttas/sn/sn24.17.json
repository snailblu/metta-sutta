{
  "uid": "sn24.17",
  "title": "Hoticanacahotitathāgatosutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.17:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.17:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.17:1.3",
      "pali": "‘hoti ca na ca hoti tathāgato paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.17:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.17:1.5",
      "pali": "niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.17:1.6",
      "pali": "Sattarasamaṁ."
    }
  ]
}
