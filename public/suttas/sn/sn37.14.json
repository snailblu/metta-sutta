{
  "uid": "sn37.14",
  "title": "Pañcaverasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn37.14:1.1",
      "pali": "“Pañcahi, anuruddha, dhammehi samannāgato mātugāmo …pe… nirayaṁ upapajjati."
    },
    {
      "id": "sn37.14:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "sn37.14:1.3",
      "pali": "Pāṇātipātī ca hoti, adinnādāyī ca hoti, kāmesumicchācārī ca hoti, musāvādī ca hoti, surāmerayamajjappamādaṭṭhāyī ca hoti—"
    },
    {
      "id": "sn37.14:1.4",
      "pali": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapajjatī”ti."
    },
    {
      "id": "sn37.14:1.5",
      "pali": "Cuddasamaṁ."
    },
    {
      "id": "sn37.14:1.6",
      "pali": "Paṭhamapeyyālavaggo."
    },
    {
      "id": "sn37.14:2.1",
      "pali": "Mātugāmo puriso ca,"
    },
    {
      "id": "sn37.14:2.2",
      "pali": "āveṇikā tidhammo ca;"
    },
    {
      "id": "sn37.14:2.3",
      "pali": "Kodhano upanāhī ca,"
    },
    {
      "id": "sn37.14:2.4",
      "pali": "issukī maccharena ca;"
    },
    {
      "id": "sn37.14:2.5",
      "pali": "Aticārī ca dussīlo,"
    },
    {
      "id": "sn37.14:2.6",
      "pali": "appassuto ca kusīto;"
    },
    {
      "id": "sn37.14:2.7",
      "pali": "Muṭṭhassati pañcaveraṁ,"
    },
    {
      "id": "sn37.14:2.8",
      "pali": "kaṇhapakkhe pakāsito."
    }
  ]
}
