{
  "uid": "sn27.8",
  "title": "Taṇhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.8:1.2",
      "pali": "“Yo, bhikkhave, rūpataṇhāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.8:1.3",
      "pali": "Yo saddataṇhāya …"
    },
    {
      "id": "sn27.8:1.4",
      "pali": "yo gandhataṇhāya …"
    },
    {
      "id": "sn27.8:1.5",
      "pali": "yo rasataṇhāya …"
    },
    {
      "id": "sn27.8:1.6",
      "pali": "yo phoṭṭhabbataṇhāya …"
    },
    {
      "id": "sn27.8:1.7",
      "pali": "yo dhammataṇhāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.8:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno …pe…"
    },
    {
      "id": "sn27.8:1.9",
      "pali": "abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.8:1.10",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
