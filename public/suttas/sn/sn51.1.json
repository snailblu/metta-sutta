{
  "uid": "sn51.1",
  "title": "Apārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.1:1.1",
      "pali": "“Cattārome, bhikkhave, iddhipādā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattanti."
    },
    {
      "id": "sn51.1:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.1:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.1:1.4",
      "pali": "vīriyasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.1:1.5",
      "pali": "cittasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.1:1.6",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn51.1:1.7",
      "pali": "Ime kho, bhikkhave, cattāro iddhipādā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattantī”ti."
    },
    {
      "id": "sn51.1:1.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
