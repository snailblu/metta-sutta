{
  "uid": "sn46.143-152",
  "title": "Punatathāgatādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.143-152:1.1",
      "pali": "…pe…"
    },
    {
      "id": "sn46.143-152:1.2",
      "pali": "Pannarasamo."
    },
    {
      "id": "sn46.143-152:2.1",
      "pali": "Tathāgataṁ padaṁ kūṭaṁ,"
    },
    {
      "id": "sn46.143-152:2.2",
      "pali": "mūlaṁ sārena vassikaṁ;"
    },
    {
      "id": "sn46.143-152:2.3",
      "pali": "Rājā candimasūriyā ca,"
    },
    {
      "id": "sn46.143-152:2.4",
      "pali": "vatthena dasamaṁ padanti."
    },
    {
      "id": "sn46.143-152:3.1",
      "pali": "(Appamādavaggo rāgavasena vitthāretabbo.)"
    }
  ]
}
