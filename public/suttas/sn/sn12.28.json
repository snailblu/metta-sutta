{
  "uid": "sn12.28",
  "title": "Bhikkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.28:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.28:1.2",
      "pali": "“Tatra kho …pe…"
    },
    {
      "id": "sn12.28:1.3",
      "pali": "idha, bhikkhave, bhikkhu jarāmaraṇaṁ pajānāti, jarāmaraṇasamudayaṁ pajānāti, jarāmaraṇanirodhaṁ pajānāti, jarāmaraṇanirodhagāminiṁ paṭipadaṁ pajānāti, jātiṁ pajānāti …pe…"
    },
    {
      "id": "sn12.28:1.4",
      "pali": "bhavaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.5",
      "pali": "upādānaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.6",
      "pali": "taṇhaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.7",
      "pali": "vedanaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.8",
      "pali": "phassaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.9",
      "pali": "saḷāyatanaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.10",
      "pali": "nāmarūpaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.11",
      "pali": "viññāṇaṁ pajānāti …"
    },
    {
      "id": "sn12.28:1.12",
      "pali": "saṅkhāre pajānāti, saṅkhārasamudayaṁ pajānāti, saṅkhāranirodhaṁ pajānāti, saṅkhāranirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn12.28:2.1",
      "pali": "Katamañca, bhikkhave, jarāmaraṇaṁ?"
    },
    {
      "id": "sn12.28:2.2",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhi tamhi sattanikāye jarā jīraṇatā khaṇḍiccaṁ pāliccaṁ valittacatā āyuno saṁhāni indriyānaṁ paripāko—"
    },
    {
      "id": "sn12.28:2.3",
      "pali": "ayaṁ vuccati jarā."
    },
    {
      "id": "sn12.28:2.4",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhā tamhā sattanikāyā cuti cavanatā bhedo antaradhānaṁ maccu maraṇaṁ kālakiriyā khandhānaṁ bhedo kaḷevarassa nikkhepo;"
    },
    {
      "id": "sn12.28:2.5",
      "pali": "idaṁ vuccati maraṇaṁ."
    },
    {
      "id": "sn12.28:2.6",
      "pali": "Iti ayañca jarā idañca maraṇaṁ."
    },
    {
      "id": "sn12.28:2.7",
      "pali": "Idaṁ vuccati, bhikkhave, jarāmaraṇaṁ."
    },
    {
      "id": "sn12.28:2.8",
      "pali": "Jātisamudayā jarāmaraṇasamudayo;"
    },
    {
      "id": "sn12.28:2.9",
      "pali": "jātinirodhā jarāmaraṇanirodho."
    },
    {
      "id": "sn12.28:2.10",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo jarāmaraṇanirodhagāminī paṭipadā."
    },
    {
      "id": "sn12.28:2.11",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn12.28:3.1",
      "pali": "Katamā ca, bhikkhave, jāti …pe…"
    },
    {
      "id": "sn12.28:3.2",
      "pali": "katamo ca, bhikkhave, bhavo …"
    },
    {
      "id": "sn12.28:3.3",
      "pali": "katamañca, bhikkhave, upādānaṁ …"
    },
    {
      "id": "sn12.28:3.4",
      "pali": "katamā ca, bhikkhave, taṇhā …"
    },
    {
      "id": "sn12.28:3.5",
      "pali": "vedanā …"
    },
    {
      "id": "sn12.28:3.6",
      "pali": "phasso …"
    },
    {
      "id": "sn12.28:3.7",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.28:3.8",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.28:3.9",
      "pali": "viññāṇaṁ …."
    },
    {
      "id": "sn12.28:4.1",
      "pali": "Katame ca, bhikkhave, saṅkhārā?"
    },
    {
      "id": "sn12.28:4.2",
      "pali": "Tayome, bhikkhave, saṅkhārā—"
    },
    {
      "id": "sn12.28:4.3",
      "pali": "kāyasaṅkhāro, vacīsaṅkhāro, cittasaṅkhāro."
    },
    {
      "id": "sn12.28:4.4",
      "pali": "Ime vuccanti, bhikkhave, saṅkhārā."
    },
    {
      "id": "sn12.28:4.5",
      "pali": "Avijjāsamudayā saṅkhārasamudayo;"
    },
    {
      "id": "sn12.28:4.6",
      "pali": "avijjānirodhā saṅkhāranirodho."
    },
    {
      "id": "sn12.28:4.7",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo saṅkhāranirodhagāminī paṭipadā."
    },
    {
      "id": "sn12.28:4.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn12.28:5.1",
      "pali": "Yato kho, bhikkhave, bhikkhu evaṁ jarāmaraṇaṁ pajānāti, evaṁ jarāmaraṇasamudayaṁ pajānāti, evaṁ jarāmaraṇanirodhaṁ pajānāti, evaṁ jarāmaraṇanirodhagāminiṁ paṭipadaṁ pajānāti, evaṁ jātiṁ pajānāti …pe…"
    },
    {
      "id": "sn12.28:5.2",
      "pali": "bhavaṁ …"
    },
    {
      "id": "sn12.28:5.3",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.28:5.4",
      "pali": "taṇhaṁ …"
    },
    {
      "id": "sn12.28:5.5",
      "pali": "vedanaṁ …"
    },
    {
      "id": "sn12.28:5.6",
      "pali": "phassaṁ …"
    },
    {
      "id": "sn12.28:5.7",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.28:5.8",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.28:5.9",
      "pali": "viññāṇaṁ …"
    },
    {
      "id": "sn12.28:5.10",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn12.28:5.11",
      "pali": "saṅkhārasamudayaṁ …"
    },
    {
      "id": "sn12.28:5.12",
      "pali": "saṅkhāranirodhaṁ …"
    },
    {
      "id": "sn12.28:5.13",
      "pali": "evaṁ saṅkhāranirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn12.28:5.14",
      "pali": "Ayaṁ vuccati, bhikkhave, bhikkhu diṭṭhisampanno itipi, dassanasampanno itipi, āgato imaṁ saddhammaṁ itipi, passati imaṁ saddhammaṁ itipi, sekkhena ñāṇena samannāgato itipi, sekkhāya vijjāya samannāgato itipi, dhammasotaṁ samāpanno itipi, ariyo nibbedhikapañño itipi, amatadvāraṁ āhacca tiṭṭhati itipī”ti."
    },
    {
      "id": "sn12.28:5.15",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
