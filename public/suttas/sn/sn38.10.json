{
  "uid": "sn38.10",
  "title": "Taṇhāpañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.10:1.1",
      "pali": "“‘Taṇhā, taṇhā’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.10:1.2",
      "pali": "Katamā nu kho, āvuso, taṇhā”ti?"
    },
    {
      "id": "sn38.10:1.3",
      "pali": "“Tisso imā, āvuso, taṇhā."
    },
    {
      "id": "sn38.10:1.4",
      "pali": "Kāmataṇhā, bhavataṇhā, vibhavataṇhā—"
    },
    {
      "id": "sn38.10:1.5",
      "pali": "imā kho, āvuso, tisso taṇhā”ti."
    },
    {
      "id": "sn38.10:1.6",
      "pali": "“Atthi panāvuso, maggo atthi paṭipadā, etāsaṁ taṇhānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.10:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā, etāsaṁ taṇhānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.10:1.8",
      "pali": "“Katamo panāvuso, maggo katamā paṭipadā, etāsaṁ taṇhānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.10:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etāsaṁ taṇhānaṁ pahānāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.10:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.10:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etāsaṁ taṇhānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.10:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etāsaṁ taṇhānaṁ pahānāya."
    },
    {
      "id": "sn38.10:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.10:1.14",
      "pali": "Dasamaṁ."
    }
  ]
}
