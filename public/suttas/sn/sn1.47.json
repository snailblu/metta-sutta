{
  "uid": "sn1.47",
  "title": "Vanaropasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.47:1.1",
      "pali": "“Kesaṁ divā ca ratto ca,"
    },
    {
      "id": "sn1.47:1.2",
      "pali": "sadā puññaṁ pavaḍḍhati;"
    },
    {
      "id": "sn1.47:1.3",
      "pali": "Dhammaṭṭhā sīlasampannā,"
    },
    {
      "id": "sn1.47:1.4",
      "pali": "ke janā saggagāmino”ti."
    },
    {
      "id": "sn1.47:2.1",
      "pali": "“Ārāmaropā vanaropā,"
    },
    {
      "id": "sn1.47:2.2",
      "pali": "ye janā setukārakā;"
    },
    {
      "id": "sn1.47:2.3",
      "pali": "Papañca udapānañca,"
    },
    {
      "id": "sn1.47:2.4",
      "pali": "ye dadanti upassayaṁ."
    },
    {
      "id": "sn1.47:3.1",
      "pali": "Tesaṁ divā ca ratto ca,"
    },
    {
      "id": "sn1.47:3.2",
      "pali": "sadā puññaṁ pavaḍḍhati;"
    },
    {
      "id": "sn1.47:3.3",
      "pali": "Dhammaṭṭhā sīlasampannā,"
    },
    {
      "id": "sn1.47:3.4",
      "pali": "te janā saggagāmino”ti."
    }
  ]
}
