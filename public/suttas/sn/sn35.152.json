{
  "uid": "sn35.152",
  "title": "Kimatthiyabrahmacariyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.152:1.1",
      "pali": "“Sace vo, bhikkhave, aññatitthiyā paribbājakā evaṁ puccheyyuṁ:"
    },
    {
      "id": "sn35.152:1.2",
      "pali": "‘kimatthiyaṁ, āvuso, samaṇe gotame brahmacariyaṁ vussatī’ti?"
    },
    {
      "id": "sn35.152:1.3",
      "pali": "Evaṁ puṭṭhā tumhe, bhikkhave, tesaṁ aññatitthiyānaṁ paribbājakānaṁ evaṁ byākareyyātha:"
    },
    {
      "id": "sn35.152:1.4",
      "pali": "‘dukkhassa kho, āvuso, pariññāya bhagavati brahmacariyaṁ vussatī’ti."
    },
    {
      "id": "sn35.152:1.5",
      "pali": "Sace pana vo, bhikkhave, aññatitthiyā paribbājakā evaṁ puccheyyuṁ:"
    },
    {
      "id": "sn35.152:1.6",
      "pali": "‘katamaṁ panāvuso, dukkhaṁ, yassa pariññāya samaṇe gotame brahmacariyaṁ vussatī’ti?"
    },
    {
      "id": "sn35.152:1.7",
      "pali": "Evaṁ puṭṭhā tumhe, bhikkhave, tesaṁ aññatitthiyānaṁ paribbājakānaṁ evaṁ byākareyyātha:"
    },
    {
      "id": "sn35.152:2.1",
      "pali": "‘Cakkhu kho, āvuso, dukkhaṁ;"
    },
    {
      "id": "sn35.152:2.2",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati."
    },
    {
      "id": "sn35.152:2.3",
      "pali": "Rūpā dukkhā;"
    },
    {
      "id": "sn35.152:2.4",
      "pali": "tesaṁ pariññāya bhagavati brahmacariyaṁ vussati."
    },
    {
      "id": "sn35.152:2.5",
      "pali": "Cakkhuviññāṇaṁ dukkhaṁ;"
    },
    {
      "id": "sn35.152:2.6",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati."
    },
    {
      "id": "sn35.152:2.7",
      "pali": "Cakkhusamphasso dukkho;"
    },
    {
      "id": "sn35.152:2.8",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati."
    },
    {
      "id": "sn35.152:2.9",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi dukkhaṁ;"
    },
    {
      "id": "sn35.152:2.10",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati …pe…"
    },
    {
      "id": "sn35.152:2.11",
      "pali": "jivhā dukkhā …"
    },
    {
      "id": "sn35.152:2.12",
      "pali": "mano dukkho;"
    },
    {
      "id": "sn35.152:2.13",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati …"
    },
    {
      "id": "sn35.152:2.14",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi dukkhaṁ;"
    },
    {
      "id": "sn35.152:2.15",
      "pali": "tassa pariññāya bhagavati brahmacariyaṁ vussati."
    },
    {
      "id": "sn35.152:2.16",
      "pali": "Idaṁ kho, āvuso, dukkhaṁ;"
    },
    {
      "id": "sn35.152:2.17",
      "pali": "yassa pariññāya bhagavati brahmacariyaṁ vussatī’ti."
    },
    {
      "id": "sn35.152:2.18",
      "pali": "Evaṁ puṭṭhā tumhe, bhikkhave, tesaṁ aññatitthiyānaṁ paribbājakānaṁ evaṁ byākareyyāthā”ti."
    },
    {
      "id": "sn35.152:2.19",
      "pali": "Sattamaṁ."
    }
  ]
}
