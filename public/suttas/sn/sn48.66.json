{
  "uid": "sn48.66",
  "title": "Dutiyaphalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.66:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.66:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.66:1.3",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ—"
    },
    {
      "id": "sn48.66:1.4",
      "pali": "imāni kho, bhikkhave, pañcindriyāni."
    },
    {
      "id": "sn48.66:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā satta phalā sattānisaṁsā pāṭikaṅkhā."
    },
    {
      "id": "sn48.66:1.6",
      "pali": "Katame satta phalā sattānisaṁsā?"
    },
    {
      "id": "sn48.66:1.7",
      "pali": "Diṭṭheva dhamme paṭikacca aññaṁ ārādheti,"
    },
    {
      "id": "sn48.66:1.8",
      "pali": "no ce diṭṭheva dhamme paṭikacca aññaṁ ārādheti, atha maraṇakāle aññaṁ ārādheti."
    },
    {
      "id": "sn48.66:1.9",
      "pali": "No ce diṭṭheva dhamme aññaṁ ārādheti, no ce maraṇakāle aññaṁ ārādheti, atha pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ parikkhayā antarāparinibbāyī hoti,"
    },
    {
      "id": "sn48.66:1.10",
      "pali": "upahaccaparinibbāyī hoti,"
    },
    {
      "id": "sn48.66:1.11",
      "pali": "asaṅkhāraparinibbāyī hoti,"
    },
    {
      "id": "sn48.66:1.12",
      "pali": "sasaṅkhāraparinibbāyī hoti,"
    },
    {
      "id": "sn48.66:1.13",
      "pali": "uddhaṁsoto hoti akaniṭṭhagāmī."
    },
    {
      "id": "sn48.66:1.14",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā ime satta phalā sattānisaṁsā pāṭikaṅkhā”ti."
    },
    {
      "id": "sn48.66:1.15",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
