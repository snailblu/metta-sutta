{
  "uid": "sn35.156",
  "title": "Ajjhattanandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.156:1.1",
      "pali": "“Aniccaṁyeva, bhikkhave, bhikkhu cakkhuṁ aniccanti passati, sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn35.156:1.2",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn35.156:1.3",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.156:1.4",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.156:1.5",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccati …pe…"
    },
    {
      "id": "sn35.156:1.6",
      "pali": "aniccaṁyeva, bhikkhave, bhikkhu jivhaṁ aniccanti passati, sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn35.156:1.7",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn35.156:1.8",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.156:1.9",
      "pali": "rāgakkhayā …pe…"
    },
    {
      "id": "sn35.156:1.10",
      "pali": "cittaṁ suvimuttanti vuccati …pe…"
    },
    {
      "id": "sn35.156:1.11",
      "pali": "aniccaṁyeva, bhikkhave, bhikkhu manaṁ aniccanti passati, sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn35.156:1.12",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn35.156:1.13",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.156:1.14",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.156:1.15",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn35.156:1.16",
      "pali": "Paṭhamaṁ."
    }
  ]
}
