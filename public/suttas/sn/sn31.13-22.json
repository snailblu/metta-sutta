{
  "uid": "sn31.13-22",
  "title": "Mūlagandhadānūpakārasuttadasaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn31.13-22:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn31.13-22:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn31.13-22:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā mūlagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn31.13-22:1.4",
      "pali": "“Idha, bhikkhu, ekacco kāyena sucaritaṁ carati, vācāya sucaritaṁ carati, manasā sucaritaṁ carati."
    },
    {
      "id": "sn31.13-22:1.5",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn31.13-22:1.6",
      "pali": "‘mūlagandhe adhivatthā devā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn31.13-22:1.7",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn31.13-22:1.8",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā mūlagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn31.13-22:1.9",
      "pali": "So annaṁ deti …pe…"
    },
    {
      "id": "sn31.13-22:1.10",
      "pali": "pānaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.11",
      "pali": "vatthaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.12",
      "pali": "yānaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.13",
      "pali": "mālaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.14",
      "pali": "gandhaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.15",
      "pali": "vilepanaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.16",
      "pali": "seyyaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.17",
      "pali": "āvasathaṁ deti …"
    },
    {
      "id": "sn31.13-22:1.18",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn31.13-22:1.19",
      "pali": "So kāyassa bhedā paraṁ maraṇā mūlagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn31.13-22:1.20",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā mūlagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn31.13-22:1.21",
      "pali": "Bāvīsatimaṁ."
    }
  ]
}
