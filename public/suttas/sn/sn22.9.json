{
  "uid": "sn22.9",
  "title": "Kālattayaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.9:1.2",
      "pali": "“Rūpaṁ, bhikkhave, aniccaṁ atītānāgataṁ;"
    },
    {
      "id": "sn22.9:1.3",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.9:1.4",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ rūpasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.9:1.5",
      "pali": "anāgataṁ rūpaṁ nābhinandati;"
    },
    {
      "id": "sn22.9:1.6",
      "pali": "paccuppannassa rūpassa nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn22.9:1.7",
      "pali": "Vedanā aniccā …pe…"
    },
    {
      "id": "sn22.9:1.8",
      "pali": "saññā aniccā …"
    },
    {
      "id": "sn22.9:1.9",
      "pali": "saṅkhārā aniccā atītānāgatā;"
    },
    {
      "id": "sn22.9:1.10",
      "pali": "ko pana vādo paccuppannānaṁ."
    },
    {
      "id": "sn22.9:1.11",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu saṅkhāresu anapekkho hoti;"
    },
    {
      "id": "sn22.9:1.12",
      "pali": "anāgate saṅkhāre nābhinandati;"
    },
    {
      "id": "sn22.9:1.13",
      "pali": "paccuppannānaṁ saṅkhārānaṁ nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn22.9:1.14",
      "pali": "Viññāṇaṁ aniccaṁ atītānāgataṁ;"
    },
    {
      "id": "sn22.9:1.15",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.9:1.16",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ viññāṇasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.9:1.17",
      "pali": "anāgataṁ viññāṇaṁ nābhinandati;"
    },
    {
      "id": "sn22.9:1.18",
      "pali": "paccuppannassa viññāṇassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn22.9:1.19",
      "pali": "Navamaṁ."
    }
  ]
}
