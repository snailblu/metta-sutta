{
  "uid": "sn9.4",
  "title": "Sambahulasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.4:1.1",
      "pali": "Ekaṁ samayaṁ sambahulā bhikkhū kosalesu viharanti aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.4:1.2",
      "pali": "Atha kho te bhikkhū vassaṁvuṭṭhā temāsaccayena cārikaṁ pakkamiṁsu."
    },
    {
      "id": "sn9.4:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā te bhikkhū apassantī paridevamānā tāyaṁ velāyaṁ imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn9.4:2.1",
      "pali": "“Arati viya mejja khāyati,"
    },
    {
      "id": "sn9.4:2.2",
      "pali": "Bahuke disvāna vivitte āsane;"
    },
    {
      "id": "sn9.4:2.3",
      "pali": "Te cittakathā bahussutā,"
    },
    {
      "id": "sn9.4:2.4",
      "pali": "Kome gotamasāvakā gatā”ti."
    },
    {
      "id": "sn9.4:3.1",
      "pali": "Evaṁ vutte, aññatarā devatā taṁ devataṁ gāthāya paccabhāsi:"
    },
    {
      "id": "sn9.4:4.1",
      "pali": "“Māgadhaṁ gatā kosalaṁ gatā,"
    },
    {
      "id": "sn9.4:4.2",
      "pali": "Ekacciyā pana vajjibhūmiyā;"
    },
    {
      "id": "sn9.4:4.3",
      "pali": "Magā viya asaṅgacārino,"
    },
    {
      "id": "sn9.4:4.4",
      "pali": "Aniketā viharanti bhikkhavo”ti."
    }
  ]
}
