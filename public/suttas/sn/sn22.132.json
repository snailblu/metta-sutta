{
  "uid": "sn22.132",
  "title": "Dutiyasamudayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.132:1.1",
      "pali": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe…"
    },
    {
      "id": "sn22.132:1.2",
      "pali": "ekamantaṁ nisinno kho āyasmā mahākoṭṭhiko āyasmantaṁ sāriputtaṁ etadavoca:"
    },
    {
      "id": "sn22.132:1.3",
      "pali": "“‘vijjā, vijjā’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn22.132:1.4",
      "pali": "Katamā nu kho, āvuso, vijjā;"
    },
    {
      "id": "sn22.132:1.5",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.132:2.1",
      "pali": "“Idhāvuso, sutavā ariyasāvako rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.132:2.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.132:2.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.132:2.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.132:2.5",
      "pali": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.132:2.6",
      "pali": "Ayaṁ vuccatāvuso, vijjā;"
    },
    {
      "id": "sn22.132:2.7",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.132:2.8",
      "pali": "Sattamaṁ."
    }
  ]
}
