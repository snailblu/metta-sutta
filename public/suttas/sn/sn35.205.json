{
  "uid": "sn35.205",
  "title": "Ajjhattānāgatayadaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.205:1.1",
      "pali": "“Cakkhu, bhikkhave, aniccaṁ anāgataṁ."
    },
    {
      "id": "sn35.205:1.2",
      "pali": "Yadaniccaṁ, taṁ dukkhaṁ."
    },
    {
      "id": "sn35.205:1.3",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.205:1.4",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe…"
    },
    {
      "id": "sn35.205:1.5",
      "pali": "jivhā aniccā anāgatā."
    },
    {
      "id": "sn35.205:1.6",
      "pali": "Yadaniccaṁ, taṁ dukkhaṁ."
    },
    {
      "id": "sn35.205:1.7",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.205:1.8",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe…"
    },
    {
      "id": "sn35.205:1.9",
      "pali": "mano anicco anāgato."
    },
    {
      "id": "sn35.205:1.10",
      "pali": "Yadaniccaṁ, taṁ dukkhaṁ."
    },
    {
      "id": "sn35.205:1.11",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.205:1.12",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.205:1.13",
      "pali": "Evaṁ passaṁ, bhikkhave …pe…"
    },
    {
      "id": "sn35.205:1.14",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
