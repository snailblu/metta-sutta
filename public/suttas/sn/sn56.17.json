{
  "uid": "sn56.17",
  "title": "Avijjāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.17:1.1",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn56.17:1.2",
      "pali": "“‘avijjā, avijjā’ti, bhante, vuccati."
    },
    {
      "id": "sn56.17:1.3",
      "pali": "Katamā nu kho, bhante, avijjā;"
    },
    {
      "id": "sn56.17:1.4",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn56.17:1.5",
      "pali": "“Yaṁ kho, bhikkhu, dukkhe aññāṇaṁ, dukkhasamudaye aññāṇaṁ, dukkhanirodhe aññāṇaṁ, dukkhanirodhagāminiyā paṭipadāya aññāṇaṁ—"
    },
    {
      "id": "sn56.17:1.6",
      "pali": "ayaṁ vuccati, bhikkhu, avijjā;"
    },
    {
      "id": "sn56.17:1.7",
      "pali": "ettāvatā ca avijjāgato hotīti."
    },
    {
      "id": "sn56.17:2.1",
      "pali": "Tasmātiha, bhikkhu, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.17:2.2",
      "pali": "Sattamaṁ."
    }
  ]
}
