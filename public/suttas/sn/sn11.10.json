{
  "uid": "sn11.10",
  "title": "Samuddakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.10:1.1",
      "pali": "Sāvatthiyaṁ."
    },
    {
      "id": "sn11.10:1.2",
      "pali": "“Bhūtapubbaṁ, bhikkhave, sambahulā isayo sīlavanto kalyāṇadhammā samuddatīre paṇṇakuṭīsu sammanti."
    },
    {
      "id": "sn11.10:1.3",
      "pali": "Tena kho pana samayena devāsurasaṅgāmo samupabyūḷho ahosi."
    },
    {
      "id": "sn11.10:1.4",
      "pali": "Atha kho, bhikkhave, tesaṁ isīnaṁ sīlavantānaṁ kalyāṇadhammānaṁ etadahosi:"
    },
    {
      "id": "sn11.10:1.5",
      "pali": "‘dhammikā kho devā, adhammikā asurā."
    },
    {
      "id": "sn11.10:1.6",
      "pali": "Siyāpi no asurato bhayaṁ."
    },
    {
      "id": "sn11.10:1.7",
      "pali": "Yannūna mayaṁ sambaraṁ asurindaṁ upasaṅkamitvā abhayadakkhiṇaṁ yāceyyāmā’ti."
    },
    {
      "id": "sn11.10:1.8",
      "pali": "Atha kho, bhikkhave, te isayo sīlavanto kalyāṇadhammā—seyyathāpi nāma balavā puriso samiñjitaṁ vā bāhaṁ pasāreyya, pasāritaṁ vā bāhaṁ samiñjeyya; evameva—samuddatīre paṇṇakuṭīsu antarahitā sambarassa asurindassa sammukhe pāturahesuṁ."
    },
    {
      "id": "sn11.10:1.9",
      "pali": "Atha kho, bhikkhave, te isayo sīlavanto kalyāṇadhammā sambaraṁ asurindaṁ gāthāya ajjhabhāsiṁsu:"
    },
    {
      "id": "sn11.10:2.1",
      "pali": "‘Isayo sambaraṁ pattā,"
    },
    {
      "id": "sn11.10:2.2",
      "pali": "yācanti abhayadakkhiṇaṁ;"
    },
    {
      "id": "sn11.10:2.3",
      "pali": "Kāmaṅkaro hi te dātuṁ,"
    },
    {
      "id": "sn11.10:2.4",
      "pali": "bhayassa abhayassa vā’ti."
    },
    {
      "id": "sn11.10:3.1",
      "pali": "‘Isīnaṁ abhayaṁ natthi,"
    },
    {
      "id": "sn11.10:3.2",
      "pali": "duṭṭhānaṁ sakkasevinaṁ;"
    },
    {
      "id": "sn11.10:3.3",
      "pali": "Abhayaṁ yācamānānaṁ,"
    },
    {
      "id": "sn11.10:3.4",
      "pali": "bhayameva dadāmi vo’ti."
    },
    {
      "id": "sn11.10:4.1",
      "pali": "‘Abhayaṁ yācamānānaṁ,"
    },
    {
      "id": "sn11.10:4.2",
      "pali": "bhayameva dadāsi no;"
    },
    {
      "id": "sn11.10:4.3",
      "pali": "Paṭiggaṇhāma te etaṁ,"
    },
    {
      "id": "sn11.10:4.4",
      "pali": "akkhayaṁ hotu te bhayaṁ."
    },
    {
      "id": "sn11.10:5.1",
      "pali": "Yādisaṁ vapate bījaṁ,"
    },
    {
      "id": "sn11.10:5.2",
      "pali": "tādisaṁ harate phalaṁ;"
    },
    {
      "id": "sn11.10:5.3",
      "pali": "Kalyāṇakārī kalyāṇaṁ,"
    },
    {
      "id": "sn11.10:5.4",
      "pali": "pāpakārī ca pāpakaṁ;"
    },
    {
      "id": "sn11.10:5.5",
      "pali": "Pavuttaṁ tāta te bījaṁ,"
    },
    {
      "id": "sn11.10:5.6",
      "pali": "phalaṁ paccanubhossasī’ti."
    },
    {
      "id": "sn11.10:6.1",
      "pali": "Atha kho, bhikkhave, te isayo sīlavanto kalyāṇadhammā sambaraṁ asurindaṁ abhisapitvā—seyyathāpi nāma balavā puriso samiñjitaṁ vā bāhaṁ pasāreyya, pasāritaṁ vā bāhaṁ samiñjeyya; evameva—sambarassa asurindassa sammukhe antarahitā samuddatīre paṇṇakuṭīsu pāturahesuṁ."
    },
    {
      "id": "sn11.10:6.2",
      "pali": "Atha kho, bhikkhave, sambaro asurindo tehi isīhi sīlavantehi kalyāṇadhammehi abhisapito rattiyā sudaṁ tikkhattuṁ ubbijjī”ti."
    },
    {
      "id": "sn11.10:6.3",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn11.10:7.1",
      "pali": "Suvīraṁ susīmañceva,"
    },
    {
      "id": "sn11.10:7.2",
      "pali": "dhajaggaṁ vepacittino;"
    },
    {
      "id": "sn11.10:7.3",
      "pali": "Subhāsitaṁ jayañceva,"
    },
    {
      "id": "sn11.10:7.4",
      "pali": "kulāvakaṁ nadubbhiyaṁ;"
    },
    {
      "id": "sn11.10:7.5",
      "pali": "Verocana asurindo,"
    },
    {
      "id": "sn11.10:7.6",
      "pali": "isayo araññakañceva;"
    },
    {
      "id": "sn11.10:7.7",
      "pali": "Isayo ca samuddakāti."
    }
  ]
}
