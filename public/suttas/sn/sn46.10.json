{
  "uid": "sn46.10",
  "title": "Dutiyauppannasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.10:1.1",
      "pali": "“Sattime, bhikkhave, bojjhaṅgā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā."
    },
    {
      "id": "sn46.10:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.10:1.3",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.10:1.4",
      "pali": "ime kho, bhikkhave, satta bojjhaṅgā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā”ti."
    },
    {
      "id": "sn46.10:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn46.10:1.6",
      "pali": "Pabbatavaggo paṭhamo."
    },
    {
      "id": "sn46.10:2.1",
      "pali": "Himavantaṁ kāyaṁ sīlaṁ,"
    },
    {
      "id": "sn46.10:2.2",
      "pali": "vatthaṁ bhikkhu ca kuṇḍali;"
    },
    {
      "id": "sn46.10:2.3",
      "pali": "Kūṭañca upavānañca,"
    },
    {
      "id": "sn46.10:2.4",
      "pali": "uppannā apare duveti."
    }
  ]
}
