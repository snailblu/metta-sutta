{
  "uid": "sn35.107",
  "title": "Lokasamudayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.107:1.1",
      "pali": "“Lokassa, bhikkhave, samudayañca atthaṅgamañca desessāmi."
    },
    {
      "id": "sn35.107:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.107:1.3",
      "pali": "Katamo ca, bhikkhave, lokassa samudayo?"
    },
    {
      "id": "sn35.107:1.4",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.107:1.5",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.107:1.6",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn35.107:1.7",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn35.107:1.8",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn35.107:1.9",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn35.107:1.10",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn35.107:1.11",
      "pali": "Ayaṁ kho, bhikkhave, lokassa samudayo …pe…"
    },
    {
      "id": "sn35.107:1.12",
      "pali": "jivhañca paṭicca rase ca uppajjati jivhāviññāṇaṁ …pe…"
    },
    {
      "id": "sn35.107:1.13",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.107:1.14",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.107:1.15",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn35.107:1.16",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn35.107:1.17",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn35.107:1.18",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn35.107:1.19",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn35.107:1.20",
      "pali": "Ayaṁ kho, bhikkhave, lokassa samudayo."
    },
    {
      "id": "sn35.107:2.1",
      "pali": "Katamo ca, bhikkhave, lokassa atthaṅgamo?"
    },
    {
      "id": "sn35.107:2.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.107:2.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.107:2.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.107:2.5",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.107:2.6",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn35.107:2.7",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn35.107:2.8",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn35.107:2.9",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn35.107:2.10",
      "pali": "Ayaṁ kho, bhikkhave, lokassa atthaṅgamo …pe…"
    },
    {
      "id": "sn35.107:2.11",
      "pali": "jivhañca paṭicca rase ca uppajjati …pe…"
    },
    {
      "id": "sn35.107:2.12",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.107:2.13",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.107:2.14",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.107:2.15",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.107:2.16",
      "pali": "upādānanirodhā …pe…"
    },
    {
      "id": "sn35.107:2.17",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn35.107:2.18",
      "pali": "Ayaṁ kho, bhikkhave, lokassa atthaṅgamo”ti."
    },
    {
      "id": "sn35.107:2.19",
      "pali": "Catutthaṁ."
    }
  ]
}
