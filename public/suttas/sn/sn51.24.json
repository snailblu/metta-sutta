{
  "uid": "sn51.24",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.24:1.1",
      "pali": "“Cattārome, bhikkhave, iddhipādā."
    },
    {
      "id": "sn51.24:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.24:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.24:1.4",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.24:1.5",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.24:1.6",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.24:1.7",
      "pali": "ime kho, bhikkhave, cattāro iddhipādā”ti."
    },
    {
      "id": "sn51.24:1.8",
      "pali": "Catutthaṁ."
    }
  ]
}
