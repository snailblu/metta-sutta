{
  "uid": "sn1.11",
  "title": "Nandanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.11:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.11:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.11:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn1.11:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn1.11:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn1.11:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn1.11:2.1",
      "pali": "“Bhūtapubbaṁ, bhikkhave, aññatarā tāvatiṁsakāyikā devatā nandane vane accharāsaṅghaparivutā dibbehi pañcahi kāmaguṇehi samappitā samaṅgībhūtā paricārayamānā tāyaṁ velāyaṁ imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.11:3.1",
      "pali": "‘Na te sukhaṁ pajānanti,"
    },
    {
      "id": "sn1.11:3.2",
      "pali": "ye na passanti nandanaṁ;"
    },
    {
      "id": "sn1.11:3.3",
      "pali": "Āvāsaṁ naradevānaṁ,"
    },
    {
      "id": "sn1.11:3.4",
      "pali": "tidasānaṁ yasassinan’ti."
    },
    {
      "id": "sn1.11:4.1",
      "pali": "Evaṁ vutte, bhikkhave, aññatarā devatā taṁ devataṁ gāthāya paccabhāsi:"
    },
    {
      "id": "sn1.11:5.1",
      "pali": "‘Na tvaṁ bāle pajānāsi,"
    },
    {
      "id": "sn1.11:5.2",
      "pali": "yathā arahataṁ vaco;"
    },
    {
      "id": "sn1.11:5.3",
      "pali": "Aniccā sabbasaṅkhārā,"
    },
    {
      "id": "sn1.11:5.4",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "sn1.11:5.5",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "sn1.11:5.6",
      "pali": "tesaṁ vūpasamo sukho’”ti."
    }
  ]
}
