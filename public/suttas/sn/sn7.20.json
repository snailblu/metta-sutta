{
  "uid": "sn7.20",
  "title": "Bhikkhakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.20:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.20:1.2",
      "pali": "Atha kho bhikkhako brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.20:1.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho bhikkhako brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.20:1.4",
      "pali": "“ahampi kho, bho gotama, bhikkhako, bhavampi bhikkhako, idha no kiṁ nānākaraṇan”ti?"
    },
    {
      "id": "sn7.20:2.1",
      "pali": "“Na tena bhikkhako hoti,"
    },
    {
      "id": "sn7.20:2.2",
      "pali": "yāvatā bhikkhate pare;"
    },
    {
      "id": "sn7.20:2.3",
      "pali": "Vissaṁ dhammaṁ samādāya,"
    },
    {
      "id": "sn7.20:2.4",
      "pali": "bhikkhu hoti na tāvatā."
    },
    {
      "id": "sn7.20:3.1",
      "pali": "Yodha puññañca pāpañca,"
    },
    {
      "id": "sn7.20:3.2",
      "pali": "bāhitvā brahmacariyaṁ;"
    },
    {
      "id": "sn7.20:3.3",
      "pali": "Saṅkhāya loke carati,"
    },
    {
      "id": "sn7.20:3.4",
      "pali": "sa ve bhikkhūti vuccatī”ti."
    },
    {
      "id": "sn7.20:4.1",
      "pali": "Evaṁ vutte, bhikkhako brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.20:4.2",
      "pali": "“abhikkantaṁ, bho gotama, abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.20:4.3",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
