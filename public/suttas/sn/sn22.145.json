{
  "uid": "sn22.145",
  "title": "Tatiyaanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.145:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.145:1.2",
      "pali": "“Yo, bhikkhave, anattā; tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.145:1.3",
      "pali": "Ko ca, bhikkhave, anattā?"
    },
    {
      "id": "sn22.145:1.4",
      "pali": "Rūpaṁ, bhikkhave, anattā; tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.145:1.5",
      "pali": "Vedanā anattā …"
    },
    {
      "id": "sn22.145:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn22.145:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.145:1.8",
      "pali": "viññāṇaṁ anattā; tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.145:1.9",
      "pali": "Yo, bhikkhave, anattā; tatra vo chandarāgo pahātabbo”ti."
    },
    {
      "id": "sn22.145:1.10",
      "pali": "Dasamaṁ."
    }
  ]
}
