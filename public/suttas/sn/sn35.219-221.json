{
  "uid": "sn35.219-221",
  "title": "Bāhirātītādiyadanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.219-221:1.1",
      "pali": "“Rūpā, bhikkhave, anattā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.219-221:1.2",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.219-221:1.3",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.219-221:1.4",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.219-221:1.5",
      "pali": "rasā …"
    },
    {
      "id": "sn35.219-221:1.6",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.219-221:1.7",
      "pali": "dhammā anattā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.219-221:1.8",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.219-221:1.9",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.219-221:1.10",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
