{
  "uid": "sn1.54",
  "title": "Vatthusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.54:1.1",
      "pali": "“Kiṁsu vatthu manussānaṁ,"
    },
    {
      "id": "sn1.54:1.2",
      "pali": "kiṁsūdha paramo sakhā;"
    },
    {
      "id": "sn1.54:1.3",
      "pali": "Kiṁsu bhūtā upajīvanti,"
    },
    {
      "id": "sn1.54:1.4",
      "pali": "ye pāṇā pathavissitā”ti."
    },
    {
      "id": "sn1.54:2.1",
      "pali": "“Puttā vatthu manussānaṁ,"
    },
    {
      "id": "sn1.54:2.2",
      "pali": "bhariyā ca paramo sakhā;"
    },
    {
      "id": "sn1.54:2.3",
      "pali": "Vuṭṭhiṁ bhūtā upajīvanti,"
    },
    {
      "id": "sn1.54:2.4",
      "pali": "ye pāṇā pathavissitā”ti."
    }
  ]
}
