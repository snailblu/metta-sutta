{
  "uid": "sn23.16",
  "title": "Dukkhadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.16:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.16:1.3",
      "pali": "“‘dukkhadhammo, dukkhadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.16:1.4",
      "pali": "Katamo nu kho, bhante, dukkhadhammo”ti?"
    },
    {
      "id": "sn23.16:1.5",
      "pali": "“Rūpaṁ kho, rādha, dukkhadhammo, vedanā dukkhadhammo, saññā dukkhadhammo, saṅkhārā dukkhadhammo, viññāṇaṁ dukkhadhammo."
    },
    {
      "id": "sn23.16:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.16:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.16:1.8",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
