{
  "uid": "sn45.170",
  "title": "Taṇhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.170:1.1",
      "pali": "“Tisso imā, bhikkhave, taṇhā."
    },
    {
      "id": "sn45.170:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.170:1.3",
      "pali": "Kāmataṇhā, bhavataṇhā, vibhavataṇhā—"
    },
    {
      "id": "sn45.170:1.4",
      "pali": "imā kho, bhikkhave, tisso taṇhā."
    },
    {
      "id": "sn45.170:1.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ taṇhānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.170:1.6",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.170:1.7",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ …pe… sammāsamādhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn45.170:1.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ taṇhānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.170:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn45.170:2.1",
      "pali": "“Tisso imā, bhikkhave, tasinā."
    },
    {
      "id": "sn45.170:2.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.170:2.3",
      "pali": "Kāmatasinā, bhavatasinā, vibhavatasinā."
    },
    {
      "id": "sn45.170:2.4",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ tasinānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe…."
    },
    {
      "id": "sn45.170:2.5",
      "pali": "rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ …pe…"
    },
    {
      "id": "sn45.170:2.6",
      "pali": "amatogadhaṁ amataparāyanaṁ amatapariyosānaṁ …pe…"
    },
    {
      "id": "sn45.170:2.7",
      "pali": "nibbānaninnaṁ nibbānapoṇaṁ nibbānapabbhāraṁ."
    },
    {
      "id": "sn45.170:2.8",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ tasinānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.170:2.9",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn45.170:2.10",
      "pali": "Esanāvaggo sattamo."
    },
    {
      "id": "sn45.170:2.11",
      "pali": "Tassuddānaṁ"
    },
    {
      "id": "sn45.170:2.12",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn45.170:2.13",
      "pali": "bhavo ca dukkhatā khilā;"
    },
    {
      "id": "sn45.170:2.14",
      "pali": "Malaṁ nīgho ca vedanā,"
    },
    {
      "id": "sn45.170:2.15",
      "pali": "dve taṇhā tasināya cāti."
    }
  ]
}
