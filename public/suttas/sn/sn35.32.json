{
  "uid": "sn35.32",
  "title": "Dutiyasamugghātasappāyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.32:1.1",
      "pali": "“Sabbamaññitasamugghātasappāyaṁ vo, bhikkhave, paṭipadaṁ desessāmi."
    },
    {
      "id": "sn35.32:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.32:1.3",
      "pali": "Katamā ca sā, bhikkhave, sabbamaññitasamugghātasappāyā paṭipadā?"
    },
    {
      "id": "sn35.32:2.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn35.32:2.2",
      "pali": "cakkhu niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.32:3.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.32:4.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.32:5.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.32:6.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.32:6.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.32:7.1",
      "pali": "“No hetaṁ bhante”."
    },
    {
      "id": "sn35.32:8.1",
      "pali": "“Rūpā …pe…"
    },
    {
      "id": "sn35.32:8.2",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.32:8.3",
      "pali": "cakkhusamphasso nicco vā anicco vā”ti?"
    },
    {
      "id": "sn35.32:9.1",
      "pali": "“Anicco, bhante” …pe…."
    },
    {
      "id": "sn35.32:10.1",
      "pali": "“Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.32:11.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.32:12.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.32:13.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.32:14.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.32:14.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.32:15.1",
      "pali": "“No hetaṁ, bhante” …pe…."
    },
    {
      "id": "sn35.32:16.1",
      "pali": "“Jivhā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn35.32:17.1",
      "pali": "“Aniccā, bhante” …pe…."
    },
    {
      "id": "sn35.32:18.1",
      "pali": "“Rasā …"
    },
    {
      "id": "sn35.32:18.2",
      "pali": "jivhāviññāṇaṁ …"
    },
    {
      "id": "sn35.32:18.3",
      "pali": "jivhāsamphasso …pe…"
    },
    {
      "id": "sn35.32:18.4",
      "pali": "yampidaṁ jivhāsamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.32:19.1",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn35.32:20.1",
      "pali": "dhammā …"
    },
    {
      "id": "sn35.32:20.2",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.32:20.3",
      "pali": "manosamphasso nicco vā anicco vā”ti?"
    },
    {
      "id": "sn35.32:21.1",
      "pali": "“Anicco, bhante”."
    },
    {
      "id": "sn35.32:22.1",
      "pali": "“Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.32:23.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.32:24.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.32:25.1",
      "pali": "“Dukkhaṁ bhante”."
    },
    {
      "id": "sn35.32:26.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.32:26.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.32:27.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.32:28.1",
      "pali": "“Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako cakkhusmimpi nibbindati, rūpesupi nibbindati, cakkhuviññāṇepi nibbindati, cakkhusamphassepi nibbindati."
    },
    {
      "id": "sn35.32:28.2",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati …pe…"
    },
    {
      "id": "sn35.32:28.3",
      "pali": "jivhāyapi nibbindati, rasesupi …pe… yampidaṁ jivhāsamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati …pe…."
    },
    {
      "id": "sn35.32:28.4",
      "pali": "Manasmimpi nibbindati, dhammesupi nibbindati, manoviññāṇepi nibbindati, manosamphassepi nibbindati."
    },
    {
      "id": "sn35.32:28.5",
      "pali": "Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati."
    },
    {
      "id": "sn35.32:28.6",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn35.32:28.7",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānāti."
    },
    {
      "id": "sn35.32:28.8",
      "pali": "Ayaṁ kho sā, bhikkhave, sabbamaññitasamugghātasappāyā paṭipadā”ti."
    },
    {
      "id": "sn35.32:28.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.32:28.10",
      "pali": "Sabbavaggo tatiyo."
    },
    {
      "id": "sn35.32:29.1",
      "pali": "Sabbañca dvepi pahānā,"
    },
    {
      "id": "sn35.32:29.2",
      "pali": "parijānāpare duve;"
    },
    {
      "id": "sn35.32:29.3",
      "pali": "Ādittaṁ addhabhūtañca,"
    },
    {
      "id": "sn35.32:29.4",
      "pali": "sāruppā dve ca sappāyā;"
    },
    {
      "id": "sn35.32:29.5",
      "pali": "Vaggo tena pavuccatīti."
    }
  ]
}
