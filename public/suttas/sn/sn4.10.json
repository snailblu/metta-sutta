{
  "uid": "sn4.10",
  "title": "Dutiyaāyusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.10:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.10:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn4.10:1.3",
      "pali": "Tatra kho bhagavā …pe… etadavoca:"
    },
    {
      "id": "sn4.10:2.1",
      "pali": "“Appamidaṁ, bhikkhave, manussānaṁ āyu."
    },
    {
      "id": "sn4.10:2.2",
      "pali": "Gamanīyo samparāyo, kattabbaṁ kusalaṁ, caritabbaṁ brahmacariyaṁ."
    },
    {
      "id": "sn4.10:2.3",
      "pali": "Natthi jātassa amaraṇaṁ."
    },
    {
      "id": "sn4.10:2.4",
      "pali": "Yo, bhikkhave, ciraṁ jīvati, so vassasataṁ appaṁ vā bhiyyo”ti."
    },
    {
      "id": "sn4.10:3.1",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.10:4.1",
      "pali": "“Nāccayanti ahorattā,"
    },
    {
      "id": "sn4.10:4.2",
      "pali": "Jīvitaṁ nūparujjhati;"
    },
    {
      "id": "sn4.10:4.3",
      "pali": "Āyu anupariyāyati maccānaṁ,"
    },
    {
      "id": "sn4.10:4.4",
      "pali": "Nemīva rathakubbaran”ti."
    },
    {
      "id": "sn4.10:5.1",
      "pali": "“Accayanti ahorattā,"
    },
    {
      "id": "sn4.10:5.2",
      "pali": "jīvitaṁ uparujjhati;"
    },
    {
      "id": "sn4.10:5.3",
      "pali": "Āyu khīyati maccānaṁ,"
    },
    {
      "id": "sn4.10:5.4",
      "pali": "kunnadīnaṁva odakan”ti."
    },
    {
      "id": "sn4.10:6.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti dukkhī dummano tatthevantaradhāyīti."
    },
    {
      "id": "sn4.10:6.2",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn4.10:7.1",
      "pali": "Tapokammañca nāgo ca,"
    },
    {
      "id": "sn4.10:7.2",
      "pali": "subhaṁ pāsena te duve;"
    },
    {
      "id": "sn4.10:7.3",
      "pali": "Sappo supati nandanaṁ,"
    },
    {
      "id": "sn4.10:7.4",
      "pali": "āyunā apare duveti."
    }
  ]
}
