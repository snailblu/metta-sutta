{
  "uid": "sn18.11",
  "title": "Cakkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.11:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn18.11:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.11:1.3",
      "pali": "Atha kho āyasmā rāhulo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinnaṁ kho āyasmantaṁ rāhulaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn18.11:1.4",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.11:1.5",
      "pali": "cakkhuṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.11:1.6",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn18.11:1.7",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn18.11:1.8",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn18.11:1.9",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn18.11:1.10",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn18.11:1.11",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn18.11:1.12",
      "pali": "“Sotaṁ …pe…"
    },
    {
      "id": "sn18.11:1.13",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn18.11:1.14",
      "pali": "jivhā …"
    },
    {
      "id": "sn18.11:1.15",
      "pali": "kāyo …"
    },
    {
      "id": "sn18.11:1.16",
      "pali": "mano nicco vā anicco vā”ti?"
    },
    {
      "id": "sn18.11:1.17",
      "pali": "“Anicco, bhante”."
    },
    {
      "id": "sn18.11:1.18",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn18.11:1.19",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn18.11:1.20",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn18.11:1.21",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn18.11:1.22",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn18.11:1.23",
      "pali": "“Evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusmimpi nibbindati …pe… sotasmimpi nibbindati … ghānasmimpi nibbindati … jivhāyapi nibbindati … kāyasmimpi nibbindati … manasmimpi nibbindati;"
    },
    {
      "id": "sn18.11:1.24",
      "pali": "nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn18.11:1.25",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn18.11:1.26",
      "pali": "(Etena peyyālena dasa suttantā kātabbā.)"
    },
    {
      "id": "sn18.11:1.27",
      "pali": "Paṭhamaṁ."
    }
  ]
}
