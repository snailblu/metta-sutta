{
  "uid": "sn35.3",
  "title": "Ajjhattānattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.3:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, anattā."
    },
    {
      "id": "sn35.3:1.2",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.3:1.3",
      "pali": "Sotaṁ anattā …pe…"
    },
    {
      "id": "sn35.3:1.4",
      "pali": "ghānaṁ anattā …"
    },
    {
      "id": "sn35.3:1.5",
      "pali": "jivhā anattā …"
    },
    {
      "id": "sn35.3:1.6",
      "pali": "kāyo anattā …"
    },
    {
      "id": "sn35.3:1.7",
      "pali": "mano anattā."
    },
    {
      "id": "sn35.3:1.8",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.3:1.9",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.3:1.10",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn35.3:1.11",
      "pali": "Tatiyaṁ."
    }
  ]
}
