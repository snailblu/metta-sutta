{
  "uid": "sn1.76",
  "title": "Najīratisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.76:1.1",
      "pali": "“Kiṁ jīrati kiṁ na jīrati,"
    },
    {
      "id": "sn1.76:1.2",
      "pali": "kiṁsu uppathoti vuccati;"
    },
    {
      "id": "sn1.76:1.3",
      "pali": "Kiṁsu dhammānaṁ paripantho,"
    },
    {
      "id": "sn1.76:1.4",
      "pali": "kiṁsu rattindivakkhayo;"
    },
    {
      "id": "sn1.76:1.5",
      "pali": "Kiṁ malaṁ brahmacariyassa,"
    },
    {
      "id": "sn1.76:1.6",
      "pali": "kiṁ sinānamanodakaṁ."
    },
    {
      "id": "sn1.76:2.1",
      "pali": "Kati lokasmiṁ chiddāni,"
    },
    {
      "id": "sn1.76:2.2",
      "pali": "yattha vittaṁ na tiṭṭhati;"
    },
    {
      "id": "sn1.76:2.3",
      "pali": "Bhagavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "sn1.76:2.4",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "sn1.76:3.1",
      "pali": "“Rūpaṁ jīrati maccānaṁ,"
    },
    {
      "id": "sn1.76:3.2",
      "pali": "nāmagottaṁ na jīrati;"
    },
    {
      "id": "sn1.76:3.3",
      "pali": "Rāgo uppathoti vuccati."
    },
    {
      "id": "sn1.76:4.1",
      "pali": "Lobho dhammānaṁ paripantho,"
    },
    {
      "id": "sn1.76:4.2",
      "pali": "Vayo rattindivakkhayo;"
    },
    {
      "id": "sn1.76:4.3",
      "pali": "Itthī malaṁ brahmacariyassa,"
    },
    {
      "id": "sn1.76:4.4",
      "pali": "Etthāyaṁ sajjate pajā;"
    },
    {
      "id": "sn1.76:4.5",
      "pali": "Tapo ca brahmacariyañca,"
    },
    {
      "id": "sn1.76:4.6",
      "pali": "Taṁ sinānamanodakaṁ."
    },
    {
      "id": "sn1.76:5.1",
      "pali": "Cha lokasmiṁ chiddāni,"
    },
    {
      "id": "sn1.76:5.2",
      "pali": "yattha vittaṁ na tiṭṭhati;"
    },
    {
      "id": "sn1.76:5.3",
      "pali": "Ālasyañca pamādo ca,"
    },
    {
      "id": "sn1.76:5.4",
      "pali": "anuṭṭhānaṁ asaṁyamo;"
    },
    {
      "id": "sn1.76:5.5",
      "pali": "Niddā tandī ca te chidde,"
    },
    {
      "id": "sn1.76:5.6",
      "pali": "sabbaso taṁ vivajjaye”ti."
    }
  ]
}
