{
  "uid": "sn11.4",
  "title": "Vepacittisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn11.4:1.2",
      "pali": "“Bhūtapubbaṁ, bhikkhave, devāsurasaṅgāmo samupabyūḷho ahosi."
    },
    {
      "id": "sn11.4:1.3",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo asure āmantesi:"
    },
    {
      "id": "sn11.4:1.4",
      "pali": "‘sace, mārisā, devānaṁ asurasaṅgāme samupabyūḷhe asurā jineyyuṁ devā parājineyyuṁ, yena naṁ sakkaṁ devānamindaṁ kaṇṭhapañcamehi bandhanehi bandhitvā mama santike āneyyātha asurapuran’ti."
    },
    {
      "id": "sn11.4:1.5",
      "pali": "Sakkopi kho, bhikkhave, devānamindo deve tāvatiṁse āmantesi:"
    },
    {
      "id": "sn11.4:1.6",
      "pali": "‘sace, mārisā, devānaṁ asurasaṅgāme samupabyūḷhe devā jineyyuṁ asurā parājineyyuṁ, yena naṁ vepacittiṁ asurindaṁ kaṇṭhapañcamehi bandhanehi bandhitvā mama santike āneyyātha sudhammasabhan’ti."
    },
    {
      "id": "sn11.4:1.7",
      "pali": "Tasmiṁ kho pana, bhikkhave, saṅgāme devā jiniṁsu, asurā parājiniṁsu."
    },
    {
      "id": "sn11.4:1.8",
      "pali": "Atha kho, bhikkhave, devā tāvatiṁsā vepacittiṁ asurindaṁ kaṇṭhapañcamehi bandhanehi bandhitvā sakkassa devānamindassa santike ānesuṁ sudhammasabhaṁ."
    },
    {
      "id": "sn11.4:1.9",
      "pali": "Tatra sudaṁ, bhikkhave, vepacitti asurindo kaṇṭhapañcamehi bandhanehi baddho sakkaṁ devānamindaṁ sudhammasabhaṁ pavisantañca nikkhamantañca asabbhāhi pharusāhi vācāhi akkosati paribhāsati."
    },
    {
      "id": "sn11.4:1.10",
      "pali": "Atha kho, bhikkhave, mātali saṅgāhako sakkaṁ devānamindaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn11.4:2.1",
      "pali": "‘Bhayā nu maghavā sakka,"
    },
    {
      "id": "sn11.4:2.2",
      "pali": "dubbalyā no titikkhasi;"
    },
    {
      "id": "sn11.4:2.3",
      "pali": "Suṇanto pharusaṁ vācaṁ,"
    },
    {
      "id": "sn11.4:2.4",
      "pali": "sammukhā vepacittino’ti."
    },
    {
      "id": "sn11.4:3.1",
      "pali": "‘Nāhaṁ bhayā na dubbalyā,"
    },
    {
      "id": "sn11.4:3.2",
      "pali": "khamāmi vepacittino;"
    },
    {
      "id": "sn11.4:3.3",
      "pali": "Kathañhi mādiso viññū,"
    },
    {
      "id": "sn11.4:3.4",
      "pali": "bālena paṭisaṁyuje’ti."
    },
    {
      "id": "sn11.4:4.1",
      "pali": "‘Bhiyyo bālā pabhijjeyyuṁ,"
    },
    {
      "id": "sn11.4:4.2",
      "pali": "no cassa paṭisedhako;"
    },
    {
      "id": "sn11.4:4.3",
      "pali": "Tasmā bhusena daṇḍena,"
    },
    {
      "id": "sn11.4:4.4",
      "pali": "dhīro bālaṁ nisedhaye’ti."
    },
    {
      "id": "sn11.4:5.1",
      "pali": "‘Etadeva ahaṁ maññe,"
    },
    {
      "id": "sn11.4:5.2",
      "pali": "bālassa paṭisedhanaṁ;"
    },
    {
      "id": "sn11.4:5.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "sn11.4:5.4",
      "pali": "yo sato upasammatī’ti."
    },
    {
      "id": "sn11.4:6.1",
      "pali": "‘Etadeva titikkhāya,"
    },
    {
      "id": "sn11.4:6.2",
      "pali": "vajjaṁ passāmi vāsava;"
    },
    {
      "id": "sn11.4:6.3",
      "pali": "Yadā naṁ maññati bālo,"
    },
    {
      "id": "sn11.4:6.4",
      "pali": "bhayā myāyaṁ titikkhati;"
    },
    {
      "id": "sn11.4:6.5",
      "pali": "Ajjhāruhati dummedho,"
    },
    {
      "id": "sn11.4:6.6",
      "pali": "gova bhiyyo palāyinan’ti."
    },
    {
      "id": "sn11.4:7.1",
      "pali": "‘Kāmaṁ maññatu vā mā vā,"
    },
    {
      "id": "sn11.4:7.2",
      "pali": "bhayā myāyaṁ titikkhati;"
    },
    {
      "id": "sn11.4:7.3",
      "pali": "Sadatthaparamā atthā,"
    },
    {
      "id": "sn11.4:7.4",
      "pali": "khantyā bhiyyo na vijjati."
    },
    {
      "id": "sn11.4:8.1",
      "pali": "Yo have balavā santo,"
    },
    {
      "id": "sn11.4:8.2",
      "pali": "dubbalassa titikkhati;"
    },
    {
      "id": "sn11.4:8.3",
      "pali": "Tamāhu paramaṁ khantiṁ,"
    },
    {
      "id": "sn11.4:8.4",
      "pali": "niccaṁ khamati dubbalo."
    },
    {
      "id": "sn11.4:9.1",
      "pali": "Abalaṁ taṁ balaṁ āhu,"
    },
    {
      "id": "sn11.4:9.2",
      "pali": "yassa bālabalaṁ balaṁ;"
    },
    {
      "id": "sn11.4:9.3",
      "pali": "Balassa dhammaguttassa,"
    },
    {
      "id": "sn11.4:9.4",
      "pali": "paṭivattā na vijjati."
    },
    {
      "id": "sn11.4:10.1",
      "pali": "Tasseva tena pāpiyo,"
    },
    {
      "id": "sn11.4:10.2",
      "pali": "yo kuddhaṁ paṭikujjhati;"
    },
    {
      "id": "sn11.4:10.3",
      "pali": "Kuddhaṁ appaṭikujjhanto,"
    },
    {
      "id": "sn11.4:10.4",
      "pali": "saṅgāmaṁ jeti dujjayaṁ."
    },
    {
      "id": "sn11.4:11.1",
      "pali": "Ubhinnamatthaṁ carati,"
    },
    {
      "id": "sn11.4:11.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn11.4:11.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "sn11.4:11.4",
      "pali": "yo sato upasammati."
    },
    {
      "id": "sn11.4:12.1",
      "pali": "Ubhinnaṁ tikicchantānaṁ,"
    },
    {
      "id": "sn11.4:12.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn11.4:12.3",
      "pali": "Janā maññanti bāloti,"
    },
    {
      "id": "sn11.4:12.4",
      "pali": "ye dhammassa akovidā’ti."
    },
    {
      "id": "sn11.4:13.1",
      "pali": "So hi nāma, bhikkhave, sakko devānamindo sakaṁ puññaphalaṁ upajīvamāno devānaṁ tāvatiṁsānaṁ issariyādhipaccaṁ rajjaṁ kārento khantisoraccassa vaṇṇavādī bhavissati."
    },
    {
      "id": "sn11.4:13.2",
      "pali": "Idha kho taṁ, bhikkhave, sobhetha yaṁ tumhe evaṁ svākkhāte dhammavinaye pabbajitā samānā khamā ca bhaveyyātha soratā cā”ti."
    }
  ]
}
