{
  "uid": "sn25.9",
  "title": "Pathavīdhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.9:1.2",
      "pali": "“Pathavīdhātu, bhikkhave, aniccā vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.9:1.3",
      "pali": "āpodhātu …"
    },
    {
      "id": "sn25.9:1.4",
      "pali": "tejodhātu …"
    },
    {
      "id": "sn25.9:1.5",
      "pali": "vāyodhātu …"
    },
    {
      "id": "sn25.9:1.6",
      "pali": "ākāsadhātu …"
    },
    {
      "id": "sn25.9:1.7",
      "pali": "viññāṇadhātu aniccā vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.9:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.9:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.9:1.10",
      "pali": "Navamaṁ."
    }
  ]
}
