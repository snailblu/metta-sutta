{
  "uid": "sn1.15",
  "title": "Saṇamānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.15:1.1",
      "pali": "“Ṭhite majjhanhike kāle,"
    },
    {
      "id": "sn1.15:1.2",
      "pali": "sannisīvesu pakkhisu;"
    },
    {
      "id": "sn1.15:1.3",
      "pali": "Saṇateva brahāraññaṁ,"
    },
    {
      "id": "sn1.15:1.4",
      "pali": "taṁ bhayaṁ paṭibhāti man”ti."
    },
    {
      "id": "sn1.15:2.1",
      "pali": "“Ṭhite majjhanhike kāle,"
    },
    {
      "id": "sn1.15:2.2",
      "pali": "sannisīvesu pakkhisu;"
    },
    {
      "id": "sn1.15:2.3",
      "pali": "Saṇateva brahāraññaṁ,"
    },
    {
      "id": "sn1.15:2.4",
      "pali": "sā rati paṭibhāti man”ti."
    }
  ]
}
