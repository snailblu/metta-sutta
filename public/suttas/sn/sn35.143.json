{
  "uid": "sn35.143",
  "title": "Bāhirāniccahetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.143:1.1",
      "pali": "“Rūpā, bhikkhave, aniccā."
    },
    {
      "id": "sn35.143:1.2",
      "pali": "Yopi hetu, yopi paccayo rūpānaṁ uppādāya, sopi anicco."
    },
    {
      "id": "sn35.143:1.3",
      "pali": "Aniccasambhūtā, bhikkhave, rūpā kuto niccā bhavissanti."
    },
    {
      "id": "sn35.143:1.4",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.143:1.5",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.143:1.6",
      "pali": "rasā …"
    },
    {
      "id": "sn35.143:1.7",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.143:1.8",
      "pali": "dhammā aniccā."
    },
    {
      "id": "sn35.143:1.9",
      "pali": "Yopi hetu, yopi paccayo dhammānaṁ uppādāya, sopi anicco."
    },
    {
      "id": "sn35.143:1.10",
      "pali": "Aniccasambhūtā, bhikkhave, dhammā kuto niccā bhavissanti."
    },
    {
      "id": "sn35.143:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.143:1.12",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.143:1.13",
      "pali": "Dasamaṁ."
    }
  ]
}
