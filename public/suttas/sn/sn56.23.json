{
  "uid": "sn56.23",
  "title": "Sammāsambuddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.23:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn56.23:1.2",
      "pali": "Cattārimāni, bhikkhave, ariyasaccāni."
    },
    {
      "id": "sn56.23:1.3",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "sn56.23:1.4",
      "pali": "Dukkhaṁ ariyasaccaṁ …pe… dukkhanirodhagāminī paṭipadā ariyasaccaṁ—"
    },
    {
      "id": "sn56.23:1.5",
      "pali": "imāni kho, bhikkhave, cattāri ariyasaccāni."
    },
    {
      "id": "sn56.23:1.6",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ ariyasaccānaṁ yathābhūtaṁ abhisambuddhattā tathāgato ‘arahaṁ sammāsambuddho’ti vuccati."
    },
    {
      "id": "sn56.23:2.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.23:2.2",
      "pali": "Tatiyaṁ."
    }
  ]
}
