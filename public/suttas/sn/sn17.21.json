{
  "uid": "sn17.21",
  "title": "Mātugāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.21:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.21:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.21:1.3",
      "pali": "na tassa, bhikkhave, mātugāmo eko ekassa cittaṁ pariyādāya tiṭṭhati yassa lābhasakkārasiloko cittaṁ pariyādāya tiṭṭhati."
    },
    {
      "id": "sn17.21:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.21:1.5",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.21:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
