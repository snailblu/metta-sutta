{
  "uid": "sn22.8",
  "title": "Dutiyaupādāparitassanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.8:1.2",
      "pali": "“Upādāparitassanañca vo, bhikkhave, desessāmi anupādāaparitassanañca."
    },
    {
      "id": "sn22.8:1.3",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "sn22.8:1.4",
      "pali": "kathañca, bhikkhave, upādāparitassanā hoti?"
    },
    {
      "id": "sn22.8:1.5",
      "pali": "Idha, bhikkhave, assutavā puthujjano rūpaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassati."
    },
    {
      "id": "sn22.8:1.6",
      "pali": "Tassa taṁ rūpaṁ vipariṇamati aññathā hoti."
    },
    {
      "id": "sn22.8:1.7",
      "pali": "Tassa rūpavipariṇāmaññathābhāvā uppajjanti sokaparidevadukkhadomanassupāyāsā."
    },
    {
      "id": "sn22.8:1.8",
      "pali": "Vedanaṁ etaṁ mama …pe…"
    },
    {
      "id": "sn22.8:1.9",
      "pali": "saññaṁ etaṁ mama …"
    },
    {
      "id": "sn22.8:1.10",
      "pali": "saṅkhāre etaṁ mama …"
    },
    {
      "id": "sn22.8:1.11",
      "pali": "viññāṇaṁ ‘etaṁ mama, esohamasmi, eso me attā’ti samanupassati."
    },
    {
      "id": "sn22.8:1.12",
      "pali": "Tassa taṁ viññāṇaṁ vipariṇamati aññathā hoti."
    },
    {
      "id": "sn22.8:1.13",
      "pali": "Tassa viññāṇavipariṇāmaññathābhāvā uppajjanti sokaparidevadukkhadomanassupāyāsā."
    },
    {
      "id": "sn22.8:1.14",
      "pali": "Evaṁ kho, bhikkhave, upādāparitassanā hoti."
    },
    {
      "id": "sn22.8:2.1",
      "pali": "Kathañca, bhikkhave, anupādāaparitassanā hoti?"
    },
    {
      "id": "sn22.8:2.2",
      "pali": "Idha, bhikkhave, sutavā ariyasāvako rūpaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti samanupassati."
    },
    {
      "id": "sn22.8:2.3",
      "pali": "Tassa taṁ rūpaṁ vipariṇamati aññathā hoti."
    },
    {
      "id": "sn22.8:2.4",
      "pali": "Tassa rūpavipariṇāmaññathābhāvā nuppajjanti sokaparidevadukkhadomanassupāyāsā."
    },
    {
      "id": "sn22.8:2.5",
      "pali": "Vedanaṁ netaṁ mama …"
    },
    {
      "id": "sn22.8:2.6",
      "pali": "saññaṁ netaṁ mama …"
    },
    {
      "id": "sn22.8:2.7",
      "pali": "saṅkhāre netaṁ mama …"
    },
    {
      "id": "sn22.8:2.8",
      "pali": "viññāṇaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti samanupassati."
    },
    {
      "id": "sn22.8:2.9",
      "pali": "Tassa taṁ viññāṇaṁ vipariṇamati aññathā hoti."
    },
    {
      "id": "sn22.8:2.10",
      "pali": "Tassa viññāṇavipariṇāmaññathābhāvā nuppajjanti sokaparidevadukkhadomanassupāyāsā."
    },
    {
      "id": "sn22.8:2.11",
      "pali": "Evaṁ kho, bhikkhave, anupādāaparitassanā hotī”ti."
    },
    {
      "id": "sn22.8:2.12",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
