{
  "uid": "sn12.65",
  "title": "Nagarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.65:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.65:1.2",
      "pali": "“Pubbe me, bhikkhave, sambodhā anabhisambuddhassa bodhisattasseva sato etadahosi:"
    },
    {
      "id": "sn12.65:1.3",
      "pali": "‘kicchā vatāyaṁ loko āpanno jāyati ca jīyati ca mīyati ca cavati ca upapajjati ca."
    },
    {
      "id": "sn12.65:1.4",
      "pali": "Atha ca panimassa dukkhassa nissaraṇaṁ nappajānāti jarāmaraṇassa."
    },
    {
      "id": "sn12.65:1.5",
      "pali": "Kudāssu nāma imassa dukkhassa nissaraṇaṁ paññāyissati jarāmaraṇassā’ti?"
    },
    {
      "id": "sn12.65:1.6",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:1.7",
      "pali": "‘kimhi nu kho sati jarāmaraṇaṁ hoti, kiṁpaccayā jarāmaraṇan’ti?"
    },
    {
      "id": "sn12.65:1.8",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:1.9",
      "pali": "‘jātiyā kho sati jarāmaraṇaṁ hoti, jātipaccayā jarāmaraṇan’ti."
    },
    {
      "id": "sn12.65:2.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:2.2",
      "pali": "‘kimhi nu kho sati jāti hoti …pe…"
    },
    {
      "id": "sn12.65:2.3",
      "pali": "bhavo hoti …"
    },
    {
      "id": "sn12.65:2.4",
      "pali": "upādānaṁ hoti …"
    },
    {
      "id": "sn12.65:2.5",
      "pali": "taṇhā hoti …"
    },
    {
      "id": "sn12.65:2.6",
      "pali": "vedanā hoti …"
    },
    {
      "id": "sn12.65:2.7",
      "pali": "phasso hoti …"
    },
    {
      "id": "sn12.65:2.8",
      "pali": "saḷāyatanaṁ hoti …"
    },
    {
      "id": "sn12.65:2.9",
      "pali": "nāmarūpaṁ hoti …"
    },
    {
      "id": "sn12.65:2.10",
      "pali": "kiṁpaccayā nāmarūpan’ti?"
    },
    {
      "id": "sn12.65:2.11",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:2.12",
      "pali": "‘viññāṇe kho sati nāmarūpaṁ hoti, viññāṇapaccayā nāmarūpan’ti."
    },
    {
      "id": "sn12.65:2.13",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:2.14",
      "pali": "‘kimhi nu kho sati viññāṇaṁ hoti, kiṁpaccayā viññāṇan’ti?"
    },
    {
      "id": "sn12.65:2.15",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:2.16",
      "pali": "‘nāmarūpe kho sati viññāṇaṁ hoti, nāmarūpapaccayā viññāṇan’ti."
    },
    {
      "id": "sn12.65:3.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi—"
    },
    {
      "id": "sn12.65:3.2",
      "pali": "paccudāvattati kho idaṁ viññāṇaṁ nāmarūpamhā na paraṁ gacchati."
    },
    {
      "id": "sn12.65:3.3",
      "pali": "Ettāvatā jāyetha vā jīyetha vā mīyetha vā cavetha vā upapajjetha vā, yadidaṁ nāmarūpapaccayā viññāṇaṁ;"
    },
    {
      "id": "sn12.65:3.4",
      "pali": "viññāṇapaccayā nāmarūpaṁ;"
    },
    {
      "id": "sn12.65:3.5",
      "pali": "nāmarūpapaccayā saḷāyatanaṁ;"
    },
    {
      "id": "sn12.65:3.6",
      "pali": "saḷāyatanapaccayā phasso …pe…"
    },
    {
      "id": "sn12.65:3.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.65:3.8",
      "pali": "‘Samudayo, samudayo’ti kho me, bhikkhave, pubbe ananussutesu dhammesu cakkhuṁ udapādi ñāṇaṁ udapādi paññā udapādi vijjā udapādi āloko udapādi."
    },
    {
      "id": "sn12.65:4.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:4.2",
      "pali": "‘kimhi nu kho asati, jarāmaraṇaṁ na hoti;"
    },
    {
      "id": "sn12.65:4.3",
      "pali": "kissa nirodhā jarāmaraṇanirodho’ti?"
    },
    {
      "id": "sn12.65:4.4",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:4.5",
      "pali": "‘jātiyā kho asati, jarāmaraṇaṁ na hoti;"
    },
    {
      "id": "sn12.65:4.6",
      "pali": "jātinirodhā jarāmaraṇanirodho’ti."
    },
    {
      "id": "sn12.65:4.7",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:4.8",
      "pali": "‘kimhi nu kho asati jāti na hoti …pe…"
    },
    {
      "id": "sn12.65:4.9",
      "pali": "bhavo na hoti …"
    },
    {
      "id": "sn12.65:4.10",
      "pali": "upādānaṁ na hoti …"
    },
    {
      "id": "sn12.65:4.11",
      "pali": "taṇhā na hoti …"
    },
    {
      "id": "sn12.65:4.12",
      "pali": "vedanā na hoti …"
    },
    {
      "id": "sn12.65:4.13",
      "pali": "phasso na hoti …"
    },
    {
      "id": "sn12.65:4.14",
      "pali": "saḷāyatanaṁ na hoti …"
    },
    {
      "id": "sn12.65:4.15",
      "pali": "nāmarūpaṁ na hoti."
    },
    {
      "id": "sn12.65:4.16",
      "pali": "Kissa nirodhā nāmarūpanirodho’ti?"
    },
    {
      "id": "sn12.65:4.17",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:4.18",
      "pali": "‘viññāṇe kho asati, nāmarūpaṁ na hoti;"
    },
    {
      "id": "sn12.65:4.19",
      "pali": "viññāṇanirodhā nāmarūpanirodho’ti."
    },
    {
      "id": "sn12.65:5.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.65:5.2",
      "pali": "‘kimhi nu kho asati viññāṇaṁ na hoti;"
    },
    {
      "id": "sn12.65:5.3",
      "pali": "kissa nirodhā viññāṇanirodho’ti?"
    },
    {
      "id": "sn12.65:5.4",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.65:5.5",
      "pali": "‘nāmarūpe kho asati, viññāṇaṁ na hoti;"
    },
    {
      "id": "sn12.65:5.6",
      "pali": "nāmarūpanirodhā viññāṇanirodho’ti."
    },
    {
      "id": "sn12.65:6.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi—"
    },
    {
      "id": "sn12.65:6.2",
      "pali": "adhigato kho myāyaṁ maggo bodhāya yadidaṁ—"
    },
    {
      "id": "sn12.65:6.3",
      "pali": "nāmarūpanirodhā viññāṇanirodho;"
    },
    {
      "id": "sn12.65:6.4",
      "pali": "viññāṇanirodhā nāmarūpanirodho;"
    },
    {
      "id": "sn12.65:6.5",
      "pali": "nāmarūpanirodhā saḷāyatananirodho;"
    },
    {
      "id": "sn12.65:6.6",
      "pali": "saḷāyatananirodhā phassanirodho …pe…"
    },
    {
      "id": "sn12.65:6.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.65:6.8",
      "pali": "‘Nirodho, nirodho’ti kho me, bhikkhave, pubbe ananussutesu dhammesu cakkhuṁ udapādi ñāṇaṁ udapādi paññā udapādi vijjā udapādi āloko udapādi."
    },
    {
      "id": "sn12.65:7.1",
      "pali": "Seyyathāpi, bhikkhave, puriso araññe pavane caramāno passeyya purāṇaṁ maggaṁ purāṇañjasaṁ pubbakehi manussehi anuyātaṁ."
    },
    {
      "id": "sn12.65:7.2",
      "pali": "So tamanugaccheyya."
    },
    {
      "id": "sn12.65:7.3",
      "pali": "Tamanugacchanto passeyya purāṇaṁ nagaraṁ purāṇaṁ rājadhāniṁ pubbakehi manussehi ajjhāvuṭṭhaṁ ārāmasampannaṁ vanasampannaṁ pokkharaṇīsampannaṁ uddhāpavantaṁ ramaṇīyaṁ."
    },
    {
      "id": "sn12.65:7.4",
      "pali": "Atha kho so, bhikkhave, puriso rañño vā rājamahāmattassa vā āroceyya:"
    },
    {
      "id": "sn12.65:7.5",
      "pali": "‘yagghe, bhante, jāneyyāsi—ahaṁ addasaṁ araññe pavane caramāno purāṇaṁ maggaṁ purāṇañjasaṁ pubbakehi manussehi anuyātaṁ tamanugacchiṁ."
    },
    {
      "id": "sn12.65:7.6",
      "pali": "Tamanugacchanto addasaṁ purāṇaṁ nagaraṁ purāṇaṁ rājadhāniṁ pubbakehi manussehi ajjhāvuṭṭhaṁ ārāmasampannaṁ vanasampannaṁ pokkharaṇīsampannaṁ uddhāpavantaṁ ramaṇīyaṁ."
    },
    {
      "id": "sn12.65:7.7",
      "pali": "Taṁ, bhante, nagaraṁ māpehī’ti."
    },
    {
      "id": "sn12.65:7.8",
      "pali": "Atha kho so, bhikkhave, rājā vā rājamahāmatto vā taṁ nagaraṁ māpeyya."
    },
    {
      "id": "sn12.65:7.9",
      "pali": "Tadassa nagaraṁ aparena samayena iddhañceva phītañca bāhujaññaṁ ākiṇṇamanussaṁ vuddhivepullappattaṁ."
    },
    {
      "id": "sn12.65:7.10",
      "pali": "Evameva khvāhaṁ, bhikkhave, addasaṁ purāṇaṁ maggaṁ purāṇañjasaṁ pubbakehi sammāsambuddhehi anuyātaṁ."
    },
    {
      "id": "sn12.65:8.1",
      "pali": "Katamo ca so, bhikkhave, purāṇamaggo purāṇañjaso pubbakehi sammāsambuddhehi anuyāto?"
    },
    {
      "id": "sn12.65:8.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn12.65:8.3",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn12.65:8.4",
      "pali": "Ayaṁ kho so, bhikkhave, purāṇamaggo purāṇañjaso pubbakehi sammāsambuddhehi anuyāto, tamanugacchiṁ;"
    },
    {
      "id": "sn12.65:8.5",
      "pali": "tamanugacchanto jarāmaraṇaṁ abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.6",
      "pali": "jarāmaraṇasamudayaṁ abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.7",
      "pali": "jarāmaraṇanirodhaṁ abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.8",
      "pali": "jarāmaraṇanirodhagāminiṁ paṭipadaṁ abbhaññāsiṁ."
    },
    {
      "id": "sn12.65:8.9",
      "pali": "Tamanugacchiṁ;"
    },
    {
      "id": "sn12.65:8.10",
      "pali": "tamanugacchanto jātiṁ abbhaññāsiṁ …pe…"
    },
    {
      "id": "sn12.65:8.11",
      "pali": "bhavaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.12",
      "pali": "upādānaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.13",
      "pali": "taṇhaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.14",
      "pali": "vedanaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.15",
      "pali": "phassaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.16",
      "pali": "saḷāyatanaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.17",
      "pali": "nāmarūpaṁ abbhaññāsiṁ …"
    },
    {
      "id": "sn12.65:8.18",
      "pali": "viññāṇaṁ abbhaññāsiṁ."
    },
    {
      "id": "sn12.65:8.19",
      "pali": "Tamanugacchiṁ;"
    },
    {
      "id": "sn12.65:8.20",
      "pali": "tamanugacchanto saṅkhāre abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.21",
      "pali": "saṅkhārasamudayaṁ abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.22",
      "pali": "saṅkhāranirodhaṁ abbhaññāsiṁ;"
    },
    {
      "id": "sn12.65:8.23",
      "pali": "saṅkhāranirodhagāminiṁ paṭipadaṁ abbhaññāsiṁ."
    },
    {
      "id": "sn12.65:8.24",
      "pali": "Tadabhiññāya ācikkhiṁ bhikkhūnaṁ bhikkhunīnaṁ upāsakānaṁ upāsikānaṁ."
    },
    {
      "id": "sn12.65:8.25",
      "pali": "Tayidaṁ, bhikkhave, brahmacariyaṁ iddhañceva phītañca vitthārikaṁ bāhujaññaṁ puthubhūtaṁ yāva devamanussehi suppakāsitan”ti."
    },
    {
      "id": "sn12.65:8.26",
      "pali": "Pañcamaṁ."
    }
  ]
}
