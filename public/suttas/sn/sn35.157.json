{
  "uid": "sn35.157",
  "title": "Bāhiranandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.157:1.1",
      "pali": "“Anicceyeva, bhikkhave, bhikkhu rūpe aniccāti passati, sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn35.157:1.2",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn35.157:1.3",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.157:1.4",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.157:1.5",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn35.157:1.6",
      "pali": "Anicceyeva, bhikkhave, bhikkhu sadde …"
    },
    {
      "id": "sn35.157:1.7",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.157:1.8",
      "pali": "rase …"
    },
    {
      "id": "sn35.157:1.9",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.157:1.10",
      "pali": "dhamme aniccāti passati, sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn35.157:1.11",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn35.157:1.12",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.157:1.13",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.157:1.14",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn35.157:1.15",
      "pali": "Dutiyaṁ."
    }
  ]
}
