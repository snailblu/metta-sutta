{
  "uid": "sn45.34",
  "title": "Pāraṅgamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.34:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.34:1.2",
      "pali": "“Aṭṭhime, bhikkhave, dhammā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattanti."
    },
    {
      "id": "sn45.34:1.3",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "sn45.34:1.4",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.34:1.5",
      "pali": "Ime kho, bhikkhave, aṭṭha dhammā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattantī”ti."
    },
    {
      "id": "sn45.34:2.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn45.34:2.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn45.34:3.1",
      "pali": "“Appakā te manussesu,"
    },
    {
      "id": "sn45.34:3.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "sn45.34:3.3",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "sn45.34:3.4",
      "pali": "tīramevānudhāvati."
    },
    {
      "id": "sn45.34:4.1",
      "pali": "Ye ca kho sammadakkhāte,"
    },
    {
      "id": "sn45.34:4.2",
      "pali": "dhamme dhammānuvattino;"
    },
    {
      "id": "sn45.34:4.3",
      "pali": "Te janā pāramessanti,"
    },
    {
      "id": "sn45.34:4.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "sn45.34:5.1",
      "pali": "Kaṇhaṁ dhammaṁ vippahāya,"
    },
    {
      "id": "sn45.34:5.2",
      "pali": "sukkaṁ bhāvetha paṇḍito;"
    },
    {
      "id": "sn45.34:5.3",
      "pali": "Okā anokamāgamma,"
    },
    {
      "id": "sn45.34:5.4",
      "pali": "viveke yattha dūramaṁ."
    },
    {
      "id": "sn45.34:6.1",
      "pali": "Tatrābhiratimiccheyya,"
    },
    {
      "id": "sn45.34:6.2",
      "pali": "hitvā kāme akiñcano;"
    },
    {
      "id": "sn45.34:6.3",
      "pali": "Pariyodapeyya attānaṁ,"
    },
    {
      "id": "sn45.34:6.4",
      "pali": "cittaklesehi paṇḍito."
    },
    {
      "id": "sn45.34:7.1",
      "pali": "Yesaṁ sambodhiyaṅgesu,"
    },
    {
      "id": "sn45.34:7.2",
      "pali": "sammā cittaṁ subhāvitaṁ;"
    },
    {
      "id": "sn45.34:7.3",
      "pali": "Ādānapaṭinissagge,"
    },
    {
      "id": "sn45.34:7.4",
      "pali": "anupādāya ye ratā;"
    },
    {
      "id": "sn45.34:7.5",
      "pali": "Khīṇāsavā jutimanto,"
    },
    {
      "id": "sn45.34:7.6",
      "pali": "te loke parinibbutā”ti."
    },
    {
      "id": "sn45.34:7.7",
      "pali": "Catutthaṁ."
    }
  ]
}
