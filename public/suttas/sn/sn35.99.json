{
  "uid": "sn35.99",
  "title": "Samādhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.99:1.1",
      "pali": "“Samādhiṁ, bhikkhave, bhāvetha."
    },
    {
      "id": "sn35.99:1.2",
      "pali": "Samāhito, bhikkhave, bhikkhu yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.99:1.3",
      "pali": "Kiñca yathābhūtaṁ pajānāti?"
    },
    {
      "id": "sn35.99:1.4",
      "pali": "‘Cakkhu aniccan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.99:1.5",
      "pali": "‘rūpā aniccā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.99:1.6",
      "pali": "‘cakkhuviññāṇaṁ aniccan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.99:1.7",
      "pali": "‘cakkhusamphasso anicco’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.99:1.8",
      "pali": "‘Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti …pe…"
    },
    {
      "id": "sn35.99:1.9",
      "pali": "‘mano aniccan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.99:1.10",
      "pali": "Dhammā …"
    },
    {
      "id": "sn35.99:1.11",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.99:1.12",
      "pali": "manosamphasso …"
    },
    {
      "id": "sn35.99:1.13",
      "pali": "‘yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.99:1.14",
      "pali": "Samādhiṁ, bhikkhave, bhāvetha."
    },
    {
      "id": "sn35.99:1.15",
      "pali": "Samāhito, bhikkhave, bhikkhu yathābhūtaṁ pajānātī”ti."
    },
    {
      "id": "sn35.99:1.16",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
