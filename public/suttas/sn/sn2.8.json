{
  "uid": "sn2.8",
  "title": "Tāyanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.8:1.2",
      "pali": "Atha kho tāyano devaputto purāṇatitthakaro abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.8:1.3",
      "pali": "Ekamantaṁ ṭhito kho tāyano devaputto bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.8:2.1",
      "pali": "“Chinda sotaṁ parakkamma,"
    },
    {
      "id": "sn2.8:2.2",
      "pali": "kāme panuda brāhmaṇa;"
    },
    {
      "id": "sn2.8:2.3",
      "pali": "Nappahāya munī kāme,"
    },
    {
      "id": "sn2.8:2.4",
      "pali": "nekattamupapajjati."
    },
    {
      "id": "sn2.8:3.1",
      "pali": "Kayirā ce kayirāthenaṁ,"
    },
    {
      "id": "sn2.8:3.2",
      "pali": "daḷhamenaṁ parakkame;"
    },
    {
      "id": "sn2.8:3.3",
      "pali": "Sithilo hi paribbājo,"
    },
    {
      "id": "sn2.8:3.4",
      "pali": "bhiyyo ākirate rajaṁ."
    },
    {
      "id": "sn2.8:4.1",
      "pali": "Akataṁ dukkaṭaṁ seyyo,"
    },
    {
      "id": "sn2.8:4.2",
      "pali": "pacchā tapati dukkaṭaṁ;"
    },
    {
      "id": "sn2.8:4.3",
      "pali": "Katañca sukataṁ seyyo,"
    },
    {
      "id": "sn2.8:4.4",
      "pali": "yaṁ katvā nānutappati."
    },
    {
      "id": "sn2.8:5.1",
      "pali": "Kuso yathā duggahito,"
    },
    {
      "id": "sn2.8:5.2",
      "pali": "hatthamevānukantati;"
    },
    {
      "id": "sn2.8:5.3",
      "pali": "Sāmaññaṁ dupparāmaṭṭhaṁ,"
    },
    {
      "id": "sn2.8:5.4",
      "pali": "nirayāyūpakaḍḍhati."
    },
    {
      "id": "sn2.8:6.1",
      "pali": "Yaṁ kiñci sithilaṁ kammaṁ,"
    },
    {
      "id": "sn2.8:6.2",
      "pali": "saṅkiliṭṭhañca yaṁ vataṁ;"
    },
    {
      "id": "sn2.8:6.3",
      "pali": "Saṅkassaraṁ brahmacariyaṁ,"
    },
    {
      "id": "sn2.8:6.4",
      "pali": "na taṁ hoti mahapphalan”ti."
    },
    {
      "id": "sn2.8:7.1",
      "pali": "Idamavoca tāyano devaputto;"
    },
    {
      "id": "sn2.8:7.2",
      "pali": "idaṁ vatvā bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyīti."
    },
    {
      "id": "sn2.8:8.1",
      "pali": "Atha kho bhagavā tassā rattiyā accayena bhikkhū āmantesi:"
    },
    {
      "id": "sn2.8:8.2",
      "pali": "“imaṁ, bhikkhave, rattiṁ tāyano nāma devaputto purāṇatitthakaro abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yenāhaṁ tenupasaṅkami; upasaṅkamitvā maṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.8:8.3",
      "pali": "Ekamantaṁ ṭhito kho, bhikkhave, tāyano devaputto mama santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.8:9.1",
      "pali": "‘Chinda sotaṁ parakkamma,"
    },
    {
      "id": "sn2.8:9.2",
      "pali": "kāme panuda brāhmaṇa;"
    },
    {
      "id": "sn2.8:9.3",
      "pali": "Nappahāya munī kāme,"
    },
    {
      "id": "sn2.8:9.4",
      "pali": "nekattamupapajjati."
    },
    {
      "id": "sn2.8:10.1",
      "pali": "Kayirā ce kayirāthenaṁ,"
    },
    {
      "id": "sn2.8:10.2",
      "pali": "daḷhamenaṁ parakkame;"
    },
    {
      "id": "sn2.8:10.3",
      "pali": "Sithilo hi paribbājo,"
    },
    {
      "id": "sn2.8:10.4",
      "pali": "bhiyyo ākirate rajaṁ."
    },
    {
      "id": "sn2.8:11.1",
      "pali": "Akataṁ dukkaṭaṁ seyyo,"
    },
    {
      "id": "sn2.8:11.2",
      "pali": "pacchā tapati dukkaṭaṁ;"
    },
    {
      "id": "sn2.8:11.3",
      "pali": "Katañca sukataṁ seyyo,"
    },
    {
      "id": "sn2.8:11.4",
      "pali": "yaṁ katvā nānutappati."
    },
    {
      "id": "sn2.8:12.1",
      "pali": "Kuso yathā duggahito,"
    },
    {
      "id": "sn2.8:12.2",
      "pali": "hatthamevānukantati;"
    },
    {
      "id": "sn2.8:12.3",
      "pali": "Sāmaññaṁ dupparāmaṭṭhaṁ,"
    },
    {
      "id": "sn2.8:12.4",
      "pali": "nirayāyūpakaḍḍhati."
    },
    {
      "id": "sn2.8:13.1",
      "pali": "Yaṁ kiñci sithilaṁ kammaṁ,"
    },
    {
      "id": "sn2.8:13.2",
      "pali": "saṅkiliṭṭhañca yaṁ vataṁ;"
    },
    {
      "id": "sn2.8:13.3",
      "pali": "Saṅkassaraṁ brahmacariyaṁ,"
    },
    {
      "id": "sn2.8:13.4",
      "pali": "na taṁ hoti mahapphalan’ti."
    },
    {
      "id": "sn2.8:14.1",
      "pali": "Idamavoca, bhikkhave, tāyano devaputto, idaṁ vatvā maṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyi."
    },
    {
      "id": "sn2.8:14.2",
      "pali": "Uggaṇhātha, bhikkhave, tāyanagāthā;"
    },
    {
      "id": "sn2.8:14.3",
      "pali": "pariyāpuṇātha, bhikkhave, tāyanagāthā;"
    },
    {
      "id": "sn2.8:14.4",
      "pali": "dhāretha, bhikkhave, tāyanagāthā."
    },
    {
      "id": "sn2.8:14.5",
      "pali": "Atthasaṁhitā, bhikkhave, tāyanagāthā ādibrahmacariyikā”ti."
    }
  ]
}
