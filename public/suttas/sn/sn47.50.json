{
  "uid": "sn47.50",
  "title": "Āsavasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.50:1.1",
      "pali": "“Tayome, bhikkhave āsavā."
    },
    {
      "id": "sn47.50:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "sn47.50:1.3",
      "pali": "Kāmāsavo, bhavāsavo, avijjāsavo—"
    },
    {
      "id": "sn47.50:1.4",
      "pali": "ime kho, bhikkhave, tayo āsavā."
    },
    {
      "id": "sn47.50:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ āsavānaṁ pahānāya cattāro satipaṭṭhānā bhāvetabbā."
    },
    {
      "id": "sn47.50:2.1",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn47.50:2.2",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.50:2.3",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.50:2.4",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.50:2.5",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.50:2.6",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ āsavānaṁ pahānāya ime cattāro satipaṭṭhānā bhāvetabbā”ti."
    },
    {
      "id": "sn47.50:2.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn47.50:2.8",
      "pali": "Amatavaggo pañcamo."
    },
    {
      "id": "sn47.50:3.1",
      "pali": "Amataṁ samudayo maggo,"
    },
    {
      "id": "sn47.50:3.2",
      "pali": "Sati kusalarāsi ca;"
    },
    {
      "id": "sn47.50:3.3",
      "pali": "Pātimokkhaṁ duccaritaṁ,"
    },
    {
      "id": "sn47.50:3.4",
      "pali": "Mittavedanā āsavena cāti."
    }
  ]
}
