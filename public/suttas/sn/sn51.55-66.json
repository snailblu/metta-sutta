{
  "uid": "sn51.55-66",
  "title": "Balakaraṇīyavagga",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.55-66:1.1",
      "pali": "(Balakaraṇīyavaggo vitthāretabbo.)"
    },
    {
      "id": "sn51.55-66:2.1",
      "pali": "Balaṁ bījañca nāgo ca,"
    },
    {
      "id": "sn51.55-66:2.2",
      "pali": "rukkho kumbhena sūkiyā;"
    },
    {
      "id": "sn51.55-66:2.3",
      "pali": "Ākāsena ca dve meghā,"
    },
    {
      "id": "sn51.55-66:2.4",
      "pali": "nāvā āgantukā nadīti."
    }
  ]
}
