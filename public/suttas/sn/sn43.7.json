{
  "uid": "sn43.7",
  "title": "Iddhipādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.7:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.7:1.2",
      "pali": "Cattāro iddhipādā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.7:1.3",
      "pali": "Sattamaṁ."
    }
  ]
}
