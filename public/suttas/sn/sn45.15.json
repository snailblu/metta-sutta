{
  "uid": "sn45.15",
  "title": "Dutiyauppādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.15:1.2",
      "pali": "“Aṭṭhime, bhikkhave, dhammā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā."
    },
    {
      "id": "sn45.15:1.3",
      "pali": "Katame aṭṭha?"
    },
    {
      "id": "sn45.15:1.4",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.15:1.5",
      "pali": "Ime kho, bhikkhave, aṭṭha dhammā bhāvitā bahulīkatā anuppannā uppajjanti, nāññatra sugatavinayā”ti."
    },
    {
      "id": "sn45.15:1.6",
      "pali": "Pañcamaṁ."
    }
  ]
}
