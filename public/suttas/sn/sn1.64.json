{
  "uid": "sn1.64",
  "title": "Saṁyojanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.64:1.1",
      "pali": "“Kiṁsu saṁyojano loko,"
    },
    {
      "id": "sn1.64:1.2",
      "pali": "kiṁsu tassa vicāraṇaṁ;"
    },
    {
      "id": "sn1.64:1.3",
      "pali": "Kissassu vippahānena,"
    },
    {
      "id": "sn1.64:1.4",
      "pali": "nibbānaṁ iti vuccatī”ti."
    },
    {
      "id": "sn1.64:2.1",
      "pali": "“Nandīsaṁyojano loko,"
    },
    {
      "id": "sn1.64:2.2",
      "pali": "vitakkassa vicāraṇaṁ;"
    },
    {
      "id": "sn1.64:2.3",
      "pali": "Taṇhāya vippahānena,"
    },
    {
      "id": "sn1.64:2.4",
      "pali": "nibbānaṁ iti vuccatī”ti."
    }
  ]
}
