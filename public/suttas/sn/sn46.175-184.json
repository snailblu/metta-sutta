{
  "uid": "sn46.175-184",
  "title": "Punaoghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.175-184:1.1",
      "pali": "…pe…"
    },
    {
      "id": "sn46.175-184:1.2",
      "pali": "Bojjhaṅgasaṁyuttassa punaoghavaggo aṭṭhārasamo."
    },
    {
      "id": "sn46.175-184:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn46.175-184:2.2",
      "pali": "Ganthā anusayena ca;"
    },
    {
      "id": "sn46.175-184:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn46.175-184:2.4",
      "pali": "Khandhā oruddhambhāgiyānīti."
    },
    {
      "id": "sn46.175-184:3.1",
      "pali": "(Rāgavinayapariyosāna-dosavinayapariyosāna-mohavinayapariyosānavaggo vitthāretabbo.)"
    },
    {
      "id": "sn46.175-184:3.2",
      "pali": "(Yadapi maggasaṁyuttaṁ vitthāretabbaṁ, tadapi bojjhaṅgasaṁyuttaṁ vitthāretabbaṁ.)"
    },
    {
      "id": "sn46.175-184:3.3",
      "pali": "Bojjhaṅgasaṁyuttaṁ dutiyaṁ."
    }
  ]
}
