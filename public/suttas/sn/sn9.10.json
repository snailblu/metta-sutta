{
  "uid": "sn9.10",
  "title": "Sajjhāyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.10:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.10:1.2",
      "pali": "Tena kho pana samayena so bhikkhu yaṁ sudaṁ pubbe ativelaṁ sajjhāyabahulo viharati so aparena samayena appossukko tuṇhībhūto saṅkasāyati."
    },
    {
      "id": "sn9.10:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno dhammaṁ asuṇantī yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn9.10:2.1",
      "pali": "“Kasmā tuvaṁ dhammapadāni bhikkhu,"
    },
    {
      "id": "sn9.10:2.2",
      "pali": "Nādhīyasi bhikkhuhi saṁvasanto;"
    },
    {
      "id": "sn9.10:2.3",
      "pali": "Sutvāna dhammaṁ labhatippasādaṁ,"
    },
    {
      "id": "sn9.10:2.4",
      "pali": "Diṭṭheva dhamme labhatippasaṁsan”ti."
    },
    {
      "id": "sn9.10:3.1",
      "pali": "“Ahu pure dhammapadesu chando,"
    },
    {
      "id": "sn9.10:3.2",
      "pali": "Yāva virāgena samāgamimha;"
    },
    {
      "id": "sn9.10:3.3",
      "pali": "Yato virāgena samāgamimha,"
    },
    {
      "id": "sn9.10:3.4",
      "pali": "Yaṁ kiñci diṭṭhaṁva sutaṁ mutaṁ vā;"
    },
    {
      "id": "sn9.10:3.5",
      "pali": "Aññāya nikkhepanamāhu santo”ti."
    }
  ]
}
