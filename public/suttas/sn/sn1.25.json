{
  "uid": "sn1.25",
  "title": "Arahantasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.25:1.1",
      "pali": "“Yo hoti bhikkhu arahaṁ katāvī,"
    },
    {
      "id": "sn1.25:1.2",
      "pali": "Khīṇāsavo antimadehadhārī;"
    },
    {
      "id": "sn1.25:1.3",
      "pali": "Ahaṁ vadāmītipi so vadeyya,"
    },
    {
      "id": "sn1.25:1.4",
      "pali": "Mamaṁ vadantītipi so vadeyyā”ti."
    },
    {
      "id": "sn1.25:2.1",
      "pali": "“Yo hoti bhikkhu arahaṁ katāvī,"
    },
    {
      "id": "sn1.25:2.2",
      "pali": "Khīṇāsavo antimadehadhārī;"
    },
    {
      "id": "sn1.25:2.3",
      "pali": "Ahaṁ vadāmītipi so vadeyya,"
    },
    {
      "id": "sn1.25:2.4",
      "pali": "Mamaṁ vadantītipi so vadeyya;"
    },
    {
      "id": "sn1.25:2.5",
      "pali": "Loke samaññaṁ kusalo viditvā,"
    },
    {
      "id": "sn1.25:2.6",
      "pali": "Vohāramattena so vohareyyā”ti."
    },
    {
      "id": "sn1.25:3.1",
      "pali": "“Yo hoti bhikkhu arahaṁ katāvī,"
    },
    {
      "id": "sn1.25:3.2",
      "pali": "Khīṇāsavo antimadehadhārī;"
    },
    {
      "id": "sn1.25:3.3",
      "pali": "Mānaṁ nu kho so upagamma bhikkhu,"
    },
    {
      "id": "sn1.25:3.4",
      "pali": "Ahaṁ vadāmītipi so vadeyya;"
    },
    {
      "id": "sn1.25:3.5",
      "pali": "Mamaṁ vadantītipi so vadeyyā”ti."
    },
    {
      "id": "sn1.25:4.1",
      "pali": "“Pahīnamānassa na santi ganthā,"
    },
    {
      "id": "sn1.25:4.2",
      "pali": "Vidhūpitā mānaganthassa sabbe;"
    },
    {
      "id": "sn1.25:4.3",
      "pali": "Sa vītivatto maññataṁ sumedho,"
    },
    {
      "id": "sn1.25:4.4",
      "pali": "Ahaṁ vadāmītipi so vadeyya."
    },
    {
      "id": "sn1.25:5.1",
      "pali": "Mamaṁ vadantītipi so vadeyya,"
    },
    {
      "id": "sn1.25:5.2",
      "pali": "Loke samaññaṁ kusalo viditvā;"
    },
    {
      "id": "sn1.25:5.3",
      "pali": "Vohāramattena so vohareyyā”ti."
    }
  ]
}
