{
  "uid": "sn22.137",
  "title": "Aniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.137:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.137:1.2",
      "pali": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.137:1.3",
      "pali": "Kiñca, bhikkhave, aniccaṁ?"
    },
    {
      "id": "sn22.137:1.4",
      "pali": "Rūpaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.137:1.5",
      "pali": "Vedanā aniccā …pe…"
    },
    {
      "id": "sn22.137:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn22.137:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.137:1.8",
      "pali": "viññāṇaṁ aniccaṁ; tatra vo chando pahātabbo."
    },
    {
      "id": "sn22.137:1.9",
      "pali": "Yaṁ, bhikkhave, aniccaṁ; tatra vo chando pahātabbo”ti."
    },
    {
      "id": "sn22.137:1.10",
      "pali": "Dutiyaṁ."
    }
  ]
}
