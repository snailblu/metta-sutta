{
  "uid": "sn45.18",
  "title": "Paṭhamakukkuṭārāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.18:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn45.18:1.2",
      "pali": "ekaṁ samayaṁ āyasmā ca ānando āyasmā ca bhaddo pāṭaliputte viharanti kukkuṭārāme."
    },
    {
      "id": "sn45.18:1.3",
      "pali": "Atha kho āyasmā bhaddo sāyanhasamayaṁ paṭisallānā vuṭṭhito yenāyasmā ānando tenupasaṅkami; upasaṅkamitvā āyasmatā ānandena saddhiṁ sammodi."
    },
    {
      "id": "sn45.18:1.4",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā bhaddo āyasmantaṁ ānandaṁ etadavoca:"
    },
    {
      "id": "sn45.18:2.1",
      "pali": "“‘Abrahmacariyaṁ, abrahmacariyan’ti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.18:2.2",
      "pali": "Katamaṁ nu kho, āvuso, abrahmacariyan”ti?"
    },
    {
      "id": "sn45.18:2.3",
      "pali": "“Sādhu sādhu, āvuso bhadda."
    },
    {
      "id": "sn45.18:2.4",
      "pali": "Bhaddako kho te, āvuso bhadda, ummaṅgo, bhaddakaṁ paṭibhānaṁ, kalyāṇī paripucchā."
    },
    {
      "id": "sn45.18:2.5",
      "pali": "Evañhi tvaṁ, āvuso bhadda, pucchasi:"
    },
    {
      "id": "sn45.18:2.6",
      "pali": "‘abrahmacariyaṁ, abrahmacariyanti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.18:2.7",
      "pali": "Katamaṁ nu kho, āvuso, abrahmacariyan’”ti?"
    },
    {
      "id": "sn45.18:2.8",
      "pali": "“Evamāvuso”ti."
    },
    {
      "id": "sn45.18:2.9",
      "pali": "“Ayameva kho, āvuso, aṭṭhaṅgiko micchāmaggo abrahmacariyaṁ, seyyathidaṁ—"
    },
    {
      "id": "sn45.18:2.10",
      "pali": "micchādiṭṭhi …pe… micchāsamādhī”ti."
    },
    {
      "id": "sn45.18:2.11",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
