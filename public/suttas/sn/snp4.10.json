{
  "uid": "snp4.10",
  "title": "Purābhedasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.10:1.1",
      "pali": "“Kathaṁdassī kathaṁsīlo,"
    },
    {
      "id": "snp4.10:1.2",
      "pali": "upasantoti vuccati;"
    },
    {
      "id": "snp4.10:1.3",
      "pali": "Taṁ me gotama pabrūhi,"
    },
    {
      "id": "snp4.10:1.4",
      "pali": "pucchito uttamaṁ naraṁ”."
    },
    {
      "id": "snp4.10:2.1",
      "pali": "“Vītataṇho purā bhedā,"
    },
    {
      "id": "snp4.10:2.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp4.10:2.3",
      "pali": "Pubbamantamanissito;"
    },
    {
      "id": "snp4.10:2.4",
      "pali": "Vemajjhe nupasaṅkheyyo,"
    },
    {
      "id": "snp4.10:2.5",
      "pali": "Tassa natthi purakkhataṁ."
    },
    {
      "id": "snp4.10:3.1",
      "pali": "Akkodhano asantāsī,"
    },
    {
      "id": "snp4.10:3.2",
      "pali": "avikatthī akukkuco;"
    },
    {
      "id": "snp4.10:3.3",
      "pali": "Mantabhāṇī anuddhato,"
    },
    {
      "id": "snp4.10:3.4",
      "pali": "sa ve vācāyato muni."
    },
    {
      "id": "snp4.10:4.1",
      "pali": "Nirāsatti anāgate,"
    },
    {
      "id": "snp4.10:4.2",
      "pali": "atītaṁ nānusocati;"
    },
    {
      "id": "snp4.10:4.3",
      "pali": "Vivekadassī phassesu,"
    },
    {
      "id": "snp4.10:4.4",
      "pali": "diṭṭhīsu ca na nīyati."
    },
    {
      "id": "snp4.10:5.1",
      "pali": "Patilīno akuhako,"
    },
    {
      "id": "snp4.10:5.2",
      "pali": "apihālu amaccharī;"
    },
    {
      "id": "snp4.10:5.3",
      "pali": "Appagabbho ajeguccho,"
    },
    {
      "id": "snp4.10:5.4",
      "pali": "pesuṇeyye ca no yuto."
    },
    {
      "id": "snp4.10:6.1",
      "pali": "Sātiyesu anassāvī,"
    },
    {
      "id": "snp4.10:6.2",
      "pali": "atimāne ca no yuto;"
    },
    {
      "id": "snp4.10:6.3",
      "pali": "Saṇho ca paṭibhānavā,"
    },
    {
      "id": "snp4.10:6.4",
      "pali": "na saddho na virajjati."
    },
    {
      "id": "snp4.10:7.1",
      "pali": "Lābhakamyā na sikkhati,"
    },
    {
      "id": "snp4.10:7.2",
      "pali": "alābhe ca na kuppati;"
    },
    {
      "id": "snp4.10:7.3",
      "pali": "Aviruddho ca taṇhāya,"
    },
    {
      "id": "snp4.10:7.4",
      "pali": "rasesu nānugijjhati."
    },
    {
      "id": "snp4.10:8.1",
      "pali": "Upekkhako sadā sato,"
    },
    {
      "id": "snp4.10:8.2",
      "pali": "na loke maññate samaṁ;"
    },
    {
      "id": "snp4.10:8.3",
      "pali": "Na visesī na nīceyyo,"
    },
    {
      "id": "snp4.10:8.4",
      "pali": "tassa no santi ussadā."
    },
    {
      "id": "snp4.10:9.1",
      "pali": "Yassa nissayanā natthi,"
    },
    {
      "id": "snp4.10:9.2",
      "pali": "ñatvā dhammaṁ anissito;"
    },
    {
      "id": "snp4.10:9.3",
      "pali": "Bhavāya vibhavāya vā,"
    },
    {
      "id": "snp4.10:9.4",
      "pali": "taṇhā yassa na vijjati."
    },
    {
      "id": "snp4.10:10.1",
      "pali": "Taṁ brūmi upasantoti,"
    },
    {
      "id": "snp4.10:10.2",
      "pali": "Kāmesu anapekkhinaṁ;"
    },
    {
      "id": "snp4.10:10.3",
      "pali": "Ganthā tassa na vijjanti,"
    },
    {
      "id": "snp4.10:10.4",
      "pali": "Atarī so visattikaṁ."
    },
    {
      "id": "snp4.10:11.1",
      "pali": "Na tassa puttā pasavo,"
    },
    {
      "id": "snp4.10:11.2",
      "pali": "Khettaṁ vatthuñca vijjati;"
    },
    {
      "id": "snp4.10:11.3",
      "pali": "Attā vāpi nirattā vā,"
    },
    {
      "id": "snp4.10:11.4",
      "pali": "Na tasmiṁ upalabbhati."
    },
    {
      "id": "snp4.10:12.1",
      "pali": "Yena naṁ vajjuṁ puthujjanā,"
    },
    {
      "id": "snp4.10:12.2",
      "pali": "Atho samaṇabrāhmaṇā;"
    },
    {
      "id": "snp4.10:12.3",
      "pali": "Taṁ tassa apurakkhataṁ,"
    },
    {
      "id": "snp4.10:12.4",
      "pali": "Tasmā vādesu nejati."
    },
    {
      "id": "snp4.10:13.1",
      "pali": "Vītagedho amaccharī,"
    },
    {
      "id": "snp4.10:13.2",
      "pali": "Na ussesu vadate muni;"
    },
    {
      "id": "snp4.10:13.3",
      "pali": "Na samesu na omesu,"
    },
    {
      "id": "snp4.10:13.4",
      "pali": "Kappaṁ neti akappiyo."
    },
    {
      "id": "snp4.10:14.1",
      "pali": "Yassa loke sakaṁ natthi,"
    },
    {
      "id": "snp4.10:14.2",
      "pali": "Asatā ca na socati;"
    },
    {
      "id": "snp4.10:14.3",
      "pali": "Dhammesu ca na gacchati,"
    },
    {
      "id": "snp4.10:14.4",
      "pali": "Sa ve santoti vuccatī”ti."
    },
    {
      "id": "snp4.10:14.5",
      "pali": "Purābhedasuttaṁ dasamaṁ."
    }
  ]
}
