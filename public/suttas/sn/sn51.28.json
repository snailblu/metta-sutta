{
  "uid": "sn51.28",
  "title": "Dutiyaānandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.28:1.1",
      "pali": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ ānandaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn51.28:1.2",
      "pali": "“katamā nu kho, ānanda, iddhi, katamo iddhipādo, katamā iddhipādabhāvanā, katamā iddhipādabhāvanāgāminī paṭipadā”ti?"
    },
    {
      "id": "sn51.28:1.3",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā bhagavaṁnettikā …pe…."
    },
    {
      "id": "sn51.28:2.1",
      "pali": "“Idhānanda, bhikkhu anekavihitaṁ iddhividhaṁ paccanubhoti—ekopi hutvā bahudhā hoti …pe… yāva brahmalokāpi kāyena vasaṁ vatteti—"
    },
    {
      "id": "sn51.28:2.2",
      "pali": "ayaṁ vuccatānanda, iddhi."
    },
    {
      "id": "sn51.28:3.1",
      "pali": "Katamo cānanda, iddhipādo?"
    },
    {
      "id": "sn51.28:3.2",
      "pali": "Yo, ānanda, maggo yā paṭipadā iddhilābhāya iddhipaṭilābhāya saṁvattati—"
    },
    {
      "id": "sn51.28:3.3",
      "pali": "ayaṁ vuccatānanda, iddhipādo."
    },
    {
      "id": "sn51.28:4.1",
      "pali": "Katamā cānanda, iddhipādabhāvanā?"
    },
    {
      "id": "sn51.28:4.2",
      "pali": "Idhānanda, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.28:4.3",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.28:4.4",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.28:4.5",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.28:4.6",
      "pali": "ayaṁ vuccatānanda, iddhipādabhāvanā."
    },
    {
      "id": "sn51.28:5.1",
      "pali": "Katamā cānanda, iddhipādabhāvanāgāminī paṭipadā?"
    },
    {
      "id": "sn51.28:5.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn51.28:5.3",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi—"
    },
    {
      "id": "sn51.28:5.4",
      "pali": "ayaṁ vuccatānanda, iddhipādabhāvanāgāminī paṭipadā”ti."
    },
    {
      "id": "sn51.28:5.5",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
