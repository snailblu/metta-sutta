{
  "uid": "sn19.21",
  "title": "Pāpasāmaṇerīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.21:1.1",
      "pali": "“Idhāhaṁ, āvuso, gijjhakūṭā pabbatā orohanto addasaṁ sāmaṇeriṁ vehāsaṁ gacchantiṁ."
    },
    {
      "id": "sn19.21:1.2",
      "pali": "Tassā saṅghāṭipi ādittā sampajjalitā sajotibhūtā, pattopi āditto sampajjalito sajotibhūto, kāyabandhanampi ādittaṁ sampajjalitaṁ sajotibhūtaṁ, kāyopi āditto sampajjalito sajotibhūto."
    },
    {
      "id": "sn19.21:1.3",
      "pali": "Sā sudaṁ aṭṭassaraṁ karoti."
    },
    {
      "id": "sn19.21:1.4",
      "pali": "Tassa mayhaṁ, āvuso, etadahosi:"
    },
    {
      "id": "sn19.21:1.5",
      "pali": "‘acchariyaṁ vata bho, abbhutaṁ vata bho."
    },
    {
      "id": "sn19.21:1.6",
      "pali": "Evarūpopi nāma satto bhavissati."
    },
    {
      "id": "sn19.21:1.7",
      "pali": "Evarūpopi nāma yakkho bhavissati."
    },
    {
      "id": "sn19.21:1.8",
      "pali": "Evarūpopi nāma attabhāvapaṭilābho bhavissatī’”ti."
    },
    {
      "id": "sn19.21:2.1",
      "pali": "Atha kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn19.21:2.2",
      "pali": "“cakkhubhūtā vata, bhikkhave, sāvakā viharanti;"
    },
    {
      "id": "sn19.21:2.3",
      "pali": "ñāṇabhūtā vata, bhikkhave, sāvakā viharanti, yatra hi nāma sāvako evarūpaṁ ñassati vā dakkhati vā sakkhiṁ vā karissati."
    },
    {
      "id": "sn19.21:2.4",
      "pali": "Pubbeva me sā, bhikkhave, sāmaṇerī diṭṭhā ahosi."
    },
    {
      "id": "sn19.21:2.5",
      "pali": "Api cāhaṁ na byākāsiṁ."
    },
    {
      "id": "sn19.21:2.6",
      "pali": "Ahañcetaṁ byākareyyaṁ, pare ca me na saddaheyyuṁ."
    },
    {
      "id": "sn19.21:2.7",
      "pali": "Ye me na saddaheyyuṁ, tesaṁ taṁ assa dīgharattaṁ ahitāya dukkhāya."
    },
    {
      "id": "sn19.21:2.8",
      "pali": "Esā, bhikkhave, sāmaṇerī kassapassa sammāsambuddhassa pāvacane pāpasāmaṇerī ahosi."
    },
    {
      "id": "sn19.21:2.9",
      "pali": "Sā tassa kammassa vipākena bahūni vassāni bahūni vassasatāni bahūni vassasahassāni bahūni vassasatasahassāni niraye paccitvā tasseva kammassa vipākāvasesena evarūpaṁ attabhāvapaṭilābhaṁ paṭisaṁvedayatī”ti."
    },
    {
      "id": "sn19.21:2.10",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn19.21:2.11",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn19.21:3.1",
      "pali": "Kūpe nimuggo hi so pāradāriko,"
    },
    {
      "id": "sn19.21:3.2",
      "pali": "Gūthakhādi ahu duṭṭhabrāhmaṇo;"
    },
    {
      "id": "sn19.21:3.3",
      "pali": "Nicchavitthi aticārinī ahu,"
    },
    {
      "id": "sn19.21:3.4",
      "pali": "Maṅgulitthi ahu ikkhaṇitthikā;"
    },
    {
      "id": "sn19.21:3.5",
      "pali": "Okilini sapattaṅgārokiri,"
    },
    {
      "id": "sn19.21:3.6",
      "pali": "Sīsacchinno ahu coraghātako."
    },
    {
      "id": "sn19.21:4.1",
      "pali": "Bhikkhu bhikkhunī sikkhamānā,"
    },
    {
      "id": "sn19.21:4.2",
      "pali": "Sāmaṇero atha sāmaṇerikā;"
    },
    {
      "id": "sn19.21:4.3",
      "pali": "Kassapassa vinayasmiṁ pabbajjaṁ,"
    },
    {
      "id": "sn19.21:4.4",
      "pali": "Pāpakammaṁ kariṁsu tāvadeti."
    },
    {
      "id": "sn19.21:4.5",
      "pali": "Lakkhaṇasaṁyuttaṁ samattaṁ."
    }
  ]
}
