{
  "uid": "sn1.69",
  "title": "Icchāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.69:1.1",
      "pali": "“Kenassu bajjhatī loko,"
    },
    {
      "id": "sn1.69:1.2",
      "pali": "kissa vinayāya muccati;"
    },
    {
      "id": "sn1.69:1.3",
      "pali": "Kissassu vippahānena,"
    },
    {
      "id": "sn1.69:1.4",
      "pali": "sabbaṁ chindati bandhanan”ti."
    },
    {
      "id": "sn1.69:2.1",
      "pali": "“Icchāya bajjhatī loko,"
    },
    {
      "id": "sn1.69:2.2",
      "pali": "icchāvinayāya muccati;"
    },
    {
      "id": "sn1.69:2.3",
      "pali": "Icchāya vippahānena,"
    },
    {
      "id": "sn1.69:2.4",
      "pali": "sabbaṁ chindati bandhanan”ti."
    }
  ]
}
