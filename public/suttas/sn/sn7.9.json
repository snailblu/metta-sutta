{
  "uid": "sn7.9",
  "title": "Sundarikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.9:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā kosalesu viharati sundarikāya nadiyā tīre."
    },
    {
      "id": "sn7.9:1.2",
      "pali": "Tena kho pana samayena sundarikabhāradvājo brāhmaṇo sundarikāya nadiyā tīre aggiṁ juhati, aggihuttaṁ paricarati."
    },
    {
      "id": "sn7.9:1.3",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo aggiṁ juhitvā aggihuttaṁ paricaritvā uṭṭhāyāsanā samantā catuddisā anuvilokesi:"
    },
    {
      "id": "sn7.9:1.4",
      "pali": "“ko nu kho imaṁ habyasesaṁ bhuñjeyyā”ti?"
    },
    {
      "id": "sn7.9:1.5",
      "pali": "Addasā kho sundarikabhāradvājo brāhmaṇo bhagavantaṁ aññatarasmiṁ rukkhamūle sasīsaṁ pārutaṁ nisinnaṁ."
    },
    {
      "id": "sn7.9:1.6",
      "pali": "Disvāna vāmena hatthena habyasesaṁ gahetvā dakkhiṇena hatthena kamaṇḍaluṁ gahetvā yena bhagavā tenupasaṅkami."
    },
    {
      "id": "sn7.9:1.7",
      "pali": "Atha kho bhagavā sundarikabhāradvājassa brāhmaṇassa padasaddena sīsaṁ vivari."
    },
    {
      "id": "sn7.9:1.8",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo “muṇḍo ayaṁ bhavaṁ, muṇḍako ayaṁ bhavan”ti tatova puna nivattitukāmo ahosi."
    },
    {
      "id": "sn7.9:1.9",
      "pali": "Atha kho sundarikabhāradvājassa brāhmaṇassa etadahosi:"
    },
    {
      "id": "sn7.9:1.10",
      "pali": "“muṇḍāpi hi idhekacce brāhmaṇā bhavanti;"
    },
    {
      "id": "sn7.9:1.11",
      "pali": "yannūnāhaṁ taṁ upasaṅkamitvā jātiṁ puccheyyan”ti."
    },
    {
      "id": "sn7.9:2.1",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.9:2.2",
      "pali": "“kiṁjacco bhavan”ti?"
    },
    {
      "id": "sn7.9:3.1",
      "pali": "“Mā jātiṁ puccha caraṇañca puccha,"
    },
    {
      "id": "sn7.9:3.2",
      "pali": "Kaṭṭhā have jāyati jātavedo;"
    },
    {
      "id": "sn7.9:3.3",
      "pali": "Nīcākulīnopi muni dhitimā,"
    },
    {
      "id": "sn7.9:3.4",
      "pali": "Ājānīyo hoti hirīnisedho."
    },
    {
      "id": "sn7.9:4.1",
      "pali": "Saccena danto damasā upeto,"
    },
    {
      "id": "sn7.9:4.2",
      "pali": "Vedantagū vusitabrahmacariyo;"
    },
    {
      "id": "sn7.9:4.3",
      "pali": "Yaññopanīto tamupavhayetha,"
    },
    {
      "id": "sn7.9:4.4",
      "pali": "Kālena so juhati dakkhiṇeyye”ti."
    },
    {
      "id": "sn7.9:5.1",
      "pali": "“Addhā suyiṭṭhaṁ suhutaṁ mama yidaṁ,"
    },
    {
      "id": "sn7.9:5.2",
      "pali": "Yaṁ tādisaṁ vedagumaddasāmi;"
    },
    {
      "id": "sn7.9:5.3",
      "pali": "Tumhādisānañhi adassanena,"
    },
    {
      "id": "sn7.9:5.4",
      "pali": "Añño jano bhuñjati habyasesan”ti."
    },
    {
      "id": "sn7.9:6.1",
      "pali": "“Bhuñjatu bhavaṁ gotamo."
    },
    {
      "id": "sn7.9:6.2",
      "pali": "Brāhmaṇo bhavan”ti."
    },
    {
      "id": "sn7.9:7.1",
      "pali": "“Gāthābhigītaṁ me abhojaneyyaṁ,"
    },
    {
      "id": "sn7.9:7.2",
      "pali": "Sampassataṁ brāhmaṇa nesa dhammo;"
    },
    {
      "id": "sn7.9:7.3",
      "pali": "Gāthābhigītaṁ panudanti buddhā,"
    },
    {
      "id": "sn7.9:7.4",
      "pali": "Dhamme sati brāhmaṇa vuttiresā."
    },
    {
      "id": "sn7.9:8.1",
      "pali": "Aññena ca kevalinaṁ mahesiṁ,"
    },
    {
      "id": "sn7.9:8.2",
      "pali": "Khīṇāsavaṁ kukkuccavūpasantaṁ;"
    },
    {
      "id": "sn7.9:8.3",
      "pali": "Annena pānena upaṭṭhahassu,"
    },
    {
      "id": "sn7.9:8.4",
      "pali": "Khettañhi taṁ puññapekkhassa hotī”ti."
    },
    {
      "id": "sn7.9:9.1",
      "pali": "“Atha kassa cāhaṁ, bho gotama, imaṁ habyasesaṁ dammī”ti?"
    },
    {
      "id": "sn7.9:9.2",
      "pali": "“Na khvāhaṁ, brāhmaṇa, passāmi sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya yasseso habyaseso bhutto sammā pariṇāmaṁ gaccheyya aññatra, brāhmaṇa, tathāgatassa vā tathāgatasāvakassa vā."
    },
    {
      "id": "sn7.9:9.3",
      "pali": "Tena hi tvaṁ, brāhmaṇa, taṁ habyasesaṁ appaharite vā chaḍḍehi appāṇake vā udake opilāpehī”ti."
    },
    {
      "id": "sn7.9:10.1",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo taṁ habyasesaṁ appāṇake udake opilāpesi."
    },
    {
      "id": "sn7.9:10.2",
      "pali": "Atha kho so habyaseso udake pakkhitto cicciṭāyati ciṭiciṭāyati sandhūpāyati sampadhūpāyati."
    },
    {
      "id": "sn7.9:10.3",
      "pali": "Seyyathāpi nāma phālo divasaṁsantatto udake pakkhitto cicciṭāyati ciṭiciṭāyati sandhūpāyati sampadhūpāyati;"
    },
    {
      "id": "sn7.9:10.4",
      "pali": "evameva so habyaseso udake pakkhitto cicciṭāyati ciṭiciṭāyati sandhūpāyati sampadhūpāyati."
    },
    {
      "id": "sn7.9:11.1",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo saṁviggo lomahaṭṭhajāto yena bhagavā tenupasaṅkami; upasaṅkamitvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn7.9:11.2",
      "pali": "Ekamantaṁ ṭhitaṁ kho sundarikabhāradvājaṁ brāhmaṇaṁ bhagavā gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn7.9:12.1",
      "pali": "“Mā brāhmaṇa dāru samādahāno,"
    },
    {
      "id": "sn7.9:12.2",
      "pali": "Suddhiṁ amaññi bahiddhā hi etaṁ;"
    },
    {
      "id": "sn7.9:12.3",
      "pali": "Na hi tena suddhiṁ kusalā vadanti,"
    },
    {
      "id": "sn7.9:12.4",
      "pali": "Yo bāhirena parisuddhimicche."
    },
    {
      "id": "sn7.9:13.1",
      "pali": "Hitvā ahaṁ brāhmaṇa dārudāhaṁ,"
    },
    {
      "id": "sn7.9:13.2",
      "pali": "Ajjhattamevujjalayāmi jotiṁ;"
    },
    {
      "id": "sn7.9:13.3",
      "pali": "Niccagginī niccasamāhitatto,"
    },
    {
      "id": "sn7.9:13.4",
      "pali": "Arahaṁ ahaṁ brahmacariyaṁ carāmi."
    },
    {
      "id": "sn7.9:14.1",
      "pali": "Māno hi te brāhmaṇa khāribhāro,"
    },
    {
      "id": "sn7.9:14.2",
      "pali": "Kodho dhumo bhasmani mosavajjaṁ;"
    },
    {
      "id": "sn7.9:14.3",
      "pali": "Jivhā sujā hadayaṁ jotiṭhānaṁ,"
    },
    {
      "id": "sn7.9:14.4",
      "pali": "Attā sudanto purisassa joti."
    },
    {
      "id": "sn7.9:15.1",
      "pali": "Dhammo rahado brāhmaṇa sīlatittho,"
    },
    {
      "id": "sn7.9:15.2",
      "pali": "Anāvilo sabbhi sataṁ pasattho;"
    },
    {
      "id": "sn7.9:15.3",
      "pali": "Yattha have vedaguno sinātā,"
    },
    {
      "id": "sn7.9:15.4",
      "pali": "Anallagattāva taranti pāraṁ."
    },
    {
      "id": "sn7.9:16.1",
      "pali": "Saccaṁ dhammo saṁyamo brahmacariyaṁ,"
    },
    {
      "id": "sn7.9:16.2",
      "pali": "Majjhe sitā brāhmaṇa brahmapatti;"
    },
    {
      "id": "sn7.9:16.3",
      "pali": "Sa tujjubhūtesu namo karohi,"
    },
    {
      "id": "sn7.9:16.4",
      "pali": "Tamahaṁ naraṁ dhammasārīti brūmī”ti."
    },
    {
      "id": "sn7.9:17.1",
      "pali": "Evaṁ vutte, sundarikabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.9:17.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.9:17.3",
      "pali": "aññataro ca panāyasmā bhāradvājo arahataṁ ahosīti."
    }
  ]
}
