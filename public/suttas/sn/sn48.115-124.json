{
  "uid": "sn48.115-124",
  "title": "Oghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.115-124:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn48.115-124:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.115-124:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn48.115-124:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn48.115-124:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya pañcindriyāni bhāvetabbāni."
    },
    {
      "id": "sn48.115-124:1.6",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.115-124:1.7",
      "pali": "Idha, bhikkhave, bhikkhu saddhindriyaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ …pe… paññindriyaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn48.115-124:1.8",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya imāni pañcindriyāni bhāvetabbānī”ti."
    },
    {
      "id": "sn48.115-124:1.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn48.115-124:1.10",
      "pali": "(Yathā maggasaṁyuttaṁ, tathā vitthāretabbaṁ.)"
    },
    {
      "id": "sn48.115-124:1.11",
      "pali": "Oghavaggo dvādasamo."
    },
    {
      "id": "sn48.115-124:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn48.115-124:2.2",
      "pali": "ganthā anusayena ca;"
    },
    {
      "id": "sn48.115-124:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn48.115-124:2.4",
      "pali": "khandhā oruddhambhāgiyāti."
    }
  ]
}
