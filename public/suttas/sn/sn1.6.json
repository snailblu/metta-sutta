{
  "uid": "sn1.6",
  "title": "Jāgarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.6:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.6:2.1",
      "pali": "“Kati jāgarataṁ suttā,"
    },
    {
      "id": "sn1.6:2.2",
      "pali": "kati suttesu jāgarā;"
    },
    {
      "id": "sn1.6:2.3",
      "pali": "Katibhi rajamādeti,"
    },
    {
      "id": "sn1.6:2.4",
      "pali": "katibhi parisujjhatī”ti."
    },
    {
      "id": "sn1.6:3.1",
      "pali": "“Pañca jāgarataṁ suttā,"
    },
    {
      "id": "sn1.6:3.2",
      "pali": "pañca suttesu jāgarā;"
    },
    {
      "id": "sn1.6:3.3",
      "pali": "Pañcabhi rajamādeti,"
    },
    {
      "id": "sn1.6:3.4",
      "pali": "pañcabhi parisujjhatī”ti."
    }
  ]
}
