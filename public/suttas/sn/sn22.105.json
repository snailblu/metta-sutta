{
  "uid": "sn22.105",
  "title": "Sakkāyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.105:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.105:1.2",
      "pali": "“Sakkāyañca vo, bhikkhave, desessāmi sakkāyasamudayañca sakkāyanirodhañca sakkāyanirodhagāminiñca paṭipadaṁ."
    },
    {
      "id": "sn22.105:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.105:1.4",
      "pali": "Katamo ca, bhikkhave, sakkāyo?"
    },
    {
      "id": "sn22.105:1.5",
      "pali": "Pañcupādānakkhandhātissa vacanīyaṁ."
    },
    {
      "id": "sn22.105:1.6",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.105:1.7",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho."
    },
    {
      "id": "sn22.105:1.8",
      "pali": "Ayaṁ vuccati, bhikkhave, sakkāyo."
    },
    {
      "id": "sn22.105:1.9",
      "pali": "Katamo ca, bhikkhave, sakkāyasamudayo?"
    },
    {
      "id": "sn22.105:1.10",
      "pali": "Yāyaṁ taṇhā ponobhavikā …pe…"
    },
    {
      "id": "sn22.105:1.11",
      "pali": "ayaṁ vuccati, bhikkhave, sakkāyasamudayo."
    },
    {
      "id": "sn22.105:1.12",
      "pali": "Katamo ca, bhikkhave, sakkāyanirodho?"
    },
    {
      "id": "sn22.105:1.13",
      "pali": "Yo tassāyeva taṇhāya …pe…"
    },
    {
      "id": "sn22.105:1.14",
      "pali": "ayaṁ vuccati, bhikkhave, sakkāyanirodho."
    },
    {
      "id": "sn22.105:1.15",
      "pali": "Katamā ca, bhikkhave, sakkāyanirodhagāminī paṭipadā?"
    },
    {
      "id": "sn22.105:1.16",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo."
    },
    {
      "id": "sn22.105:1.17",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn22.105:1.18",
      "pali": "Ayaṁ vuccati, bhikkhave, sakkāyanirodhagāminī paṭipadā”ti."
    },
    {
      "id": "sn22.105:1.19",
      "pali": "Tatiyaṁ."
    }
  ]
}
