{
  "uid": "sn1.35",
  "title": "Ujjhānasaññisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.35:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.35:1.2",
      "pali": "Atha kho sambahulā ujjhānasaññikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā vehāsaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.35:1.3",
      "pali": "Vehāsaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.35:2.1",
      "pali": "“Aññathā santamattānaṁ,"
    },
    {
      "id": "sn1.35:2.2",
      "pali": "aññathā yo pavedaye;"
    },
    {
      "id": "sn1.35:2.3",
      "pali": "Nikacca kitavasseva,"
    },
    {
      "id": "sn1.35:2.4",
      "pali": "bhuttaṁ theyyena tassa taṁ."
    },
    {
      "id": "sn1.35:3.1",
      "pali": "Yañhi kayirā tañhi vade,"
    },
    {
      "id": "sn1.35:3.2",
      "pali": "yaṁ na kayirā na taṁ vade;"
    },
    {
      "id": "sn1.35:3.3",
      "pali": "Akarontaṁ bhāsamānaṁ,"
    },
    {
      "id": "sn1.35:3.4",
      "pali": "parijānanti paṇḍitā”ti."
    },
    {
      "id": "sn1.35:4.1",
      "pali": "“Na yidaṁ bhāsitamattena,"
    },
    {
      "id": "sn1.35:4.2",
      "pali": "ekantasavanena vā;"
    },
    {
      "id": "sn1.35:4.3",
      "pali": "Anukkamitave sakkā,"
    },
    {
      "id": "sn1.35:4.4",
      "pali": "yāyaṁ paṭipadā daḷhā;"
    },
    {
      "id": "sn1.35:4.5",
      "pali": "Yāya dhīrā pamuccanti,"
    },
    {
      "id": "sn1.35:4.6",
      "pali": "jhāyino mārabandhanā."
    },
    {
      "id": "sn1.35:5.1",
      "pali": "Na ve dhīrā pakubbanti,"
    },
    {
      "id": "sn1.35:5.2",
      "pali": "viditvā lokapariyāyaṁ;"
    },
    {
      "id": "sn1.35:5.3",
      "pali": "Aññāya nibbutā dhīrā,"
    },
    {
      "id": "sn1.35:5.4",
      "pali": "tiṇṇā loke visattikan”ti."
    },
    {
      "id": "sn1.35:6.1",
      "pali": "Atha kho tā devatāyo pathaviyaṁ patiṭṭhahitvā bhagavato pādesu sirasā nipatitvā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn1.35:6.2",
      "pali": "“accayo no, bhante, accagamā yathābālaṁ yathāmūḷhaṁ yathāakusalaṁ, yā mayaṁ bhagavantaṁ āsādetabbaṁ amaññimhā."
    },
    {
      "id": "sn1.35:6.3",
      "pali": "Tāsaṁ no, bhante, bhagavā accayaṁ accayato paṭiggaṇhātu āyatiṁ saṁvarāyā”ti."
    },
    {
      "id": "sn1.35:6.4",
      "pali": "Atha kho bhagavā sitaṁ pātvākāsi."
    },
    {
      "id": "sn1.35:6.5",
      "pali": "Atha kho tā devatāyo bhiyyoso mattāya ujjhāyantiyo vehāsaṁ abbhuggañchuṁ."
    },
    {
      "id": "sn1.35:6.6",
      "pali": "Ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.35:7.1",
      "pali": "“Accayaṁ desayantīnaṁ,"
    },
    {
      "id": "sn1.35:7.2",
      "pali": "yo ce na paṭigaṇhati;"
    },
    {
      "id": "sn1.35:7.3",
      "pali": "Kopantaro dosagaru,"
    },
    {
      "id": "sn1.35:7.4",
      "pali": "sa veraṁ paṭimuñcatī”ti."
    },
    {
      "id": "sn1.35:8.1",
      "pali": "“Accayo ce na vijjetha,"
    },
    {
      "id": "sn1.35:8.2",
      "pali": "nocidhāpagataṁ siyā;"
    },
    {
      "id": "sn1.35:8.3",
      "pali": "Verāni na ca sammeyyuṁ,"
    },
    {
      "id": "sn1.35:8.4",
      "pali": "kenīdha kusalo siyā”ti."
    },
    {
      "id": "sn1.35:9.1",
      "pali": "“Kassaccayā na vijjanti,"
    },
    {
      "id": "sn1.35:9.2",
      "pali": "kassa natthi apāgataṁ;"
    },
    {
      "id": "sn1.35:9.3",
      "pali": "Ko na sammohamāpādi,"
    },
    {
      "id": "sn1.35:9.4",
      "pali": "ko ca dhīro sadā sato”ti."
    },
    {
      "id": "sn1.35:10.1",
      "pali": "“Tathāgatassa buddhassa,"
    },
    {
      "id": "sn1.35:10.2",
      "pali": "sabbabhūtānukampino;"
    },
    {
      "id": "sn1.35:10.3",
      "pali": "Tassaccayā na vijjanti,"
    },
    {
      "id": "sn1.35:10.4",
      "pali": "tassa natthi apāgataṁ;"
    },
    {
      "id": "sn1.35:10.5",
      "pali": "So na sammohamāpādi,"
    },
    {
      "id": "sn1.35:10.6",
      "pali": "sova dhīro sadā satoti."
    },
    {
      "id": "sn1.35:11.1",
      "pali": "Accayaṁ desayantīnaṁ,"
    },
    {
      "id": "sn1.35:11.2",
      "pali": "yo ce na paṭigaṇhati;"
    },
    {
      "id": "sn1.35:11.3",
      "pali": "Kopantaro dosagaru,"
    },
    {
      "id": "sn1.35:11.4",
      "pali": "sa veraṁ paṭimuñcati;"
    },
    {
      "id": "sn1.35:11.5",
      "pali": "Taṁ veraṁ nābhinandāmi,"
    },
    {
      "id": "sn1.35:11.6",
      "pali": "paṭiggaṇhāmi voccayan”ti."
    }
  ]
}
