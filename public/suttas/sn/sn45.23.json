{
  "uid": "sn45.23",
  "title": "Paṭhamapaṭipadāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.23:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.23:1.2",
      "pali": "“Micchāpaṭipadañca vo, bhikkhave, desessāmi, sammāpaṭipadañca."
    },
    {
      "id": "sn45.23:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.23:1.4",
      "pali": "Katamā ca, bhikkhave, micchāpaṭipadā?"
    },
    {
      "id": "sn45.23:1.5",
      "pali": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi."
    },
    {
      "id": "sn45.23:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, micchāpaṭipadā."
    },
    {
      "id": "sn45.23:1.7",
      "pali": "Katamā ca, bhikkhave, sammāpaṭipadā?"
    },
    {
      "id": "sn45.23:1.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.23:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, sammāpaṭipadā”ti."
    },
    {
      "id": "sn45.23:1.10",
      "pali": "Tatiyaṁ."
    }
  ]
}
