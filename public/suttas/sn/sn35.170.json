{
  "uid": "sn35.170",
  "title": "Ajjhattaaniccachandarāgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.170:1.1",
      "pali": "“Yaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn35.170:1.2",
      "pali": "Kiñca, bhikkhave, aniccaṁ?"
    },
    {
      "id": "sn35.170:1.3",
      "pali": "Cakkhu, bhikkhave, aniccaṁ;"
    },
    {
      "id": "sn35.170:1.4",
      "pali": "tatra vo chandarāgo pahātabbo …pe…"
    },
    {
      "id": "sn35.170:1.5",
      "pali": "jivhā aniccā;"
    },
    {
      "id": "sn35.170:1.6",
      "pali": "tatra vo chandarāgo pahātabbo …pe…"
    },
    {
      "id": "sn35.170:1.7",
      "pali": "mano anicco;"
    },
    {
      "id": "sn35.170:1.8",
      "pali": "tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn35.170:1.9",
      "pali": "Yaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo”ti."
    }
  ]
}
