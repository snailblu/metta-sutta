{
  "uid": "sn12.48",
  "title": "Lokāyatikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.48:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.48:1.2",
      "pali": "Atha kho lokāyatiko brāhmaṇo yena bhagavā …pe…"
    },
    {
      "id": "sn12.48:1.3",
      "pali": "ekamantaṁ nisinno kho lokāyatiko brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.48:2.1",
      "pali": "“Kiṁ nu kho, bho gotama, sabbamatthī”ti?"
    },
    {
      "id": "sn12.48:2.2",
      "pali": "“‘Sabbamatthī’ti kho, brāhmaṇa, jeṭṭhametaṁ lokāyataṁ”."
    },
    {
      "id": "sn12.48:3.1",
      "pali": "“Kiṁ pana, bho gotama, sabbaṁ natthī”ti?"
    },
    {
      "id": "sn12.48:3.2",
      "pali": "“‘Sabbaṁ natthī’ti kho, brāhmaṇa, dutiyametaṁ lokāyataṁ”."
    },
    {
      "id": "sn12.48:4.1",
      "pali": "“Kiṁ nu kho, bho gotama, sabbamekattan”ti?"
    },
    {
      "id": "sn12.48:4.2",
      "pali": "“‘Sabbamekattan’ti kho, brāhmaṇa, tatiyametaṁ lokāyataṁ”."
    },
    {
      "id": "sn12.48:5.1",
      "pali": "“Kiṁ pana, bho gotama, sabbaṁ puthuttan”ti?"
    },
    {
      "id": "sn12.48:5.2",
      "pali": "“‘Sabbaṁ puthuttan’ti kho, brāhmaṇa, catutthametaṁ lokāyataṁ."
    },
    {
      "id": "sn12.48:6.1",
      "pali": "Ete te, brāhmaṇa, ubho ante anupagamma majjhena tathāgato dhammaṁ deseti:"
    },
    {
      "id": "sn12.48:6.2",
      "pali": "‘avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.48:6.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.48:6.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.48:6.5",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.48:6.6",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.48:6.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī’”ti."
    },
    {
      "id": "sn12.48:7.1",
      "pali": "Evaṁ vutte, lokāyatiko brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.48:7.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn12.48:7.3",
      "pali": "ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    },
    {
      "id": "sn12.48:7.4",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
