{
  "uid": "sn25.3",
  "title": "Viññāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.3:1.2",
      "pali": "“Cakkhuviññāṇaṁ, bhikkhave, aniccaṁ vipariṇāmi aññathābhāvi;"
    },
    {
      "id": "sn25.3:1.3",
      "pali": "sotaviññāṇaṁ …"
    },
    {
      "id": "sn25.3:1.4",
      "pali": "ghānaviññāṇaṁ …"
    },
    {
      "id": "sn25.3:1.5",
      "pali": "jivhāviññāṇaṁ …"
    },
    {
      "id": "sn25.3:1.6",
      "pali": "kāyaviññāṇaṁ …"
    },
    {
      "id": "sn25.3:1.7",
      "pali": "manoviññāṇaṁ aniccaṁ vipariṇāmi aññathābhāvi."
    },
    {
      "id": "sn25.3:1.8",
      "pali": "Yo bhikkhave …pe…"
    },
    {
      "id": "sn25.3:1.9",
      "pali": "sambodhiparāyano”ti."
    },
    {
      "id": "sn25.3:1.10",
      "pali": "Tatiyaṁ."
    }
  ]
}
