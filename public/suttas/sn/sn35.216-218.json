{
  "uid": "sn35.216-218",
  "title": "Bāhirātītādiyaṁdukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.216-218:1.1",
      "pali": "“Rūpā, bhikkhave, dukkhā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.216-218:1.2",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.216-218:1.3",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.216-218:1.4",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.216-218:1.5",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.216-218:1.6",
      "pali": "rasā …"
    },
    {
      "id": "sn35.216-218:1.7",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.216-218:1.8",
      "pali": "dhammā dukkhā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.216-218:1.9",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.216-218:1.10",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.216-218:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.216-218:1.12",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
