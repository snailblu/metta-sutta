{
  "uid": "sn12.3",
  "title": "Paṭipadāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.3:1.1",
      "pali": "Sāvatthiyaṁ viharati …pe…"
    },
    {
      "id": "sn12.3:1.2",
      "pali": "“micchāpaṭipadañca vo, bhikkhave, desessāmi sammāpaṭipadañca."
    },
    {
      "id": "sn12.3:1.3",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.3:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.3:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.3:2.1",
      "pali": "“Katamā ca, bhikkhave, micchāpaṭipadā?"
    },
    {
      "id": "sn12.3:2.2",
      "pali": "Avijjāpaccayā, bhikkhave, saṅkhārā;"
    },
    {
      "id": "sn12.3:2.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.3:2.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.3:2.5",
      "pali": "Ayaṁ vuccati, bhikkhave, micchāpaṭipadā."
    },
    {
      "id": "sn12.3:3.1",
      "pali": "Katamā ca, bhikkhave, sammāpaṭipadā?"
    },
    {
      "id": "sn12.3:3.2",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.3:3.3",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.3:3.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.3:3.5",
      "pali": "Ayaṁ vuccati, bhikkhave, sammāpaṭipadā”ti."
    },
    {
      "id": "sn12.3:3.6",
      "pali": "Tatiyaṁ."
    }
  ]
}
