{
  "uid": "sn4.6",
  "title": "Sappasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.6:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.6:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn4.6:1.3",
      "pali": "Tena kho pana samayena bhagavā rattandhakāratimisāyaṁ abbhokāse nisinno hoti, devo ca ekamekaṁ phusāyati."
    },
    {
      "id": "sn4.6:2.1",
      "pali": "Atha kho māro pāpimā bhagavato bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo mahantaṁ sapparājavaṇṇaṁ abhinimminitvā yena bhagavā tenupasaṅkami."
    },
    {
      "id": "sn4.6:2.2",
      "pali": "Seyyathāpi nāma mahatī ekarukkhikā nāvā;"
    },
    {
      "id": "sn4.6:2.3",
      "pali": "evamassa kāyo hoti."
    },
    {
      "id": "sn4.6:2.4",
      "pali": "Seyyathāpi nāma mahantaṁ soṇḍikākiḷañjaṁ;"
    },
    {
      "id": "sn4.6:2.5",
      "pali": "evamassa phaṇo hoti."
    },
    {
      "id": "sn4.6:2.6",
      "pali": "Seyyathāpi nāma mahatī kosalikā kaṁsapāti;"
    },
    {
      "id": "sn4.6:2.7",
      "pali": "evamassa akkhīni bhavanti."
    },
    {
      "id": "sn4.6:2.8",
      "pali": "Seyyathāpi nāma deve gaḷagaḷāyante vijjullatā niccharanti;"
    },
    {
      "id": "sn4.6:2.9",
      "pali": "evamassa mukhato jivhā niccharati."
    },
    {
      "id": "sn4.6:2.10",
      "pali": "Seyyathāpi nāma kammāragaggariyā dhamamānāya saddo hoti;"
    },
    {
      "id": "sn4.6:2.11",
      "pali": "evamassa assāsapassāsānaṁ saddo hoti."
    },
    {
      "id": "sn4.6:3.1",
      "pali": "Atha kho bhagavā “māro ayaṁ pāpimā” iti viditvā māraṁ pāpimantaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn4.6:4.1",
      "pali": "“Yo suññagehāni sevati,"
    },
    {
      "id": "sn4.6:4.2",
      "pali": "Seyyā so muni attasaññato;"
    },
    {
      "id": "sn4.6:4.3",
      "pali": "Vossajja careyya tattha so,"
    },
    {
      "id": "sn4.6:4.4",
      "pali": "Patirūpañhi tathāvidhassa taṁ."
    },
    {
      "id": "sn4.6:5.1",
      "pali": "Carakā bahū bheravā bahū,"
    },
    {
      "id": "sn4.6:5.2",
      "pali": "Atho ḍaṁsasarīsapā bahū;"
    },
    {
      "id": "sn4.6:5.3",
      "pali": "Lomampi na tattha iñjaye,"
    },
    {
      "id": "sn4.6:5.4",
      "pali": "Suññāgāragato mahāmuni."
    },
    {
      "id": "sn4.6:6.1",
      "pali": "Nabhaṁ phaleyya pathavī caleyya,"
    },
    {
      "id": "sn4.6:6.2",
      "pali": "Sabbepi pāṇā uda santaseyyuṁ;"
    },
    {
      "id": "sn4.6:6.3",
      "pali": "Sallampi ce urasi pakappayeyyuṁ,"
    },
    {
      "id": "sn4.6:6.4",
      "pali": "Upadhīsu tāṇaṁ na karonti buddhā”ti."
    },
    {
      "id": "sn4.6:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
