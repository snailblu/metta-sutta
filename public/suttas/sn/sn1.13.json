{
  "uid": "sn1.13",
  "title": "Natthiputtasamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.13:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.13:2.1",
      "pali": "“Natthi puttasamaṁ pemaṁ,"
    },
    {
      "id": "sn1.13:2.2",
      "pali": "natthi gosamitaṁ dhanaṁ;"
    },
    {
      "id": "sn1.13:2.3",
      "pali": "Natthi sūriyasamā ābhā,"
    },
    {
      "id": "sn1.13:2.4",
      "pali": "samuddaparamā sarā”ti."
    },
    {
      "id": "sn1.13:3.1",
      "pali": "“Natthi attasamaṁ pemaṁ,"
    },
    {
      "id": "sn1.13:3.2",
      "pali": "natthi dhaññasamaṁ dhanaṁ;"
    },
    {
      "id": "sn1.13:3.3",
      "pali": "Natthi paññāsamā ābhā,"
    },
    {
      "id": "sn1.13:3.4",
      "pali": "vuṭṭhi ve paramā sarā”ti."
    }
  ]
}
