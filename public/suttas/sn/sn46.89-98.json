{
  "uid": "sn46.89-98",
  "title": "Tathāgatādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.89-98:1.1",
      "pali": "“Yāvatā, bhikkhave, sattā apadā vā dvipadā vā catuppadā vā bahuppadā vā”ti vitthāretabbaṁ."
    },
    {
      "id": "sn46.89-98:1.2",
      "pali": "Appamādavaggo dasamo."
    },
    {
      "id": "sn46.89-98:2.1",
      "pali": "Tathāgataṁ padaṁ kūṭaṁ,"
    },
    {
      "id": "sn46.89-98:2.2",
      "pali": "mūlaṁ sārena vassikaṁ;"
    },
    {
      "id": "sn46.89-98:2.3",
      "pali": "Rājā candimasūriyā ca,"
    },
    {
      "id": "sn46.89-98:2.4",
      "pali": "vatthena dasamaṁ padanti."
    },
    {
      "id": "sn46.89-98:3.1",
      "pali": "(Appamādavaggo bojjhaṅgasaṁyuttassa bojjhaṅgavasena vitthāretabbo.)"
    }
  ]
}
