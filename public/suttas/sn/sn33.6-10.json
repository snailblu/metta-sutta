{
  "uid": "sn33.6-10",
  "title": "Rūpaadassanādisuttapañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn33.6-10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.6-10:1.2",
      "pali": "Ekamantaṁ nisinno kho vacchagotto paribbājako bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn33.6-10:1.3",
      "pali": "“ko nu kho, bho gotama, hetu, ko paccayo, yānimāni anekavihitāni diṭṭhigatāni loke uppajjanti—"
    },
    {
      "id": "sn33.6-10:1.4",
      "pali": "sassato lokoti vā, asassato lokoti vā …pe…"
    },
    {
      "id": "sn33.6-10:1.5",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇāti vā”ti?"
    },
    {
      "id": "sn33.6-10:1.6",
      "pali": "“Rūpe kho, vaccha, adassanā …pe…"
    },
    {
      "id": "sn33.6-10:1.7",
      "pali": "rūpanirodhagāminiyā paṭipadāya adassanā …pe…"
    },
    {
      "id": "sn33.6-10:1.8",
      "pali": "vedanāya …"
    },
    {
      "id": "sn33.6-10:1.9",
      "pali": "saññāya …"
    },
    {
      "id": "sn33.6-10:1.10",
      "pali": "saṅkhāresu kho, vaccha, adassanā …pe…"
    },
    {
      "id": "sn33.6-10:1.11",
      "pali": "viññāṇe kho, vaccha, adassanā …pe… viññāṇanirodhagāminiyā paṭipadāya adassanā …pe…."
    },
    {
      "id": "sn33.6-10:1.12",
      "pali": "Dasamaṁ."
    }
  ]
}
