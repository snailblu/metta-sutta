{
  "uid": "sn23.17",
  "title": "Anattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.17:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.17:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.17:1.3",
      "pali": "“‘anattā, anattā’ti, bhante, vuccati."
    },
    {
      "id": "sn23.17:1.4",
      "pali": "Katamo nu kho, bhante, anattā”ti?"
    },
    {
      "id": "sn23.17:1.5",
      "pali": "“Rūpaṁ kho, rādha, anattā, vedanā anattā, saññā anattā, saṅkhārā anattā, viññāṇaṁ anattā."
    },
    {
      "id": "sn23.17:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.17:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.17:1.8",
      "pali": "Sattamaṁ."
    }
  ]
}
