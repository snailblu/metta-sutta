{
  "uid": "sn35.159",
  "title": "Bāhiraaniccanandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.159:1.1",
      "pali": "“Rūpe, bhikkhave, yoniso manasi karotha, rūpāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn35.159:1.2",
      "pali": "Rūpe, bhikkhave, bhikkhu yoniso manasikaronto, rūpāniccatañca yathābhūtaṁ samanupassanto rūpesupi nibbindati."
    },
    {
      "id": "sn35.159:1.3",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.159:1.4",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.159:1.5",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn35.159:1.6",
      "pali": "Sadde …"
    },
    {
      "id": "sn35.159:1.7",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.159:1.8",
      "pali": "rase …"
    },
    {
      "id": "sn35.159:1.9",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.159:1.10",
      "pali": "dhamme, bhikkhave, yoniso manasi karotha, dhammāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn35.159:1.11",
      "pali": "Dhamme, bhikkhave, bhikkhu yoniso manasikaronto, dhammāniccatañca yathābhūtaṁ samanupassanto dhammesupi nibbindati."
    },
    {
      "id": "sn35.159:1.12",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.159:1.13",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.159:1.14",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn35.159:1.15",
      "pali": "Catutthaṁ."
    }
  ]
}
