{
  "uid": "sn23.3",
  "title": "Bhavanettisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.3:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.3:1.3",
      "pali": "“‘bhavanettinirodho, bhavanettinirodho’ti, bhante, vuccati."
    },
    {
      "id": "sn23.3:1.4",
      "pali": "Katamā nu kho, bhante, bhavanetti, katamo bhavanettinirodho”ti?"
    },
    {
      "id": "sn23.3:1.5",
      "pali": "“Rūpe kho, rādha, yo chando yo rāgo yā nandī yā taṇhā ye upayupādānā cetaso adhiṭṭhānābhinivesānusayā—"
    },
    {
      "id": "sn23.3:1.6",
      "pali": "ayaṁ vuccati bhavanetti."
    },
    {
      "id": "sn23.3:1.7",
      "pali": "Tesaṁ nirodho bhavanettinirodho."
    },
    {
      "id": "sn23.3:1.8",
      "pali": "Vedanāya …"
    },
    {
      "id": "sn23.3:1.9",
      "pali": "saññāya …"
    },
    {
      "id": "sn23.3:1.10",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn23.3:1.11",
      "pali": "viññāṇe yo chando …pe… adhiṭṭhānābhinivesānusayā—"
    },
    {
      "id": "sn23.3:1.12",
      "pali": "ayaṁ vuccati bhavanetti."
    },
    {
      "id": "sn23.3:1.13",
      "pali": "Tesaṁ nirodho bhavanettinirodho”ti."
    },
    {
      "id": "sn23.3:1.14",
      "pali": "Tatiyaṁ."
    }
  ]
}
