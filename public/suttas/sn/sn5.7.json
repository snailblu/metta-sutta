{
  "uid": "sn5.7",
  "title": "Upacālāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.7:1.2",
      "pali": "Atha kho upacālā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.7:1.3",
      "pali": "aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.7:1.4",
      "pali": "Atha kho māro pāpimā yena upacālā bhikkhunī tenupasaṅkami; upasaṅkamitvā upacālaṁ bhikkhuniṁ etadavoca:"
    },
    {
      "id": "sn5.7:1.5",
      "pali": "“kattha nu tvaṁ, bhikkhuni, uppajjitukāmā”ti?"
    },
    {
      "id": "sn5.7:1.6",
      "pali": "“Na khvāhaṁ, āvuso, katthaci uppajjitukāmā”ti."
    },
    {
      "id": "sn5.7:2.1",
      "pali": "“Tāvatiṁsā ca yāmā ca,"
    },
    {
      "id": "sn5.7:2.2",
      "pali": "tusitā cāpi devatā;"
    },
    {
      "id": "sn5.7:2.3",
      "pali": "Nimmānaratino devā,"
    },
    {
      "id": "sn5.7:2.4",
      "pali": "ye devā vasavattino;"
    },
    {
      "id": "sn5.7:2.5",
      "pali": "Tattha cittaṁ paṇidhehi,"
    },
    {
      "id": "sn5.7:2.6",
      "pali": "ratiṁ paccanubhossasī”ti."
    },
    {
      "id": "sn5.7:3.1",
      "pali": "“Tāvatiṁsā ca yāmā ca,"
    },
    {
      "id": "sn5.7:3.2",
      "pali": "tusitā cāpi devatā;"
    },
    {
      "id": "sn5.7:3.3",
      "pali": "Nimmānaratino devā,"
    },
    {
      "id": "sn5.7:3.4",
      "pali": "ye devā vasavattino;"
    },
    {
      "id": "sn5.7:3.5",
      "pali": "Kāmabandhanabaddhā te,"
    },
    {
      "id": "sn5.7:3.6",
      "pali": "enti māravasaṁ puna."
    },
    {
      "id": "sn5.7:4.1",
      "pali": "Sabbo ādīpito loko,"
    },
    {
      "id": "sn5.7:4.2",
      "pali": "sabbo loko padhūpito;"
    },
    {
      "id": "sn5.7:4.3",
      "pali": "Sabbo pajjālito loko,"
    },
    {
      "id": "sn5.7:4.4",
      "pali": "sabbo loko pakampito."
    },
    {
      "id": "sn5.7:5.1",
      "pali": "Akampitaṁ apajjalitaṁ,"
    },
    {
      "id": "sn5.7:5.2",
      "pali": "aputhujjanasevitaṁ;"
    },
    {
      "id": "sn5.7:5.3",
      "pali": "Agati yattha mārassa,"
    },
    {
      "id": "sn5.7:5.4",
      "pali": "tattha me nirato mano”ti."
    },
    {
      "id": "sn5.7:6.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ upacālā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
