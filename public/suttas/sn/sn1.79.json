{
  "uid": "sn1.79",
  "title": "Pātheyyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.79:1.1",
      "pali": "“Kiṁsu bandhati pātheyyaṁ,"
    },
    {
      "id": "sn1.79:1.2",
      "pali": "kiṁsu bhogānamāsayo;"
    },
    {
      "id": "sn1.79:1.3",
      "pali": "Kiṁsu naraṁ parikassati,"
    },
    {
      "id": "sn1.79:1.4",
      "pali": "kiṁsu lokasmi dujjahaṁ;"
    },
    {
      "id": "sn1.79:1.5",
      "pali": "Kismiṁ baddhā puthū sattā,"
    },
    {
      "id": "sn1.79:1.6",
      "pali": "pāsena sakuṇī yathā”ti."
    },
    {
      "id": "sn1.79:2.1",
      "pali": "“Saddhā bandhati pātheyyaṁ,"
    },
    {
      "id": "sn1.79:2.2",
      "pali": "sirī bhogānamāsayo;"
    },
    {
      "id": "sn1.79:2.3",
      "pali": "Icchā naraṁ parikassati,"
    },
    {
      "id": "sn1.79:2.4",
      "pali": "icchā lokasmi dujjahā;"
    },
    {
      "id": "sn1.79:2.5",
      "pali": "Icchābaddhā puthū sattā,"
    },
    {
      "id": "sn1.79:2.6",
      "pali": "pāsena sakuṇī yathā”ti."
    }
  ]
}
