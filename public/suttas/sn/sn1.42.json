{
  "uid": "sn1.42",
  "title": "Kiṁdadasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.42:1.1",
      "pali": "“Kiṁdado balado hoti,"
    },
    {
      "id": "sn1.42:1.2",
      "pali": "kiṁdado hoti vaṇṇado;"
    },
    {
      "id": "sn1.42:1.3",
      "pali": "Kiṁdado sukhado hoti,"
    },
    {
      "id": "sn1.42:1.4",
      "pali": "kiṁdado hoti cakkhudo;"
    },
    {
      "id": "sn1.42:1.5",
      "pali": "Ko ca sabbadado hoti,"
    },
    {
      "id": "sn1.42:1.6",
      "pali": "taṁ me akkhāhi pucchito”ti."
    },
    {
      "id": "sn1.42:2.1",
      "pali": "“Annado balado hoti,"
    },
    {
      "id": "sn1.42:2.2",
      "pali": "vatthado hoti vaṇṇado;"
    },
    {
      "id": "sn1.42:2.3",
      "pali": "Yānado sukhado hoti,"
    },
    {
      "id": "sn1.42:2.4",
      "pali": "dīpado hoti cakkhudo."
    },
    {
      "id": "sn1.42:3.1",
      "pali": "So ca sabbadado hoti,"
    },
    {
      "id": "sn1.42:3.2",
      "pali": "yo dadāti upassayaṁ;"
    },
    {
      "id": "sn1.42:3.3",
      "pali": "Amataṁ dado ca so hoti,"
    },
    {
      "id": "sn1.42:3.4",
      "pali": "yo dhammamanusāsatī”ti."
    }
  ]
}
