{
  "uid": "sn8.2",
  "title": "Aratīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.2:1.1",
      "pali": "Ekaṁ samayaṁ …pe… āyasmā vaṅgīso āḷaviyaṁ viharati aggāḷave cetiye āyasmatā nigrodhakappena upajjhāyena saddhiṁ."
    },
    {
      "id": "sn8.2:1.2",
      "pali": "Tena kho pana samayena āyasmā nigrodhakappo pacchābhattaṁ piṇḍapātapaṭikkanto vihāraṁ pavisati, sāyaṁ vā nikkhamati aparajju vā kāle."
    },
    {
      "id": "sn8.2:1.3",
      "pali": "Tena kho pana samayena āyasmato vaṅgīsassa anabhirati uppannā hoti, rāgo cittaṁ anuddhaṁseti."
    },
    {
      "id": "sn8.2:1.4",
      "pali": "Atha kho āyasmato vaṅgīsassa etadahosi:"
    },
    {
      "id": "sn8.2:1.5",
      "pali": "“alābhā vata me, na vata me lābhā; dulladdhaṁ vata me, na vata me suladdhaṁ;"
    },
    {
      "id": "sn8.2:1.6",
      "pali": "yassa me anabhirati uppannā, rāgo cittaṁ anuddhaṁseti; taṁ kutettha labbhā, yaṁ me paro anabhiratiṁ vinodetvā abhiratiṁ uppādeyya."
    },
    {
      "id": "sn8.2:1.7",
      "pali": "Yannūnāhaṁ attanāva attano anabhiratiṁ vinodetvā abhiratiṁ uppādeyyan”ti."
    },
    {
      "id": "sn8.2:1.8",
      "pali": "Atha kho āyasmā vaṅgīso attanāva attano anabhiratiṁ vinodetvā abhiratiṁ uppādetvā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn8.2:2.1",
      "pali": "“Aratiñca ratiñca pahāya,"
    },
    {
      "id": "sn8.2:2.2",
      "pali": "Sabbaso gehasitañca vitakkaṁ;"
    },
    {
      "id": "sn8.2:2.3",
      "pali": "Vanathaṁ na kareyya kuhiñci,"
    },
    {
      "id": "sn8.2:2.4",
      "pali": "Nibbanatho arato sa hi bhikkhu."
    },
    {
      "id": "sn8.2:3.1",
      "pali": "Yamidha pathaviñca vehāsaṁ,"
    },
    {
      "id": "sn8.2:3.2",
      "pali": "Rūpagatañca jagatogadhaṁ;"
    },
    {
      "id": "sn8.2:3.3",
      "pali": "Kiñci parijīyati sabbamaniccaṁ,"
    },
    {
      "id": "sn8.2:3.4",
      "pali": "Evaṁ samecca caranti mutattā."
    },
    {
      "id": "sn8.2:4.1",
      "pali": "Upadhīsu janā gadhitāse,"
    },
    {
      "id": "sn8.2:4.2",
      "pali": "Diṭṭhasute paṭighe ca mute ca;"
    },
    {
      "id": "sn8.2:4.3",
      "pali": "Ettha vinodaya chandamanejo,"
    },
    {
      "id": "sn8.2:4.4",
      "pali": "Yo ettha na limpati taṁ munimāhu."
    },
    {
      "id": "sn8.2:5.1",
      "pali": "Atha saṭṭhinissitā savitakkā,"
    },
    {
      "id": "sn8.2:5.2",
      "pali": "Puthū janatāya adhammā niviṭṭhā;"
    },
    {
      "id": "sn8.2:5.3",
      "pali": "Na ca vaggagatassa kuhiñci,"
    },
    {
      "id": "sn8.2:5.4",
      "pali": "No pana duṭṭhullabhāṇī sa bhikkhu."
    },
    {
      "id": "sn8.2:6.1",
      "pali": "Dabbo cirarattasamāhito,"
    },
    {
      "id": "sn8.2:6.2",
      "pali": "Akuhako nipako apihālu;"
    },
    {
      "id": "sn8.2:6.3",
      "pali": "Santaṁ padaṁ ajjhagamā muni paṭicca,"
    },
    {
      "id": "sn8.2:6.4",
      "pali": "Parinibbuto kaṅkhati kālan”ti."
    }
  ]
}
