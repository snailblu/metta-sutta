{
  "uid": "sn1.29",
  "title": "Catucakkasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.29:1.1",
      "pali": "“Catucakkaṁ navadvāraṁ,"
    },
    {
      "id": "sn1.29:1.2",
      "pali": "puṇṇaṁ lobhena saṁyutaṁ;"
    },
    {
      "id": "sn1.29:1.3",
      "pali": "Paṅkajātaṁ mahāvīra,"
    },
    {
      "id": "sn1.29:1.4",
      "pali": "kathaṁ yātrā bhavissatī”ti."
    },
    {
      "id": "sn1.29:2.1",
      "pali": "“Chetvā naddhiṁ varattañca,"
    },
    {
      "id": "sn1.29:2.2",
      "pali": "icchā lobhañca pāpakaṁ;"
    },
    {
      "id": "sn1.29:2.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "sn1.29:2.4",
      "pali": "evaṁ yātrā bhavissatī”ti."
    }
  ]
}
