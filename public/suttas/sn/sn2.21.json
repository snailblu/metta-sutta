{
  "uid": "sn2.21",
  "title": "Sivasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.21:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn2.21:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn2.21:1.3",
      "pali": "Atha kho sivo devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.21:1.4",
      "pali": "Ekamantaṁ ṭhito kho sivo devaputto bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.21:2.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:2.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:2.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:2.4",
      "pali": "seyyo hoti na pāpiyo."
    },
    {
      "id": "sn2.21:3.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:3.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:3.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:3.4",
      "pali": "paññā labbhati nāññato."
    },
    {
      "id": "sn2.21:4.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:4.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:4.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:4.4",
      "pali": "sokamajjhe na socati."
    },
    {
      "id": "sn2.21:5.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:5.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:5.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:5.4",
      "pali": "ñātimajjhe virocati."
    },
    {
      "id": "sn2.21:6.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:6.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:6.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:6.4",
      "pali": "sattā gacchanti suggatiṁ."
    },
    {
      "id": "sn2.21:7.1",
      "pali": "Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:7.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:7.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:7.4",
      "pali": "sattā tiṭṭhanti sātatan”ti."
    },
    {
      "id": "sn2.21:8.1",
      "pali": "Atha kho bhagavā sivaṁ devaputtaṁ gāthāya paccabhāsi:"
    },
    {
      "id": "sn2.21:9.1",
      "pali": "“Sabbhireva samāsetha,"
    },
    {
      "id": "sn2.21:9.2",
      "pali": "sabbhi kubbetha santhavaṁ;"
    },
    {
      "id": "sn2.21:9.3",
      "pali": "Sataṁ saddhammamaññāya,"
    },
    {
      "id": "sn2.21:9.4",
      "pali": "sabbadukkhā pamuccatī”ti."
    }
  ]
}
