{
  "uid": "sn22.157",
  "title": "Abhinivesasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.157:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.157:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhā”ti?"
    },
    {
      "id": "sn22.157:1.3",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.157:1.4",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhā."
    },
    {
      "id": "sn22.157:1.5",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn22.157:1.6",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn22.157:1.7",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn22.157:1.8",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhā."
    },
    {
      "id": "sn22.157:1.9",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.157:1.10",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.157:1.11",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.157:1.12",
      "pali": "“Yaṁ panāniccaṁ …pe…"
    },
    {
      "id": "sn22.157:1.13",
      "pali": "api nu taṁ anupādāya uppajjeyyuṁ saṁyojanābhinivesavinibandhā”ti?"
    },
    {
      "id": "sn22.157:1.14",
      "pali": "“No hetaṁ, bhante” …pe…"
    },
    {
      "id": "sn22.157:1.15",
      "pali": "“evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.157:1.16",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.157:1.17",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
