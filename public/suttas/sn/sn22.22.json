{
  "uid": "sn22.22",
  "title": "Bhārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.22:1.1",
      "pali": "Sāvatthiyaṁ … tatra kho …"
    },
    {
      "id": "sn22.22:1.2",
      "pali": "“bhārañca vo, bhikkhave, desessāmi bhārahārañca bhārādānañca bhāranikkhepanañca."
    },
    {
      "id": "sn22.22:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.22:1.4",
      "pali": "Katamo ca, bhikkhave, bhāro?"
    },
    {
      "id": "sn22.22:1.5",
      "pali": "Pañcupādānakkhandhā tissa vacanīyaṁ."
    },
    {
      "id": "sn22.22:1.6",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.22:1.7",
      "pali": "Rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho;"
    },
    {
      "id": "sn22.22:1.8",
      "pali": "ayaṁ vuccati, bhikkhave, bhāro."
    },
    {
      "id": "sn22.22:2.1",
      "pali": "Katamo ca, bhikkhave, bhārahāro?"
    },
    {
      "id": "sn22.22:2.2",
      "pali": "Puggalo tissa vacanīyaṁ."
    },
    {
      "id": "sn22.22:2.3",
      "pali": "Yvāyaṁ āyasmā evaṁnāmo evaṅgotto;"
    },
    {
      "id": "sn22.22:2.4",
      "pali": "ayaṁ vuccati, bhikkhave, bhārahāro."
    },
    {
      "id": "sn22.22:3.1",
      "pali": "Katamañca, bhikkhave, bhārādānaṁ?"
    },
    {
      "id": "sn22.22:3.2",
      "pali": "Yāyaṁ taṇhā ponobhavikā nandīrāgasahagatā tatratatrābhinandinī, seyyathidaṁ—"
    },
    {
      "id": "sn22.22:3.3",
      "pali": "kāmataṇhā, bhavataṇhā, vibhavataṇhā."
    },
    {
      "id": "sn22.22:3.4",
      "pali": "Idaṁ vuccati, bhikkhave, bhārādānaṁ."
    },
    {
      "id": "sn22.22:4.1",
      "pali": "Katamañca, bhikkhave, bhāranikkhepanaṁ?"
    },
    {
      "id": "sn22.22:4.2",
      "pali": "Yo tassāyeva taṇhāya asesavirāganirodho cāgo paṭinissaggo mutti anālayo."
    },
    {
      "id": "sn22.22:4.3",
      "pali": "Idaṁ vuccati, bhikkhave, bhāranikkhepanan”ti."
    },
    {
      "id": "sn22.22:5.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn22.22:5.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn22.22:6.1",
      "pali": "“Bhārā have pañcakkhandhā,"
    },
    {
      "id": "sn22.22:6.2",
      "pali": "bhārahāro ca puggalo;"
    },
    {
      "id": "sn22.22:6.3",
      "pali": "Bhārādānaṁ dukhaṁ loke,"
    },
    {
      "id": "sn22.22:6.4",
      "pali": "bhāranikkhepanaṁ sukhaṁ."
    },
    {
      "id": "sn22.22:7.1",
      "pali": "Nikkhipitvā garuṁ bhāraṁ,"
    },
    {
      "id": "sn22.22:7.2",
      "pali": "aññaṁ bhāraṁ anādiya;"
    },
    {
      "id": "sn22.22:7.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "sn22.22:7.4",
      "pali": "nicchāto parinibbuto”ti."
    },
    {
      "id": "sn22.22:7.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
