{
  "uid": "sn12.27",
  "title": "Paccayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.27:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.27:1.2",
      "pali": "“Avijjāpaccayā, bhikkhave, saṅkhārā;"
    },
    {
      "id": "sn12.27:1.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.27:1.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.27:2.1",
      "pali": "Katamañca, bhikkhave, jarāmaraṇaṁ?"
    },
    {
      "id": "sn12.27:2.2",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhi tamhi sattanikāye jarā jīraṇatā khaṇḍiccaṁ pāliccaṁ valittacatā āyuno saṁhāni indriyānaṁ paripāko—"
    },
    {
      "id": "sn12.27:2.3",
      "pali": "ayaṁ vuccati jarā."
    },
    {
      "id": "sn12.27:2.4",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhā tamhā sattanikāyā cuti cavanatā bhedo antaradhānaṁ maccu maraṇaṁ kālakiriyā khandhānaṁ bhedo kaḷevarassa nikkhepo;"
    },
    {
      "id": "sn12.27:2.5",
      "pali": "idaṁ vuccati maraṇaṁ."
    },
    {
      "id": "sn12.27:2.6",
      "pali": "Iti ayañca jarā idañca maraṇaṁ."
    },
    {
      "id": "sn12.27:2.7",
      "pali": "Idaṁ vuccati, bhikkhave, jarāmaraṇaṁ."
    },
    {
      "id": "sn12.27:2.8",
      "pali": "Jātisamudayā jarāmaraṇasamudayo;"
    },
    {
      "id": "sn12.27:2.9",
      "pali": "jātinirodhā jarāmaraṇanirodho."
    },
    {
      "id": "sn12.27:2.10",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo jarāmaraṇanirodhagāminī paṭipadā."
    },
    {
      "id": "sn12.27:2.11",
      "pali": "Seyyathidaṁ—sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi."
    },
    {
      "id": "sn12.27:3.1",
      "pali": "Katamā ca, bhikkhave, jāti …pe…"
    },
    {
      "id": "sn12.27:3.2",
      "pali": "katamo ca, bhikkhave, bhavo …"
    },
    {
      "id": "sn12.27:3.3",
      "pali": "katamañca, bhikkhave, upādānaṁ …"
    },
    {
      "id": "sn12.27:3.4",
      "pali": "katamā ca, bhikkhave, taṇhā …"
    },
    {
      "id": "sn12.27:3.5",
      "pali": "katamā ca, bhikkhave, vedanā …"
    },
    {
      "id": "sn12.27:3.6",
      "pali": "katamo ca, bhikkhave, phasso …"
    },
    {
      "id": "sn12.27:3.7",
      "pali": "katamañca, bhikkhave, saḷāyatanaṁ …"
    },
    {
      "id": "sn12.27:3.8",
      "pali": "katamañca, bhikkhave, nāmarūpaṁ …"
    },
    {
      "id": "sn12.27:3.9",
      "pali": "katamañca, bhikkhave, viññāṇaṁ …?"
    },
    {
      "id": "sn12.27:4.1",
      "pali": "Katame ca, bhikkhave, saṅkhārā?"
    },
    {
      "id": "sn12.27:4.2",
      "pali": "Tayome, bhikkhave, saṅkhārā—"
    },
    {
      "id": "sn12.27:4.3",
      "pali": "kāyasaṅkhāro, vacīsaṅkhāro, cittasaṅkhāro."
    },
    {
      "id": "sn12.27:4.4",
      "pali": "Ime vuccanti, bhikkhave, saṅkhārā."
    },
    {
      "id": "sn12.27:4.5",
      "pali": "Avijjāsamudayā saṅkhārasamudayo;"
    },
    {
      "id": "sn12.27:4.6",
      "pali": "avijjānirodhā saṅkhāranirodho."
    },
    {
      "id": "sn12.27:4.7",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo saṅkhāranirodhagāminī paṭipadā."
    },
    {
      "id": "sn12.27:4.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn12.27:5.1",
      "pali": "Yato kho, bhikkhave, ariyasāvako evaṁ paccayaṁ pajānāti, evaṁ paccayasamudayaṁ pajānāti, evaṁ paccayanirodhaṁ pajānāti, evaṁ paccayanirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn12.27:5.2",
      "pali": "Ayaṁ vuccati, bhikkhave, ariyasāvako diṭṭhisampanno itipi, dassanasampanno itipi, āgato imaṁ saddhammaṁ itipi, passati imaṁ saddhammaṁ itipi, sekkhena ñāṇena samannāgato itipi, sekkhāya vijjāya samannāgato itipi, dhammasotaṁ samāpanno itipi, ariyo nibbedhikapañño itipi, amatadvāraṁ āhacca tiṭṭhati itipī”ti."
    },
    {
      "id": "sn12.27:5.3",
      "pali": "Sattamaṁ."
    }
  ]
}
