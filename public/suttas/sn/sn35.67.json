{
  "uid": "sn35.67",
  "title": "Samiddhidukkhapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.67:1.1",
      "pali": "“‘Dukkhaṁ, dukkhan’ti, bhante, vuccati."
    },
    {
      "id": "sn35.67:1.2",
      "pali": "Kittāvatā nu kho, bhante, dukkhaṁ vā assa dukkhapaññatti vā”ti …pe…."
    },
    {
      "id": "sn35.67:1.3",
      "pali": "Pañcamaṁ."
    }
  ]
}
