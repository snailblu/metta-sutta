{
  "uid": "sn36.18",
  "title": "Dutiyasambahulasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.18:1.1",
      "pali": "Atha kho sambahulā bhikkhū yena bhagavā tenupasaṅkamiṁsu …pe…"
    },
    {
      "id": "sn36.18:1.2",
      "pali": "ekamantaṁ nisinnā kho te bhikkhū bhagavā etadavoca:"
    },
    {
      "id": "sn36.18:1.3",
      "pali": "“katamā nu kho, bhikkhave, vedanā, katamo vedanāsamudayo, katamo vedanānirodho, katamā vedanānirodhagāminī paṭipadā?"
    },
    {
      "id": "sn36.18:1.4",
      "pali": "Ko vedanāya assādo, ko ādīnavo, kiṁ nissaraṇan”ti?"
    },
    {
      "id": "sn36.18:1.5",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…”"
    },
    {
      "id": "sn36.18:1.6",
      "pali": "“tisso imā, bhikkhave, vedanā—"
    },
    {
      "id": "sn36.18:1.7",
      "pali": "sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn36.18:1.8",
      "pali": "imā vuccanti, bhikkhave, vedanā …pe… phassasamudayā …pe…."
    },
    {
      "id": "sn36.18:1.9",
      "pali": "(Yathā purimasuttante, tathā vitthāretabbo.)"
    },
    {
      "id": "sn36.18:1.10",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
