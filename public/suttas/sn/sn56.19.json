{
  "uid": "sn56.19",
  "title": "Saṅkāsanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.19:1.1",
      "pali": "“‘Idaṁ dukkhaṁ ariyasaccan’ti, bhikkhave, mayā paññattaṁ."
    },
    {
      "id": "sn56.19:1.2",
      "pali": "Tattha aparimāṇā vaṇṇā aparimāṇā byañjanā aparimāṇā saṅkāsanā:"
    },
    {
      "id": "sn56.19:1.3",
      "pali": "‘itipidaṁ dukkhaṁ ariyasaccan’ti;"
    },
    {
      "id": "sn56.19:1.4",
      "pali": "idaṁ dukkhasamudayaṁ …pe…"
    },
    {
      "id": "sn56.19:1.5",
      "pali": "idaṁ dukkhanirodhaṁ …pe…"
    },
    {
      "id": "sn56.19:1.6",
      "pali": "‘idaṁ dukkhanirodhagāminī paṭipadā ariyasaccan’ti, bhikkhave, mayā paññattaṁ."
    },
    {
      "id": "sn56.19:1.7",
      "pali": "Tattha aparimāṇā vaṇṇā aparimāṇā byañjanā aparimāṇā saṅkāsanā:"
    },
    {
      "id": "sn56.19:1.8",
      "pali": "‘itipidaṁ dukkhanirodhagāminī paṭipadā ariyasaccan’ti."
    },
    {
      "id": "sn56.19:2.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.19:2.2",
      "pali": "Navamaṁ."
    }
  ]
}
