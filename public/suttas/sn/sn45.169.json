{
  "uid": "sn45.169",
  "title": "Vedanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.169:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn45.169:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.169:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn45.169:1.4",
      "pali": "imā kho, bhikkhave, tisso vedanā."
    },
    {
      "id": "sn45.169:1.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ vedanānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.169:1.6",
      "pali": "Navamaṁ."
    }
  ]
}
