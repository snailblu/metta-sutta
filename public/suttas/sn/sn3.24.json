{
  "uid": "sn3.24",
  "title": "Issattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.24:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn3.24:1.2",
      "pali": "Ekamantaṁ nisinno kho rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.24:1.3",
      "pali": "“kattha nu kho, bhante, dānaṁ dātabban”ti?"
    },
    {
      "id": "sn3.24:1.4",
      "pali": "“Yattha kho, mahārāja, cittaṁ pasīdatī”ti."
    },
    {
      "id": "sn3.24:1.5",
      "pali": "“Kattha pana, bhante, dinnaṁ mahapphalan”ti?"
    },
    {
      "id": "sn3.24:1.6",
      "pali": "“Aññaṁ kho etaṁ, mahārāja, kattha dānaṁ dātabbaṁ, aññaṁ panetaṁ kattha dinnaṁ mahapphalanti?"
    },
    {
      "id": "sn3.24:1.7",
      "pali": "Sīlavato kho, mahārāja, dinnaṁ mahapphalaṁ, no tathā dussīle."
    },
    {
      "id": "sn3.24:1.8",
      "pali": "Tena hi, mahārāja, taññevettha paṭipucchissāmi. Yathā, te khameyya, tathā naṁ byākareyyāsi."
    },
    {
      "id": "sn3.24:1.9",
      "pali": "Taṁ kiṁ maññasi, mahārāja,"
    },
    {
      "id": "sn3.24:1.10",
      "pali": "idha tyassa yuddhaṁ paccupaṭṭhitaṁ saṅgāmo samupabyūḷho."
    },
    {
      "id": "sn3.24:1.11",
      "pali": "Atha āgaccheyya khattiyakumāro asikkhito akatahattho akatayoggo akatūpāsano bhīru chambhī utrāsī palāyī."
    },
    {
      "id": "sn3.24:1.12",
      "pali": "Bhareyyāsi taṁ purisaṁ, attho ca te tādisena purisenā”ti?"
    },
    {
      "id": "sn3.24:1.13",
      "pali": "“Nāhaṁ, bhante, bhareyyaṁ taṁ purisaṁ, na ca me attho tādisena purisenā”ti."
    },
    {
      "id": "sn3.24:1.14",
      "pali": "“Atha āgaccheyya brāhmaṇakumāro asikkhito …pe…"
    },
    {
      "id": "sn3.24:1.15",
      "pali": "atha āgaccheyya vessakumāro asikkhito …pe…"
    },
    {
      "id": "sn3.24:1.16",
      "pali": "atha āgaccheyya suddakumāro asikkhito …pe…"
    },
    {
      "id": "sn3.24:1.17",
      "pali": "na ca me attho tādisena purisenā”ti."
    },
    {
      "id": "sn3.24:2.1",
      "pali": "“Taṁ kiṁ maññasi, mahārāja,"
    },
    {
      "id": "sn3.24:2.2",
      "pali": "idha tyassa yuddhaṁ paccupaṭṭhitaṁ saṅgāmo samupabyūḷho."
    },
    {
      "id": "sn3.24:2.3",
      "pali": "Atha āgaccheyya khattiyakumāro susikkhito katahattho katayoggo katūpāsano abhīru acchambhī anutrāsī apalāyī."
    },
    {
      "id": "sn3.24:2.4",
      "pali": "Bhareyyāsi taṁ purisaṁ, attho ca te tādisena purisenā”ti?"
    },
    {
      "id": "sn3.24:2.5",
      "pali": "“Bhareyyāhaṁ, bhante, taṁ purisaṁ, attho ca me tādisena purisenā”ti."
    },
    {
      "id": "sn3.24:2.6",
      "pali": "“Atha āgaccheyya brāhmaṇakumāro …pe…"
    },
    {
      "id": "sn3.24:2.7",
      "pali": "atha āgaccheyya vessakumāro …pe…"
    },
    {
      "id": "sn3.24:2.8",
      "pali": "atha āgaccheyya suddakumāro susikkhito katahattho katayoggo katūpāsano abhīru acchambhī anutrāsī apalāyī."
    },
    {
      "id": "sn3.24:2.9",
      "pali": "Bhareyyāsi taṁ purisaṁ, attho ca te tādisena purisenā”ti?"
    },
    {
      "id": "sn3.24:2.10",
      "pali": "“Bhareyyāhaṁ, bhante, taṁ purisaṁ, attho ca me tādisena purisenā”ti."
    },
    {
      "id": "sn3.24:3.1",
      "pali": "“Evameva kho, mahārāja, yasmā kasmā cepi kulā agārasmā anagāriyaṁ pabbajito hoti, so ca hoti pañcaṅgavippahīno pañcaṅgasamannāgato, tasmiṁ dinnaṁ mahapphalaṁ hoti."
    },
    {
      "id": "sn3.24:3.2",
      "pali": "Katamāni pañcaṅgāni pahīnāni honti?"
    },
    {
      "id": "sn3.24:3.3",
      "pali": "Kāmacchando pahīno hoti, byāpādo pahīno hoti, thinamiddhaṁ pahīnaṁ hoti, uddhaccakukkuccaṁ pahīnaṁ hoti, vicikicchā pahīnā hoti."
    },
    {
      "id": "sn3.24:3.4",
      "pali": "Imāni pañcaṅgāni pahīnāni honti."
    },
    {
      "id": "sn3.24:3.5",
      "pali": "Katamehi pañcahaṅgehi samannāgato hoti?"
    },
    {
      "id": "sn3.24:3.6",
      "pali": "Asekkhena sīlakkhandhena samannāgato hoti, asekkhena samādhikkhandhena samannāgato hoti, asekkhena paññākkhandhena samannāgato hoti, asekkhena vimuttikkhandhena samannāgato hoti, asekkhena vimuttiñāṇadassanakkhandhena samannāgato hoti."
    },
    {
      "id": "sn3.24:3.7",
      "pali": "Imehi pañcahaṅgehi samannāgato hoti."
    },
    {
      "id": "sn3.24:3.8",
      "pali": "Iti pañcaṅgavippahīne pañcaṅgasamannāgate dinnaṁ mahapphalan”ti."
    },
    {
      "id": "sn3.24:3.9",
      "pali": "Idamavoca bhagavā …pe…"
    },
    {
      "id": "sn3.24:3.10",
      "pali": "satthā:"
    },
    {
      "id": "sn3.24:4.1",
      "pali": "“Issattaṁ balavīriyañca,"
    },
    {
      "id": "sn3.24:4.2",
      "pali": "yasmiṁ vijjetha māṇave;"
    },
    {
      "id": "sn3.24:4.3",
      "pali": "Taṁ yuddhattho bhare rājā,"
    },
    {
      "id": "sn3.24:4.4",
      "pali": "nāsūraṁ jātipaccayā."
    },
    {
      "id": "sn3.24:5.1",
      "pali": "Tatheva khantisoraccaṁ,"
    },
    {
      "id": "sn3.24:5.2",
      "pali": "dhammā yasmiṁ patiṭṭhitā;"
    },
    {
      "id": "sn3.24:5.3",
      "pali": "Ariyavuttiṁ medhāviṁ,"
    },
    {
      "id": "sn3.24:5.4",
      "pali": "hīnajaccampi pūjaye."
    },
    {
      "id": "sn3.24:6.1",
      "pali": "Kāraye assame ramme,"
    },
    {
      "id": "sn3.24:6.2",
      "pali": "vāsayettha bahussute;"
    },
    {
      "id": "sn3.24:6.3",
      "pali": "Papañca vivane kayirā,"
    },
    {
      "id": "sn3.24:6.4",
      "pali": "dugge saṅkamanāni ca."
    },
    {
      "id": "sn3.24:7.1",
      "pali": "Annaṁ pānaṁ khādanīyaṁ,"
    },
    {
      "id": "sn3.24:7.2",
      "pali": "vatthasenāsanāni ca;"
    },
    {
      "id": "sn3.24:7.3",
      "pali": "Dadeyya ujubhūtesu,"
    },
    {
      "id": "sn3.24:7.4",
      "pali": "vippasannena cetasā."
    },
    {
      "id": "sn3.24:8.1",
      "pali": "Yathā hi megho thanayaṁ,"
    },
    {
      "id": "sn3.24:8.2",
      "pali": "vijjumālī satakkaku;"
    },
    {
      "id": "sn3.24:8.3",
      "pali": "Thalaṁ ninnañca pūreti,"
    },
    {
      "id": "sn3.24:8.4",
      "pali": "abhivassaṁ vasundharaṁ."
    },
    {
      "id": "sn3.24:9.1",
      "pali": "Tatheva saddho sutavā,"
    },
    {
      "id": "sn3.24:9.2",
      "pali": "abhisaṅkhacca bhojanaṁ;"
    },
    {
      "id": "sn3.24:9.3",
      "pali": "Vanibbake tappayati,"
    },
    {
      "id": "sn3.24:9.4",
      "pali": "annapānena paṇḍito."
    },
    {
      "id": "sn3.24:10.1",
      "pali": "Āmodamāno pakireti,"
    },
    {
      "id": "sn3.24:10.2",
      "pali": "detha dethāti bhāsati;"
    },
    {
      "id": "sn3.24:10.3",
      "pali": "Taṁ hissa gajjitaṁ hoti,"
    },
    {
      "id": "sn3.24:10.4",
      "pali": "devasseva pavassato;"
    },
    {
      "id": "sn3.24:10.5",
      "pali": "Sā puññadhārā vipulā,"
    },
    {
      "id": "sn3.24:10.6",
      "pali": "dātāraṁ abhivassatī”ti."
    }
  ]
}
