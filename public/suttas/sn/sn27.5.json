{
  "uid": "sn27.5",
  "title": "Samphassajasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.5:1.2",
      "pali": "“Yo, bhikkhave, cakkhusamphassajāya vedanāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.5:1.3",
      "pali": "Yo sotasamphassajāya vedanāya …"
    },
    {
      "id": "sn27.5:1.4",
      "pali": "yo ghānasamphassajāya vedanāya …"
    },
    {
      "id": "sn27.5:1.5",
      "pali": "yo jivhāsamphassajāya vedanāya …"
    },
    {
      "id": "sn27.5:1.6",
      "pali": "yo kāyasamphassajāya vedanāya …"
    },
    {
      "id": "sn27.5:1.7",
      "pali": "yo manosamphassajāya vedanāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.5:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno …pe…"
    },
    {
      "id": "sn27.5:1.9",
      "pali": "abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.5:1.10",
      "pali": "Pañcamaṁ."
    }
  ]
}
