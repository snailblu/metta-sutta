{
  "uid": "sn43.2",
  "title": "Samathavipassanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.2:1.1",
      "pali": "“Asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.2:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.2:1.3",
      "pali": "Katamañca, bhikkhave, asaṅkhataṁ?"
    },
    {
      "id": "sn43.2:1.4",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn43.2:1.5",
      "pali": "idaṁ vuccati, bhikkhave, asaṅkhataṁ."
    },
    {
      "id": "sn43.2:1.6",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.2:1.7",
      "pali": "Samatho ca vipassanā ca."
    },
    {
      "id": "sn43.2:1.8",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.2:1.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
