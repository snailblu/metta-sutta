{
  "uid": "sn22.65",
  "title": "Abhinandamānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.65:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.65:1.2",
      "pali": "Atha kho aññataro bhikkhu …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.65:1.3",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena …pe… pahitatto vihareyyan”ti."
    },
    {
      "id": "sn22.65:1.4",
      "pali": "“Abhinandamāno kho, bhikkhu, baddho mārassa;"
    },
    {
      "id": "sn22.65:1.5",
      "pali": "anabhinandamāno mutto pāpimato”ti."
    },
    {
      "id": "sn22.65:1.6",
      "pali": "“Aññātaṁ, bhagavā, aññātaṁ, sugatā”ti."
    },
    {
      "id": "sn22.65:2.1",
      "pali": "“Yathā kathaṁ pana tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsī”ti?"
    },
    {
      "id": "sn22.65:2.2",
      "pali": "“Rūpaṁ kho, bhante, abhinandamāno baddho mārassa;"
    },
    {
      "id": "sn22.65:2.3",
      "pali": "anabhinandamāno mutto pāpimato."
    },
    {
      "id": "sn22.65:2.4",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.65:2.5",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.65:2.6",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.65:2.7",
      "pali": "viññāṇaṁ abhinandamāno baddho mārassa;"
    },
    {
      "id": "sn22.65:2.8",
      "pali": "anabhinandamāno mutto pāpimato."
    },
    {
      "id": "sn22.65:2.9",
      "pali": "Imassa khvāhaṁ, bhante, bhagavatā saṅkhittena bhāsitassa evaṁ vitthārena atthaṁ ājānāmī”ti."
    },
    {
      "id": "sn22.65:3.1",
      "pali": "“Sādhu sādhu, bhikkhu."
    },
    {
      "id": "sn22.65:3.2",
      "pali": "Sādhu kho tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsi."
    },
    {
      "id": "sn22.65:3.3",
      "pali": "Rūpaṁ kho, bhikkhu, abhinandamāno baddho mārassa;"
    },
    {
      "id": "sn22.65:3.4",
      "pali": "anabhinandamāno mutto pāpimato."
    },
    {
      "id": "sn22.65:3.5",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.65:3.6",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.65:3.7",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.65:3.8",
      "pali": "viññāṇaṁ abhinandamāno baddho mārassa;"
    },
    {
      "id": "sn22.65:3.9",
      "pali": "anabhinandamāno mutto pāpimato."
    },
    {
      "id": "sn22.65:3.10",
      "pali": "Imassa kho, bhikkhu, mayā saṅkhittena bhāsitassa evaṁ vitthārena attho daṭṭhabbo”ti …pe…"
    },
    {
      "id": "sn22.65:3.11",
      "pali": "aññataro ca pana so bhikkhu arahataṁ ahosīti."
    },
    {
      "id": "sn22.65:3.12",
      "pali": "Tatiyaṁ."
    }
  ]
}
