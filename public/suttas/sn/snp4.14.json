{
  "uid": "snp4.14",
  "title": "Tuvaṭakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.14:1.1",
      "pali": "“Pucchāmi taṁ ādiccabandhu,"
    },
    {
      "id": "snp4.14:1.2",
      "pali": "Vivekaṁ santipadañca mahesi;"
    },
    {
      "id": "snp4.14:1.3",
      "pali": "Kathaṁ disvā nibbāti bhikkhu,"
    },
    {
      "id": "snp4.14:1.4",
      "pali": "Anupādiyāno lokasmiṁ kiñci”."
    },
    {
      "id": "snp4.14:2.1",
      "pali": "“Mūlaṁ papañcasaṅkhāya,"
    },
    {
      "id": "snp4.14:2.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp4.14:2.3",
      "pali": "Mantā asmīti sabbamuparundhe;"
    },
    {
      "id": "snp4.14:2.4",
      "pali": "Yā kāci taṇhā ajjhattaṁ,"
    },
    {
      "id": "snp4.14:2.5",
      "pali": "Tāsaṁ vinayā sadā sato sikkhe."
    },
    {
      "id": "snp4.14:3.1",
      "pali": "Yaṁ kiñci dhammamabhijaññā,"
    },
    {
      "id": "snp4.14:3.2",
      "pali": "Ajjhattaṁ atha vāpi bahiddhā;"
    },
    {
      "id": "snp4.14:3.3",
      "pali": "Na tena thāmaṁ kubbetha,"
    },
    {
      "id": "snp4.14:3.4",
      "pali": "Na hi sā nibbuti sataṁ vuttā."
    },
    {
      "id": "snp4.14:4.1",
      "pali": "Seyyo na tena maññeyya,"
    },
    {
      "id": "snp4.14:4.2",
      "pali": "Nīceyyo atha vāpi sarikkho;"
    },
    {
      "id": "snp4.14:4.3",
      "pali": "Phuṭṭho anekarūpehi,"
    },
    {
      "id": "snp4.14:4.4",
      "pali": "Nātumānaṁ vikappayaṁ tiṭṭhe."
    },
    {
      "id": "snp4.14:5.1",
      "pali": "Ajjhattamevupasame,"
    },
    {
      "id": "snp4.14:5.2",
      "pali": "Na aññato bhikkhu santimeseyya;"
    },
    {
      "id": "snp4.14:5.3",
      "pali": "Ajjhattaṁ upasantassa,"
    },
    {
      "id": "snp4.14:5.4",
      "pali": "Natthi attā kuto nirattā vā."
    },
    {
      "id": "snp4.14:6.1",
      "pali": "Majjhe yathā samuddassa,"
    },
    {
      "id": "snp4.14:6.2",
      "pali": "Ūmi no jāyatī ṭhito hoti;"
    },
    {
      "id": "snp4.14:6.3",
      "pali": "Evaṁ ṭhito anejassa,"
    },
    {
      "id": "snp4.14:6.4",
      "pali": "Ussadaṁ bhikkhu na kareyya kuhiñci”."
    },
    {
      "id": "snp4.14:7.1",
      "pali": "“Akittayī vivaṭacakkhu,"
    },
    {
      "id": "snp4.14:7.2",
      "pali": "Sakkhidhammaṁ parissayavinayaṁ;"
    },
    {
      "id": "snp4.14:7.3",
      "pali": "Paṭipadaṁ vadehi bhaddante,"
    },
    {
      "id": "snp4.14:7.4",
      "pali": "Pātimokkhaṁ atha vāpi samādhiṁ”."
    },
    {
      "id": "snp4.14:8.1",
      "pali": "“Cakkhūhi neva lolassa,"
    },
    {
      "id": "snp4.14:8.2",
      "pali": "Gāmakathāya āvaraye sotaṁ;"
    },
    {
      "id": "snp4.14:8.3",
      "pali": "Rase ca nānugijjheyya,"
    },
    {
      "id": "snp4.14:8.4",
      "pali": "Na ca mamāyetha kiñci lokasmiṁ."
    },
    {
      "id": "snp4.14:9.1",
      "pali": "Phassena yadā phuṭṭhassa,"
    },
    {
      "id": "snp4.14:9.2",
      "pali": "Paridevaṁ bhikkhu na kareyya kuhiñci;"
    },
    {
      "id": "snp4.14:9.3",
      "pali": "Bhavañca nābhijappeyya,"
    },
    {
      "id": "snp4.14:9.4",
      "pali": "Bheravesu ca na sampavedheyya."
    },
    {
      "id": "snp4.14:10.1",
      "pali": "Annānamatho pānānaṁ,"
    },
    {
      "id": "snp4.14:10.2",
      "pali": "Khādanīyānaṁ athopi vatthānaṁ;"
    },
    {
      "id": "snp4.14:10.3",
      "pali": "Laddhā na sannidhiṁ kayirā,"
    },
    {
      "id": "snp4.14:10.4",
      "pali": "Na ca parittase tāni alabhamāno."
    },
    {
      "id": "snp4.14:11.1",
      "pali": "Jhāyī na pādalolassa,"
    },
    {
      "id": "snp4.14:11.2",
      "pali": "Virame kukkuccā nappamajjeyya;"
    },
    {
      "id": "snp4.14:11.3",
      "pali": "Athāsanesu sayanesu,"
    },
    {
      "id": "snp4.14:11.4",
      "pali": "Appasaddesu bhikkhu vihareyya."
    },
    {
      "id": "snp4.14:12.1",
      "pali": "Niddaṁ na bahulīkareyya,"
    },
    {
      "id": "snp4.14:12.2",
      "pali": "Jāgariyaṁ bhajeyya ātāpī;"
    },
    {
      "id": "snp4.14:12.3",
      "pali": "Tandiṁ māyaṁ hassaṁ khiḍḍaṁ,"
    },
    {
      "id": "snp4.14:12.4",
      "pali": "Methunaṁ vippajahe savibhūsaṁ."
    },
    {
      "id": "snp4.14:13.1",
      "pali": "Āthabbaṇaṁ supinaṁ lakkhaṇaṁ,"
    },
    {
      "id": "snp4.14:13.2",
      "pali": "No vidahe athopi nakkhattaṁ;"
    },
    {
      "id": "snp4.14:13.3",
      "pali": "Virutañca gabbhakaraṇaṁ,"
    },
    {
      "id": "snp4.14:13.4",
      "pali": "Tikicchaṁ māmako na seveyya."
    },
    {
      "id": "snp4.14:14.1",
      "pali": "Nindāya nappavedheyya,"
    },
    {
      "id": "snp4.14:14.2",
      "pali": "Na uṇṇameyya pasaṁsito bhikkhu;"
    },
    {
      "id": "snp4.14:14.3",
      "pali": "Lobhaṁ saha macchariyena,"
    },
    {
      "id": "snp4.14:14.4",
      "pali": "Kodhaṁ pesuṇiyañca panudeyya."
    },
    {
      "id": "snp4.14:15.1",
      "pali": "Kayavikkaye na tiṭṭheyya,"
    },
    {
      "id": "snp4.14:15.2",
      "pali": "Upavādaṁ bhikkhu na kareyya kuhiñci;"
    },
    {
      "id": "snp4.14:15.3",
      "pali": "Gāme ca nābhisajjeyya,"
    },
    {
      "id": "snp4.14:15.4",
      "pali": "Lābhakamyā janaṁ na lapayeyya."
    },
    {
      "id": "snp4.14:16.1",
      "pali": "Na ca katthitā siyā bhikkhu,"
    },
    {
      "id": "snp4.14:16.2",
      "pali": "Na ca vācaṁ payuttaṁ bhāseyya;"
    },
    {
      "id": "snp4.14:16.3",
      "pali": "Pāgabbhiyaṁ na sikkheyya,"
    },
    {
      "id": "snp4.14:16.4",
      "pali": "Kathaṁ viggāhikaṁ na kathayeyya."
    },
    {
      "id": "snp4.14:17.1",
      "pali": "Mosavajje na nīyetha,"
    },
    {
      "id": "snp4.14:17.2",
      "pali": "Sampajāno saṭhāni na kayirā;"
    },
    {
      "id": "snp4.14:17.3",
      "pali": "Atha jīvitena paññāya,"
    },
    {
      "id": "snp4.14:17.4",
      "pali": "Sīlabbatena nāññamatimaññe."
    },
    {
      "id": "snp4.14:18.1",
      "pali": "Sutvā rusito bahuṁ vācaṁ,"
    },
    {
      "id": "snp4.14:18.2",
      "pali": "Samaṇānaṁ vā puthujanānaṁ;"
    },
    {
      "id": "snp4.14:18.3",
      "pali": "Pharusena ne na paṭivajjā,"
    },
    {
      "id": "snp4.14:18.4",
      "pali": "Na hi santo paṭisenikaronti."
    },
    {
      "id": "snp4.14:19.1",
      "pali": "Etañca dhammamaññāya,"
    },
    {
      "id": "snp4.14:19.2",
      "pali": "Vicinaṁ bhikkhu sadā sato sikkhe;"
    },
    {
      "id": "snp4.14:19.3",
      "pali": "Santīti nibbutiṁ ñatvā,"
    },
    {
      "id": "snp4.14:19.4",
      "pali": "Sāsane gotamassa na pamajjeyya."
    },
    {
      "id": "snp4.14:20.1",
      "pali": "Abhibhū hi so anabhibhūto,"
    },
    {
      "id": "snp4.14:20.2",
      "pali": "Sakkhidhammamanītihamadassī;"
    },
    {
      "id": "snp4.14:20.3",
      "pali": "Tasmā hi tassa bhagavato sāsane,"
    },
    {
      "id": "snp4.14:20.4",
      "pali": "Appamatto sadā namassamanusikkhe”ti."
    },
    {
      "id": "snp4.14:20.5",
      "pali": "Tuvaṭakasuttaṁ cuddasamaṁ."
    }
  ]
}
