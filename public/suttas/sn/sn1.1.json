{
  "uid": "sn1.1",
  "title": "Oghataraṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.1:1.3",
      "pali": "Atha kho aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn1.1:1.4",
      "pali": "“kathaṁ nu tvaṁ, mārisa, oghamatarī”ti?"
    },
    {
      "id": "sn1.1:1.5",
      "pali": "“Appatiṭṭhaṁ khvāhaṁ, āvuso, anāyūhaṁ oghamatarin”ti."
    },
    {
      "id": "sn1.1:1.6",
      "pali": "“Yathākathaṁ pana tvaṁ, mārisa, appatiṭṭhaṁ anāyūhaṁ oghamatarī”ti?"
    },
    {
      "id": "sn1.1:1.7",
      "pali": "“Yadāsvāhaṁ, āvuso, santiṭṭhāmi tadāssu saṁsīdāmi;"
    },
    {
      "id": "sn1.1:1.8",
      "pali": "yadāsvāhaṁ, āvuso, āyūhāmi tadāssu nibbuyhāmi."
    },
    {
      "id": "sn1.1:1.9",
      "pali": "Evaṁ khvāhaṁ, āvuso, appatiṭṭhaṁ anāyūhaṁ oghamatarin”ti."
    },
    {
      "id": "sn1.1:2.1",
      "pali": "“Cirassaṁ vata passāmi,"
    },
    {
      "id": "sn1.1:2.2",
      "pali": "brāhmaṇaṁ parinibbutaṁ;"
    },
    {
      "id": "sn1.1:2.3",
      "pali": "Appatiṭṭhaṁ anāyūhaṁ,"
    },
    {
      "id": "sn1.1:2.4",
      "pali": "tiṇṇaṁ loke visattikan”ti."
    },
    {
      "id": "sn1.1:3.1",
      "pali": "Idamavoca sā devatā."
    },
    {
      "id": "sn1.1:3.2",
      "pali": "Samanuñño satthā ahosi."
    },
    {
      "id": "sn1.1:3.3",
      "pali": "Atha kho sā devatā:"
    },
    {
      "id": "sn1.1:3.4",
      "pali": "“samanuñño me satthā”ti bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā tatthevantaradhāyīti."
    }
  ]
}
