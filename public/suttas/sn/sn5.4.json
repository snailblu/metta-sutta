{
  "uid": "sn5.4",
  "title": "Vijayāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.4:1.2",
      "pali": "Atha kho vijayā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.4:1.3",
      "pali": "aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.4:1.4",
      "pali": "Atha kho māro pāpimā vijayāya bhikkhuniyā bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo yena vijayā bhikkhunī tenupasaṅkami; upasaṅkamitvā vijayaṁ bhikkhuniṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn5.4:2.1",
      "pali": "“Daharā tvaṁ rūpavatī,"
    },
    {
      "id": "sn5.4:2.2",
      "pali": "ahañca daharo susu;"
    },
    {
      "id": "sn5.4:2.3",
      "pali": "Pañcaṅgikena turiyena,"
    },
    {
      "id": "sn5.4:2.4",
      "pali": "ehayyebhiramāmase”ti."
    },
    {
      "id": "sn5.4:3.1",
      "pali": "Atha kho vijayāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.4:3.2",
      "pali": "“ko nu khvāyaṁ manusso vā amanusso vā gāthaṁ bhāsatī”ti?"
    },
    {
      "id": "sn5.4:3.3",
      "pali": "Atha kho vijayāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.4:3.4",
      "pali": "“māro kho ayaṁ pāpimā mama bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo gāthaṁ bhāsatī”ti."
    },
    {
      "id": "sn5.4:3.5",
      "pali": "Atha kho vijayā bhikkhunī “māro ayaṁ pāpimā” iti viditvā māraṁ pāpimantaṁ gāthāhi paccabhāsi:"
    },
    {
      "id": "sn5.4:4.1",
      "pali": "“Rūpā saddā rasā gandhā,"
    },
    {
      "id": "sn5.4:4.2",
      "pali": "phoṭṭhabbā ca manoramā;"
    },
    {
      "id": "sn5.4:4.3",
      "pali": "Niyyātayāmi tuyheva,"
    },
    {
      "id": "sn5.4:4.4",
      "pali": "māra nāhaṁ tenatthikā."
    },
    {
      "id": "sn5.4:5.1",
      "pali": "Iminā pūtikāyena,"
    },
    {
      "id": "sn5.4:5.2",
      "pali": "bhindanena pabhaṅgunā;"
    },
    {
      "id": "sn5.4:5.3",
      "pali": "Aṭṭīyāmi harāyāmi,"
    },
    {
      "id": "sn5.4:5.4",
      "pali": "kāmataṇhā samūhatā."
    },
    {
      "id": "sn5.4:6.1",
      "pali": "Ye ca rūpūpagā sattā,"
    },
    {
      "id": "sn5.4:6.2",
      "pali": "ye ca arūpaṭṭhāyino;"
    },
    {
      "id": "sn5.4:6.3",
      "pali": "Yā ca santā samāpatti,"
    },
    {
      "id": "sn5.4:6.4",
      "pali": "sabbattha vihato tamo”ti."
    },
    {
      "id": "sn5.4:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ vijayā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
