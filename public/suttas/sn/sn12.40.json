{
  "uid": "sn12.40",
  "title": "Tatiyacetanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.40:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.40:1.2",
      "pali": "“Yañca, bhikkhave, ceteti yañca pakappeti yañca anuseti ārammaṇametaṁ hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.40:1.3",
      "pali": "Ārammaṇe sati patiṭṭhā viññāṇassa hoti."
    },
    {
      "id": "sn12.40:1.4",
      "pali": "Tasmiṁ patiṭṭhite viññāṇe virūḷhe nati hoti."
    },
    {
      "id": "sn12.40:1.5",
      "pali": "Natiyā sati āgatigati hoti."
    },
    {
      "id": "sn12.40:1.6",
      "pali": "Āgatigatiyā sati cutūpapāto hoti."
    },
    {
      "id": "sn12.40:1.7",
      "pali": "Cutūpapāte sati āyatiṁ jāti jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.40:1.8",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.40:2.1",
      "pali": "No ce, bhikkhave, ceteti no ce pakappeti atha ce anuseti, ārammaṇametaṁ hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.40:2.2",
      "pali": "Ārammaṇe sati patiṭṭhā viññāṇassa hoti."
    },
    {
      "id": "sn12.40:2.3",
      "pali": "Tasmiṁ patiṭṭhite viññāṇe virūḷhe nati hoti."
    },
    {
      "id": "sn12.40:2.4",
      "pali": "Natiyā sati āgatigati hoti."
    },
    {
      "id": "sn12.40:2.5",
      "pali": "Āgatigatiyā sati cutūpapāto hoti."
    },
    {
      "id": "sn12.40:2.6",
      "pali": "Cutūpapāte sati āyatiṁ jāti jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.40:2.7",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.40:3.1",
      "pali": "Yato ca kho, bhikkhave, no ceva ceteti no ca pakappeti no ca anuseti, ārammaṇametaṁ na hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.40:3.2",
      "pali": "Ārammaṇe asati patiṭṭhā viññāṇassa na hoti."
    },
    {
      "id": "sn12.40:3.3",
      "pali": "Tadappatiṭṭhite viññāṇe avirūḷhe nati na hoti."
    },
    {
      "id": "sn12.40:3.4",
      "pali": "Natiyā asati āgatigati na hoti."
    },
    {
      "id": "sn12.40:3.5",
      "pali": "Āgatigatiyā asati cutūpapāto na hoti."
    },
    {
      "id": "sn12.40:3.6",
      "pali": "Cutūpapāte asati āyatiṁ jāti jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.40:3.7",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.40:3.8",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn12.40:3.9",
      "pali": "Kaḷārakhattiyavaggo catuttho."
    },
    {
      "id": "sn12.40:4.1",
      "pali": "Bhūtamidaṁ kaḷārañca,"
    },
    {
      "id": "sn12.40:4.2",
      "pali": "duve ca ñāṇavatthūni;"
    },
    {
      "id": "sn12.40:4.3",
      "pali": "Avijjāpaccayā ca dve,"
    },
    {
      "id": "sn12.40:4.4",
      "pali": "natumhā cetanā tayoti."
    }
  ]
}
