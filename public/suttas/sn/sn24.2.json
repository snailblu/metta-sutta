{
  "uid": "sn24.2",
  "title": "Etaṁmamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.2:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.2:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.2:1.3",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn24.2:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.2:1.5",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.2:1.6",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’ti."
    },
    {
      "id": "sn24.2:1.7",
      "pali": "Vedanāya sati …pe…"
    },
    {
      "id": "sn24.2:1.8",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.2:1.9",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.2:1.10",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.2:1.11",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’ti."
    },
    {
      "id": "sn24.2:2.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn24.2:2.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.2:2.3",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.2:2.4",
      "pali": "“vedanā …"
    },
    {
      "id": "sn24.2:2.5",
      "pali": "saññā …"
    },
    {
      "id": "sn24.2:2.6",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.2:2.7",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.2:2.8",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.2:2.9",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.2:2.10",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn24.2:2.11",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.2:2.12",
      "pali": "“Yampidaṁ diṭṭhaṁ sutaṁ mutaṁ viññātaṁ pattaṁ pariyesitaṁ anuvicaritaṁ manasā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.2:2.13",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn24.2:2.14",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn24.2:2.15",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn24.2:2.16",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.2:2.17",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn24.2:2.18",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.2:3.1",
      "pali": "“Yato kho, bhikkhave, ariyasāvakassa imesu ca ṭhānesu kaṅkhā pahīnā hoti, dukkhepissa kaṅkhā pahīnā hoti …pe… dukkhanirodhagāminiyā paṭipadāyapissa kaṅkhā pahīnā hoti—"
    },
    {
      "id": "sn24.2:3.2",
      "pali": "ayaṁ vuccati, bhikkhave, ariyasāvako sotāpanno avinipātadhammo niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.2:3.3",
      "pali": "Dutiyaṁ."
    }
  ]
}
