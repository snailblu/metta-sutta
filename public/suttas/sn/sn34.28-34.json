{
  "uid": "sn34.28-34",
  "title": "Vuṭṭhānamūlakakallitasuttādisattaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.28-34:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn34.28-34:1.2",
      "pali": "“Cattārome, bhikkhave, jhāyī."
    },
    {
      "id": "sn34.28-34:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn34.28-34:1.4",
      "pali": "Idha, bhikkhave, ekacco jhāyī samādhismiṁ vuṭṭhānakusalo hoti, na samādhismiṁ kallitakusalo …"
    },
    {
      "id": "sn34.28-34:1.5",
      "pali": "samādhismiṁ kallitakusalo hoti, na samādhismiṁ vuṭṭhānakusalo …"
    },
    {
      "id": "sn34.28-34:1.6",
      "pali": "neva samādhismiṁ vuṭṭhānakusalo hoti, na ca samādhismiṁ kallitakusalo …"
    },
    {
      "id": "sn34.28-34:1.7",
      "pali": "samādhismiṁ vuṭṭhānakusalo ca hoti samādhismiṁ kallitakusalo ca."
    },
    {
      "id": "sn34.28-34:1.8",
      "pali": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe…"
    },
    {
      "id": "sn34.28-34:1.9",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.28-34:1.10",
      "pali": "Aṭṭhavīsatimaṁ."
    },
    {
      "id": "sn34.28-34:1.11",
      "pali": "(Purimamūlakāni viya yāva catuttiṁsatimā vuṭṭhānamūlakasappāyakārīsuttā satta suttāni pūretabbāni.)"
    },
    {
      "id": "sn34.28-34:1.12",
      "pali": "(Vuṭṭhānamūlakaṁ.)"
    }
  ]
}
