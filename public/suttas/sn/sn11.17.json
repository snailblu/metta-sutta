{
  "uid": "sn11.17",
  "title": "Buddhavandanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.17:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.17:1.2",
      "pali": "Tena kho pana samayena bhagavā divāvihāragato hoti paṭisallīno."
    },
    {
      "id": "sn11.17:1.3",
      "pali": "Atha kho sakko ca devānamindo brahmā ca sahampati yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā paccekaṁ dvārabāhaṁ nissāya aṭṭhaṁsu."
    },
    {
      "id": "sn11.17:1.4",
      "pali": "Atha kho sakko devānamindo bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.17:2.1",
      "pali": "“Uṭṭhehi vīra vijitasaṅgāma,"
    },
    {
      "id": "sn11.17:2.2",
      "pali": "Pannabhāra anaṇa vicara loke;"
    },
    {
      "id": "sn11.17:2.3",
      "pali": "Cittañca te suvimuttaṁ,"
    },
    {
      "id": "sn11.17:2.4",
      "pali": "Cando yathā pannarasāya rattin”ti."
    },
    {
      "id": "sn11.17:3.1",
      "pali": "“Na kho, devānaminda, tathāgatā evaṁ vanditabbā."
    },
    {
      "id": "sn11.17:3.2",
      "pali": "Evañca kho, devānaminda, tathāgatā vanditabbā:"
    },
    {
      "id": "sn11.17:4.1",
      "pali": "‘Uṭṭhehi vīra vijitasaṅgāma,"
    },
    {
      "id": "sn11.17:4.2",
      "pali": "Satthavāha anaṇa vicara loke;"
    },
    {
      "id": "sn11.17:4.3",
      "pali": "Desassu bhagavā dhammaṁ,"
    },
    {
      "id": "sn11.17:4.4",
      "pali": "Aññātāro bhavissantī’”ti."
    }
  ]
}
