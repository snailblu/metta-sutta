{
  "uid": "sn35.98",
  "title": "Saṁvarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.98:1.1",
      "pali": "“Saṁvarañca vo, bhikkhave, desessāmi, asaṁvarañca."
    },
    {
      "id": "sn35.98:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.98:1.3",
      "pali": "Kathañca, bhikkhave, asaṁvaro hoti?"
    },
    {
      "id": "sn35.98:1.4",
      "pali": "Santi, bhikkhave, cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.98:1.5",
      "pali": "Tañce bhikkhu abhinandati abhivadati ajjhosāya tiṭṭhati, veditabbametaṁ, bhikkhave, bhikkhunā:"
    },
    {
      "id": "sn35.98:1.6",
      "pali": "‘parihāyāmi kusalehi dhammehi."
    },
    {
      "id": "sn35.98:1.7",
      "pali": "Parihānañhetaṁ vuttaṁ bhagavatā’ti …pe…"
    },
    {
      "id": "sn35.98:1.8",
      "pali": "santi, bhikkhave, jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn35.98:1.9",
      "pali": "santi, bhikkhave, manoviññeyyā dhammā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.98:1.10",
      "pali": "Tañce bhikkhu abhinandati abhivadati ajjhosāya tiṭṭhati, veditabbametaṁ, bhikkhave, bhikkhunā:"
    },
    {
      "id": "sn35.98:1.11",
      "pali": "‘parihāyāmi kusalehi dhammehi."
    },
    {
      "id": "sn35.98:1.12",
      "pali": "Parihānañhetaṁ vuttaṁ bhagavatā’ti."
    },
    {
      "id": "sn35.98:1.13",
      "pali": "Evaṁ kho, bhikkhave, asaṁvaro hoti."
    },
    {
      "id": "sn35.98:2.1",
      "pali": "Kathañca, bhikkhave, saṁvaro hoti?"
    },
    {
      "id": "sn35.98:2.2",
      "pali": "Santi, bhikkhave, cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.98:2.3",
      "pali": "Tañce bhikkhu nābhinandati nābhivadati nājjhosāya tiṭṭhati, veditabbametaṁ, bhikkhave, bhikkhunā:"
    },
    {
      "id": "sn35.98:2.4",
      "pali": "‘na parihāyāmi kusalehi dhammehi."
    },
    {
      "id": "sn35.98:2.5",
      "pali": "Aparihānañhetaṁ vuttaṁ bhagavatā’ti …pe…"
    },
    {
      "id": "sn35.98:2.6",
      "pali": "santi, bhikkhave, jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn35.98:2.7",
      "pali": "santi, bhikkhave, manoviññeyyā dhammā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.98:2.8",
      "pali": "Tañce bhikkhu nābhinandati nābhivadati nājjhosāya tiṭṭhati, veditabbametaṁ bhikkhunā:"
    },
    {
      "id": "sn35.98:2.9",
      "pali": "‘na parihāyāmi kusalehi dhammehi."
    },
    {
      "id": "sn35.98:2.10",
      "pali": "Aparihānañhetaṁ vuttaṁ bhagavatā’ti."
    },
    {
      "id": "sn35.98:2.11",
      "pali": "Evaṁ kho, bhikkhave, saṁvaro hotī”ti."
    },
    {
      "id": "sn35.98:2.12",
      "pali": "Pañcamaṁ."
    }
  ]
}
