{
  "uid": "sn23.18",
  "title": "Anattadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.18:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.18:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.18:1.3",
      "pali": "“‘anattadhammo, anattadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.18:1.4",
      "pali": "Katamo nu kho, bhante, anattadhammo”ti?"
    },
    {
      "id": "sn23.18:1.5",
      "pali": "“Rūpaṁ kho, rādha, anattadhammo, vedanā anattadhammo, saññā anattadhammo, saṅkhārā anattadhammo, viññāṇaṁ anattadhammo."
    },
    {
      "id": "sn23.18:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.18:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.18:1.8",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
