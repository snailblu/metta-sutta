{
  "uid": "snp1.1",
  "title": "Uragasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp1.1:1.1",
      "pali": "Yo uppatitaṁ vineti kodhaṁ,"
    },
    {
      "id": "snp1.1:1.2",
      "pali": "Visaṭaṁ sappavisaṁva osadhehi;"
    },
    {
      "id": "snp1.1:1.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:1.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:2.1",
      "pali": "Yo rāgamudacchidā asesaṁ,"
    },
    {
      "id": "snp1.1:2.2",
      "pali": "Bhisapupphaṁva saroruhaṁ vigayha;"
    },
    {
      "id": "snp1.1:2.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:2.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:3.1",
      "pali": "Yo taṇhamudacchidā asesaṁ,"
    },
    {
      "id": "snp1.1:3.2",
      "pali": "Saritaṁ sīghasaraṁ visosayitvā;"
    },
    {
      "id": "snp1.1:3.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:3.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:4.1",
      "pali": "Yo mānamudabbadhī asesaṁ,"
    },
    {
      "id": "snp1.1:4.2",
      "pali": "Naḷasetuṁva sudubbalaṁ mahogho;"
    },
    {
      "id": "snp1.1:4.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:4.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:5.1",
      "pali": "Yo nājjhagamā bhavesu sāraṁ,"
    },
    {
      "id": "snp1.1:5.2",
      "pali": "Vicinaṁ pupphamivā udumbaresu;"
    },
    {
      "id": "snp1.1:5.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:5.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:6.1",
      "pali": "Yassantarato na santi kopā,"
    },
    {
      "id": "snp1.1:6.2",
      "pali": "Itibhavābhavatañca vītivatto;"
    },
    {
      "id": "snp1.1:6.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:6.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:7.1",
      "pali": "Yassa vitakkā vidhūpitā,"
    },
    {
      "id": "snp1.1:7.2",
      "pali": "Ajjhattaṁ suvikappitā asesā;"
    },
    {
      "id": "snp1.1:7.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:7.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:8.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:8.2",
      "pali": "Sabbaṁ accagamā imaṁ papañcaṁ;"
    },
    {
      "id": "snp1.1:8.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:8.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:9.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:9.2",
      "pali": "Sabbaṁ vitathamidanti ñatva loke;"
    },
    {
      "id": "snp1.1:9.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:9.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:10.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:10.2",
      "pali": "Sabbaṁ vitathamidanti vītalobho;"
    },
    {
      "id": "snp1.1:10.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:10.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:11.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:11.2",
      "pali": "Sabbaṁ vitathamidanti vītarāgo;"
    },
    {
      "id": "snp1.1:11.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:11.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:12.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:12.2",
      "pali": "Sabbaṁ vitathamidanti vītadoso;"
    },
    {
      "id": "snp1.1:12.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:12.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:13.1",
      "pali": "Yo nāccasārī na paccasārī,"
    },
    {
      "id": "snp1.1:13.2",
      "pali": "Sabbaṁ vitathamidanti vītamoho;"
    },
    {
      "id": "snp1.1:13.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:13.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:14.1",
      "pali": "Yassānusayā na santi keci,"
    },
    {
      "id": "snp1.1:14.2",
      "pali": "Mūlā ca akusalā samūhatāse;"
    },
    {
      "id": "snp1.1:14.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:14.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:15.1",
      "pali": "Yassa darathajā na santi keci,"
    },
    {
      "id": "snp1.1:15.2",
      "pali": "Oraṁ āgamanāya paccayāse;"
    },
    {
      "id": "snp1.1:15.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:15.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:16.1",
      "pali": "Yassa vanathajā na santi keci,"
    },
    {
      "id": "snp1.1:16.2",
      "pali": "Vinibandhāya bhavāya hetukappā;"
    },
    {
      "id": "snp1.1:16.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:16.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇaṁ."
    },
    {
      "id": "snp1.1:17.1",
      "pali": "Yo nīvaraṇe pahāya pañca,"
    },
    {
      "id": "snp1.1:17.2",
      "pali": "Anigho tiṇṇakathaṅkatho visallo;"
    },
    {
      "id": "snp1.1:17.3",
      "pali": "So bhikkhu jahāti orapāraṁ,"
    },
    {
      "id": "snp1.1:17.4",
      "pali": "Urago jiṇṇamivattacaṁ purāṇanti."
    },
    {
      "id": "snp1.1:17.5",
      "pali": "Uragasuttaṁ paṭhamaṁ."
    }
  ]
}
