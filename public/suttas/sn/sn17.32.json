{
  "uid": "sn17.32",
  "title": "Kusalamūlasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.32:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.32:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko."
    },
    {
      "id": "sn17.32:1.3",
      "pali": "Lābhasakkārasilokena abhibhūtassa pariyādiṇṇacittassa, bhikkhave, devadattassa kusalamūlaṁ samucchedamagamā."
    },
    {
      "id": "sn17.32:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.32:1.5",
      "pali": "sikkhitabban”ti."
    },
    {
      "id": "sn17.32:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
