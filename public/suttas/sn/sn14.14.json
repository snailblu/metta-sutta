{
  "uid": "sn14.14",
  "title": "Hīnādhimuttikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.14:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.14:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.14:1.3",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.14:1.4",
      "pali": "kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.14:2.1",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.14:2.2",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.14:2.3",
      "pali": "kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.14:3.1",
      "pali": "Anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti."
    },
    {
      "id": "sn14.14:3.2",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandissanti samessanti;"
    },
    {
      "id": "sn14.14:3.3",
      "pali": "kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandissanti samessanti."
    },
    {
      "id": "sn14.14:4.1",
      "pali": "Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.14:4.2",
      "pali": "Hīnādhimuttikā hīnādhimuttikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.14:4.3",
      "pali": "kalyāṇādhimuttikā kalyāṇādhimuttikehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.14:4.4",
      "pali": "Catutthaṁ."
    }
  ]
}
