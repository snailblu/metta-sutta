{
  "uid": "sn1.33",
  "title": "Sādhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.33:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.33:1.2",
      "pali": "Atha kho sambahulā satullapakāyikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.33:1.3",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:2.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:2.2",
      "pali": "maccherā ca pamādā ca;"
    },
    {
      "id": "sn1.33:2.3",
      "pali": "Evaṁ dānaṁ na dīyati,"
    },
    {
      "id": "sn1.33:2.4",
      "pali": "puññaṁ ākaṅkhamānena;"
    },
    {
      "id": "sn1.33:2.5",
      "pali": "Deyyaṁ hoti vijānatā”ti."
    },
    {
      "id": "sn1.33:3.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:4.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:4.2",
      "pali": "Api ca appakasmimpi sāhu dānaṁ."
    },
    {
      "id": "sn1.33:5.1",
      "pali": "Appasmeke pavecchanti,"
    },
    {
      "id": "sn1.33:5.2",
      "pali": "bahuneke na dicchare;"
    },
    {
      "id": "sn1.33:5.3",
      "pali": "Appasmā dakkhiṇā dinnā,"
    },
    {
      "id": "sn1.33:5.4",
      "pali": "sahassena samaṁ mitā”ti."
    },
    {
      "id": "sn1.33:6.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:7.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:7.2",
      "pali": "Appakasmimpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:7.3",
      "pali": "Api ca saddhāyapi sāhu dānaṁ,"
    },
    {
      "id": "sn1.33:7.4",
      "pali": "Dānañca yuddhañca samānamāhu;"
    },
    {
      "id": "sn1.33:7.5",
      "pali": "Appāpi santā bahuke jinanti,"
    },
    {
      "id": "sn1.33:7.6",
      "pali": "Appampi ce saddahāno dadāti;"
    },
    {
      "id": "sn1.33:7.7",
      "pali": "Teneva so hoti sukhī paratthā”ti."
    },
    {
      "id": "sn1.33:8.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:9.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:9.2",
      "pali": "Appakasmimpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:9.3",
      "pali": "Saddhāyapi sāhu dānaṁ,"
    },
    {
      "id": "sn1.33:9.4",
      "pali": "Api ca dhammaladdhassāpi sāhu dānaṁ."
    },
    {
      "id": "sn1.33:10.1",
      "pali": "Yo dhammaladdhassa dadāti dānaṁ,"
    },
    {
      "id": "sn1.33:10.2",
      "pali": "Uṭṭhānavīriyādhigatassa jantu;"
    },
    {
      "id": "sn1.33:10.3",
      "pali": "Atikkamma so vetaraṇiṁ yamassa,"
    },
    {
      "id": "sn1.33:10.4",
      "pali": "Dibbāni ṭhānāni upeti macco”ti."
    },
    {
      "id": "sn1.33:11.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:12.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:12.2",
      "pali": "Appakasmimpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:12.3",
      "pali": "Saddhāyapi sāhu dānaṁ,"
    },
    {
      "id": "sn1.33:12.4",
      "pali": "Dhammaladdhassāpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:12.5",
      "pali": "Api ca viceyya dānampi sāhu dānaṁ."
    },
    {
      "id": "sn1.33:13.1",
      "pali": "Viceyya dānaṁ sugatappasatthaṁ,"
    },
    {
      "id": "sn1.33:13.2",
      "pali": "Ye dakkhiṇeyyā idha jīvaloke;"
    },
    {
      "id": "sn1.33:13.3",
      "pali": "Etesu dinnāni mahapphalāni,"
    },
    {
      "id": "sn1.33:13.4",
      "pali": "Bījāni vuttāni yathā sukhette”ti."
    },
    {
      "id": "sn1.33:14.1",
      "pali": "Atha kho aparā devatā bhagavato santike imaṁ udānaṁ udānesi:"
    },
    {
      "id": "sn1.33:15.1",
      "pali": "“Sādhu kho mārisa dānaṁ,"
    },
    {
      "id": "sn1.33:15.2",
      "pali": "Appakasmimpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:15.3",
      "pali": "Saddhāyapi sāhu dānaṁ,"
    },
    {
      "id": "sn1.33:15.4",
      "pali": "Dhammaladdhassāpi sāhu dānaṁ;"
    },
    {
      "id": "sn1.33:15.5",
      "pali": "Viceyya dānampi sāhu dānaṁ,"
    },
    {
      "id": "sn1.33:15.6",
      "pali": "Api ca pāṇesupi sādhu saṁyamo."
    },
    {
      "id": "sn1.33:16.1",
      "pali": "Yo pāṇabhūtāni aheṭhayaṁ caraṁ,"
    },
    {
      "id": "sn1.33:16.2",
      "pali": "Parūpavādā na karonti pāpaṁ;"
    },
    {
      "id": "sn1.33:16.3",
      "pali": "Bhīruṁ pasaṁsanti na hi tattha sūraṁ,"
    },
    {
      "id": "sn1.33:16.4",
      "pali": "Bhayā hi santo na karonti pāpan”ti."
    },
    {
      "id": "sn1.33:17.1",
      "pali": "Atha kho aparā devatā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn1.33:17.2",
      "pali": "“kassa nu kho, bhagavā, subhāsitan”ti?"
    },
    {
      "id": "sn1.33:18.1",
      "pali": "“Sabbāsaṁ vo subhāsitaṁ pariyāyena, api ca mamapi suṇātha—"
    },
    {
      "id": "sn1.33:19.1",
      "pali": "Saddhā hi dānaṁ bahudhā pasatthaṁ,"
    },
    {
      "id": "sn1.33:19.2",
      "pali": "Dānā ca kho dhammapadaṁva seyyo;"
    },
    {
      "id": "sn1.33:19.3",
      "pali": "Pubbe ca hi pubbatare ca santo,"
    },
    {
      "id": "sn1.33:19.4",
      "pali": "Nibbānamevajjhagamuṁ sapaññā”ti."
    }
  ]
}
