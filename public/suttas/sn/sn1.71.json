{
  "uid": "sn1.71",
  "title": "Chetvāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.71:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.71:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn1.71:2.1",
      "pali": "“Kiṁsu chetvā sukhaṁ seti,"
    },
    {
      "id": "sn1.71:2.2",
      "pali": "kiṁsu chetvā na socati;"
    },
    {
      "id": "sn1.71:2.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn1.71:2.4",
      "pali": "vadhaṁ rocesi gotamā”ti."
    },
    {
      "id": "sn1.71:3.1",
      "pali": "“Kodhaṁ chetvā sukhaṁ seti,"
    },
    {
      "id": "sn1.71:3.2",
      "pali": "kodhaṁ chetvā na socati;"
    },
    {
      "id": "sn1.71:3.3",
      "pali": "Kodhassa visamūlassa,"
    },
    {
      "id": "sn1.71:3.4",
      "pali": "madhuraggassa devate;"
    },
    {
      "id": "sn1.71:3.5",
      "pali": "Vadhaṁ ariyā pasaṁsanti,"
    },
    {
      "id": "sn1.71:3.6",
      "pali": "tañhi chetvā na socatī”ti."
    }
  ]
}
