{
  "uid": "sn35.22",
  "title": "Dutiyadukkhuppādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.22:1.1",
      "pali": "“Yo, bhikkhave, rūpānaṁ uppādo ṭhiti abhinibbatti pātubhāvo, dukkhasseso uppādo, rogānaṁ ṭhiti, jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn35.22:1.2",
      "pali": "Yo saddānaṁ …pe…"
    },
    {
      "id": "sn35.22:1.3",
      "pali": "yo gandhānaṁ …"
    },
    {
      "id": "sn35.22:1.4",
      "pali": "yo rasānaṁ …"
    },
    {
      "id": "sn35.22:1.5",
      "pali": "yo phoṭṭhabbānaṁ …"
    },
    {
      "id": "sn35.22:1.6",
      "pali": "yo dhammānaṁ uppādo ṭhiti abhinibbatti pātubhāvo, dukkhasseso uppādo, rogānaṁ ṭhiti, jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn35.22:2.1",
      "pali": "Yo ca kho, bhikkhave, rūpānaṁ nirodho vūpasamo atthaṅgamo, dukkhasseso nirodho, rogānaṁ vūpasamo, jarāmaraṇassa atthaṅgamo."
    },
    {
      "id": "sn35.22:2.2",
      "pali": "Yo saddānaṁ …pe…"
    },
    {
      "id": "sn35.22:2.3",
      "pali": "yo gandhānaṁ …"
    },
    {
      "id": "sn35.22:2.4",
      "pali": "yo rasānaṁ …"
    },
    {
      "id": "sn35.22:2.5",
      "pali": "yo phoṭṭhabbānaṁ …"
    },
    {
      "id": "sn35.22:2.6",
      "pali": "yo dhammānaṁ nirodho vūpasamo atthaṅgamo, dukkhasseso nirodho, rogānaṁ vūpasamo, jarāmaraṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn35.22:2.7",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.22:2.8",
      "pali": "Yamakavaggo dutiyo."
    },
    {
      "id": "sn35.22:3.1",
      "pali": "Sambodhena duve vuttā,"
    },
    {
      "id": "sn35.22:3.2",
      "pali": "Assādena apare duve;"
    },
    {
      "id": "sn35.22:3.3",
      "pali": "No cetena duve vuttā,"
    },
    {
      "id": "sn35.22:3.4",
      "pali": "Abhinandena apare duve;"
    },
    {
      "id": "sn35.22:3.5",
      "pali": "Uppādena duve vuttā,"
    },
    {
      "id": "sn35.22:3.6",
      "pali": "Vaggo tena pavuccatīti."
    }
  ]
}
