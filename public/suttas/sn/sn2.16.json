{
  "uid": "sn2.16",
  "title": "Vāsudattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.16:1.1",
      "pali": "Ekamantaṁ ṭhito kho vāsudatto devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.16:2.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "sn2.16:2.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "sn2.16:2.3",
      "pali": "Kāmarāgappahānāya,"
    },
    {
      "id": "sn2.16:2.4",
      "pali": "sato bhikkhu paribbaje”ti."
    },
    {
      "id": "sn2.16:3.1",
      "pali": "“Sattiyā viya omaṭṭho,"
    },
    {
      "id": "sn2.16:3.2",
      "pali": "ḍayhamānova matthake;"
    },
    {
      "id": "sn2.16:3.3",
      "pali": "Sakkāyadiṭṭhippahānāya,"
    },
    {
      "id": "sn2.16:3.4",
      "pali": "sato bhikkhu paribbaje”ti."
    }
  ]
}
