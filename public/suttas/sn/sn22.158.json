{
  "uid": "sn22.158",
  "title": "Dutiyaabhinivesasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.158:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.158:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhājjhosānā”ti?"
    },
    {
      "id": "sn22.158:1.3",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.158:1.4",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhājjhosānā."
    },
    {
      "id": "sn22.158:1.5",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn22.158:1.6",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn22.158:1.7",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn22.158:1.8",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa uppajjanti saṁyojanābhinivesavinibandhājjhosānā."
    },
    {
      "id": "sn22.158:1.9",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.158:1.10",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.158:1.11",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.158:1.12",
      "pali": "“Yaṁ panāniccaṁ …pe…"
    },
    {
      "id": "sn22.158:1.13",
      "pali": "api nu taṁ anupādāya uppajjeyyuṁ saṁyojanābhinivesavinibandhājjhosānā”ti?"
    },
    {
      "id": "sn22.158:1.14",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.158:1.15",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.158:1.16",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.158:1.17",
      "pali": "Navamaṁ."
    }
  ]
}
