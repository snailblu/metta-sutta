{
  "uid": "snp4.15",
  "title": "Attadaṇḍasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.15:1.1",
      "pali": "“Attadaṇḍā bhayaṁ jātaṁ,"
    },
    {
      "id": "snp4.15:1.2",
      "pali": "janaṁ passatha medhagaṁ;"
    },
    {
      "id": "snp4.15:1.3",
      "pali": "Saṁvegaṁ kittayissāmi,"
    },
    {
      "id": "snp4.15:1.4",
      "pali": "yathā saṁvijitaṁ mayā."
    },
    {
      "id": "snp4.15:2.1",
      "pali": "Phandamānaṁ pajaṁ disvā,"
    },
    {
      "id": "snp4.15:2.2",
      "pali": "macche appodake yathā;"
    },
    {
      "id": "snp4.15:2.3",
      "pali": "Aññamaññehi byāruddhe,"
    },
    {
      "id": "snp4.15:2.4",
      "pali": "disvā maṁ bhayamāvisi."
    },
    {
      "id": "snp4.15:3.1",
      "pali": "Samantamasāro loko,"
    },
    {
      "id": "snp4.15:3.2",
      "pali": "disā sabbā sameritā;"
    },
    {
      "id": "snp4.15:3.3",
      "pali": "Icchaṁ bhavanamattano,"
    },
    {
      "id": "snp4.15:3.4",
      "pali": "nāddasāsiṁ anositaṁ."
    },
    {
      "id": "snp4.15:4.1",
      "pali": "Osāne tveva byāruddhe,"
    },
    {
      "id": "snp4.15:4.2",
      "pali": "Disvā me aratī ahu;"
    },
    {
      "id": "snp4.15:4.3",
      "pali": "Athettha sallamaddakkhiṁ,"
    },
    {
      "id": "snp4.15:4.4",
      "pali": "Duddasaṁ hadayanissitaṁ."
    },
    {
      "id": "snp4.15:5.1",
      "pali": "Yena sallena otiṇṇo,"
    },
    {
      "id": "snp4.15:5.2",
      "pali": "disā sabbā vidhāvati;"
    },
    {
      "id": "snp4.15:5.3",
      "pali": "Tameva sallamabbuyha,"
    },
    {
      "id": "snp4.15:5.4",
      "pali": "na dhāvati na sīdati."
    },
    {
      "id": "snp4.15:6.1",
      "pali": "Tattha sikkhānugīyanti,"
    },
    {
      "id": "snp4.15:6.2",
      "pali": "yāni loke gadhitāni;"
    },
    {
      "id": "snp4.15:6.3",
      "pali": "Na tesu pasuto siyā,"
    },
    {
      "id": "snp4.15:6.4",
      "pali": "nibbijjha sabbaso kāme;"
    },
    {
      "id": "snp4.15:6.5",
      "pali": "Sikkhe nibbānamattano."
    },
    {
      "id": "snp4.15:7.1",
      "pali": "Sacco siyā appagabbho,"
    },
    {
      "id": "snp4.15:7.2",
      "pali": "amāyo rittapesuṇo;"
    },
    {
      "id": "snp4.15:7.3",
      "pali": "Akkodhano lobhapāpaṁ,"
    },
    {
      "id": "snp4.15:7.4",
      "pali": "vevicchaṁ vitare muni."
    },
    {
      "id": "snp4.15:8.1",
      "pali": "Niddaṁ tandiṁ sahe thīnaṁ,"
    },
    {
      "id": "snp4.15:8.2",
      "pali": "pamādena na saṁvase;"
    },
    {
      "id": "snp4.15:8.3",
      "pali": "Atimāne na tiṭṭheyya,"
    },
    {
      "id": "snp4.15:8.4",
      "pali": "nibbānamanaso naro."
    },
    {
      "id": "snp4.15:9.1",
      "pali": "Mosavajje na nīyetha,"
    },
    {
      "id": "snp4.15:9.2",
      "pali": "rūpe snehaṁ na kubbaye;"
    },
    {
      "id": "snp4.15:9.3",
      "pali": "Mānañca parijāneyya,"
    },
    {
      "id": "snp4.15:9.4",
      "pali": "sāhasā virato care."
    },
    {
      "id": "snp4.15:10.1",
      "pali": "Purāṇaṁ nābhinandeyya,"
    },
    {
      "id": "snp4.15:10.2",
      "pali": "Nave khantiṁ na kubbaye;"
    },
    {
      "id": "snp4.15:10.3",
      "pali": "Hiyyamāne na soceyya,"
    },
    {
      "id": "snp4.15:10.4",
      "pali": "Ākāsaṁ na sito siyā."
    },
    {
      "id": "snp4.15:11.1",
      "pali": "Gedhaṁ brūmi mahoghoti,"
    },
    {
      "id": "snp4.15:11.2",
      "pali": "Ājavaṁ brūmi jappanaṁ;"
    },
    {
      "id": "snp4.15:11.3",
      "pali": "Ārammaṇaṁ pakappanaṁ,"
    },
    {
      "id": "snp4.15:11.4",
      "pali": "Kāmapaṅko duraccayo."
    },
    {
      "id": "snp4.15:12.1",
      "pali": "Saccā avokkamma muni,"
    },
    {
      "id": "snp4.15:12.2",
      "pali": "Thale tiṭṭhati brāhmaṇo;"
    },
    {
      "id": "snp4.15:12.3",
      "pali": "Sabbaṁ so paṭinissajja,"
    },
    {
      "id": "snp4.15:12.4",
      "pali": "Sa ve santoti vuccati."
    },
    {
      "id": "snp4.15:13.1",
      "pali": "Sa ve vidvā sa vedagū,"
    },
    {
      "id": "snp4.15:13.2",
      "pali": "Ñatvā dhammaṁ anissito;"
    },
    {
      "id": "snp4.15:13.3",
      "pali": "Sammā so loke iriyāno,"
    },
    {
      "id": "snp4.15:13.4",
      "pali": "Na pihetīdha kassaci."
    },
    {
      "id": "snp4.15:14.1",
      "pali": "Yodha kāme accatari,"
    },
    {
      "id": "snp4.15:14.2",
      "pali": "Saṅgaṁ loke duraccayaṁ;"
    },
    {
      "id": "snp4.15:14.3",
      "pali": "Na so socati nājjheti,"
    },
    {
      "id": "snp4.15:14.4",
      "pali": "Chinnasoto abandhano."
    },
    {
      "id": "snp4.15:15.1",
      "pali": "Yaṁ pubbe taṁ visosehi,"
    },
    {
      "id": "snp4.15:15.2",
      "pali": "Pacchā te māhu kiñcanaṁ;"
    },
    {
      "id": "snp4.15:15.3",
      "pali": "Majjhe ce no gahessasi,"
    },
    {
      "id": "snp4.15:15.4",
      "pali": "Upasanto carissasi."
    },
    {
      "id": "snp4.15:16.1",
      "pali": "Sabbaso nāmarūpasmiṁ,"
    },
    {
      "id": "snp4.15:16.2",
      "pali": "Yassa natthi mamāyitaṁ;"
    },
    {
      "id": "snp4.15:16.3",
      "pali": "Asatā ca na socati,"
    },
    {
      "id": "snp4.15:16.4",
      "pali": "Sa ve loke na jīyati."
    },
    {
      "id": "snp4.15:17.1",
      "pali": "Yassa natthi idaṁ meti,"
    },
    {
      "id": "snp4.15:17.2",
      "pali": "Paresaṁ vāpi kiñcanaṁ;"
    },
    {
      "id": "snp4.15:17.3",
      "pali": "Mamattaṁ so asaṁvindaṁ,"
    },
    {
      "id": "snp4.15:17.4",
      "pali": "Natthi meti na socati."
    },
    {
      "id": "snp4.15:18.1",
      "pali": "Aniṭṭhurī ananugiddho,"
    },
    {
      "id": "snp4.15:18.2",
      "pali": "Anejo sabbadhī samo;"
    },
    {
      "id": "snp4.15:18.3",
      "pali": "Tamānisaṁsaṁ pabrūmi,"
    },
    {
      "id": "snp4.15:18.4",
      "pali": "Pucchito avikampinaṁ."
    },
    {
      "id": "snp4.15:19.1",
      "pali": "Anejassa vijānato,"
    },
    {
      "id": "snp4.15:19.2",
      "pali": "Natthi kāci nisaṅkhati;"
    },
    {
      "id": "snp4.15:19.3",
      "pali": "Virato so viyārabbhā,"
    },
    {
      "id": "snp4.15:19.4",
      "pali": "Khemaṁ passati sabbadhi."
    },
    {
      "id": "snp4.15:20.1",
      "pali": "Na samesu na omesu,"
    },
    {
      "id": "snp4.15:20.2",
      "pali": "Na ussesu vadate muni;"
    },
    {
      "id": "snp4.15:20.3",
      "pali": "Santo so vītamaccharo,"
    },
    {
      "id": "snp4.15:20.4",
      "pali": "Nādeti na nirassatī”ti."
    },
    {
      "id": "snp4.15:20.5",
      "pali": "Attadaṇḍasuttaṁ pannarasamaṁ."
    }
  ]
}
