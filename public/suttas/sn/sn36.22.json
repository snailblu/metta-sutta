{
  "uid": "sn36.22",
  "title": "Aṭṭhasatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.22:1.1",
      "pali": "“Aṭṭhasatapariyāyaṁ vo, bhikkhave, dhammapariyāyaṁ desessāmi."
    },
    {
      "id": "sn36.22:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn36.22:1.3",
      "pali": "Katamo ca, bhikkhave, aṭṭhasatapariyāyo, dhammapariyāyo?"
    },
    {
      "id": "sn36.22:1.4",
      "pali": "Dvepi mayā, bhikkhave, vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.5",
      "pali": "tissopi mayā vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.6",
      "pali": "pañcapi mayā vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.7",
      "pali": "chapi mayā vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.8",
      "pali": "aṭṭhārasāpi mayā vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.9",
      "pali": "chattiṁsāpi mayā vedanā vuttā pariyāyena;"
    },
    {
      "id": "sn36.22:1.10",
      "pali": "aṭṭhasatampi mayā vedanā vuttā pariyāyena."
    },
    {
      "id": "sn36.22:2.1",
      "pali": "Katamā ca, bhikkhave, dve vedanā?"
    },
    {
      "id": "sn36.22:2.2",
      "pali": "Kāyikā ca cetasikā ca—"
    },
    {
      "id": "sn36.22:2.3",
      "pali": "imā vuccanti, bhikkhave, dve vedanā."
    },
    {
      "id": "sn36.22:2.4",
      "pali": "Katamā ca, bhikkhave, tisso vedanā?"
    },
    {
      "id": "sn36.22:2.5",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn36.22:2.6",
      "pali": "imā vuccanti, bhikkhave, tisso vedanā."
    },
    {
      "id": "sn36.22:2.7",
      "pali": "Katamā ca, bhikkhave, pañca vedanā?"
    },
    {
      "id": "sn36.22:2.8",
      "pali": "Sukhindriyaṁ, dukkhindriyaṁ, somanassindriyaṁ, domanassindriyaṁ, upekkhindriyaṁ—"
    },
    {
      "id": "sn36.22:2.9",
      "pali": "imā vuccanti, bhikkhave, pañca vedanā."
    },
    {
      "id": "sn36.22:2.10",
      "pali": "Katamā ca, bhikkhave, cha vedanā?"
    },
    {
      "id": "sn36.22:2.11",
      "pali": "Cakkhusamphassajā vedanā …pe…"
    },
    {
      "id": "sn36.22:2.12",
      "pali": "manosamphassajā vedanā—"
    },
    {
      "id": "sn36.22:2.13",
      "pali": "imā vuccanti, bhikkhave, cha vedanā."
    },
    {
      "id": "sn36.22:2.14",
      "pali": "Katamā ca, bhikkhave, aṭṭhārasa vedanā?"
    },
    {
      "id": "sn36.22:2.15",
      "pali": "Cha somanassūpavicārā, cha domanassūpavicārā, cha upekkhūpavicārā—"
    },
    {
      "id": "sn36.22:2.16",
      "pali": "imā vuccanti, bhikkhave, aṭṭhārasa vedanā."
    },
    {
      "id": "sn36.22:2.17",
      "pali": "Katamā ca, bhikkhave, chattiṁsa vedanā?"
    },
    {
      "id": "sn36.22:2.18",
      "pali": "Cha gehasitāni somanassāni, cha nekkhammasitāni somanassāni, cha gehasitāni domanassāni, cha nekkhammasitāni domanassāni, cha gehasitā upekkhā, cha nekkhammasitā upekkhā—"
    },
    {
      "id": "sn36.22:2.19",
      "pali": "imā vuccanti, bhikkhave, chattiṁsa vedanā."
    },
    {
      "id": "sn36.22:2.20",
      "pali": "Katamañca, bhikkhave, aṭṭhasataṁ vedanā?"
    },
    {
      "id": "sn36.22:2.21",
      "pali": "Atītā chattiṁsa vedanā, anāgatā chattiṁsa vedanā, paccuppannā chattiṁsa vedanā—"
    },
    {
      "id": "sn36.22:2.22",
      "pali": "imā vuccanti, bhikkhave, aṭṭhasataṁ vedanā."
    },
    {
      "id": "sn36.22:2.23",
      "pali": "Ayaṁ, bhikkhave, aṭṭhasatapariyāyo dhammapariyāyo”ti."
    },
    {
      "id": "sn36.22:2.24",
      "pali": "Dutiyaṁ."
    }
  ]
}
