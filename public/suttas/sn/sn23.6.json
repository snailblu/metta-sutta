{
  "uid": "sn23.6",
  "title": "Dutiyasamaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.6:1.2",
      "pali": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ rādhaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn23.6:1.3",
      "pali": "“pañcime, rādha, upādānakkhandhā."
    },
    {
      "id": "sn23.6:1.4",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn23.6:1.5",
      "pali": "Rūpupādānakkhandho …pe… viññāṇupādānakkhandho."
    },
    {
      "id": "sn23.6:1.6",
      "pali": "Ye hi keci, rādha, samaṇā vā brāhmaṇā vā imesaṁ pañcannaṁ upādānakkhandhānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe…"
    },
    {
      "id": "sn23.6:1.7",
      "pali": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn23.6:1.8",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
