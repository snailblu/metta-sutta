{
  "uid": "sn10.12",
  "title": "Āḷavakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.12:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn10.12:1.2",
      "pali": "ekaṁ samayaṁ bhagavā āḷaviyaṁ viharati āḷavakassa yakkhassa bhavane."
    },
    {
      "id": "sn10.12:1.3",
      "pali": "Atha kho āḷavako yakkho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn10.12:1.4",
      "pali": "“nikkhama, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.5",
      "pali": "“Sādhāvuso”ti bhagavā nikkhami."
    },
    {
      "id": "sn10.12:1.6",
      "pali": "“Pavisa, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.7",
      "pali": "“Sādhāvuso”ti bhagavā pāvisi."
    },
    {
      "id": "sn10.12:1.8",
      "pali": "Dutiyampi kho āḷavako yakkho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn10.12:1.9",
      "pali": "“nikkhama, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.10",
      "pali": "“Sādhāvuso”ti bhagavā nikkhami."
    },
    {
      "id": "sn10.12:1.11",
      "pali": "“Pavisa, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.12",
      "pali": "“Sādhāvuso”ti bhagavā pāvisi."
    },
    {
      "id": "sn10.12:1.13",
      "pali": "Tatiyampi kho āḷavako yakkho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn10.12:1.14",
      "pali": "“nikkhama, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.15",
      "pali": "“Sādhāvuso”ti bhagavā nikkhami."
    },
    {
      "id": "sn10.12:1.16",
      "pali": "“Pavisa, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.17",
      "pali": "“Sādhāvuso”ti bhagavā pāvisi."
    },
    {
      "id": "sn10.12:1.18",
      "pali": "Catutthampi kho āḷavako yakkho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn10.12:1.19",
      "pali": "“nikkhama, samaṇā”ti."
    },
    {
      "id": "sn10.12:1.20",
      "pali": "“Na khvāhaṁ taṁ, āvuso, nikkhamissāmi."
    },
    {
      "id": "sn10.12:1.21",
      "pali": "Yaṁ te karaṇīyaṁ taṁ karohī”ti."
    },
    {
      "id": "sn10.12:1.22",
      "pali": "“Pañhaṁ taṁ, samaṇa, pucchissāmi."
    },
    {
      "id": "sn10.12:1.23",
      "pali": "Sace me na byākarissasi, cittaṁ vā te khipissāmi, hadayaṁ vā te phālessāmi, pādesu vā gahetvā pāragaṅgāya khipissāmī”ti."
    },
    {
      "id": "sn10.12:1.24",
      "pali": "“Na khvāhaṁ taṁ, āvuso, passāmi sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya, yo me cittaṁ vā khipeyya hadayaṁ vā phāleyya, pādesu vā gahetvā pāragaṅgāya khipeyya."
    },
    {
      "id": "sn10.12:1.25",
      "pali": "Api ca tvaṁ, āvuso, puccha yadā kaṅkhasī”ti (…)."
    },
    {
      "id": "sn10.12:2.1",
      "pali": "“Kiṁsūdha vittaṁ purisassa seṭṭhaṁ,"
    },
    {
      "id": "sn10.12:2.2",
      "pali": "Kiṁsu suciṇṇaṁ sukhamāvahāti;"
    },
    {
      "id": "sn10.12:2.3",
      "pali": "Kiṁsu have sādutaraṁ rasānaṁ,"
    },
    {
      "id": "sn10.12:2.4",
      "pali": "Kathaṁjīviṁ jīvitamāhu seṭṭhan”ti."
    },
    {
      "id": "sn10.12:3.1",
      "pali": "“Saddhīdha vittaṁ purisassa seṭṭhaṁ,"
    },
    {
      "id": "sn10.12:3.2",
      "pali": "Dhammo suciṇṇo sukhamāvahāti;"
    },
    {
      "id": "sn10.12:3.3",
      "pali": "Saccaṁ have sādutaraṁ rasānaṁ,"
    },
    {
      "id": "sn10.12:3.4",
      "pali": "Paññājīviṁ jīvitamāhu seṭṭhan”ti."
    },
    {
      "id": "sn10.12:4.1",
      "pali": "“Kathaṁsu tarati oghaṁ,"
    },
    {
      "id": "sn10.12:4.2",
      "pali": "kathaṁsu tarati aṇṇavaṁ;"
    },
    {
      "id": "sn10.12:4.3",
      "pali": "Kathaṁsu dukkhamacceti,"
    },
    {
      "id": "sn10.12:4.4",
      "pali": "kathaṁsu parisujjhatī”ti."
    },
    {
      "id": "sn10.12:5.1",
      "pali": "“Saddhāya tarati oghaṁ,"
    },
    {
      "id": "sn10.12:5.2",
      "pali": "appamādena aṇṇavaṁ;"
    },
    {
      "id": "sn10.12:5.3",
      "pali": "Vīriyena dukkhamacceti,"
    },
    {
      "id": "sn10.12:5.4",
      "pali": "paññāya parisujjhatī”ti."
    },
    {
      "id": "sn10.12:6.1",
      "pali": "“Kathaṁsu labhate paññaṁ,"
    },
    {
      "id": "sn10.12:6.2",
      "pali": "kathaṁsu vindate dhanaṁ;"
    },
    {
      "id": "sn10.12:6.3",
      "pali": "Kathaṁsu kittiṁ pappoti,"
    },
    {
      "id": "sn10.12:6.4",
      "pali": "kathaṁ mittāni ganthati;"
    },
    {
      "id": "sn10.12:6.5",
      "pali": "Asmā lokā paraṁ lokaṁ,"
    },
    {
      "id": "sn10.12:6.6",
      "pali": "kathaṁ pecca na socatī”ti."
    },
    {
      "id": "sn10.12:7.1",
      "pali": "“Saddahāno arahataṁ,"
    },
    {
      "id": "sn10.12:7.2",
      "pali": "dhammaṁ nibbānapattiyā;"
    },
    {
      "id": "sn10.12:7.3",
      "pali": "Sussūsaṁ labhate paññaṁ,"
    },
    {
      "id": "sn10.12:7.4",
      "pali": "appamatto vicakkhaṇo."
    },
    {
      "id": "sn10.12:8.1",
      "pali": "Patirūpakārī dhuravā,"
    },
    {
      "id": "sn10.12:8.2",
      "pali": "uṭṭhātā vindate dhanaṁ;"
    },
    {
      "id": "sn10.12:8.3",
      "pali": "Saccena kittiṁ pappoti,"
    },
    {
      "id": "sn10.12:8.4",
      "pali": "dadaṁ mittāni ganthati;"
    },
    {
      "id": "sn10.12:8.5",
      "pali": "Asmā lokā paraṁ lokaṁ,"
    },
    {
      "id": "sn10.12:8.6",
      "pali": "evaṁ pecca na socati."
    },
    {
      "id": "sn10.12:9.1",
      "pali": "Yassete caturo dhammā,"
    },
    {
      "id": "sn10.12:9.2",
      "pali": "saddhassa gharamesino;"
    },
    {
      "id": "sn10.12:9.3",
      "pali": "Saccaṁ dhammo dhiti cāgo,"
    },
    {
      "id": "sn10.12:9.4",
      "pali": "sa ve pecca na socati."
    },
    {
      "id": "sn10.12:10.1",
      "pali": "Iṅgha aññepi pucchassu,"
    },
    {
      "id": "sn10.12:10.2",
      "pali": "puthū samaṇabrāhmaṇe;"
    },
    {
      "id": "sn10.12:10.3",
      "pali": "Yadi saccā dhammā cāgā,"
    },
    {
      "id": "sn10.12:10.4",
      "pali": "khantyā bhiyyodha vijjatī”ti."
    },
    {
      "id": "sn10.12:11.1",
      "pali": "“Kathaṁ nu dāni puccheyyaṁ,"
    },
    {
      "id": "sn10.12:11.2",
      "pali": "puthū samaṇabrāhmaṇe;"
    },
    {
      "id": "sn10.12:11.3",
      "pali": "Yohaṁ ajja pajānāmi,"
    },
    {
      "id": "sn10.12:11.4",
      "pali": "yo attho samparāyiko."
    },
    {
      "id": "sn10.12:12.1",
      "pali": "Atthāya vata me buddho,"
    },
    {
      "id": "sn10.12:12.2",
      "pali": "vāsāyāḷavimāgamā;"
    },
    {
      "id": "sn10.12:12.3",
      "pali": "Yohaṁ ajja pajānāmi,"
    },
    {
      "id": "sn10.12:12.4",
      "pali": "yattha dinnaṁ mahapphalaṁ."
    },
    {
      "id": "sn10.12:13.1",
      "pali": "So ahaṁ vicarissāmi,"
    },
    {
      "id": "sn10.12:13.2",
      "pali": "Gāmā gāmaṁ purā puraṁ;"
    },
    {
      "id": "sn10.12:13.3",
      "pali": "Namassamāno sambuddhaṁ,"
    },
    {
      "id": "sn10.12:13.4",
      "pali": "Dhammassa ca sudhammatan”ti."
    },
    {
      "id": "sn10.12:13.5",
      "pali": "Indakavaggo paṭhamo."
    },
    {
      "id": "sn10.12:14.1",
      "pali": "Indako sakka sūci ca,"
    },
    {
      "id": "sn10.12:14.2",
      "pali": "Maṇibhaddo ca sānu ca;"
    },
    {
      "id": "sn10.12:14.3",
      "pali": "Piyaṅkara punabbasu sudatto ca,"
    },
    {
      "id": "sn10.12:14.4",
      "pali": "Dve sukkā cīraāḷavīti dvādasa."
    },
    {
      "id": "sn10.12:14.5",
      "pali": "Yakkhasaṁyuttaṁ samattaṁ."
    }
  ]
}
