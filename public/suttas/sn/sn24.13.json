{
  "uid": "sn24.13",
  "title": "Taṁjīvaṁtaṁsarīraṁsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.13:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.13:1.3",
      "pali": "‘taṁ jīvaṁ taṁ sarīran’”ti?"
    },
    {
      "id": "sn24.13:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.13:1.5",
      "pali": "niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.13:1.6",
      "pali": "Terasamaṁ."
    }
  ]
}
