{
  "uid": "sn27.3",
  "title": "Viññāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.3:1.2",
      "pali": "“Yo, bhikkhave, cakkhuviññāṇasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.3:1.3",
      "pali": "Yo sotaviññāṇasmiṁ …"
    },
    {
      "id": "sn27.3:1.4",
      "pali": "yo ghānaviññāṇasmiṁ …"
    },
    {
      "id": "sn27.3:1.5",
      "pali": "yo jivhāviññāṇasmiṁ …"
    },
    {
      "id": "sn27.3:1.6",
      "pali": "yo kāyaviññāṇasmiṁ …"
    },
    {
      "id": "sn27.3:1.7",
      "pali": "yo manoviññāṇasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.3:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti."
    },
    {
      "id": "sn27.3:1.9",
      "pali": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.3:1.10",
      "pali": "Tatiyaṁ."
    }
  ]
}
