{
  "uid": "sn45.40",
  "title": "Dutiyabrahmacariyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.40:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.40:1.2",
      "pali": "“Brahmacariyañca vo, bhikkhave, desessāmi, brahmacariyatthañca."
    },
    {
      "id": "sn45.40:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.40:1.4",
      "pali": "Katamañca, bhikkhave, brahmacariyaṁ?"
    },
    {
      "id": "sn45.40:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.40:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.40:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, brahmacariyaṁ."
    },
    {
      "id": "sn45.40:1.8",
      "pali": "Katamo ca, bhikkhave, brahmacariyattho?"
    },
    {
      "id": "sn45.40:1.9",
      "pali": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.40:1.10",
      "pali": "ayaṁ vuccati, bhikkhave, brahmacariyattho”ti."
    },
    {
      "id": "sn45.40:1.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn45.40:1.12",
      "pali": "Paṭipattivaggo catuttho."
    },
    {
      "id": "sn45.40:2.1",
      "pali": "Paṭipatti paṭipanno ca,"
    },
    {
      "id": "sn45.40:2.2",
      "pali": "viraddhañca pāraṅgamā;"
    },
    {
      "id": "sn45.40:2.3",
      "pali": "Sāmaññena ca dve vuttā,"
    },
    {
      "id": "sn45.40:2.4",
      "pali": "brahmaññā apare duve;"
    },
    {
      "id": "sn45.40:2.5",
      "pali": "Brahmacariyena dve vuttā,"
    },
    {
      "id": "sn45.40:2.6",
      "pali": "vaggo tena pavuccatīti."
    }
  ]
}
