{
  "uid": "sn6.9",
  "title": "Turūbrahmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn6.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn6.9:1.2",
      "pali": "Tena kho pana samayena kokāliko bhikkhu ābādhiko hoti dukkhito bāḷhagilāno."
    },
    {
      "id": "sn6.9:1.3",
      "pali": "Atha kho turū paccekabrahmā abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena kokāliko bhikkhu tenupasaṅkami; upasaṅkamitvā vehāsaṁ ṭhito kokālikaṁ bhikkhuṁ etadavoca:"
    },
    {
      "id": "sn6.9:1.4",
      "pali": "“pasādehi, kokālika, sāriputtamoggallānesu cittaṁ."
    },
    {
      "id": "sn6.9:1.5",
      "pali": "Pesalā sāriputtamoggallānā”ti."
    },
    {
      "id": "sn6.9:1.6",
      "pali": "“Kosi tvaṁ, āvuso”ti?"
    },
    {
      "id": "sn6.9:1.7",
      "pali": "“Ahaṁ turū paccekabrahmā”ti."
    },
    {
      "id": "sn6.9:1.8",
      "pali": "“Nanu tvaṁ, āvuso, bhagavatā anāgāmī byākato, atha kiñcarahi idhāgato?"
    },
    {
      "id": "sn6.9:1.9",
      "pali": "Passa, yāvañca te idaṁ aparaddhan”ti."
    },
    {
      "id": "sn6.9:2.1",
      "pali": "“Purisassa hi jātassa,"
    },
    {
      "id": "sn6.9:2.2",
      "pali": "kuṭhārī jāyate mukhe;"
    },
    {
      "id": "sn6.9:2.3",
      "pali": "Yāya chindati attānaṁ,"
    },
    {
      "id": "sn6.9:2.4",
      "pali": "bālo dubbhāsitaṁ bhaṇaṁ."
    },
    {
      "id": "sn6.9:3.1",
      "pali": "Yo nindiyaṁ pasaṁsati,"
    },
    {
      "id": "sn6.9:3.2",
      "pali": "Taṁ vā nindati yo pasaṁsiyo;"
    },
    {
      "id": "sn6.9:3.3",
      "pali": "Vicināti mukhena so kaliṁ,"
    },
    {
      "id": "sn6.9:3.4",
      "pali": "Kalinā tena sukhaṁ na vindati."
    },
    {
      "id": "sn6.9:4.1",
      "pali": "Appamattako ayaṁ kali,"
    },
    {
      "id": "sn6.9:4.2",
      "pali": "Yo akkhesu dhanaparājayo;"
    },
    {
      "id": "sn6.9:4.3",
      "pali": "Sabbassāpi sahāpi attanā,"
    },
    {
      "id": "sn6.9:4.4",
      "pali": "Ayameva mahantataro kali;"
    },
    {
      "id": "sn6.9:4.5",
      "pali": "Yo sugatesu manaṁ padosaye."
    },
    {
      "id": "sn6.9:5.1",
      "pali": "Sataṁ sahassānaṁ nirabbudānaṁ,"
    },
    {
      "id": "sn6.9:5.2",
      "pali": "Chattiṁsati pañca ca abbudāni;"
    },
    {
      "id": "sn6.9:5.3",
      "pali": "Yamariyagarahī nirayaṁ upeti,"
    },
    {
      "id": "sn6.9:5.4",
      "pali": "Vācaṁ manañca paṇidhāya pāpakan”ti."
    }
  ]
}
