{
  "uid": "sn21.12",
  "title": "Sahāyakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn21.12:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn21.12:1.2",
      "pali": "Atha kho dve bhikkhū sahāyakā āyasmato mahākappinassa saddhivihārino yena bhagavā tenupasaṅkamiṁsu."
    },
    {
      "id": "sn21.12:1.3",
      "pali": "Addasā kho bhagavā te bhikkhū dūratova āgacchante."
    },
    {
      "id": "sn21.12:1.4",
      "pali": "Disvāna bhikkhū āmantesi:"
    },
    {
      "id": "sn21.12:1.5",
      "pali": "“passatha no tumhe, bhikkhave, ete bhikkhū sahāyake āgacchante kappinassa saddhivihārino”ti?"
    },
    {
      "id": "sn21.12:1.6",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn21.12:1.7",
      "pali": "“Ete kho te bhikkhū mahiddhikā mahānubhāvā."
    },
    {
      "id": "sn21.12:1.8",
      "pali": "Na ca sā samāpatti sulabharūpā, yā tehi bhikkhūhi asamāpannapubbā."
    },
    {
      "id": "sn21.12:1.9",
      "pali": "Yassa catthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti tadanuttaraṁ brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn21.12:2.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn21.12:2.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn21.12:3.1",
      "pali": "“Sahāyāvatime bhikkhū,"
    },
    {
      "id": "sn21.12:3.2",
      "pali": "cirarattaṁ sametikā;"
    },
    {
      "id": "sn21.12:3.3",
      "pali": "Sameti nesaṁ saddhammo,"
    },
    {
      "id": "sn21.12:3.4",
      "pali": "dhamme buddhappavedite."
    },
    {
      "id": "sn21.12:4.1",
      "pali": "Suvinītā kappinena,"
    },
    {
      "id": "sn21.12:4.2",
      "pali": "dhamme ariyappavedite;"
    },
    {
      "id": "sn21.12:4.3",
      "pali": "Dhārenti antimaṁ dehaṁ,"
    },
    {
      "id": "sn21.12:4.4",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "sn21.12:4.5",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn21.12:4.6",
      "pali": "Bhikkhuvaggo paṭhamo."
    },
    {
      "id": "sn21.12:5.1",
      "pali": "Kolito upatisso ca,"
    },
    {
      "id": "sn21.12:5.2",
      "pali": "ghaṭo cāpi pavuccati;"
    },
    {
      "id": "sn21.12:5.3",
      "pali": "Navo sujāto bhaddi ca,"
    },
    {
      "id": "sn21.12:5.4",
      "pali": "visākho nando tisso ca;"
    },
    {
      "id": "sn21.12:5.5",
      "pali": "Theranāmo ca kappino,"
    },
    {
      "id": "sn21.12:5.6",
      "pali": "sahāyena ca dvādasāti."
    },
    {
      "id": "sn21.12:5.7",
      "pali": "Bhikkhusaṁyuttaṁ samattaṁ."
    },
    {
      "id": "sn21.12:5.8",
      "pali": "Nidānavaggo dutiyo."
    },
    {
      "id": "sn21.12:6.1",
      "pali": "Nidānābhisamayadhātu,"
    },
    {
      "id": "sn21.12:6.2",
      "pali": "anamataggena kassapaṁ;"
    },
    {
      "id": "sn21.12:6.3",
      "pali": "Sakkārarāhulalakkhaṇo,"
    },
    {
      "id": "sn21.12:6.4",
      "pali": "opammabhikkhunā vaggo."
    },
    {
      "id": "sn21.12:6.5",
      "pali": "Dutiyo tena pavuccatīti."
    },
    {
      "id": "sn21.12:6.6",
      "pali": "Nidānavaggasaṁyuttapāḷi niṭṭhitā."
    }
  ]
}
