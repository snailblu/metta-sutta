{
  "uid": "snp4.4",
  "title": "Suddhaṭṭhakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.4:1.1",
      "pali": "Passāmi suddhaṁ paramaṁ arogaṁ,"
    },
    {
      "id": "snp4.4:1.2",
      "pali": "Diṭṭhena saṁsuddhi narassa hoti;"
    },
    {
      "id": "snp4.4:1.3",
      "pali": "Evābhijānaṁ paramanti ñatvā,"
    },
    {
      "id": "snp4.4:1.4",
      "pali": "Suddhānupassīti pacceti ñāṇaṁ."
    },
    {
      "id": "snp4.4:2.1",
      "pali": "Diṭṭhena ce suddhi narassa hoti,"
    },
    {
      "id": "snp4.4:2.2",
      "pali": "Ñāṇena vā so pajahāti dukkhaṁ;"
    },
    {
      "id": "snp4.4:2.3",
      "pali": "Aññena so sujjhati sopadhīko,"
    },
    {
      "id": "snp4.4:2.4",
      "pali": "Diṭṭhī hi naṁ pāva tathā vadānaṁ."
    },
    {
      "id": "snp4.4:3.1",
      "pali": "Na brāhmaṇo aññato suddhimāha,"
    },
    {
      "id": "snp4.4:3.2",
      "pali": "Diṭṭhe sute sīlavate mute vā;"
    },
    {
      "id": "snp4.4:3.3",
      "pali": "Puññe ca pāpe ca anūpalitto,"
    },
    {
      "id": "snp4.4:3.4",
      "pali": "Attañjaho nayidha pakubbamāno."
    },
    {
      "id": "snp4.4:4.1",
      "pali": "Purimaṁ pahāya aparaṁ sitāse,"
    },
    {
      "id": "snp4.4:4.2",
      "pali": "Ejānugā te na taranti saṅgaṁ;"
    },
    {
      "id": "snp4.4:4.3",
      "pali": "Te uggahāyanti nirassajanti,"
    },
    {
      "id": "snp4.4:4.4",
      "pali": "Kapīva sākhaṁ pamuñcaṁ gahāyaṁ."
    },
    {
      "id": "snp4.4:5.1",
      "pali": "Sayaṁ samādāya vatāni jantu,"
    },
    {
      "id": "snp4.4:5.2",
      "pali": "Uccāvacaṁ gacchati saññasatto;"
    },
    {
      "id": "snp4.4:5.3",
      "pali": "Vidvā ca vedehi samecca dhammaṁ,"
    },
    {
      "id": "snp4.4:5.4",
      "pali": "Na uccāvacaṁ gacchati bhūripañño."
    },
    {
      "id": "snp4.4:6.1",
      "pali": "Sa sabbadhammesu visenibhūto,"
    },
    {
      "id": "snp4.4:6.2",
      "pali": "Yaṁ kiñci diṭṭhaṁ va sutaṁ mutaṁ vā;"
    },
    {
      "id": "snp4.4:6.3",
      "pali": "Tameva dassiṁ vivaṭaṁ carantaṁ,"
    },
    {
      "id": "snp4.4:6.4",
      "pali": "Kenīdha lokasmi vikappayeyya."
    },
    {
      "id": "snp4.4:7.1",
      "pali": "Na kappayanti na purekkharonti,"
    },
    {
      "id": "snp4.4:7.2",
      "pali": "Accantasuddhīti na te vadanti;"
    },
    {
      "id": "snp4.4:7.3",
      "pali": "Ādānaganthaṁ gathitaṁ visajja,"
    },
    {
      "id": "snp4.4:7.4",
      "pali": "Āsaṁ na kubbanti kuhiñci loke."
    },
    {
      "id": "snp4.4:8.1",
      "pali": "Sīmātigo brāhmaṇo tassa natthi,"
    },
    {
      "id": "snp4.4:8.2",
      "pali": "Ñatvā va disvā va samuggahītaṁ;"
    },
    {
      "id": "snp4.4:8.3",
      "pali": "Na rāgarāgī na virāgaratto,"
    },
    {
      "id": "snp4.4:8.4",
      "pali": "Tassīdha natthi paramuggahītanti."
    },
    {
      "id": "snp4.4:8.5",
      "pali": "Suddhaṭṭhakasuttaṁ catutthaṁ."
    }
  ]
}
