{
  "uid": "sn22.19",
  "title": "Sahetudukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.19:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.19:1.2",
      "pali": "“Rūpaṁ, bhikkhave, dukkhaṁ."
    },
    {
      "id": "sn22.19:1.3",
      "pali": "Yopi hetu yopi paccayo rūpassa uppādāya, sopi dukkho."
    },
    {
      "id": "sn22.19:1.4",
      "pali": "Dukkhasambhūtaṁ, bhikkhave, rūpaṁ kuto sukhaṁ bhavissati."
    },
    {
      "id": "sn22.19:1.5",
      "pali": "Vedanā dukkhā …"
    },
    {
      "id": "sn22.19:1.6",
      "pali": "saññā dukkhā …"
    },
    {
      "id": "sn22.19:1.7",
      "pali": "saṅkhārā dukkhā …"
    },
    {
      "id": "sn22.19:1.8",
      "pali": "viññāṇaṁ dukkhaṁ."
    },
    {
      "id": "sn22.19:1.9",
      "pali": "Yopi hetu yopi paccayo viññāṇassa uppādāya, sopi dukkho."
    },
    {
      "id": "sn22.19:1.10",
      "pali": "Dukkhasambhūtaṁ, bhikkhave, viññāṇaṁ kuto sukhaṁ bhavissati."
    },
    {
      "id": "sn22.19:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.19:1.12",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.19:1.13",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
