{
  "uid": "sn17.22",
  "title": "Kalyāṇīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.22:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.22:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.22:1.3",
      "pali": "na tassa, bhikkhave, janapadakalyāṇī ekā ekassa cittaṁ pariyādāya tiṭṭhati yassa lābhasakkārasiloko cittaṁ pariyādāya tiṭṭhati."
    },
    {
      "id": "sn17.22:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.22:1.5",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.22:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
