{
  "uid": "sn45.30",
  "title": "Uttiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.30:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.30:1.2",
      "pali": "Atha kho āyasmā uttiyo yena bhagavā tenupasaṅkami …pe… ekamantaṁ nisinno kho āyasmā uttiyo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn45.30:1.3",
      "pali": "“idha mayhaṁ, bhante, rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "sn45.30:1.4",
      "pali": "‘pañca kāmaguṇā vuttā bhagavatā."
    },
    {
      "id": "sn45.30:1.5",
      "pali": "Katame nu kho pañca kāmaguṇā vuttā bhagavatā’”ti?"
    },
    {
      "id": "sn45.30:1.6",
      "pali": "“Sādhu sādhu, uttiya."
    },
    {
      "id": "sn45.30:1.7",
      "pali": "Pañcime kho, uttiya, kāmaguṇā vuttā mayā."
    },
    {
      "id": "sn45.30:1.8",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn45.30:1.9",
      "pali": "Cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā,"
    },
    {
      "id": "sn45.30:1.10",
      "pali": "sotaviññeyyā saddā …pe…"
    },
    {
      "id": "sn45.30:1.11",
      "pali": "ghānaviññeyyā gandhā …pe…"
    },
    {
      "id": "sn45.30:1.12",
      "pali": "jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn45.30:1.13",
      "pali": "kāyaviññeyyā phoṭṭhabbā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā—"
    },
    {
      "id": "sn45.30:1.14",
      "pali": "ime kho, uttiya, pañca kāmaguṇā vuttā mayā."
    },
    {
      "id": "sn45.30:1.15",
      "pali": "Imesaṁ kho, uttiya, pañcannaṁ kāmaguṇānaṁ pahānāya ariyo aṭṭhaṅgiko maggo bhāvetabbo."
    },
    {
      "id": "sn45.30:1.16",
      "pali": "Katamo ariyo aṭṭhaṅgiko maggo?"
    },
    {
      "id": "sn45.30:1.17",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.30:1.18",
      "pali": "Imesaṁ kho, uttiya, pañcannaṁ kāmaguṇānaṁ pahānāya ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.30:1.19",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn45.30:1.20",
      "pali": "Micchattavaggo tatiyo."
    },
    {
      "id": "sn45.30:2.1",
      "pali": "Micchattaṁ akusalaṁ dhammaṁ,"
    },
    {
      "id": "sn45.30:2.2",
      "pali": "Duve paṭipadāpi ca;"
    },
    {
      "id": "sn45.30:2.3",
      "pali": "Asappurisena dve kumbho,"
    },
    {
      "id": "sn45.30:2.4",
      "pali": "Samādhi vedanuttiyenāti."
    }
  ]
}
