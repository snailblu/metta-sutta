{
  "uid": "sn15.17",
  "title": "Bhaginisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.17:1.1",
      "pali": "Sāvatthiyaṁ viharati …pe…"
    },
    {
      "id": "sn15.17:1.2",
      "pali": "“na so, bhikkhave, satto sulabharūpo yo nabhaginibhūtapubbo …pe…"
    },
    {
      "id": "sn15.17:1.3",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.17:1.4",
      "pali": "Sattamaṁ."
    }
  ]
}
