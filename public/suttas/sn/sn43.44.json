{
  "uid": "sn43.44",
  "title": "Parāyanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.44:1.1",
      "pali": "“Parāyanañca vo, bhikkhave, desessāmi parāyanagāmiñca maggaṁ."
    },
    {
      "id": "sn43.44:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.44:1.3",
      "pali": "Katamañca, bhikkhave, parāyanaṁ?"
    },
    {
      "id": "sn43.44:1.4",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn43.44:1.5",
      "pali": "idaṁ vuccati, bhikkhave, parāyanaṁ."
    },
    {
      "id": "sn43.44:1.6",
      "pali": "Katamo ca, bhikkhave, parāyanagāmī maggo?"
    },
    {
      "id": "sn43.44:1.7",
      "pali": "Kāyagatāsati."
    },
    {
      "id": "sn43.44:1.8",
      "pali": "Ayaṁ vuccati, bhikkhave, parāyanagāmimaggo."
    },
    {
      "id": "sn43.44:1.9",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā parāyanaṁ, desito parāyanagāmimaggo."
    },
    {
      "id": "sn43.44:1.10",
      "pali": "Yaṁ, bhikkhave, satthārā karaṇīyaṁ sāvakānaṁ hitesinā anukampakena anukampaṁ upādāya, kataṁ vo taṁ mayā."
    },
    {
      "id": "sn43.44:1.11",
      "pali": "Etāni, bhikkhave, rukkhamūlāni, etāni suññāgārāni. Jhāyatha, bhikkhave, mā pamādattha; mā pacchā vippaṭisārino ahuvattha. Ayaṁ vo amhākaṁ anusāsanī”ti."
    },
    {
      "id": "sn43.44:1.12",
      "pali": "(Yathā asaṅkhataṁ tathā vitthāretabbaṁ.)"
    },
    {
      "id": "sn43.44:1.13",
      "pali": "Tettiṁsatimaṁ."
    },
    {
      "id": "sn43.44:1.14",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn43.44:2.1",
      "pali": "Asaṅkhataṁ anataṁ anāsavaṁ,"
    },
    {
      "id": "sn43.44:2.2",
      "pali": "Saccañca pāraṁ nipuṇaṁ sududdasaṁ;"
    },
    {
      "id": "sn43.44:2.3",
      "pali": "Ajajjaraṁ dhuvaṁ apalokitaṁ,"
    },
    {
      "id": "sn43.44:2.4",
      "pali": "Anidassanaṁ nippapañca santaṁ."
    },
    {
      "id": "sn43.44:3.1",
      "pali": "Amataṁ paṇītañca sivañca khemaṁ,"
    },
    {
      "id": "sn43.44:3.2",
      "pali": "Taṇhākkhayo acchariyañca abbhutaṁ;"
    },
    {
      "id": "sn43.44:3.3",
      "pali": "Anītikaṁ anītikadhammaṁ,"
    },
    {
      "id": "sn43.44:3.4",
      "pali": "Nibbānametaṁ sugatena desitaṁ."
    },
    {
      "id": "sn43.44:4.1",
      "pali": "Abyābajjho virāgo ca,"
    },
    {
      "id": "sn43.44:4.2",
      "pali": "suddhi mutti anālayo;"
    },
    {
      "id": "sn43.44:4.3",
      "pali": "Dīpo leṇañca tāṇañca,"
    },
    {
      "id": "sn43.44:4.4",
      "pali": "saraṇañca parāyananti."
    },
    {
      "id": "sn43.44:4.5",
      "pali": "Asaṅkhatasaṁyuttaṁ samattaṁ."
    }
  ]
}
