{
  "uid": "sn21.11",
  "title": "Mahākappinasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn21.11:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn21.11:1.2",
      "pali": "Atha kho āyasmā mahākappino yena bhagavā tenupasaṅkami."
    },
    {
      "id": "sn21.11:1.3",
      "pali": "Addasā kho bhagavā āyasmantaṁ mahākappinaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn21.11:1.4",
      "pali": "Disvāna bhikkhū āmantesi:"
    },
    {
      "id": "sn21.11:1.5",
      "pali": "“passatha no tumhe, bhikkhave, etaṁ bhikkhuṁ āgacchantaṁ odātakaṁ tanukaṁ tuṅganāsikan”ti?"
    },
    {
      "id": "sn21.11:1.6",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn21.11:1.7",
      "pali": "“Eso kho, bhikkhave, bhikkhu mahiddhiko mahānubhāvo."
    },
    {
      "id": "sn21.11:1.8",
      "pali": "Na ca sā samāpatti sulabharūpā yā tena bhikkhunā asamāpannapubbā."
    },
    {
      "id": "sn21.11:1.9",
      "pali": "Yassa catthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti tadanuttaraṁ brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti."
    },
    {
      "id": "sn21.11:2.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn21.11:2.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn21.11:3.1",
      "pali": "“Khattiyo seṭṭho janetasmiṁ,"
    },
    {
      "id": "sn21.11:3.2",
      "pali": "ye gottapaṭisārino;"
    },
    {
      "id": "sn21.11:3.3",
      "pali": "Vijjācaraṇasampanno,"
    },
    {
      "id": "sn21.11:3.4",
      "pali": "so seṭṭho devamānuse."
    },
    {
      "id": "sn21.11:4.1",
      "pali": "Divā tapati ādicco,"
    },
    {
      "id": "sn21.11:4.2",
      "pali": "rattimābhāti candimā;"
    },
    {
      "id": "sn21.11:4.3",
      "pali": "Sannaddho khattiyo tapati,"
    },
    {
      "id": "sn21.11:4.4",
      "pali": "jhāyī tapati brāhmaṇo;"
    },
    {
      "id": "sn21.11:4.5",
      "pali": "Atha sabbamahorattiṁ,"
    },
    {
      "id": "sn21.11:4.6",
      "pali": "buddho tapati tejasā”ti."
    },
    {
      "id": "sn21.11:4.7",
      "pali": "Ekādasamaṁ."
    }
  ]
}
