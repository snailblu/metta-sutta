{
  "uid": "sn22.49",
  "title": "Soṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.49:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn22.49:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn22.49:1.3",
      "pali": "Atha kho soṇo gahapatiputto yena bhagavā tenupasaṅkami …pe…"
    },
    {
      "id": "sn22.49:1.4",
      "pali": "ekamantaṁ nisinnaṁ kho soṇaṁ gahapatiputtaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn22.49:2.1",
      "pali": "“Ye hi keci, soṇa, samaṇā vā brāhmaṇā vā aniccena rūpena dukkhena vipariṇāmadhammena ‘seyyohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.2",
      "pali": "‘sadisohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.3",
      "pali": "‘hīnohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.4",
      "pali": "kimaññatra yathābhūtassa adassanā?"
    },
    {
      "id": "sn22.49:2.5",
      "pali": "Aniccāya vedanāya dukkhāya vipariṇāmadhammāya ‘seyyohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.6",
      "pali": "‘sadisohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.7",
      "pali": "‘hīnohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.8",
      "pali": "kimaññatra yathābhūtassa adassanā?"
    },
    {
      "id": "sn22.49:2.9",
      "pali": "Aniccāya saññāya …"
    },
    {
      "id": "sn22.49:2.10",
      "pali": "aniccehi saṅkhārehi dukkhehi vipariṇāmadhammehi ‘seyyohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.11",
      "pali": "‘sadisohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.12",
      "pali": "‘hīnohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.13",
      "pali": "kimaññatra yathābhūtassa adassanā?"
    },
    {
      "id": "sn22.49:2.14",
      "pali": "Aniccena viññāṇena dukkhena vipariṇāmadhammena ‘seyyohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.15",
      "pali": "‘sadisohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.16",
      "pali": "‘hīnohamasmī’ti vā samanupassanti;"
    },
    {
      "id": "sn22.49:2.17",
      "pali": "kimaññatra yathābhūtassa adassanā?"
    },
    {
      "id": "sn22.49:3.1",
      "pali": "Ye ca kho keci, soṇa, samaṇā vā brāhmaṇā vā aniccena rūpena dukkhena vipariṇāmadhammena ‘seyyohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.2",
      "pali": "‘sadisohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.3",
      "pali": "‘hīnohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.4",
      "pali": "kimaññatra yathābhūtassa dassanā?"
    },
    {
      "id": "sn22.49:3.5",
      "pali": "Aniccāya vedanāya …"
    },
    {
      "id": "sn22.49:3.6",
      "pali": "aniccāya saññāya …"
    },
    {
      "id": "sn22.49:3.7",
      "pali": "aniccehi saṅkhārehi …"
    },
    {
      "id": "sn22.49:3.8",
      "pali": "aniccena viññāṇena dukkhena vipariṇāmadhammena ‘seyyohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.9",
      "pali": "‘sadisohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.10",
      "pali": "‘hīnohamasmī’tipi na samanupassanti;"
    },
    {
      "id": "sn22.49:3.11",
      "pali": "kimaññatra yathābhūtassa dassanā?"
    },
    {
      "id": "sn22.49:4.1",
      "pali": "Taṁ kiṁ maññasi, soṇa,"
    },
    {
      "id": "sn22.49:4.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.49:4.3",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.49:4.4",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.49:4.5",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.49:4.6",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn22.49:4.7",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn22.49:4.8",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.49:4.9",
      "pali": "“Vedanā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn22.49:4.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn22.49:4.11",
      "pali": "“saññā …"
    },
    {
      "id": "sn22.49:4.12",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.49:4.13",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.49:4.14",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.49:4.15",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.49:4.16",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.49:4.17",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn22.49:4.18",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn22.49:4.19",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.49:5.1",
      "pali": "“Tasmātiha, soṇa, yaṁ kiñci rūpaṁ atītānāgatapaccuppannaṁ ajjhattaṁ vā bahiddhā vā oḷārikaṁ vā sukhumaṁ vā hīnaṁ vā paṇītaṁ vā yaṁ dūre santike vā, sabbaṁ rūpaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.49:6.1",
      "pali": "Yā kāci vedanā …"
    },
    {
      "id": "sn22.49:6.2",
      "pali": "yā kāci saññā …"
    },
    {
      "id": "sn22.49:6.3",
      "pali": "ye keci saṅkhārā …"
    },
    {
      "id": "sn22.49:6.4",
      "pali": "yaṁ kiñci viññāṇaṁ atītānāgatapaccuppannaṁ ajjhattaṁ vā bahiddhā vā oḷārikaṁ vā sukhumaṁ vā hīnaṁ vā paṇītaṁ vā yaṁ dūre santike vā, sabbaṁ viññāṇaṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.49:7.1",
      "pali": "Evaṁ passaṁ, soṇa, sutavā ariyasāvako rūpasmimpi nibbindati, vedanāyapi nibbindati, saññāyapi nibbindati, saṅkhāresupi nibbindati, viññāṇasmimpi nibbindati."
    },
    {
      "id": "sn22.49:7.2",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati. Vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn22.49:7.3",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.49:7.4",
      "pali": "Sattamaṁ."
    }
  ]
}
