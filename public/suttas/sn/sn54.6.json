{
  "uid": "sn54.6",
  "title": "Ariṭṭhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn54.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn54.6:1.2",
      "pali": "Tatra kho bhagavā …pe… etadavoca:"
    },
    {
      "id": "sn54.6:1.3",
      "pali": "“bhāvetha no tumhe bhikkhave, ānāpānassatin”ti?"
    },
    {
      "id": "sn54.6:1.4",
      "pali": "Evaṁ vutte, āyasmā ariṭṭho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn54.6:1.5",
      "pali": "“ahaṁ kho, bhante, bhāvemi ānāpānassatin”ti."
    },
    {
      "id": "sn54.6:1.6",
      "pali": "“Yathā kathaṁ pana tvaṁ, ariṭṭha, bhāvesi ānāpānassatin”ti?"
    },
    {
      "id": "sn54.6:1.7",
      "pali": "“Atītesu me, bhante, kāmesu kāmacchando pahīno, anāgatesu me kāmesu kāmacchando vigato, ajjhattabahiddhā ca me dhammesu paṭighasaññā suppaṭivinītā."
    },
    {
      "id": "sn54.6:1.8",
      "pali": "So satova assasissāmi, satova passasissāmi."
    },
    {
      "id": "sn54.6:1.9",
      "pali": "Evaṁ khvāhaṁ, bhante, bhāvemi ānāpānassatin”ti."
    },
    {
      "id": "sn54.6:2.1",
      "pali": "“‘Atthesā, ariṭṭha, ānāpānassati, nesā natthī’ti vadāmi."
    },
    {
      "id": "sn54.6:2.2",
      "pali": "Api ca, ariṭṭha, yathā ānāpānassati vitthārena paripuṇṇā hoti"
    },
    {
      "id": "sn54.6:2.3",
      "pali": "taṁ suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "sn54.6:2.4",
      "pali": "“Evaṁ, bhante”ti kho āyasmā ariṭṭho bhagavato paccassosi."
    },
    {
      "id": "sn54.6:2.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn54.6:3.1",
      "pali": "“Kathañca, ariṭṭha, ānāpānassati vitthārena paripuṇṇā hoti?"
    },
    {
      "id": "sn54.6:3.2",
      "pali": "Idha, ariṭṭha, bhikkhu araññagato vā rukkhamūlagato vā suññāgāragato vā nisīdati pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā."
    },
    {
      "id": "sn54.6:3.3",
      "pali": "So satova assasati, satova passasati."
    },
    {
      "id": "sn54.6:3.4",
      "pali": "Dīghaṁ vā assasanto ‘dīghaṁ assasāmī’ti pajānāti …pe…"
    },
    {
      "id": "sn54.6:3.5",
      "pali": "‘paṭinissaggānupassī assasissāmī’ti sikkhati, ‘paṭinissaggānupassī passasissāmī’ti sikkhati."
    },
    {
      "id": "sn54.6:3.6",
      "pali": "Evaṁ kho, ariṭṭha, ānāpānassati vitthārena paripuṇṇā hotī”ti."
    },
    {
      "id": "sn54.6:3.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
