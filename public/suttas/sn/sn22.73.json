{
  "uid": "sn22.73",
  "title": "Assādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.73:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.73:1.2",
      "pali": "“Assutavā, bhikkhave, puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.73:1.3",
      "pali": "Vedanāya …"
    },
    {
      "id": "sn22.73:1.4",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.73:1.5",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.73:1.6",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.73:1.7",
      "pali": "Sutavā ca kho, bhikkhave, ariyasāvako rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.73:1.8",
      "pali": "Vedanāya …"
    },
    {
      "id": "sn22.73:1.9",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.73:1.10",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.73:1.11",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānātī”ti."
    },
    {
      "id": "sn22.73:1.12",
      "pali": "Paṭhamaṁ."
    }
  ]
}
