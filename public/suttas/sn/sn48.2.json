{
  "uid": "sn48.2",
  "title": "Paṭhamasotāpannasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.2:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.2:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.2:1.3",
      "pali": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ."
    },
    {
      "id": "sn48.2:1.4",
      "pali": "Yato kho, bhikkhave, ariyasāvako imesaṁ pañcannaṁ indriyānaṁ assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti—"
    },
    {
      "id": "sn48.2:1.5",
      "pali": "ayaṁ vuccati, bhikkhave, ariyasāvako sotāpanno avinipātadhammo niyato sambodhiparāyaṇo”ti."
    },
    {
      "id": "sn48.2:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
