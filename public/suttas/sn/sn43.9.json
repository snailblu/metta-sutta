{
  "uid": "sn43.9",
  "title": "Balasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.9:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.9:1.2",
      "pali": "Pañca balāni. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.9:1.3",
      "pali": "Navamaṁ."
    }
  ]
}
