{
  "uid": "sn38.13",
  "title": "Bhavapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.13:1.1",
      "pali": "“‘Bhavo, bhavo’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.13:1.2",
      "pali": "Katamo nu kho, āvuso, bhavo”ti?"
    },
    {
      "id": "sn38.13:1.3",
      "pali": "“Tayome, āvuso, bhavā."
    },
    {
      "id": "sn38.13:1.4",
      "pali": "Kāmabhavo, rūpabhavo, arūpabhavo—"
    },
    {
      "id": "sn38.13:1.5",
      "pali": "ime kho, āvuso, tayo bhavā”ti."
    },
    {
      "id": "sn38.13:1.6",
      "pali": "“Atthi panāvuso, maggo atthi paṭipadā, etesaṁ bhavānaṁ pariññāyā”ti?"
    },
    {
      "id": "sn38.13:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā, etesaṁ bhavānaṁ pariññāyā”ti."
    },
    {
      "id": "sn38.13:1.8",
      "pali": "“Katamo, panāvuso, maggo katamā paṭipadā, etesaṁ bhavānaṁ pariññāyā”ti?"
    },
    {
      "id": "sn38.13:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etesaṁ bhavānaṁ pariññāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.13:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.13:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etesaṁ bhavānaṁ pariññāyā”ti."
    },
    {
      "id": "sn38.13:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etesaṁ bhavānaṁ pariññāya."
    },
    {
      "id": "sn38.13:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.13:1.14",
      "pali": "Terasamaṁ."
    }
  ]
}
