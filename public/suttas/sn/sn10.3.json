{
  "uid": "sn10.3",
  "title": "Sūcilomasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.3:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā gayāyaṁ viharati ṭaṅkitamañce sūcilomassa yakkhassa bhavane."
    },
    {
      "id": "sn10.3:1.2",
      "pali": "Tena kho pana samayena kharo ca yakkho sūcilomo ca yakkho bhagavato avidūre atikkamanti."
    },
    {
      "id": "sn10.3:1.3",
      "pali": "Atha kho kharo yakkho sūcilomaṁ yakkhaṁ etadavoca:"
    },
    {
      "id": "sn10.3:1.4",
      "pali": "“eso samaṇo”ti."
    },
    {
      "id": "sn10.3:1.5",
      "pali": "“Neso samaṇo, samaṇako eso."
    },
    {
      "id": "sn10.3:1.6",
      "pali": "Yāva jānāmi yadi vā so samaṇo yadi vā pana so samaṇako”ti."
    },
    {
      "id": "sn10.3:2.1",
      "pali": "Atha kho sūcilomo yakkho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavato kāyaṁ upanāmesi."
    },
    {
      "id": "sn10.3:2.2",
      "pali": "Atha kho bhagavā kāyaṁ apanāmesi."
    },
    {
      "id": "sn10.3:2.3",
      "pali": "Atha kho sūcilomo yakkho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn10.3:2.4",
      "pali": "“bhāyasi maṁ, samaṇā”ti?"
    },
    {
      "id": "sn10.3:2.5",
      "pali": "“Na khvāhaṁ taṁ, āvuso, bhāyāmi;"
    },
    {
      "id": "sn10.3:2.6",
      "pali": "api ca te samphasso pāpako”ti."
    },
    {
      "id": "sn10.3:2.7",
      "pali": "“Pañhaṁ taṁ, samaṇa, pucchissāmi."
    },
    {
      "id": "sn10.3:2.8",
      "pali": "Sace me na byākarissasi, cittaṁ vā te khipissāmi, hadayaṁ vā te phālessāmi, pādesu vā gahetvā pāragaṅgāya khipissāmī”ti."
    },
    {
      "id": "sn10.3:2.9",
      "pali": "“Na khvāhaṁ taṁ, āvuso, passāmi sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya, yo me cittaṁ vā khipeyya hadayaṁ vā phāleyya pādesu vā gahetvā pāragaṅgāya khipeyya;"
    },
    {
      "id": "sn10.3:2.10",
      "pali": "api ca tvaṁ, āvuso, puccha yadā kaṅkhasī”ti. (…)"
    },
    {
      "id": "sn10.3:3.1",
      "pali": "“Rāgo ca doso ca kutonidānā,"
    },
    {
      "id": "sn10.3:3.2",
      "pali": "Aratī ratī lomahaṁso kutojā;"
    },
    {
      "id": "sn10.3:3.3",
      "pali": "Kuto samuṭṭhāya manovitakkā,"
    },
    {
      "id": "sn10.3:3.4",
      "pali": "Kumārakā dhaṅkamivossajantī”ti."
    },
    {
      "id": "sn10.3:4.1",
      "pali": "“Rāgo ca doso ca itonidānā,"
    },
    {
      "id": "sn10.3:4.2",
      "pali": "Aratī ratī lomahaṁso itojā;"
    },
    {
      "id": "sn10.3:4.3",
      "pali": "Ito samuṭṭhāya manovitakkā,"
    },
    {
      "id": "sn10.3:4.4",
      "pali": "Kumārakā dhaṅkamivossajanti."
    },
    {
      "id": "sn10.3:5.1",
      "pali": "Snehajā attasambhūtā,"
    },
    {
      "id": "sn10.3:5.2",
      "pali": "nigrodhasseva khandhajā;"
    },
    {
      "id": "sn10.3:5.3",
      "pali": "Puthū visattā kāmesu,"
    },
    {
      "id": "sn10.3:5.4",
      "pali": "māluvāva vitatā vane."
    },
    {
      "id": "sn10.3:6.1",
      "pali": "Ye naṁ pajānanti yatonidānaṁ,"
    },
    {
      "id": "sn10.3:6.2",
      "pali": "Te naṁ vinodenti suṇohi yakkha;"
    },
    {
      "id": "sn10.3:6.3",
      "pali": "Te duttaraṁ oghamimaṁ taranti,"
    },
    {
      "id": "sn10.3:6.4",
      "pali": "Atiṇṇapubbaṁ apunabbhavāyā”ti."
    }
  ]
}
