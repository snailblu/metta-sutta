{
  "uid": "sn12.44",
  "title": "Lokasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.44:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.44:1.2",
      "pali": "“Lokassa, bhikkhave, samudayañca atthaṅgamañca desessāmi."
    },
    {
      "id": "sn12.44:1.3",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.44:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.44:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.44:2.1",
      "pali": "“Katamo ca, bhikkhave, lokassa samudayo?"
    },
    {
      "id": "sn12.44:2.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.44:2.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.44:2.4",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn12.44:2.5",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.44:2.6",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.44:2.7",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.44:2.8",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.44:2.9",
      "pali": "Ayaṁ kho, bhikkhave, lokassa samudayo."
    },
    {
      "id": "sn12.44:3.1",
      "pali": "Sotañca paṭicca sadde ca …pe…"
    },
    {
      "id": "sn12.44:3.2",
      "pali": "ghānañca paṭicca gandhe ca …"
    },
    {
      "id": "sn12.44:3.3",
      "pali": "jivhañca paṭicca rase ca …"
    },
    {
      "id": "sn12.44:3.4",
      "pali": "kāyañca paṭicca phoṭṭhabbe ca …"
    },
    {
      "id": "sn12.44:3.5",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.44:3.6",
      "pali": "Phassapaccayā vedanā …pe…"
    },
    {
      "id": "sn12.44:3.7",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.44:3.8",
      "pali": "Ayaṁ kho, bhikkhave, lokassa samudayo."
    },
    {
      "id": "sn12.44:4.1",
      "pali": "Katamo ca, bhikkhave, lokassa atthaṅgamo?"
    },
    {
      "id": "sn12.44:4.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.44:4.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.44:4.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.44:4.5",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.44:4.6",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn12.44:4.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.44:4.8",
      "pali": "Ayaṁ kho, bhikkhave, lokassa atthaṅgamo."
    },
    {
      "id": "sn12.44:5.1",
      "pali": "Sotañca paṭicca sadde ca …pe…"
    },
    {
      "id": "sn12.44:5.2",
      "pali": "ghānañca paṭicca gandhe ca …"
    },
    {
      "id": "sn12.44:5.3",
      "pali": "jivhañca paṭicca rase ca …"
    },
    {
      "id": "sn12.44:5.4",
      "pali": "kāyañca paṭicca phoṭṭhabbe ca …"
    },
    {
      "id": "sn12.44:5.5",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.44:5.6",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.44:5.7",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.44:5.8",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.44:5.9",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn12.44:5.10",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.44:5.11",
      "pali": "Ayaṁ kho, bhikkhave, lokassa atthaṅgamo”ti."
    },
    {
      "id": "sn12.44:5.12",
      "pali": "Catutthaṁ."
    }
  ]
}
