{
  "uid": "sn45.20",
  "title": "Tatiyakukkuṭārāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.20:1.1",
      "pali": "Pāṭaliputtanidānaṁ."
    },
    {
      "id": "sn45.20:1.2",
      "pali": "“‘Brahmacariyaṁ, brahmacariyan’ti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.20:1.3",
      "pali": "Katamaṁ nu kho, āvuso, brahmacariyaṁ, katamo brahmacārī, katamaṁ brahmacariyapariyosānan”ti?"
    },
    {
      "id": "sn45.20:1.4",
      "pali": "“Sādhu sādhu, āvuso bhadda."
    },
    {
      "id": "sn45.20:1.5",
      "pali": "Bhaddako kho te, āvuso bhadda, ummaṅgo, bhaddakaṁ paṭibhānaṁ, kalyāṇī paripucchā."
    },
    {
      "id": "sn45.20:1.6",
      "pali": "Evañhi tvaṁ, āvuso bhadda, pucchasi:"
    },
    {
      "id": "sn45.20:1.7",
      "pali": "‘brahmacariyaṁ, brahmacariyanti, āvuso ānanda, vuccati."
    },
    {
      "id": "sn45.20:1.8",
      "pali": "Katamaṁ nu kho, āvuso, brahmacariyaṁ, katamo brahmacārī, katamaṁ brahmacariyapariyosānan’”ti?"
    },
    {
      "id": "sn45.20:1.9",
      "pali": "“Evamāvuso”ti."
    },
    {
      "id": "sn45.20:1.10",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo brahmacariyaṁ, seyyathidaṁ—"
    },
    {
      "id": "sn45.20:1.11",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.20:1.12",
      "pali": "Yo kho, āvuso, iminā ariyena aṭṭhaṅgikena maggena samannāgato—"
    },
    {
      "id": "sn45.20:1.13",
      "pali": "ayaṁ vuccati brahmacārī."
    },
    {
      "id": "sn45.20:1.14",
      "pali": "Yo kho, āvuso, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.20:1.15",
      "pali": "idaṁ brahmacariyapariyosānan”ti."
    },
    {
      "id": "sn45.20:1.16",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn45.20:1.17",
      "pali": "Tīṇi suttantāni ekanidānāni."
    },
    {
      "id": "sn45.20:1.18",
      "pali": "Vihāravaggo dutiyo."
    },
    {
      "id": "sn45.20:2.1",
      "pali": "Dve vihārā ca sekkho ca,"
    },
    {
      "id": "sn45.20:2.2",
      "pali": "uppādā apare duve;"
    },
    {
      "id": "sn45.20:2.3",
      "pali": "Parisuddhena dve vuttā,"
    },
    {
      "id": "sn45.20:2.4",
      "pali": "kukkuṭārāmena tayoti."
    }
  ]
}
