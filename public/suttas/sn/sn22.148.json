{
  "uid": "sn22.148",
  "title": "Dukkhānupassīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.148:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.148:1.2",
      "pali": "“Saddhāpabbajitassa, bhikkhave, kulaputtassa ayamanudhammo hoti—"
    },
    {
      "id": "sn22.148:1.3",
      "pali": "yaṁ rūpe dukkhānupassī vihareyya."
    },
    {
      "id": "sn22.148:1.4",
      "pali": "Vedanāya …"
    },
    {
      "id": "sn22.148:1.5",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.148:1.6",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn22.148:1.7",
      "pali": "viññāṇe dukkhānupassī vihareyya …pe…"
    },
    {
      "id": "sn22.148:1.8",
      "pali": "‘parimuccati dukkhasmā’ti vadāmī”ti."
    },
    {
      "id": "sn22.148:1.9",
      "pali": "Terasamaṁ."
    }
  ]
}
