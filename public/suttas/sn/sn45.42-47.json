{
  "uid": "sn45.42-47",
  "title": "Saṁyojanappahānādisuttachakka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.42-47:1.1",
      "pali": "“Sace vo, bhikkhave, aññatitthiyā paribbājakā evaṁ puccheyyuṁ:"
    },
    {
      "id": "sn45.42-47:1.2",
      "pali": "‘kimatthiyaṁ, āvuso, samaṇe gotame brahmacariyaṁ vussatī’ti, evaṁ puṭṭhā tumhe, bhikkhave, tesaṁ aññatitthiyānaṁ paribbājakānaṁ evaṁ byākareyyātha:"
    },
    {
      "id": "sn45.42-47:1.3",
      "pali": "‘saṁyojanappahānatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…"
    },
    {
      "id": "sn45.42-47:1.4",
      "pali": "‘anusayasamugghātanatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…"
    },
    {
      "id": "sn45.42-47:1.5",
      "pali": "‘addhānapariññatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…"
    },
    {
      "id": "sn45.42-47:1.6",
      "pali": "‘āsavānaṁ khayatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…"
    },
    {
      "id": "sn45.42-47:1.7",
      "pali": "‘vijjāvimuttiphalasacchikiriyatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…"
    },
    {
      "id": "sn45.42-47:1.8",
      "pali": "‘ñāṇadassanatthaṁ kho, āvuso, bhagavati brahmacariyaṁ vussatī’ti …pe…."
    },
    {
      "id": "sn45.42-47:1.9",
      "pali": "Sattamaṁ."
    }
  ]
}
