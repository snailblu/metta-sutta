{
  "uid": "sn55.74",
  "title": "Nibbedhikapaññāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.74:1.1",
      "pali": "“… Nibbedhikapaññatāya saṁvattanti."
    },
    {
      "id": "sn55.74:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn55.74:1.3",
      "pali": "Sappurisasaṁsevo, saddhammassavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—"
    },
    {
      "id": "sn55.74:1.4",
      "pali": "ime kho, bhikkhave, cattāro dhammā bhāvitā bahulīkatā nibbedhikapaññatāya saṁvattantī”ti."
    },
    {
      "id": "sn55.74:1.5",
      "pali": "Terasamaṁ."
    },
    {
      "id": "sn55.74:1.6",
      "pali": "Mahāpaññavaggo sattamo."
    },
    {
      "id": "sn55.74:2.1",
      "pali": "Mahā puthu vipula gambhīraṁ,"
    },
    {
      "id": "sn55.74:2.2",
      "pali": "Appamatta bhūri bāhullaṁ;"
    },
    {
      "id": "sn55.74:2.3",
      "pali": "Sīgha lahu hāsa javana,"
    },
    {
      "id": "sn55.74:2.4",
      "pali": "Tikkha nibbedhikāya cāti."
    },
    {
      "id": "sn55.74:2.5",
      "pali": "Sotāpattisaṁyuttaṁ ekādasamaṁ."
    }
  ]
}
