{
  "uid": "sn48.1",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn48.1:1.2",
      "pali": "Tatra kho bhagavā etadavoca."
    },
    {
      "id": "sn48.1:1.3",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.1:1.4",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.1:1.5",
      "pali": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—"
    },
    {
      "id": "sn48.1:1.6",
      "pali": "imāni kho, bhikkhave, pañcindriyānī”ti."
    },
    {
      "id": "sn48.1:1.7",
      "pali": "Paṭhamaṁ."
    }
  ]
}
