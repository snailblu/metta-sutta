{
  "uid": "sn35.66",
  "title": "Samiddhisattapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.66:1.1",
      "pali": "“‘Satto, satto’ti, bhante, vuccati."
    },
    {
      "id": "sn35.66:1.2",
      "pali": "Kittāvatā nu kho, bhante, satto vā assa sattapaññatti vā”ti …pe…."
    },
    {
      "id": "sn35.66:1.3",
      "pali": "Catutthaṁ."
    }
  ]
}
