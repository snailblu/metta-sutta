{
  "uid": "sn38.11",
  "title": "Oghapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.11:1.1",
      "pali": "“‘Ogho, ogho’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.11:1.2",
      "pali": "Katamo nu kho, āvuso, ogho”ti?"
    },
    {
      "id": "sn38.11:1.3",
      "pali": "“Cattārome, āvuso, oghā."
    },
    {
      "id": "sn38.11:1.4",
      "pali": "Kāmogho, bhavogho, diṭṭhogho, avijjogho—"
    },
    {
      "id": "sn38.11:1.5",
      "pali": "ime kho, āvuso, cattāro oghā”ti."
    },
    {
      "id": "sn38.11:1.6",
      "pali": "“Atthi panāvuso, maggo atthi paṭipadā, etesaṁ oghānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.11:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā, etesaṁ oghānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.11:1.8",
      "pali": "“Katamo panāvuso, maggo katamā paṭipadā, etesaṁ oghānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.11:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etesaṁ oghānaṁ pahānāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.11:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.11:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etesaṁ oghānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.11:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etesaṁ oghānaṁ pahānāya."
    },
    {
      "id": "sn38.11:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.11:1.14",
      "pali": "Ekādasamaṁ."
    }
  ]
}
