{
  "uid": "sn12.53",
  "title": "Saṁyojanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.53:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.53:1.2",
      "pali": "“Saṁyojaniyesu, bhikkhave, dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.53:1.3",
      "pali": "Taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.53:1.4",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.53:1.5",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.53:1.6",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.53:1.7",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.53:2.1",
      "pali": "Seyyathāpi, bhikkhave, telañca paṭicca vaṭṭiñca paṭicca telappadīpo jhāyeyya."
    },
    {
      "id": "sn12.53:2.2",
      "pali": "Tatra puriso kālena kālaṁ telaṁ āsiñceyya vaṭṭiṁ upasaṁhareyya."
    },
    {
      "id": "sn12.53:2.3",
      "pali": "Evañhi so, bhikkhave, telappadīpo tadāhāro tadupādāno ciraṁ dīghamaddhānaṁ jaleyya."
    },
    {
      "id": "sn12.53:2.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.53:2.5",
      "pali": "Taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.53:2.6",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.53:2.7",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.53:2.8",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.53:2.9",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.53:3.1",
      "pali": "Saṁyojaniyesu, bhikkhave, dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.53:3.2",
      "pali": "Taṇhānirodhā upādānanirodho;"
    },
    {
      "id": "sn12.53:3.3",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.53:3.4",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.53:3.5",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.53:3.6",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.53:4.1",
      "pali": "Seyyathāpi, bhikkhave, telañca paṭicca vaṭṭiñca paṭicca telappadīpo jhāyeyya."
    },
    {
      "id": "sn12.53:4.2",
      "pali": "Tatra puriso na kālena kālaṁ telaṁ āsiñceyya na vaṭṭiṁ upasaṁhareyya."
    },
    {
      "id": "sn12.53:4.3",
      "pali": "Evañhi so, bhikkhave, telappadīpo purimassa ca upādānassa pariyādānā aññassa ca anupahārā anāhāro nibbāyeyya."
    },
    {
      "id": "sn12.53:4.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.53:4.5",
      "pali": "Taṇhānirodhā upādānanirodho …pe…"
    },
    {
      "id": "sn12.53:4.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.53:4.7",
      "pali": "Tatiyaṁ."
    }
  ]
}
