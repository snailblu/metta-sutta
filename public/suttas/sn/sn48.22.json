{
  "uid": "sn48.22",
  "title": "Jīvitindriyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.22:1.1",
      "pali": "“Tīṇimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.22:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "sn48.22:1.3",
      "pali": "Itthindriyaṁ, purisindriyaṁ, jīvitindriyaṁ—"
    },
    {
      "id": "sn48.22:1.4",
      "pali": "imāni kho, bhikkhave, tīṇi indriyānī”ti."
    },
    {
      "id": "sn48.22:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
