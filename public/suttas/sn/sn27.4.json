{
  "uid": "sn27.4",
  "title": "Samphassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.4:1.2",
      "pali": "“Yo, bhikkhave, cakkhusamphassasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.4:1.3",
      "pali": "Yo sotasamphassasmiṁ …"
    },
    {
      "id": "sn27.4:1.4",
      "pali": "yo ghānasamphassasmiṁ …"
    },
    {
      "id": "sn27.4:1.5",
      "pali": "yo jivhāsamphassasmiṁ …"
    },
    {
      "id": "sn27.4:1.6",
      "pali": "yo kāyasamphassasmiṁ …"
    },
    {
      "id": "sn27.4:1.7",
      "pali": "yo manosamphassasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.4:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno …pe…"
    },
    {
      "id": "sn27.4:1.9",
      "pali": "abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.4:1.10",
      "pali": "Catutthaṁ."
    }
  ]
}
