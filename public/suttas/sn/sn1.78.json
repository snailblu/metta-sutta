{
  "uid": "sn1.78",
  "title": "Kāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.78:1.1",
      "pali": "“Kimatthakāmo na dade,"
    },
    {
      "id": "sn1.78:1.2",
      "pali": "kiṁ macco na pariccaje;"
    },
    {
      "id": "sn1.78:1.3",
      "pali": "Kiṁsu muñceyya kalyāṇaṁ,"
    },
    {
      "id": "sn1.78:1.4",
      "pali": "pāpikaṁ na ca mocaye”ti."
    },
    {
      "id": "sn1.78:2.1",
      "pali": "“Attānaṁ na dade poso,"
    },
    {
      "id": "sn1.78:2.2",
      "pali": "attānaṁ na pariccaje;"
    },
    {
      "id": "sn1.78:2.3",
      "pali": "Vācaṁ muñceyya kalyāṇaṁ,"
    },
    {
      "id": "sn1.78:2.4",
      "pali": "pāpikañca na mocaye”ti."
    }
  ]
}
