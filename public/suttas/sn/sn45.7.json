{
  "uid": "sn45.7",
  "title": "Dutiyaaññatarabhikkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.7:1.2",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn45.7:2.1",
      "pali": "“‘Rāgavinayo dosavinayo mohavinayo’ti, bhante, vuccati."
    },
    {
      "id": "sn45.7:2.2",
      "pali": "Kissa nu kho etaṁ, bhante, adhivacanaṁ:"
    },
    {
      "id": "sn45.7:2.3",
      "pali": "‘rāgavinayo dosavinayo mohavinayo’”ti?"
    },
    {
      "id": "sn45.7:2.4",
      "pali": "“Nibbānadhātuyā kho etaṁ, bhikkhu, adhivacanaṁ:"
    },
    {
      "id": "sn45.7:2.5",
      "pali": "‘rāgavinayo dosavinayo mohavinayo’ti."
    },
    {
      "id": "sn45.7:2.6",
      "pali": "Āsavānaṁ khayo tena vuccatī”ti."
    },
    {
      "id": "sn45.7:3.1",
      "pali": "Evaṁ vutte, so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn45.7:3.2",
      "pali": "“‘amataṁ, amatan’ti, bhante, vuccati."
    },
    {
      "id": "sn45.7:3.3",
      "pali": "Katamaṁ nu kho, bhante, amataṁ, katamo amatagāmimaggo”ti?"
    },
    {
      "id": "sn45.7:3.4",
      "pali": "“Yo kho, bhikkhu, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.7:3.5",
      "pali": "idaṁ vuccati amataṁ."
    },
    {
      "id": "sn45.7:3.6",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo amatagāmimaggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.7:3.7",
      "pali": "sammādiṭṭhi …pe… sammāsamādhī”ti."
    },
    {
      "id": "sn45.7:3.8",
      "pali": "Sattamaṁ."
    }
  ]
}
