{
  "uid": "sn35.144",
  "title": "Bāhiradukkhahetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.144:1.1",
      "pali": "“Rūpā, bhikkhave, dukkhā."
    },
    {
      "id": "sn35.144:1.2",
      "pali": "Yopi hetu, yopi paccayo rūpānaṁ uppādāya, sopi dukkho."
    },
    {
      "id": "sn35.144:1.3",
      "pali": "Dukkhasambhūtā, bhikkhave, rūpā kuto sukhā bhavissanti."
    },
    {
      "id": "sn35.144:1.4",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.144:1.5",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.144:1.6",
      "pali": "rasā …"
    },
    {
      "id": "sn35.144:1.7",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.144:1.8",
      "pali": "dhammā dukkhā."
    },
    {
      "id": "sn35.144:1.9",
      "pali": "Yopi hetu, yopi paccayo dhammānaṁ uppādāya, sopi dukkho."
    },
    {
      "id": "sn35.144:1.10",
      "pali": "Dukkhasambhūtā, bhikkhave, dhammā kuto sukhā bhavissanti."
    },
    {
      "id": "sn35.144:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.144:1.12",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.144:1.13",
      "pali": "Ekādasamaṁ."
    }
  ]
}
