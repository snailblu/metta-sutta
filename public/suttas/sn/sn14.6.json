{
  "uid": "sn14.6",
  "title": "Bāhiradhātunānattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.6:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.6:1.2",
      "pali": "“Dhātunānattaṁ vo, bhikkhave, desessāmi."
    },
    {
      "id": "sn14.6:1.3",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "sn14.6:1.4",
      "pali": "katamañca, bhikkhave, dhātunānattaṁ?"
    },
    {
      "id": "sn14.6:1.5",
      "pali": "Rūpadhātu saddadhātu gandhadhātu rasadhātu phoṭṭhabbadhātu dhammadhātu—"
    },
    {
      "id": "sn14.6:1.6",
      "pali": "idaṁ vuccati, bhikkhave, dhātunānattan”ti."
    },
    {
      "id": "sn14.6:1.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
