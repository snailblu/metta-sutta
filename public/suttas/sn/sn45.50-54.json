{
  "uid": "sn45.50-54",
  "title": "Sīlasampadādisuttapañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.50-54:1.1",
      "pali": "“Sūriyassa, bhikkhave, udayato etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—aruṇuggaṁ;"
    },
    {
      "id": "sn45.50-54:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhuno ariyassa aṭṭhaṅgikassa maggassa uppādāya etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—sīlasampadā."
    },
    {
      "id": "sn45.50-54:1.3",
      "pali": "Sīlasampannassetaṁ, bhikkhave, bhikkhuno pāṭikaṅkhaṁ …pe…"
    },
    {
      "id": "sn45.50-54:1.4",
      "pali": "yadidaṁ—chandasampadā …pe…"
    },
    {
      "id": "sn45.50-54:1.5",
      "pali": "yadidaṁ—attasampadā …pe…"
    },
    {
      "id": "sn45.50-54:1.6",
      "pali": "yadidaṁ—diṭṭhisampadā …pe…"
    },
    {
      "id": "sn45.50-54:1.7",
      "pali": "yadidaṁ—appamādasampadā …pe…."
    },
    {
      "id": "sn45.50-54:1.8",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
