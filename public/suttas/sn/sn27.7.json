{
  "uid": "sn27.7",
  "title": "Sañcetanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.7:1.2",
      "pali": "“Yo, bhikkhave, rūpasañcetanāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.7:1.3",
      "pali": "Yo saddasañcetanāya …"
    },
    {
      "id": "sn27.7:1.4",
      "pali": "yo gandhasañcetanāya …"
    },
    {
      "id": "sn27.7:1.5",
      "pali": "yo rasasañcetanāya …"
    },
    {
      "id": "sn27.7:1.6",
      "pali": "yo phoṭṭhabbasañcetanāya …"
    },
    {
      "id": "sn27.7:1.7",
      "pali": "yo dhammasañcetanāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.7:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno …pe…"
    },
    {
      "id": "sn27.7:1.9",
      "pali": "abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.7:1.10",
      "pali": "Sattamaṁ."
    }
  ]
}
