{
  "uid": "sn46.47",
  "title": "Adaliddasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.47:1.1",
      "pali": "“‘Adaliddo, adaliddo’ti, bhante, vuccati."
    },
    {
      "id": "sn46.47:1.2",
      "pali": "Kittāvatā nu kho, bhante, ‘adaliddo’ti vuccatī”ti?"
    },
    {
      "id": "sn46.47:1.3",
      "pali": "“Sattannaṁ kho, bhikkhu, bojjhaṅgānaṁ bhāvitattā bahulīkatattā ‘adaliddo’ti vuccati."
    },
    {
      "id": "sn46.47:1.4",
      "pali": "Katamesaṁ sattannaṁ?"
    },
    {
      "id": "sn46.47:1.5",
      "pali": "Satisambojjhaṅgassa …pe… upekkhāsambojjhaṅgassa—"
    },
    {
      "id": "sn46.47:1.6",
      "pali": "imesaṁ kho, bhikkhu, sattannaṁ bojjhaṅgānaṁ bhāvitattā bahulīkatattā ‘adaliddo’ti vuccatī”ti."
    },
    {
      "id": "sn46.47:1.7",
      "pali": "Sattamaṁ."
    }
  ]
}
