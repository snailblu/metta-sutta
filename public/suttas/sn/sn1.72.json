{
  "uid": "sn1.72",
  "title": "Rathasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.72:1.1",
      "pali": "“Kiṁsu rathassa paññāṇaṁ,"
    },
    {
      "id": "sn1.72:1.2",
      "pali": "kiṁsu paññāṇamaggino;"
    },
    {
      "id": "sn1.72:1.3",
      "pali": "Kiṁsu raṭṭhassa paññāṇaṁ,"
    },
    {
      "id": "sn1.72:1.4",
      "pali": "kiṁsu paññāṇamitthiyā”ti."
    },
    {
      "id": "sn1.72:2.1",
      "pali": "“Dhajo rathassa paññāṇaṁ,"
    },
    {
      "id": "sn1.72:2.2",
      "pali": "dhūmo paññāṇamaggino;"
    },
    {
      "id": "sn1.72:2.3",
      "pali": "Rājā raṭṭhassa paññāṇaṁ,"
    },
    {
      "id": "sn1.72:2.4",
      "pali": "bhattā paññāṇamitthiyā”ti."
    }
  ]
}
