{
  "uid": "sn18.8",
  "title": "Taṇhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.8:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.8:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.8:1.3",
      "pali": "rūpataṇhā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.8:1.4",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.8:1.5",
      "pali": "“saddataṇhā …pe…"
    },
    {
      "id": "sn18.8:1.6",
      "pali": "gandhataṇhā …"
    },
    {
      "id": "sn18.8:1.7",
      "pali": "rasataṇhā …"
    },
    {
      "id": "sn18.8:1.8",
      "pali": "phoṭṭhabbataṇhā …"
    },
    {
      "id": "sn18.8:1.9",
      "pali": "dhammataṇhā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.8:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.8:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpataṇhāyapi nibbindati …pe… saddataṇhāyapi nibbindati … gandhataṇhāyapi nibbindati … rasataṇhāyapi nibbindati … phoṭṭhabbataṇhāyapi nibbindati … dhammataṇhāyapi nibbindati …pe…"
    },
    {
      "id": "sn18.8:1.12",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.8:1.13",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
