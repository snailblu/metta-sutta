{
  "uid": "sn52.7",
  "title": "Taṇhākkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn52.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn52.7:1.2",
      "pali": "Tatra kho āyasmā anuruddho bhikkhū āmantesi:"
    },
    {
      "id": "sn52.7:1.3",
      "pali": "“āvuso bhikkhavo”ti."
    },
    {
      "id": "sn52.7:1.4",
      "pali": "“Āvuso”ti kho te bhikkhū āyasmato anuruddhassa paccassosuṁ."
    },
    {
      "id": "sn52.7:1.5",
      "pali": "Āyasmā anuruddho etadavoca:"
    },
    {
      "id": "sn52.7:2.1",
      "pali": "“Cattārome, āvuso, satipaṭṭhānā bhāvitā bahulīkatā taṇhākkhayāya saṁvattanti."
    },
    {
      "id": "sn52.7:2.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn52.7:2.3",
      "pali": "Idhāvuso, bhikkhu kāye kāyānupassī viharati …pe…"
    },
    {
      "id": "sn52.7:2.4",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn52.7:2.5",
      "pali": "citte …pe…"
    },
    {
      "id": "sn52.7:2.6",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ—"
    },
    {
      "id": "sn52.7:2.7",
      "pali": "ime kho, āvuso, cattāro satipaṭṭhānā bhāvitā bahulīkatā taṇhākkhayāya saṁvattantī”ti."
    },
    {
      "id": "sn52.7:2.8",
      "pali": "Sattamaṁ."
    }
  ]
}
