{
  "uid": "sn46.29",
  "title": "Ekadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.29:1.1",
      "pali": "“Nāhaṁ, bhikkhave, aññaṁ ekadhammampi samanupassāmi, yo evaṁ bhāvito bahulīkato saṁyojanīyānaṁ dhammānaṁ pahānāya saṁvattati, yathayidaṁ, bhikkhave, satta bojjhaṅgā."
    },
    {
      "id": "sn46.29:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.29:1.3",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo."
    },
    {
      "id": "sn46.29:1.4",
      "pali": "Kathaṁ bhāvitā ca, bhikkhave, satta bojjhaṅgā kathaṁ bahulīkatā saṁyojanīyānaṁ dhammānaṁ pahānāya saṁvattanti?"
    },
    {
      "id": "sn46.29:2.1",
      "pali": "Idha, bhikkhave, bhikkhu satisambojjhaṅgaṁ bhāveti vivekanissitaṁ …pe…"
    },
    {
      "id": "sn46.29:2.2",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn46.29:2.3",
      "pali": "Evaṁ bhāvitā kho, bhikkhave, satta bojjhaṅgā evaṁ bahulīkatā saṁyojanīyānaṁ dhammānaṁ pahānāya saṁvattanti."
    },
    {
      "id": "sn46.29:3.1",
      "pali": "Katame ca, bhikkhave, saṁyojanīyā dhammā?"
    },
    {
      "id": "sn46.29:3.2",
      "pali": "Cakkhu, bhikkhave, saṁyojanīyo dhammo."
    },
    {
      "id": "sn46.29:3.3",
      "pali": "Etthete uppajjanti saṁyojanavinibandhā ajjhosānā …pe…"
    },
    {
      "id": "sn46.29:3.4",
      "pali": "jivhā saṁyojanīyā dhammā."
    },
    {
      "id": "sn46.29:3.5",
      "pali": "Etthete uppajjanti saṁyojanavinibandhā ajjhosānā …pe…"
    },
    {
      "id": "sn46.29:3.6",
      "pali": "mano saṁyojanīyo dhammo."
    },
    {
      "id": "sn46.29:3.7",
      "pali": "Etthete uppajjanti saṁyojanavinibandhā ajjhosānā."
    },
    {
      "id": "sn46.29:3.8",
      "pali": "Ime vuccanti, bhikkhave, saṁyojanīyā dhammā”ti."
    },
    {
      "id": "sn46.29:3.9",
      "pali": "Navamaṁ."
    }
  ]
}
