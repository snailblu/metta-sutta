{
  "uid": "snp2.6",
  "title": "Kapilasutta (dhammacariyasutta)",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp2.6:1.1",
      "pali": "Dhammacariyaṁ brahmacariyaṁ,"
    },
    {
      "id": "snp2.6:1.2",
      "pali": "Etadāhu vasuttamaṁ;"
    },
    {
      "id": "snp2.6:1.3",
      "pali": "Pabbajitopi ce hoti,"
    },
    {
      "id": "snp2.6:1.4",
      "pali": "Agārā anagāriyaṁ."
    },
    {
      "id": "snp2.6:2.1",
      "pali": "So ce mukharajātiko,"
    },
    {
      "id": "snp2.6:2.2",
      "pali": "vihesābhirato mago;"
    },
    {
      "id": "snp2.6:2.3",
      "pali": "Jīvitaṁ tassa pāpiyo,"
    },
    {
      "id": "snp2.6:2.4",
      "pali": "rajaṁ vaḍḍheti attano."
    },
    {
      "id": "snp2.6:3.1",
      "pali": "Kalahābhirato bhikkhu,"
    },
    {
      "id": "snp2.6:3.2",
      "pali": "Mohadhammena āvuto;"
    },
    {
      "id": "snp2.6:3.3",
      "pali": "Akkhātampi na jānāti,"
    },
    {
      "id": "snp2.6:3.4",
      "pali": "Dhammaṁ buddhena desitaṁ."
    },
    {
      "id": "snp2.6:4.1",
      "pali": "Vihesaṁ bhāvitattānaṁ,"
    },
    {
      "id": "snp2.6:4.2",
      "pali": "avijjāya purakkhato;"
    },
    {
      "id": "snp2.6:4.3",
      "pali": "Saṅkilesaṁ na jānāti,"
    },
    {
      "id": "snp2.6:4.4",
      "pali": "maggaṁ nirayagāminaṁ."
    },
    {
      "id": "snp2.6:5.1",
      "pali": "Vinipātaṁ samāpanno,"
    },
    {
      "id": "snp2.6:5.2",
      "pali": "gabbhā gabbhaṁ tamā tamaṁ;"
    },
    {
      "id": "snp2.6:5.3",
      "pali": "Sa ve tādisako bhikkhu,"
    },
    {
      "id": "snp2.6:5.4",
      "pali": "pecca dukkhaṁ nigacchati."
    },
    {
      "id": "snp2.6:6.1",
      "pali": "Gūthakūpo yathā assa,"
    },
    {
      "id": "snp2.6:6.2",
      "pali": "sampuṇṇo gaṇavassiko;"
    },
    {
      "id": "snp2.6:6.3",
      "pali": "Yo ca evarūpo assa,"
    },
    {
      "id": "snp2.6:6.4",
      "pali": "dubbisodho hi sāṅgaṇo."
    },
    {
      "id": "snp2.6:7.1",
      "pali": "Yaṁ evarūpaṁ jānātha,"
    },
    {
      "id": "snp2.6:7.2",
      "pali": "bhikkhavo gehanissitaṁ;"
    },
    {
      "id": "snp2.6:7.3",
      "pali": "Pāpicchaṁ pāpasaṅkappaṁ,"
    },
    {
      "id": "snp2.6:7.4",
      "pali": "pāpaācāragocaraṁ."
    },
    {
      "id": "snp2.6:8.1",
      "pali": "Sabbe samaggā hutvāna,"
    },
    {
      "id": "snp2.6:8.2",
      "pali": "abhinibbajjiyātha naṁ;"
    },
    {
      "id": "snp2.6:8.3",
      "pali": "Kāraṇḍavaṁ niddhamatha,"
    },
    {
      "id": "snp2.6:8.4",
      "pali": "kasambuṁ apakassatha."
    },
    {
      "id": "snp2.6:9.1",
      "pali": "Tato palāpe vāhetha,"
    },
    {
      "id": "snp2.6:9.2",
      "pali": "Assamaṇe samaṇamānine;"
    },
    {
      "id": "snp2.6:9.3",
      "pali": "Niddhamitvāna pāpicche,"
    },
    {
      "id": "snp2.6:9.4",
      "pali": "Pāpaācāragocare."
    },
    {
      "id": "snp2.6:10.1",
      "pali": "Suddhā suddhehi saṁvāsaṁ,"
    },
    {
      "id": "snp2.6:10.2",
      "pali": "Kappayavho patissatā;"
    },
    {
      "id": "snp2.6:10.3",
      "pali": "Tato samaggā nipakā,"
    },
    {
      "id": "snp2.6:10.4",
      "pali": "Dukkhassantaṁ karissathāti."
    },
    {
      "id": "snp2.6:10.5",
      "pali": "Dhammacariyasuttaṁ chaṭṭhaṁ."
    }
  ]
}
