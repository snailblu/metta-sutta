{
  "uid": "sn52.24",
  "title": "Āsavakkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn52.24:1.1",
      "pali": "“Imesañca panāhaṁ, āvuso, catunnaṁ satipaṭṭhānānaṁ bhāvitattā bahulīkatattā āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharāmī”ti."
    },
    {
      "id": "sn52.24:1.2",
      "pali": "Cuddasamaṁ."
    },
    {
      "id": "sn52.24:1.3",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn52.24:2.1",
      "pali": "Mahābhiññaṁ iddhi dibbaṁ,"
    },
    {
      "id": "sn52.24:2.2",
      "pali": "Cetopariyaṁ ṭhānaṁ kammaṁ;"
    },
    {
      "id": "sn52.24:2.3",
      "pali": "Sabbatthadhātudhimutti,"
    },
    {
      "id": "sn52.24:2.4",
      "pali": "Indriyaṁ jhānaṁ tisso vijjāti."
    },
    {
      "id": "sn52.24:2.5",
      "pali": "Anuruddhasaṁyuttaṁ aṭṭhamaṁ."
    }
  ]
}
