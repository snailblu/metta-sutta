{
  "uid": "sn1.53",
  "title": "Mittasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.53:1.1",
      "pali": "“Kiṁsu pavasato mittaṁ,"
    },
    {
      "id": "sn1.53:1.2",
      "pali": "kiṁsu mittaṁ sake ghare;"
    },
    {
      "id": "sn1.53:1.3",
      "pali": "Kiṁ mittaṁ atthajātassa,"
    },
    {
      "id": "sn1.53:1.4",
      "pali": "kiṁ mittaṁ samparāyikan”ti."
    },
    {
      "id": "sn1.53:2.1",
      "pali": "“Sattho pavasato mittaṁ,"
    },
    {
      "id": "sn1.53:2.2",
      "pali": "mātā mittaṁ sake ghare;"
    },
    {
      "id": "sn1.53:2.3",
      "pali": "Sahāyo atthajātassa,"
    },
    {
      "id": "sn1.53:2.4",
      "pali": "hoti mittaṁ punappunaṁ;"
    },
    {
      "id": "sn1.53:2.5",
      "pali": "Sayaṅkatāni puññāni,"
    },
    {
      "id": "sn1.53:2.6",
      "pali": "taṁ mittaṁ samparāyikan”ti."
    }
  ]
}
