{
  "uid": "sn48.83-92",
  "title": "Appamādavagga",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.83-92:1.1",
      "pali": "(Appamādavaggo vitthāretabbo.)"
    },
    {
      "id": "sn48.83-92:2.1",
      "pali": "Tathāgataṁ padaṁ kūṭaṁ,"
    },
    {
      "id": "sn48.83-92:2.2",
      "pali": "mūlaṁ sārena vassikaṁ;"
    },
    {
      "id": "sn48.83-92:2.3",
      "pali": "Rājā candimasūriyā,"
    },
    {
      "id": "sn48.83-92:2.4",
      "pali": "vatthena dasamaṁ padanti."
    }
  ]
}
