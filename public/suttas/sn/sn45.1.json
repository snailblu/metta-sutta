{
  "uid": "sn45.1",
  "title": "Avijjāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn45.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn45.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn45.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn45.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn45.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn45.1:2.1",
      "pali": "“Avijjā, bhikkhave, pubbaṅgamā akusalānaṁ dhammānaṁ samāpattiyā, anvadeva ahirikaṁ anottappaṁ."
    },
    {
      "id": "sn45.1:2.2",
      "pali": "Avijjāgatassa, bhikkhave, aviddasuno micchādiṭṭhi pahoti;"
    },
    {
      "id": "sn45.1:2.3",
      "pali": "micchādiṭṭhissa micchāsaṅkappo pahoti;"
    },
    {
      "id": "sn45.1:2.4",
      "pali": "micchāsaṅkappassa micchāvācā pahoti;"
    },
    {
      "id": "sn45.1:2.5",
      "pali": "micchāvācassa micchākammanto pahoti;"
    },
    {
      "id": "sn45.1:2.6",
      "pali": "micchākammantassa micchāājīvo pahoti;"
    },
    {
      "id": "sn45.1:2.7",
      "pali": "micchāājīvassa micchāvāyāmo pahoti;"
    },
    {
      "id": "sn45.1:2.8",
      "pali": "micchāvāyāmassa micchāsati pahoti;"
    },
    {
      "id": "sn45.1:2.9",
      "pali": "micchāsatissa micchāsamādhi pahoti."
    },
    {
      "id": "sn45.1:3.1",
      "pali": "Vijjā ca kho, bhikkhave, pubbaṅgamā kusalānaṁ dhammānaṁ samāpattiyā, anvadeva hirottappaṁ."
    },
    {
      "id": "sn45.1:3.2",
      "pali": "Vijjāgatassa, bhikkhave, viddasuno sammādiṭṭhi pahoti;"
    },
    {
      "id": "sn45.1:3.3",
      "pali": "sammādiṭṭhissa sammāsaṅkappo pahoti;"
    },
    {
      "id": "sn45.1:3.4",
      "pali": "sammāsaṅkappassa sammāvācā pahoti;"
    },
    {
      "id": "sn45.1:3.5",
      "pali": "sammāvācassa sammākammanto pahoti;"
    },
    {
      "id": "sn45.1:3.6",
      "pali": "sammākammantassa sammāājīvo pahoti;"
    },
    {
      "id": "sn45.1:3.7",
      "pali": "sammāājīvassa sammāvāyāmo pahoti;"
    },
    {
      "id": "sn45.1:3.8",
      "pali": "sammāvāyāmassa sammāsati pahoti;"
    },
    {
      "id": "sn45.1:3.9",
      "pali": "sammāsatissa sammāsamādhi pahotī”ti."
    },
    {
      "id": "sn45.1:3.10",
      "pali": "Paṭhamaṁ."
    }
  ]
}
