{
  "uid": "sn12.60",
  "title": "Nidānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.60:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā kurūsu viharati kammāsadhammaṁ nāma kurūnaṁ nigamo."
    },
    {
      "id": "sn12.60:1.2",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā ānando bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.60:1.3",
      "pali": "“acchariyaṁ, bhante, abbhutaṁ, bhante."
    },
    {
      "id": "sn12.60:1.4",
      "pali": "Yāva gambhīro cāyaṁ, bhante, paṭiccasamuppādo gambhīrāvabhāso ca, atha ca pana me uttānakuttānako viya khāyatī”ti."
    },
    {
      "id": "sn12.60:2.1",
      "pali": "“Mā hevaṁ, ānanda, mā hevaṁ, ānanda."
    },
    {
      "id": "sn12.60:2.2",
      "pali": "Gambhīro cāyaṁ, ānanda, paṭiccasamuppādo gambhīrāvabhāso ca."
    },
    {
      "id": "sn12.60:2.3",
      "pali": "Etassa, ānanda, dhammassa ananubodhā appaṭivedhā evamayaṁ pajā tantākulakajātā kulagaṇṭhikajātā muñjapabbajabhūtā apāyaṁ duggatiṁ vinipātaṁ saṁsāraṁ nātivattati."
    },
    {
      "id": "sn12.60:3.1",
      "pali": "Upādāniyesu, ānanda, dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.60:3.2",
      "pali": "Taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.60:3.3",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.60:3.4",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.60:3.5",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.60:3.6",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.60:4.1",
      "pali": "Seyyathāpi, ānanda, mahārukkho."
    },
    {
      "id": "sn12.60:4.2",
      "pali": "Tassa yāni ceva mūlāni adhogamāni, yāni ca tiriyaṅgamāni, sabbāni tāni uddhaṁ ojaṁ abhiharanti."
    },
    {
      "id": "sn12.60:4.3",
      "pali": "Evañhi so, ānanda, mahārukkho tadāhāro tadupādāno ciraṁ dīghamaddhānaṁ tiṭṭheyya."
    },
    {
      "id": "sn12.60:4.4",
      "pali": "Evameva kho, ānanda, upādāniyesu dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.60:4.5",
      "pali": "Taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.60:4.6",
      "pali": "upādānapaccayā bhavo …pe…"
    },
    {
      "id": "sn12.60:4.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.60:5.1",
      "pali": "Upādāniyesu, ānanda, dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.60:5.2",
      "pali": "Taṇhānirodhā upādānanirodho;"
    },
    {
      "id": "sn12.60:5.3",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn12.60:5.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.60:6.1",
      "pali": "Seyyathāpi, ānanda, mahārukkho."
    },
    {
      "id": "sn12.60:6.2",
      "pali": "Atha puriso āgaccheyya kuddālapiṭakaṁ ādāya."
    },
    {
      "id": "sn12.60:6.3",
      "pali": "So taṁ rukkhaṁ mūle chindeyya, mūle chetvā palikhaṇeyya, palikhaṇitvā mūlāni uddhareyya antamaso usīranāḷimattānipi."
    },
    {
      "id": "sn12.60:6.4",
      "pali": "So taṁ rukkhaṁ khaṇḍākhaṇḍikaṁ chindeyya."
    },
    {
      "id": "sn12.60:6.5",
      "pali": "Khaṇḍākhaṇḍikaṁ chinditvā phāleyya;"
    },
    {
      "id": "sn12.60:6.6",
      "pali": "phāletvā sakalikaṁ sakalikaṁ kareyya, sakalikaṁ sakalikaṁ karitvā vātātape visoseyya, vātātape visosetvā agginā ḍaheyya, agginā ḍahetvā masiṁ kareyya, masiṁ karitvā mahāvāte vā ophuṇeyya, nadiyā vā sīghasotāya pavāheyya."
    },
    {
      "id": "sn12.60:6.7",
      "pali": "Evañhi so, ānanda, mahārukkho ucchinnamūlo assa tālāvatthukato anabhāvaṅkato āyatiṁ anuppādadhammo."
    },
    {
      "id": "sn12.60:6.8",
      "pali": "Evameva kho, ānanda, upādāniyesu dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.60:6.9",
      "pali": "Taṇhānirodhā upādānanirodho;"
    },
    {
      "id": "sn12.60:6.10",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.60:6.11",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.60:6.12",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.60:6.13",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.60:6.14",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn12.60:6.15",
      "pali": "Dukkhavaggo chaṭṭho."
    },
    {
      "id": "sn12.60:7.1",
      "pali": "Parivīmaṁsanupādānaṁ,"
    },
    {
      "id": "sn12.60:7.2",
      "pali": "dve ca saṁyojanāni ca;"
    },
    {
      "id": "sn12.60:7.3",
      "pali": "Mahārukkhena dve vuttā,"
    },
    {
      "id": "sn12.60:7.4",
      "pali": "taruṇena ca sattamaṁ;"
    },
    {
      "id": "sn12.60:7.5",
      "pali": "Nāmarūpañca viññāṇaṁ,"
    },
    {
      "id": "sn12.60:7.6",
      "pali": "nidānena ca te dasāti."
    }
  ]
}
