{
  "uid": "sn45.176",
  "title": "Kāmaguṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.176:1.1",
      "pali": "“Pañcime, bhikkhave, kāmaguṇā."
    },
    {
      "id": "sn45.176:1.2",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn45.176:1.3",
      "pali": "Cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā,"
    },
    {
      "id": "sn45.176:1.4",
      "pali": "sotaviññeyyā saddā …pe… ghānaviññeyyā gandhā …pe…"
    },
    {
      "id": "sn45.176:1.5",
      "pali": "jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn45.176:1.6",
      "pali": "kāyaviññeyyā phoṭṭhabbā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā—"
    },
    {
      "id": "sn45.176:1.7",
      "pali": "ime kho, bhikkhave, pañca kāmaguṇā."
    },
    {
      "id": "sn45.176:1.8",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ kāmaguṇānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.176:1.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
