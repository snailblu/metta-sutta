{
  "uid": "sn45.173",
  "title": "Upādānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.173:1.1",
      "pali": "“Cattārimāni, bhikkhave, upādānāni."
    },
    {
      "id": "sn45.173:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "sn45.173:1.3",
      "pali": "Kāmupādānaṁ, diṭṭhupādānaṁ, sīlabbatupādānaṁ, attavādupādānaṁ—"
    },
    {
      "id": "sn45.173:1.4",
      "pali": "imāni kho, bhikkhave, cattāri upādānāni."
    },
    {
      "id": "sn45.173:1.5",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ upādānānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.173:1.6",
      "pali": "Tatiyaṁ."
    }
  ]
}
