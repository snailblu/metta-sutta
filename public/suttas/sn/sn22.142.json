{
  "uid": "sn22.142",
  "title": "Tatiyadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.142:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.142:1.2",
      "pali": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo chandarāgo pahātabbo …pe…"
    },
    {
      "id": "sn22.142:1.3",
      "pali": "yaṁ, bhikkhave, dukkhaṁ; tatra vo chandarāgo pahātabbo”ti."
    },
    {
      "id": "sn22.142:1.4",
      "pali": "Sattamaṁ."
    }
  ]
}
