{
  "uid": "sn1.77",
  "title": "Issariyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.77:1.1",
      "pali": "“Kiṁsu issariyaṁ loke,"
    },
    {
      "id": "sn1.77:1.2",
      "pali": "kiṁsu bhaṇḍānamuttamaṁ;"
    },
    {
      "id": "sn1.77:1.3",
      "pali": "Kiṁsu satthamalaṁ loke,"
    },
    {
      "id": "sn1.77:1.4",
      "pali": "kiṁsu lokasmimabbudaṁ."
    },
    {
      "id": "sn1.77:2.1",
      "pali": "Kiṁsu harantaṁ vārenti,"
    },
    {
      "id": "sn1.77:2.2",
      "pali": "haranto pana ko piyo;"
    },
    {
      "id": "sn1.77:2.3",
      "pali": "Kiṁsu punappunāyantaṁ,"
    },
    {
      "id": "sn1.77:2.4",
      "pali": "abhinandanti paṇḍitā”ti."
    },
    {
      "id": "sn1.77:3.1",
      "pali": "“Vaso issariyaṁ loke,"
    },
    {
      "id": "sn1.77:3.2",
      "pali": "itthī bhaṇḍānamuttamaṁ;"
    },
    {
      "id": "sn1.77:3.3",
      "pali": "Kodho satthamalaṁ loke,"
    },
    {
      "id": "sn1.77:3.4",
      "pali": "corā lokasmimabbudā."
    },
    {
      "id": "sn1.77:4.1",
      "pali": "Coraṁ harantaṁ vārenti,"
    },
    {
      "id": "sn1.77:4.2",
      "pali": "haranto samaṇo piyo;"
    },
    {
      "id": "sn1.77:4.3",
      "pali": "Samaṇaṁ punappunāyantaṁ,"
    },
    {
      "id": "sn1.77:4.4",
      "pali": "abhinandanti paṇḍitā”ti."
    }
  ]
}
