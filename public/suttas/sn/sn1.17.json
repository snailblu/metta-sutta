{
  "uid": "sn1.17",
  "title": "Dukkarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.17:1.1",
      "pali": "“Dukkaraṁ duttitikkhañca,"
    },
    {
      "id": "sn1.17:1.2",
      "pali": "abyattena ca sāmaññaṁ;"
    },
    {
      "id": "sn1.17:1.3",
      "pali": "Bahūhi tattha sambādhā,"
    },
    {
      "id": "sn1.17:1.4",
      "pali": "yattha bālo visīdatī”ti."
    },
    {
      "id": "sn1.17:2.1",
      "pali": "“Katihaṁ careyya sāmaññaṁ,"
    },
    {
      "id": "sn1.17:2.2",
      "pali": "cittañce na nivāraye;"
    },
    {
      "id": "sn1.17:2.3",
      "pali": "Pade pade visīdeyya,"
    },
    {
      "id": "sn1.17:2.4",
      "pali": "saṅkappānaṁ vasānugoti."
    },
    {
      "id": "sn1.17:3.1",
      "pali": "Kummova aṅgāni sake kapāle,"
    },
    {
      "id": "sn1.17:3.2",
      "pali": "Samodahaṁ bhikkhu manovitakke;"
    },
    {
      "id": "sn1.17:3.3",
      "pali": "Anissito aññamaheṭhayāno,"
    },
    {
      "id": "sn1.17:3.4",
      "pali": "Parinibbuto nūpavadeyya kañcī”ti."
    }
  ]
}
