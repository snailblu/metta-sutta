{
  "uid": "sn9.8",
  "title": "Kulagharaṇīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.8:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.8:1.2",
      "pali": "Tena kho pana samayena so bhikkhu aññatarasmiṁ kule ativelaṁ ajjhogāḷhappatto viharati."
    },
    {
      "id": "sn9.8:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno anukampikā atthakāmā taṁ bhikkhuṁ saṁvejetukāmā yā tasmiṁ kule kulagharaṇī, tassā vaṇṇaṁ abhinimminitvā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn9.8:2.1",
      "pali": "“Nadītīresu saṇṭhāne,"
    },
    {
      "id": "sn9.8:2.2",
      "pali": "sabhāsu rathiyāsu ca;"
    },
    {
      "id": "sn9.8:2.3",
      "pali": "Janā saṅgamma mantenti,"
    },
    {
      "id": "sn9.8:2.4",
      "pali": "mañca tañca kimantaran”ti."
    },
    {
      "id": "sn9.8:3.1",
      "pali": "“Bahūhi saddā paccūhā,"
    },
    {
      "id": "sn9.8:3.2",
      "pali": "khamitabbā tapassinā;"
    },
    {
      "id": "sn9.8:3.3",
      "pali": "Na tena maṅku hotabbaṁ,"
    },
    {
      "id": "sn9.8:3.4",
      "pali": "na hi tena kilissati."
    },
    {
      "id": "sn9.8:4.1",
      "pali": "Yo ca saddaparittāsī,"
    },
    {
      "id": "sn9.8:4.2",
      "pali": "vane vātamigo yathā;"
    },
    {
      "id": "sn9.8:4.3",
      "pali": "Lahucittoti taṁ āhu,"
    },
    {
      "id": "sn9.8:4.4",
      "pali": "nāssa sampajjate vatan”ti."
    }
  ]
}
