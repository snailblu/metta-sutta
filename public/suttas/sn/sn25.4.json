{
  "uid": "sn25.4",
  "title": "Samphassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.4:1.2",
      "pali": "“Cakkhusamphasso, bhikkhave, anicco vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.4:1.3",
      "pali": "sotasamphasso …"
    },
    {
      "id": "sn25.4:1.4",
      "pali": "ghānasamphasso …"
    },
    {
      "id": "sn25.4:1.5",
      "pali": "jivhāsamphasso …"
    },
    {
      "id": "sn25.4:1.6",
      "pali": "kāyasamphasso …"
    },
    {
      "id": "sn25.4:1.7",
      "pali": "manosamphasso anicco vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.4:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.4:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.4:1.10",
      "pali": "Catutthaṁ."
    }
  ]
}
