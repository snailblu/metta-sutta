{
  "uid": "sn1.34",
  "title": "Nasantisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.34:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.34:1.2",
      "pali": "Atha kho sambahulā satullapakāyikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.34:1.3",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.34:2.1",
      "pali": "“Na santi kāmā manujesu niccā,"
    },
    {
      "id": "sn1.34:2.2",
      "pali": "Santīdha kamanīyāni yesu baddho;"
    },
    {
      "id": "sn1.34:2.3",
      "pali": "Yesu pamatto apunāgamanaṁ,"
    },
    {
      "id": "sn1.34:2.4",
      "pali": "Anāgantā puriso maccudheyyā”ti."
    },
    {
      "id": "sn1.34:3.1",
      "pali": "“Chandajaṁ aghaṁ chandajaṁ dukkhaṁ,"
    },
    {
      "id": "sn1.34:3.2",
      "pali": "Chandavinayā aghavinayo;"
    },
    {
      "id": "sn1.34:3.3",
      "pali": "Aghavinayā dukkhavinayo”ti."
    },
    {
      "id": "sn1.34:4.1",
      "pali": "“Na te kāmā yāni citrāni loke,"
    },
    {
      "id": "sn1.34:4.2",
      "pali": "Saṅkapparāgo purisassa kāmo;"
    },
    {
      "id": "sn1.34:4.3",
      "pali": "Tiṭṭhanti citrāni tatheva loke,"
    },
    {
      "id": "sn1.34:4.4",
      "pali": "Athettha dhīrā vinayanti chandaṁ."
    },
    {
      "id": "sn1.34:5.1",
      "pali": "Kodhaṁ jahe vippajaheyya mānaṁ,"
    },
    {
      "id": "sn1.34:5.2",
      "pali": "Saṁyojanaṁ sabbamatikkameyya;"
    },
    {
      "id": "sn1.34:5.3",
      "pali": "Taṁ nāmarūpasmimasajjamānaṁ,"
    },
    {
      "id": "sn1.34:5.4",
      "pali": "Akiñcanaṁ nānupatanti dukkhā."
    },
    {
      "id": "sn1.34:6.1",
      "pali": "Pahāsi saṅkhaṁ na vimānamajjhagā,"
    },
    {
      "id": "sn1.34:6.2",
      "pali": "Acchecchi taṇhaṁ idha nāmarūpe;"
    },
    {
      "id": "sn1.34:6.3",
      "pali": "Taṁ chinnaganthaṁ anighaṁ nirāsaṁ,"
    },
    {
      "id": "sn1.34:6.4",
      "pali": "Pariyesamānā nājjhagamuṁ;"
    },
    {
      "id": "sn1.34:6.5",
      "pali": "Devā manussā idha vā huraṁ vā,"
    },
    {
      "id": "sn1.34:6.6",
      "pali": "Saggesu vā sabbanivesanesū”ti."
    },
    {
      "id": "sn1.34:7.1",
      "pali": "“Tañce hi nāddakkhuṁ tathāvimuttaṁ,"
    },
    {
      "id": "sn1.34:7.2",
      "pali": "(iccāyasmā mogharājā)"
    },
    {
      "id": "sn1.34:7.3",
      "pali": "Devā manussā idha vā huraṁ vā;"
    },
    {
      "id": "sn1.34:7.4",
      "pali": "Naruttamaṁ atthacaraṁ narānaṁ,"
    },
    {
      "id": "sn1.34:7.5",
      "pali": "Ye taṁ namassanti pasaṁsiyā te”ti."
    },
    {
      "id": "sn1.34:8.1",
      "pali": "“Pasaṁsiyā tepi bhavanti bhikkhū,"
    },
    {
      "id": "sn1.34:8.2",
      "pali": "(mogharājāti bhagavā)"
    },
    {
      "id": "sn1.34:8.3",
      "pali": "Ye taṁ namassanti tathāvimuttaṁ;"
    },
    {
      "id": "sn1.34:8.4",
      "pali": "Aññāya dhammaṁ vicikicchaṁ pahāya,"
    },
    {
      "id": "sn1.34:8.5",
      "pali": "Saṅgātigā tepi bhavanti bhikkhū”ti."
    }
  ]
}
