{
  "uid": "sn18.5",
  "title": "Vedanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.5:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.5:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.5:1.3",
      "pali": "cakkhusamphassajā vedanā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.5:1.4",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.5:1.5",
      "pali": "“sotasamphassajā vedanā …pe…"
    },
    {
      "id": "sn18.5:1.6",
      "pali": "ghānasamphassajā vedanā …"
    },
    {
      "id": "sn18.5:1.7",
      "pali": "jivhāsamphassajā vedanā …"
    },
    {
      "id": "sn18.5:1.8",
      "pali": "kāyasamphassajā vedanā …"
    },
    {
      "id": "sn18.5:1.9",
      "pali": "manosamphassajā vedanā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.5:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.5:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusamphassajāya vedanāyapi nibbindati …pe… sota … ghāna … jivhā … kāya … manosamphassajāya vedanāyapi nibbindati …pe…"
    },
    {
      "id": "sn18.5:1.12",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.5:1.13",
      "pali": "Pañcamaṁ."
    }
  ]
}
