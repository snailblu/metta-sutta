{
  "uid": "sn3.17",
  "title": "Appamādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.17:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn3.17:1.2",
      "pali": "Ekamantaṁ nisīdi."
    },
    {
      "id": "sn3.17:1.3",
      "pali": "Ekamantaṁ nisinno kho rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.17:1.4",
      "pali": "“atthi nu kho, bhante, eko dhammo yo ubho atthe samadhiggayha tiṭṭhati—"
    },
    {
      "id": "sn3.17:1.5",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcā”ti?"
    },
    {
      "id": "sn3.17:2.1",
      "pali": "“Atthi kho, mahārāja, eko dhammo yo ubho atthe samadhiggayha tiṭṭhati—"
    },
    {
      "id": "sn3.17:2.2",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcā”ti."
    },
    {
      "id": "sn3.17:3.1",
      "pali": "“Katamo pana, bhante, eko dhammo, yo ubho atthe samadhiggayha tiṭṭhati—"
    },
    {
      "id": "sn3.17:3.2",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcā”ti?"
    },
    {
      "id": "sn3.17:4.1",
      "pali": "“Appamādo kho, mahārāja, eko dhammo, yo ubho atthe samadhiggayha tiṭṭhati—"
    },
    {
      "id": "sn3.17:4.2",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcāti."
    },
    {
      "id": "sn3.17:4.3",
      "pali": "Seyyathāpi, mahārāja, yāni kānici jaṅgalānaṁ pāṇānaṁ padajātāni, sabbāni tāni hatthipade samodhānaṁ gacchanti, hatthipadaṁ tesaṁ aggamakkhāyati—yadidaṁ mahantattena;"
    },
    {
      "id": "sn3.17:4.4",
      "pali": "evameva kho, mahārāja, appamādo eko dhammo, yo ubho atthe samadhiggayha tiṭṭhati—"
    },
    {
      "id": "sn3.17:4.5",
      "pali": "diṭṭhadhammikañceva atthaṁ samparāyikañcā”ti."
    },
    {
      "id": "sn3.17:4.6",
      "pali": "Idamavoca …pe…"
    },
    {
      "id": "sn3.17:5.1",
      "pali": "“Āyuṁ arogiyaṁ vaṇṇaṁ,"
    },
    {
      "id": "sn3.17:5.2",
      "pali": "saggaṁ uccākulīnataṁ;"
    },
    {
      "id": "sn3.17:5.3",
      "pali": "Ratiyo patthayantena,"
    },
    {
      "id": "sn3.17:5.4",
      "pali": "uḷārā aparāparā."
    },
    {
      "id": "sn3.17:6.1",
      "pali": "Appamādaṁ pasaṁsanti,"
    },
    {
      "id": "sn3.17:6.2",
      "pali": "puññakiriyāsu paṇḍitā;"
    },
    {
      "id": "sn3.17:6.3",
      "pali": "Appamatto ubho atthe,"
    },
    {
      "id": "sn3.17:6.4",
      "pali": "adhiggaṇhāti paṇḍito."
    },
    {
      "id": "sn3.17:7.1",
      "pali": "Diṭṭhe dhamme ca yo attho,"
    },
    {
      "id": "sn3.17:7.2",
      "pali": "yo cattho samparāyiko;"
    },
    {
      "id": "sn3.17:7.3",
      "pali": "Atthābhisamayā dhīro,"
    },
    {
      "id": "sn3.17:7.4",
      "pali": "paṇḍitoti pavuccatī”ti."
    }
  ]
}
