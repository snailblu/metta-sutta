{
  "uid": "sn45.35",
  "title": "Paṭhamasāmaññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.35:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.35:1.2",
      "pali": "“Sāmaññañca vo, bhikkhave, desessāmi, sāmaññaphalāni ca."
    },
    {
      "id": "sn45.35:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.35:1.4",
      "pali": "Katamañca, bhikkhave, sāmaññaṁ?"
    },
    {
      "id": "sn45.35:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.35:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.35:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, sāmaññaṁ."
    },
    {
      "id": "sn45.35:1.8",
      "pali": "Katamāni ca, bhikkhave, sāmaññaphalāni?"
    },
    {
      "id": "sn45.35:1.9",
      "pali": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—"
    },
    {
      "id": "sn45.35:1.10",
      "pali": "imāni vuccanti, bhikkhave, sāmaññaphalānī”ti."
    },
    {
      "id": "sn45.35:1.11",
      "pali": "Pañcamaṁ."
    }
  ]
}
