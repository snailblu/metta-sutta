{
  "uid": "sn12.57",
  "title": "Taruṇarukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.57:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.57:1.2",
      "pali": "“Saṁyojaniyesu, bhikkhave, dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.57:1.3",
      "pali": "Taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "sn12.57:1.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.57:2.1",
      "pali": "Seyyathāpi, bhikkhave, taruṇo rukkho."
    },
    {
      "id": "sn12.57:2.2",
      "pali": "Tassa puriso kālena kālaṁ mūlāni palimajjeyya kālena kālaṁ paṁsuṁ dadeyya, kālena kālaṁ udakaṁ dadeyya."
    },
    {
      "id": "sn12.57:2.3",
      "pali": "Evañhi so, bhikkhave, taruṇo rukkho tadāhāro tadupādāno vuddhiṁ virūḷhiṁ vepullaṁ āpajjeyya."
    },
    {
      "id": "sn12.57:2.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.57:2.5",
      "pali": "Taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "sn12.57:2.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.57:3.1",
      "pali": "Saṁyojaniyesu, bhikkhave, dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.57:3.2",
      "pali": "Taṇhānirodhā upādānanirodho …pe…"
    },
    {
      "id": "sn12.57:3.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.57:4.1",
      "pali": "Seyyathāpi, bhikkhave, taruṇo rukkho."
    },
    {
      "id": "sn12.57:4.2",
      "pali": "Atha puriso āgaccheyya kuddālapiṭakaṁ ādāya …pe…"
    },
    {
      "id": "sn12.57:4.3",
      "pali": "nadiyā vā sīghasotāya pavāheyya."
    },
    {
      "id": "sn12.57:4.4",
      "pali": "Evañhi so, bhikkhave, taruṇo rukkho ucchinnamūlo assa tālāvatthukato anabhāvaṅkato āyatiṁ anuppādadhammo."
    },
    {
      "id": "sn12.57:4.5",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.57:4.6",
      "pali": "Taṇhānirodhā upādānanirodho …pe…"
    },
    {
      "id": "sn12.57:4.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.57:4.8",
      "pali": "Sattamaṁ."
    }
  ]
}
