{
  "uid": "sn46.165-174",
  "title": "Punaesanādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.165-174:1.1",
      "pali": "…pe…"
    },
    {
      "id": "sn46.165-174:1.2",
      "pali": "Punaesanāvaggo sattarasamo."
    },
    {
      "id": "sn46.165-174:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn46.165-174:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn46.165-174:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn46.165-174:2.4",
      "pali": "Vedanātaṇhā tasināya cāti."
    }
  ]
}
