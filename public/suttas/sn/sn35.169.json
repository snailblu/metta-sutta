{
  "uid": "sn35.169",
  "title": "Ajjhattaaniccarāgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.169:1.1",
      "pali": "“Yaṁ, bhikkhave, aniccaṁ, tatra vo rāgo pahātabbo."
    },
    {
      "id": "sn35.169:1.2",
      "pali": "Kiñca, bhikkhave, aniccaṁ?"
    },
    {
      "id": "sn35.169:1.3",
      "pali": "Cakkhu, bhikkhave, aniccaṁ;"
    },
    {
      "id": "sn35.169:1.4",
      "pali": "tatra vo rāgo pahātabbo …pe…"
    },
    {
      "id": "sn35.169:1.5",
      "pali": "jivhā aniccā;"
    },
    {
      "id": "sn35.169:1.6",
      "pali": "tatra vo rāgo pahātabbo …pe…"
    },
    {
      "id": "sn35.169:1.7",
      "pali": "mano anicco;"
    },
    {
      "id": "sn35.169:1.8",
      "pali": "tatra vo rāgo pahātabbo."
    },
    {
      "id": "sn35.169:1.9",
      "pali": "Yaṁ, bhikkhave, aniccaṁ, tatra vo rāgo pahātabbo”ti."
    }
  ]
}
