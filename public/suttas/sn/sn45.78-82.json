{
  "uid": "sn45.78-82",
  "title": "Sīlasampadādisuttapañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.78-82:1.1",
      "pali": "“Nāhaṁ, bhikkhave, aññaṁ ekadhammampi samanupassāmi, yena anuppanno vā ariyo aṭṭhaṅgiko maggo uppajjati, uppanno vā ariyo aṭṭhaṅgiko maggo bhāvanāpāripūriṁ gacchati, yathayidaṁ, bhikkhave, sīlasampadā …pe…"
    },
    {
      "id": "sn45.78-82:1.2",
      "pali": "yathayidaṁ, bhikkhave, chandasampadā …pe…"
    },
    {
      "id": "sn45.78-82:1.3",
      "pali": "yathayidaṁ, bhikkhave, attasampadā …pe…"
    },
    {
      "id": "sn45.78-82:1.4",
      "pali": "yathayidaṁ, bhikkhave, diṭṭhisampadā …pe…"
    },
    {
      "id": "sn45.78-82:1.5",
      "pali": "yathayidaṁ, bhikkhave, appamādasampadā …pe…."
    },
    {
      "id": "sn45.78-82:1.6",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
