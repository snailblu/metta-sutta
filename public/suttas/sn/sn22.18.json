{
  "uid": "sn22.18",
  "title": "Sahetuaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.18:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.18:1.2",
      "pali": "“Rūpaṁ, bhikkhave, aniccaṁ."
    },
    {
      "id": "sn22.18:1.3",
      "pali": "Yopi hetu, yopi paccayo rūpassa uppādāya, sopi anicco."
    },
    {
      "id": "sn22.18:1.4",
      "pali": "Aniccasambhūtaṁ, bhikkhave, rūpaṁ kuto niccaṁ bhavissati."
    },
    {
      "id": "sn22.18:1.5",
      "pali": "Vedanā aniccā."
    },
    {
      "id": "sn22.18:1.6",
      "pali": "Yopi hetu, yopi paccayo vedanāya uppādāya, sopi anicco."
    },
    {
      "id": "sn22.18:1.7",
      "pali": "Aniccasambhūtā, bhikkhave, vedanā kuto niccā bhavissati."
    },
    {
      "id": "sn22.18:1.8",
      "pali": "Saññā aniccā …"
    },
    {
      "id": "sn22.18:1.9",
      "pali": "saṅkhārā aniccā."
    },
    {
      "id": "sn22.18:1.10",
      "pali": "Yopi hetu yopi paccayo saṅkhārānaṁ uppādāya, sopi anicco."
    },
    {
      "id": "sn22.18:1.11",
      "pali": "Aniccasambhūtā, bhikkhave, saṅkhārā kuto niccā bhavissanti."
    },
    {
      "id": "sn22.18:1.12",
      "pali": "Viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn22.18:1.13",
      "pali": "Yopi hetu yopi paccayo viññāṇassa uppādāya, sopi anicco."
    },
    {
      "id": "sn22.18:1.14",
      "pali": "Aniccasambhūtaṁ, bhikkhave, viññāṇaṁ kuto niccaṁ bhavissati."
    },
    {
      "id": "sn22.18:1.15",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.18:1.16",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.18:1.17",
      "pali": "Sattamaṁ."
    }
  ]
}
