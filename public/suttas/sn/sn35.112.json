{
  "uid": "sn35.112",
  "title": "Bāhirāyatanaparijānanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.112:1.1",
      "pali": "“Rūpe, bhikkhave, anabhijānaṁ aparijānaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "sn35.112:1.2",
      "pali": "Sadde …"
    },
    {
      "id": "sn35.112:1.3",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.112:1.4",
      "pali": "rase …"
    },
    {
      "id": "sn35.112:1.5",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.112:1.6",
      "pali": "dhamme anabhijānaṁ aparijānaṁ avirājayaṁ appajahaṁ abhabbo dukkhakkhayāya."
    },
    {
      "id": "sn35.112:1.7",
      "pali": "Rūpe ca kho, bhikkhave, abhijānaṁ parijānaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāya."
    },
    {
      "id": "sn35.112:1.8",
      "pali": "Sadde …"
    },
    {
      "id": "sn35.112:1.9",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.112:1.10",
      "pali": "rase …"
    },
    {
      "id": "sn35.112:1.11",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.112:1.12",
      "pali": "dhamme abhijānaṁ parijānaṁ virājayaṁ pajahaṁ bhabbo dukkhakkhayāyā”ti."
    },
    {
      "id": "sn35.112:1.13",
      "pali": "Navamaṁ."
    }
  ]
}
