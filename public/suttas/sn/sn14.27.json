{
  "uid": "sn14.27",
  "title": "Dasakammapathasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.27:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.27:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.27:1.3",
      "pali": "Pāṇātipātino pāṇātipātīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:1.4",
      "pali": "adinnādāyino …pe…"
    },
    {
      "id": "sn14.27:1.5",
      "pali": "kāmesumicchācārino …"
    },
    {
      "id": "sn14.27:1.6",
      "pali": "musāvādino …"
    },
    {
      "id": "sn14.27:1.7",
      "pali": "pisuṇavācā …"
    },
    {
      "id": "sn14.27:1.8",
      "pali": "pharusavācā …"
    },
    {
      "id": "sn14.27:1.9",
      "pali": "samphappalāpino samphappalāpīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:1.10",
      "pali": "abhijjhāluno abhijjhālūhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:1.11",
      "pali": "byāpannacittā byāpannacittehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:1.12",
      "pali": "micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.27:2.1",
      "pali": "Pāṇātipātā paṭiviratā pāṇātipātā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:2.2",
      "pali": "adinnādānā paṭiviratā …pe…"
    },
    {
      "id": "sn14.27:2.3",
      "pali": "kāmesumicchācārā paṭiviratā …"
    },
    {
      "id": "sn14.27:2.4",
      "pali": "musāvādā paṭiviratā …"
    },
    {
      "id": "sn14.27:2.5",
      "pali": "pisuṇāya vācāya …"
    },
    {
      "id": "sn14.27:2.6",
      "pali": "pharusāya vācāya …"
    },
    {
      "id": "sn14.27:2.7",
      "pali": "samphappalāpā paṭiviratā samphappalāpā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:2.8",
      "pali": "anabhijjhāluno anabhijjhālūhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:2.9",
      "pali": "abyāpannacittā abyāpannacittehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.27:2.10",
      "pali": "sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.27:2.11",
      "pali": "Pañcamaṁ."
    }
  ]
}
