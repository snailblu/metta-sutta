{
  "uid": "sn14.28",
  "title": "Aṭṭhaṅgikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.28:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.28:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.28:1.3",
      "pali": "Micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.28:1.4",
      "pali": "micchāsaṅkappā …pe…"
    },
    {
      "id": "sn14.28:1.5",
      "pali": "micchāvācā …"
    },
    {
      "id": "sn14.28:1.6",
      "pali": "micchākammantā …"
    },
    {
      "id": "sn14.28:1.7",
      "pali": "micchāājīvā …"
    },
    {
      "id": "sn14.28:1.8",
      "pali": "micchāvāyāmā …"
    },
    {
      "id": "sn14.28:1.9",
      "pali": "micchāsatino …"
    },
    {
      "id": "sn14.28:1.10",
      "pali": "micchāsamādhino micchāsamādhīhi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.28:2.1",
      "pali": "Sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.28:2.2",
      "pali": "sammāsaṅkappā …pe…"
    },
    {
      "id": "sn14.28:2.3",
      "pali": "sammāvācā …"
    },
    {
      "id": "sn14.28:2.4",
      "pali": "sammākammantā …"
    },
    {
      "id": "sn14.28:2.5",
      "pali": "sammāājīvā …"
    },
    {
      "id": "sn14.28:2.6",
      "pali": "sammāvāyāmā …"
    },
    {
      "id": "sn14.28:2.7",
      "pali": "sammāsatino …"
    },
    {
      "id": "sn14.28:2.8",
      "pali": "sammāsamādhino sammāsamādhīhi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.28:2.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
