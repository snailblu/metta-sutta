{
  "uid": "sn11.5",
  "title": "Subhāsitajayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn11.5:1.2",
      "pali": "“Bhūtapubbaṁ, bhikkhave, devāsurasaṅgāmo samupabyūḷho ahosi."
    },
    {
      "id": "sn11.5:1.3",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:1.4",
      "pali": "‘hotu, devānaminda, subhāsitena jayo’ti."
    },
    {
      "id": "sn11.5:1.5",
      "pali": "‘Hotu, vepacitti, subhāsitena jayo’ti."
    },
    {
      "id": "sn11.5:1.6",
      "pali": "Atha kho, bhikkhave, devā ca asurā ca pārisajje ṭhapesuṁ:"
    },
    {
      "id": "sn11.5:1.7",
      "pali": "‘ime no subhāsitadubbhāsitaṁ ājānissantī’ti."
    },
    {
      "id": "sn11.5:1.8",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:1.9",
      "pali": "‘bhaṇa, devānaminda, gāthan’ti."
    },
    {
      "id": "sn11.5:1.10",
      "pali": "Evaṁ vutte, bhikkhave, sakko devānamindo vepacittiṁ asurindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:1.11",
      "pali": "‘tumhe khvettha, vepacitti, pubbadevā."
    },
    {
      "id": "sn11.5:1.12",
      "pali": "Bhaṇa, vepacitti, gāthan’ti."
    },
    {
      "id": "sn11.5:1.13",
      "pali": "Evaṁ vutte, bhikkhave, vepacitti asurindo imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.5:2.1",
      "pali": "‘Bhiyyo bālā pabhijjeyyuṁ,"
    },
    {
      "id": "sn11.5:2.2",
      "pali": "no cassa paṭisedhako;"
    },
    {
      "id": "sn11.5:2.3",
      "pali": "Tasmā bhusena daṇḍena,"
    },
    {
      "id": "sn11.5:2.4",
      "pali": "dhīro bālaṁ nisedhaye’ti."
    },
    {
      "id": "sn11.5:3.1",
      "pali": "Bhāsitāya kho pana, bhikkhave, vepacittinā asurindena gāthāya asurā anumodiṁsu, devā tuṇhī ahesuṁ."
    },
    {
      "id": "sn11.5:3.2",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:3.3",
      "pali": "‘bhaṇa, devānaminda, gāthan’ti."
    },
    {
      "id": "sn11.5:3.4",
      "pali": "Evaṁ vutte, bhikkhave, sakko devānamindo imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.5:4.1",
      "pali": "‘Etadeva ahaṁ maññe,"
    },
    {
      "id": "sn11.5:4.2",
      "pali": "bālassa paṭisedhanaṁ;"
    },
    {
      "id": "sn11.5:4.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "sn11.5:4.4",
      "pali": "yo sato upasammatī’ti."
    },
    {
      "id": "sn11.5:5.1",
      "pali": "Bhāsitāya kho pana, bhikkhave, sakkena devānamindena gāthāya, devā anumodiṁsu, asurā tuṇhī ahesuṁ."
    },
    {
      "id": "sn11.5:5.2",
      "pali": "Atha kho, bhikkhave, sakko devānamindo vepacittiṁ asurindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:5.3",
      "pali": "‘bhaṇa, vepacitti, gāthan’ti."
    },
    {
      "id": "sn11.5:5.4",
      "pali": "Evaṁ vutte, bhikkhave, vepacitti asurindo imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.5:6.1",
      "pali": "‘Etadeva titikkhāya,"
    },
    {
      "id": "sn11.5:6.2",
      "pali": "vajjaṁ passāmi vāsava;"
    },
    {
      "id": "sn11.5:6.3",
      "pali": "Yadā naṁ maññati bālo,"
    },
    {
      "id": "sn11.5:6.4",
      "pali": "bhayā myāyaṁ titikkhati;"
    },
    {
      "id": "sn11.5:6.5",
      "pali": "Ajjhāruhati dummedho,"
    },
    {
      "id": "sn11.5:6.6",
      "pali": "gova bhiyyo palāyinan’ti."
    },
    {
      "id": "sn11.5:7.1",
      "pali": "Bhāsitāya kho pana, bhikkhave, vepacittinā asurindena gāthāya asurā anumodiṁsu, devā tuṇhī ahesuṁ."
    },
    {
      "id": "sn11.5:7.2",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ etadavoca:"
    },
    {
      "id": "sn11.5:7.3",
      "pali": "‘bhaṇa, devānaminda, gāthan’ti."
    },
    {
      "id": "sn11.5:7.4",
      "pali": "Evaṁ vutte, bhikkhave, sakko devānamindo imā gāthāyo abhāsi:"
    },
    {
      "id": "sn11.5:8.1",
      "pali": "‘Kāmaṁ maññatu vā mā vā,"
    },
    {
      "id": "sn11.5:8.2",
      "pali": "bhayā myāyaṁ titikkhati;"
    },
    {
      "id": "sn11.5:8.3",
      "pali": "Sadatthaparamā atthā,"
    },
    {
      "id": "sn11.5:8.4",
      "pali": "khantyā bhiyyo na vijjati."
    },
    {
      "id": "sn11.5:9.1",
      "pali": "Yo have balavā santo,"
    },
    {
      "id": "sn11.5:9.2",
      "pali": "dubbalassa titikkhati;"
    },
    {
      "id": "sn11.5:9.3",
      "pali": "Tamāhu paramaṁ khantiṁ,"
    },
    {
      "id": "sn11.5:9.4",
      "pali": "niccaṁ khamati dubbalo."
    },
    {
      "id": "sn11.5:10.1",
      "pali": "Abalaṁ taṁ balaṁ āhu,"
    },
    {
      "id": "sn11.5:10.2",
      "pali": "yassa bālabalaṁ balaṁ;"
    },
    {
      "id": "sn11.5:10.3",
      "pali": "Balassa dhammaguttassa,"
    },
    {
      "id": "sn11.5:10.4",
      "pali": "paṭivattā na vijjati."
    },
    {
      "id": "sn11.5:11.1",
      "pali": "Tasseva tena pāpiyo,"
    },
    {
      "id": "sn11.5:11.2",
      "pali": "yo kuddhaṁ paṭikujjhati;"
    },
    {
      "id": "sn11.5:11.3",
      "pali": "Kuddhaṁ appaṭikujjhanto,"
    },
    {
      "id": "sn11.5:11.4",
      "pali": "saṅgāmaṁ jeti dujjayaṁ."
    },
    {
      "id": "sn11.5:12.1",
      "pali": "Ubhinnamatthaṁ carati,"
    },
    {
      "id": "sn11.5:12.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn11.5:12.3",
      "pali": "Paraṁ saṅkupitaṁ ñatvā,"
    },
    {
      "id": "sn11.5:12.4",
      "pali": "yo sato upasammati."
    },
    {
      "id": "sn11.5:13.1",
      "pali": "Ubhinnaṁ tikicchantānaṁ,"
    },
    {
      "id": "sn11.5:13.2",
      "pali": "attano ca parassa ca;"
    },
    {
      "id": "sn11.5:13.3",
      "pali": "Janā maññanti bāloti,"
    },
    {
      "id": "sn11.5:13.4",
      "pali": "ye dhammassa akovidā’ti."
    },
    {
      "id": "sn11.5:14.1",
      "pali": "Bhāsitāsu kho pana, bhikkhave, sakkena devānamindena gāthāsu, devā anumodiṁsu, asurā tuṇhī ahesuṁ."
    },
    {
      "id": "sn11.5:14.2",
      "pali": "Atha kho, bhikkhave, devānañca asurānañca pārisajjā etadavocuṁ:"
    },
    {
      "id": "sn11.5:14.3",
      "pali": "‘bhāsitā kho vepacittinā asurindena gāthāyo."
    },
    {
      "id": "sn11.5:14.4",
      "pali": "Tā ca kho sadaṇḍāvacarā sasatthāvacarā, iti bhaṇḍanaṁ iti viggaho iti kalaho."
    },
    {
      "id": "sn11.5:14.5",
      "pali": "Bhāsitā kho sakkena devānamindena gāthāyo."
    },
    {
      "id": "sn11.5:14.6",
      "pali": "Tā ca kho adaṇḍāvacarā asatthāvacarā, iti abhaṇḍanaṁ iti aviggaho iti akalaho."
    },
    {
      "id": "sn11.5:14.7",
      "pali": "Sakkassa devānamindassa subhāsitena jayo’ti."
    },
    {
      "id": "sn11.5:14.8",
      "pali": "Iti kho, bhikkhave, sakkassa devānamindassa subhāsitena jayo ahosī”ti."
    }
  ]
}
