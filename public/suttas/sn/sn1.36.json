{
  "uid": "sn1.36",
  "title": "Saddhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.36:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.36:1.2",
      "pali": "Atha kho sambahulā satullapakāyikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.36:1.3",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.36:2.1",
      "pali": "“Saddhā dutiyā purisassa hoti,"
    },
    {
      "id": "sn1.36:2.2",
      "pali": "No ce assaddhiyaṁ avatiṭṭhati;"
    },
    {
      "id": "sn1.36:2.3",
      "pali": "Yaso ca kittī ca tatvassa hoti,"
    },
    {
      "id": "sn1.36:2.4",
      "pali": "Saggañca so gacchati sarīraṁ vihāyā”ti."
    },
    {
      "id": "sn1.36:3.1",
      "pali": "Atha kho aparā devatā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.36:4.1",
      "pali": "“Kodhaṁ jahe vippajaheyya mānaṁ,"
    },
    {
      "id": "sn1.36:4.2",
      "pali": "Saṁyojanaṁ sabbamatikkameyya;"
    },
    {
      "id": "sn1.36:4.3",
      "pali": "Taṁ nāmarūpasmimasajjamānaṁ,"
    },
    {
      "id": "sn1.36:4.4",
      "pali": "Akiñcanaṁ nānupatanti saṅgā”ti."
    },
    {
      "id": "sn1.36:5.1",
      "pali": "“Pamādamanuyuñjanti,"
    },
    {
      "id": "sn1.36:5.2",
      "pali": "bālā dummedhino janā;"
    },
    {
      "id": "sn1.36:5.3",
      "pali": "Appamādañca medhāvī,"
    },
    {
      "id": "sn1.36:5.4",
      "pali": "dhanaṁ seṭṭhaṁva rakkhati."
    },
    {
      "id": "sn1.36:6.1",
      "pali": "Mā pamādamanuyuñjetha,"
    },
    {
      "id": "sn1.36:6.2",
      "pali": "mā kāmarati santhavaṁ;"
    },
    {
      "id": "sn1.36:6.3",
      "pali": "Appamatto hi jhāyanto,"
    },
    {
      "id": "sn1.36:6.4",
      "pali": "pappoti paramaṁ sukhan”ti."
    }
  ]
}
