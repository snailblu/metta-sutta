{
  "uid": "sn1.59",
  "title": "Dutiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.59:1.1",
      "pali": "“Kiṁsu dutiyā purisassa hoti,"
    },
    {
      "id": "sn1.59:1.2",
      "pali": "Kiṁsu cenaṁ pasāsati;"
    },
    {
      "id": "sn1.59:1.3",
      "pali": "Kissa cābhirato macco,"
    },
    {
      "id": "sn1.59:1.4",
      "pali": "Sabbadukkhā pamuccatī”ti."
    },
    {
      "id": "sn1.59:2.1",
      "pali": "“Saddhā dutiyā purisassa hoti,"
    },
    {
      "id": "sn1.59:2.2",
      "pali": "Paññā cenaṁ pasāsati;"
    },
    {
      "id": "sn1.59:2.3",
      "pali": "Nibbānābhirato macco,"
    },
    {
      "id": "sn1.59:2.4",
      "pali": "Sabbadukkhā pamuccatī”ti."
    }
  ]
}
