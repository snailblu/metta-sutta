{
  "uid": "sn45.163",
  "title": "Āsavasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.163:1.1",
      "pali": "“Tayome, bhikkhave, āsavā."
    },
    {
      "id": "sn45.163:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "sn45.163:1.3",
      "pali": "Kāmāsavo, bhavāsavo, avijjāsavo—"
    },
    {
      "id": "sn45.163:1.4",
      "pali": "ime kho, bhikkhave, tayo āsavā."
    },
    {
      "id": "sn45.163:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ āsavānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.163:1.6",
      "pali": "Tatiyaṁ."
    }
  ]
}
