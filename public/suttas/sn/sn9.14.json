{
  "uid": "sn9.14",
  "title": "Gandhatthenasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.14:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.14:1.2",
      "pali": "Tena kho pana samayena so bhikkhu pacchābhattaṁ piṇḍapātapaṭikkanto pokkharaṇiṁ ogāhetvā padumaṁ upasiṅghati."
    },
    {
      "id": "sn9.14:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno anukampikā atthakāmā taṁ bhikkhuṁ saṁvejetukāmā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn9.14:2.1",
      "pali": "“Yametaṁ vārijaṁ pupphaṁ,"
    },
    {
      "id": "sn9.14:2.2",
      "pali": "adinnaṁ upasiṅghasi;"
    },
    {
      "id": "sn9.14:2.3",
      "pali": "Ekaṅgametaṁ theyyānaṁ,"
    },
    {
      "id": "sn9.14:2.4",
      "pali": "gandhatthenosi mārisā”ti."
    },
    {
      "id": "sn9.14:3.1",
      "pali": "“Na harāmi na bhañjāmi,"
    },
    {
      "id": "sn9.14:3.2",
      "pali": "ārā siṅghāmi vārijaṁ;"
    },
    {
      "id": "sn9.14:3.3",
      "pali": "Atha kena nu vaṇṇena,"
    },
    {
      "id": "sn9.14:3.4",
      "pali": "gandhatthenoti vuccati."
    },
    {
      "id": "sn9.14:4.1",
      "pali": "Yvāyaṁ bhisāni khanati,"
    },
    {
      "id": "sn9.14:4.2",
      "pali": "puṇḍarīkāni bhañjati;"
    },
    {
      "id": "sn9.14:4.3",
      "pali": "Evaṁ ākiṇṇakammanto,"
    },
    {
      "id": "sn9.14:4.4",
      "pali": "kasmā eso na vuccatī”ti."
    },
    {
      "id": "sn9.14:5.1",
      "pali": "“Ākiṇṇaluddo puriso,"
    },
    {
      "id": "sn9.14:5.2",
      "pali": "dhāticelaṁva makkhito;"
    },
    {
      "id": "sn9.14:5.3",
      "pali": "Tasmiṁ me vacanaṁ natthi,"
    },
    {
      "id": "sn9.14:5.4",
      "pali": "tvañcārahāmi vattave."
    },
    {
      "id": "sn9.14:6.1",
      "pali": "Anaṅgaṇassa posassa,"
    },
    {
      "id": "sn9.14:6.2",
      "pali": "niccaṁ sucigavesino;"
    },
    {
      "id": "sn9.14:6.3",
      "pali": "Vālaggamattaṁ pāpassa,"
    },
    {
      "id": "sn9.14:6.4",
      "pali": "abbhāmattaṁva khāyatī”ti."
    },
    {
      "id": "sn9.14:7.1",
      "pali": "“Addhā maṁ yakkha jānāsi,"
    },
    {
      "id": "sn9.14:7.2",
      "pali": "atho me anukampasi;"
    },
    {
      "id": "sn9.14:7.3",
      "pali": "Punapi yakkha vajjāsi,"
    },
    {
      "id": "sn9.14:7.4",
      "pali": "yadā passasi edisan”ti."
    },
    {
      "id": "sn9.14:8.1",
      "pali": "“Neva taṁ upajīvāma,"
    },
    {
      "id": "sn9.14:8.2",
      "pali": "napi te bhatakāmhase;"
    },
    {
      "id": "sn9.14:8.3",
      "pali": "Tvameva bhikkhu jāneyya,"
    },
    {
      "id": "sn9.14:8.4",
      "pali": "yena gaccheyya suggatin”ti."
    },
    {
      "id": "sn9.14:9.1",
      "pali": "Atha kho so bhikkhu tāya devatāya saṁvejito saṁvegamāpādīti."
    },
    {
      "id": "sn9.14:9.2",
      "pali": "Vanavaggo paṭhamo."
    },
    {
      "id": "sn9.14:10.1",
      "pali": "Vivekaṁ upaṭṭhānañca,"
    },
    {
      "id": "sn9.14:10.2",
      "pali": "Kassapagottena sambahulā;"
    },
    {
      "id": "sn9.14:10.3",
      "pali": "Ānando anuruddho ca,"
    },
    {
      "id": "sn9.14:10.4",
      "pali": "Nāgadattañca kulagharaṇī."
    },
    {
      "id": "sn9.14:11.1",
      "pali": "Vajjiputto ca vesālī,"
    },
    {
      "id": "sn9.14:11.2",
      "pali": "Sajjhāyena ayoniso;"
    },
    {
      "id": "sn9.14:11.3",
      "pali": "Majjhanhikālamhi pākatindriya—"
    },
    {
      "id": "sn9.14:11.4",
      "pali": "Padumapupphena cuddasa bhaveti."
    },
    {
      "id": "sn9.14:11.5",
      "pali": "Vanasaṁyuttaṁ samattaṁ."
    }
  ]
}
