{
  "uid": "sn45.22",
  "title": "Akusaladhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.22:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.22:1.2",
      "pali": "“Akusale ca kho, bhikkhave, dhamme desessāmi, kusale ca dhamme."
    },
    {
      "id": "sn45.22:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.22:1.4",
      "pali": "Katame ca, bhikkhave, akusalā dhammā?"
    },
    {
      "id": "sn45.22:1.5",
      "pali": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi."
    },
    {
      "id": "sn45.22:1.6",
      "pali": "Ime vuccanti, bhikkhave, akusalā dhammā."
    },
    {
      "id": "sn45.22:1.7",
      "pali": "Katame ca, bhikkhave, kusalā dhammā?"
    },
    {
      "id": "sn45.22:1.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.22:1.9",
      "pali": "Ime vuccanti, bhikkhave, kusalā dhammā”ti."
    },
    {
      "id": "sn45.22:1.10",
      "pali": "Dutiyaṁ."
    }
  ]
}
