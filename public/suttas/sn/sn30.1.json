{
  "uid": "sn30.1",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn30.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn30.1:1.2",
      "pali": "“Catasso imā, bhikkhave, supaṇṇayoniyo."
    },
    {
      "id": "sn30.1:1.3",
      "pali": "Katamā catasso?"
    },
    {
      "id": "sn30.1:1.4",
      "pali": "Aṇḍajā supaṇṇā, jalābujā supaṇṇā, saṁsedajā supaṇṇā, opapātikā supaṇṇā—"
    },
    {
      "id": "sn30.1:1.5",
      "pali": "imā kho, bhikkhave, catasso supaṇṇayoniyo”ti."
    },
    {
      "id": "sn30.1:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
