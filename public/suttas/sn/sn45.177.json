{
  "uid": "sn45.177",
  "title": "Nīvaraṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.177:1.1",
      "pali": "“Pañcimāni, bhikkhave, nīvaraṇāni."
    },
    {
      "id": "sn45.177:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn45.177:1.3",
      "pali": "Kāmacchandanīvaraṇaṁ, byāpādanīvaraṇaṁ, thinamiddhanīvaraṇaṁ, uddhaccakukkuccanīvaraṇaṁ, vicikicchānīvaraṇaṁ—"
    },
    {
      "id": "sn45.177:1.4",
      "pali": "imāni kho, bhikkhave, pañca nīvaraṇāni."
    },
    {
      "id": "sn45.177:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ nīvaraṇānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.177:1.6",
      "pali": "Sattamaṁ."
    }
  ]
}
