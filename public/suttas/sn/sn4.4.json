{
  "uid": "sn4.4",
  "title": "Paṭhamamārapāsasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.4:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.4:1.2",
      "pali": "ekaṁ samayaṁ bhagavā bārāṇasiyaṁ viharati isipatane migadāye."
    },
    {
      "id": "sn4.4:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn4.4:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn4.4:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn4.4:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn4.4:2.1",
      "pali": "“Mayhaṁ kho, bhikkhave, yoniso manasikārā yoniso sammappadhānā anuttarā vimutti anuppattā, anuttarā vimutti sacchikatā."
    },
    {
      "id": "sn4.4:2.2",
      "pali": "Tumhepi, bhikkhave, yoniso manasikārā yoniso sammappadhānā anuttaraṁ vimuttiṁ anupāpuṇātha, anuttaraṁ vimuttiṁ sacchikarothā”ti."
    },
    {
      "id": "sn4.4:2.3",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.4:3.1",
      "pali": "“Baddhosi mārapāsena,"
    },
    {
      "id": "sn4.4:3.2",
      "pali": "ye dibbā ye ca mānusā;"
    },
    {
      "id": "sn4.4:3.3",
      "pali": "Mārabandhanabaddhosi,"
    },
    {
      "id": "sn4.4:3.4",
      "pali": "na me samaṇa mokkhasī”ti."
    },
    {
      "id": "sn4.4:4.1",
      "pali": "“Muttāhaṁ mārapāsena,"
    },
    {
      "id": "sn4.4:4.2",
      "pali": "Ye dibbā ye ca mānusā;"
    },
    {
      "id": "sn4.4:4.3",
      "pali": "Mārabandhanamuttomhi,"
    },
    {
      "id": "sn4.4:4.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "sn4.4:5.1",
      "pali": "Atha kho māro pāpimā …pe… tatthevantaradhāyīti."
    }
  ]
}
