{
  "uid": "sn31.1",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn31.1:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme …pe…"
    },
    {
      "id": "sn31.1:1.2",
      "pali": "bhagavā etadavoca:"
    },
    {
      "id": "sn31.1:1.3",
      "pali": "“gandhabbakāyike vo, bhikkhave, deve desessāmi."
    },
    {
      "id": "sn31.1:1.4",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn31.1:1.5",
      "pali": "Katamā ca, bhikkhave, gandhabbakāyikā devā?"
    },
    {
      "id": "sn31.1:1.6",
      "pali": "Santi, bhikkhave, mūlagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.7",
      "pali": "Santi, bhikkhave, sāragandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.8",
      "pali": "Santi, bhikkhave, pheggugandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.9",
      "pali": "Santi, bhikkhave, tacagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.10",
      "pali": "Santi, bhikkhave, papaṭikagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.11",
      "pali": "Santi, bhikkhave, pattagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.12",
      "pali": "Santi, bhikkhave, pupphagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.13",
      "pali": "Santi, bhikkhave, phalagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.14",
      "pali": "Santi, bhikkhave, rasagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.15",
      "pali": "Santi, bhikkhave, gandhagandhe adhivatthā devā."
    },
    {
      "id": "sn31.1:1.16",
      "pali": "Ime vuccanti, bhikkhave, gandhabbakāyikā devā”ti."
    },
    {
      "id": "sn31.1:1.17",
      "pali": "Paṭhamaṁ."
    }
  ]
}
