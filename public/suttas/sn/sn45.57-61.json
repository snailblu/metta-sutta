{
  "uid": "sn45.57-61",
  "title": "Dutiyasīlasampadādisuttapañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.57-61:1.1",
      "pali": "“Sūriyassa, bhikkhave, udayato etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—aruṇuggaṁ;"
    },
    {
      "id": "sn45.57-61:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhuno ariyassa aṭṭhaṅgikassa maggassa uppādāya etaṁ pubbaṅgamaṁ etaṁ pubbanimittaṁ, yadidaṁ—sīlasampadā …pe…"
    },
    {
      "id": "sn45.57-61:1.3",
      "pali": "yadidaṁ—chandasampadā …pe…"
    },
    {
      "id": "sn45.57-61:1.4",
      "pali": "yadidaṁ—attasampadā …pe…"
    },
    {
      "id": "sn45.57-61:1.5",
      "pali": "yadidaṁ—diṭṭhisampadā …pe…"
    },
    {
      "id": "sn45.57-61:1.6",
      "pali": "yadidaṁ—appamādasampadā …pe…."
    },
    {
      "id": "sn45.57-61:1.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
