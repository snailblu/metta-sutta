{
  "uid": "sn55.56",
  "title": "Sakadāgāmiphalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.56:1.1",
      "pali": "“Cattārome, bhikkhave, dhammā bhāvitā bahulīkatā sakadāgāmiphalasacchikiriyāya saṁvattanti."
    },
    {
      "id": "sn55.56:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn55.56:1.3",
      "pali": "… pe Saṁvattantī”ti."
    },
    {
      "id": "sn55.56:1.4",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
