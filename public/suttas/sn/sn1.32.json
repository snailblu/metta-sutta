{
  "uid": "sn1.32",
  "title": "Maccharisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.32:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.32:1.2",
      "pali": "Atha kho sambahulā satullapakāyikā devatāyo abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn1.32:1.3",
      "pali": "Ekamantaṁ ṭhitā kho ekā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.32:2.1",
      "pali": "“Maccherā ca pamādā ca,"
    },
    {
      "id": "sn1.32:2.2",
      "pali": "evaṁ dānaṁ na dīyati;"
    },
    {
      "id": "sn1.32:2.3",
      "pali": "Puññaṁ ākaṅkhamānena,"
    },
    {
      "id": "sn1.32:2.4",
      "pali": "deyyaṁ hoti vijānatā”ti."
    },
    {
      "id": "sn1.32:3.1",
      "pali": "Atha kho aparā devatā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.32:4.1",
      "pali": "“Yasseva bhīto na dadāti maccharī,"
    },
    {
      "id": "sn1.32:4.2",
      "pali": "Tadevādadato bhayaṁ;"
    },
    {
      "id": "sn1.32:4.3",
      "pali": "Jighacchā ca pipāsā ca,"
    },
    {
      "id": "sn1.32:4.4",
      "pali": "Yassa bhāyati maccharī;"
    },
    {
      "id": "sn1.32:4.5",
      "pali": "Tameva bālaṁ phusati,"
    },
    {
      "id": "sn1.32:4.6",
      "pali": "Asmiṁ loke paramhi ca."
    },
    {
      "id": "sn1.32:5.1",
      "pali": "Tasmā vineyya maccheraṁ,"
    },
    {
      "id": "sn1.32:5.2",
      "pali": "dajjā dānaṁ malābhibhū;"
    },
    {
      "id": "sn1.32:5.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "sn1.32:5.4",
      "pali": "patiṭṭhā honti pāṇinan”ti."
    },
    {
      "id": "sn1.32:6.1",
      "pali": "Atha kho aparā devatā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.32:7.1",
      "pali": "“Te matesu na mīyanti,"
    },
    {
      "id": "sn1.32:7.2",
      "pali": "panthānaṁva sahabbajaṁ;"
    },
    {
      "id": "sn1.32:7.3",
      "pali": "Appasmiṁ ye pavecchanti,"
    },
    {
      "id": "sn1.32:7.4",
      "pali": "esa dhammo sanantano."
    },
    {
      "id": "sn1.32:8.1",
      "pali": "Appasmeke pavecchanti,"
    },
    {
      "id": "sn1.32:8.2",
      "pali": "bahuneke na dicchare;"
    },
    {
      "id": "sn1.32:8.3",
      "pali": "Appasmā dakkhiṇā dinnā,"
    },
    {
      "id": "sn1.32:8.4",
      "pali": "sahassena samaṁ mitā”ti."
    },
    {
      "id": "sn1.32:9.1",
      "pali": "Atha kho aparā devatā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.32:10.1",
      "pali": "“Duddadaṁ dadamānānaṁ,"
    },
    {
      "id": "sn1.32:10.2",
      "pali": "dukkaraṁ kamma kubbataṁ;"
    },
    {
      "id": "sn1.32:10.3",
      "pali": "Asanto nānukubbanti,"
    },
    {
      "id": "sn1.32:10.4",
      "pali": "sataṁ dhammo duranvayo."
    },
    {
      "id": "sn1.32:11.1",
      "pali": "Tasmā satañca asataṁ,"
    },
    {
      "id": "sn1.32:11.2",
      "pali": "nānā hoti ito gati;"
    },
    {
      "id": "sn1.32:11.3",
      "pali": "Asanto nirayaṁ yanti,"
    },
    {
      "id": "sn1.32:11.4",
      "pali": "santo saggaparāyanā”ti."
    },
    {
      "id": "sn1.32:12.1",
      "pali": "Atha kho aparā devatā bhagavato santike etadavoca:"
    },
    {
      "id": "sn1.32:12.2",
      "pali": "“kassa nu kho, bhagavā, subhāsitan”ti?"
    },
    {
      "id": "sn1.32:13.1",
      "pali": "“Sabbāsaṁ vo subhāsitaṁ pariyāyena; api ca mamapi suṇātha—"
    },
    {
      "id": "sn1.32:14.1",
      "pali": "Dhammaṁ care yopi samuñjakaṁ care,"
    },
    {
      "id": "sn1.32:14.2",
      "pali": "Dārañca posaṁ dadamappakasmiṁ;"
    },
    {
      "id": "sn1.32:14.3",
      "pali": "Sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "sn1.32:14.4",
      "pali": "Kalampi nāgghanti tathāvidhassa te”ti."
    },
    {
      "id": "sn1.32:15.1",
      "pali": "Atha kho aparā devatā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn1.32:16.1",
      "pali": "“Kenesa yañño vipulo mahaggato,"
    },
    {
      "id": "sn1.32:16.2",
      "pali": "Samena dinnassa na agghameti;"
    },
    {
      "id": "sn1.32:16.3",
      "pali": "Kathaṁ sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "sn1.32:16.4",
      "pali": "Kalampi nāgghanti tathāvidhassa te”ti."
    },
    {
      "id": "sn1.32:17.1",
      "pali": "“Dadanti heke visame niviṭṭhā,"
    },
    {
      "id": "sn1.32:17.2",
      "pali": "Chetvā vadhitvā atha socayitvā;"
    },
    {
      "id": "sn1.32:17.3",
      "pali": "Sā dakkhiṇā assumukhā sadaṇḍā,"
    },
    {
      "id": "sn1.32:17.4",
      "pali": "Samena dinnassa na agghameti."
    },
    {
      "id": "sn1.32:18.1",
      "pali": "Evaṁ sataṁ sahassānaṁ sahassayāginaṁ,"
    },
    {
      "id": "sn1.32:18.2",
      "pali": "Kalampi nāgghanti tathāvidhassa te”ti."
    }
  ]
}
