{
  "uid": "sn9.6",
  "title": "Anuruddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.6:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā anuruddho kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.6:1.2",
      "pali": "Atha kho aññatarā tāvatiṁsakāyikā devatā jālinī nāma āyasmato anuruddhassa purāṇadutiyikā yenāyasmā anuruddho tenupasaṅkami; upasaṅkamitvā āyasmantaṁ anuruddhaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn9.6:2.1",
      "pali": "“Tattha cittaṁ paṇidhehi,"
    },
    {
      "id": "sn9.6:2.2",
      "pali": "yattha te vusitaṁ pure;"
    },
    {
      "id": "sn9.6:2.3",
      "pali": "Tāvatiṁsesu devesu,"
    },
    {
      "id": "sn9.6:2.4",
      "pali": "sabbakāmasamiddhisu;"
    },
    {
      "id": "sn9.6:2.5",
      "pali": "Purakkhato parivuto,"
    },
    {
      "id": "sn9.6:2.6",
      "pali": "devakaññāhi sobhasī”ti."
    },
    {
      "id": "sn9.6:3.1",
      "pali": "“Duggatā devakaññāyo,"
    },
    {
      "id": "sn9.6:3.2",
      "pali": "sakkāyasmiṁ patiṭṭhitā;"
    },
    {
      "id": "sn9.6:3.3",
      "pali": "Te cāpi duggatā sattā,"
    },
    {
      "id": "sn9.6:3.4",
      "pali": "devakaññāhi patthitā”ti."
    },
    {
      "id": "sn9.6:4.1",
      "pali": "“Na te sukhaṁ pajānanti,"
    },
    {
      "id": "sn9.6:4.2",
      "pali": "ye na passanti nandanaṁ;"
    },
    {
      "id": "sn9.6:4.3",
      "pali": "Āvāsaṁ naradevānaṁ,"
    },
    {
      "id": "sn9.6:4.4",
      "pali": "tidasānaṁ yasassinan”ti."
    },
    {
      "id": "sn9.6:5.1",
      "pali": "“Na tvaṁ bāle vijānāsi,"
    },
    {
      "id": "sn9.6:5.2",
      "pali": "yathā arahataṁ vaco;"
    },
    {
      "id": "sn9.6:5.3",
      "pali": "Aniccā sabbasaṅkhārā,"
    },
    {
      "id": "sn9.6:5.4",
      "pali": "uppādavayadhammino;"
    },
    {
      "id": "sn9.6:5.5",
      "pali": "Uppajjitvā nirujjhanti,"
    },
    {
      "id": "sn9.6:5.6",
      "pali": "tesaṁ vūpasamo sukho."
    },
    {
      "id": "sn9.6:6.1",
      "pali": "Natthi dāni punāvāso,"
    },
    {
      "id": "sn9.6:6.2",
      "pali": "devakāyasmi jālini;"
    },
    {
      "id": "sn9.6:6.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "sn9.6:6.4",
      "pali": "natthi dāni punabbhavo”ti."
    }
  ]
}
