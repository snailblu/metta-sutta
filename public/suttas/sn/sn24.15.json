{
  "uid": "sn24.15",
  "title": "Hotitathāgatosutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.15:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.15:1.3",
      "pali": "‘hoti tathāgato paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.15:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.15:1.5",
      "pali": "niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.15:1.6",
      "pali": "Pannarasamaṁ."
    }
  ]
}
