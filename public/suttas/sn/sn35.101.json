{
  "uid": "sn35.101",
  "title": "Paṭhamanatumhākasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.101:1.1",
      "pali": "“Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn35.101:1.2",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:1.3",
      "pali": "Kiñca, bhikkhave, na tumhākaṁ?"
    },
    {
      "id": "sn35.101:1.4",
      "pali": "Cakkhu, bhikkhave, na tumhākaṁ."
    },
    {
      "id": "sn35.101:1.5",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:1.6",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:1.7",
      "pali": "Rūpā na tumhākaṁ."
    },
    {
      "id": "sn35.101:1.8",
      "pali": "Te pajahatha."
    },
    {
      "id": "sn35.101:1.9",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.101:1.10",
      "pali": "Cakkhuviññāṇaṁ na tumhākaṁ."
    },
    {
      "id": "sn35.101:1.11",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:1.12",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:1.13",
      "pali": "Cakkhusamphasso na tumhākaṁ."
    },
    {
      "id": "sn35.101:1.14",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:1.15",
      "pali": "So vo pahīno hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:1.16",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi na tumhākaṁ."
    },
    {
      "id": "sn35.101:1.17",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:1.18",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:1.19",
      "pali": "…pe…"
    },
    {
      "id": "sn35.101:2.1",
      "pali": "Jivhā na tumhākaṁ."
    },
    {
      "id": "sn35.101:2.2",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:2.3",
      "pali": "Sā vo pahīnā hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:2.4",
      "pali": "Rasā na tumhākaṁ."
    },
    {
      "id": "sn35.101:2.5",
      "pali": "Te pajahatha."
    },
    {
      "id": "sn35.101:2.6",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.101:2.7",
      "pali": "Jivhāviññāṇaṁ na tumhākaṁ."
    },
    {
      "id": "sn35.101:2.8",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:2.9",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:2.10",
      "pali": "Jivhāsamphasso na tumhākaṁ."
    },
    {
      "id": "sn35.101:2.11",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:2.12",
      "pali": "So vo pahīno hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:2.13",
      "pali": "Yampidaṁ jivhāsamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi na tumhākaṁ."
    },
    {
      "id": "sn35.101:2.14",
      "pali": "Taṁ pajahatha. Taṁ vo pahīnaṁ hitāya sukhāya bhavissati …pe…."
    },
    {
      "id": "sn35.101:3.1",
      "pali": "Mano na tumhākaṁ."
    },
    {
      "id": "sn35.101:3.2",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:3.3",
      "pali": "So vo pahīno hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:3.4",
      "pali": "Dhammā na tumhākaṁ."
    },
    {
      "id": "sn35.101:3.5",
      "pali": "Te pajahatha."
    },
    {
      "id": "sn35.101:3.6",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.101:3.7",
      "pali": "Manoviññāṇaṁ na tumhākaṁ."
    },
    {
      "id": "sn35.101:3.8",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:3.9",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:3.10",
      "pali": "Manosamphasso na tumhākaṁ."
    },
    {
      "id": "sn35.101:3.11",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:3.12",
      "pali": "So vo pahīno hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:3.13",
      "pali": "Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi na tumhākaṁ."
    },
    {
      "id": "sn35.101:3.14",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:3.15",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:4.1",
      "pali": "Seyyathāpi, bhikkhave, yaṁ imasmiṁ jetavane tiṇakaṭṭhasākhāpalāsaṁ taṁ jano hareyya vā ḍaheyya vā yathāpaccayaṁ vā kareyya,"
    },
    {
      "id": "sn35.101:4.2",
      "pali": "api nu tumhākaṁ evamassa:"
    },
    {
      "id": "sn35.101:4.3",
      "pali": "‘amhe jano harati vā ḍahati vā yathāpaccayaṁ vā karotī’”ti?"
    },
    {
      "id": "sn35.101:5.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.101:6.1",
      "pali": "“Taṁ kissa hetu”?"
    },
    {
      "id": "sn35.101:7.1",
      "pali": "“Na hi no etaṁ, bhante, attā vā attaniyaṁ vā”ti."
    },
    {
      "id": "sn35.101:8.1",
      "pali": "“Evameva kho, bhikkhave, cakkhu na tumhākaṁ."
    },
    {
      "id": "sn35.101:8.2",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:8.3",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.101:8.4",
      "pali": "Rūpā na tumhākaṁ …"
    },
    {
      "id": "sn35.101:8.5",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.101:8.6",
      "pali": "cakkhusamphasso …pe…"
    },
    {
      "id": "sn35.101:8.7",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi na tumhākaṁ."
    },
    {
      "id": "sn35.101:8.8",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.101:8.9",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissatī”ti."
    },
    {
      "id": "sn35.101:8.10",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
