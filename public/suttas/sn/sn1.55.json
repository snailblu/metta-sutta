{
  "uid": "sn1.55",
  "title": "Paṭhamajanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.55:1.1",
      "pali": "“Kiṁsu janeti purisaṁ,"
    },
    {
      "id": "sn1.55:1.2",
      "pali": "kiṁsu tassa vidhāvati;"
    },
    {
      "id": "sn1.55:1.3",
      "pali": "Kiṁsu saṁsāramāpādi,"
    },
    {
      "id": "sn1.55:1.4",
      "pali": "kiṁsu tassa mahabbhayan”ti."
    },
    {
      "id": "sn1.55:2.1",
      "pali": "“Taṇhā janeti purisaṁ,"
    },
    {
      "id": "sn1.55:2.2",
      "pali": "cittamassa vidhāvati;"
    },
    {
      "id": "sn1.55:2.3",
      "pali": "Satto saṁsāramāpādi,"
    },
    {
      "id": "sn1.55:2.4",
      "pali": "dukkhamassa mahabbhayan”ti."
    }
  ]
}
