{
  "uid": "sn52.14",
  "title": "Cetopariyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn52.14:1.1",
      "pali": "“Imesañca panāhaṁ, āvuso, catunnaṁ satipaṭṭhānānaṁ bhāvitattā bahulīkatattā parasattānaṁ parapuggalānaṁ cetasā ceto paricca pajānāmi—"
    },
    {
      "id": "sn52.14:1.2",
      "pali": "sarāgaṁ vā cittaṁ ‘sarāgaṁ cittan’ti pajānāmi …pe…"
    },
    {
      "id": "sn52.14:1.3",
      "pali": "avimuttaṁ vā cittaṁ ‘avimuttaṁ cittan’ti pajānāmī”ti."
    },
    {
      "id": "sn52.14:1.4",
      "pali": "Catutthaṁ."
    }
  ]
}
