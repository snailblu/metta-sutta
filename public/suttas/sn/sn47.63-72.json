{
  "uid": "sn47.63-72",
  "title": "Tathāgatādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.63-72:1.1",
      "pali": "“Yāvatā, bhikkhave, sattā apadā vā dvipadā vā catuppadā vā bahuppadā vā”ti"
    },
    {
      "id": "sn47.63-72:1.2",
      "pali": "vitthāretabbaṁ."
    },
    {
      "id": "sn47.63-72:1.3",
      "pali": "Appamādavaggo sattamo."
    },
    {
      "id": "sn47.63-72:2.1",
      "pali": "Tathāgataṁ padaṁ kūṭaṁ,"
    },
    {
      "id": "sn47.63-72:2.2",
      "pali": "mūlaṁ sāro ca vassikaṁ;"
    },
    {
      "id": "sn47.63-72:2.3",
      "pali": "Rājā candimasūriyā,"
    },
    {
      "id": "sn47.63-72:2.4",
      "pali": "vatthena dasamaṁ padanti."
    }
  ]
}
