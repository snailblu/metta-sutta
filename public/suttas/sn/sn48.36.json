{
  "uid": "sn48.36",
  "title": "Paṭhamavibhaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.36:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.36:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.36:1.3",
      "pali": "Sukhindriyaṁ, dukkhindriyaṁ, somanassindriyaṁ, domanassindriyaṁ, upekkhindriyaṁ."
    },
    {
      "id": "sn48.36:2.1",
      "pali": "Katamañca, bhikkhave, sukhindriyaṁ?"
    },
    {
      "id": "sn48.36:2.2",
      "pali": "Yaṁ kho, bhikkhave, kāyikaṁ sukhaṁ, kāyikaṁ sātaṁ, kāyasamphassajaṁ sukhaṁ sātaṁ vedayitaṁ—"
    },
    {
      "id": "sn48.36:2.3",
      "pali": "idaṁ vuccati, bhikkhave, sukhindriyaṁ."
    },
    {
      "id": "sn48.36:3.1",
      "pali": "Katamañca, bhikkhave, dukkhindriyaṁ?"
    },
    {
      "id": "sn48.36:3.2",
      "pali": "Yaṁ kho, bhikkhave, kāyikaṁ dukkhaṁ, kāyikaṁ asātaṁ, kāyasamphassajaṁ dukkhaṁ asātaṁ vedayitaṁ—"
    },
    {
      "id": "sn48.36:3.3",
      "pali": "idaṁ vuccati, bhikkhave, dukkhindriyaṁ."
    },
    {
      "id": "sn48.36:4.1",
      "pali": "Katamañca, bhikkhave, somanassindriyaṁ?"
    },
    {
      "id": "sn48.36:4.2",
      "pali": "Yaṁ kho, bhikkhave, cetasikaṁ sukhaṁ, cetasikaṁ sātaṁ, manosamphassajaṁ sukhaṁ sātaṁ vedayitaṁ—"
    },
    {
      "id": "sn48.36:4.3",
      "pali": "idaṁ vuccati, bhikkhave, somanassindriyaṁ."
    },
    {
      "id": "sn48.36:5.1",
      "pali": "Katamañca, bhikkhave, domanassindriyaṁ?"
    },
    {
      "id": "sn48.36:5.2",
      "pali": "Yaṁ kho, bhikkhave, cetasikaṁ dukkhaṁ, cetasikaṁ asātaṁ, manosamphassajaṁ dukkhaṁ asātaṁ vedayitaṁ—"
    },
    {
      "id": "sn48.36:5.3",
      "pali": "idaṁ vuccati, bhikkhave, domanassindriyaṁ."
    },
    {
      "id": "sn48.36:6.1",
      "pali": "Katamañca, bhikkhave, upekkhindriyaṁ?"
    },
    {
      "id": "sn48.36:6.2",
      "pali": "Yaṁ kho, bhikkhave, kāyikaṁ vā cetasikaṁ vā nevasātaṁ nāsātaṁ vedayitaṁ—"
    },
    {
      "id": "sn48.36:6.3",
      "pali": "idaṁ vuccati, bhikkhave, upekkhindriyaṁ."
    },
    {
      "id": "sn48.36:6.4",
      "pali": "Imāni kho, bhikkhave, pañcindriyānī”ti."
    },
    {
      "id": "sn48.36:6.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
