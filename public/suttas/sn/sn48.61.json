{
  "uid": "sn48.61",
  "title": "Saṁyojanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.61:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn48.61:1.2",
      "pali": "“Pañcimāni, bhikkhave, indriyāni bhāvitāni bahulīkatāni saṁyojanappahānāya saṁvattanti."
    },
    {
      "id": "sn48.61:1.3",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.61:1.4",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ—"
    },
    {
      "id": "sn48.61:1.5",
      "pali": "imāni kho, bhikkhave, pañcindriyāni bhāvitāni bahulīkatāni saṁyojanappahānāya saṁvattantī”ti."
    },
    {
      "id": "sn48.61:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
