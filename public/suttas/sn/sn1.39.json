{
  "uid": "sn1.39",
  "title": "Paṭhamapajjunnadhītusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.39:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.39:1.2",
      "pali": "ekaṁ samayaṁ bhagavā vesāliyaṁ viharati mahāvane kūṭāgārasālāyaṁ."
    },
    {
      "id": "sn1.39:1.3",
      "pali": "Atha kho kokanadā pajjunnassa dhītā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ mahāvanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn1.39:1.4",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā kokanadā pajjunnassa dhītā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.39:2.1",
      "pali": "“Vesāliyaṁ vane viharantaṁ,"
    },
    {
      "id": "sn1.39:2.2",
      "pali": "Aggaṁ sattassa sambuddhaṁ;"
    },
    {
      "id": "sn1.39:2.3",
      "pali": "Kokanadāhamasmi abhivande,"
    },
    {
      "id": "sn1.39:2.4",
      "pali": "Kokanadā pajjunnassa dhītā."
    },
    {
      "id": "sn1.39:3.1",
      "pali": "Sutameva pure āsi,"
    },
    {
      "id": "sn1.39:3.2",
      "pali": "Dhammo cakkhumatānubuddho;"
    },
    {
      "id": "sn1.39:3.3",
      "pali": "Sāhaṁ dāni sakkhi jānāmi,"
    },
    {
      "id": "sn1.39:3.4",
      "pali": "Munino desayato sugatassa."
    },
    {
      "id": "sn1.39:4.1",
      "pali": "Ye keci ariyaṁ dhammaṁ,"
    },
    {
      "id": "sn1.39:4.2",
      "pali": "Vigarahantā caranti dummedhā;"
    },
    {
      "id": "sn1.39:4.3",
      "pali": "Upenti roruvaṁ ghoraṁ,"
    },
    {
      "id": "sn1.39:4.4",
      "pali": "Cirarattaṁ dukkhaṁ anubhavanti."
    },
    {
      "id": "sn1.39:5.1",
      "pali": "Ye ca kho ariye dhamme,"
    },
    {
      "id": "sn1.39:5.2",
      "pali": "Khantiyā upasamena upetā;"
    },
    {
      "id": "sn1.39:5.3",
      "pali": "Pahāya mānusaṁ dehaṁ,"
    },
    {
      "id": "sn1.39:5.4",
      "pali": "Devakāyaṁ paripūressantī”ti."
    }
  ]
}
