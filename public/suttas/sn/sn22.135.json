{
  "uid": "sn22.135",
  "title": "Tatiyakoṭṭhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.135:1.1",
      "pali": "Taññeva nidānaṁ."
    },
    {
      "id": "sn22.135:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca:"
    },
    {
      "id": "sn22.135:1.3",
      "pali": "“‘avijjā, avijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.135:1.4",
      "pali": "Katamā nu kho, āvuso, avijjā;"
    },
    {
      "id": "sn22.135:1.5",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.135:2.1",
      "pali": "“Idhāvuso, assutavā puthujjano rūpaṁ nappajānāti, rūpasamudayaṁ nappajānāti, rūpanirodhaṁ nappajānāti, rūpanirodhagāminiṁ paṭipadaṁ nappajānāti."
    },
    {
      "id": "sn22.135:2.2",
      "pali": "Vedanaṁ nappajānāti …pe…"
    },
    {
      "id": "sn22.135:2.3",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.135:2.4",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.135:2.5",
      "pali": "viññāṇaṁ nappajānāti, viññāṇasamudayaṁ nappajānāti, viññāṇanirodhaṁ nappajānāti, viññāṇanirodhagāminiṁ paṭipadaṁ nappajānāti."
    },
    {
      "id": "sn22.135:2.6",
      "pali": "Ayaṁ vuccatāvuso, avijjā;"
    },
    {
      "id": "sn22.135:2.7",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.135:3.1",
      "pali": "Evaṁ vutte, āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca:"
    },
    {
      "id": "sn22.135:3.2",
      "pali": "“‘vijjā, vijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.135:3.3",
      "pali": "Katamā nu kho, āvuso, vijjā;"
    },
    {
      "id": "sn22.135:3.4",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.135:4.1",
      "pali": "“Idhāvuso, sutavā ariyasāvako rūpaṁ pajānāti, rūpasamudayaṁ pajānāti, rūpanirodhaṁ pajānāti, rūpanirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn22.135:4.2",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.135:4.3",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.135:4.4",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.135:4.5",
      "pali": "viññāṇaṁ pajānāti, viññāṇasamudayaṁ pajānāti, viññāṇanirodhaṁ pajānāti, viññāṇanirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn22.135:4.6",
      "pali": "Ayaṁ vuccatāvuso, vijjā;"
    },
    {
      "id": "sn22.135:4.7",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.135:4.8",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn22.135:4.9",
      "pali": "Avijjāvaggo tatiyo."
    },
    {
      "id": "sn22.135:5.1",
      "pali": "Samudayadhamme tīṇi,"
    },
    {
      "id": "sn22.135:5.2",
      "pali": "assādo apare duve;"
    },
    {
      "id": "sn22.135:5.3",
      "pali": "Samudaye ca dve vuttā,"
    },
    {
      "id": "sn22.135:5.4",
      "pali": "koṭṭhike apare tayoti."
    }
  ]
}
