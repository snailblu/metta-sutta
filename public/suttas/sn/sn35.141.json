{
  "uid": "sn35.141",
  "title": "Ajjhattadukkhahetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.141:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, dukkhaṁ."
    },
    {
      "id": "sn35.141:1.2",
      "pali": "Yopi hetu yopi paccayo cakkhussa uppādāya, sopi dukkho."
    },
    {
      "id": "sn35.141:1.3",
      "pali": "Dukkhasambhūtaṁ, bhikkhave, cakkhu kuto sukhaṁ bhavissati …pe…"
    },
    {
      "id": "sn35.141:1.4",
      "pali": "jivhā dukkhā."
    },
    {
      "id": "sn35.141:1.5",
      "pali": "Yopi hetu, yopi paccayo jivhāya uppādāya, sopi dukkho."
    },
    {
      "id": "sn35.141:1.6",
      "pali": "Dukkhasambhūtā, bhikkhave, jivhā kuto sukhā bhavissati …pe…"
    },
    {
      "id": "sn35.141:1.7",
      "pali": "mano dukkho."
    },
    {
      "id": "sn35.141:1.8",
      "pali": "Yopi hetu yopi paccayo manassa uppādāya, sopi dukkho."
    },
    {
      "id": "sn35.141:1.9",
      "pali": "Dukkhasambhūto, bhikkhave, mano kuto sukho bhavissati."
    },
    {
      "id": "sn35.141:1.10",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.141:1.11",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.141:1.12",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
