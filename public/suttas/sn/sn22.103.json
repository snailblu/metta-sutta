{
  "uid": "sn22.103",
  "title": "Antasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.103:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.103:1.2",
      "pali": "“Cattārome, bhikkhave, antā."
    },
    {
      "id": "sn22.103:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn22.103:1.4",
      "pali": "Sakkāyanto, sakkāyasamudayanto, sakkāyanirodhanto, sakkāyanirodhagāminippaṭipadanto."
    },
    {
      "id": "sn22.103:1.5",
      "pali": "Katamo ca, bhikkhave, sakkāyanto?"
    },
    {
      "id": "sn22.103:1.6",
      "pali": "Pañcupādānakkhandhātissa vacanīyaṁ."
    },
    {
      "id": "sn22.103:1.7",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.103:1.8",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho, vedanupādānakkhandho, saññupādānakkhandho, saṅkhārupādānakkhandho, viññāṇupādānakkhandho—"
    },
    {
      "id": "sn22.103:1.9",
      "pali": "ayaṁ vuccati, bhikkhave, sakkāyanto."
    },
    {
      "id": "sn22.103:2.1",
      "pali": "Katamo ca, bhikkhave, sakkāyasamudayanto?"
    },
    {
      "id": "sn22.103:2.2",
      "pali": "Yāyaṁ taṇhā ponobhavikā nandirāgasahagatā tatratatrābhinandinī, seyyathidaṁ—"
    },
    {
      "id": "sn22.103:2.3",
      "pali": "kāmataṇhā, bhavataṇhā, vibhavataṇhā."
    },
    {
      "id": "sn22.103:2.4",
      "pali": "Ayaṁ vuccati, bhikkhave, sakkāyasamudayanto."
    },
    {
      "id": "sn22.103:3.1",
      "pali": "Katamo ca, bhikkhave, sakkāyanirodhanto?"
    },
    {
      "id": "sn22.103:3.2",
      "pali": "Yo tassāyeva taṇhāya asesavirāganirodho cāgo paṭinissaggo mutti anālayo—"
    },
    {
      "id": "sn22.103:3.3",
      "pali": "ayaṁ vuccati, bhikkhave, sakkāyanirodhanto."
    },
    {
      "id": "sn22.103:4.1",
      "pali": "Katamo ca, bhikkhave, sakkāyanirodhagāminippaṭipadanto?"
    },
    {
      "id": "sn22.103:4.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo."
    },
    {
      "id": "sn22.103:4.3",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn22.103:4.4",
      "pali": "Ayaṁ vuccati, bhikkhave, sakkāyanirodhagāminippaṭipadanto."
    },
    {
      "id": "sn22.103:4.5",
      "pali": "Ime kho, bhikkhave, cattāro antā”ti."
    },
    {
      "id": "sn22.103:4.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
