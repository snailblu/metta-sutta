{
  "uid": "sn1.7",
  "title": "Appaṭividitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.7:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.7:2.1",
      "pali": "“Yesaṁ dhammā appaṭividitā,"
    },
    {
      "id": "sn1.7:2.2",
      "pali": "Paravādesu nīyare;"
    },
    {
      "id": "sn1.7:2.3",
      "pali": "Suttā te nappabujjhanti,"
    },
    {
      "id": "sn1.7:2.4",
      "pali": "Kālo tesaṁ pabujjhitun”ti."
    },
    {
      "id": "sn1.7:3.1",
      "pali": "“Yesaṁ dhammā suppaṭividitā,"
    },
    {
      "id": "sn1.7:3.2",
      "pali": "Paravādesu na nīyare;"
    },
    {
      "id": "sn1.7:3.3",
      "pali": "Te sambuddhā sammadaññā,"
    },
    {
      "id": "sn1.7:3.4",
      "pali": "Caranti visame saman”ti."
    }
  ]
}
