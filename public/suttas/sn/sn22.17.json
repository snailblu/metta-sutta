{
  "uid": "sn22.17",
  "title": "Yadanattāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.17:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.17:1.2",
      "pali": "“Rūpaṁ, bhikkhave, anattā."
    },
    {
      "id": "sn22.17:1.3",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.17:1.4",
      "pali": "Vedanā anattā …"
    },
    {
      "id": "sn22.17:1.5",
      "pali": "saññā anattā …"
    },
    {
      "id": "sn22.17:1.6",
      "pali": "saṅkhārā anattā …"
    },
    {
      "id": "sn22.17:1.7",
      "pali": "viññāṇaṁ anattā."
    },
    {
      "id": "sn22.17:1.8",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.17:1.9",
      "pali": "Evaṁ passaṁ, bhikkhave …pe…"
    },
    {
      "id": "sn22.17:1.10",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.17:1.11",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
