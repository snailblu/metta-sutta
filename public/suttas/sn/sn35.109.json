{
  "uid": "sn35.109",
  "title": "Saṁyojaniyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.109:1.1",
      "pali": "“Saṁyojaniye ca, bhikkhave, dhamme desessāmi saṁyojanañca."
    },
    {
      "id": "sn35.109:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.109:1.3",
      "pali": "Katame ca, bhikkhave, saṁyojaniyā dhammā, katamañca saṁyojanaṁ?"
    },
    {
      "id": "sn35.109:1.4",
      "pali": "Cakkhuṁ, bhikkhave, saṁyojaniyo dhammo."
    },
    {
      "id": "sn35.109:1.5",
      "pali": "Yo tattha chandarāgo, taṁ tattha saṁyojanaṁ …pe…"
    },
    {
      "id": "sn35.109:1.6",
      "pali": "jivhā saṁyojaniyo dhammo …pe…"
    },
    {
      "id": "sn35.109:1.7",
      "pali": "mano saṁyojaniyo dhammo."
    },
    {
      "id": "sn35.109:1.8",
      "pali": "Yo tattha chandarāgo, taṁ tattha saṁyojanaṁ."
    },
    {
      "id": "sn35.109:1.9",
      "pali": "Ime vuccanti, bhikkhave, saṁyojaniyā dhammā, idaṁ saṁyojanan”ti."
    },
    {
      "id": "sn35.109:1.10",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
