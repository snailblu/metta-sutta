{
  "uid": "sn35.136",
  "title": "Paṭhamarūpārāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.136:1.1",
      "pali": "“Rūpārāmā, bhikkhave, devamanussā rūparatā rūpasammuditā."
    },
    {
      "id": "sn35.136:1.2",
      "pali": "Rūpavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti."
    },
    {
      "id": "sn35.136:1.3",
      "pali": "Saddārāmā, bhikkhave, devamanussā saddaratā saddasammuditā."
    },
    {
      "id": "sn35.136:1.4",
      "pali": "Saddavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti."
    },
    {
      "id": "sn35.136:1.5",
      "pali": "Gandhārāmā …"
    },
    {
      "id": "sn35.136:1.6",
      "pali": "rasārāmā …"
    },
    {
      "id": "sn35.136:1.7",
      "pali": "phoṭṭhabbārāmā …"
    },
    {
      "id": "sn35.136:1.8",
      "pali": "dhammārāmā, bhikkhave, devamanussā dhammaratā dhammasammuditā."
    },
    {
      "id": "sn35.136:1.9",
      "pali": "Dhammavipariṇāmavirāganirodhā dukkhā, bhikkhave, devamanussā viharanti."
    },
    {
      "id": "sn35.136:1.10",
      "pali": "Tathāgato ca kho, bhikkhave, arahaṁ sammāsambuddho rūpānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na rūpārāmo na rūparato na rūpasammudito."
    },
    {
      "id": "sn35.136:1.11",
      "pali": "Rūpavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharati."
    },
    {
      "id": "sn35.136:1.12",
      "pali": "Saddānaṁ …"
    },
    {
      "id": "sn35.136:1.13",
      "pali": "gandhānaṁ …"
    },
    {
      "id": "sn35.136:1.14",
      "pali": "rasānaṁ …"
    },
    {
      "id": "sn35.136:1.15",
      "pali": "phoṭṭhabbānaṁ …"
    },
    {
      "id": "sn35.136:1.16",
      "pali": "dhammānaṁ samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ viditvā na dhammārāmo, na dhammarato, na dhammasammudito."
    },
    {
      "id": "sn35.136:1.17",
      "pali": "Dhammavipariṇāmavirāganirodhā sukho, bhikkhave, tathāgato viharati”."
    },
    {
      "id": "sn35.136:1.18",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn35.136:1.19",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn35.136:2.1",
      "pali": "“Rūpā saddā rasā gandhā,"
    },
    {
      "id": "sn35.136:2.2",
      "pali": "phassā dhammā ca kevalā;"
    },
    {
      "id": "sn35.136:2.3",
      "pali": "Iṭṭhā kantā manāpā ca,"
    },
    {
      "id": "sn35.136:2.4",
      "pali": "yāvatatthīti vuccati."
    },
    {
      "id": "sn35.136:3.1",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "sn35.136:3.2",
      "pali": "ete vo sukhasammatā;"
    },
    {
      "id": "sn35.136:3.3",
      "pali": "Yattha cete nirujjhanti,"
    },
    {
      "id": "sn35.136:3.4",
      "pali": "taṁ tesaṁ dukkhasammataṁ."
    },
    {
      "id": "sn35.136:4.1",
      "pali": "Sukhaṁ diṭṭhamariyebhi,"
    },
    {
      "id": "sn35.136:4.2",
      "pali": "sakkāyassa nirodhanaṁ;"
    },
    {
      "id": "sn35.136:4.3",
      "pali": "Paccanīkamidaṁ hoti,"
    },
    {
      "id": "sn35.136:4.4",
      "pali": "sabbalokena passataṁ."
    },
    {
      "id": "sn35.136:5.1",
      "pali": "Yaṁ pare sukhato āhu,"
    },
    {
      "id": "sn35.136:5.2",
      "pali": "tadariyā āhu dukkhato;"
    },
    {
      "id": "sn35.136:5.3",
      "pali": "Yaṁ pare dukkhato āhu,"
    },
    {
      "id": "sn35.136:5.4",
      "pali": "tadariyā sukhato vidū."
    },
    {
      "id": "sn35.136:6.1",
      "pali": "Passa dhammaṁ durājānaṁ,"
    },
    {
      "id": "sn35.136:6.2",
      "pali": "sammūḷhettha aviddasu;"
    },
    {
      "id": "sn35.136:6.3",
      "pali": "Nivutānaṁ tamo hoti,"
    },
    {
      "id": "sn35.136:6.4",
      "pali": "andhakāro apassataṁ."
    },
    {
      "id": "sn35.136:7.1",
      "pali": "Satañca vivaṭaṁ hoti,"
    },
    {
      "id": "sn35.136:7.2",
      "pali": "āloko passatāmiva;"
    },
    {
      "id": "sn35.136:7.3",
      "pali": "Santike na vijānanti,"
    },
    {
      "id": "sn35.136:7.4",
      "pali": "maggā dhammassa akovidā."
    },
    {
      "id": "sn35.136:8.1",
      "pali": "Bhavarāgaparetebhi,"
    },
    {
      "id": "sn35.136:8.2",
      "pali": "bhavarāgānusārībhi;"
    },
    {
      "id": "sn35.136:8.3",
      "pali": "Māradheyyānupannehi,"
    },
    {
      "id": "sn35.136:8.4",
      "pali": "nāyaṁ dhammo susambudho."
    },
    {
      "id": "sn35.136:9.1",
      "pali": "Ko nu aññatra mariyebhi,"
    },
    {
      "id": "sn35.136:9.2",
      "pali": "Padaṁ sambuddhumarahati;"
    },
    {
      "id": "sn35.136:9.3",
      "pali": "Yaṁ padaṁ sammadaññāya,"
    },
    {
      "id": "sn35.136:9.4",
      "pali": "Parinibbanti anāsavā”ti."
    },
    {
      "id": "sn35.136:9.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
