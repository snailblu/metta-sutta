{
  "uid": "sn10.9",
  "title": "Paṭhamasukkāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.9:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn10.9:1.2",
      "pali": "Tena kho pana samayena sukkā bhikkhunī mahatiyā parisāya parivutā dhammaṁ deseti."
    },
    {
      "id": "sn10.9:1.3",
      "pali": "Atha kho sukkāya bhikkhuniyā abhippasanno yakkho rājagahe rathikāya rathikaṁ siṅghāṭakena siṅghāṭakaṁ upasaṅkamitvā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn10.9:2.1",
      "pali": "“Kiṁ me katā rājagahe manussā,"
    },
    {
      "id": "sn10.9:2.2",
      "pali": "Madhupītāva seyare;"
    },
    {
      "id": "sn10.9:2.3",
      "pali": "Ye sukkaṁ na payirupāsanti,"
    },
    {
      "id": "sn10.9:2.4",
      "pali": "Desentiṁ amataṁ padaṁ."
    },
    {
      "id": "sn10.9:3.1",
      "pali": "Tañca pana appaṭivānīyaṁ,"
    },
    {
      "id": "sn10.9:3.2",
      "pali": "Asecanakamojavaṁ;"
    },
    {
      "id": "sn10.9:3.3",
      "pali": "Pivanti maññe sappaññā,"
    },
    {
      "id": "sn10.9:3.4",
      "pali": "Valāhakamiva panthagū”ti."
    }
  ]
}
