{
  "uid": "sn46.46",
  "title": "Daliddasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.46:1.1",
      "pali": "“‘Daliddo, daliddo’ti, bhante, vuccati."
    },
    {
      "id": "sn46.46:1.2",
      "pali": "Kittāvatā nu kho, bhante, ‘daliddo’ti vuccatī”ti?"
    },
    {
      "id": "sn46.46:1.3",
      "pali": "“Sattannaṁ kho, bhikkhu, bojjhaṅgānaṁ abhāvitattā abahulīkatattā ‘daliddo’ti vuccati."
    },
    {
      "id": "sn46.46:1.4",
      "pali": "Katamesaṁ sattannaṁ?"
    },
    {
      "id": "sn46.46:1.5",
      "pali": "Satisambojjhaṅgassa …pe… upekkhāsambojjhaṅgassa—"
    },
    {
      "id": "sn46.46:1.6",
      "pali": "imesaṁ kho, bhikkhu, sattannaṁ bojjhaṅgānaṁ abhāvitattā abahulīkatattā ‘daliddo’ti vuccatī”ti."
    },
    {
      "id": "sn46.46:1.7",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
