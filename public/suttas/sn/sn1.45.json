{
  "uid": "sn1.45",
  "title": "Anomasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.45:1.1",
      "pali": "“Anomanāmaṁ nipuṇatthadassiṁ,"
    },
    {
      "id": "sn1.45:1.2",
      "pali": "Paññādadaṁ kāmālaye asattaṁ;"
    },
    {
      "id": "sn1.45:1.3",
      "pali": "Taṁ passatha sabbaviduṁ sumedhaṁ,"
    },
    {
      "id": "sn1.45:1.4",
      "pali": "Ariye pathe kamamānaṁ mahesin”ti."
    }
  ]
}
