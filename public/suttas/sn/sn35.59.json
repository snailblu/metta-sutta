{
  "uid": "sn35.59",
  "title": "Anusayasamugghātasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.59:1.1",
      "pali": "“Kathaṁ nu kho …pe…"
    },
    {
      "id": "sn35.59:1.2",
      "pali": "anusayā samugghātaṁ gacchantī”ti?"
    },
    {
      "id": "sn35.59:1.3",
      "pali": "“Cakkhuṁ kho, bhikkhu, anattato jānato passato anusayā samugghātaṁ gacchanti …pe…"
    },
    {
      "id": "sn35.59:1.4",
      "pali": "sotaṁ …"
    },
    {
      "id": "sn35.59:1.5",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn35.59:1.6",
      "pali": "jivhaṁ …"
    },
    {
      "id": "sn35.59:1.7",
      "pali": "kāyaṁ …"
    },
    {
      "id": "sn35.59:1.8",
      "pali": "manaṁ …"
    },
    {
      "id": "sn35.59:1.9",
      "pali": "dhamme …"
    },
    {
      "id": "sn35.59:1.10",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.59:1.11",
      "pali": "manosamphassaṁ …"
    },
    {
      "id": "sn35.59:1.12",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi anattato jānato passato anusayā samugghātaṁ gacchanti."
    },
    {
      "id": "sn35.59:1.13",
      "pali": "Evaṁ kho, bhikkhu, jānato evaṁ passato anusayā samugghātaṁ gacchantī”ti."
    },
    {
      "id": "sn35.59:1.14",
      "pali": "Sattamaṁ."
    }
  ]
}
