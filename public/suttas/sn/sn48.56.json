{
  "uid": "sn48.56",
  "title": "Patiṭṭhitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.56:1.1",
      "pali": "“Ekadhamme patiṭṭhitassa, bhikkhave, bhikkhuno pañcindriyāni bhāvitāni honti subhāvitāni."
    },
    {
      "id": "sn48.56:1.2",
      "pali": "Katamasmiṁ ekadhamme?"
    },
    {
      "id": "sn48.56:1.3",
      "pali": "Appamāde."
    },
    {
      "id": "sn48.56:1.4",
      "pali": "Katamo ca bhikkhave, appamādo?"
    },
    {
      "id": "sn48.56:1.5",
      "pali": "Idha, bhikkhave, bhikkhu cittaṁ rakkhati āsavesu ca sāsavesu ca dhammesu."
    },
    {
      "id": "sn48.56:1.6",
      "pali": "Tassa cittaṁ rakkhato āsavesu ca sāsavesu ca dhammesu saddhindriyampi bhāvanāpāripūriṁ gacchati."
    },
    {
      "id": "sn48.56:1.7",
      "pali": "Vīriyindriyampi bhāvanāpāripūriṁ gacchati."
    },
    {
      "id": "sn48.56:1.8",
      "pali": "Satindriyampi bhāvanāpāripūriṁ gacchati."
    },
    {
      "id": "sn48.56:1.9",
      "pali": "Samādhindriyampi bhāvanāpāripūriṁ gacchati."
    },
    {
      "id": "sn48.56:1.10",
      "pali": "Paññindriyampi bhāvanāpāripūriṁ gacchati."
    },
    {
      "id": "sn48.56:1.11",
      "pali": "Evampi kho, bhikkhave, ekadhamme patiṭṭhitassa bhikkhuno pañcindriyāni bhāvitāni honti subhāvitānī”ti."
    },
    {
      "id": "sn48.56:1.12",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
