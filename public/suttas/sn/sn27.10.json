{
  "uid": "sn27.10",
  "title": "Khandhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.10:1.2",
      "pali": "“Yo, bhikkhave, rūpasmiṁ chandarāgo, cittasseso upakkileso …pe… yo viññāṇasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.10:1.3",
      "pali": "Yato kho, bhikkhave, bhikkhuno imesu pañcasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti."
    },
    {
      "id": "sn27.10:1.4",
      "pali": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.10:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn27.10:1.6",
      "pali": "Kilesavaggo paṭhamo."
    },
    {
      "id": "sn27.10:2.1",
      "pali": "Cakkhu rūpañca viññāṇaṁ,"
    },
    {
      "id": "sn27.10:2.2",
      "pali": "phasso ca vedanāya ca;"
    },
    {
      "id": "sn27.10:2.3",
      "pali": "Saññā ca cetanā taṇhā,"
    },
    {
      "id": "sn27.10:2.4",
      "pali": "dhātu khandhena te dasāti."
    },
    {
      "id": "sn27.10:2.5",
      "pali": "Kilesasaṁyuttaṁ samattaṁ."
    }
  ]
}
