{
  "uid": "sn28.6",
  "title": "Viññāṇañcāyatanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn28.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn28.6:1.2",
      "pali": "Addasā kho āyasmā ānando …pe…"
    },
    {
      "id": "sn28.6:1.3",
      "pali": "“idhāhaṁ, āvuso, sabbaso ākāsānañcāyatanaṁ samatikkamma anantaṁ viññāṇanti viññāṇañcāyatanaṁ upasampajja viharāmi …pe…"
    },
    {
      "id": "sn28.6:1.4",
      "pali": "vuṭṭhitoti vā”ti."
    },
    {
      "id": "sn28.6:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
