{
  "uid": "sn2.7",
  "title": "Pañcālacaṇḍasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.7:1.2",
      "pali": "Ekamantaṁ ṭhito kho pañcālacaṇḍo devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.7:2.1",
      "pali": "“Sambādhe vata okāsaṁ,"
    },
    {
      "id": "sn2.7:2.2",
      "pali": "Avindi bhūrimedhaso;"
    },
    {
      "id": "sn2.7:2.3",
      "pali": "Yo jhānamabujjhi buddho,"
    },
    {
      "id": "sn2.7:2.4",
      "pali": "Paṭilīnanisabho munī”ti."
    },
    {
      "id": "sn2.7:3.1",
      "pali": "“Sambādhe vāpi vindanti,"
    },
    {
      "id": "sn2.7:3.2",
      "pali": "(pañcālacaṇḍāti bhagavā)"
    },
    {
      "id": "sn2.7:3.3",
      "pali": "Dhammaṁ nibbānapattiyā;"
    },
    {
      "id": "sn2.7:3.4",
      "pali": "Ye satiṁ paccalatthaṁsu,"
    },
    {
      "id": "sn2.7:3.5",
      "pali": "Sammā te susamāhitā”ti."
    }
  ]
}
