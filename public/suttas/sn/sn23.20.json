{
  "uid": "sn23.20",
  "title": "Vayadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.20:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.20:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.20:1.3",
      "pali": "“‘vayadhammo, vayadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.20:1.4",
      "pali": "Katamo nu kho, bhante, vayadhammo”ti?"
    },
    {
      "id": "sn23.20:1.5",
      "pali": "“Rūpaṁ kho, rādha, vayadhammo, vedanā vayadhammo, saññā vayadhammo, saṅkhārā vayadhammo, viññāṇaṁ vayadhammo."
    },
    {
      "id": "sn23.20:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.20:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.20:1.8",
      "pali": "Dasamaṁ."
    }
  ]
}
