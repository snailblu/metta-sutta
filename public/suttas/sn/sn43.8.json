{
  "uid": "sn43.8",
  "title": "Indriyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.8:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.8:1.2",
      "pali": "Pañcindriyāni. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.8:1.3",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
