{
  "uid": "sn36.3",
  "title": "Pahānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.3:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn36.3:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn36.3:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā."
    },
    {
      "id": "sn36.3:1.4",
      "pali": "Sukhāya, bhikkhave, vedanāya rāgānusayo pahātabbo, dukkhāya vedanāya paṭighānusayo pahātabbo, adukkhamasukhāya vedanāya avijjānusayo pahātabbo."
    },
    {
      "id": "sn36.3:1.5",
      "pali": "Yato kho, bhikkhave, bhikkhuno sukhāya vedanāya rāgānusayo pahīno hoti, dukkhāya vedanāya paṭighānusayo pahīno hoti, adukkhamasukhāya vedanāya avijjānusayo pahīno hoti, ayaṁ vuccati, bhikkhave, ‘bhikkhu niranusayo sammaddaso acchecchi taṇhaṁ, vivattayi saṁyojanaṁ, sammā mānābhisamayā antamakāsi dukkhassā’ti."
    },
    {
      "id": "sn36.3:2.1",
      "pali": "Sukhaṁ vedayamānassa,"
    },
    {
      "id": "sn36.3:2.2",
      "pali": "vedanaṁ appajānato;"
    },
    {
      "id": "sn36.3:2.3",
      "pali": "So rāgānusayo hoti,"
    },
    {
      "id": "sn36.3:2.4",
      "pali": "anissaraṇadassino."
    },
    {
      "id": "sn36.3:3.1",
      "pali": "Dukkhaṁ vedayamānassa,"
    },
    {
      "id": "sn36.3:3.2",
      "pali": "vedanaṁ appajānato;"
    },
    {
      "id": "sn36.3:3.3",
      "pali": "Paṭighānusayo hoti,"
    },
    {
      "id": "sn36.3:3.4",
      "pali": "anissaraṇadassino."
    },
    {
      "id": "sn36.3:4.1",
      "pali": "Adukkhamasukhaṁ santaṁ,"
    },
    {
      "id": "sn36.3:4.2",
      "pali": "bhūripaññena desitaṁ;"
    },
    {
      "id": "sn36.3:4.3",
      "pali": "Tañcāpi abhinandati,"
    },
    {
      "id": "sn36.3:4.4",
      "pali": "neva dukkhā pamuccati."
    },
    {
      "id": "sn36.3:5.1",
      "pali": "Yato ca bhikkhu ātāpī,"
    },
    {
      "id": "sn36.3:5.2",
      "pali": "sampajaññaṁ na riñcati;"
    },
    {
      "id": "sn36.3:5.3",
      "pali": "Tato so vedanā sabbā,"
    },
    {
      "id": "sn36.3:5.4",
      "pali": "parijānāti paṇḍito."
    },
    {
      "id": "sn36.3:6.1",
      "pali": "So vedanā pariññāya,"
    },
    {
      "id": "sn36.3:6.2",
      "pali": "diṭṭhe dhamme anāsavo;"
    },
    {
      "id": "sn36.3:6.3",
      "pali": "Kāyassa bhedā dhammaṭṭho,"
    },
    {
      "id": "sn36.3:6.4",
      "pali": "saṅkhyaṁ nopeti vedagū”ti."
    },
    {
      "id": "sn36.3:6.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
