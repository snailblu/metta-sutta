{
  "uid": "sn45.25",
  "title": "Paṭhamaasappurisasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.25:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.25:1.2",
      "pali": "“Asappurisañca vo, bhikkhave, desessāmi, sappurisañca."
    },
    {
      "id": "sn45.25:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.25:1.4",
      "pali": "Katamo ca, bhikkhave, asappuriso?"
    },
    {
      "id": "sn45.25:1.5",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti, micchāsaṅkappo, micchāvāco, micchākammanto, micchāājīvo, micchāvāyāmo, micchāsati, micchāsamādhi—"
    },
    {
      "id": "sn45.25:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, asappuriso."
    },
    {
      "id": "sn45.25:2.1",
      "pali": "Katamo ca, bhikkhave, sappuriso?"
    },
    {
      "id": "sn45.25:2.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti, sammāsaṅkappo, sammāvāco, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi—"
    },
    {
      "id": "sn45.25:2.3",
      "pali": "ayaṁ vuccati, bhikkhave, sappuriso”ti."
    },
    {
      "id": "sn45.25:2.4",
      "pali": "Pañcamaṁ."
    }
  ]
}
