{
  "uid": "sn24.37",
  "title": "Rūpīattāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.37:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.37:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.37:1.3",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.37:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.37:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.37:2.2",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.37:2.3",
      "pali": "Vedanāya sati …pe…"
    },
    {
      "id": "sn24.37:2.4",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.37:2.5",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.37:2.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.37:2.7",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.37:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave, rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.37:3.2",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.37:3.3",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.37:3.4",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.37:3.5",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.37:3.6",
      "pali": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.37:3.7",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.37:3.8",
      "pali": "“Vedanā …pe…"
    },
    {
      "id": "sn24.37:3.9",
      "pali": "“no hetaṁ, bhante”."
    },
    {
      "id": "sn24.37:3.10",
      "pali": "“Iti kho, bhikkhave, dukkhe sati, dukkhaṁ upādāya, dukkhaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.37:3.11",
      "pali": "‘rūpī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.37:3.12",
      "pali": "Ekūnavīsatimaṁ."
    }
  ]
}
