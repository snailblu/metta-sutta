{
  "uid": "sn12.2",
  "title": "Vibhaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.2:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.2:1.2",
      "pali": "“Paṭiccasamuppādaṁ vo, bhikkhave, desessāmi vibhajissāmi."
    },
    {
      "id": "sn12.2:1.3",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.2:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.2:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.2:2.1",
      "pali": "“Katamo ca, bhikkhave, paṭiccasamuppādo?"
    },
    {
      "id": "sn12.2:2.2",
      "pali": "Avijjāpaccayā, bhikkhave, saṅkhārā;"
    },
    {
      "id": "sn12.2:2.3",
      "pali": "saṅkhārapaccayā viññāṇaṁ;"
    },
    {
      "id": "sn12.2:2.4",
      "pali": "viññāṇapaccayā nāmarūpaṁ;"
    },
    {
      "id": "sn12.2:2.5",
      "pali": "nāmarūpapaccayā saḷāyatanaṁ;"
    },
    {
      "id": "sn12.2:2.6",
      "pali": "saḷāyatanapaccayā phasso;"
    },
    {
      "id": "sn12.2:2.7",
      "pali": "phassapaccayā vedanā;"
    },
    {
      "id": "sn12.2:2.8",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn12.2:2.9",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.2:2.10",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn12.2:2.11",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn12.2:2.12",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.2:2.13",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.2:3.1",
      "pali": "Katamañca, bhikkhave, jarāmaraṇaṁ?"
    },
    {
      "id": "sn12.2:3.2",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhi tamhi sattanikāye jarā jīraṇatā khaṇḍiccaṁ pāliccaṁ valittacatā āyuno saṁhāni indriyānaṁ paripāko;"
    },
    {
      "id": "sn12.2:3.3",
      "pali": "ayaṁ vuccati jarā."
    },
    {
      "id": "sn12.2:3.4",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhā tamhā sattanikāyā cuti cavanatā bhedo antaradhānaṁ maccu maraṇaṁ kālakiriyā khandhānaṁ bhedo kaḷevarassa nikkhepo (…),"
    },
    {
      "id": "sn12.2:3.5",
      "pali": "idaṁ vuccati maraṇaṁ."
    },
    {
      "id": "sn12.2:3.6",
      "pali": "Iti ayañca jarā, idañca maraṇaṁ."
    },
    {
      "id": "sn12.2:3.7",
      "pali": "Idaṁ vuccati, bhikkhave, jarāmaraṇaṁ."
    },
    {
      "id": "sn12.2:4.1",
      "pali": "Katamā ca, bhikkhave, jāti?"
    },
    {
      "id": "sn12.2:4.2",
      "pali": "Yā tesaṁ tesaṁ sattānaṁ tamhi tamhi sattanikāye jāti sañjāti okkanti abhinibbatti khandhānaṁ pātubhāvo āyatanānaṁ paṭilābho."
    },
    {
      "id": "sn12.2:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, jāti."
    },
    {
      "id": "sn12.2:5.1",
      "pali": "Katamo ca, bhikkhave, bhavo?"
    },
    {
      "id": "sn12.2:5.2",
      "pali": "Tayome, bhikkhave, bhavā—"
    },
    {
      "id": "sn12.2:5.3",
      "pali": "kāmabhavo, rūpabhavo, arūpabhavo."
    },
    {
      "id": "sn12.2:5.4",
      "pali": "Ayaṁ vuccati, bhikkhave, bhavo."
    },
    {
      "id": "sn12.2:6.1",
      "pali": "Katamañca, bhikkhave, upādānaṁ?"
    },
    {
      "id": "sn12.2:6.2",
      "pali": "Cattārimāni, bhikkhave, upādānāni—"
    },
    {
      "id": "sn12.2:6.3",
      "pali": "kāmupādānaṁ, diṭṭhupādānaṁ, sīlabbatupādānaṁ, attavādupādānaṁ."
    },
    {
      "id": "sn12.2:6.4",
      "pali": "Idaṁ vuccati, bhikkhave, upādānaṁ."
    },
    {
      "id": "sn12.2:7.1",
      "pali": "Katamā ca, bhikkhave, taṇhā?"
    },
    {
      "id": "sn12.2:7.2",
      "pali": "Chayime, bhikkhave, taṇhākāyā—"
    },
    {
      "id": "sn12.2:7.3",
      "pali": "rūpataṇhā, saddataṇhā, gandhataṇhā, rasataṇhā, phoṭṭhabbataṇhā, dhammataṇhā."
    },
    {
      "id": "sn12.2:7.4",
      "pali": "Ayaṁ vuccati, bhikkhave, taṇhā."
    },
    {
      "id": "sn12.2:8.1",
      "pali": "Katamā ca, bhikkhave, vedanā?"
    },
    {
      "id": "sn12.2:8.2",
      "pali": "Chayime, bhikkhave, vedanākāyā—"
    },
    {
      "id": "sn12.2:8.3",
      "pali": "cakkhusamphassajā vedanā, sotasamphassajā vedanā, ghānasamphassajā vedanā, jivhāsamphassajā vedanā, kāyasamphassajā vedanā, manosamphassajā vedanā."
    },
    {
      "id": "sn12.2:8.4",
      "pali": "Ayaṁ vuccati, bhikkhave, vedanā."
    },
    {
      "id": "sn12.2:9.1",
      "pali": "Katamo ca, bhikkhave, phasso?"
    },
    {
      "id": "sn12.2:9.2",
      "pali": "Chayime, bhikkhave, phassakāyā—"
    },
    {
      "id": "sn12.2:9.3",
      "pali": "cakkhusamphasso, sotasamphasso, ghānasamphasso, jivhāsamphasso, kāyasamphasso, manosamphasso."
    },
    {
      "id": "sn12.2:9.4",
      "pali": "Ayaṁ vuccati, bhikkhave, phasso."
    },
    {
      "id": "sn12.2:10.1",
      "pali": "Katamañca, bhikkhave, saḷāyatanaṁ?"
    },
    {
      "id": "sn12.2:10.2",
      "pali": "Cakkhāyatanaṁ, sotāyatanaṁ, ghānāyatanaṁ, jivhāyatanaṁ, kāyāyatanaṁ, manāyatanaṁ—"
    },
    {
      "id": "sn12.2:10.3",
      "pali": "idaṁ vuccati, bhikkhave, saḷāyatanaṁ."
    },
    {
      "id": "sn12.2:11.1",
      "pali": "Katamañca, bhikkhave, nāmarūpaṁ?"
    },
    {
      "id": "sn12.2:11.2",
      "pali": "Vedanā, saññā, cetanā, phasso, manasikāro—"
    },
    {
      "id": "sn12.2:11.3",
      "pali": "idaṁ vuccati nāmaṁ."
    },
    {
      "id": "sn12.2:11.4",
      "pali": "Cattāro ca mahābhūtā, catunnañca mahābhūtānaṁ upādāyarūpaṁ."
    },
    {
      "id": "sn12.2:11.5",
      "pali": "Idaṁ vuccati rūpaṁ."
    },
    {
      "id": "sn12.2:11.6",
      "pali": "Iti idañca nāmaṁ, idañca rūpaṁ."
    },
    {
      "id": "sn12.2:11.7",
      "pali": "Idaṁ vuccati, bhikkhave, nāmarūpaṁ."
    },
    {
      "id": "sn12.2:12.1",
      "pali": "Katamañca, bhikkhave, viññāṇaṁ?"
    },
    {
      "id": "sn12.2:12.2",
      "pali": "Chayime, bhikkhave, viññāṇakāyā—"
    },
    {
      "id": "sn12.2:12.3",
      "pali": "cakkhuviññāṇaṁ, sotaviññāṇaṁ, ghānaviññāṇaṁ, jivhāviññāṇaṁ, kāyaviññāṇaṁ, manoviññāṇaṁ."
    },
    {
      "id": "sn12.2:12.4",
      "pali": "Idaṁ vuccati, bhikkhave, viññāṇaṁ."
    },
    {
      "id": "sn12.2:13.1",
      "pali": "Katame ca, bhikkhave, saṅkhārā?"
    },
    {
      "id": "sn12.2:13.2",
      "pali": "Tayome, bhikkhave, saṅkhārā—"
    },
    {
      "id": "sn12.2:13.3",
      "pali": "kāyasaṅkhāro, vacīsaṅkhāro, cittasaṅkhāro."
    },
    {
      "id": "sn12.2:13.4",
      "pali": "Ime vuccanti, bhikkhave, saṅkhārā."
    },
    {
      "id": "sn12.2:14.1",
      "pali": "Katamā ca, bhikkhave, avijjā?"
    },
    {
      "id": "sn12.2:14.2",
      "pali": "Yaṁ kho, bhikkhave, dukkhe aññāṇaṁ, dukkhasamudaye aññāṇaṁ, dukkhanirodhe aññāṇaṁ, dukkhanirodhagāminiyā paṭipadāya aññāṇaṁ."
    },
    {
      "id": "sn12.2:14.3",
      "pali": "Ayaṁ vuccati, bhikkhave, avijjā."
    },
    {
      "id": "sn12.2:15.1",
      "pali": "Iti kho, bhikkhave, avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.2:15.2",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.2:15.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.2:15.4",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.2:15.5",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.2:15.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.2:15.7",
      "pali": "Dutiyaṁ."
    }
  ]
}
