{
  "uid": "sn48.65",
  "title": "Paṭhamaphalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.65:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.65:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.65:1.3",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ—"
    },
    {
      "id": "sn48.65:1.4",
      "pali": "imāni kho, bhikkhave, pañcindriyāni."
    },
    {
      "id": "sn48.65:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "sn48.65:1.6",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "sn48.65:1.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
