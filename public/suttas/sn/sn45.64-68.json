{
  "uid": "sn45.64-68",
  "title": "Sīlasampadādisuttapañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.64-68:1.1",
      "pali": "“Ekadhammo, bhikkhave, bahūpakāro ariyassa aṭṭhaṅgikassa maggassa uppādāya."
    },
    {
      "id": "sn45.64-68:1.2",
      "pali": "Katamo ekadhammo?"
    },
    {
      "id": "sn45.64-68:1.3",
      "pali": "Yadidaṁ—sīlasampadā …pe…"
    },
    {
      "id": "sn45.64-68:1.4",
      "pali": "yadidaṁ—chandasampadā …pe…"
    },
    {
      "id": "sn45.64-68:1.5",
      "pali": "yadidaṁ—attasampadā …pe…"
    },
    {
      "id": "sn45.64-68:1.6",
      "pali": "yadidaṁ—diṭṭhisampadā …pe…"
    },
    {
      "id": "sn45.64-68:1.7",
      "pali": "yadidaṁ—appamādasampadā …pe…."
    },
    {
      "id": "sn45.64-68:1.8",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
