{
  "uid": "sn56.20",
  "title": "Tathasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.20:1.1",
      "pali": "“Cattārimāni, bhikkhave, tathāni avitathāni anaññathāni."
    },
    {
      "id": "sn56.20:1.2",
      "pali": "Katamāni cattāri?"
    },
    {
      "id": "sn56.20:1.3",
      "pali": "‘Idaṁ dukkhan’ti, bhikkhave, tathametaṁ avitathametaṁ anaññathametaṁ;"
    },
    {
      "id": "sn56.20:1.4",
      "pali": "‘ayaṁ dukkhasamudayo’ti tathametaṁ avitathametaṁ anaññathametaṁ;"
    },
    {
      "id": "sn56.20:1.5",
      "pali": "‘ayaṁ dukkhanirodho’ti tathametaṁ avitathametaṁ anaññathametaṁ;"
    },
    {
      "id": "sn56.20:1.6",
      "pali": "‘ayaṁ dukkhanirodhagāminī paṭipadā’ti tathametaṁ avitathametaṁ anaññathametaṁ—"
    },
    {
      "id": "sn56.20:1.7",
      "pali": "imāni kho, bhikkhave, cattāri tathāni avitathāni anaññathāni."
    },
    {
      "id": "sn56.20:2.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.20:2.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn56.20:2.3",
      "pali": "Dhammacakkappavattanavaggo dutiyo."
    },
    {
      "id": "sn56.20:3.1",
      "pali": "Dhammacakkaṁ tathāgataṁ,"
    },
    {
      "id": "sn56.20:3.2",
      "pali": "khandhā āyatanena ca;"
    },
    {
      "id": "sn56.20:3.3",
      "pali": "Dhāraṇā ca dve avijjā,"
    },
    {
      "id": "sn56.20:3.4",
      "pali": "vijjā saṅkāsanā tathāti."
    }
  ]
}
