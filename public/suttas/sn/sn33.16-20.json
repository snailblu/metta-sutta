{
  "uid": "sn33.16-20",
  "title": "sn33.16-20",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn33.16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.16:1.2",
      "pali": "Ekamantaṁ nisinno kho vacchagotto paribbājako bhagavantaṁ etadavoca—"
    },
    {
      "id": "sn33.16:1.3",
      "pali": "ko nu kho, bho gotama, hetu, ko paccayo …pe…"
    },
    {
      "id": "sn33.16:1.4",
      "pali": "rūpe kho, vaccha, ananubodhā …pe… “rūpanirodhagāminiyā paṭipadāya ananubodhā …pe…."
    },
    {
      "id": "sn33.17:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.17:1.2",
      "pali": "“Vedanāya kho, vaccha …pe…."
    },
    {
      "id": "sn33.18:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.18:1.2",
      "pali": "“Saññāya kho, vaccha …pe…."
    },
    {
      "id": "sn33.19:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.19:1.2",
      "pali": "“Saṅkhāresu kho, vaccha …pe…."
    },
    {
      "id": "sn33.20:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.20:1.2",
      "pali": "“Viññāṇe kho, vaccha, ananubodhā …pe…"
    },
    {
      "id": "sn33.20:1.3",
      "pali": "viññāṇanirodhagāminiyā paṭipadāya ananubodhā …pe…"
    },
    {
      "id": "sn33.20:1.4",
      "pali": "vīsatimaṁ."
    }
  ]
}
