{
  "uid": "sn5.10",
  "title": "Vajirāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.10:1.2",
      "pali": "Atha kho vajirā bhikkhunī pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisi."
    },
    {
      "id": "sn5.10:1.3",
      "pali": "Sāvatthiyaṁ piṇḍāya caritvā pacchābhattaṁ piṇḍapātapaṭikkantā yena andhavanaṁ tenupasaṅkami divāvihārāya."
    },
    {
      "id": "sn5.10:1.4",
      "pali": "Andhavanaṁ ajjhogāhetvā aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.10:1.5",
      "pali": "Atha kho māro pāpimā vajirāya bhikkhuniyā bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo yena vajirā bhikkhunī tenupasaṅkami; upasaṅkamitvā vajiraṁ bhikkhuniṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn5.10:2.1",
      "pali": "“Kenāyaṁ pakato satto,"
    },
    {
      "id": "sn5.10:2.2",
      "pali": "kuvaṁ sattassa kārako;"
    },
    {
      "id": "sn5.10:2.3",
      "pali": "Kuvaṁ satto samuppanno,"
    },
    {
      "id": "sn5.10:2.4",
      "pali": "kuvaṁ satto nirujjhatī”ti."
    },
    {
      "id": "sn5.10:3.1",
      "pali": "Atha kho vajirāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.10:3.2",
      "pali": "“ko nu khvāyaṁ manusso vā amanusso vā gāthaṁ bhāsatī”ti?"
    },
    {
      "id": "sn5.10:3.3",
      "pali": "Atha kho vajirāya bhikkhuniyā etadahosi:"
    },
    {
      "id": "sn5.10:3.4",
      "pali": "“māro kho ayaṁ pāpimā mama bhayaṁ chambhitattaṁ lomahaṁsaṁ uppādetukāmo samādhimhā cāvetukāmo gāthaṁ bhāsatī”ti."
    },
    {
      "id": "sn5.10:3.5",
      "pali": "Atha kho vajirā bhikkhunī “māro ayaṁ pāpimā” iti viditvā, māraṁ pāpimantaṁ gāthāhi paccabhāsi:"
    },
    {
      "id": "sn5.10:4.1",
      "pali": "“Kiṁ nu sattoti paccesi,"
    },
    {
      "id": "sn5.10:4.2",
      "pali": "māra diṭṭhigataṁ nu te;"
    },
    {
      "id": "sn5.10:4.3",
      "pali": "Suddhasaṅkhārapuñjoyaṁ,"
    },
    {
      "id": "sn5.10:4.4",
      "pali": "nayidha sattupalabbhati."
    },
    {
      "id": "sn5.10:5.1",
      "pali": "Yathā hi aṅgasambhārā,"
    },
    {
      "id": "sn5.10:5.2",
      "pali": "hoti saddo ratho iti;"
    },
    {
      "id": "sn5.10:5.3",
      "pali": "Evaṁ khandhesu santesu,"
    },
    {
      "id": "sn5.10:5.4",
      "pali": "hoti sattoti sammuti."
    },
    {
      "id": "sn5.10:6.1",
      "pali": "Dukkhameva hi sambhoti,"
    },
    {
      "id": "sn5.10:6.2",
      "pali": "dukkhaṁ tiṭṭhati veti ca;"
    },
    {
      "id": "sn5.10:6.3",
      "pali": "Nāññatra dukkhā sambhoti,"
    },
    {
      "id": "sn5.10:6.4",
      "pali": "nāññaṁ dukkhā nirujjhatī”ti."
    },
    {
      "id": "sn5.10:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ vajirā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    },
    {
      "id": "sn5.10:7.2",
      "pali": "Bhikkhunīvaggo paṭhamo."
    },
    {
      "id": "sn5.10:8.1",
      "pali": "Āḷavikā ca somā ca,"
    },
    {
      "id": "sn5.10:8.2",
      "pali": "Gotamī vijayā saha;"
    },
    {
      "id": "sn5.10:8.3",
      "pali": "Uppalavaṇṇā ca cālā,"
    },
    {
      "id": "sn5.10:8.4",
      "pali": "Upacālā sīsupacālā ca;"
    },
    {
      "id": "sn5.10:8.5",
      "pali": "Selā vajirāya te dasāti."
    },
    {
      "id": "sn5.10:8.6",
      "pali": "Bhikkhunīsaṁyuttaṁ samattaṁ."
    }
  ]
}
