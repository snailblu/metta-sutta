{
  "uid": "sn12.43",
  "title": "Dukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.43:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.43:1.2",
      "pali": "“Dukkhassa, bhikkhave, samudayañca atthaṅgamañca desessāmi."
    },
    {
      "id": "sn12.43:1.3",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "sn12.43:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn12.43:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn12.43:2.1",
      "pali": "“Katamo ca, bhikkhave, dukkhassa samudayo?"
    },
    {
      "id": "sn12.43:2.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.43:2.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.43:2.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.43:2.5",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa samudayo."
    },
    {
      "id": "sn12.43:3.1",
      "pali": "Sotañca paṭicca sadde ca uppajjati sotaviññāṇaṁ …pe…"
    },
    {
      "id": "sn12.43:3.2",
      "pali": "ghānañca paṭicca gandhe ca …pe…"
    },
    {
      "id": "sn12.43:3.3",
      "pali": "jivhañca paṭicca rase ca …pe…"
    },
    {
      "id": "sn12.43:3.4",
      "pali": "kāyañca paṭicca phoṭṭhabbe ca …pe…"
    },
    {
      "id": "sn12.43:3.5",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.43:3.6",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.43:3.7",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.43:3.8",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa samudayo."
    },
    {
      "id": "sn12.43:4.1",
      "pali": "Katamo ca, bhikkhave, dukkhassa atthaṅgamo?"
    },
    {
      "id": "sn12.43:4.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.43:4.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.43:4.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.43:4.5",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.43:4.6",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.43:4.7",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.43:4.8",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.43:4.9",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.43:4.10",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa atthaṅgamo."
    },
    {
      "id": "sn12.43:5.1",
      "pali": "Sotañca paṭicca sadde ca uppajjati sotaviññāṇaṁ …pe…"
    },
    {
      "id": "sn12.43:5.2",
      "pali": "ghānañca paṭicca gandhe ca …pe…"
    },
    {
      "id": "sn12.43:5.3",
      "pali": "jivhañca paṭicca rase ca …pe…"
    },
    {
      "id": "sn12.43:5.4",
      "pali": "kāyañca paṭicca phoṭṭhabbe ca …pe…"
    },
    {
      "id": "sn12.43:5.5",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.43:5.6",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.43:5.7",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.43:5.8",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.43:5.9",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.43:5.10",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.43:5.11",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.43:5.12",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.43:5.13",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa atthaṅgamo”ti."
    },
    {
      "id": "sn12.43:5.14",
      "pali": "Tatiyaṁ."
    }
  ]
}
