{
  "uid": "sn35.92",
  "title": "Paṭhamadvayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.92:1.1",
      "pali": "“Dvayaṁ vo, bhikkhave, desessāmi."
    },
    {
      "id": "sn35.92:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.92:1.3",
      "pali": "Kiñca, bhikkhave, dvayaṁ?"
    },
    {
      "id": "sn35.92:1.4",
      "pali": "Cakkhuñceva rūpā ca, sotañceva saddā ca, ghānañceva gandhā ca, jivhā ceva rasā ca, kāyo ceva phoṭṭhabbā ca, mano ceva dhammā ca—"
    },
    {
      "id": "sn35.92:1.5",
      "pali": "idaṁ vuccati, bhikkhave, dvayaṁ."
    },
    {
      "id": "sn35.92:2.1",
      "pali": "Yo, bhikkhave, evaṁ vadeyya:"
    },
    {
      "id": "sn35.92:2.2",
      "pali": "‘ahametaṁ dvayaṁ paccakkhāya aññaṁ dvayaṁ paññapessāmī’ti, tassa vācāvatthukamevassa."
    },
    {
      "id": "sn35.92:2.3",
      "pali": "Puṭṭho ca na sampāyeyya."
    },
    {
      "id": "sn35.92:2.4",
      "pali": "Uttariñca vighātaṁ āpajjeyya."
    },
    {
      "id": "sn35.92:2.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn35.92:2.6",
      "pali": "Yathā taṁ, bhikkhave, avisayasmin”ti."
    },
    {
      "id": "sn35.92:2.7",
      "pali": "Navamaṁ."
    }
  ]
}
