{
  "uid": "snp2.12",
  "title": "Nigrodhakappa (vaṅgīsa) sutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp2.12:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp2.12:1.2",
      "pali": "ekaṁ samayaṁ bhagavā āḷaviyaṁ viharati aggāḷave cetiye."
    },
    {
      "id": "snp2.12:1.3",
      "pali": "Tena kho pana samayena āyasmato vaṅgīsassa upajjhāyo nigrodhakappo nāma thero aggāḷave cetiye aciraparinibbuto hoti."
    },
    {
      "id": "snp2.12:1.4",
      "pali": "Atha kho āyasmato vaṅgīsassa rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi—"
    },
    {
      "id": "snp2.12:1.5",
      "pali": "parinibbuto nu kho me upajjhāyo udāhu no parinibbutoti?"
    },
    {
      "id": "snp2.12:1.6",
      "pali": "Atha kho āyasmā vaṅgīso sāyanhasamayaṁ paṭisallānā vuṭṭhito yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā vaṅgīso bhagavantaṁ etadavoca—"
    },
    {
      "id": "snp2.12:1.7",
      "pali": "idha mayhaṁ, bhante, rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi—"
    },
    {
      "id": "snp2.12:1.8",
      "pali": "parinibbuto nu kho me upajjhāyo, udāhu no parinibbutoti."
    },
    {
      "id": "snp2.12:1.9",
      "pali": "Atha kho āyasmā vaṅgīso uṭṭhāyāsanā ekaṁsaṁ cīvaraṁ katvā yena bhagavā tenañjaliṁ paṇāmetvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "snp2.12:2.1",
      "pali": "“Pucchāmi satthāramanomapaññaṁ,"
    },
    {
      "id": "snp2.12:2.2",
      "pali": "Diṭṭheva dhamme yo vicikicchānaṁ chettā;"
    },
    {
      "id": "snp2.12:2.3",
      "pali": "Aggāḷave kālamakāsi bhikkhu,"
    },
    {
      "id": "snp2.12:2.4",
      "pali": "Ñāto yasassī abhinibbutatto."
    },
    {
      "id": "snp2.12:3.1",
      "pali": "Nigrodhakappo iti tassa nāmaṁ,"
    },
    {
      "id": "snp2.12:3.2",
      "pali": "Tayā kataṁ bhagavā brāhmaṇassa;"
    },
    {
      "id": "snp2.12:3.3",
      "pali": "So taṁ namassaṁ acari mutyapekkho,"
    },
    {
      "id": "snp2.12:3.4",
      "pali": "Āraddhaviriyo daḷhadhammadassī."
    },
    {
      "id": "snp2.12:4.1",
      "pali": "Taṁ sāvakaṁ sakya mayampi sabbe,"
    },
    {
      "id": "snp2.12:4.2",
      "pali": "Aññātumicchāma samantacakkhu;"
    },
    {
      "id": "snp2.12:4.3",
      "pali": "Samavaṭṭhitā no savanāya sotā,"
    },
    {
      "id": "snp2.12:4.4",
      "pali": "Tuvaṁ no satthā tvamanuttarosi."
    },
    {
      "id": "snp2.12:5.1",
      "pali": "Chindeva no vicikicchaṁ brūhi metaṁ,"
    },
    {
      "id": "snp2.12:5.2",
      "pali": "Parinibbutaṁ vedaya bhūripañña;"
    },
    {
      "id": "snp2.12:5.3",
      "pali": "Majjheva no bhāsa samantacakkhu,"
    },
    {
      "id": "snp2.12:5.4",
      "pali": "Sakkova devāna sahassanetto."
    },
    {
      "id": "snp2.12:6.1",
      "pali": "Ye keci ganthā idha mohamaggā,"
    },
    {
      "id": "snp2.12:6.2",
      "pali": "Aññāṇapakkhā vicikicchaṭhānā;"
    },
    {
      "id": "snp2.12:6.3",
      "pali": "Tathāgataṁ patvā na te bhavanti,"
    },
    {
      "id": "snp2.12:6.4",
      "pali": "Cakkhuñhi etaṁ paramaṁ narānaṁ."
    },
    {
      "id": "snp2.12:7.1",
      "pali": "No ce hi jātu puriso kilese,"
    },
    {
      "id": "snp2.12:7.2",
      "pali": "Vāto yathā abbhaghanaṁ vihāne;"
    },
    {
      "id": "snp2.12:7.3",
      "pali": "Tamovassa nivuto sabbaloko,"
    },
    {
      "id": "snp2.12:7.4",
      "pali": "Na jotimantopi narā tapeyyuṁ."
    },
    {
      "id": "snp2.12:8.1",
      "pali": "Dhīrā ca pajjotakarā bhavanti,"
    },
    {
      "id": "snp2.12:8.2",
      "pali": "Taṁ taṁ ahaṁ vīra tatheva maññe;"
    },
    {
      "id": "snp2.12:8.3",
      "pali": "Vipassinaṁ jānamupāgamumhā,"
    },
    {
      "id": "snp2.12:8.4",
      "pali": "Parisāsu no āvikarohi kappaṁ."
    },
    {
      "id": "snp2.12:9.1",
      "pali": "Khippaṁ giraṁ eraya vaggu vagguṁ,"
    },
    {
      "id": "snp2.12:9.2",
      "pali": "Haṁsova paggayha saṇikaṁ nikūja;"
    },
    {
      "id": "snp2.12:9.3",
      "pali": "Bindussarena suvikappitena,"
    },
    {
      "id": "snp2.12:9.4",
      "pali": "Sabbeva te ujjugatā suṇoma."
    },
    {
      "id": "snp2.12:10.1",
      "pali": "Pahīnajātimaraṇaṁ asesaṁ,"
    },
    {
      "id": "snp2.12:10.2",
      "pali": "Niggayha dhonaṁ vadessāmi dhammaṁ;"
    },
    {
      "id": "snp2.12:10.3",
      "pali": "Na kāmakāro hi puthujjanānaṁ,"
    },
    {
      "id": "snp2.12:10.4",
      "pali": "Saṅkheyyakāro ca tathāgatānaṁ."
    },
    {
      "id": "snp2.12:11.1",
      "pali": "Sampannaveyyākaraṇaṁ tavedaṁ,"
    },
    {
      "id": "snp2.12:11.2",
      "pali": "Samujjupaññassa samuggahītaṁ;"
    },
    {
      "id": "snp2.12:11.3",
      "pali": "Ayamañjalī pacchimo suppaṇāmito,"
    },
    {
      "id": "snp2.12:11.4",
      "pali": "Mā mohayī jānamanomapañña."
    },
    {
      "id": "snp2.12:12.1",
      "pali": "Parovaraṁ ariyadhammaṁ viditvā,"
    },
    {
      "id": "snp2.12:12.2",
      "pali": "Mā mohayī jānamanomavīra;"
    },
    {
      "id": "snp2.12:12.3",
      "pali": "Vāriṁ yathā ghammani ghammatatto,"
    },
    {
      "id": "snp2.12:12.4",
      "pali": "Vācābhikaṅkhāmi sutaṁ pavassa."
    },
    {
      "id": "snp2.12:13.1",
      "pali": "Yadatthikaṁ brahmacariyaṁ acarī,"
    },
    {
      "id": "snp2.12:13.2",
      "pali": "Kappāyano kaccissa taṁ amoghaṁ;"
    },
    {
      "id": "snp2.12:13.3",
      "pali": "Nibbāyi so ādu saupādiseso,"
    },
    {
      "id": "snp2.12:13.4",
      "pali": "Yathā vimutto ahu taṁ suṇoma”."
    },
    {
      "id": "snp2.12:14.1",
      "pali": "“Acchecchi taṇhaṁ idha nāmarūpe,"
    },
    {
      "id": "snp2.12:14.2",
      "pali": "(iti bhagavā)"
    },
    {
      "id": "snp2.12:14.3",
      "pali": "Kaṇhassa sotaṁ dīgharattānusayitaṁ;"
    },
    {
      "id": "snp2.12:14.4",
      "pali": "Atāri jātiṁ maraṇaṁ asesaṁ”,"
    },
    {
      "id": "snp2.12:14.5",
      "pali": "Iccabravī bhagavā pañcaseṭṭho."
    },
    {
      "id": "snp2.12:15.1",
      "pali": "“Esa sutvā pasīdāmi,"
    },
    {
      "id": "snp2.12:15.2",
      "pali": "Vaco te isisattama;"
    },
    {
      "id": "snp2.12:15.3",
      "pali": "Amoghaṁ kira me puṭṭhaṁ,"
    },
    {
      "id": "snp2.12:15.4",
      "pali": "Na maṁ vañcesi brāhmaṇo."
    },
    {
      "id": "snp2.12:16.1",
      "pali": "Yathāvādī tathākārī,"
    },
    {
      "id": "snp2.12:16.2",
      "pali": "Ahu buddhassa sāvako;"
    },
    {
      "id": "snp2.12:16.3",
      "pali": "Acchidā maccuno jālaṁ,"
    },
    {
      "id": "snp2.12:16.4",
      "pali": "Tataṁ māyāvino daḷhaṁ."
    },
    {
      "id": "snp2.12:17.1",
      "pali": "Addasā bhagavā ādiṁ,"
    },
    {
      "id": "snp2.12:17.2",
      "pali": "Upādānassa kappiyo;"
    },
    {
      "id": "snp2.12:17.3",
      "pali": "Accagā vata kappāyano,"
    },
    {
      "id": "snp2.12:17.4",
      "pali": "Maccudheyyaṁ suduttaran”ti."
    },
    {
      "id": "snp2.12:17.5",
      "pali": "Nigrodhakappasuttaṁ dvādasamaṁ."
    }
  ]
}
