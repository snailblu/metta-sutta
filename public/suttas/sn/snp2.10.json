{
  "uid": "snp2.10",
  "title": "Uṭṭhānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp2.10:1.1",
      "pali": "Uṭṭhahatha nisīdatha,"
    },
    {
      "id": "snp2.10:1.2",
      "pali": "ko attho supitena vo;"
    },
    {
      "id": "snp2.10:1.3",
      "pali": "Āturānañhi kā niddā,"
    },
    {
      "id": "snp2.10:1.4",
      "pali": "sallaviddhāna ruppataṁ."
    },
    {
      "id": "snp2.10:2.1",
      "pali": "Uṭṭhahatha nisīdatha,"
    },
    {
      "id": "snp2.10:2.2",
      "pali": "Daḷhaṁ sikkhatha santiyā;"
    },
    {
      "id": "snp2.10:2.3",
      "pali": "Mā vo pamatte viññāya,"
    },
    {
      "id": "snp2.10:2.4",
      "pali": "Maccurājā amohayittha vasānuge."
    },
    {
      "id": "snp2.10:3.1",
      "pali": "Yāya devā manussā ca,"
    },
    {
      "id": "snp2.10:3.2",
      "pali": "sitā tiṭṭhanti atthikā;"
    },
    {
      "id": "snp2.10:3.3",
      "pali": "Tarathetaṁ visattikaṁ,"
    },
    {
      "id": "snp2.10:3.4",
      "pali": "khaṇo vo mā upaccagā;"
    },
    {
      "id": "snp2.10:3.5",
      "pali": "Khaṇātītā hi socanti,"
    },
    {
      "id": "snp2.10:3.6",
      "pali": "nirayamhi samappitā."
    },
    {
      "id": "snp2.10:4.1",
      "pali": "Pamādo rajo pamādo,"
    },
    {
      "id": "snp2.10:4.2",
      "pali": "Pamādānupatito rajo;"
    },
    {
      "id": "snp2.10:4.3",
      "pali": "Appamādena vijjāya,"
    },
    {
      "id": "snp2.10:4.4",
      "pali": "Abbahe sallamattanoti."
    },
    {
      "id": "snp2.10:4.5",
      "pali": "Uṭṭhānasuttaṁ dasamaṁ."
    }
  ]
}
