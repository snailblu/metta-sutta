{
  "uid": "sn1.12",
  "title": "Nandatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.12:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.12:2.1",
      "pali": "“Nandati puttehi puttimā,"
    },
    {
      "id": "sn1.12:2.2",
      "pali": "Gomā gohi tatheva nandati;"
    },
    {
      "id": "sn1.12:2.3",
      "pali": "Upadhīhi narassa nandanā,"
    },
    {
      "id": "sn1.12:2.4",
      "pali": "Na hi so nandati yo nirūpadhī”ti."
    },
    {
      "id": "sn1.12:3.1",
      "pali": "“Socati puttehi puttimā,"
    },
    {
      "id": "sn1.12:3.2",
      "pali": "Gomā gohi tatheva socati;"
    },
    {
      "id": "sn1.12:3.3",
      "pali": "Upadhīhi narassa socanā,"
    },
    {
      "id": "sn1.12:3.4",
      "pali": "Na hi so socati yo nirūpadhī”ti."
    }
  ]
}
