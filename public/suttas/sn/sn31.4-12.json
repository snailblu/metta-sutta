{
  "uid": "sn31.4-12",
  "title": "Sāragandhādidātāsuttanavaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn31.4-12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn31.4-12:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn31.4-12:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā sāragandhe adhivatthānaṁ devānaṁ …pe…"
    },
    {
      "id": "sn31.4-12:1.4",
      "pali": "pheggugandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.5",
      "pali": "tacagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.6",
      "pali": "papaṭikagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.7",
      "pali": "pattagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.8",
      "pali": "pupphagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.9",
      "pali": "phalagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.10",
      "pali": "rasagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.11",
      "pali": "gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn31.4-12:1.12",
      "pali": "“Idha, bhikkhu, ekacco kāyena sucaritaṁ carati, vācāya sucaritaṁ carati, manasā sucaritaṁ carati."
    },
    {
      "id": "sn31.4-12:1.13",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn31.4-12:1.14",
      "pali": "‘sāragandhe adhivatthā devā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn31.4-12:1.15",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn31.4-12:1.16",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā sāragandhe adhivatthānaṁ devānaṁ …pe…"
    },
    {
      "id": "sn31.4-12:1.17",
      "pali": "pheggugandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.18",
      "pali": "tacagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.19",
      "pali": "papaṭikagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.20",
      "pali": "pattagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.21",
      "pali": "pupphagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.22",
      "pali": "phalagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.23",
      "pali": "rasagandhe adhivatthānaṁ devānaṁ …"
    },
    {
      "id": "sn31.4-12:1.24",
      "pali": "gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn31.4-12:1.25",
      "pali": "So dātā hoti sāragandhānaṁ …pe…"
    },
    {
      "id": "sn31.4-12:1.26",
      "pali": "so dātā hoti pheggugandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.27",
      "pali": "so dātā hoti tacagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.28",
      "pali": "so dātā hoti papaṭikagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.29",
      "pali": "so dātā hoti pattagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.30",
      "pali": "so dātā hoti pupphagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.31",
      "pali": "so dātā hoti phalagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.32",
      "pali": "so dātā hoti rasagandhānaṁ …"
    },
    {
      "id": "sn31.4-12:1.33",
      "pali": "so dātā hoti gandhagandhānaṁ."
    },
    {
      "id": "sn31.4-12:1.34",
      "pali": "So kāyassa bhedā paraṁ maraṇā gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn31.4-12:1.35",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā gandhagandhe adhivatthānaṁ devānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn31.4-12:1.36",
      "pali": "Dvādasamaṁ."
    }
  ]
}
