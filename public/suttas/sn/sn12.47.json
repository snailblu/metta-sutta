{
  "uid": "sn12.47",
  "title": "Jāṇussoṇisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.47:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.47:1.2",
      "pali": "Atha kho jāṇussoṇi brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ …pe… ekamantaṁ nisinno kho jāṇussoṇi brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.47:2.1",
      "pali": "“Kiṁ nu kho, bho gotama, sabbamatthī”ti?"
    },
    {
      "id": "sn12.47:2.2",
      "pali": "“‘Sabbamatthī’ti kho, brāhmaṇa, ayameko anto”."
    },
    {
      "id": "sn12.47:3.1",
      "pali": "“Kiṁ pana, bho gotama, sabbaṁ natthī”ti?"
    },
    {
      "id": "sn12.47:3.2",
      "pali": "“‘Sabbaṁ natthī’ti kho, brāhmaṇa, ayaṁ dutiyo anto."
    },
    {
      "id": "sn12.47:3.3",
      "pali": "Ete te, brāhmaṇa, ubho ante anupagamma majjhena tathāgato dhammaṁ deseti:"
    },
    {
      "id": "sn12.47:3.4",
      "pali": "‘avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.47:3.5",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.47:3.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.47:3.7",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.47:3.8",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.47:3.9",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī’”ti."
    },
    {
      "id": "sn12.47:4.1",
      "pali": "Evaṁ vutte, jāṇussoṇi brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.47:4.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn12.47:4.3",
      "pali": "pāṇupetaṁ saraṇaṁ gatan”ti."
    },
    {
      "id": "sn12.47:4.4",
      "pali": "Sattamaṁ."
    }
  ]
}
