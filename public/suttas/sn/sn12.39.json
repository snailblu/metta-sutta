{
  "uid": "sn12.39",
  "title": "Dutiyacetanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.39:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.39:1.2",
      "pali": "“Yañca, bhikkhave, ceteti yañca pakappeti yañca anuseti, ārammaṇametaṁ hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.39:1.3",
      "pali": "Ārammaṇe sati patiṭṭhā viññāṇassa hoti."
    },
    {
      "id": "sn12.39:1.4",
      "pali": "Tasmiṁ patiṭṭhite viññāṇe virūḷhe nāmarūpassa avakkanti hoti."
    },
    {
      "id": "sn12.39:1.5",
      "pali": "Nāmarūpapaccayā saḷāyatanaṁ;"
    },
    {
      "id": "sn12.39:1.6",
      "pali": "saḷāyatanapaccayā phasso;"
    },
    {
      "id": "sn12.39:1.7",
      "pali": "phassapaccayā vedanā …pe…"
    },
    {
      "id": "sn12.39:1.8",
      "pali": "taṇhā …"
    },
    {
      "id": "sn12.39:1.9",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.39:1.10",
      "pali": "bhavo …"
    },
    {
      "id": "sn12.39:1.11",
      "pali": "jāti …"
    },
    {
      "id": "sn12.39:1.12",
      "pali": "jarāmaraṇaṁ …"
    },
    {
      "id": "sn12.39:1.13",
      "pali": "sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn12.39:1.14",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.39:2.1",
      "pali": "No ce, bhikkhave, ceteti no ce pakappeti, atha ce anuseti, ārammaṇametaṁ hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.39:2.2",
      "pali": "Ārammaṇe sati patiṭṭhā viññāṇassa hoti."
    },
    {
      "id": "sn12.39:2.3",
      "pali": "Tasmiṁ patiṭṭhite viññāṇe virūḷhe nāmarūpassa avakkanti hoti."
    },
    {
      "id": "sn12.39:2.4",
      "pali": "Nāmarūpapaccayā saḷāyatanaṁ …pe…"
    },
    {
      "id": "sn12.39:2.5",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.39:3.1",
      "pali": "Yato ca kho, bhikkhave, no ceva ceteti no ca pakappeti no ca anuseti, ārammaṇametaṁ na hoti viññāṇassa ṭhitiyā."
    },
    {
      "id": "sn12.39:3.2",
      "pali": "Ārammaṇe asati patiṭṭhā viññāṇassa na hoti."
    },
    {
      "id": "sn12.39:3.3",
      "pali": "Tadappatiṭṭhite viññāṇe avirūḷhe nāmarūpassa avakkanti na hoti."
    },
    {
      "id": "sn12.39:3.4",
      "pali": "Nāmarūpanirodhā saḷāyatananirodho …pe…"
    },
    {
      "id": "sn12.39:3.5",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.39:3.6",
      "pali": "Navamaṁ."
    }
  ]
}
