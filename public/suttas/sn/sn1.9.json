{
  "uid": "sn1.9",
  "title": "Mānakāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.9:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.9:2.1",
      "pali": "“Na mānakāmassa damo idhatthi,"
    },
    {
      "id": "sn1.9:2.2",
      "pali": "Na monamatthi asamāhitassa;"
    },
    {
      "id": "sn1.9:2.3",
      "pali": "Eko araññe viharaṁ pamatto,"
    },
    {
      "id": "sn1.9:2.4",
      "pali": "Na maccudheyyassa tareyya pāran”ti."
    },
    {
      "id": "sn1.9:3.1",
      "pali": "“Mānaṁ pahāya susamāhitatto,"
    },
    {
      "id": "sn1.9:3.2",
      "pali": "Sucetaso sabbadhi vippamutto;"
    },
    {
      "id": "sn1.9:3.3",
      "pali": "Eko araññe viharaṁ appamatto,"
    },
    {
      "id": "sn1.9:3.4",
      "pali": "Sa maccudheyyassa tareyya pāran”ti."
    }
  ]
}
