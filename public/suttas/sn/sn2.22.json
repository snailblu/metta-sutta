{
  "uid": "sn2.22",
  "title": "Khemasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.22:1.1",
      "pali": "Ekamantaṁ ṭhito kho khemo devaputto bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.22:2.1",
      "pali": "“Caranti bālā dummedhā,"
    },
    {
      "id": "sn2.22:2.2",
      "pali": "amitteneva attanā;"
    },
    {
      "id": "sn2.22:2.3",
      "pali": "Karontā pāpakaṁ kammaṁ,"
    },
    {
      "id": "sn2.22:2.4",
      "pali": "yaṁ hoti kaṭukapphalaṁ."
    },
    {
      "id": "sn2.22:3.1",
      "pali": "Na taṁ kammaṁ kataṁ sādhu,"
    },
    {
      "id": "sn2.22:3.2",
      "pali": "yaṁ katvā anutappati;"
    },
    {
      "id": "sn2.22:3.3",
      "pali": "Yassa assumukho rodaṁ,"
    },
    {
      "id": "sn2.22:3.4",
      "pali": "vipākaṁ paṭisevati."
    },
    {
      "id": "sn2.22:4.1",
      "pali": "Tañca kammaṁ kataṁ sādhu,"
    },
    {
      "id": "sn2.22:4.2",
      "pali": "yaṁ katvā nānutappati;"
    },
    {
      "id": "sn2.22:4.3",
      "pali": "Yassa patīto sumano,"
    },
    {
      "id": "sn2.22:4.4",
      "pali": "vipākaṁ paṭisevati."
    },
    {
      "id": "sn2.22:5.1",
      "pali": "Paṭikacceva taṁ kayirā,"
    },
    {
      "id": "sn2.22:5.2",
      "pali": "yaṁ jaññā hitamattano;"
    },
    {
      "id": "sn2.22:5.3",
      "pali": "Na sākaṭikacintāya,"
    },
    {
      "id": "sn2.22:5.4",
      "pali": "mantā dhīro parakkame."
    },
    {
      "id": "sn2.22:6.1",
      "pali": "Yathā sākaṭiko maṭṭhaṁ,"
    },
    {
      "id": "sn2.22:6.2",
      "pali": "samaṁ hitvā mahāpathaṁ;"
    },
    {
      "id": "sn2.22:6.3",
      "pali": "Visamaṁ maggamāruyha,"
    },
    {
      "id": "sn2.22:6.4",
      "pali": "akkhacchinnova jhāyati."
    },
    {
      "id": "sn2.22:7.1",
      "pali": "Evaṁ dhammā apakkamma,"
    },
    {
      "id": "sn2.22:7.2",
      "pali": "adhammamanuvattiya;"
    },
    {
      "id": "sn2.22:7.3",
      "pali": "Mando maccumukhaṁ patto,"
    },
    {
      "id": "sn2.22:7.4",
      "pali": "akkhacchinnova jhāyatī”ti."
    }
  ]
}
