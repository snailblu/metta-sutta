{
  "uid": "sn46.99-110",
  "title": "Balādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.99-110:1.1",
      "pali": "“Seyyathāpi, bhikkhave, ye keci balakaraṇīyā kammantā karīyan”ti vitthāretabbaṁ."
    },
    {
      "id": "sn46.99-110:1.2",
      "pali": "Balakaraṇīyavaggo ekādasamo."
    },
    {
      "id": "sn46.99-110:2.1",
      "pali": "Balaṁ bījañca nāgo ca,"
    },
    {
      "id": "sn46.99-110:2.2",
      "pali": "rukkho kumbhena sūkiyā;"
    },
    {
      "id": "sn46.99-110:2.3",
      "pali": "Ākāsena ca dve meghā,"
    },
    {
      "id": "sn46.99-110:2.4",
      "pali": "nāvā āgantukā nadīti."
    },
    {
      "id": "sn46.99-110:3.1",
      "pali": "(Balakaraṇīyavaggo bojjhaṅgasaṁyuttassa bojjhaṅgavasena vitthāretabbo.)"
    }
  ]
}
