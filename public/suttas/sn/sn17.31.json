{
  "uid": "sn17.31",
  "title": "Bhindisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.31:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.31:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko."
    },
    {
      "id": "sn17.31:1.3",
      "pali": "Lābhasakkārasilokena abhibhūto pariyādiṇṇacitto, bhikkhave, devadatto saṅghaṁ bhindi."
    },
    {
      "id": "sn17.31:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.31:1.5",
      "pali": "sikkhitabban”ti."
    },
    {
      "id": "sn17.31:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
