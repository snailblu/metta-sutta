{
  "uid": "sn9.13",
  "title": "Pākatindriyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.13:1.1",
      "pali": "Ekaṁ samayaṁ sambahulā bhikkhū kosalesu viharanti aññatarasmiṁ vanasaṇḍe uddhatā unnaḷā capalā mukharā vikiṇṇavācā muṭṭhassatino asampajānā asamāhitā vibbhantacittā pākatindriyā."
    },
    {
      "id": "sn9.13:1.2",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tesaṁ bhikkhūnaṁ anukampikā atthakāmā te bhikkhū saṁvejetukāmā yena te bhikkhū tenupasaṅkami; upasaṅkamitvā te bhikkhū gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn9.13:2.1",
      "pali": "“Sukhajīvino pure āsuṁ,"
    },
    {
      "id": "sn9.13:2.2",
      "pali": "bhikkhū gotamasāvakā;"
    },
    {
      "id": "sn9.13:2.3",
      "pali": "Anicchā piṇḍamesanā,"
    },
    {
      "id": "sn9.13:2.4",
      "pali": "anicchā sayanāsanaṁ;"
    },
    {
      "id": "sn9.13:2.5",
      "pali": "Loke aniccataṁ ñatvā,"
    },
    {
      "id": "sn9.13:2.6",
      "pali": "dukkhassantaṁ akaṁsu te."
    },
    {
      "id": "sn9.13:3.1",
      "pali": "Dupposaṁ katvā attānaṁ,"
    },
    {
      "id": "sn9.13:3.2",
      "pali": "gāme gāmaṇikā viya;"
    },
    {
      "id": "sn9.13:3.3",
      "pali": "Bhutvā bhutvā nipajjanti,"
    },
    {
      "id": "sn9.13:3.4",
      "pali": "parāgāresu mucchitā."
    },
    {
      "id": "sn9.13:4.1",
      "pali": "Saṅghassa añjaliṁ katvā,"
    },
    {
      "id": "sn9.13:4.2",
      "pali": "idhekacce vadāmahaṁ;"
    },
    {
      "id": "sn9.13:4.3",
      "pali": "Apaviddhā anāthā te,"
    },
    {
      "id": "sn9.13:4.4",
      "pali": "yathā petā tatheva te."
    },
    {
      "id": "sn9.13:5.1",
      "pali": "Ye kho pamattā viharanti,"
    },
    {
      "id": "sn9.13:5.2",
      "pali": "te me sandhāya bhāsitaṁ;"
    },
    {
      "id": "sn9.13:5.3",
      "pali": "Ye appamattā viharanti,"
    },
    {
      "id": "sn9.13:5.4",
      "pali": "namo tesaṁ karomahan”ti."
    },
    {
      "id": "sn9.13:6.1",
      "pali": "Atha kho te bhikkhū tāya devatāya saṁvejitā saṁvegamāpādunti."
    }
  ]
}
