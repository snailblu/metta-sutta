{
  "uid": "sn2.3",
  "title": "Māghasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.3:1.2",
      "pali": "Atha kho māgho devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.3:1.3",
      "pali": "Ekamantaṁ ṭhito kho māgho devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.3:2.1",
      "pali": "“Kiṁsu chetvā sukhaṁ seti,"
    },
    {
      "id": "sn2.3:2.2",
      "pali": "kiṁsu chetvā na socati;"
    },
    {
      "id": "sn2.3:2.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn2.3:2.4",
      "pali": "vadhaṁ rocesi gotamā”ti."
    },
    {
      "id": "sn2.3:3.1",
      "pali": "“Kodhaṁ chetvā sukhaṁ seti,"
    },
    {
      "id": "sn2.3:3.2",
      "pali": "kodhaṁ chetvā na socati;"
    },
    {
      "id": "sn2.3:3.3",
      "pali": "Kodhassa visamūlassa,"
    },
    {
      "id": "sn2.3:3.4",
      "pali": "madhuraggassa vatrabhū;"
    },
    {
      "id": "sn2.3:3.5",
      "pali": "Vadhaṁ ariyā pasaṁsanti,"
    },
    {
      "id": "sn2.3:3.6",
      "pali": "tañhi chetvā na socatī”ti."
    }
  ]
}
