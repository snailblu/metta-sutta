{
  "uid": "snp5.9",
  "title": "Hemakamāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.9:1.1",
      "pali": "“Ye me pubbe viyākaṁsu,"
    },
    {
      "id": "snp5.9:1.2",
      "pali": "(iccāyasmā hemako)"
    },
    {
      "id": "snp5.9:1.3",
      "pali": "Huraṁ gotamasāsanā;"
    },
    {
      "id": "snp5.9:1.4",
      "pali": "Iccāsi iti bhavissati,"
    },
    {
      "id": "snp5.9:1.5",
      "pali": "Sabbaṁ taṁ itihītihaṁ;"
    },
    {
      "id": "snp5.9:1.6",
      "pali": "Sabbaṁ taṁ takkavaḍḍhanaṁ,"
    },
    {
      "id": "snp5.9:1.7",
      "pali": "Nāhaṁ tattha abhiramiṁ."
    },
    {
      "id": "snp5.9:2.1",
      "pali": "Tvañca me dhammamakkhāhi,"
    },
    {
      "id": "snp5.9:2.2",
      "pali": "taṇhānigghātanaṁ muni;"
    },
    {
      "id": "snp5.9:2.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "snp5.9:2.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "snp5.9:3.1",
      "pali": "“Idha diṭṭhasutamutaviññātesu,"
    },
    {
      "id": "snp5.9:3.2",
      "pali": "Piyarūpesu hemaka;"
    },
    {
      "id": "snp5.9:3.3",
      "pali": "Chandarāgavinodanaṁ,"
    },
    {
      "id": "snp5.9:3.4",
      "pali": "Nibbānapadamaccutaṁ."
    },
    {
      "id": "snp5.9:4.1",
      "pali": "Etadaññāya ye satā,"
    },
    {
      "id": "snp5.9:4.2",
      "pali": "Diṭṭhadhammābhinibbutā;"
    },
    {
      "id": "snp5.9:4.3",
      "pali": "Upasantā ca te sadā,"
    },
    {
      "id": "snp5.9:4.4",
      "pali": "Tiṇṇā loke visattikan”ti."
    },
    {
      "id": "snp5.9:4.5",
      "pali": "Hemakamāṇavapucchā aṭṭhamā."
    }
  ]
}
