{
  "uid": "sn18.7",
  "title": "Sañcetanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.7:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.7:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.7:1.3",
      "pali": "rūpasañcetanā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.7:1.4",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.7:1.5",
      "pali": "“saddasañcetanā …pe…"
    },
    {
      "id": "sn18.7:1.6",
      "pali": "gandhasañcetanā …"
    },
    {
      "id": "sn18.7:1.7",
      "pali": "rasasañcetanā …"
    },
    {
      "id": "sn18.7:1.8",
      "pali": "phoṭṭhabbasañcetanā …"
    },
    {
      "id": "sn18.7:1.9",
      "pali": "dhammasañcetanā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.7:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.7:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasañcetanāyapi nibbindati …pe… saddasañcetanāyapi nibbindati … gandhasañcetanāyapi nibbindati … rasasañcetanāyapi nibbindati … phoṭṭhabbasañcetanāyapi nibbindati … dhammasañcetanāyapi nibbindati …pe…"
    },
    {
      "id": "sn18.7:1.12",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.7:1.13",
      "pali": "Sattamaṁ."
    }
  ]
}
