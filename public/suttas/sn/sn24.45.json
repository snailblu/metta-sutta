{
  "uid": "sn24.45",
  "title": "Navātasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.45:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.45:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.45:1.3",
      "pali": "‘na vātā vāyanti, na najjo sandanti, na gabbhiniyo vijāyanti, na candimasūriyā udenti vā apenti vā esikaṭṭhāyiṭṭhitā’”ti?"
    },
    {
      "id": "sn24.45:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…."
    },
    {
      "id": "sn24.45:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati—"
    },
    {
      "id": "sn24.45:2.2",
      "pali": "na vātā vāyanti …pe…"
    },
    {
      "id": "sn24.45:2.3",
      "pali": "vedanāya sati …"
    },
    {
      "id": "sn24.45:2.4",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.45:2.5",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.45:2.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.45:2.7",
      "pali": "‘na vātā vāyanti …pe… esikaṭṭhāyiṭṭhitā’ti."
    },
    {
      "id": "sn24.45:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn24.45:3.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.45:3.3",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn24.45:3.4",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.45:3.5",
      "pali": "‘na vātā vāyanti …pe… esikaṭṭhāyiṭṭhitā’”ti?"
    },
    {
      "id": "sn24.45:3.6",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.45:3.7",
      "pali": "“Iti kho, bhikkhave, yadaniccaṁ taṁ dukkhaṁ."
    },
    {
      "id": "sn24.45:3.8",
      "pali": "Tasmiṁ sati, tadupādāya, evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.45:3.9",
      "pali": "‘na vātā vāyanti, na najjo sandanti, na gabbhiniyo vijāyanti, na candimasūriyā udenti vā apenti vā esikaṭṭhāyiṭṭhitā’”ti."
    },
    {
      "id": "sn24.45:3.10",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn24.45:3.11",
      "pali": "saññā …"
    },
    {
      "id": "sn24.45:3.12",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.45:3.13",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.45:3.14",
      "pali": "“Aniccaṁ, bhante” …pe… vipariṇāmadhammaṁ,"
    },
    {
      "id": "sn24.45:3.15",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.45:3.16",
      "pali": "‘na vātā vāyanti …pe… esikaṭṭhāyiṭṭhitā’”ti?"
    },
    {
      "id": "sn24.45:3.17",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.45:3.18",
      "pali": "“Iti kho, bhikkhave, yadaniccaṁ taṁ dukkhaṁ."
    },
    {
      "id": "sn24.45:3.19",
      "pali": "Tasmiṁ sati, tadupādāya evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.45:3.20",
      "pali": "‘na vātā vāyanti …pe… esikaṭṭhāyiṭṭhitā’”ti."
    },
    {
      "id": "sn24.45:3.21",
      "pali": "Paṭhamaṁ."
    }
  ]
}
