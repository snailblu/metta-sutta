{
  "uid": "sn2.18",
  "title": "Kakudhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.18:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn2.18:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sākete viharati añjanavane migadāye."
    },
    {
      "id": "sn2.18:1.3",
      "pali": "Atha kho kakudho devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ añjanavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhito kho kakudho devaputto bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn2.18:1.4",
      "pali": "“nandasi, samaṇā”ti?"
    },
    {
      "id": "sn2.18:1.5",
      "pali": "“Kiṁ laddhā, āvuso”ti?"
    },
    {
      "id": "sn2.18:1.6",
      "pali": "“Tena hi, samaṇa, socasī”ti?"
    },
    {
      "id": "sn2.18:1.7",
      "pali": "“Kiṁ jīyittha, āvuso”ti?"
    },
    {
      "id": "sn2.18:1.8",
      "pali": "“Tena hi, samaṇa, neva nandasi na ca socasī”ti?"
    },
    {
      "id": "sn2.18:1.9",
      "pali": "“Evamāvuso”ti."
    },
    {
      "id": "sn2.18:2.1",
      "pali": "“Kacci tvaṁ anagho bhikkhu,"
    },
    {
      "id": "sn2.18:2.2",
      "pali": "kacci nandī na vijjati;"
    },
    {
      "id": "sn2.18:2.3",
      "pali": "Kacci taṁ ekamāsīnaṁ,"
    },
    {
      "id": "sn2.18:2.4",
      "pali": "aratī nābhikīratī”ti."
    },
    {
      "id": "sn2.18:3.1",
      "pali": "“Anagho ve ahaṁ yakkha,"
    },
    {
      "id": "sn2.18:3.2",
      "pali": "atho nandī na vijjati;"
    },
    {
      "id": "sn2.18:3.3",
      "pali": "Atho maṁ ekamāsīnaṁ,"
    },
    {
      "id": "sn2.18:3.4",
      "pali": "aratī nābhikīratī”ti."
    },
    {
      "id": "sn2.18:4.1",
      "pali": "“Kathaṁ tvaṁ anagho bhikkhu,"
    },
    {
      "id": "sn2.18:4.2",
      "pali": "kathaṁ nandī na vijjati;"
    },
    {
      "id": "sn2.18:4.3",
      "pali": "Kathaṁ taṁ ekamāsīnaṁ,"
    },
    {
      "id": "sn2.18:4.4",
      "pali": "aratī nābhikīratī”ti."
    },
    {
      "id": "sn2.18:5.1",
      "pali": "“Aghajātassa ve nandī,"
    },
    {
      "id": "sn2.18:5.2",
      "pali": "nandījātassa ve aghaṁ;"
    },
    {
      "id": "sn2.18:5.3",
      "pali": "Anandī anagho bhikkhu,"
    },
    {
      "id": "sn2.18:5.4",
      "pali": "evaṁ jānāhi āvuso”ti."
    },
    {
      "id": "sn2.18:6.1",
      "pali": "“Cirassaṁ vata passāmi,"
    },
    {
      "id": "sn2.18:6.2",
      "pali": "brāhmaṇaṁ parinibbutaṁ;"
    },
    {
      "id": "sn2.18:6.3",
      "pali": "Anandiṁ anaghaṁ bhikkhuṁ,"
    },
    {
      "id": "sn2.18:6.4",
      "pali": "tiṇṇaṁ loke visattikan”ti."
    }
  ]
}
