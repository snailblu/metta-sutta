{
  "uid": "sn35.142",
  "title": "Ajjhattānattahetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.142:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, anattā."
    },
    {
      "id": "sn35.142:1.2",
      "pali": "Yopi hetu, yopi paccayo cakkhussa uppādāya, sopi anattā."
    },
    {
      "id": "sn35.142:1.3",
      "pali": "Anattasambhūtaṁ, bhikkhave, cakkhu kuto attā bhavissati …pe…"
    },
    {
      "id": "sn35.142:1.4",
      "pali": "jivhā anattā."
    },
    {
      "id": "sn35.142:1.5",
      "pali": "Yopi hetu yopi paccayo jivhāya uppādāya, sopi anattā."
    },
    {
      "id": "sn35.142:1.6",
      "pali": "Anattasambhūtā, bhikkhave, jivhā kuto attā bhavissati …pe…"
    },
    {
      "id": "sn35.142:1.7",
      "pali": "mano anattā."
    },
    {
      "id": "sn35.142:1.8",
      "pali": "Yopi hetu yopi paccayo manassa uppādāya, sopi anattā."
    },
    {
      "id": "sn35.142:1.9",
      "pali": "Anattasambhūto, bhikkhave, mano kuto attā bhavissati."
    },
    {
      "id": "sn35.142:1.10",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.142:1.11",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn35.142:1.12",
      "pali": "Navamaṁ."
    }
  ]
}
