{
  "uid": "sn22.11",
  "title": "Kālattayaanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.11:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.11:1.2",
      "pali": "“Rūpaṁ, bhikkhave, anattā atītānāgataṁ;"
    },
    {
      "id": "sn22.11:1.3",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.11:1.4",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ rūpasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.11:1.5",
      "pali": "anāgataṁ rūpaṁ nābhinandati;"
    },
    {
      "id": "sn22.11:1.6",
      "pali": "paccuppannassa rūpassa nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn22.11:1.7",
      "pali": "Vedanā anattā …"
    },
    {
      "id": "sn22.11:1.8",
      "pali": "saññā anattā …"
    },
    {
      "id": "sn22.11:1.9",
      "pali": "saṅkhārā anattā …"
    },
    {
      "id": "sn22.11:1.10",
      "pali": "viññāṇaṁ anattā atītānāgataṁ;"
    },
    {
      "id": "sn22.11:1.11",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.11:1.12",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ viññāṇasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.11:1.13",
      "pali": "anāgataṁ viññāṇaṁ nābhinandati;"
    },
    {
      "id": "sn22.11:1.14",
      "pali": "paccuppannassa viññāṇassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn22.11:1.15",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn22.11:1.16",
      "pali": "Nakulapituvaggo paṭhamo."
    },
    {
      "id": "sn22.11:2.1",
      "pali": "Nakulapitā devadahā,"
    },
    {
      "id": "sn22.11:2.2",
      "pali": "Dvepi hāliddikāni ca;"
    },
    {
      "id": "sn22.11:2.3",
      "pali": "Samādhipaṭisallāṇā,"
    },
    {
      "id": "sn22.11:2.4",
      "pali": "Upādāparitassanā duve;"
    },
    {
      "id": "sn22.11:2.5",
      "pali": "Atītānāgatapaccuppannā,"
    },
    {
      "id": "sn22.11:2.6",
      "pali": "Vaggo tena pavuccati."
    }
  ]
}
