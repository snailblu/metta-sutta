{
  "uid": "sn35.106",
  "title": "Dukkhasamudayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.106:1.1",
      "pali": "“Dukkhassa, bhikkhave, samudayañca atthaṅgamañca desessāmi."
    },
    {
      "id": "sn35.106:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.106:1.3",
      "pali": "Katamo ca, bhikkhave, dukkhassa samudayo?"
    },
    {
      "id": "sn35.106:1.4",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.106:1.5",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.106:1.6",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.106:1.7",
      "pali": "Ayaṁ dukkhassa samudayo …pe…"
    },
    {
      "id": "sn35.106:1.8",
      "pali": "jivhañca paṭicca rase ca uppajjati jivhāviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.106:1.9",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.106:1.10",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.106:1.11",
      "pali": "Ayaṁ dukkhassa samudayo …pe… manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ."
    },
    {
      "id": "sn35.106:1.12",
      "pali": "Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.106:1.13",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.106:1.14",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.106:1.15",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa samudayo."
    },
    {
      "id": "sn35.106:2.1",
      "pali": "Katamo ca, bhikkhave, dukkhassa atthaṅgamo?"
    },
    {
      "id": "sn35.106:2.2",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.106:2.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.106:2.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.106:2.5",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.106:2.6",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn35.106:2.7",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn35.106:2.8",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn35.106:2.9",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn35.106:2.10",
      "pali": "Ayaṁ dukkhassa atthaṅgamo …pe…"
    },
    {
      "id": "sn35.106:2.11",
      "pali": "jivhañca paṭicca rase ca uppajjati jivhāviññāṇaṁ …pe…"
    },
    {
      "id": "sn35.106:2.12",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.106:2.13",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.106:2.14",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.106:2.15",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.106:2.16",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn35.106:2.17",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn35.106:2.18",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn35.106:2.19",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn35.106:2.20",
      "pali": "Ayaṁ kho, bhikkhave, dukkhassa atthaṅgamo”ti."
    },
    {
      "id": "sn35.106:2.21",
      "pali": "Tatiyaṁ."
    }
  ]
}
