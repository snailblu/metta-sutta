{
  "uid": "sn2.5",
  "title": "Dāmalisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.5:1.2",
      "pali": "Atha kho dāmali devaputto abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.5:1.3",
      "pali": "Ekamantaṁ ṭhito kho dāmali devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.5:2.1",
      "pali": "“Karaṇīyametaṁ brāhmaṇena,"
    },
    {
      "id": "sn2.5:2.2",
      "pali": "Padhānaṁ akilāsunā;"
    },
    {
      "id": "sn2.5:2.3",
      "pali": "Kāmānaṁ vippahānena,"
    },
    {
      "id": "sn2.5:2.4",
      "pali": "Na tenāsīsate bhavan”ti."
    },
    {
      "id": "sn2.5:3.1",
      "pali": "“Natthi kiccaṁ brāhmaṇassa,"
    },
    {
      "id": "sn2.5:3.2",
      "pali": "(dāmalīti bhagavā)"
    },
    {
      "id": "sn2.5:3.3",
      "pali": "Katakicco hi brāhmaṇo;"
    },
    {
      "id": "sn2.5:3.4",
      "pali": "Yāva na gādhaṁ labhati nadīsu,"
    },
    {
      "id": "sn2.5:3.5",
      "pali": "Āyūhati sabbagattebhi jantu;"
    },
    {
      "id": "sn2.5:3.6",
      "pali": "Gādhañca laddhāna thale ṭhito yo,"
    },
    {
      "id": "sn2.5:3.7",
      "pali": "Nāyūhatī pāragato hi sova."
    },
    {
      "id": "sn2.5:4.1",
      "pali": "Esūpamā dāmali brāhmaṇassa,"
    },
    {
      "id": "sn2.5:4.2",
      "pali": "Khīṇāsavassa nipakassa jhāyino;"
    },
    {
      "id": "sn2.5:4.3",
      "pali": "Pappuyya jātimaraṇassa antaṁ,"
    },
    {
      "id": "sn2.5:4.4",
      "pali": "Nāyūhatī pāragato hi so”ti."
    }
  ]
}
