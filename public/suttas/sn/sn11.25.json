{
  "uid": "sn11.25",
  "title": "Akkodhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.25:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn11.25:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn11.25:1.3",
      "pali": "Tatra kho bhagavā bhikkhū …pe… bhagavā etadavoca:"
    },
    {
      "id": "sn11.25:1.4",
      "pali": "“bhūtapubbaṁ, bhikkhave, sakko devānamindo sudhammāyaṁ sabhāyaṁ deve tāvatiṁse anunayamāno tāyaṁ velāyaṁ imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.25:2.1",
      "pali": "‘Mā vo kodho ajjhabhavi,"
    },
    {
      "id": "sn11.25:2.2",
      "pali": "mā ca kujjhittha kujjhataṁ;"
    },
    {
      "id": "sn11.25:2.3",
      "pali": "Akkodho avihiṁsā ca,"
    },
    {
      "id": "sn11.25:2.4",
      "pali": "ariyesu ca paṭipadā;"
    },
    {
      "id": "sn11.25:2.5",
      "pali": "Atha pāpajanaṁ kodho,"
    },
    {
      "id": "sn11.25:2.6",
      "pali": "pabbatovābhimaddatī’”ti."
    },
    {
      "id": "sn11.25:2.7",
      "pali": "Tatiyo vaggo."
    },
    {
      "id": "sn11.25:3.1",
      "pali": "Chetvā dubbaṇṇiya māyā,"
    },
    {
      "id": "sn11.25:3.2",
      "pali": "accayena akodhano;"
    },
    {
      "id": "sn11.25:3.3",
      "pali": "Desitaṁ buddhaseṭṭhena,"
    },
    {
      "id": "sn11.25:3.4",
      "pali": "idañhi sakkapañcakanti."
    },
    {
      "id": "sn11.25:3.5",
      "pali": "Sakkasaṁyuttaṁ samattaṁ."
    },
    {
      "id": "sn11.25:3.6",
      "pali": "Sagāthāvaggo paṭhamo."
    },
    {
      "id": "sn11.25:4.1",
      "pali": "Devatā devaputto ca,"
    },
    {
      "id": "sn11.25:4.2",
      "pali": "rājā māro ca bhikkhunī;"
    },
    {
      "id": "sn11.25:4.3",
      "pali": "Brahmā brāhmaṇa vaṅgīso,"
    },
    {
      "id": "sn11.25:4.4",
      "pali": "vanayakkhena vāsavoti."
    },
    {
      "id": "sn11.25:4.5",
      "pali": "Sagāthāvaggasaṁyuttapāḷi niṭṭhitā."
    }
  ]
}
