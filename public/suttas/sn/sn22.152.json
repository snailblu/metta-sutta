{
  "uid": "sn22.152",
  "title": "Soattāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.152:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.152:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.152:1.3",
      "pali": "‘so attā, so loko, so pecca bhavissāmi nicco dhuvo sassato avipariṇāmadhammo’”ti?"
    },
    {
      "id": "sn22.152:1.4",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…."
    },
    {
      "id": "sn22.152:1.5",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.152:1.6",
      "pali": "‘so attā, so loko, so pecca bhavissāmi nicco dhuvo sassato avipariṇāmadhammo’ti."
    },
    {
      "id": "sn22.152:1.7",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.152:1.8",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.152:1.9",
      "pali": "saṅkhāresu …pe…"
    },
    {
      "id": "sn22.152:1.10",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn22.152:1.11",
      "pali": "‘so attā, so loko, so pecca bhavissāmi nicco dhuvo sassato avipariṇāmadhammo’ti."
    },
    {
      "id": "sn22.152:2.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.152:2.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.152:2.3",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.4",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.152:2.5",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.6",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn22.152:2.7",
      "pali": "‘so attā, so loko, so pecca bhavissāmi nicco dhuvo sassato avipariṇāmadhammo’”ti?"
    },
    {
      "id": "sn22.152:2.8",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.9",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn22.152:2.10",
      "pali": "saññā …"
    },
    {
      "id": "sn22.152:2.11",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.152:2.12",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.152:2.13",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.14",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.152:2.15",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.16",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn22.152:2.17",
      "pali": "‘so attā so loko, so pecca bhavissāmi nicco dhuvo sassato avipariṇāmadhammo’”ti?"
    },
    {
      "id": "sn22.152:2.18",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.152:2.19",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.152:2.20",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.152:2.21",
      "pali": "Tatiyaṁ."
    }
  ]
}
