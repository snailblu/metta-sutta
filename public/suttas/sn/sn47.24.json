{
  "uid": "sn47.24",
  "title": "Suddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.24:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn47.24:1.2",
      "pali": "“Cattārome, bhikkhave, satipaṭṭhānā."
    },
    {
      "id": "sn47.24:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn47.24:1.4",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.24:1.5",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.24:1.6",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.24:1.7",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.24:1.8",
      "pali": "Ime kho, bhikkhave, cattāro satipaṭṭhānā”ti."
    },
    {
      "id": "sn47.24:1.9",
      "pali": "Catutthaṁ."
    }
  ]
}
