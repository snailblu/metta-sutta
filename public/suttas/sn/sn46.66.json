{
  "uid": "sn46.66",
  "title": "Ānāpānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.66:1.1",
      "pali": "“Ānāpānassati, bhikkhave, bhāvitā …pe…”"
    },
    {
      "id": "sn46.66:1.2",
      "pali": "dasamaṁ."
    },
    {
      "id": "sn46.66:1.3",
      "pali": "Ānāpānavaggo sattamo."
    },
    {
      "id": "sn46.66:2.1",
      "pali": "Aṭṭhikapuḷavakaṁ vinīlakaṁ,"
    },
    {
      "id": "sn46.66:2.2",
      "pali": "Vicchiddakaṁ uddhumātena pañcamaṁ;"
    },
    {
      "id": "sn46.66:2.3",
      "pali": "Mettā karuṇā muditā,"
    },
    {
      "id": "sn46.66:2.4",
      "pali": "Upekkhā ānāpānena te dasāti."
    }
  ]
}
