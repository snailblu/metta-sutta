{
  "uid": "sn48.11",
  "title": "Paṭilābhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.11:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.11:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.11:1.3",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ …pe…."
    },
    {
      "id": "sn48.11:1.4",
      "pali": "Katamañca, bhikkhave, saddhindriyaṁ?"
    },
    {
      "id": "sn48.11:1.5",
      "pali": "Idha, bhikkhave, ariyasāvako saddho hoti, saddahati tathāgatassa bodhiṁ:"
    },
    {
      "id": "sn48.11:1.6",
      "pali": "‘itipi so bhagavā arahaṁ sammāsambuddho vijjācaraṇasampanno sugato lokavidū anuttaro purisadammasārathi satthā devamanussānaṁ buddho bhagavā’ti—"
    },
    {
      "id": "sn48.11:1.7",
      "pali": "idaṁ vuccati, bhikkhave, saddhindriyaṁ."
    },
    {
      "id": "sn48.11:2.1",
      "pali": "Katamañca, bhikkhave, vīriyindriyaṁ?"
    },
    {
      "id": "sn48.11:2.2",
      "pali": "Yaṁ kho, bhikkhave, cattāro sammappadhāne ārabbha vīriyaṁ paṭilabhati—"
    },
    {
      "id": "sn48.11:2.3",
      "pali": "idaṁ vuccati, bhikkhave, vīriyindriyaṁ."
    },
    {
      "id": "sn48.11:3.1",
      "pali": "Katamañca, bhikkhave, satindriyaṁ?"
    },
    {
      "id": "sn48.11:3.2",
      "pali": "Yaṁ kho, bhikkhave, cattāro satipaṭṭhāne ārabbha satiṁ paṭilabhati—"
    },
    {
      "id": "sn48.11:3.3",
      "pali": "idaṁ vuccati, bhikkhave, satindriyaṁ."
    },
    {
      "id": "sn48.11:4.1",
      "pali": "Katamañca, bhikkhave, samādhindriyaṁ?"
    },
    {
      "id": "sn48.11:4.2",
      "pali": "Idha, bhikkhave, ariyasāvako vossaggārammaṇaṁ karitvā labhati samādhiṁ, labhati cittassa ekaggataṁ—"
    },
    {
      "id": "sn48.11:4.3",
      "pali": "idaṁ vuccati, bhikkhave, samādhindriyaṁ."
    },
    {
      "id": "sn48.11:5.1",
      "pali": "Katamañca, bhikkhave, paññindriyaṁ?"
    },
    {
      "id": "sn48.11:5.2",
      "pali": "Idha, bhikkhave, ariyasāvako paññavā hoti udayatthagāminiyā paññāya samannāgato ariyāya nibbedhikāya sammā dukkhakkhayagāminiyā—"
    },
    {
      "id": "sn48.11:5.3",
      "pali": "idaṁ vuccati, bhikkhave, paññindriyaṁ."
    },
    {
      "id": "sn48.11:5.4",
      "pali": "Imāni kho, bhikkhave, pañcindriyānī”ti."
    },
    {
      "id": "sn48.11:5.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
