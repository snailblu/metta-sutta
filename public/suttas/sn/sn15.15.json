{
  "uid": "sn15.15",
  "title": "Pitusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.15:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn15.15:1.2",
      "pali": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.15:1.3",
      "pali": "na so, bhikkhave, satto sulabharūpo yo napitābhūtapubbo …pe…"
    },
    {
      "id": "sn15.15:1.4",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.15:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
