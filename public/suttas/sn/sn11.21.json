{
  "uid": "sn11.21",
  "title": "Chetvāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.21:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.21:1.2",
      "pali": "Atha kho sakko devānamindo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn11.21:1.3",
      "pali": "Ekamantaṁ ṭhito kho sakko devānamindo bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.21:2.1",
      "pali": "“Kiṁsu chetvā sukhaṁ seti,"
    },
    {
      "id": "sn11.21:2.2",
      "pali": "kiṁsu chetvā na socati;"
    },
    {
      "id": "sn11.21:2.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn11.21:2.4",
      "pali": "vadhaṁ rocesi gotamā”ti."
    },
    {
      "id": "sn11.21:3.1",
      "pali": "“Kodhaṁ chetvā sukhaṁ seti,"
    },
    {
      "id": "sn11.21:3.2",
      "pali": "kodhaṁ chetvā na socati;"
    },
    {
      "id": "sn11.21:3.3",
      "pali": "Kodhassa visamūlassa,"
    },
    {
      "id": "sn11.21:3.4",
      "pali": "madhuraggassa vāsava;"
    },
    {
      "id": "sn11.21:3.5",
      "pali": "Vadhaṁ ariyā pasaṁsanti,"
    },
    {
      "id": "sn11.21:3.6",
      "pali": "tañhi chetvā na socatī”ti."
    }
  ]
}
