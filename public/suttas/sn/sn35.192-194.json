{
  "uid": "sn35.192-194",
  "title": "Ajjhattātītādianattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.192-194:1.1",
      "pali": "“Cakkhu, bhikkhave, anattā atītaṁ anāgataṁ paccuppannaṁ …pe… jivhā anattā …pe… mano anattā atīto anāgato paccuppanno."
    },
    {
      "id": "sn35.192-194:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.192-194:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
