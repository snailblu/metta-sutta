{
  "uid": "sn48.23",
  "title": "Aññindriyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.23:1.1",
      "pali": "“Tīṇimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.23:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "sn48.23:1.3",
      "pali": "Anaññātaññassāmītindriyaṁ, aññindriyaṁ, aññātāvindriyaṁ—"
    },
    {
      "id": "sn48.23:1.4",
      "pali": "imāni kho, bhikkhave, tīṇi indriyānī”ti."
    },
    {
      "id": "sn48.23:1.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
