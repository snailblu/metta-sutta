{
  "uid": "snp1.12",
  "title": "Munisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp1.12:1.1",
      "pali": "Santhavāto bhayaṁ jātaṁ,"
    },
    {
      "id": "snp1.12:1.2",
      "pali": "niketā jāyate rajo;"
    },
    {
      "id": "snp1.12:1.3",
      "pali": "Aniketamasanthavaṁ,"
    },
    {
      "id": "snp1.12:1.4",
      "pali": "etaṁ ve munidassanaṁ."
    },
    {
      "id": "snp1.12:2.1",
      "pali": "Yo jātamucchijja na ropayeyya,"
    },
    {
      "id": "snp1.12:2.2",
      "pali": "Jāyantamassa nānuppavecche;"
    },
    {
      "id": "snp1.12:2.3",
      "pali": "Tamāhu ekaṁ muninaṁ carantaṁ,"
    },
    {
      "id": "snp1.12:2.4",
      "pali": "Addakkhi so santipadaṁ mahesi."
    },
    {
      "id": "snp1.12:3.1",
      "pali": "Saṅkhāya vatthūni pamāya bījaṁ,"
    },
    {
      "id": "snp1.12:3.2",
      "pali": "Sinehamassa nānuppavecche;"
    },
    {
      "id": "snp1.12:3.3",
      "pali": "Sa ve munī jātikhayantadassī,"
    },
    {
      "id": "snp1.12:3.4",
      "pali": "Takkaṁ pahāya na upeti saṅkhaṁ."
    },
    {
      "id": "snp1.12:4.1",
      "pali": "Aññāya sabbāni nivesanāni,"
    },
    {
      "id": "snp1.12:4.2",
      "pali": "Anikāmayaṁ aññatarampi tesaṁ;"
    },
    {
      "id": "snp1.12:4.3",
      "pali": "Sa ve munī vītagedho agiddho,"
    },
    {
      "id": "snp1.12:4.4",
      "pali": "Nāyūhatī pāragato hi hoti."
    },
    {
      "id": "snp1.12:5.1",
      "pali": "Sabbābhibhuṁ sabbaviduṁ sumedhaṁ,"
    },
    {
      "id": "snp1.12:5.2",
      "pali": "Sabbesu dhammesu anūpalittaṁ;"
    },
    {
      "id": "snp1.12:5.3",
      "pali": "Sabbañjahaṁ taṇhakkhaye vimuttaṁ,"
    },
    {
      "id": "snp1.12:5.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:6.1",
      "pali": "Paññābalaṁ sīlavatūpapannaṁ,"
    },
    {
      "id": "snp1.12:6.2",
      "pali": "Samāhitaṁ jhānarataṁ satīmaṁ;"
    },
    {
      "id": "snp1.12:6.3",
      "pali": "Saṅgā pamuttaṁ akhilaṁ anāsavaṁ,"
    },
    {
      "id": "snp1.12:6.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:7.1",
      "pali": "Ekaṁ carantaṁ munimappamattaṁ,"
    },
    {
      "id": "snp1.12:7.2",
      "pali": "Nindāpasaṁsāsu avedhamānaṁ;"
    },
    {
      "id": "snp1.12:7.3",
      "pali": "Sīhaṁva saddesu asantasantaṁ,"
    },
    {
      "id": "snp1.12:7.4",
      "pali": "Vātaṁva jālamhi asajjamānaṁ;"
    },
    {
      "id": "snp1.12:7.5",
      "pali": "Padmaṁva toyena alippamānaṁ,"
    },
    {
      "id": "snp1.12:7.6",
      "pali": "Netāramaññesamanaññaneyyaṁ;"
    },
    {
      "id": "snp1.12:7.7",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:8.1",
      "pali": "Yo ogahaṇe thambhorivābhijāyati,"
    },
    {
      "id": "snp1.12:8.2",
      "pali": "Yasmiṁ pare vācāpariyantaṁ vadanti;"
    },
    {
      "id": "snp1.12:8.3",
      "pali": "Taṁ vītarāgaṁ susamāhitindriyaṁ,"
    },
    {
      "id": "snp1.12:8.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:9.1",
      "pali": "Yo ve ṭhitatto tasaraṁva ujju,"
    },
    {
      "id": "snp1.12:9.2",
      "pali": "Jigucchati kammehi pāpakehi;"
    },
    {
      "id": "snp1.12:9.3",
      "pali": "Vīmaṁsamāno visamaṁ samañca,"
    },
    {
      "id": "snp1.12:9.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:10.1",
      "pali": "Yo saññatatto na karoti pāpaṁ,"
    },
    {
      "id": "snp1.12:10.2",
      "pali": "Daharo majjhimo ca muni yatatto;"
    },
    {
      "id": "snp1.12:10.3",
      "pali": "Arosaneyyo na so roseti kañci,"
    },
    {
      "id": "snp1.12:10.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:11.1",
      "pali": "Yadaggato majjhato sesato vā,"
    },
    {
      "id": "snp1.12:11.2",
      "pali": "Piṇḍaṁ labhetha paradattūpajīvī;"
    },
    {
      "id": "snp1.12:11.3",
      "pali": "Nālaṁ thutuṁ nopi nipaccavādī,"
    },
    {
      "id": "snp1.12:11.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:12.1",
      "pali": "Muniṁ carantaṁ virataṁ methunasmā,"
    },
    {
      "id": "snp1.12:12.2",
      "pali": "Yo yobbane nopanibajjhate kvaci;"
    },
    {
      "id": "snp1.12:12.3",
      "pali": "Madappamādā virataṁ vippamuttaṁ,"
    },
    {
      "id": "snp1.12:12.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:13.1",
      "pali": "Aññāya lokaṁ paramatthadassiṁ,"
    },
    {
      "id": "snp1.12:13.2",
      "pali": "Oghaṁ samuddaṁ atitariya tādiṁ;"
    },
    {
      "id": "snp1.12:13.3",
      "pali": "Taṁ chinnaganthaṁ asitaṁ anāsavaṁ,"
    },
    {
      "id": "snp1.12:13.4",
      "pali": "Taṁ vāpi dhīrā muni vedayanti."
    },
    {
      "id": "snp1.12:14.1",
      "pali": "Asamā ubho dūravihāravuttino,"
    },
    {
      "id": "snp1.12:14.2",
      "pali": "Gihī dāraposī amamo ca subbato;"
    },
    {
      "id": "snp1.12:14.3",
      "pali": "Parapāṇarodhāya gihī asaññato,"
    },
    {
      "id": "snp1.12:14.4",
      "pali": "Niccaṁ munī rakkhati pāṇine yato."
    },
    {
      "id": "snp1.12:15.1",
      "pali": "Sikhī yathā nīlagīvo vihaṅgamo,"
    },
    {
      "id": "snp1.12:15.2",
      "pali": "Haṁsassa nopeti javaṁ kudācanaṁ;"
    },
    {
      "id": "snp1.12:15.3",
      "pali": "Evaṁ gihī nānukaroti bhikkhuno,"
    },
    {
      "id": "snp1.12:15.4",
      "pali": "Munino vivittassa vanamhi jhāyatoti."
    },
    {
      "id": "snp1.12:15.5",
      "pali": "Munisuttaṁ dvādasamaṁ."
    },
    {
      "id": "snp1.12:15.6",
      "pali": "Uragavaggo paṭhamo."
    },
    {
      "id": "snp1.12:16.1",
      "pali": "Urago dhaniyo ceva,"
    },
    {
      "id": "snp1.12:16.2",
      "pali": "visāṇañca tathā kasi;"
    },
    {
      "id": "snp1.12:16.3",
      "pali": "Cundo parābhavo ceva,"
    },
    {
      "id": "snp1.12:16.4",
      "pali": "vasalo mettabhāvanā."
    },
    {
      "id": "snp1.12:17.1",
      "pali": "Sātāgiro āḷavako,"
    },
    {
      "id": "snp1.12:17.2",
      "pali": "Vijayo ca tathā muni;"
    },
    {
      "id": "snp1.12:17.3",
      "pali": "Dvādasetāni suttāni,"
    },
    {
      "id": "snp1.12:17.4",
      "pali": "Uragavaggoti vuccatīti."
    }
  ]
}
