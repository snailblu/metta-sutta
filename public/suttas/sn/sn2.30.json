{
  "uid": "sn2.30",
  "title": "Nānātitthiyasāvakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.30:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn2.30:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn2.30:1.3",
      "pali": "Atha kho sambahulā nānātitthiyasāvakā devaputtā asamo ca sahali ca nīko ca ākoṭako ca vegabbhari ca māṇavagāmiyo ca abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ veḷuvanaṁ obhāsetvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn2.30:1.4",
      "pali": "Ekamantaṁ ṭhito kho asamo devaputto pūraṇaṁ kassapaṁ ārabbha bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.30:2.1",
      "pali": "“Idha chinditamārite,"
    },
    {
      "id": "sn2.30:2.2",
      "pali": "Hatajānīsu kassapo;"
    },
    {
      "id": "sn2.30:2.3",
      "pali": "Na pāpaṁ samanupassati,"
    },
    {
      "id": "sn2.30:2.4",
      "pali": "Puññaṁ vā pana attano;"
    },
    {
      "id": "sn2.30:2.5",
      "pali": "Sa ve vissāsamācikkhi,"
    },
    {
      "id": "sn2.30:2.6",
      "pali": "Satthā arahati mānanan”ti."
    },
    {
      "id": "sn2.30:3.1",
      "pali": "Atha kho sahali devaputto makkhaliṁ gosālaṁ ārabbha bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.30:4.1",
      "pali": "“Tapojigucchāya susaṁvutatto,"
    },
    {
      "id": "sn2.30:4.2",
      "pali": "Vācaṁ pahāya kalahaṁ janena;"
    },
    {
      "id": "sn2.30:4.3",
      "pali": "Samosavajjā virato saccavādī,"
    },
    {
      "id": "sn2.30:4.4",
      "pali": "Na hi nūna tādisaṁ karoti pāpan”ti."
    },
    {
      "id": "sn2.30:5.1",
      "pali": "Atha kho nīko devaputto nigaṇṭhaṁ nāṭaputtaṁ ārabbha bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.30:6.1",
      "pali": "“Jegucchī nipako bhikkhu,"
    },
    {
      "id": "sn2.30:6.2",
      "pali": "Cātuyāmasusaṁvuto;"
    },
    {
      "id": "sn2.30:6.3",
      "pali": "Diṭṭhaṁ sutañca ācikkhaṁ,"
    },
    {
      "id": "sn2.30:6.4",
      "pali": "Na hi nūna kibbisī siyā”ti."
    },
    {
      "id": "sn2.30:7.1",
      "pali": "Atha kho ākoṭako devaputto nānātitthiye ārabbha bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.30:8.1",
      "pali": "“Pakudhako kātiyāno nigaṇṭho,"
    },
    {
      "id": "sn2.30:8.2",
      "pali": "Ye cāpime makkhalipūraṇāse;"
    },
    {
      "id": "sn2.30:8.3",
      "pali": "Gaṇassa satthāro sāmaññappattā,"
    },
    {
      "id": "sn2.30:8.4",
      "pali": "Na hi nūna te sappurisehi dūre”ti."
    },
    {
      "id": "sn2.30:9.1",
      "pali": "Atha kho vegabbhari devaputto ākoṭakaṁ devaputtaṁ gāthāya paccabhāsi:"
    },
    {
      "id": "sn2.30:10.1",
      "pali": "“Sahācaritena chavo sigālo,"
    },
    {
      "id": "sn2.30:10.2",
      "pali": "Na kotthuko sīhasamo kadāci;"
    },
    {
      "id": "sn2.30:10.3",
      "pali": "Naggo musāvādī gaṇassa satthā,"
    },
    {
      "id": "sn2.30:10.4",
      "pali": "Saṅkassarācāro na sataṁ sarikkho”ti."
    },
    {
      "id": "sn2.30:11.1",
      "pali": "Atha kho māro pāpimā begabbhariṁ devaputtaṁ anvāvisitvā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.30:12.1",
      "pali": "“Tapojigucchāya āyuttā,"
    },
    {
      "id": "sn2.30:12.2",
      "pali": "pālayaṁ pavivekiyaṁ;"
    },
    {
      "id": "sn2.30:12.3",
      "pali": "Rūpe ca ye niviṭṭhāse,"
    },
    {
      "id": "sn2.30:12.4",
      "pali": "devalokābhinandino;"
    },
    {
      "id": "sn2.30:12.5",
      "pali": "Te ve sammānusāsanti,"
    },
    {
      "id": "sn2.30:12.6",
      "pali": "paralokāya mātiyā”ti."
    },
    {
      "id": "sn2.30:13.1",
      "pali": "Atha kho bhagavā “māro ayaṁ pāpimā” iti viditvā, māraṁ pāpimantaṁ gāthāya paccabhāsi:"
    },
    {
      "id": "sn2.30:14.1",
      "pali": "“Ye keci rūpā idha vā huraṁ vā,"
    },
    {
      "id": "sn2.30:14.2",
      "pali": "Ye cantalikkhasmiṁ pabhāsavaṇṇā;"
    },
    {
      "id": "sn2.30:14.3",
      "pali": "Sabbeva te te namucippasatthā,"
    },
    {
      "id": "sn2.30:14.4",
      "pali": "Āmisaṁva macchānaṁ vadhāya khittā”ti."
    },
    {
      "id": "sn2.30:15.1",
      "pali": "Atha kho māṇavagāmiyo devaputto bhagavantaṁ ārabbha bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn2.30:16.1",
      "pali": "“Vipulo rājagahīyānaṁ,"
    },
    {
      "id": "sn2.30:16.2",
      "pali": "giri seṭṭho pavuccati;"
    },
    {
      "id": "sn2.30:16.3",
      "pali": "Seto himavataṁ seṭṭho,"
    },
    {
      "id": "sn2.30:16.4",
      "pali": "ādicco aghagāminaṁ."
    },
    {
      "id": "sn2.30:17.1",
      "pali": "Samuddo udadhinaṁ seṭṭho,"
    },
    {
      "id": "sn2.30:17.2",
      "pali": "nakkhattānaṁva candimā;"
    },
    {
      "id": "sn2.30:17.3",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "sn2.30:17.4",
      "pali": "buddho aggo pavuccatī”ti."
    },
    {
      "id": "sn2.30:17.5",
      "pali": "Nānātitthiyavaggo tatiyo."
    },
    {
      "id": "sn2.30:18.1",
      "pali": "Sivo khemo ca serī ca,"
    },
    {
      "id": "sn2.30:18.2",
      "pali": "Ghaṭī jantu ca rohito;"
    },
    {
      "id": "sn2.30:18.3",
      "pali": "Nando nandivisālo ca,"
    },
    {
      "id": "sn2.30:18.4",
      "pali": "Susimo nānātitthiyena te dasāti."
    },
    {
      "id": "sn2.30:18.5",
      "pali": "Devaputtasaṁyuttaṁ samattaṁ."
    }
  ]
}
