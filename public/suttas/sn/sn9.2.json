{
  "uid": "sn9.2",
  "title": "Upaṭṭhānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.2:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.2:1.2",
      "pali": "Tena kho pana samayena so bhikkhu divāvihāragato supati."
    },
    {
      "id": "sn9.2:1.3",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno anukampikā atthakāmā taṁ bhikkhuṁ saṁvejetukāmā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn9.2:2.1",
      "pali": "“Uṭṭhehi bhikkhu kiṁ sesi,"
    },
    {
      "id": "sn9.2:2.2",
      "pali": "ko attho supitena te;"
    },
    {
      "id": "sn9.2:2.3",
      "pali": "Āturassa hi kā niddā,"
    },
    {
      "id": "sn9.2:2.4",
      "pali": "sallaviddhassa ruppato."
    },
    {
      "id": "sn9.2:3.1",
      "pali": "Yāya saddhāya pabbajito,"
    },
    {
      "id": "sn9.2:3.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "sn9.2:3.3",
      "pali": "Tameva saddhaṁ brūhehi,"
    },
    {
      "id": "sn9.2:3.4",
      "pali": "mā niddāya vasaṁ gamī”ti."
    },
    {
      "id": "sn9.2:4.1",
      "pali": "“Aniccā addhuvā kāmā,"
    },
    {
      "id": "sn9.2:4.2",
      "pali": "yesu mandova mucchito;"
    },
    {
      "id": "sn9.2:4.3",
      "pali": "Baddhesu muttaṁ asitaṁ,"
    },
    {
      "id": "sn9.2:4.4",
      "pali": "kasmā pabbajitaṁ tape."
    },
    {
      "id": "sn9.2:5.1",
      "pali": "Chandarāgassa vinayā,"
    },
    {
      "id": "sn9.2:5.2",
      "pali": "avijjāsamatikkamā;"
    },
    {
      "id": "sn9.2:5.3",
      "pali": "Taṁ ñāṇaṁ paramodānaṁ,"
    },
    {
      "id": "sn9.2:5.4",
      "pali": "kasmā pabbajitaṁ tape."
    },
    {
      "id": "sn9.2:6.1",
      "pali": "Chetvā avijjaṁ vijjāya,"
    },
    {
      "id": "sn9.2:6.2",
      "pali": "āsavānaṁ parikkhayā;"
    },
    {
      "id": "sn9.2:6.3",
      "pali": "Asokaṁ anupāyāsaṁ,"
    },
    {
      "id": "sn9.2:6.4",
      "pali": "kasmā pabbajitaṁ tape."
    },
    {
      "id": "sn9.2:7.1",
      "pali": "Āraddhavīriyaṁ pahitattaṁ,"
    },
    {
      "id": "sn9.2:7.2",
      "pali": "Niccaṁ daḷhaparakkamaṁ;"
    },
    {
      "id": "sn9.2:7.3",
      "pali": "Nibbānaṁ abhikaṅkhantaṁ,"
    },
    {
      "id": "sn9.2:7.4",
      "pali": "Kasmā pabbajitaṁ tape”ti."
    }
  ]
}
