{
  "uid": "sn26.4",
  "title": "Samphassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn26.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn26.4:1.2",
      "pali": "“Yo kho, bhikkhave, cakkhusamphassassa uppādo ṭhiti …pe…"
    },
    {
      "id": "sn26.4:1.3",
      "pali": "jarāmaraṇassa pātubhāvo …pe…"
    },
    {
      "id": "sn26.4:1.4",
      "pali": "yo manosamphassassa uppādo ṭhiti …pe…"
    },
    {
      "id": "sn26.4:1.5",
      "pali": "jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn26.4:1.6",
      "pali": "Yo ca kho, bhikkhave, cakkhusamphassassa nirodho …pe…"
    },
    {
      "id": "sn26.4:1.7",
      "pali": "jarāmaraṇassa atthaṅgamo …pe…"
    },
    {
      "id": "sn26.4:1.8",
      "pali": "yo manosamphassassa nirodho …pe…"
    },
    {
      "id": "sn26.4:1.9",
      "pali": "jarāmaraṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn26.4:1.10",
      "pali": "Catutthaṁ."
    }
  ]
}
