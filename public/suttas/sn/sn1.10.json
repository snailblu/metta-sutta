{
  "uid": "sn1.10",
  "title": "Araññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.10:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn1.10:2.1",
      "pali": "“Araññe viharantānaṁ,"
    },
    {
      "id": "sn1.10:2.2",
      "pali": "santānaṁ brahmacārinaṁ;"
    },
    {
      "id": "sn1.10:2.3",
      "pali": "Ekabhattaṁ bhuñjamānānaṁ,"
    },
    {
      "id": "sn1.10:2.4",
      "pali": "kena vaṇṇo pasīdatī”ti."
    },
    {
      "id": "sn1.10:3.1",
      "pali": "“Atītaṁ nānusocanti,"
    },
    {
      "id": "sn1.10:3.2",
      "pali": "nappajappanti nāgataṁ;"
    },
    {
      "id": "sn1.10:3.3",
      "pali": "Paccuppannena yāpenti,"
    },
    {
      "id": "sn1.10:3.4",
      "pali": "tena vaṇṇo pasīdati."
    },
    {
      "id": "sn1.10:4.1",
      "pali": "Anāgatappajappāya,"
    },
    {
      "id": "sn1.10:4.2",
      "pali": "atītassānusocanā;"
    },
    {
      "id": "sn1.10:4.3",
      "pali": "Etena bālā sussanti,"
    },
    {
      "id": "sn1.10:4.4",
      "pali": "naḷova harito luto”ti."
    },
    {
      "id": "sn1.10:4.5",
      "pali": "Naḷavaggo paṭhamo."
    },
    {
      "id": "sn1.10:5.1",
      "pali": "Oghaṁ nimokkhaṁ upaneyyaṁ,"
    },
    {
      "id": "sn1.10:5.2",
      "pali": "Accenti katichindi ca;"
    },
    {
      "id": "sn1.10:5.3",
      "pali": "Jāgaraṁ appaṭividitā,"
    },
    {
      "id": "sn1.10:5.4",
      "pali": "Susammuṭṭhā mānakāminā;"
    },
    {
      "id": "sn1.10:5.5",
      "pali": "Araññe dasamo vutto,"
    },
    {
      "id": "sn1.10:5.6",
      "pali": "Vaggo tena pavuccati."
    }
  ]
}
