{
  "uid": "sn22.159",
  "title": "Ānandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.159:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.159:1.2",
      "pali": "Atha kho āyasmā ānando yena bhagavā tenupasaṅkami; upasaṅkamitvā …pe… bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.159:1.3",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu, yamahaṁ bhagavato dhammaṁ sutvā eko vūpakaṭṭho appamatto ātāpī pahitatto vihareyyan”ti."
    },
    {
      "id": "sn22.159:2.1",
      "pali": "“Taṁ kiṁ maññasi, ānanda,"
    },
    {
      "id": "sn22.159:2.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.159:2.3",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.4",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.159:2.5",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.6",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn22.159:2.7",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn22.159:2.8",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.9",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn22.159:2.10",
      "pali": "saññā …"
    },
    {
      "id": "sn22.159:2.11",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.159:2.12",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.159:2.13",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.14",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.159:2.15",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.16",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn22.159:2.17",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn22.159:2.18",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.159:2.19",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.159:2.20",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.159:2.21",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn22.159:2.22",
      "pali": "Diṭṭhivaggo pañcamo."
    },
    {
      "id": "sn22.159:3.1",
      "pali": "Ajjhattikaṁ etaṁmama,"
    },
    {
      "id": "sn22.159:3.2",
      "pali": "Soattā nocamesiyā;"
    },
    {
      "id": "sn22.159:3.3",
      "pali": "Micchāsakkāyattānu dve,"
    },
    {
      "id": "sn22.159:3.4",
      "pali": "Abhinivesā ānandenāti."
    },
    {
      "id": "sn22.159:3.5",
      "pali": "Uparipaṇṇāsako samatto."
    },
    {
      "id": "sn22.159:4.1",
      "pali": "Anto dhammakathikā vijjā,"
    },
    {
      "id": "sn22.159:4.2",
      "pali": "kukkuḷaṁ diṭṭhipañcamaṁ;"
    },
    {
      "id": "sn22.159:4.3",
      "pali": "Tatiyo paṇṇāsako vutto,"
    },
    {
      "id": "sn22.159:4.4",
      "pali": "nipātoti pavuccatīti."
    },
    {
      "id": "sn22.159:4.5",
      "pali": "Khandhasaṁyuttaṁ samattaṁ."
    }
  ]
}
