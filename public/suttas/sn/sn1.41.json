{
  "uid": "sn1.41",
  "title": "Ādittasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.41:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.41:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn1.41:1.3",
      "pali": "Atha kho aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ jetavanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn1.41:1.4",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.41:2.1",
      "pali": "“Ādittasmiṁ agārasmiṁ,"
    },
    {
      "id": "sn1.41:2.2",
      "pali": "yaṁ nīharati bhājanaṁ;"
    },
    {
      "id": "sn1.41:2.3",
      "pali": "Taṁ tassa hoti atthāya,"
    },
    {
      "id": "sn1.41:2.4",
      "pali": "no ca yaṁ tattha ḍayhati."
    },
    {
      "id": "sn1.41:3.1",
      "pali": "Evaṁ ādittako loko,"
    },
    {
      "id": "sn1.41:3.2",
      "pali": "jarāya maraṇena ca;"
    },
    {
      "id": "sn1.41:3.3",
      "pali": "Nīharetheva dānena,"
    },
    {
      "id": "sn1.41:3.4",
      "pali": "dinnaṁ hoti sunīhataṁ."
    },
    {
      "id": "sn1.41:4.1",
      "pali": "Dinnaṁ sukhaphalaṁ hoti,"
    },
    {
      "id": "sn1.41:4.2",
      "pali": "nādinnaṁ hoti taṁ tathā;"
    },
    {
      "id": "sn1.41:4.3",
      "pali": "Corā haranti rājāno,"
    },
    {
      "id": "sn1.41:4.4",
      "pali": "aggi ḍahati nassati."
    },
    {
      "id": "sn1.41:5.1",
      "pali": "Atha antena jahati,"
    },
    {
      "id": "sn1.41:5.2",
      "pali": "Sarīraṁ sapariggahaṁ;"
    },
    {
      "id": "sn1.41:5.3",
      "pali": "Etadaññāya medhāvī,"
    },
    {
      "id": "sn1.41:5.4",
      "pali": "Bhuñjetha ca dadetha ca;"
    },
    {
      "id": "sn1.41:5.5",
      "pali": "Datvā ca bhutvā ca yathānubhāvaṁ,"
    },
    {
      "id": "sn1.41:5.6",
      "pali": "Anindito saggamupeti ṭhānan”ti."
    }
  ]
}
