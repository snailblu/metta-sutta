{
  "uid": "snp2.8",
  "title": "Dhamma (nāvā) sutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp2.8:1.1",
      "pali": "Yasmā hi dhammaṁ puriso vijaññā,"
    },
    {
      "id": "snp2.8:1.2",
      "pali": "Indaṁva naṁ devatā pūjayeyya;"
    },
    {
      "id": "snp2.8:1.3",
      "pali": "So pūjito tasmi pasannacitto,"
    },
    {
      "id": "snp2.8:1.4",
      "pali": "Bahussuto pātukaroti dhammaṁ."
    },
    {
      "id": "snp2.8:2.1",
      "pali": "Tadaṭṭhikatvāna nisamma dhīro,"
    },
    {
      "id": "snp2.8:2.2",
      "pali": "Dhammānudhammaṁ paṭipajjamāno;"
    },
    {
      "id": "snp2.8:2.3",
      "pali": "Viññū vibhāvī nipuṇo ca hoti,"
    },
    {
      "id": "snp2.8:2.4",
      "pali": "Yo tādisaṁ bhajati appamatto."
    },
    {
      "id": "snp2.8:3.1",
      "pali": "Khuddañca bālaṁ upasevamāno,"
    },
    {
      "id": "snp2.8:3.2",
      "pali": "Anāgatatthañca usūyakañca;"
    },
    {
      "id": "snp2.8:3.3",
      "pali": "Idheva dhammaṁ avibhāvayitvā,"
    },
    {
      "id": "snp2.8:3.4",
      "pali": "Avitiṇṇakaṅkho maraṇaṁ upeti."
    },
    {
      "id": "snp2.8:4.1",
      "pali": "Yathā naro āpagamotaritvā,"
    },
    {
      "id": "snp2.8:4.2",
      "pali": "Mahodakaṁ salilaṁ sīghasotaṁ;"
    },
    {
      "id": "snp2.8:4.3",
      "pali": "So vuyhamāno anusotagāmī,"
    },
    {
      "id": "snp2.8:4.4",
      "pali": "Kiṁ so pare sakkhati tārayetuṁ."
    },
    {
      "id": "snp2.8:5.1",
      "pali": "Tatheva dhammaṁ avibhāvayitvā,"
    },
    {
      "id": "snp2.8:5.2",
      "pali": "Bahussutānaṁ anisāmayatthaṁ;"
    },
    {
      "id": "snp2.8:5.3",
      "pali": "Sayaṁ ajānaṁ avitiṇṇakaṅkho,"
    },
    {
      "id": "snp2.8:5.4",
      "pali": "Kiṁ so pare sakkhati nijjhapetuṁ."
    },
    {
      "id": "snp2.8:6.1",
      "pali": "Yathāpi nāvaṁ daḷhamāruhitvā,"
    },
    {
      "id": "snp2.8:6.2",
      "pali": "Phiyena rittena samaṅgibhūto;"
    },
    {
      "id": "snp2.8:6.3",
      "pali": "So tāraye tattha bahūpi aññe,"
    },
    {
      "id": "snp2.8:6.4",
      "pali": "Tatrūpayaññū kusalo mutīmā."
    },
    {
      "id": "snp2.8:7.1",
      "pali": "Evampi yo vedagu bhāvitatto,"
    },
    {
      "id": "snp2.8:7.2",
      "pali": "Bahussuto hoti avedhadhammo;"
    },
    {
      "id": "snp2.8:7.3",
      "pali": "So kho pare nijjhapaye pajānaṁ,"
    },
    {
      "id": "snp2.8:7.4",
      "pali": "Sotāvadhānūpanisūpapanne."
    },
    {
      "id": "snp2.8:8.1",
      "pali": "Tasmā have sappurisaṁ bhajetha,"
    },
    {
      "id": "snp2.8:8.2",
      "pali": "Medhāvinañceva bahussutañca;"
    },
    {
      "id": "snp2.8:8.3",
      "pali": "Aññāya atthaṁ paṭipajjamāno,"
    },
    {
      "id": "snp2.8:8.4",
      "pali": "Viññātadhammo sa sukhaṁ labhethāti."
    },
    {
      "id": "snp2.8:8.5",
      "pali": "Nāvāsuttaṁ aṭṭhamaṁ."
    }
  ]
}
