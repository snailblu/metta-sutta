{
  "uid": "sn25.5",
  "title": "Samphassajasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.5:1.2",
      "pali": "“Cakkhusamphassajā, bhikkhave, vedanā aniccā vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.5:1.3",
      "pali": "sotasamphassajā vedanā …pe…"
    },
    {
      "id": "sn25.5:1.4",
      "pali": "ghānasamphassajā vedanā …pe…"
    },
    {
      "id": "sn25.5:1.5",
      "pali": "jivhāsamphassajā vedanā …pe…"
    },
    {
      "id": "sn25.5:1.6",
      "pali": "kāyasamphassajā vedanā …pe…"
    },
    {
      "id": "sn25.5:1.7",
      "pali": "manosamphassajā vedanā aniccā vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.5:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.5:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.5:1.10",
      "pali": "Pañcamaṁ."
    }
  ]
}
