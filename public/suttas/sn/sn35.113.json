{
  "uid": "sn35.113",
  "title": "Upassutisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.113:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā nātike viharati giñjakāvasathe."
    },
    {
      "id": "sn35.113:1.2",
      "pali": "Atha kho bhagavā rahogato paṭisallīno imaṁ dhammapariyāyaṁ abhāsi:"
    },
    {
      "id": "sn35.113:1.3",
      "pali": "“cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.113:1.4",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.113:1.5",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn35.113:1.6",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn35.113:1.7",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn35.113:1.8",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn35.113:1.9",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn35.113:1.10",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn35.113:1.11",
      "pali": "Jivhañca paṭicca rase ca uppajjati …pe…"
    },
    {
      "id": "sn35.113:1.12",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.113:1.13",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.113:1.14",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn35.113:1.15",
      "pali": "taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn35.113:1.16",
      "pali": "upādānapaccayā bhavo;"
    },
    {
      "id": "sn35.113:1.17",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn35.113:1.18",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn35.113:1.19",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn35.113:2.1",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.113:2.2",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.113:2.3",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.113:2.4",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.113:2.5",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn35.113:2.6",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn35.113:2.7",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn35.113:2.8",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hoti …pe…"
    },
    {
      "id": "sn35.113:2.9",
      "pali": "jivhañca paṭicca rase ca uppajjati …pe…"
    },
    {
      "id": "sn35.113:2.10",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn35.113:2.11",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn35.113:2.12",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn35.113:2.13",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn35.113:2.14",
      "pali": "upādānanirodhā …pe…"
    },
    {
      "id": "sn35.113:2.15",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn35.113:3.1",
      "pali": "Tena kho pana samayena aññataro bhikkhu bhagavato upassuti ṭhito hoti."
    },
    {
      "id": "sn35.113:3.2",
      "pali": "Addasā kho bhagavā taṁ bhikkhuṁ upassuti ṭhitaṁ."
    },
    {
      "id": "sn35.113:3.3",
      "pali": "Disvāna taṁ bhikkhuṁ etadavoca:"
    },
    {
      "id": "sn35.113:3.4",
      "pali": "“assosi no tvaṁ, bhikkhu, imaṁ dhammapariyāyan”ti?"
    },
    {
      "id": "sn35.113:3.5",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn35.113:3.6",
      "pali": "“Uggaṇhāhi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ."
    },
    {
      "id": "sn35.113:3.7",
      "pali": "Pariyāpuṇāhi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ."
    },
    {
      "id": "sn35.113:3.8",
      "pali": "Dhārehi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ."
    },
    {
      "id": "sn35.113:3.9",
      "pali": "Atthasañhitoyaṁ, bhikkhu, dhammapariyāyo ādibrahmacariyako”ti."
    },
    {
      "id": "sn35.113:3.10",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.113:3.11",
      "pali": "Yogakkhemivaggo paṭhamo."
    },
    {
      "id": "sn35.113:4.1",
      "pali": "Yogakkhemi upādāya,"
    },
    {
      "id": "sn35.113:4.2",
      "pali": "Dukkhaṁ loko ca seyyo ca;"
    },
    {
      "id": "sn35.113:4.3",
      "pali": "Saṁyojanaṁ upādānaṁ,"
    },
    {
      "id": "sn35.113:4.4",
      "pali": "Dve parijānaṁ upassutīti."
    }
  ]
}
