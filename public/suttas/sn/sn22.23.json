{
  "uid": "sn22.23",
  "title": "Pariññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.23:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.23:1.2",
      "pali": "“Pariññeyye ca, bhikkhave, dhamme desessāmi pariññañca."
    },
    {
      "id": "sn22.23:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.23:1.4",
      "pali": "Katame ca, bhikkhave, pariññeyyā dhammā?"
    },
    {
      "id": "sn22.23:1.5",
      "pali": "Rūpaṁ, bhikkhave, pariññeyyo dhammo, vedanā pariññeyyo dhammo, saññā pariññeyyo dhammo, saṅkhārā pariññeyyo dhammo, viññāṇaṁ pariññeyyo dhammo."
    },
    {
      "id": "sn22.23:1.6",
      "pali": "Ime vuccanti, bhikkhave, pariññeyyā dhammā."
    },
    {
      "id": "sn22.23:1.7",
      "pali": "Katamā ca, bhikkhave, pariññā?"
    },
    {
      "id": "sn22.23:1.8",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo."
    },
    {
      "id": "sn22.23:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, pariññā”ti."
    },
    {
      "id": "sn22.23:1.10",
      "pali": "Dutiyaṁ."
    }
  ]
}
