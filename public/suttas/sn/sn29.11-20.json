{
  "uid": "sn29.11-20",
  "title": "Aṇḍajadānūpakārasuttadasaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn29.11-20:1.1",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn29.11-20:1.2",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ nāgānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn29.11-20:2.1",
      "pali": "“Idha, bhikkhu, ekacco kāyena dvayakārī hoti, vācāya dvayakārī, manasā dvayakārī."
    },
    {
      "id": "sn29.11-20:2.2",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn29.11-20:2.3",
      "pali": "‘aṇḍajā nāgā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn29.11-20:2.4",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn29.11-20:2.5",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ nāgānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn29.11-20:2.6",
      "pali": "So annaṁ deti."
    },
    {
      "id": "sn29.11-20:2.7",
      "pali": "So kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ nāgānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn29.11-20:2.8",
      "pali": "Ayaṁ kho, bhikkhu, hetu …pe… upapajjatīti …pe…"
    },
    {
      "id": "sn29.11-20:2.9",
      "pali": "so pānaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.10",
      "pali": "vatthaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.11",
      "pali": "yānaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.12",
      "pali": "mālaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.13",
      "pali": "gandhaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.14",
      "pali": "vilepanaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.15",
      "pali": "seyyaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.16",
      "pali": "āvasathaṁ deti …pe…"
    },
    {
      "id": "sn29.11-20:2.17",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn29.11-20:2.18",
      "pali": "So kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ nāgānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn29.11-20:2.19",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā aṇḍajānaṁ nāgānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn29.11-20:2.20",
      "pali": "Vīsatimaṁ."
    }
  ]
}
