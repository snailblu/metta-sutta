{
  "uid": "sn14.25",
  "title": "Pañcasikkhāpadasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.25:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.25:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.25:1.3",
      "pali": "Pāṇātipātino pāṇātipātīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:1.4",
      "pali": "adinnādāyino adinnādāyīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:1.5",
      "pali": "kāmesumicchācārino kāmesumicchācārīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:1.6",
      "pali": "musāvādino musāvādīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:1.7",
      "pali": "surāmerayamajjappamādaṭṭhāyino surāmerayamajjappamādaṭṭhāyīhi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.25:2.1",
      "pali": "Pāṇātipātā paṭiviratā pāṇātipātā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:2.2",
      "pali": "adinnādānā paṭiviratā adinnādānā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:2.3",
      "pali": "kāmesumicchācārā paṭiviratā kāmesumicchācārā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:2.4",
      "pali": "musāvādā paṭiviratā musāvādā paṭiviratehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.25:2.5",
      "pali": "surāmerayamajjappamādaṭṭhānā paṭiviratā surāmerayamajjappamādaṭṭhānā paṭiviratehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.25:2.6",
      "pali": "Tatiyaṁ."
    }
  ]
}
