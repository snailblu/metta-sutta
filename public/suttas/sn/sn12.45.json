{
  "uid": "sn12.45",
  "title": "Ñātikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.45:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn12.45:1.2",
      "pali": "ekaṁ samayaṁ bhagavā ñātike viharati giñjakāvasathe."
    },
    {
      "id": "sn12.45:1.3",
      "pali": "Atha kho bhagavā rahogato paṭisallāno imaṁ dhammapariyāyaṁ abhāsi:"
    },
    {
      "id": "sn12.45:2.1",
      "pali": "“Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.45:2.2",
      "pali": "Phassapaccayā vedanā,"
    },
    {
      "id": "sn12.45:2.3",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn12.45:2.4",
      "pali": "taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "sn12.45:2.5",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.45:3.1",
      "pali": "Sotañca paṭicca sadde ca …pe…"
    },
    {
      "id": "sn12.45:3.2",
      "pali": "ghānañca paṭicca gandhe ca …"
    },
    {
      "id": "sn12.45:3.3",
      "pali": "jivhañca paṭicca rase ca …"
    },
    {
      "id": "sn12.45:3.4",
      "pali": "kāyañca paṭicca phoṭṭhabbe ca …"
    },
    {
      "id": "sn12.45:3.5",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.45:3.6",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.45:3.7",
      "pali": "vedanāpaccayā taṇhā;"
    },
    {
      "id": "sn12.45:3.8",
      "pali": "taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "sn12.45:3.9",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.45:4.1",
      "pali": "Cakkhuñca paṭicca rūpe ca uppajjati cakkhuviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.45:4.2",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.45:4.3",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.45:4.4",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.45:4.5",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn12.45:4.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.45:5.1",
      "pali": "Sotañca paṭicca sadde ca …pe…"
    },
    {
      "id": "sn12.45:5.2",
      "pali": "manañca paṭicca dhamme ca uppajjati manoviññāṇaṁ. Tiṇṇaṁ saṅgati phasso."
    },
    {
      "id": "sn12.45:5.3",
      "pali": "Phassapaccayā vedanā;"
    },
    {
      "id": "sn12.45:5.4",
      "pali": "vedanāpaccayā taṇhā."
    },
    {
      "id": "sn12.45:5.5",
      "pali": "Tassāyeva taṇhāya asesavirāganirodhā upādānanirodho;"
    },
    {
      "id": "sn12.45:5.6",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn12.45:5.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.45:6.1",
      "pali": "Tena kho pana samayena aññataro bhikkhu bhagavato upassuti ṭhito hoti."
    },
    {
      "id": "sn12.45:6.2",
      "pali": "Addasā kho bhagavā taṁ bhikkhuṁ upassuti ṭhitaṁ."
    },
    {
      "id": "sn12.45:6.3",
      "pali": "Disvāna taṁ bhikkhuṁ etadavoca:"
    },
    {
      "id": "sn12.45:6.4",
      "pali": "“assosi no tvaṁ, bhikkhu, imaṁ dhammapariyāyan”ti?"
    },
    {
      "id": "sn12.45:6.5",
      "pali": "“Evaṁ, bhante”ti."
    },
    {
      "id": "sn12.45:6.6",
      "pali": "“Uggaṇhāhi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ;"
    },
    {
      "id": "sn12.45:6.7",
      "pali": "pariyāpuṇāhi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ;"
    },
    {
      "id": "sn12.45:6.8",
      "pali": "dhārehi tvaṁ, bhikkhu, imaṁ dhammapariyāyaṁ."
    },
    {
      "id": "sn12.45:6.9",
      "pali": "Atthasaṁhito ayaṁ, bhikkhu, dhammapariyāyo ādibrahmacariyako”ti."
    },
    {
      "id": "sn12.45:6.10",
      "pali": "Pañcamaṁ."
    }
  ]
}
