{
  "uid": "sn22.41",
  "title": "Tatiyaanudhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.41:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.41:1.2",
      "pali": "“Dhammānudhammappaṭipannassa, bhikkhave, bhikkhuno ayamanudhammo hoti yaṁ rūpe dukkhānupassī vihareyya …pe…"
    },
    {
      "id": "sn22.41:1.3",
      "pali": "‘parimuccati dukkhasmā’ti vadāmī”ti."
    },
    {
      "id": "sn22.41:1.4",
      "pali": "Navamaṁ."
    }
  ]
}
