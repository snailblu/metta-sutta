{
  "uid": "sn12.83-92",
  "title": "sn12.83-92",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.83:1.1",
      "pali": "“Jātiṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.84:1.1",
      "pali": "“Bhavaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.85:1.1",
      "pali": "“Upādānaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.86:1.1",
      "pali": "“Taṇhaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.87:1.1",
      "pali": "“Vedanaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.88:1.1",
      "pali": "“Phassaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.89:1.1",
      "pali": "“Saḷāyatanaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.90:1.1",
      "pali": "“Nāmarūpaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.91:1.1",
      "pali": "“Viññāṇaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ …pe…."
    },
    {
      "id": "sn12.92:1.1",
      "pali": "“Saṅkhāre, bhikkhave, ajānatā apassatā yathābhūtaṁ saṅkhāresu yathābhūtaṁ ñāṇāya satthā pariyesitabbo;"
    },
    {
      "id": "sn12.92:1.2",
      "pali": "saṅkhārasamudayaṁ ajānatā apassatā yathābhūtaṁ saṅkhārasamudaye yathābhūtaṁ ñāṇāya satthā pariyesitabbo;"
    },
    {
      "id": "sn12.92:1.3",
      "pali": "saṅkhāranirodhaṁ ajānatā apassatā yathābhūtaṁ saṅkhāranirodhe yathābhūtaṁ ñāṇāya satthā pariyesitabbo;"
    },
    {
      "id": "sn12.92:1.4",
      "pali": "saṅkhāranirodhagāminiṁ paṭipadaṁ ajānatā apassatā yathābhūtaṁ saṅkhāranirodhagāminiyā paṭipadāya yathābhūtaṁ ñāṇāya satthā pariyesitabbo”ti."
    },
    {
      "id": "sn12.92:1.5",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn12.92:1.6",
      "pali": "(Sabbesaṁ catusaccikaṁ kātabbaṁ.)"
    }
  ]
}
