{
  "uid": "sn7.11",
  "title": "Kasibhāradvājasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.11:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn7.11:1.2",
      "pali": "ekaṁ samayaṁ bhagavā magadhesu viharati dakkhiṇāgirismiṁ ekanāḷāyaṁ brāhmaṇagāme."
    },
    {
      "id": "sn7.11:1.3",
      "pali": "Tena kho pana samayena kasibhāradvājassa brāhmaṇassa pañcamattāni naṅgalasatāni payuttāni honti vappakāle."
    },
    {
      "id": "sn7.11:1.4",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya yena kasibhāradvājassa brāhmaṇassa kammanto tenupasaṅkami."
    },
    {
      "id": "sn7.11:2.1",
      "pali": "Tena kho pana samayena kasibhāradvājassa brāhmaṇassa parivesanā vattati."
    },
    {
      "id": "sn7.11:2.2",
      "pali": "Atha kho bhagavā yena parivesanā tenupasaṅkami; upasaṅkamitvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn7.11:2.3",
      "pali": "Addasā kho kasibhāradvājo brāhmaṇo bhagavantaṁ piṇḍāya ṭhitaṁ."
    },
    {
      "id": "sn7.11:2.4",
      "pali": "Disvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.11:2.5",
      "pali": "“ahaṁ kho, samaṇa, kasāmi ca vapāmi ca, kasitvā ca vapitvā ca bhuñjāmi."
    },
    {
      "id": "sn7.11:2.6",
      "pali": "Tvampi, samaṇa, kasassu ca vapassu ca, kasitvā ca vapitvā ca bhuñjassū”ti."
    },
    {
      "id": "sn7.11:2.7",
      "pali": "“Ahampi kho, brāhmaṇa, kasāmi ca vapāmi ca, kasitvā ca vapitvā ca bhuñjāmī”ti."
    },
    {
      "id": "sn7.11:2.8",
      "pali": "“Na kho mayaṁ passāma bhoto gotamassa yugaṁ vā naṅgalaṁ vā phālaṁ vā pācanaṁ vā balībadde vā, atha ca pana bhavaṁ gotamo evamāha:"
    },
    {
      "id": "sn7.11:2.9",
      "pali": "‘ahampi kho, brāhmaṇa, kasāmi ca vapāmi ca, kasitvā ca vapitvā ca bhuñjāmī’”ti."
    },
    {
      "id": "sn7.11:2.10",
      "pali": "Atha kho kasibhāradvājo brāhmaṇo bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.11:3.1",
      "pali": "“Kassako paṭijānāsi,"
    },
    {
      "id": "sn7.11:3.2",
      "pali": "na ca passāmi te kasiṁ;"
    },
    {
      "id": "sn7.11:3.3",
      "pali": "Kassako pucchito brūhi,"
    },
    {
      "id": "sn7.11:3.4",
      "pali": "kathaṁ jānemu taṁ kasin”ti."
    },
    {
      "id": "sn7.11:4.1",
      "pali": "“Saddhā bījaṁ tapo vuṭṭhi,"
    },
    {
      "id": "sn7.11:4.2",
      "pali": "paññā me yuganaṅgalaṁ;"
    },
    {
      "id": "sn7.11:4.3",
      "pali": "Hirī īsā mano yottaṁ,"
    },
    {
      "id": "sn7.11:4.4",
      "pali": "sati me phālapācanaṁ."
    },
    {
      "id": "sn7.11:5.1",
      "pali": "Kāyagutto vacīgutto,"
    },
    {
      "id": "sn7.11:5.2",
      "pali": "āhāre udare yato;"
    },
    {
      "id": "sn7.11:5.3",
      "pali": "Saccaṁ karomi niddānaṁ,"
    },
    {
      "id": "sn7.11:5.4",
      "pali": "soraccaṁ me pamocanaṁ."
    },
    {
      "id": "sn7.11:6.1",
      "pali": "Vīriyaṁ me dhuradhorayhaṁ,"
    },
    {
      "id": "sn7.11:6.2",
      "pali": "yogakkhemādhivāhanaṁ;"
    },
    {
      "id": "sn7.11:6.3",
      "pali": "Gacchati anivattantaṁ,"
    },
    {
      "id": "sn7.11:6.4",
      "pali": "yattha gantvā na socati."
    },
    {
      "id": "sn7.11:7.1",
      "pali": "Evamesā kasī kaṭṭhā,"
    },
    {
      "id": "sn7.11:7.2",
      "pali": "sā hoti amatapphalā;"
    },
    {
      "id": "sn7.11:7.3",
      "pali": "Etaṁ kasiṁ kasitvāna,"
    },
    {
      "id": "sn7.11:7.4",
      "pali": "sabbadukkhā pamuccatī”ti."
    },
    {
      "id": "sn7.11:8.1",
      "pali": "“Bhuñjatu bhavaṁ gotamo."
    },
    {
      "id": "sn7.11:8.2",
      "pali": "Kassako bhavaṁ."
    },
    {
      "id": "sn7.11:8.3",
      "pali": "Yañhi bhavaṁ gotamo amatapphalampi kasiṁ kasatī”ti."
    },
    {
      "id": "sn7.11:9.1",
      "pali": "“Gāthābhigītaṁ me abhojaneyyaṁ,"
    },
    {
      "id": "sn7.11:9.2",
      "pali": "Sampassataṁ brāhmaṇa nesa dhammo;"
    },
    {
      "id": "sn7.11:9.3",
      "pali": "Gāthābhigītaṁ panudanti buddhā,"
    },
    {
      "id": "sn7.11:9.4",
      "pali": "Dhamme sati brāhmaṇa vuttiresā."
    },
    {
      "id": "sn7.11:10.1",
      "pali": "Aññena ca kevalinaṁ mahesiṁ,"
    },
    {
      "id": "sn7.11:10.2",
      "pali": "Khīṇāsavaṁ kukkuccavūpasantaṁ;"
    },
    {
      "id": "sn7.11:10.3",
      "pali": "Annena pānena upaṭṭhahassu,"
    },
    {
      "id": "sn7.11:10.4",
      "pali": "Khettañhi taṁ puññapekkhassa hotī”ti."
    },
    {
      "id": "sn7.11:11.1",
      "pali": "Evaṁ vutte, kasibhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.11:11.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.11:11.3",
      "pali": "ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
