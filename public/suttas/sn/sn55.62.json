{
  "uid": "sn55.62",
  "title": "Mahāpaññāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.62:1.1",
      "pali": "“Cattārome, bhikkhave, dhammā bhāvitā bahulīkatā mahāpaññatāya saṁvattanti."
    },
    {
      "id": "sn55.62:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn55.62:1.3",
      "pali": "Sappurisasaṁsevo, saddhammassavanaṁ, yonisomanasikāro, dhammānudhammappaṭipatti—"
    },
    {
      "id": "sn55.62:1.4",
      "pali": "ime kho, bhikkhave, cattāro dhammā bhāvitā bahulīkatā mahāpaññatāya saṁvattantī”ti."
    },
    {
      "id": "sn55.62:1.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
