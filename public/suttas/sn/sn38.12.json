{
  "uid": "sn38.12",
  "title": "Upādānapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.12:1.1",
      "pali": "“‘Upādānaṁ, upādānan’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.12:1.2",
      "pali": "Katamaṁ nu kho, āvuso, upādānan”ti?"
    },
    {
      "id": "sn38.12:1.3",
      "pali": "“Cattārimāni, āvuso, upādānāni."
    },
    {
      "id": "sn38.12:1.4",
      "pali": "Kāmupādānaṁ, diṭṭhupādānaṁ sīlabbatupādānaṁ, attavādupādānaṁ—"
    },
    {
      "id": "sn38.12:1.5",
      "pali": "imāni kho, āvuso, cattāri upādānānī”ti."
    },
    {
      "id": "sn38.12:1.6",
      "pali": "“Atthi panāvuso, maggo atthi paṭipadā, etesaṁ upādānānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.12:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā, etesaṁ upādānānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.12:1.8",
      "pali": "“Katamo panāvuso, maggo katamā paṭipadā, etesaṁ upādānānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.12:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo, etesaṁ upādānānaṁ pahānāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.12:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.12:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etesaṁ upādānānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.12:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etesaṁ upādānānaṁ pahānāya."
    },
    {
      "id": "sn38.12:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.12:1.14",
      "pali": "Dvādasamaṁ."
    }
  ]
}
