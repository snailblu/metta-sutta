{
  "uid": "sn22.10",
  "title": "Kālattayadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.10:1.2",
      "pali": "“Rūpaṁ, bhikkhave, dukkhaṁ atītānāgataṁ;"
    },
    {
      "id": "sn22.10:1.3",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.10:1.4",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ rūpasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.10:1.5",
      "pali": "anāgataṁ rūpaṁ nābhinandati;"
    },
    {
      "id": "sn22.10:1.6",
      "pali": "paccuppannassa rūpassa nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn22.10:1.7",
      "pali": "Vedanā dukkhā …"
    },
    {
      "id": "sn22.10:1.8",
      "pali": "saññā dukkhā …"
    },
    {
      "id": "sn22.10:1.9",
      "pali": "saṅkhārā dukkhā …"
    },
    {
      "id": "sn22.10:1.10",
      "pali": "viññāṇaṁ dukkhaṁ atītānāgataṁ;"
    },
    {
      "id": "sn22.10:1.11",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn22.10:1.12",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ viññāṇasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn22.10:1.13",
      "pali": "anāgataṁ viññāṇaṁ nābhinandati;"
    },
    {
      "id": "sn22.10:1.14",
      "pali": "paccuppannassa viññāṇassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn22.10:1.15",
      "pali": "Dasamaṁ."
    }
  ]
}
