{
  "uid": "sn43.5",
  "title": "Satipaṭṭhānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.5:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.5:1.2",
      "pali": "Cattāro satipaṭṭhānā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.5:1.3",
      "pali": "Pañcamaṁ."
    }
  ]
}
