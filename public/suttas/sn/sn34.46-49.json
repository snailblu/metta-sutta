{
  "uid": "sn34.46-49",
  "title": "sn34.46-49",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.46:1.1",
      "pali": "Sāvatthinidānaṁ …"
    },
    {
      "id": "sn34.46:1.2",
      "pali": "“samādhismiṁ gocarakusalo hoti, na samādhismiṁ abhinīhārakusalo …"
    },
    {
      "id": "sn34.46:1.3",
      "pali": "samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ gocarakusalo …"
    },
    {
      "id": "sn34.46:1.4",
      "pali": "neva samādhismiṁ gocarakusalo hoti, na ca samādhismiṁ abhinīhārakusalo …"
    },
    {
      "id": "sn34.46:1.5",
      "pali": "samādhismiṁ gocarakusalo ca hoti, samādhismiṁ abhinīhārakusalo ca …"
    },
    {
      "id": "sn34.46:1.6",
      "pali": "seyyathāpi, bhikkhave, gavā khīraṁ, khīramhā dadhi, dadhimhā navanītaṁ, navanītamhā sappi, sappimhā sappimaṇḍo tatra aggamakkhāyati;"
    },
    {
      "id": "sn34.46:1.7",
      "pali": "evameva kho, bhikkhave, yvāyaṁ jhāyī samādhismiṁ gocarakusalo ca hoti samādhismiṁ abhinīhārakusalo ca ayaṁ imesaṁ catunnaṁ jhāyīnaṁ …pe…"
    },
    {
      "id": "sn34.46:1.8",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.46:1.9",
      "pali": "Chacattālīsamaṁ."
    },
    {
      "id": "sn34.47:1.1",
      "pali": "“Samādhismiṁ gocarakusalo hoti, na samādhismiṁ sakkaccakārī …pe…."
    },
    {
      "id": "sn34.47:1.2",
      "pali": "Vitthāretabbaṁ."
    },
    {
      "id": "sn34.47:1.3",
      "pali": "Sattacattālīsamaṁ."
    },
    {
      "id": "sn34.48:1.1",
      "pali": "“Samādhismiṁ gocarakusalo hoti, na samādhismiṁ sātaccakārī …pe…."
    },
    {
      "id": "sn34.48:1.2",
      "pali": "Aṭṭhacattālīsamaṁ."
    },
    {
      "id": "sn34.49:1.1",
      "pali": "“Samādhismiṁ gocarakusalo hoti, na samādhismiṁ sappāyakārī …pe…."
    },
    {
      "id": "sn34.49:1.2",
      "pali": "Ekūnapaññāsamaṁ."
    },
    {
      "id": "sn34.49:1.3",
      "pali": "(Gocaramūlakaṁ.)"
    }
  ]
}
