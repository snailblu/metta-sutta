{
  "uid": "sn25.8",
  "title": "Rūpataṇhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.8:1.2",
      "pali": "“Rūpataṇhā, bhikkhave, aniccā vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.8:1.3",
      "pali": "saddataṇhā …"
    },
    {
      "id": "sn25.8:1.4",
      "pali": "gandhataṇhā …"
    },
    {
      "id": "sn25.8:1.5",
      "pali": "rasataṇhā …"
    },
    {
      "id": "sn25.8:1.6",
      "pali": "phoṭṭhabbataṇhā …"
    },
    {
      "id": "sn25.8:1.7",
      "pali": "dhammataṇhā aniccā vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.8:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.8:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.8:1.10",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
