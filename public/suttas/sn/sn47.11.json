{
  "uid": "sn47.11",
  "title": "Mahāpurisasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.11:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn47.11:1.2",
      "pali": "Atha kho āyasmā sāriputto yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā sāriputto bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn47.11:1.3",
      "pali": "“‘mahāpuriso, mahāpuriso’ti, bhante, vuccati."
    },
    {
      "id": "sn47.11:1.4",
      "pali": "Kittāvatā nu kho, bhante, mahāpuriso hotī”ti?"
    },
    {
      "id": "sn47.11:1.5",
      "pali": "“Vimuttacittattā khvāhaṁ, sāriputta, ‘mahāpuriso’ti vadāmi."
    },
    {
      "id": "sn47.11:1.6",
      "pali": "Avimuttacittattā ‘no mahāpuriso’ti vadāmi."
    },
    {
      "id": "sn47.11:2.1",
      "pali": "Kathañca, sāriputta, vimuttacitto hoti?"
    },
    {
      "id": "sn47.11:2.2",
      "pali": "Idha, sāriputta, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.11:2.3",
      "pali": "Tassa kāye kāyānupassino viharato cittaṁ virajjati, vimuccati anupādāya āsavehi."
    },
    {
      "id": "sn47.11:2.4",
      "pali": "Vedanāsu …pe…"
    },
    {
      "id": "sn47.11:2.5",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.11:2.6",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.11:2.7",
      "pali": "Tassa dhammesu dhammānupassino viharato cittaṁ virajjati, vimuccati anupādāya āsavehi."
    },
    {
      "id": "sn47.11:2.8",
      "pali": "Evaṁ kho, sāriputta, vimuttacitto hoti."
    },
    {
      "id": "sn47.11:2.9",
      "pali": "Vimuttacittattā khvāhaṁ, sāriputta, ‘mahāpuriso’ti vadāmi."
    },
    {
      "id": "sn47.11:2.10",
      "pali": "Avimuttacittattā ‘no mahāpuriso’ti vadāmī”ti."
    },
    {
      "id": "sn47.11:2.11",
      "pali": "Paṭhamaṁ."
    }
  ]
}
