{
  "uid": "sn1.27",
  "title": "Sarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.27:1.1",
      "pali": "“Kuto sarā nivattanti,"
    },
    {
      "id": "sn1.27:1.2",
      "pali": "kattha vaṭṭaṁ na vattati;"
    },
    {
      "id": "sn1.27:1.3",
      "pali": "Kattha nāmañca rūpañca,"
    },
    {
      "id": "sn1.27:1.4",
      "pali": "asesaṁ uparujjhatī”ti."
    },
    {
      "id": "sn1.27:2.1",
      "pali": "“Yattha āpo ca pathavī,"
    },
    {
      "id": "sn1.27:2.2",
      "pali": "tejo vāyo na gādhati;"
    },
    {
      "id": "sn1.27:2.3",
      "pali": "Ato sarā nivattanti,"
    },
    {
      "id": "sn1.27:2.4",
      "pali": "ettha vaṭṭaṁ na vattati;"
    },
    {
      "id": "sn1.27:2.5",
      "pali": "Ettha nāmañca rūpañca,"
    },
    {
      "id": "sn1.27:2.6",
      "pali": "asesaṁ uparujjhatī”ti."
    }
  ]
}
