{
  "uid": "sn22.76",
  "title": "Arahantasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.76:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.76:1.2",
      "pali": "“Rūpaṁ, bhikkhave, aniccaṁ."
    },
    {
      "id": "sn22.76:1.3",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.76:1.4",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.76:1.5",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.76:1.6",
      "pali": "Vedanā …"
    },
    {
      "id": "sn22.76:1.7",
      "pali": "saññā …"
    },
    {
      "id": "sn22.76:1.8",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.76:1.9",
      "pali": "viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn22.76:1.10",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.76:1.11",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.76:1.12",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.76:2.1",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako rūpasmimpi nibbindati, vedanāyapi … saññāyapi … saṅkhāresupi … viññāṇasmimpi nibbindati."
    },
    {
      "id": "sn22.76:2.2",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati. Vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn22.76:2.3",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānāti."
    },
    {
      "id": "sn22.76:2.4",
      "pali": "Yāvatā, bhikkhave, sattāvāsā, yāvatā bhavaggaṁ, ete aggā, ete seṭṭhā lokasmiṁ yadidaṁ arahanto”ti."
    },
    {
      "id": "sn22.76:3.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn22.76:3.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn22.76:4.1",
      "pali": "“Sukhino vata arahanto,"
    },
    {
      "id": "sn22.76:4.2",
      "pali": "taṇhā tesaṁ na vijjati;"
    },
    {
      "id": "sn22.76:4.3",
      "pali": "Asmimāno samucchinno,"
    },
    {
      "id": "sn22.76:4.4",
      "pali": "mohajālaṁ padālitaṁ."
    },
    {
      "id": "sn22.76:5.1",
      "pali": "Anejaṁ te anuppattā,"
    },
    {
      "id": "sn22.76:5.2",
      "pali": "cittaṁ tesaṁ anāvilaṁ;"
    },
    {
      "id": "sn22.76:5.3",
      "pali": "Loke anupalittā te,"
    },
    {
      "id": "sn22.76:5.4",
      "pali": "brahmabhūtā anāsavā."
    },
    {
      "id": "sn22.76:6.1",
      "pali": "Pañcakkhandhe pariññāya,"
    },
    {
      "id": "sn22.76:6.2",
      "pali": "satta saddhammagocarā;"
    },
    {
      "id": "sn22.76:6.3",
      "pali": "Pasaṁsiyā sappurisā,"
    },
    {
      "id": "sn22.76:6.4",
      "pali": "puttā buddhassa orasā."
    },
    {
      "id": "sn22.76:7.1",
      "pali": "Sattaratanasampannā,"
    },
    {
      "id": "sn22.76:7.2",
      "pali": "Tīsu sikkhāsu sikkhitā;"
    },
    {
      "id": "sn22.76:7.3",
      "pali": "Anuvicaranti mahāvīrā,"
    },
    {
      "id": "sn22.76:7.4",
      "pali": "Pahīnabhayabheravā."
    },
    {
      "id": "sn22.76:8.1",
      "pali": "Dasahaṅgehi sampannā,"
    },
    {
      "id": "sn22.76:8.2",
      "pali": "mahānāgā samāhitā;"
    },
    {
      "id": "sn22.76:8.3",
      "pali": "Ete kho seṭṭhā lokasmiṁ,"
    },
    {
      "id": "sn22.76:8.4",
      "pali": "taṇhā tesaṁ na vijjati."
    },
    {
      "id": "sn22.76:9.1",
      "pali": "Asekhañāṇamuppannaṁ,"
    },
    {
      "id": "sn22.76:9.2",
      "pali": "antimoyaṁ samussayo;"
    },
    {
      "id": "sn22.76:9.3",
      "pali": "Yo sāro brahmacariyassa,"
    },
    {
      "id": "sn22.76:9.4",
      "pali": "tasmiṁ aparapaccayā."
    },
    {
      "id": "sn22.76:10.1",
      "pali": "Vidhāsu na vikampanti,"
    },
    {
      "id": "sn22.76:10.2",
      "pali": "vippamuttā punabbhavā;"
    },
    {
      "id": "sn22.76:10.3",
      "pali": "Dantabhūmimanuppattā,"
    },
    {
      "id": "sn22.76:10.4",
      "pali": "te loke vijitāvino."
    },
    {
      "id": "sn22.76:11.1",
      "pali": "Uddhaṁ tiriyaṁ apācīnaṁ,"
    },
    {
      "id": "sn22.76:11.2",
      "pali": "nandī tesaṁ na vijjati;"
    },
    {
      "id": "sn22.76:11.3",
      "pali": "Nadanti te sīhanādaṁ,"
    },
    {
      "id": "sn22.76:11.4",
      "pali": "buddhā loke anuttarā”ti."
    },
    {
      "id": "sn22.76:11.5",
      "pali": "Catutthaṁ."
    }
  ]
}
