{
  "uid": "sn48.8",
  "title": "Daṭṭhabbasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.8:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.8:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.8:1.3",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ."
    },
    {
      "id": "sn48.8:1.4",
      "pali": "Kattha ca, bhikkhave, saddhindriyaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "sn48.8:1.5",
      "pali": "Catūsu sotāpattiyaṅgesu—"
    },
    {
      "id": "sn48.8:1.6",
      "pali": "ettha saddhindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn48.8:1.7",
      "pali": "Kattha ca, bhikkhave, vīriyindriyaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "sn48.8:1.8",
      "pali": "Catūsu sammappadhānesu—"
    },
    {
      "id": "sn48.8:1.9",
      "pali": "ettha vīriyindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn48.8:1.10",
      "pali": "Kattha ca, bhikkhave, satindriyaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "sn48.8:1.11",
      "pali": "Catūsu satipaṭṭhānesu—"
    },
    {
      "id": "sn48.8:1.12",
      "pali": "ettha satindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn48.8:1.13",
      "pali": "Kattha ca, bhikkhave, samādhindriyaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "sn48.8:1.14",
      "pali": "Catūsu jhānesu—"
    },
    {
      "id": "sn48.8:1.15",
      "pali": "ettha samādhindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn48.8:1.16",
      "pali": "Kattha ca, bhikkhave, paññindriyaṁ daṭṭhabbaṁ?"
    },
    {
      "id": "sn48.8:1.17",
      "pali": "Catūsu ariyasaccesu—"
    },
    {
      "id": "sn48.8:1.18",
      "pali": "ettha paññindriyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn48.8:1.19",
      "pali": "Imāni kho, bhikkhave, pañcindriyānī”ti."
    },
    {
      "id": "sn48.8:1.20",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
