{
  "uid": "sn36.5",
  "title": "Daṭṭhabbasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.5:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn36.5:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn36.5:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā."
    },
    {
      "id": "sn36.5:1.4",
      "pali": "Sukhā, bhikkhave, vedanā dukkhato daṭṭhabbā, dukkhā vedanā sallato daṭṭhabbā, adukkhamasukhā vedanā aniccato daṭṭhabbā."
    },
    {
      "id": "sn36.5:1.5",
      "pali": "Yato kho, bhikkhave, bhikkhuno sukhā vedanā dukkhato diṭṭhā hoti, dukkhā vedanā sallato diṭṭhā hoti, adukkhamasukhā vedanā aniccato diṭṭhā hoti—"
    },
    {
      "id": "sn36.5:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, ‘bhikkhu sammaddaso acchecchi taṇhaṁ, vivattayi saṁyojanaṁ, sammā mānābhisamayā antamakāsi dukkhassā’ti."
    },
    {
      "id": "sn36.5:2.1",
      "pali": "Yo sukhaṁ dukkhato adda,"
    },
    {
      "id": "sn36.5:2.2",
      "pali": "dukkhamaddakkhi sallato;"
    },
    {
      "id": "sn36.5:2.3",
      "pali": "Adukkhamasukhaṁ santaṁ,"
    },
    {
      "id": "sn36.5:2.4",
      "pali": "addakkhi naṁ aniccato."
    },
    {
      "id": "sn36.5:3.1",
      "pali": "Sa ve sammaddaso bhikkhu,"
    },
    {
      "id": "sn36.5:3.2",
      "pali": "parijānāti vedanā;"
    },
    {
      "id": "sn36.5:3.3",
      "pali": "So vedanā pariññāya,"
    },
    {
      "id": "sn36.5:3.4",
      "pali": "diṭṭhe dhamme anāsavo;"
    },
    {
      "id": "sn36.5:3.5",
      "pali": "Kāyassa bhedā dhammaṭṭho,"
    },
    {
      "id": "sn36.5:3.6",
      "pali": "saṅkhyaṁ nopeti vedagū”ti."
    },
    {
      "id": "sn36.5:3.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
