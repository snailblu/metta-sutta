{
  "uid": "sn2.4",
  "title": "Māgadhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.4:1.2",
      "pali": "Ekamantaṁ ṭhito kho māgadho devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.4:2.1",
      "pali": "“Kati lokasmiṁ pajjotā,"
    },
    {
      "id": "sn2.4:2.2",
      "pali": "yehi loko pakāsati;"
    },
    {
      "id": "sn2.4:2.3",
      "pali": "Bhavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "sn2.4:2.4",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "sn2.4:3.1",
      "pali": "“Cattāro loke pajjotā,"
    },
    {
      "id": "sn2.4:3.2",
      "pali": "pañcamettha na vijjati;"
    },
    {
      "id": "sn2.4:3.3",
      "pali": "Divā tapati ādicco,"
    },
    {
      "id": "sn2.4:3.4",
      "pali": "rattimābhāti candimā."
    },
    {
      "id": "sn2.4:4.1",
      "pali": "Atha aggi divārattiṁ,"
    },
    {
      "id": "sn2.4:4.2",
      "pali": "tattha tattha pakāsati;"
    },
    {
      "id": "sn2.4:4.3",
      "pali": "Sambuddho tapataṁ seṭṭho,"
    },
    {
      "id": "sn2.4:4.4",
      "pali": "esā ābhā anuttarā”ti."
    }
  ]
}
