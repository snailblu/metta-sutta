{
  "uid": "sn45.179",
  "title": "Orambhāgiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.179:1.1",
      "pali": "“Pañcimāni, bhikkhave, orambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.179:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn45.179:1.3",
      "pali": "Sakkāyadiṭṭhi, vicikicchā, sīlabbataparāmāso, kāmacchando, byāpādo—"
    },
    {
      "id": "sn45.179:1.4",
      "pali": "imāni kho, bhikkhave, pañcorambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn45.179:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ orambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.179:1.6",
      "pali": "Navamaṁ."
    }
  ]
}
