{
  "uid": "sn22.16",
  "title": "Yaṁdukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.16:1.2",
      "pali": "“Rūpaṁ, bhikkhave, dukkhaṁ."
    },
    {
      "id": "sn22.16:1.3",
      "pali": "Yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.16:1.4",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.16:1.5",
      "pali": "Vedanā dukkhā …"
    },
    {
      "id": "sn22.16:1.6",
      "pali": "saññā dukkhā …"
    },
    {
      "id": "sn22.16:1.7",
      "pali": "saṅkhārā dukkhā …"
    },
    {
      "id": "sn22.16:1.8",
      "pali": "viññāṇaṁ dukkhaṁ."
    },
    {
      "id": "sn22.16:1.9",
      "pali": "Yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.16:1.10",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.16:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.16:1.12",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.16:1.13",
      "pali": "Pañcamaṁ."
    }
  ]
}
