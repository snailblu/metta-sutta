{
  "uid": "sn46.20",
  "title": "Nibbidāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.20:1.1",
      "pali": "“Sattime, bhikkhave, bojjhaṅgā bhāvitā bahulīkatā ekantanibbidāya virāgāya nirodhāya upasamāya abhiññāya sambodhāya nibbānāya saṁvattanti."
    },
    {
      "id": "sn46.20:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.20:1.3",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.20:1.4",
      "pali": "ime kho, bhikkhave, satta bojjhaṅgā bhāvitā bahulīkatā ekantanibbidāya virāgāya nirodhāya upasamāya abhiññāya sambodhāya nibbānāya saṁvattantī”ti."
    },
    {
      "id": "sn46.20:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn46.20:1.6",
      "pali": "Gilānavaggo dutiyo."
    },
    {
      "id": "sn46.20:2.1",
      "pali": "Pāṇā sūriyūpamā dve,"
    },
    {
      "id": "sn46.20:2.2",
      "pali": "gilānā apare tayo;"
    },
    {
      "id": "sn46.20:2.3",
      "pali": "Pāraṅgāmī viraddho ca,"
    },
    {
      "id": "sn46.20:2.4",
      "pali": "ariyo nibbidāya cāti."
    }
  ]
}
