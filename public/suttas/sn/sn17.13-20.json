{
  "uid": "sn17.13-20",
  "title": "Suvaṇṇanikkhasuttādiaṭṭhaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.13-20:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.13-20:1.2",
      "pali": "“Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "sn17.13-20:1.3",
      "pali": "‘na cāyamāyasmā suvaṇṇanikkhassāpi hetu …pe…"
    },
    {
      "id": "sn17.13-20:1.4",
      "pali": "suvaṇṇanikkhasatassāpi hetu …"
    },
    {
      "id": "sn17.13-20:1.5",
      "pali": "siṅgīnikkhassāpi hetu …"
    },
    {
      "id": "sn17.13-20:1.6",
      "pali": "siṅgīnikkhasatassāpi hetu …"
    },
    {
      "id": "sn17.13-20:1.7",
      "pali": "pathaviyāpi jātarūpaparipūrāya hetu …"
    },
    {
      "id": "sn17.13-20:1.8",
      "pali": "āmisakiñcikkhahetupi …"
    },
    {
      "id": "sn17.13-20:1.9",
      "pali": "jīvitahetupi …"
    },
    {
      "id": "sn17.13-20:1.10",
      "pali": "janapadakalyāṇiyāpi hetu sampajānamusā bhāseyyā’ti."
    },
    {
      "id": "sn17.13-20:1.11",
      "pali": "Tamenaṁ passāmi aparena samayena lābhasakkārasilokena abhibhūtaṁ pariyādiṇṇacittaṁ sampajānamusā bhāsantaṁ."
    },
    {
      "id": "sn17.13-20:1.12",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.13-20:1.13",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.13-20:1.14",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn17.13-20:1.15",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn17.13-20:2.1",
      "pali": "Dve pāti dve suvaṇṇā ca,"
    },
    {
      "id": "sn17.13-20:2.2",
      "pali": "Siṅgīhi apare duve;"
    },
    {
      "id": "sn17.13-20:2.3",
      "pali": "Pathavī kiñcikkhajīvitaṁ,"
    },
    {
      "id": "sn17.13-20:2.4",
      "pali": "Janapadakalyāṇiyā dasāti."
    }
  ]
}
