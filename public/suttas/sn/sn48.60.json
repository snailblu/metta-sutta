{
  "uid": "sn48.60",
  "title": "Dutiyauppādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.60:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni bhāvitāni bahulīkatāni anuppannāni uppajjanti, nāññatra sugatavinayā."
    },
    {
      "id": "sn48.60:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.60:1.3",
      "pali": "Saddhindriyaṁ, vīriyindriyaṁ, satindriyaṁ, samādhindriyaṁ, paññindriyaṁ—"
    },
    {
      "id": "sn48.60:1.4",
      "pali": "imāni kho, bhikkhave, pañcindriyāni bhāvitāni bahulīkatāni anuppannāni uppajjanti, nāññatra sugatavinayā”ti."
    },
    {
      "id": "sn48.60:1.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn48.60:1.6",
      "pali": "Sūkarakhatavaggo chaṭṭho."
    },
    {
      "id": "sn48.60:2.1",
      "pali": "Sālaṁ mallikaṁ sekho ca,"
    },
    {
      "id": "sn48.60:2.2",
      "pali": "padaṁ sāraṁ patiṭṭhitaṁ;"
    },
    {
      "id": "sn48.60:2.3",
      "pali": "Brahmasūkarakhatāyo,"
    },
    {
      "id": "sn48.60:2.4",
      "pali": "uppādā apare duveti."
    }
  ]
}
