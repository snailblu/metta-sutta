{
  "uid": "sn45.31",
  "title": "Paṭhamapaṭipattisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.31:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.31:1.2",
      "pali": "“Micchāpaṭipattiñca vo, bhikkhave, desessāmi, sammāpaṭipattiñca."
    },
    {
      "id": "sn45.31:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.31:1.4",
      "pali": "Katamā ca, bhikkhave, micchāpaṭipatti?"
    },
    {
      "id": "sn45.31:1.5",
      "pali": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi."
    },
    {
      "id": "sn45.31:1.6",
      "pali": "Ayaṁ vuccati, bhikkhave, micchāpaṭipatti."
    },
    {
      "id": "sn45.31:1.7",
      "pali": "Katamā ca, bhikkhave, sammāpaṭipatti?"
    },
    {
      "id": "sn45.31:1.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.31:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, sammāpaṭipattī”ti."
    },
    {
      "id": "sn45.31:1.10",
      "pali": "Paṭhamaṁ."
    }
  ]
}
