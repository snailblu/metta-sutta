{
  "uid": "sn22.52",
  "title": "Dutiyanandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.52:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.52:1.2",
      "pali": "“Rūpaṁ, bhikkhave, yoniso manasi karotha, rūpāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn22.52:1.3",
      "pali": "Rūpaṁ, bhikkhave, bhikkhu yoniso manasi karonto, rūpāniccatañca yathābhūtaṁ samanupassanto rūpasmiṁ nibbindati."
    },
    {
      "id": "sn22.52:1.4",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.52:1.5",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.52:1.6",
      "pali": "Vedanaṁ, bhikkhave, yoniso manasi karotha, vedanāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn22.52:1.7",
      "pali": "Vedanaṁ, bhikkhave, bhikkhu yoniso manasi karonto, vedanāniccatañca yathābhūtaṁ samanupassanto vedanāya nibbindati."
    },
    {
      "id": "sn22.52:1.8",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.52:1.9",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.52:1.10",
      "pali": "Saññaṁ bhikkhave …"
    },
    {
      "id": "sn22.52:1.11",
      "pali": "saṅkhāre, bhikkhave, yoniso manasi karotha, saṅkhārāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn22.52:1.12",
      "pali": "Saṅkhāre, bhikkhave, bhikkhu yoniso manasi karonto, saṅkhārāniccataṁ yathābhūtaṁ samanupassanto saṅkhāresu nibbindati."
    },
    {
      "id": "sn22.52:1.13",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.52:1.14",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.52:1.15",
      "pali": "Viññāṇaṁ, bhikkhave, yoniso manasi karotha, viññāṇāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn22.52:1.16",
      "pali": "Viññāṇaṁ, bhikkhave, bhikkhu yoniso manasi karonto, viññāṇāniccatañca yathābhūtaṁ samanupassanto viññāṇasmiṁ nibbindati."
    },
    {
      "id": "sn22.52:1.17",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.52:1.18",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn22.52:1.19",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn22.52:1.20",
      "pali": "Attadīpavaggo pañcamo."
    },
    {
      "id": "sn22.52:2.1",
      "pali": "Attadīpā paṭipadā,"
    },
    {
      "id": "sn22.52:2.2",
      "pali": "Dve ca honti aniccatā;"
    },
    {
      "id": "sn22.52:2.3",
      "pali": "Samanupassanā khandhā,"
    },
    {
      "id": "sn22.52:2.4",
      "pali": "Dve soṇā dve nandikkhayena cāti."
    },
    {
      "id": "sn22.52:2.5",
      "pali": "Mūlapaṇṇāsako samatto."
    },
    {
      "id": "sn22.52:3.1",
      "pali": "Nakulapitā anicco ca,"
    },
    {
      "id": "sn22.52:3.2",
      "pali": "Bhāro natumhākena ca;"
    },
    {
      "id": "sn22.52:3.3",
      "pali": "Attadīpena paññāso,"
    },
    {
      "id": "sn22.52:3.4",
      "pali": "Paṭhamo tena pavuccatīti."
    }
  ]
}
