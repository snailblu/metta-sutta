{
  "uid": "sn22.126",
  "title": "Samudayadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.126:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.126:1.2",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami; upasaṅkamitvā …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.126:1.3",
      "pali": "“‘avijjā, avijjā’ti, bhante, vuccati."
    },
    {
      "id": "sn22.126:1.4",
      "pali": "Katamā nu kho, bhante, avijjā;"
    },
    {
      "id": "sn22.126:1.5",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.126:2.1",
      "pali": "“Idha, bhikkhu, assutavā puthujjano samudayadhammaṁ rūpaṁ ‘samudayadhammaṁ rūpan’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.2",
      "pali": "vayadhammaṁ rūpaṁ ‘vayadhammaṁ rūpan’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.3",
      "pali": "samudayavayadhammaṁ rūpaṁ ‘samudayavayadhammaṁ rūpan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.126:2.4",
      "pali": "Samudayadhammaṁ vedanaṁ ‘samudayadhammā vedanā’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.5",
      "pali": "vayadhammaṁ vedanaṁ ‘vayadhammā vedanā’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.6",
      "pali": "samudayavayadhammaṁ vedanaṁ ‘samudayavayadhammā vedanā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.126:2.7",
      "pali": "Samudayadhammaṁ saññaṁ …pe…"
    },
    {
      "id": "sn22.126:2.8",
      "pali": "samudayadhamme saṅkhāre ‘samudayadhammā saṅkhārā’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.9",
      "pali": "vayadhamme saṅkhāre ‘vayadhammā saṅkhārā’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.10",
      "pali": "samudayavayadhamme saṅkhāre ‘samudayavayadhammā saṅkhārā’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.126:2.11",
      "pali": "Samudayadhammaṁ viññāṇaṁ ‘samudayadhammaṁ viññāṇan’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.12",
      "pali": "vayadhammaṁ viññāṇaṁ ‘vayadhammaṁ viññāṇan’ti yathābhūtaṁ nappajānāti;"
    },
    {
      "id": "sn22.126:2.13",
      "pali": "samudayavayadhammaṁ viññāṇaṁ ‘samudayavayadhammaṁ viññāṇan’ti yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.126:2.14",
      "pali": "Ayaṁ vuccati, bhikkhu, avijjā;"
    },
    {
      "id": "sn22.126:2.15",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.126:3.1",
      "pali": "Evaṁ vutte, so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.126:3.2",
      "pali": "“‘vijjā, vijjā’ti, bhante, vuccati."
    },
    {
      "id": "sn22.126:3.3",
      "pali": "Katamā nu kho, bhante, vijjā;"
    },
    {
      "id": "sn22.126:3.4",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.126:4.1",
      "pali": "“Idha, bhikkhu, sutavā ariyasāvako samudayadhammaṁ rūpaṁ ‘samudayadhammaṁ rūpan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.2",
      "pali": "vayadhammaṁ rūpaṁ ‘vayadhammaṁ rūpan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.3",
      "pali": "samudayavayadhammaṁ rūpaṁ ‘samudayavayadhammaṁ rūpan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.126:4.4",
      "pali": "Samudayadhammaṁ vedanaṁ ‘samudayadhammā vedanā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.5",
      "pali": "vayadhammaṁ vedanaṁ ‘vayadhammā vedanā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.6",
      "pali": "samudayavayadhammaṁ vedanaṁ ‘samudayavayadhammā vedanā’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.126:4.7",
      "pali": "Samudayadhammaṁ saññaṁ …"
    },
    {
      "id": "sn22.126:4.8",
      "pali": "samudayadhamme saṅkhāre ‘samudayadhammā saṅkhārā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.9",
      "pali": "vayadhamme saṅkhāre ‘vayadhammā saṅkhārā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.10",
      "pali": "samudayavayadhamme saṅkhāre ‘samudayavayadhammā saṅkhārā’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.126:4.11",
      "pali": "Samudayadhammaṁ viññāṇaṁ ‘samudayadhammaṁ viññāṇan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.12",
      "pali": "vayadhammaṁ viññāṇaṁ ‘vayadhammaṁ viññāṇan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn22.126:4.13",
      "pali": "samudayavayadhammaṁ viññāṇaṁ ‘samudayavayadhammaṁ viññāṇan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.126:4.14",
      "pali": "Ayaṁ vuccati, bhikkhu, vijjā;"
    },
    {
      "id": "sn22.126:4.15",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.126:4.16",
      "pali": "Paṭhamaṁ."
    }
  ]
}
