{
  "uid": "sn35.224",
  "title": "Ajjhattāyatanaanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.224:1.1",
      "pali": "“Cakkhu, bhikkhave, anattā …pe… jivhā anattā …pe… mano anattā."
    },
    {
      "id": "sn35.224:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.224:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
