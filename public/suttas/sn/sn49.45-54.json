{
  "uid": "sn49.45-54",
  "title": "Oghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn49.45-54:1.1",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn49.45-54:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn49.45-54:1.3",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn49.45-54:1.4",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn49.45-54:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya cattāro sammappadhānā bhāvetabbā."
    },
    {
      "id": "sn49.45-54:1.6",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn49.45-54:1.7",
      "pali": "Idha, bhikkhave, bhikkhu anuppannānaṁ …pe…"
    },
    {
      "id": "sn49.45-54:1.8",
      "pali": "uppannānaṁ kusalānaṁ dhammānaṁ ṭhitiyā asammosāya bhiyyobhāvāya vepullāya bhāvanāya pāripūriyā chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "sn49.45-54:1.9",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ime cattāro sammappadhānā bhāvetabbā”ti."
    },
    {
      "id": "sn49.45-54:1.10",
      "pali": "(Vitthāretabbā.)"
    },
    {
      "id": "sn49.45-54:1.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn49.45-54:1.12",
      "pali": "Oghavaggo pañcamo."
    },
    {
      "id": "sn49.45-54:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn49.45-54:2.2",
      "pali": "ganthā anusayena ca;"
    },
    {
      "id": "sn49.45-54:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn49.45-54:2.4",
      "pali": "khandhā oruddhambhāgiyāti."
    },
    {
      "id": "sn49.45-54:2.5",
      "pali": "Sammappadhānasaṁyuttaṁ pañcamaṁ."
    }
  ]
}
