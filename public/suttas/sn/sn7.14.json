{
  "uid": "sn7.14",
  "title": "Mahāsālasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.14:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.14:1.2",
      "pali": "Atha kho aññataro brāhmaṇamahāsālo lūkho lūkhapāvuraṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.14:1.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinnaṁ kho taṁ brāhmaṇamahāsālaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn7.14:1.4",
      "pali": "“kiṁ nu tvaṁ, brāhmaṇa, lūkho lūkhapāvuraṇo”ti?"
    },
    {
      "id": "sn7.14:1.5",
      "pali": "“Idha me, bho gotama, cattāro puttā."
    },
    {
      "id": "sn7.14:1.6",
      "pali": "Te maṁ dārehi sampuccha gharā nikkhāmentī”ti."
    },
    {
      "id": "sn7.14:1.7",
      "pali": "“Tena hi tvaṁ, brāhmaṇa, imā gāthāyo pariyāpuṇitvā sabhāyaṁ mahājanakāye sannipatite puttesu ca sannisinnesu bhāsassu:"
    },
    {
      "id": "sn7.14:2.1",
      "pali": "‘Yehi jātehi nandissaṁ,"
    },
    {
      "id": "sn7.14:2.2",
      "pali": "yesañca bhavamicchisaṁ;"
    },
    {
      "id": "sn7.14:2.3",
      "pali": "Te maṁ dārehi sampuccha,"
    },
    {
      "id": "sn7.14:2.4",
      "pali": "sāva vārenti sūkaraṁ."
    },
    {
      "id": "sn7.14:3.1",
      "pali": "Asantā kira maṁ jammā,"
    },
    {
      "id": "sn7.14:3.2",
      "pali": "tāta tātāti bhāsare;"
    },
    {
      "id": "sn7.14:3.3",
      "pali": "Rakkhasā puttarūpena,"
    },
    {
      "id": "sn7.14:3.4",
      "pali": "te jahanti vayogataṁ."
    },
    {
      "id": "sn7.14:4.1",
      "pali": "Assova jiṇṇo nibbhogo,"
    },
    {
      "id": "sn7.14:4.2",
      "pali": "khādanā apanīyati;"
    },
    {
      "id": "sn7.14:4.3",
      "pali": "Bālakānaṁ pitā thero,"
    },
    {
      "id": "sn7.14:4.4",
      "pali": "parāgāresu bhikkhati."
    },
    {
      "id": "sn7.14:5.1",
      "pali": "Daṇḍova kira me seyyo,"
    },
    {
      "id": "sn7.14:5.2",
      "pali": "yañce puttā anassavā;"
    },
    {
      "id": "sn7.14:5.3",
      "pali": "Caṇḍampi goṇaṁ vāreti,"
    },
    {
      "id": "sn7.14:5.4",
      "pali": "atho caṇḍampi kukkuraṁ."
    },
    {
      "id": "sn7.14:6.1",
      "pali": "Andhakāre pure hoti,"
    },
    {
      "id": "sn7.14:6.2",
      "pali": "gambhīre gādhamedhati;"
    },
    {
      "id": "sn7.14:6.3",
      "pali": "Daṇḍassa ānubhāvena,"
    },
    {
      "id": "sn7.14:6.4",
      "pali": "khalitvā patitiṭṭhatī’”ti."
    },
    {
      "id": "sn7.14:7.1",
      "pali": "Atha kho so brāhmaṇamahāsālo bhagavato santike imā gāthāyo pariyāpuṇitvā sabhāyaṁ mahājanakāye sannipatite puttesu ca sannisinnesu abhāsi:"
    },
    {
      "id": "sn7.14:8.1",
      "pali": "“Yehi jātehi nandissaṁ,"
    },
    {
      "id": "sn7.14:8.2",
      "pali": "yesañca bhavamicchisaṁ;"
    },
    {
      "id": "sn7.14:8.3",
      "pali": "Te maṁ dārehi sampuccha,"
    },
    {
      "id": "sn7.14:8.4",
      "pali": "sāva vārenti sūkaraṁ."
    },
    {
      "id": "sn7.14:9.1",
      "pali": "Asantā kira maṁ jammā,"
    },
    {
      "id": "sn7.14:9.2",
      "pali": "tāta tātāti bhāsare;"
    },
    {
      "id": "sn7.14:9.3",
      "pali": "Rakkhasā puttarūpena,"
    },
    {
      "id": "sn7.14:9.4",
      "pali": "te jahanti vayogataṁ."
    },
    {
      "id": "sn7.14:10.1",
      "pali": "Assova jiṇṇo nibbhogo,"
    },
    {
      "id": "sn7.14:10.2",
      "pali": "khādanā apanīyati;"
    },
    {
      "id": "sn7.14:10.3",
      "pali": "Bālakānaṁ pitā thero,"
    },
    {
      "id": "sn7.14:10.4",
      "pali": "parāgāresu bhikkhati."
    },
    {
      "id": "sn7.14:11.1",
      "pali": "Daṇḍova kira me seyyo,"
    },
    {
      "id": "sn7.14:11.2",
      "pali": "yañce puttā anassavā;"
    },
    {
      "id": "sn7.14:11.3",
      "pali": "Caṇḍampi goṇaṁ vāreti,"
    },
    {
      "id": "sn7.14:11.4",
      "pali": "atho caṇḍampi kukkuraṁ."
    },
    {
      "id": "sn7.14:12.1",
      "pali": "Andhakāre pure hoti,"
    },
    {
      "id": "sn7.14:12.2",
      "pali": "gambhīre gādhamedhati;"
    },
    {
      "id": "sn7.14:12.3",
      "pali": "Daṇḍassa ānubhāvena,"
    },
    {
      "id": "sn7.14:12.4",
      "pali": "khalitvā patitiṭṭhatī”ti."
    },
    {
      "id": "sn7.14:13.1",
      "pali": "Atha kho naṁ brāhmaṇamahāsālaṁ puttā gharaṁ netvā nhāpetvā paccekaṁ dussayugena acchādesuṁ."
    },
    {
      "id": "sn7.14:13.2",
      "pali": "Atha kho so brāhmaṇamahāsālo ekaṁ dussayugaṁ ādāya yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.14:13.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho brāhmaṇamahāsālo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.14:13.4",
      "pali": "“mayaṁ, bho gotama, brāhmaṇā nāma ācariyassa ācariyadhanaṁ pariyesāma."
    },
    {
      "id": "sn7.14:13.5",
      "pali": "Paṭiggaṇhatu me bhavaṁ gotamo ācariyadhanan”ti."
    },
    {
      "id": "sn7.14:13.6",
      "pali": "Paṭiggahesi bhagavā anukampaṁ upādāya."
    },
    {
      "id": "sn7.14:13.7",
      "pali": "Atha kho so brāhmaṇamahāsālo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.14:13.8",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.14:13.9",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
