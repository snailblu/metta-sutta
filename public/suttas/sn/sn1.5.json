{
  "uid": "sn1.5",
  "title": "Katichindasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.5:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.5:2.1",
      "pali": "“Kati chinde kati jahe,"
    },
    {
      "id": "sn1.5:2.2",
      "pali": "kati cuttari bhāvaye;"
    },
    {
      "id": "sn1.5:2.3",
      "pali": "Kati saṅgātigo bhikkhu,"
    },
    {
      "id": "sn1.5:2.4",
      "pali": "oghatiṇṇoti vuccatī”ti."
    },
    {
      "id": "sn1.5:3.1",
      "pali": "“Pañca chinde pañca jahe,"
    },
    {
      "id": "sn1.5:3.2",
      "pali": "pañca cuttari bhāvaye;"
    },
    {
      "id": "sn1.5:3.3",
      "pali": "Pañca saṅgātigo bhikkhu,"
    },
    {
      "id": "sn1.5:3.4",
      "pali": "oghatiṇṇoti vuccatī”ti."
    }
  ]
}
