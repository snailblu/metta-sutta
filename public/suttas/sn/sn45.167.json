{
  "uid": "sn45.167",
  "title": "Malasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.167:1.1",
      "pali": "“Tīṇimāni, bhikkhave, malāni."
    },
    {
      "id": "sn45.167:1.2",
      "pali": "Katamāni tīṇi?"
    },
    {
      "id": "sn45.167:1.3",
      "pali": "Rāgo malaṁ, doso malaṁ, moho malaṁ—"
    },
    {
      "id": "sn45.167:1.4",
      "pali": "imāni kho, bhikkhave, tīṇi malāni."
    },
    {
      "id": "sn45.167:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ malānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.167:1.6",
      "pali": "Sattamaṁ."
    }
  ]
}
