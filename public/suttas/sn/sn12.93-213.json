{
  "uid": "sn12.93-213",
  "title": "sn12.93-213",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.93-103:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā apassatā yathābhūtaṁ jarāmaraṇe yathābhūtaṁ ñāṇāya sikkhā karaṇīyā."
    },
    {
      "id": "sn12.93-103:2.1",
      "pali": "(Peyyālo. Catusaccikaṁ kātabbaṁ.)"
    },
    {
      "id": "sn12.104-114:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.104-114:1.2",
      "pali": "yogo karaṇīyo …pe…."
    },
    {
      "id": "sn12.115-125:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.115-125:1.2",
      "pali": "chando karaṇīyo …pe…."
    },
    {
      "id": "sn12.126-136:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.126-136:1.2",
      "pali": "ussoḷhī karaṇīyā …pe…."
    },
    {
      "id": "sn12.137-147:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.137-147:1.2",
      "pali": "appaṭivānī karaṇīyā …pe…."
    },
    {
      "id": "sn12.148-158:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.148-158:1.2",
      "pali": "ātappaṁ karaṇīyaṁ …pe…."
    },
    {
      "id": "sn12.159-169:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.159-169:1.2",
      "pali": "vīriyaṁ karaṇīyaṁ …pe…."
    },
    {
      "id": "sn12.170-180:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.170-180:1.2",
      "pali": "sātaccaṁ karaṇīyaṁ …pe…."
    },
    {
      "id": "sn12.181-191:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.181-191:1.2",
      "pali": "sati karaṇīyā …pe…."
    },
    {
      "id": "sn12.192-202:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.192-202:1.2",
      "pali": "sampajaññaṁ karaṇīyaṁ …pe…."
    },
    {
      "id": "sn12.203-213:1.1",
      "pali": "“Jarāmaraṇaṁ, bhikkhave, ajānatā …pe…"
    },
    {
      "id": "sn12.203-213:1.2",
      "pali": "appamādo karaṇīyo …pe…."
    },
    {
      "id": "sn12.203-213:1.3",
      "pali": "Antarapeyyālo navamo."
    },
    {
      "id": "sn12.203-213:2.1",
      "pali": "Satthā sikkhā ca yogo ca,"
    },
    {
      "id": "sn12.203-213:2.2",
      "pali": "chando ussoḷhipañcamī;"
    },
    {
      "id": "sn12.203-213:2.3",
      "pali": "Appaṭivāni yātappaṁ,"
    },
    {
      "id": "sn12.203-213:2.4",
      "pali": "vīriyaṁ sātaccamuccati;"
    },
    {
      "id": "sn12.203-213:2.5",
      "pali": "Sati ca sampajaññañca,"
    },
    {
      "id": "sn12.203-213:2.6",
      "pali": "appamādena dvādasāti."
    },
    {
      "id": "sn12.203-213:2.7",
      "pali": "Suttantā antarapeyyālā niṭṭhitā."
    },
    {
      "id": "sn12.203-213:3.1",
      "pali": "Pare te dvādasa honti,"
    },
    {
      "id": "sn12.203-213:3.2",
      "pali": "suttā dvattiṁsa satāni;"
    },
    {
      "id": "sn12.203-213:3.3",
      "pali": "Catusaccena te vuttā,"
    },
    {
      "id": "sn12.203-213:3.4",
      "pali": "peyyālaantaramhi yeti."
    },
    {
      "id": "sn12.203-213:3.5",
      "pali": "Antarapeyyālesu uddānaṁ samattaṁ."
    },
    {
      "id": "sn12.203-213:3.6",
      "pali": "Nidānasaṁyuttaṁ samattaṁ."
    }
  ]
}
