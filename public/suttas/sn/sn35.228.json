{
  "uid": "sn35.228",
  "title": "Paṭhamasamuddasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.228:1.1",
      "pali": "“‘Samuddo, samuddo’ti, bhikkhave, assutavā puthujjano bhāsati."
    },
    {
      "id": "sn35.228:1.2",
      "pali": "Neso, bhikkhave, ariyassa vinaye samuddo."
    },
    {
      "id": "sn35.228:1.3",
      "pali": "Mahā eso, bhikkhave, udakarāsi mahāudakaṇṇavo."
    },
    {
      "id": "sn35.228:1.4",
      "pali": "Cakkhu, bhikkhave, purisassa samuddo;"
    },
    {
      "id": "sn35.228:1.5",
      "pali": "tassa rūpamayo vego."
    },
    {
      "id": "sn35.228:2.1",
      "pali": "Yo taṁ rūpamayaṁ vegaṁ sahati, ayaṁ vuccati, bhikkhave, atari cakkhusamuddaṁ saūmiṁ sāvaṭṭaṁ sagāhaṁ sarakkhasaṁ;"
    },
    {
      "id": "sn35.228:2.2",
      "pali": "tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo …pe…"
    },
    {
      "id": "sn35.228:2.3",
      "pali": "jivhā, bhikkhave, purisassa samuddo;"
    },
    {
      "id": "sn35.228:2.4",
      "pali": "tassa rasamayo vego."
    },
    {
      "id": "sn35.228:2.5",
      "pali": "Yo taṁ rasamayaṁ vegaṁ sahati, ayaṁ vuccati, bhikkhave, atari jivhāsamuddaṁ saūmiṁ sāvaṭṭaṁ sagāhaṁ sarakkhasaṁ;"
    },
    {
      "id": "sn35.228:2.6",
      "pali": "tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo …pe…"
    },
    {
      "id": "sn35.228:2.7",
      "pali": "mano, bhikkhave, purisassa samuddo;"
    },
    {
      "id": "sn35.228:2.8",
      "pali": "tassa dhammamayo vego."
    },
    {
      "id": "sn35.228:2.9",
      "pali": "Yo taṁ dhammamayaṁ vegaṁ sahati, ayaṁ vuccati, bhikkhave, atari manosamuddaṁ saūmiṁ sāvaṭṭaṁ sagāhaṁ sarakkhasaṁ;"
    },
    {
      "id": "sn35.228:2.10",
      "pali": "tiṇṇo pāraṅgato thale tiṭṭhati brāhmaṇo”ti."
    },
    {
      "id": "sn35.228:2.11",
      "pali": "Idamavoca …pe…"
    },
    {
      "id": "sn35.228:2.12",
      "pali": "satthā:"
    },
    {
      "id": "sn35.228:3.1",
      "pali": "“Yo imaṁ samuddaṁ sagāhaṁ sarakkhasaṁ,"
    },
    {
      "id": "sn35.228:3.2",
      "pali": "Saūmiṁ sāvaṭṭaṁ sabhayaṁ duttaraṁ accatari;"
    },
    {
      "id": "sn35.228:3.3",
      "pali": "Sa vedagū vusitabrahmacariyo,"
    },
    {
      "id": "sn35.228:3.4",
      "pali": "Lokantagū pāragatoti vuccatī”ti."
    },
    {
      "id": "sn35.228:3.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
