{
  "uid": "snp5.1",
  "title": "Vatthugāthā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.1:1.1",
      "pali": "Kosalānaṁ purā rammā,"
    },
    {
      "id": "snp5.1:1.2",
      "pali": "agamā dakkhiṇāpathaṁ;"
    },
    {
      "id": "snp5.1:1.3",
      "pali": "Ākiñcaññaṁ patthayāno,"
    },
    {
      "id": "snp5.1:1.4",
      "pali": "brāhmaṇo mantapāragū."
    },
    {
      "id": "snp5.1:2.1",
      "pali": "So assakassa visaye,"
    },
    {
      "id": "snp5.1:2.2",
      "pali": "aḷakassa samāsane;"
    },
    {
      "id": "snp5.1:2.3",
      "pali": "Vasi godhāvarīkūle,"
    },
    {
      "id": "snp5.1:2.4",
      "pali": "uñchena ca phalena ca."
    },
    {
      "id": "snp5.1:3.1",
      "pali": "Tasseva upanissāya,"
    },
    {
      "id": "snp5.1:3.2",
      "pali": "gāmo ca vipulo ahu;"
    },
    {
      "id": "snp5.1:3.3",
      "pali": "Tato jātena āyena,"
    },
    {
      "id": "snp5.1:3.4",
      "pali": "mahāyaññamakappayi."
    },
    {
      "id": "snp5.1:4.1",
      "pali": "Mahāyaññaṁ yajitvāna,"
    },
    {
      "id": "snp5.1:4.2",
      "pali": "puna pāvisi assamaṁ;"
    },
    {
      "id": "snp5.1:4.3",
      "pali": "Tasmiṁ paṭipaviṭṭhamhi,"
    },
    {
      "id": "snp5.1:4.4",
      "pali": "añño āgañchi brāhmaṇo."
    },
    {
      "id": "snp5.1:5.1",
      "pali": "Ugghaṭṭapādo tasito,"
    },
    {
      "id": "snp5.1:5.2",
      "pali": "paṅkadanto rajassiro;"
    },
    {
      "id": "snp5.1:5.3",
      "pali": "So ca naṁ upasaṅkamma,"
    },
    {
      "id": "snp5.1:5.4",
      "pali": "satāni pañca yācati."
    },
    {
      "id": "snp5.1:6.1",
      "pali": "Tamenaṁ bāvarī disvā,"
    },
    {
      "id": "snp5.1:6.2",
      "pali": "āsanena nimantayi;"
    },
    {
      "id": "snp5.1:6.3",
      "pali": "Sukhañca kusalaṁ pucchi,"
    },
    {
      "id": "snp5.1:6.4",
      "pali": "idaṁ vacanamabravi."
    },
    {
      "id": "snp5.1:7.1",
      "pali": "“Yaṁ kho mama deyyadhammaṁ,"
    },
    {
      "id": "snp5.1:7.2",
      "pali": "Sabbaṁ visajjitaṁ mayā;"
    },
    {
      "id": "snp5.1:7.3",
      "pali": "Anujānāhi me brahme,"
    },
    {
      "id": "snp5.1:7.4",
      "pali": "Natthi pañcasatāni me”."
    },
    {
      "id": "snp5.1:8.1",
      "pali": "“Sace me yācamānassa,"
    },
    {
      "id": "snp5.1:8.2",
      "pali": "bhavaṁ nānupadassati;"
    },
    {
      "id": "snp5.1:8.3",
      "pali": "Sattame divase tuyhaṁ,"
    },
    {
      "id": "snp5.1:8.4",
      "pali": "muddhā phalatu sattadhā”."
    },
    {
      "id": "snp5.1:9.1",
      "pali": "Abhisaṅkharitvā kuhako,"
    },
    {
      "id": "snp5.1:9.2",
      "pali": "bheravaṁ so akittayi;"
    },
    {
      "id": "snp5.1:9.3",
      "pali": "Tassa taṁ vacanaṁ sutvā,"
    },
    {
      "id": "snp5.1:9.4",
      "pali": "bāvarī dukkhito ahu."
    },
    {
      "id": "snp5.1:10.1",
      "pali": "Ussussati anāhāro,"
    },
    {
      "id": "snp5.1:10.2",
      "pali": "Sokasallasamappito;"
    },
    {
      "id": "snp5.1:10.3",
      "pali": "Athopi evaṁ cittassa,"
    },
    {
      "id": "snp5.1:10.4",
      "pali": "Jhāne na ramatī mano."
    },
    {
      "id": "snp5.1:11.1",
      "pali": "Utrastaṁ dukkhitaṁ disvā,"
    },
    {
      "id": "snp5.1:11.2",
      "pali": "Devatā atthakāminī;"
    },
    {
      "id": "snp5.1:11.3",
      "pali": "Bāvariṁ upasaṅkamma,"
    },
    {
      "id": "snp5.1:11.4",
      "pali": "Idaṁ vacanamabravi."
    },
    {
      "id": "snp5.1:12.1",
      "pali": "“Na so muddhaṁ pajānāti,"
    },
    {
      "id": "snp5.1:12.2",
      "pali": "Kuhako so dhanatthiko;"
    },
    {
      "id": "snp5.1:12.3",
      "pali": "Muddhani muddhapāte vā,"
    },
    {
      "id": "snp5.1:12.4",
      "pali": "Ñāṇaṁ tassa na vijjati”."
    },
    {
      "id": "snp5.1:13.1",
      "pali": "“Bhotī carahi jānāsi,"
    },
    {
      "id": "snp5.1:13.2",
      "pali": "Taṁ me akkhāhi pucchitā;"
    },
    {
      "id": "snp5.1:13.3",
      "pali": "Muddhaṁ muddhādhipātañca,"
    },
    {
      "id": "snp5.1:13.4",
      "pali": "Taṁ suṇoma vaco tava”."
    },
    {
      "id": "snp5.1:14.1",
      "pali": "“Ahampetaṁ na jānāmi,"
    },
    {
      "id": "snp5.1:14.2",
      "pali": "Ñāṇamettha na vijjati;"
    },
    {
      "id": "snp5.1:14.3",
      "pali": "Muddhani muddhādhipāte ca,"
    },
    {
      "id": "snp5.1:14.4",
      "pali": "Jinānaṁ hettha dassanaṁ”."
    },
    {
      "id": "snp5.1:15.1",
      "pali": "“Atha ko carahi jānāti,"
    },
    {
      "id": "snp5.1:15.2",
      "pali": "Asmiṁ pathavimaṇḍale;"
    },
    {
      "id": "snp5.1:15.3",
      "pali": "Muddhaṁ muddhādhipātañca,"
    },
    {
      "id": "snp5.1:15.4",
      "pali": "Taṁ me akkhāhi devate”."
    },
    {
      "id": "snp5.1:16.1",
      "pali": "“Purā kapilavatthumhā,"
    },
    {
      "id": "snp5.1:16.2",
      "pali": "Nikkhanto lokanāyako;"
    },
    {
      "id": "snp5.1:16.3",
      "pali": "Apacco okkākarājassa,"
    },
    {
      "id": "snp5.1:16.4",
      "pali": "Sakyaputto pabhaṅkaro."
    },
    {
      "id": "snp5.1:17.1",
      "pali": "So hi brāhmaṇa sambuddho,"
    },
    {
      "id": "snp5.1:17.2",
      "pali": "Sabbadhammāna pāragū;"
    },
    {
      "id": "snp5.1:17.3",
      "pali": "Sabbābhiññābalappatto,"
    },
    {
      "id": "snp5.1:17.4",
      "pali": "Sabbadhammesu cakkhumā;"
    },
    {
      "id": "snp5.1:17.5",
      "pali": "Sabbakammakkhayaṁ patto,"
    },
    {
      "id": "snp5.1:17.6",
      "pali": "Vimutto upadhikkhaye."
    },
    {
      "id": "snp5.1:18.1",
      "pali": "Buddho so bhagavā loke,"
    },
    {
      "id": "snp5.1:18.2",
      "pali": "Dhammaṁ deseti cakkhumā;"
    },
    {
      "id": "snp5.1:18.3",
      "pali": "Taṁ tvaṁ gantvāna pucchassu,"
    },
    {
      "id": "snp5.1:18.4",
      "pali": "So te taṁ byākarissati”."
    },
    {
      "id": "snp5.1:19.1",
      "pali": "Sambuddhoti vaco sutvā,"
    },
    {
      "id": "snp5.1:19.2",
      "pali": "Udaggo bāvarī ahu;"
    },
    {
      "id": "snp5.1:19.3",
      "pali": "Sokassa tanuko āsi,"
    },
    {
      "id": "snp5.1:19.4",
      "pali": "Pītiñca vipulaṁ labhi."
    },
    {
      "id": "snp5.1:20.1",
      "pali": "So bāvarī attamano udaggo,"
    },
    {
      "id": "snp5.1:20.2",
      "pali": "Taṁ devataṁ pucchati vedajāto;"
    },
    {
      "id": "snp5.1:20.3",
      "pali": "“Katamamhi gāme nigamamhi vā pana,"
    },
    {
      "id": "snp5.1:20.4",
      "pali": "Katamamhi vā janapade lokanātho;"
    },
    {
      "id": "snp5.1:20.5",
      "pali": "Yattha gantvāna passemu,"
    },
    {
      "id": "snp5.1:20.6",
      "pali": "Sambuddhaṁ dvipaduttamaṁ”."
    },
    {
      "id": "snp5.1:21.1",
      "pali": "“Sāvatthiyaṁ kosalamandire jino,"
    },
    {
      "id": "snp5.1:21.2",
      "pali": "Pahūtapañño varabhūrimedhaso;"
    },
    {
      "id": "snp5.1:21.3",
      "pali": "So sakyaputto vidhuro anāsavo,"
    },
    {
      "id": "snp5.1:21.4",
      "pali": "Muddhādhipātassa vidū narāsabho”."
    },
    {
      "id": "snp5.1:22.1",
      "pali": "Tato āmantayī sisse,"
    },
    {
      "id": "snp5.1:22.2",
      "pali": "Brāhmaṇe mantapārage;"
    },
    {
      "id": "snp5.1:22.3",
      "pali": "“Etha māṇavā akkhissaṁ,"
    },
    {
      "id": "snp5.1:22.4",
      "pali": "Suṇātha vacanaṁ mama."
    },
    {
      "id": "snp5.1:23.1",
      "pali": "Yasseso dullabho loke,"
    },
    {
      "id": "snp5.1:23.2",
      "pali": "Pātubhāvo abhiṇhaso;"
    },
    {
      "id": "snp5.1:23.3",
      "pali": "Svājja lokamhi uppanno,"
    },
    {
      "id": "snp5.1:23.4",
      "pali": "Sambuddho iti vissuto;"
    },
    {
      "id": "snp5.1:23.5",
      "pali": "Khippaṁ gantvāna sāvatthiṁ,"
    },
    {
      "id": "snp5.1:23.6",
      "pali": "Passavho dvipaduttamaṁ”."
    },
    {
      "id": "snp5.1:24.1",
      "pali": "“Kathaṁ carahi jānemu,"
    },
    {
      "id": "snp5.1:24.2",
      "pali": "Disvā buddhoti brāhmaṇa;"
    },
    {
      "id": "snp5.1:24.3",
      "pali": "Ajānataṁ no pabrūhi,"
    },
    {
      "id": "snp5.1:24.4",
      "pali": "Yathā jānemu taṁ mayaṁ”."
    },
    {
      "id": "snp5.1:25.1",
      "pali": "“Āgatāni hi mantesu,"
    },
    {
      "id": "snp5.1:25.2",
      "pali": "Mahāpurisalakkhaṇā;"
    },
    {
      "id": "snp5.1:25.3",
      "pali": "Dvattiṁsāni ca byākkhātā,"
    },
    {
      "id": "snp5.1:25.4",
      "pali": "Samattā anupubbaso."
    },
    {
      "id": "snp5.1:26.1",
      "pali": "Yassete honti gattesu,"
    },
    {
      "id": "snp5.1:26.2",
      "pali": "Mahāpurisalakkhaṇā;"
    },
    {
      "id": "snp5.1:26.3",
      "pali": "Dveyeva tassa gatiyo,"
    },
    {
      "id": "snp5.1:26.4",
      "pali": "Tatiyā hi na vijjati."
    },
    {
      "id": "snp5.1:27.1",
      "pali": "Sace agāraṁ āvasati,"
    },
    {
      "id": "snp5.1:27.2",
      "pali": "Vijeyya pathaviṁ imaṁ;"
    },
    {
      "id": "snp5.1:27.3",
      "pali": "Adaṇḍena asatthena,"
    },
    {
      "id": "snp5.1:27.4",
      "pali": "Dhammena manusāsati."
    },
    {
      "id": "snp5.1:28.1",
      "pali": "Sace ca so pabbajati,"
    },
    {
      "id": "snp5.1:28.2",
      "pali": "Agārā anagāriyaṁ;"
    },
    {
      "id": "snp5.1:28.3",
      "pali": "Vivaṭṭacchado sambuddho,"
    },
    {
      "id": "snp5.1:28.4",
      "pali": "Arahā bhavati anuttaro."
    },
    {
      "id": "snp5.1:29.1",
      "pali": "Jātiṁ gottañca lakkhaṇaṁ,"
    },
    {
      "id": "snp5.1:29.2",
      "pali": "Mante sisse punāpare;"
    },
    {
      "id": "snp5.1:29.3",
      "pali": "Muddhaṁ muddhādhipātañca,"
    },
    {
      "id": "snp5.1:29.4",
      "pali": "Manasāyeva pucchatha."
    },
    {
      "id": "snp5.1:30.1",
      "pali": "Anāvaraṇadassāvī,"
    },
    {
      "id": "snp5.1:30.2",
      "pali": "Yadi buddho bhavissati;"
    },
    {
      "id": "snp5.1:30.3",
      "pali": "Manasā pucchite pañhe,"
    },
    {
      "id": "snp5.1:30.4",
      "pali": "Vācāya vissajessati”."
    },
    {
      "id": "snp5.1:31.1",
      "pali": "Bāvarissa vaco sutvā,"
    },
    {
      "id": "snp5.1:31.2",
      "pali": "Sissā soḷasa brāhmaṇā;"
    },
    {
      "id": "snp5.1:31.3",
      "pali": "Ajito tissametteyyo,"
    },
    {
      "id": "snp5.1:31.4",
      "pali": "Puṇṇako atha mettagū."
    },
    {
      "id": "snp5.1:32.1",
      "pali": "Dhotako upasīvo ca,"
    },
    {
      "id": "snp5.1:32.2",
      "pali": "Nando ca atha hemako;"
    },
    {
      "id": "snp5.1:32.3",
      "pali": "Todeyya-kappā dubhayo,"
    },
    {
      "id": "snp5.1:32.4",
      "pali": "Jatukaṇṇī ca paṇḍito."
    },
    {
      "id": "snp5.1:33.1",
      "pali": "Bhadrāvudho udayo ca,"
    },
    {
      "id": "snp5.1:33.2",
      "pali": "Posālo cāpi brāhmaṇo;"
    },
    {
      "id": "snp5.1:33.3",
      "pali": "Mogharājā ca medhāvī,"
    },
    {
      "id": "snp5.1:33.4",
      "pali": "Piṅgiyo ca mahāisi."
    },
    {
      "id": "snp5.1:34.1",
      "pali": "Paccekagaṇino sabbe,"
    },
    {
      "id": "snp5.1:34.2",
      "pali": "Sabbalokassa vissutā;"
    },
    {
      "id": "snp5.1:34.3",
      "pali": "Jhāyī jhānaratā dhīrā,"
    },
    {
      "id": "snp5.1:34.4",
      "pali": "Pubbavāsanavāsitā."
    },
    {
      "id": "snp5.1:35.1",
      "pali": "Bāvariṁ abhivādetvā,"
    },
    {
      "id": "snp5.1:35.2",
      "pali": "Katvā ca naṁ padakkhiṇaṁ;"
    },
    {
      "id": "snp5.1:35.3",
      "pali": "Jaṭājinadharā sabbe,"
    },
    {
      "id": "snp5.1:35.4",
      "pali": "Pakkāmuṁ uttarāmukhā."
    },
    {
      "id": "snp5.1:36.1",
      "pali": "Aḷakassa patiṭṭhānaṁ,"
    },
    {
      "id": "snp5.1:36.2",
      "pali": "Purimāhissatiṁ tadā;"
    },
    {
      "id": "snp5.1:36.3",
      "pali": "Ujjeniñcāpi gonaddhaṁ,"
    },
    {
      "id": "snp5.1:36.4",
      "pali": "Vedisaṁ vanasavhayaṁ."
    },
    {
      "id": "snp5.1:37.1",
      "pali": "Kosambiñcāpi sāketaṁ,"
    },
    {
      "id": "snp5.1:37.2",
      "pali": "Sāvatthiñca puruttamaṁ;"
    },
    {
      "id": "snp5.1:37.3",
      "pali": "Setabyaṁ kapilavatthuṁ,"
    },
    {
      "id": "snp5.1:37.4",
      "pali": "Kusinārañca mandiraṁ."
    },
    {
      "id": "snp5.1:38.1",
      "pali": "Pāvañca bhoganagaraṁ,"
    },
    {
      "id": "snp5.1:38.2",
      "pali": "Vesāliṁ māgadhaṁ puraṁ;"
    },
    {
      "id": "snp5.1:38.3",
      "pali": "Pāsāṇakaṁ cetiyañca,"
    },
    {
      "id": "snp5.1:38.4",
      "pali": "Ramaṇīyaṁ manoramaṁ."
    },
    {
      "id": "snp5.1:39.1",
      "pali": "Tasitovudakaṁ sītaṁ,"
    },
    {
      "id": "snp5.1:39.2",
      "pali": "Mahālābhaṁva vāṇijo;"
    },
    {
      "id": "snp5.1:39.3",
      "pali": "Chāyaṁ ghammābhitattova,"
    },
    {
      "id": "snp5.1:39.4",
      "pali": "Turitā pabbatamāruhuṁ."
    },
    {
      "id": "snp5.1:40.1",
      "pali": "Bhagavā tamhi samaye,"
    },
    {
      "id": "snp5.1:40.2",
      "pali": "Bhikkhusaṅghapurakkhato;"
    },
    {
      "id": "snp5.1:40.3",
      "pali": "Bhikkhūnaṁ dhammaṁ deseti,"
    },
    {
      "id": "snp5.1:40.4",
      "pali": "Sīhova nadatī vane."
    },
    {
      "id": "snp5.1:41.1",
      "pali": "Ajito addasa buddhaṁ,"
    },
    {
      "id": "snp5.1:41.2",
      "pali": "Sataraṁsiṁva bhāṇumaṁ;"
    },
    {
      "id": "snp5.1:41.3",
      "pali": "Candaṁ yathā pannarase,"
    },
    {
      "id": "snp5.1:41.4",
      "pali": "Pāripūriṁ upāgataṁ."
    },
    {
      "id": "snp5.1:42.1",
      "pali": "Athassa gatte disvāna,"
    },
    {
      "id": "snp5.1:42.2",
      "pali": "Paripūrañca byañjanaṁ;"
    },
    {
      "id": "snp5.1:42.3",
      "pali": "Ekamantaṁ ṭhito haṭṭho,"
    },
    {
      "id": "snp5.1:42.4",
      "pali": "Manopañhe apucchatha."
    },
    {
      "id": "snp5.1:43.1",
      "pali": "“Ādissa jammanaṁ brūhi,"
    },
    {
      "id": "snp5.1:43.2",
      "pali": "Gottaṁ brūhi salakkhaṇaṁ;"
    },
    {
      "id": "snp5.1:43.3",
      "pali": "Mantesu pāramiṁ brūhi,"
    },
    {
      "id": "snp5.1:43.4",
      "pali": "Kati vāceti brāhmaṇo”."
    },
    {
      "id": "snp5.1:44.1",
      "pali": "“Vīsaṁ vassasataṁ āyu,"
    },
    {
      "id": "snp5.1:44.2",
      "pali": "So ca gottena bāvarī;"
    },
    {
      "id": "snp5.1:44.3",
      "pali": "Tīṇissa lakkhaṇā gatte,"
    },
    {
      "id": "snp5.1:44.4",
      "pali": "Tiṇṇaṁ vedāna pāragū."
    },
    {
      "id": "snp5.1:45.1",
      "pali": "Lakkhaṇe itihāse ca,"
    },
    {
      "id": "snp5.1:45.2",
      "pali": "Sanighaṇḍusakeṭubhe;"
    },
    {
      "id": "snp5.1:45.3",
      "pali": "Pañcasatāni vāceti,"
    },
    {
      "id": "snp5.1:45.4",
      "pali": "Sadhamme pāramiṁ gato”."
    },
    {
      "id": "snp5.1:46.1",
      "pali": "“Lakkhaṇānaṁ pavicayaṁ,"
    },
    {
      "id": "snp5.1:46.2",
      "pali": "Bāvarissa naruttama;"
    },
    {
      "id": "snp5.1:46.3",
      "pali": "Kaṅkhacchida pakāsehi,"
    },
    {
      "id": "snp5.1:46.4",
      "pali": "Mā no kaṅkhāyitaṁ ahu”."
    },
    {
      "id": "snp5.1:47.1",
      "pali": "“Mukhaṁ jivhāya chādeti,"
    },
    {
      "id": "snp5.1:47.2",
      "pali": "Uṇṇassa bhamukantare;"
    },
    {
      "id": "snp5.1:47.3",
      "pali": "Kosohitaṁ vatthaguyhaṁ,"
    },
    {
      "id": "snp5.1:47.4",
      "pali": "Evaṁ jānāhi māṇava”."
    },
    {
      "id": "snp5.1:48.1",
      "pali": "Pucchañhi kiñci asuṇanto,"
    },
    {
      "id": "snp5.1:48.2",
      "pali": "Sutvā pañhe viyākate;"
    },
    {
      "id": "snp5.1:48.3",
      "pali": "Vicinteti jano sabbo,"
    },
    {
      "id": "snp5.1:48.4",
      "pali": "Vedajāto katañjalī."
    },
    {
      "id": "snp5.1:49.1",
      "pali": "“Ko nu devo vā brahmā vā,"
    },
    {
      "id": "snp5.1:49.2",
      "pali": "Indo vāpi sujampati;"
    },
    {
      "id": "snp5.1:49.3",
      "pali": "Manasā pucchite pañhe,"
    },
    {
      "id": "snp5.1:49.4",
      "pali": "Kametaṁ paṭibhāsati”."
    },
    {
      "id": "snp5.1:50.1",
      "pali": "“Muddhaṁ muddhādhipātañca,"
    },
    {
      "id": "snp5.1:50.2",
      "pali": "Bāvarī paripucchati;"
    },
    {
      "id": "snp5.1:50.3",
      "pali": "Taṁ byākarohi bhagavā,"
    },
    {
      "id": "snp5.1:50.4",
      "pali": "Kaṅkhaṁ vinaya no ise”."
    },
    {
      "id": "snp5.1:51.1",
      "pali": "“Avijjā muddhāti jānāhi,"
    },
    {
      "id": "snp5.1:51.2",
      "pali": "Vijjā muddhādhipātinī;"
    },
    {
      "id": "snp5.1:51.3",
      "pali": "Saddhāsatisamādhīhi,"
    },
    {
      "id": "snp5.1:51.4",
      "pali": "Chandaviriyena saṁyutā”."
    },
    {
      "id": "snp5.1:52.1",
      "pali": "Tato vedena mahatā,"
    },
    {
      "id": "snp5.1:52.2",
      "pali": "Santhambhitvāna māṇavo;"
    },
    {
      "id": "snp5.1:52.3",
      "pali": "Ekaṁsaṁ ajinaṁ katvā,"
    },
    {
      "id": "snp5.1:52.4",
      "pali": "Pādesu sirasā pati."
    },
    {
      "id": "snp5.1:53.1",
      "pali": "“Bāvarī brāhmaṇo bhoto,"
    },
    {
      "id": "snp5.1:53.2",
      "pali": "Saha sissehi mārisa;"
    },
    {
      "id": "snp5.1:53.3",
      "pali": "Udaggacitto sumano,"
    },
    {
      "id": "snp5.1:53.4",
      "pali": "Pāde vandati cakkhuma”."
    },
    {
      "id": "snp5.1:54.1",
      "pali": "“Sukhito bāvarī hotu,"
    },
    {
      "id": "snp5.1:54.2",
      "pali": "Saha sissehi brāhmaṇo;"
    },
    {
      "id": "snp5.1:54.3",
      "pali": "Tvañcāpi sukhito hohi,"
    },
    {
      "id": "snp5.1:54.4",
      "pali": "Ciraṁ jīvāhi māṇava."
    },
    {
      "id": "snp5.1:55.1",
      "pali": "Bāvarissa ca tuyhaṁ vā,"
    },
    {
      "id": "snp5.1:55.2",
      "pali": "Sabbesaṁ sabbasaṁsayaṁ;"
    },
    {
      "id": "snp5.1:55.3",
      "pali": "Katāvakāsā pucchavho,"
    },
    {
      "id": "snp5.1:55.4",
      "pali": "Yaṁ kiñci manasicchatha”."
    },
    {
      "id": "snp5.1:56.1",
      "pali": "Sambuddhena katokāso,"
    },
    {
      "id": "snp5.1:56.2",
      "pali": "Nisīditvāna pañjalī;"
    },
    {
      "id": "snp5.1:56.3",
      "pali": "Ajito paṭhamaṁ pañhaṁ,"
    },
    {
      "id": "snp5.1:56.4",
      "pali": "Tattha pucchi tathāgataṁ."
    },
    {
      "id": "snp5.1:56.5",
      "pali": "Vatthugāthā niṭṭhitā."
    }
  ]
}
