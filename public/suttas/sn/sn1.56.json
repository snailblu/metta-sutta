{
  "uid": "sn1.56",
  "title": "Dutiyajanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.56:1.1",
      "pali": "“Kiṁsu janeti purisaṁ,"
    },
    {
      "id": "sn1.56:1.2",
      "pali": "kiṁsu tassa vidhāvati;"
    },
    {
      "id": "sn1.56:1.3",
      "pali": "Kiṁsu saṁsāramāpādi,"
    },
    {
      "id": "sn1.56:1.4",
      "pali": "kismā na parimuccatī”ti."
    },
    {
      "id": "sn1.56:2.1",
      "pali": "“Taṇhā janeti purisaṁ,"
    },
    {
      "id": "sn1.56:2.2",
      "pali": "cittamassa vidhāvati;"
    },
    {
      "id": "sn1.56:2.3",
      "pali": "Satto saṁsāramāpādi,"
    },
    {
      "id": "sn1.56:2.4",
      "pali": "dukkhā na parimuccatī”ti."
    }
  ]
}
