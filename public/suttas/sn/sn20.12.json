{
  "uid": "sn20.12",
  "title": "Dutiyasiṅgālasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn20.12:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn20.12:1.2",
      "pali": "“Assuttha no tumhe, bhikkhave, rattiyā paccūsasamayaṁ jarasiṅgālassa vassamānassā”ti?"
    },
    {
      "id": "sn20.12:1.3",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn20.12:1.4",
      "pali": "“Siyā kho, bhikkhave, tasmiṁ jarasiṅgāle yā kāci kataññutā kataveditā, na tveva idhekacce sakyaputtiyapaṭiññe siyā yā kāci kataññutā kataveditā."
    },
    {
      "id": "sn20.12:1.5",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "sn20.12:1.6",
      "pali": "‘kataññuno bhavissāma katavedino;"
    },
    {
      "id": "sn20.12:1.7",
      "pali": "na ca no amhesu appakampi kataṁ nassissatī’ti."
    },
    {
      "id": "sn20.12:1.8",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn20.12:1.9",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn20.12:1.10",
      "pali": "Opammavaggo paṭhamo."
    },
    {
      "id": "sn20.12:2.1",
      "pali": "Kūṭaṁ nakhasikhaṁ kulaṁ,"
    },
    {
      "id": "sn20.12:2.2",
      "pali": "okkhā satti dhanuggaho;"
    },
    {
      "id": "sn20.12:2.3",
      "pali": "Āṇi kaliṅgaro nāgo,"
    },
    {
      "id": "sn20.12:2.4",
      "pali": "biḷāro dve siṅgālakāti."
    },
    {
      "id": "sn20.12:2.5",
      "pali": "Opammasaṁyuttaṁ samattaṁ."
    }
  ]
}
