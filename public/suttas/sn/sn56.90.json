{
  "uid": "sn56.90",
  "title": "Hatthigavassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.90:1.1",
      "pali": "… “Evameva kho, bhikkhave, appakā te sattā ye hatthigavassavaḷavapaṭiggahaṇā paṭiviratā; atha kho eteva bahutarā sattā ye hatthigavassavaḷavapaṭiggahaṇā appaṭiviratā …pe…."
    },
    {
      "id": "sn56.90:1.2",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn56.90:1.3",
      "pali": "Tatiyaāmakadhaññapeyyālavaggo navamo."
    },
    {
      "id": "sn56.90:2.1",
      "pali": "Naccaṁ sayanaṁ rajataṁ,"
    },
    {
      "id": "sn56.90:2.2",
      "pali": "dhaññaṁ maṁsaṁ kumārikā;"
    },
    {
      "id": "sn56.90:2.3",
      "pali": "Dāsī ajeḷakañceva,"
    },
    {
      "id": "sn56.90:2.4",
      "pali": "kukkuṭasūkarahatthīti."
    }
  ]
}
