{
  "uid": "sn35.188",
  "title": "Ajjhattapaccuppannāniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.188:1.1",
      "pali": "“Cakkhu, bhikkhave, aniccaṁ paccuppannaṁ …pe… jivhā aniccā paccuppannā …pe… mano anicco paccuppanno."
    },
    {
      "id": "sn35.188:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.188:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
