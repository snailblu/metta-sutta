{
  "uid": "sn17.11",
  "title": "Suvaṇṇapātisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.11:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.11:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… adhigamāya."
    },
    {
      "id": "sn17.11:1.3",
      "pali": "Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "sn17.11:1.4",
      "pali": "‘na cāyamāyasmā suvaṇṇapātiyāpi rūpiyacuṇṇaparipūrāya hetu sampajānamusā bhāseyyā’ti."
    },
    {
      "id": "sn17.11:1.5",
      "pali": "Tamenaṁ passāmi aparena samayena lābhasakkārasilokena abhibhūtaṁ pariyādiṇṇacittaṁ sampajānamusā bhāsantaṁ."
    },
    {
      "id": "sn17.11:1.6",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.11:1.7",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.11:1.8",
      "pali": "Paṭhamaṁ."
    }
  ]
}
