{
  "uid": "sn14.29",
  "title": "Dasaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.29:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.29:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.29:1.3",
      "pali": "Micchādiṭṭhikā micchādiṭṭhikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.29:1.4",
      "pali": "micchāsaṅkappā …pe…"
    },
    {
      "id": "sn14.29:1.5",
      "pali": "micchāvācā …"
    },
    {
      "id": "sn14.29:1.6",
      "pali": "micchākammantā …"
    },
    {
      "id": "sn14.29:1.7",
      "pali": "micchāājīvā …"
    },
    {
      "id": "sn14.29:1.8",
      "pali": "micchāvāyāmā …"
    },
    {
      "id": "sn14.29:1.9",
      "pali": "micchāsatino …"
    },
    {
      "id": "sn14.29:1.10",
      "pali": "micchāsamādhino micchāsamādhīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.29:1.11",
      "pali": "micchāñāṇino micchāñāṇīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.29:1.12",
      "pali": "micchāvimuttino micchāvimuttīhi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.29:2.1",
      "pali": "Sammādiṭṭhikā sammādiṭṭhikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.29:2.2",
      "pali": "sammāsaṅkappā …pe…"
    },
    {
      "id": "sn14.29:2.3",
      "pali": "sammāvācā …"
    },
    {
      "id": "sn14.29:2.4",
      "pali": "sammākammantā …"
    },
    {
      "id": "sn14.29:2.5",
      "pali": "sammāājīvā …"
    },
    {
      "id": "sn14.29:2.6",
      "pali": "sammāvāyāmā …"
    },
    {
      "id": "sn14.29:2.7",
      "pali": "sammāsatino …"
    },
    {
      "id": "sn14.29:2.8",
      "pali": "sammāsamādhino …"
    },
    {
      "id": "sn14.29:2.9",
      "pali": "sammāñāṇino sammāñāṇīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.29:2.10",
      "pali": "sammāvimuttino sammāvimuttīhi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.29:2.11",
      "pali": "Sattamaṁ."
    },
    {
      "id": "sn14.29:2.12",
      "pali": "(Sabbattha atītānāgatapaccuppannaṁ kātabbaṁ.)"
    },
    {
      "id": "sn14.29:3.1",
      "pali": "Asamāhitaṁ dussīlaṁ,"
    },
    {
      "id": "sn14.29:3.2",
      "pali": "pañca sikkhāpadāni ca;"
    },
    {
      "id": "sn14.29:3.3",
      "pali": "Satta kammapathā vuttā,"
    },
    {
      "id": "sn14.29:3.4",
      "pali": "dasakammapathena ca;"
    },
    {
      "id": "sn14.29:3.5",
      "pali": "Chaṭṭhaṁ aṭṭhaṅgiko vutto,"
    },
    {
      "id": "sn14.29:3.6",
      "pali": "dasaṅgena ca sattamaṁ."
    },
    {
      "id": "sn14.29:3.7",
      "pali": "Kammapathavaggo tatiyo."
    }
  ]
}
