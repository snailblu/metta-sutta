{
  "uid": "sn48.20",
  "title": "Āsavakkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.20:1.1",
      "pali": "“Pañcimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.20:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn48.20:1.3",
      "pali": "Saddhindriyaṁ …pe… paññindriyaṁ—"
    },
    {
      "id": "sn48.20:1.4",
      "pali": "imāni kho, bhikkhave, pañcindriyāni."
    },
    {
      "id": "sn48.20:1.5",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ indriyānaṁ bhāvitattā bahulīkatattā bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti."
    },
    {
      "id": "sn48.20:1.6",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn48.20:1.7",
      "pali": "Mudutaravaggo dutiyo."
    },
    {
      "id": "sn48.20:2.1",
      "pali": "Paṭilābho tayo saṅkhittā,"
    },
    {
      "id": "sn48.20:2.2",
      "pali": "vitthārā apare tayo;"
    },
    {
      "id": "sn48.20:2.3",
      "pali": "Paṭipanno ca sampanno,"
    },
    {
      "id": "sn48.20:2.4",
      "pali": "dasamaṁ āsavakkhayanti."
    }
  ]
}
