{
  "uid": "sn2.14",
  "title": "Nandanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.14:1.1",
      "pali": "Ekamantaṁ ṭhito kho nandano devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.14:2.1",
      "pali": "“Pucchāmi taṁ gotama bhūripañña,"
    },
    {
      "id": "sn2.14:2.2",
      "pali": "Anāvaṭaṁ bhagavato ñāṇadassanaṁ;"
    },
    {
      "id": "sn2.14:2.3",
      "pali": "Kathaṁvidhaṁ sīlavantaṁ vadanti,"
    },
    {
      "id": "sn2.14:2.4",
      "pali": "Kathaṁvidhaṁ paññavantaṁ vadanti;"
    },
    {
      "id": "sn2.14:2.5",
      "pali": "Kathaṁvidho dukkhamaticca iriyati,"
    },
    {
      "id": "sn2.14:2.6",
      "pali": "Kathaṁvidhaṁ devatā pūjayantī”ti."
    },
    {
      "id": "sn2.14:3.1",
      "pali": "“Yo sīlavā paññavā bhāvitatto,"
    },
    {
      "id": "sn2.14:3.2",
      "pali": "Samāhito jhānarato satīmā;"
    },
    {
      "id": "sn2.14:3.3",
      "pali": "Sabbassa sokā vigatā pahīnā,"
    },
    {
      "id": "sn2.14:3.4",
      "pali": "Khīṇāsavo antimadehadhārī."
    },
    {
      "id": "sn2.14:4.1",
      "pali": "Tathāvidhaṁ sīlavantaṁ vadanti,"
    },
    {
      "id": "sn2.14:4.2",
      "pali": "Tathāvidhaṁ paññavantaṁ vadanti;"
    },
    {
      "id": "sn2.14:4.3",
      "pali": "Tathāvidho dukkhamaticca iriyati,"
    },
    {
      "id": "sn2.14:4.4",
      "pali": "Tathāvidhaṁ devatā pūjayantī”ti."
    }
  ]
}
