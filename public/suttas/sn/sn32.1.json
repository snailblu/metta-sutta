{
  "uid": "sn32.1",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn32.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn32.1:1.2",
      "pali": "“Valāhakakāyike vo, bhikkhave, deve desessāmi."
    },
    {
      "id": "sn32.1:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn32.1:1.4",
      "pali": "Katame ca, bhikkhave, valāhakakāyikā devā?"
    },
    {
      "id": "sn32.1:1.5",
      "pali": "Santi, bhikkhave, sītavalāhakā devā;"
    },
    {
      "id": "sn32.1:1.6",
      "pali": "santi uṇhavalāhakā devā;"
    },
    {
      "id": "sn32.1:1.7",
      "pali": "santi abbhavalāhakā devā;"
    },
    {
      "id": "sn32.1:1.8",
      "pali": "santi vātavalāhakā devā;"
    },
    {
      "id": "sn32.1:1.9",
      "pali": "santi vassavalāhakā devā—"
    },
    {
      "id": "sn32.1:1.10",
      "pali": "ime vuccanti, bhikkhave, ‘valāhakakāyikā devā’”ti."
    },
    {
      "id": "sn32.1:1.11",
      "pali": "Paṭhamaṁ."
    }
  ]
}
