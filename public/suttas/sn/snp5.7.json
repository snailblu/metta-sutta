{
  "uid": "snp5.7",
  "title": "Upasīvamāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.7:1.1",
      "pali": "“Eko ahaṁ sakka mahantamoghaṁ,"
    },
    {
      "id": "snp5.7:1.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "snp5.7:1.3",
      "pali": "Anissito no visahāmi tārituṁ;"
    },
    {
      "id": "snp5.7:1.4",
      "pali": "Ārammaṇaṁ brūhi samantacakkhu,"
    },
    {
      "id": "snp5.7:1.5",
      "pali": "Yaṁ nissito oghamimaṁ tareyyaṁ”."
    },
    {
      "id": "snp5.7:2.1",
      "pali": "“Ākiñcaññaṁ pekkhamāno satimā,"
    },
    {
      "id": "snp5.7:2.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "snp5.7:2.3",
      "pali": "Natthīti nissāya tarassu oghaṁ;"
    },
    {
      "id": "snp5.7:2.4",
      "pali": "Kāme pahāya virato kathāhi,"
    },
    {
      "id": "snp5.7:2.5",
      "pali": "Taṇhakkhayaṁ nattamahābhipassa”."
    },
    {
      "id": "snp5.7:3.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "snp5.7:3.2",
      "pali": "(iccāyasmā upasīvo)"
    },
    {
      "id": "snp5.7:3.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "snp5.7:3.4",
      "pali": "Saññāvimokkhe parame vimutto,"
    },
    {
      "id": "snp5.7:3.5",
      "pali": "Tiṭṭhe nu so tattha anānuyāyī”."
    },
    {
      "id": "snp5.7:4.1",
      "pali": "“Sabbesu kāmesu yo vītarāgo,"
    },
    {
      "id": "snp5.7:4.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "snp5.7:4.3",
      "pali": "Ākiñcaññaṁ nissito hitvā maññaṁ;"
    },
    {
      "id": "snp5.7:4.4",
      "pali": "Saññāvimokkhe parame vimutto,"
    },
    {
      "id": "snp5.7:4.5",
      "pali": "Tiṭṭheyya so tattha anānuyāyī”."
    },
    {
      "id": "snp5.7:5.1",
      "pali": "“Tiṭṭhe ce so tattha anānuyāyī,"
    },
    {
      "id": "snp5.7:5.2",
      "pali": "Pūgampi vassānaṁ samantacakkhu;"
    },
    {
      "id": "snp5.7:5.3",
      "pali": "Tattheva so sītisiyā vimutto,"
    },
    {
      "id": "snp5.7:5.4",
      "pali": "Cavetha viññāṇaṁ tathāvidhassa”."
    },
    {
      "id": "snp5.7:6.1",
      "pali": "“Accī yathā vātavegena khittā,"
    },
    {
      "id": "snp5.7:6.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "snp5.7:6.3",
      "pali": "Atthaṁ paleti na upeti saṅkhaṁ;"
    },
    {
      "id": "snp5.7:6.4",
      "pali": "Evaṁ munī nāmakāyā vimutto,"
    },
    {
      "id": "snp5.7:6.5",
      "pali": "Atthaṁ paleti na upeti saṅkhaṁ”."
    },
    {
      "id": "snp5.7:7.1",
      "pali": "“Atthaṅgato so uda vā so natthi,"
    },
    {
      "id": "snp5.7:7.2",
      "pali": "Udāhu ve sassatiyā arogo;"
    },
    {
      "id": "snp5.7:7.3",
      "pali": "Taṁ me munī sādhu viyākarohi,"
    },
    {
      "id": "snp5.7:7.4",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "snp5.7:8.1",
      "pali": "“Atthaṅgatassa na pamāṇamatthi,"
    },
    {
      "id": "snp5.7:8.2",
      "pali": "(upasīvāti bhagavā)"
    },
    {
      "id": "snp5.7:8.3",
      "pali": "Yena naṁ vajjuṁ taṁ tassa natthi;"
    },
    {
      "id": "snp5.7:8.4",
      "pali": "Sabbesu dhammesu samohatesu,"
    },
    {
      "id": "snp5.7:8.5",
      "pali": "Samūhatā vādapathāpi sabbe”ti."
    },
    {
      "id": "snp5.7:8.6",
      "pali": "Upasīvamāṇavapucchā chaṭṭhī."
    }
  ]
}
