{
  "uid": "snp5.3",
  "title": "Tissametteyyamāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.3:1.1",
      "pali": "“Kodha santusito loke,"
    },
    {
      "id": "snp5.3:1.2",
      "pali": "(iccāyasmā tissametteyyo)"
    },
    {
      "id": "snp5.3:1.3",
      "pali": "Kassa no santi iñjitā;"
    },
    {
      "id": "snp5.3:1.4",
      "pali": "Ko ubhantamabhiññāya,"
    },
    {
      "id": "snp5.3:1.5",
      "pali": "Majjhe mantā na lippati;"
    },
    {
      "id": "snp5.3:1.6",
      "pali": "Kaṁ brūsi mahāpurisoti,"
    },
    {
      "id": "snp5.3:1.7",
      "pali": "Ko idha sibbinimaccagā”."
    },
    {
      "id": "snp5.3:2.1",
      "pali": "“Kāmesu brahmacariyavā,"
    },
    {
      "id": "snp5.3:2.2",
      "pali": "(metteyyāti bhagavā)"
    },
    {
      "id": "snp5.3:2.3",
      "pali": "Vītataṇho sadā sato;"
    },
    {
      "id": "snp5.3:2.4",
      "pali": "Saṅkhāya nibbuto bhikkhu,"
    },
    {
      "id": "snp5.3:2.5",
      "pali": "Tassa no santi iñjitā."
    },
    {
      "id": "snp5.3:3.1",
      "pali": "So ubhantamabhiññāya,"
    },
    {
      "id": "snp5.3:3.2",
      "pali": "Majjhe mantā na lippati;"
    },
    {
      "id": "snp5.3:3.3",
      "pali": "Taṁ brūmi mahāpurisoti,"
    },
    {
      "id": "snp5.3:3.4",
      "pali": "So idha sibbinimaccagā”ti."
    },
    {
      "id": "snp5.3:3.5",
      "pali": "Tissametteyyamāṇavapucchā dutiyā."
    }
  ]
}
