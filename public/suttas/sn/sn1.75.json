{
  "uid": "sn1.75",
  "title": "Bhītāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.75:1.1",
      "pali": "“Kiṁsūdha bhītā janatā anekā,"
    },
    {
      "id": "sn1.75:1.2",
      "pali": "Maggo canekāyatanappavutto;"
    },
    {
      "id": "sn1.75:1.3",
      "pali": "Pucchāmi taṁ gotama bhūripañña,"
    },
    {
      "id": "sn1.75:1.4",
      "pali": "Kismiṁ ṭhito paralokaṁ na bhāye”ti."
    },
    {
      "id": "sn1.75:2.1",
      "pali": "“Vācaṁ manañca paṇidhāya sammā,"
    },
    {
      "id": "sn1.75:2.2",
      "pali": "Kāyena pāpāni akubbamāno;"
    },
    {
      "id": "sn1.75:2.3",
      "pali": "Bahvannapānaṁ gharamāvasanto,"
    },
    {
      "id": "sn1.75:2.4",
      "pali": "Saddho mudū saṁvibhāgī vadaññū;"
    },
    {
      "id": "sn1.75:2.5",
      "pali": "Etesu dhammesu ṭhito catūsu,"
    },
    {
      "id": "sn1.75:2.6",
      "pali": "Dhamme ṭhito paralokaṁ na bhāye”ti."
    }
  ]
}
