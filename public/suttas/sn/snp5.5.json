{
  "uid": "snp5.5",
  "title": "Mettagūmāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.5:1.1",
      "pali": "“Pucchāmi taṁ bhagavā brūhi me taṁ,"
    },
    {
      "id": "snp5.5:1.2",
      "pali": "(iccāyasmā mettagū)"
    },
    {
      "id": "snp5.5:1.3",
      "pali": "Maññāmi taṁ vedaguṁ bhāvitattaṁ;"
    },
    {
      "id": "snp5.5:1.4",
      "pali": "Kuto nu dukkhā samudāgatā ime,"
    },
    {
      "id": "snp5.5:1.5",
      "pali": "Ye keci lokasmimanekarūpā”."
    },
    {
      "id": "snp5.5:2.1",
      "pali": "“Dukkhassa ve maṁ pabhavaṁ apucchasi,"
    },
    {
      "id": "snp5.5:2.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "snp5.5:2.3",
      "pali": "Taṁ te pavakkhāmi yathā pajānaṁ;"
    },
    {
      "id": "snp5.5:2.4",
      "pali": "Upadhinidānā pabhavanti dukkhā,"
    },
    {
      "id": "snp5.5:2.5",
      "pali": "Ye keci lokasmimanekarūpā."
    },
    {
      "id": "snp5.5:3.1",
      "pali": "Yo ve avidvā upadhiṁ karoti,"
    },
    {
      "id": "snp5.5:3.2",
      "pali": "Punappunaṁ dukkhamupeti mando;"
    },
    {
      "id": "snp5.5:3.3",
      "pali": "Tasmā pajānaṁ upadhiṁ na kayirā,"
    },
    {
      "id": "snp5.5:3.4",
      "pali": "Dukkhassa jātippabhavānupassī”."
    },
    {
      "id": "snp5.5:4.1",
      "pali": "“Yaṁ taṁ apucchimha akittayī no,"
    },
    {
      "id": "snp5.5:4.2",
      "pali": "Aññaṁ taṁ pucchāma tadiṅgha brūhi;"
    },
    {
      "id": "snp5.5:4.3",
      "pali": "Kathaṁ nu dhīrā vitaranti oghaṁ,"
    },
    {
      "id": "snp5.5:4.4",
      "pali": "Jātiṁ jaraṁ sokapariddavañca;"
    },
    {
      "id": "snp5.5:4.5",
      "pali": "Taṁ me muni sādhu viyākarohi,"
    },
    {
      "id": "snp5.5:4.6",
      "pali": "Tathā hi te vidito esa dhammo”."
    },
    {
      "id": "snp5.5:5.1",
      "pali": "“Kittayissāmi te dhammaṁ,"
    },
    {
      "id": "snp5.5:5.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "snp5.5:5.3",
      "pali": "Diṭṭhe dhamme anītihaṁ;"
    },
    {
      "id": "snp5.5:5.4",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "snp5.5:5.5",
      "pali": "Tare loke visattikaṁ”."
    },
    {
      "id": "snp5.5:6.1",
      "pali": "“Tañcāhaṁ abhinandāmi,"
    },
    {
      "id": "snp5.5:6.2",
      "pali": "mahesi dhammamuttamaṁ;"
    },
    {
      "id": "snp5.5:6.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "snp5.5:6.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "snp5.5:7.1",
      "pali": "“Yaṁ kiñci sampajānāsi,"
    },
    {
      "id": "snp5.5:7.2",
      "pali": "(mettagūti bhagavā)"
    },
    {
      "id": "snp5.5:7.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "snp5.5:7.4",
      "pali": "Etesu nandiñca nivesanañca,"
    },
    {
      "id": "snp5.5:7.5",
      "pali": "Panujja viññāṇaṁ bhave na tiṭṭhe."
    },
    {
      "id": "snp5.5:8.1",
      "pali": "Evaṁvihārī sato appamatto,"
    },
    {
      "id": "snp5.5:8.2",
      "pali": "Bhikkhu caraṁ hitvā mamāyitāni;"
    },
    {
      "id": "snp5.5:8.3",
      "pali": "Jātiṁ jaraṁ sokapariddavañca,"
    },
    {
      "id": "snp5.5:8.4",
      "pali": "Idheva vidvā pajaheyya dukkhaṁ”."
    },
    {
      "id": "snp5.5:9.1",
      "pali": "“Etābhinandāmi vaco mahesino,"
    },
    {
      "id": "snp5.5:9.2",
      "pali": "Sukittitaṁ gotamanūpadhīkaṁ;"
    },
    {
      "id": "snp5.5:9.3",
      "pali": "Addhā hi bhagavā pahāsi dukkhaṁ,"
    },
    {
      "id": "snp5.5:9.4",
      "pali": "Tathā hi te vidito esa dhammo."
    },
    {
      "id": "snp5.5:10.1",
      "pali": "Te cāpi nūnappajaheyyu dukkhaṁ,"
    },
    {
      "id": "snp5.5:10.2",
      "pali": "Ye tvaṁ muni aṭṭhitaṁ ovadeyya;"
    },
    {
      "id": "snp5.5:10.3",
      "pali": "Taṁ taṁ namassāmi samecca nāga,"
    },
    {
      "id": "snp5.5:10.4",
      "pali": "Appeva maṁ bhagavā aṭṭhitaṁ ovadeyya”."
    },
    {
      "id": "snp5.5:11.1",
      "pali": "“Yaṁ brāhmaṇaṁ vedagumābhijaññā,"
    },
    {
      "id": "snp5.5:11.2",
      "pali": "Akiñcanaṁ kāmabhave asattaṁ;"
    },
    {
      "id": "snp5.5:11.3",
      "pali": "Addhā hi so oghamimaṁ atāri,"
    },
    {
      "id": "snp5.5:11.4",
      "pali": "Tiṇṇo ca pāraṁ akhilo akaṅkho."
    },
    {
      "id": "snp5.5:12.1",
      "pali": "Vidvā ca yo vedagū naro idha,"
    },
    {
      "id": "snp5.5:12.2",
      "pali": "Bhavābhave saṅgamimaṁ visajja;"
    },
    {
      "id": "snp5.5:12.3",
      "pali": "So vītataṇho anīgho nirāso,"
    },
    {
      "id": "snp5.5:12.4",
      "pali": "Atāri so jātijaranti brūmī”ti."
    },
    {
      "id": "snp5.5:12.5",
      "pali": "Mettagūmāṇavapucchā catutthī."
    }
  ]
}
