{
  "uid": "sn6.4",
  "title": "Bakabrahmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn6.4:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn6.4:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn6.4:1.3",
      "pali": "Tena kho pana samayena bakassa brahmuno evarūpaṁ pāpakaṁ diṭṭhigataṁ uppannaṁ hoti:"
    },
    {
      "id": "sn6.4:1.4",
      "pali": "“idaṁ niccaṁ, idaṁ dhuvaṁ, idaṁ sassataṁ, idaṁ kevalaṁ, idaṁ acavanadhammaṁ, idañhi na jāyati na jīyati na mīyati na cavati na upapajjati, ito ca panaññaṁ uttari nissaraṇaṁ natthī”ti."
    },
    {
      "id": "sn6.4:2.1",
      "pali": "Atha kho bhagavā bakassa brahmuno cetasā cetoparivitakkamaññāya—seyyathāpi nāma balavā puriso samiñjitaṁ vā bāhaṁ pasāreyya, pasāritaṁ vā bāhaṁ samiñjeyya; evameva—jetavane antarahito tasmiṁ brahmaloke pāturahosi."
    },
    {
      "id": "sn6.4:2.2",
      "pali": "Addasā kho bako brahmā bhagavantaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn6.4:2.3",
      "pali": "Disvāna bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn6.4:2.4",
      "pali": "“ehi kho, mārisa, svāgataṁ te, mārisa."
    },
    {
      "id": "sn6.4:2.5",
      "pali": "Cirassaṁ kho, mārisa, imaṁ pariyāyamakāsi yadidaṁ idhāgamanāya."
    },
    {
      "id": "sn6.4:2.6",
      "pali": "Idañhi, mārisa, niccaṁ, idaṁ dhuvaṁ, idaṁ sassataṁ, idaṁ kevalaṁ, idaṁ acavanadhammaṁ, idañhi na jāyati na jīyati na mīyati na cavati na upapajjati. Ito ca panaññaṁ uttari nissaraṇaṁ natthī”ti."
    },
    {
      "id": "sn6.4:3.1",
      "pali": "Evaṁ vutte, bhagavā bakaṁ brahmānaṁ etadavoca:"
    },
    {
      "id": "sn6.4:3.2",
      "pali": "“avijjāgato vata bho bako brahmā, avijjāgato vata bho bako brahmā."
    },
    {
      "id": "sn6.4:3.3",
      "pali": "Yatra hi nāma aniccaṁyeva samānaṁ niccanti vakkhati, adhuvaṁyeva samānaṁ dhuvanti vakkhati, asassataṁyeva samānaṁ sassatanti vakkhati, akevalaṁyeva samānaṁ kevalanti vakkhati, cavanadhammaṁyeva samānaṁ acavanadhammanti vakkhati."
    },
    {
      "id": "sn6.4:3.4",
      "pali": "Yattha ca pana jāyati ca jīyati ca mīyati ca cavati ca upapajjati ca, tañca tathā vakkhati:"
    },
    {
      "id": "sn6.4:3.5",
      "pali": "‘idañhi na jāyati na jīyati na mīyati na cavati na upapajjati’."
    },
    {
      "id": "sn6.4:3.6",
      "pali": "Santañca panaññaṁ uttari nissaraṇaṁ, ‘natthaññaṁ uttari nissaraṇan’ti vakkhatī”ti."
    },
    {
      "id": "sn6.4:4.1",
      "pali": "“Dvāsattati gotama puññakammā,"
    },
    {
      "id": "sn6.4:4.2",
      "pali": "Vasavattino jātijaraṁ atītā;"
    },
    {
      "id": "sn6.4:4.3",
      "pali": "Ayamantimā vedagū brahmupapatti,"
    },
    {
      "id": "sn6.4:4.4",
      "pali": "Asmābhijappanti janā anekā”ti."
    },
    {
      "id": "sn6.4:5.1",
      "pali": "“Appañhi etaṁ na hi dīghamāyu,"
    },
    {
      "id": "sn6.4:5.2",
      "pali": "Yaṁ tvaṁ baka maññasi dīghamāyuṁ;"
    },
    {
      "id": "sn6.4:5.3",
      "pali": "Sataṁ sahassānaṁ nirabbudānaṁ,"
    },
    {
      "id": "sn6.4:5.4",
      "pali": "Āyuṁ pajānāmi tavāhaṁ brahme”ti."
    },
    {
      "id": "sn6.4:6.1",
      "pali": "“Anantadassī bhagavāhamasmi,"
    },
    {
      "id": "sn6.4:6.2",
      "pali": "Jātijaraṁ sokamupātivatto;"
    },
    {
      "id": "sn6.4:6.3",
      "pali": "Kiṁ me purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "sn6.4:6.4",
      "pali": "Ācikkha me taṁ yamahaṁ vijaññā”ti."
    },
    {
      "id": "sn6.4:7.1",
      "pali": "“Yaṁ tvaṁ apāyesi bahū manusse,"
    },
    {
      "id": "sn6.4:7.2",
      "pali": "Pipāsite ghammani samparete;"
    },
    {
      "id": "sn6.4:7.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "sn6.4:7.4",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "sn6.4:8.1",
      "pali": "Yaṁ eṇikūlasmiṁ janaṁ gahītaṁ,"
    },
    {
      "id": "sn6.4:8.2",
      "pali": "Amocayī gayhakaṁ nīyamānaṁ;"
    },
    {
      "id": "sn6.4:8.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "sn6.4:8.4",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "sn6.4:9.1",
      "pali": "Gaṅgāya sotasmiṁ gahītanāvaṁ,"
    },
    {
      "id": "sn6.4:9.2",
      "pali": "Luddena nāgena manussakamyā;"
    },
    {
      "id": "sn6.4:9.3",
      "pali": "Pamocayittha balasā pasayha,"
    },
    {
      "id": "sn6.4:9.4",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ;"
    },
    {
      "id": "sn6.4:9.5",
      "pali": "Suttappabuddhova anussarāmi."
    },
    {
      "id": "sn6.4:10.1",
      "pali": "Kappo ca te baddhacaro ahosiṁ,"
    },
    {
      "id": "sn6.4:10.2",
      "pali": "Sambuddhimantaṁ vatinaṁ amaññi;"
    },
    {
      "id": "sn6.4:10.3",
      "pali": "Taṁ te purāṇaṁ vatasīlavattaṁ,"
    },
    {
      "id": "sn6.4:10.4",
      "pali": "Suttappabuddhova anussarāmī”ti."
    },
    {
      "id": "sn6.4:11.1",
      "pali": "“Addhā pajānāsi mametamāyuṁ,"
    },
    {
      "id": "sn6.4:11.2",
      "pali": "Aññepi jānāsi tathā hi buddho;"
    },
    {
      "id": "sn6.4:11.3",
      "pali": "Tathā hi tyāyaṁ jalitānubhāvo,"
    },
    {
      "id": "sn6.4:11.4",
      "pali": "Obhāsayaṁ tiṭṭhati brahmalokan”ti."
    }
  ]
}
