{
  "uid": "sn35.10",
  "title": "Bāhirāniccātītānāgatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.10:1.1",
      "pali": "“Rūpā, bhikkhave, aniccā atītānāgatā;"
    },
    {
      "id": "sn35.10:1.2",
      "pali": "ko pana vādo paccuppannānaṁ."
    },
    {
      "id": "sn35.10:1.3",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu rūpesu anapekkho hoti;"
    },
    {
      "id": "sn35.10:1.4",
      "pali": "anāgate rūpe nābhinandati;"
    },
    {
      "id": "sn35.10:1.5",
      "pali": "paccuppannānaṁ rūpānaṁ nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn35.10:1.6",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.10:1.7",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.10:1.8",
      "pali": "rasā …"
    },
    {
      "id": "sn35.10:1.9",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.10:1.10",
      "pali": "dhammā aniccā atītānāgatā;"
    },
    {
      "id": "sn35.10:1.11",
      "pali": "ko pana vādo paccuppannānaṁ."
    },
    {
      "id": "sn35.10:1.12",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu dhammesu anapekkho hoti;"
    },
    {
      "id": "sn35.10:1.13",
      "pali": "anāgate dhamme nābhinandati;"
    },
    {
      "id": "sn35.10:1.14",
      "pali": "paccuppannānaṁ dhammānaṁ nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn35.10:1.15",
      "pali": "Dasamaṁ."
    }
  ]
}
