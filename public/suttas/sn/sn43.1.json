{
  "uid": "sn43.1",
  "title": "Kāyagatāsatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn43.1:1.2",
      "pali": "“Asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.1:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.1:1.4",
      "pali": "Katamañca, bhikkhave, asaṅkhataṁ?"
    },
    {
      "id": "sn43.1:1.5",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn43.1:1.6",
      "pali": "idaṁ vuccati, bhikkhave, asaṅkhataṁ."
    },
    {
      "id": "sn43.1:1.7",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.1:1.8",
      "pali": "Kāyagatāsati."
    },
    {
      "id": "sn43.1:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.1:2.1",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā asaṅkhataṁ, desito asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.1:2.2",
      "pali": "Yaṁ, bhikkhave, satthārā karaṇīyaṁ sāvakānaṁ hitesinā anukampakena anukampaṁ upādāya, kataṁ vo taṁ mayā."
    },
    {
      "id": "sn43.1:2.3",
      "pali": "Etāni, bhikkhave, rukkhamūlāni, etāni suññāgārāni. Jhāyatha, bhikkhave, mā pamādattha; mā pacchā vippaṭisārino ahuvattha. Ayaṁ vo amhākaṁ anusāsanī”ti."
    },
    {
      "id": "sn43.1:2.4",
      "pali": "Paṭhamaṁ."
    }
  ]
}
