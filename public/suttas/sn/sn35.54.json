{
  "uid": "sn35.54",
  "title": "Saṁyojanappahānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.54:1.1",
      "pali": "“Kathaṁ nu kho, bhante, jānato, kathaṁ passato, saṁyojanā pahīyantī”ti?"
    },
    {
      "id": "sn35.54:1.2",
      "pali": "“Cakkhuṁ kho, bhikkhu, aniccato jānato passato saṁyojanā pahīyanti."
    },
    {
      "id": "sn35.54:1.3",
      "pali": "Rūpe …"
    },
    {
      "id": "sn35.54:1.4",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.54:1.5",
      "pali": "cakkhusamphassaṁ …"
    },
    {
      "id": "sn35.54:1.6",
      "pali": "yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccato jānato passato saṁyojanā pahīyanti."
    },
    {
      "id": "sn35.54:1.7",
      "pali": "Sotaṁ …"
    },
    {
      "id": "sn35.54:1.8",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn35.54:1.9",
      "pali": "jivhaṁ …"
    },
    {
      "id": "sn35.54:1.10",
      "pali": "kāyaṁ …"
    },
    {
      "id": "sn35.54:1.11",
      "pali": "manaṁ …"
    },
    {
      "id": "sn35.54:1.12",
      "pali": "dhamme …"
    },
    {
      "id": "sn35.54:1.13",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.54:1.14",
      "pali": "manosamphassaṁ …"
    },
    {
      "id": "sn35.54:1.15",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccato jānato passato saṁyojanā pahīyanti."
    },
    {
      "id": "sn35.54:1.16",
      "pali": "Evaṁ kho, bhikkhu, jānato evaṁ passato saṁyojanā pahīyantī”ti."
    },
    {
      "id": "sn35.54:1.17",
      "pali": "Dutiyaṁ."
    }
  ]
}
