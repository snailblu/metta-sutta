{
  "uid": "sn54.20",
  "title": "Āsavakkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn54.20:1.1",
      "pali": "“… Āsavānaṁ khayāya saṁvattati."
    },
    {
      "id": "sn54.20:1.2",
      "pali": "Kathaṁ bhāvito ca, bhikkhave, ānāpānassatisamādhi kathaṁ bahulīkato saṁyojanappahānāya saṁvattati …"
    },
    {
      "id": "sn54.20:1.3",
      "pali": "anusayasamugghātāya saṁvattati …"
    },
    {
      "id": "sn54.20:1.4",
      "pali": "addhānapariññāya saṁvattati …"
    },
    {
      "id": "sn54.20:1.5",
      "pali": "āsavānaṁ khayāya saṁvattati?"
    },
    {
      "id": "sn54.20:1.6",
      "pali": "Idha, bhikkhave, bhikkhu araññagato vā rukkhamūlagato vā …pe…"
    },
    {
      "id": "sn54.20:1.7",
      "pali": "paṭinissaggānupassī assasissāmīti sikkhati, paṭinissaggānupassī passasissāmīti sikkhati."
    },
    {
      "id": "sn54.20:1.8",
      "pali": "Evaṁ bhāvito kho, bhikkhave, ānāpānassatisamādhi evaṁ bahulīkato saṁyojanappahānāya saṁvattati …pe…"
    },
    {
      "id": "sn54.20:1.9",
      "pali": "anusayasamugghātāya saṁvattati …pe…"
    },
    {
      "id": "sn54.20:1.10",
      "pali": "addhānapariññāya saṁvattati …pe…"
    },
    {
      "id": "sn54.20:1.11",
      "pali": "āsavānaṁ khayāya saṁvattatī”ti."
    },
    {
      "id": "sn54.20:1.12",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn54.20:1.13",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn54.20:2.1",
      "pali": "Icchānaṅgalaṁ kaṅkheyyaṁ,"
    },
    {
      "id": "sn54.20:2.2",
      "pali": "ānandā apare duve;"
    },
    {
      "id": "sn54.20:2.3",
      "pali": "Bhikkhū saṁyojanānusayā,"
    },
    {
      "id": "sn54.20:2.4",
      "pali": "addhānaṁ āsavakkhayanti."
    },
    {
      "id": "sn54.20:2.5",
      "pali": "Ānāpānasaṁyuttaṁ dasamaṁ."
    }
  ]
}
