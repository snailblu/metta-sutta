{
  "uid": "sn17.1",
  "title": "Dāruṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn17.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn17.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn17.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn17.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn17.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn17.1:2.1",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko kaṭuko pharuso antarāyiko anuttarassa yogakkhemassa adhigamāya."
    },
    {
      "id": "sn17.1:2.2",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "sn17.1:2.3",
      "pali": "‘uppannaṁ lābhasakkārasilokaṁ pajahissāma, na ca no uppanno lābhasakkārasiloko cittaṁ pariyādāya ṭhassatī’ti."
    },
    {
      "id": "sn17.1:2.4",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.1:2.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
