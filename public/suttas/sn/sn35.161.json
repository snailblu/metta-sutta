{
  "uid": "sn35.161",
  "title": "Jīvakambavanapaṭisallānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.161:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati jīvakambavane."
    },
    {
      "id": "sn35.161:1.2",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi …pe…"
    },
    {
      "id": "sn35.161:1.3",
      "pali": "“paṭisallāne, bhikkhave, yogamāpajjatha."
    },
    {
      "id": "sn35.161:1.4",
      "pali": "Paṭisallīnassa, bhikkhave, bhikkhuno yathābhūtaṁ okkhāyati."
    },
    {
      "id": "sn35.161:1.5",
      "pali": "Kiñca yathābhūtaṁ okkhāyati?"
    },
    {
      "id": "sn35.161:1.6",
      "pali": "Cakkhuṁ aniccanti yathābhūtaṁ okkhāyati, rūpā aniccāti yathābhūtaṁ okkhāyati, cakkhuviññāṇaṁ aniccanti yathābhūtaṁ okkhāyati, cakkhusamphasso aniccoti yathābhūtaṁ okkhāyati, yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccanti yathābhūtaṁ okkhāyati …pe…"
    },
    {
      "id": "sn35.161:1.7",
      "pali": "mano aniccoti yathābhūtaṁ okkhāyati, dhammā …"
    },
    {
      "id": "sn35.161:1.8",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.161:1.9",
      "pali": "manosamphasso …"
    },
    {
      "id": "sn35.161:1.10",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccanti yathābhūtaṁ okkhāyati."
    },
    {
      "id": "sn35.161:1.11",
      "pali": "Paṭisallāne, bhikkhave, yogamāpajjatha."
    },
    {
      "id": "sn35.161:1.12",
      "pali": "Paṭisallīnassa, bhikkhave, bhikkhuno yathābhūtaṁ okkhāyatī”ti."
    },
    {
      "id": "sn35.161:1.13",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
