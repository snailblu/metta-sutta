{
  "uid": "sn27.2",
  "title": "Rūpasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.2:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.2:1.2",
      "pali": "“Yo, bhikkhave, rūpesu chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.2:1.3",
      "pali": "Yo saddesu …"
    },
    {
      "id": "sn27.2:1.4",
      "pali": "yo gandhesu …"
    },
    {
      "id": "sn27.2:1.5",
      "pali": "yo rasesu …"
    },
    {
      "id": "sn27.2:1.6",
      "pali": "yo phoṭṭhabbesu …"
    },
    {
      "id": "sn27.2:1.7",
      "pali": "yo dhammesu chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.2:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti."
    },
    {
      "id": "sn27.2:1.9",
      "pali": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.2:1.10",
      "pali": "Dutiyaṁ."
    }
  ]
}
