{
  "uid": "sn14.2",
  "title": "Phassanānattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.2:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.2:1.2",
      "pali": "“Dhātunānattaṁ, bhikkhave, paṭicca uppajjati phassanānattaṁ."
    },
    {
      "id": "sn14.2:1.3",
      "pali": "Katamañca, bhikkhave, dhātunānattaṁ?"
    },
    {
      "id": "sn14.2:1.4",
      "pali": "Cakkhudhātu sotadhātu ghānadhātu jivhādhātu kāyadhātu manodhātu—"
    },
    {
      "id": "sn14.2:1.5",
      "pali": "idaṁ vuccati, bhikkhave, dhātunānattaṁ."
    },
    {
      "id": "sn14.2:2.1",
      "pali": "Kathañca, bhikkhave, dhātunānattaṁ paṭicca uppajjati phassanānattaṁ?"
    },
    {
      "id": "sn14.2:2.2",
      "pali": "Cakkhudhātuṁ, bhikkhave, paṭicca uppajjati cakkhusamphasso."
    },
    {
      "id": "sn14.2:2.3",
      "pali": "Sotadhātuṁ paṭicca …"
    },
    {
      "id": "sn14.2:2.4",
      "pali": "ghānadhātuṁ paṭicca …"
    },
    {
      "id": "sn14.2:2.5",
      "pali": "jivhādhātuṁ paṭicca …"
    },
    {
      "id": "sn14.2:2.6",
      "pali": "kāyadhātuṁ paṭicca …"
    },
    {
      "id": "sn14.2:2.7",
      "pali": "manodhātuṁ paṭicca uppajjati manosamphasso."
    },
    {
      "id": "sn14.2:2.8",
      "pali": "Evaṁ kho, bhikkhave, dhātunānattaṁ paṭicca uppajjati phassanānattan”ti."
    },
    {
      "id": "sn14.2:2.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
