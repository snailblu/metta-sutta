{
  "uid": "sn45.165",
  "title": "Dukkhatāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.165:1.1",
      "pali": "“Tisso imā, bhikkhave, dukkhatā."
    },
    {
      "id": "sn45.165:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn45.165:1.3",
      "pali": "Dukkhadukkhatā, saṅkhāradukkhatā, vipariṇāmadukkhatā—"
    },
    {
      "id": "sn45.165:1.4",
      "pali": "imā kho, bhikkhave, tisso dukkhatā."
    },
    {
      "id": "sn45.165:1.5",
      "pali": "Imāsaṁ kho, bhikkhave, tissannaṁ dukkhatānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.165:1.6",
      "pali": "Pañcamaṁ."
    }
  ]
}
