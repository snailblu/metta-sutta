{
  "uid": "sn19.20",
  "title": "Pāpasāmaṇerasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.20:1.1",
      "pali": "“Addasaṁ sāmaṇeraṁ vehāsaṁ gacchantaṁ."
    },
    {
      "id": "sn19.20:1.2",
      "pali": "Tassa saṅghāṭipi ādittā …pe…"
    },
    {
      "id": "sn19.20:1.3",
      "pali": "pāpasāmaṇero ahosi …pe…."
    },
    {
      "id": "sn19.20:1.4",
      "pali": "Dasamaṁ."
    }
  ]
}
