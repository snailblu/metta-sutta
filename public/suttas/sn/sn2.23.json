{
  "uid": "sn2.23",
  "title": "Serīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.23:1.1",
      "pali": "Ekamantaṁ ṭhito kho serī devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.23:2.1",
      "pali": "“Annamevābhinandanti,"
    },
    {
      "id": "sn2.23:2.2",
      "pali": "ubhaye devamānusā;"
    },
    {
      "id": "sn2.23:2.3",
      "pali": "Atha ko nāma so yakkho,"
    },
    {
      "id": "sn2.23:2.4",
      "pali": "yaṁ annaṁ nābhinandatī”ti."
    },
    {
      "id": "sn2.23:3.1",
      "pali": "“Ye naṁ dadanti saddhāya,"
    },
    {
      "id": "sn2.23:3.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "sn2.23:3.3",
      "pali": "Tameva annaṁ bhajati,"
    },
    {
      "id": "sn2.23:3.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "sn2.23:4.1",
      "pali": "Tasmā vineyya maccheraṁ,"
    },
    {
      "id": "sn2.23:4.2",
      "pali": "dajjā dānaṁ malābhibhū;"
    },
    {
      "id": "sn2.23:4.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "sn2.23:4.4",
      "pali": "patiṭṭhā honti pāṇinan”ti."
    },
    {
      "id": "sn2.23:5.1",
      "pali": "“Acchariyaṁ, bhante, abbhutaṁ, bhante."
    },
    {
      "id": "sn2.23:5.2",
      "pali": "Yāvasubhāsitamidaṁ, bhante, bhagavatā:"
    },
    {
      "id": "sn2.23:6.1",
      "pali": "‘Ye naṁ dadanti saddhāya,"
    },
    {
      "id": "sn2.23:6.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "sn2.23:6.3",
      "pali": "Tameva annaṁ bhajati,"
    },
    {
      "id": "sn2.23:6.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "sn2.23:7.1",
      "pali": "Tasmā vineyya maccheraṁ,"
    },
    {
      "id": "sn2.23:7.2",
      "pali": "dajjā dānaṁ malābhibhū;"
    },
    {
      "id": "sn2.23:7.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "sn2.23:7.4",
      "pali": "patiṭṭhā honti pāṇinan’ti."
    },
    {
      "id": "sn2.23:8.1",
      "pali": "Bhūtapubbāhaṁ, bhante, sirī nāma rājā ahosiṁ dāyako dānapati dānassa vaṇṇavādī."
    },
    {
      "id": "sn2.23:8.2",
      "pali": "Tassa mayhaṁ, bhante, catūsu dvāresu dānaṁ dīyittha samaṇabrāhmaṇakapaṇaddhikavanibbakayācakānaṁ."
    },
    {
      "id": "sn2.23:8.3",
      "pali": "Atha kho maṁ, bhante, itthāgāraṁ upasaṅkamitvā etadavoca:"
    },
    {
      "id": "sn2.23:8.4",
      "pali": "‘devassa kho dānaṁ dīyati; amhākaṁ dānaṁ na dīyati."
    },
    {
      "id": "sn2.23:8.5",
      "pali": "Sādhu mayampi devaṁ nissāya dānāni dadeyyāma, puññāni kareyyāmā’ti."
    },
    {
      "id": "sn2.23:8.6",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn2.23:8.7",
      "pali": "‘ahaṁ khosmi dāyako dānapati dānassa vaṇṇavādī."
    },
    {
      "id": "sn2.23:8.8",
      "pali": "Dānaṁ dassāmāti vadante kinti vadeyyan’ti?"
    },
    {
      "id": "sn2.23:8.9",
      "pali": "So khvāhaṁ, bhante, paṭhamaṁ dvāraṁ itthāgārassa adāsiṁ."
    },
    {
      "id": "sn2.23:8.10",
      "pali": "Tattha itthāgārassa dānaṁ dīyittha; mama dānaṁ paṭikkami."
    },
    {
      "id": "sn2.23:9.1",
      "pali": "Atha kho maṁ, bhante, khattiyā anuyantā upasaṅkamitvā etadavocuṁ:"
    },
    {
      "id": "sn2.23:9.2",
      "pali": "‘devassa kho dānaṁ dīyati; itthāgārassa dānaṁ dīyati; amhākaṁ dānaṁ na dīyati."
    },
    {
      "id": "sn2.23:9.3",
      "pali": "Sādhu mayampi devaṁ nissāya dānāni dadeyyāma, puññāni kareyyāmā’ti."
    },
    {
      "id": "sn2.23:9.4",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn2.23:9.5",
      "pali": "‘ahaṁ khosmi dāyako dānapati dānassa vaṇṇavādī."
    },
    {
      "id": "sn2.23:9.6",
      "pali": "Dānaṁ dassāmāti vadante kinti vadeyyan’ti?"
    },
    {
      "id": "sn2.23:9.7",
      "pali": "So khvāhaṁ, bhante, dutiyaṁ dvāraṁ khattiyānaṁ anuyantānaṁ adāsiṁ."
    },
    {
      "id": "sn2.23:9.8",
      "pali": "Tattha khattiyānaṁ anuyantānaṁ dānaṁ dīyittha, mama dānaṁ paṭikkami."
    },
    {
      "id": "sn2.23:10.1",
      "pali": "Atha kho maṁ, bhante, balakāyo upasaṅkamitvā etadavoca:"
    },
    {
      "id": "sn2.23:10.2",
      "pali": "‘devassa kho dānaṁ dīyati; itthāgārassa dānaṁ dīyati; khattiyānaṁ anuyantānaṁ dānaṁ dīyati; amhākaṁ dānaṁ na dīyati."
    },
    {
      "id": "sn2.23:10.3",
      "pali": "Sādhu mayampi devaṁ nissāya dānāni dadeyyāma, puññāni kareyyāmā’ti."
    },
    {
      "id": "sn2.23:10.4",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn2.23:10.5",
      "pali": "‘ahaṁ khosmi dāyako dānapati dānassa vaṇṇavādī."
    },
    {
      "id": "sn2.23:10.6",
      "pali": "Dānaṁ dassāmāti vadante kinti vadeyyan’ti?"
    },
    {
      "id": "sn2.23:10.7",
      "pali": "So khvāhaṁ, bhante, tatiyaṁ dvāraṁ balakāyassa adāsiṁ."
    },
    {
      "id": "sn2.23:10.8",
      "pali": "Tattha balakāyassa dānaṁ dīyittha, mama dānaṁ paṭikkami."
    },
    {
      "id": "sn2.23:11.1",
      "pali": "Atha kho maṁ, bhante, brāhmaṇagahapatikā upasaṅkamitvā etadavocuṁ:"
    },
    {
      "id": "sn2.23:11.2",
      "pali": "‘devassa kho dānaṁ dīyati; itthāgārassa dānaṁ dīyati; khattiyānaṁ anuyantānaṁ dānaṁ dīyati; balakāyassa dānaṁ dīyati; amhākaṁ dānaṁ na dīyati."
    },
    {
      "id": "sn2.23:11.3",
      "pali": "Sādhu mayampi devaṁ nissāya dānāni dadeyyāma, puññāni kareyyāmā’ti."
    },
    {
      "id": "sn2.23:11.4",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn2.23:11.5",
      "pali": "‘ahaṁ khosmi dāyako dānapati dānassa vaṇṇavādī."
    },
    {
      "id": "sn2.23:11.6",
      "pali": "Dānaṁ dassāmāti vadante kinti vadeyyan’ti?"
    },
    {
      "id": "sn2.23:11.7",
      "pali": "So khvāhaṁ, bhante, catutthaṁ dvāraṁ brāhmaṇagahapatikānaṁ adāsiṁ."
    },
    {
      "id": "sn2.23:11.8",
      "pali": "Tattha brāhmaṇagahapatikānaṁ dānaṁ dīyittha, mama dānaṁ paṭikkami."
    },
    {
      "id": "sn2.23:12.1",
      "pali": "Atha kho maṁ, bhante, purisā upasaṅkamitvā etadavocuṁ:"
    },
    {
      "id": "sn2.23:12.2",
      "pali": "‘na kho dāni devassa koci dānaṁ dīyatī’ti."
    },
    {
      "id": "sn2.23:12.3",
      "pali": "Evaṁ vuttāhaṁ, bhante, te purise etadavocaṁ:"
    },
    {
      "id": "sn2.23:12.4",
      "pali": "‘tena hi, bhaṇe, yo bāhiresu janapadesu āyo sañjāyati tato upaḍḍhaṁ antepure pavesetha, upaḍḍhaṁ tattheva dānaṁ detha samaṇabrāhmaṇakapaṇaddhikavanibbakayācakānan’ti."
    },
    {
      "id": "sn2.23:12.5",
      "pali": "So khvāhaṁ, bhante, evaṁ dīgharattaṁ katānaṁ puññānaṁ evaṁ dīgharattaṁ katānaṁ kusalānaṁ dhammānaṁ pariyantaṁ nādhigacchāmi—"
    },
    {
      "id": "sn2.23:12.6",
      "pali": "ettakaṁ puññanti vā ettako puññavipākoti vā ettakaṁ sagge ṭhātabbanti vāti."
    },
    {
      "id": "sn2.23:12.7",
      "pali": "Acchariyaṁ, bhante, abbhutaṁ, bhante."
    },
    {
      "id": "sn2.23:12.8",
      "pali": "Yāvasubhāsitamidaṁ, bhante, bhagavatā:"
    },
    {
      "id": "sn2.23:13.1",
      "pali": "‘Ye naṁ dadanti saddhāya,"
    },
    {
      "id": "sn2.23:13.2",
      "pali": "vippasannena cetasā;"
    },
    {
      "id": "sn2.23:13.3",
      "pali": "Tameva annaṁ bhajati,"
    },
    {
      "id": "sn2.23:13.4",
      "pali": "asmiṁ loke paramhi ca."
    },
    {
      "id": "sn2.23:14.1",
      "pali": "Tasmā vineyya maccheraṁ,"
    },
    {
      "id": "sn2.23:14.2",
      "pali": "dajjā dānaṁ malābhibhū;"
    },
    {
      "id": "sn2.23:14.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "sn2.23:14.4",
      "pali": "patiṭṭhā honti pāṇinan’”ti."
    }
  ]
}
