{
  "uid": "sn37.34",
  "title": "Vaḍḍhīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn37.34:1.1",
      "pali": "“Pañcahi, bhikkhave, vaḍḍhīhi vaḍḍhamānā ariyasāvikā ariyāya vaḍḍhiyā vaḍḍhati sārādāyinī ca hoti varādāyinī ca kāyassa."
    },
    {
      "id": "sn37.34:1.2",
      "pali": "Katamehi pañcahi?"
    },
    {
      "id": "sn37.34:1.3",
      "pali": "Saddhāya vaḍḍhati, sīlena vaḍḍhati, sutena vaḍḍhati, cāgena vaḍḍhati, paññāya vaḍḍhati—"
    },
    {
      "id": "sn37.34:1.4",
      "pali": "imehi kho, bhikkhave, pañcahi vaḍḍhīhi vaḍḍhamānā ariyasāvikā ariyāya vaḍḍhiyā vaḍḍhati, sārādāyinī ca hoti, varādāyinī ca kāyassāti."
    },
    {
      "id": "sn37.34:2.1",
      "pali": "Saddhāya sīlena ca yādha vaḍḍhati,"
    },
    {
      "id": "sn37.34:2.2",
      "pali": "Paññāya cāgena sutena cūbhayaṁ;"
    },
    {
      "id": "sn37.34:2.3",
      "pali": "Sā tādisī sīlavatī upāsikā,"
    },
    {
      "id": "sn37.34:2.4",
      "pali": "Ādīyati sāramidheva attano”ti."
    },
    {
      "id": "sn37.34:2.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn37.34:2.6",
      "pali": "Balavaggo tatiyo."
    },
    {
      "id": "sn37.34:3.1",
      "pali": "Visāradā pasayha abhibhuyya,"
    },
    {
      "id": "sn37.34:3.2",
      "pali": "Ekaṁ aṅgena pañcamaṁ;"
    },
    {
      "id": "sn37.34:3.3",
      "pali": "Nāsenti hetu ṭhānañca,"
    },
    {
      "id": "sn37.34:3.4",
      "pali": "Visārado vaḍḍhinā dasāti."
    },
    {
      "id": "sn37.34:3.5",
      "pali": "Mātugāmasaṁyuttaṁ samattaṁ."
    }
  ]
}
