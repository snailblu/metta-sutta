{
  "uid": "sn1.63",
  "title": "Taṇhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.63:1.1",
      "pali": "“Kenassu nīyati loko,"
    },
    {
      "id": "sn1.63:1.2",
      "pali": "kenassu parikassati;"
    },
    {
      "id": "sn1.63:1.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn1.63:1.4",
      "pali": "sabbeva vasamanvagū”ti."
    },
    {
      "id": "sn1.63:2.1",
      "pali": "“Taṇhāya nīyati loko,"
    },
    {
      "id": "sn1.63:2.2",
      "pali": "taṇhāya parikassati;"
    },
    {
      "id": "sn1.63:2.3",
      "pali": "Taṇhāya ekadhammassa,"
    },
    {
      "id": "sn1.63:2.4",
      "pali": "sabbeva vasamanvagū”ti."
    }
  ]
}
