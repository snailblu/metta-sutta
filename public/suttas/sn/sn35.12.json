{
  "uid": "sn35.12",
  "title": "Bāhirānattātītānāgatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.12:1.1",
      "pali": "“Rūpā, bhikkhave, anattā atītānāgatā;"
    },
    {
      "id": "sn35.12:1.2",
      "pali": "ko pana vādo paccuppannānaṁ."
    },
    {
      "id": "sn35.12:1.3",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu rūpesu anapekkho hoti;"
    },
    {
      "id": "sn35.12:1.4",
      "pali": "anāgate rūpe nābhinandati;"
    },
    {
      "id": "sn35.12:1.5",
      "pali": "paccuppannānaṁ rūpānaṁ nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn35.12:1.6",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.12:1.7",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.12:1.8",
      "pali": "rasā …"
    },
    {
      "id": "sn35.12:1.9",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.12:1.10",
      "pali": "dhammā anattā atītānāgatā;"
    },
    {
      "id": "sn35.12:1.11",
      "pali": "ko pana vādo paccuppannānaṁ."
    },
    {
      "id": "sn35.12:1.12",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītesu dhammesu anapekkho hoti;"
    },
    {
      "id": "sn35.12:1.13",
      "pali": "anāgate dhamme nābhinandati;"
    },
    {
      "id": "sn35.12:1.14",
      "pali": "paccuppannānaṁ dhammānaṁ nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn35.12:1.15",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn35.12:1.16",
      "pali": "Aniccavaggo paṭhamo."
    },
    {
      "id": "sn35.12:2.1",
      "pali": "Aniccaṁ dukkhaṁ anattā ca,"
    },
    {
      "id": "sn35.12:2.2",
      "pali": "tayo ajjhattabāhirā;"
    },
    {
      "id": "sn35.12:2.3",
      "pali": "Yadaniccena tayo vuttā,"
    },
    {
      "id": "sn35.12:2.4",
      "pali": "te te ajjhattabāhirāti."
    }
  ]
}
