{
  "uid": "sn35.110",
  "title": "Upādāniyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.110:1.1",
      "pali": "“Upādāniye ca, bhikkhave, dhamme desessāmi upādānañca."
    },
    {
      "id": "sn35.110:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.110:1.3",
      "pali": "Katame ca, bhikkhave, upādāniyā dhammā, katamañca upādānaṁ?"
    },
    {
      "id": "sn35.110:1.4",
      "pali": "Cakkhuṁ, bhikkhave, upādāniyo dhammo."
    },
    {
      "id": "sn35.110:1.5",
      "pali": "Yo tattha chandarāgo, taṁ tattha upādānaṁ …pe…"
    },
    {
      "id": "sn35.110:1.6",
      "pali": "jivhā upādāniyo dhammo …pe…"
    },
    {
      "id": "sn35.110:1.7",
      "pali": "mano upādāniyo dhammo."
    },
    {
      "id": "sn35.110:1.8",
      "pali": "Yo tattha chandarāgo, taṁ tattha upādānaṁ."
    },
    {
      "id": "sn35.110:1.9",
      "pali": "Ime vuccanti, bhikkhave, upādāniyā dhammā, idaṁ upādānan”ti."
    },
    {
      "id": "sn35.110:1.10",
      "pali": "Sattamaṁ."
    }
  ]
}
