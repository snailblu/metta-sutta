{
  "uid": "sn51.25",
  "title": "Paṭhamaphalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.25:1.1",
      "pali": "“Cattārome, bhikkhave, iddhipādā."
    },
    {
      "id": "sn51.25:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.25:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.25:1.4",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.25:1.5",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.25:1.6",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.25:1.7",
      "pali": "ime kho, bhikkhave, cattāro iddhipādā."
    },
    {
      "id": "sn51.25:1.8",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ iddhipādānaṁ bhāvitattā bahulīkatattā bhikkhunā dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "sn51.25:1.9",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "sn51.25:1.10",
      "pali": "Pañcamaṁ."
    }
  ]
}
