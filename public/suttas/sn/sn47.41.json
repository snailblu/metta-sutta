{
  "uid": "sn47.41",
  "title": "Amatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.41:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn47.41:1.2",
      "pali": "“Catūsu, bhikkhave, satipaṭṭhānesu suppatiṭṭhitacittā viharatha."
    },
    {
      "id": "sn47.41:1.3",
      "pali": "Mā vo amataṁ panassa."
    },
    {
      "id": "sn47.41:1.4",
      "pali": "Katamesu catūsu?"
    },
    {
      "id": "sn47.41:1.5",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.41:1.6",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.41:1.7",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.41:1.8",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.41:1.9",
      "pali": "Imesu, bhikkhave, catūsu satipaṭṭhānesu suppatiṭṭhitacittā viharatha."
    },
    {
      "id": "sn47.41:1.10",
      "pali": "Mā vo amataṁ panassā”ti."
    },
    {
      "id": "sn47.41:1.11",
      "pali": "Paṭhamaṁ."
    }
  ]
}
