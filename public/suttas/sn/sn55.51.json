{
  "uid": "sn55.51",
  "title": "Sagāthakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.51:1.1",
      "pali": "“Catūhi, bhikkhave, dhammehi samannāgato ariyasāvako sotāpanno hoti avinipātadhammo niyato sambodhiparāyaṇo."
    },
    {
      "id": "sn55.51:2.1",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "sn55.51:2.2",
      "pali": "Idha, bhikkhave, ariyasāvako buddhe aveccappasādena samannāgato hoti—"
    },
    {
      "id": "sn55.51:2.3",
      "pali": "itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavāti."
    },
    {
      "id": "sn55.51:2.4",
      "pali": "Dhamme …pe…"
    },
    {
      "id": "sn55.51:2.5",
      "pali": "saṅghe …pe…"
    },
    {
      "id": "sn55.51:2.6",
      "pali": "ariyakantehi sīlehi samannāgato hoti akhaṇḍehi …pe… samādhisaṁvattanikehi."
    },
    {
      "id": "sn55.51:2.7",
      "pali": "Imehi kho, bhikkhave, catūhi dhammehi samannāgato ariyasāvako sotāpanno hoti avinipātadhammo niyato sambodhiparāyaṇo”ti."
    },
    {
      "id": "sn55.51:2.8",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn55.51:2.9",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn55.51:3.1",
      "pali": "“Yassa saddhā tathāgate,"
    },
    {
      "id": "sn55.51:3.2",
      "pali": "acalā suppatiṭṭhitā;"
    },
    {
      "id": "sn55.51:3.3",
      "pali": "Sīlañca yassa kalyāṇaṁ,"
    },
    {
      "id": "sn55.51:3.4",
      "pali": "ariyakantaṁ pasaṁsitaṁ."
    },
    {
      "id": "sn55.51:4.1",
      "pali": "Saṅghe pasādo yassatthi,"
    },
    {
      "id": "sn55.51:4.2",
      "pali": "ujubhūtañca dassanaṁ;"
    },
    {
      "id": "sn55.51:4.3",
      "pali": "Adaliddoti taṁ āhu,"
    },
    {
      "id": "sn55.51:4.4",
      "pali": "amoghaṁ tassa jīvitaṁ."
    },
    {
      "id": "sn55.51:5.1",
      "pali": "Tasmā saddhañca sīlañca,"
    },
    {
      "id": "sn55.51:5.2",
      "pali": "pasādaṁ dhammadassanaṁ;"
    },
    {
      "id": "sn55.51:5.3",
      "pali": "Anuyuñjetha medhāvī,"
    },
    {
      "id": "sn55.51:5.4",
      "pali": "saraṁ buddhānasāsanan”ti."
    },
    {
      "id": "sn55.51:5.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
