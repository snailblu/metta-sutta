{
  "uid": "sn8.12",
  "title": "Vaṅgīsasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.12:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā vaṅgīso sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn8.12:1.2",
      "pali": "Tena kho pana samayena āyasmā vaṅgīso aciraarahattappatto hutvā vimuttisukhaṁ paṭisaṁvedī tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn8.12:2.1",
      "pali": "“Kāveyyamattā vicarimha pubbe,"
    },
    {
      "id": "sn8.12:2.2",
      "pali": "Gāmā gāmaṁ purā puraṁ;"
    },
    {
      "id": "sn8.12:2.3",
      "pali": "Athaddasāma sambuddhaṁ,"
    },
    {
      "id": "sn8.12:2.4",
      "pali": "Saddhā no upapajjatha."
    },
    {
      "id": "sn8.12:3.1",
      "pali": "So me dhammamadesesi,"
    },
    {
      "id": "sn8.12:3.2",
      "pali": "khandhāyatanadhātuyo;"
    },
    {
      "id": "sn8.12:3.3",
      "pali": "Tassāhaṁ dhammaṁ sutvāna,"
    },
    {
      "id": "sn8.12:3.4",
      "pali": "pabbajiṁ anagāriyaṁ."
    },
    {
      "id": "sn8.12:4.1",
      "pali": "Bahunnaṁ vata atthāya,"
    },
    {
      "id": "sn8.12:4.2",
      "pali": "bodhiṁ ajjhagamā muni;"
    },
    {
      "id": "sn8.12:4.3",
      "pali": "Bhikkhūnaṁ bhikkhunīnañca,"
    },
    {
      "id": "sn8.12:4.4",
      "pali": "ye niyāmagataddasā."
    },
    {
      "id": "sn8.12:5.1",
      "pali": "Svāgataṁ vata me āsi,"
    },
    {
      "id": "sn8.12:5.2",
      "pali": "mama buddhassa santike;"
    },
    {
      "id": "sn8.12:5.3",
      "pali": "Tisso vijjā anuppattā,"
    },
    {
      "id": "sn8.12:5.4",
      "pali": "kataṁ buddhassa sāsanaṁ."
    },
    {
      "id": "sn8.12:6.1",
      "pali": "Pubbenivāsaṁ jānāmi,"
    },
    {
      "id": "sn8.12:6.2",
      "pali": "Dibbacakkhuṁ visodhitaṁ;"
    },
    {
      "id": "sn8.12:6.3",
      "pali": "Tevijjo iddhipattomhi,"
    },
    {
      "id": "sn8.12:6.4",
      "pali": "Cetopariyāyakovido”ti."
    },
    {
      "id": "sn8.12:7.1",
      "pali": "Nikkhantaṁ arati ceva,"
    },
    {
      "id": "sn8.12:7.2",
      "pali": "pesalā atimaññanā;"
    },
    {
      "id": "sn8.12:7.3",
      "pali": "Ānandena subhāsitā,"
    },
    {
      "id": "sn8.12:7.4",
      "pali": "sāriputtapavāraṇā;"
    },
    {
      "id": "sn8.12:7.5",
      "pali": "Parosahassaṁ koṇḍañño,"
    },
    {
      "id": "sn8.12:7.6",
      "pali": "moggallānena gaggarā;"
    },
    {
      "id": "sn8.12:7.7",
      "pali": "Vaṅgīsena dvādasāti."
    },
    {
      "id": "sn8.12:7.8",
      "pali": "Vaṅgīsasaṁyuttaṁ samattaṁ."
    }
  ]
}
