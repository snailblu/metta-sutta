{
  "uid": "snp1.3",
  "title": "Khaggavisāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp1.3:1.1",
      "pali": "“Sabbesu bhūtesu nidhāya daṇḍaṁ,"
    },
    {
      "id": "snp1.3:1.2",
      "pali": "Aviheṭhayaṁ aññatarampi tesaṁ;"
    },
    {
      "id": "snp1.3:1.3",
      "pali": "Na puttamiccheyya kuto sahāyaṁ,"
    },
    {
      "id": "snp1.3:1.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:2.1",
      "pali": "“Saṁsaggajātassa bhavanti snehā,"
    },
    {
      "id": "snp1.3:2.2",
      "pali": "Snehanvayaṁ dukkhamidaṁ pahoti;"
    },
    {
      "id": "snp1.3:2.3",
      "pali": "Ādīnavaṁ snehajaṁ pekkhamāno,"
    },
    {
      "id": "snp1.3:2.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:3.1",
      "pali": "“Mitte suhajje anukampamāno,"
    },
    {
      "id": "snp1.3:3.2",
      "pali": "Hāpeti atthaṁ paṭibaddhacitto;"
    },
    {
      "id": "snp1.3:3.3",
      "pali": "Etaṁ bhayaṁ santhave pekkhamāno,"
    },
    {
      "id": "snp1.3:3.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:4.1",
      "pali": "“Vaṁso visālova yathā visatto,"
    },
    {
      "id": "snp1.3:4.2",
      "pali": "Puttesu dāresu ca yā apekkhā;"
    },
    {
      "id": "snp1.3:4.3",
      "pali": "Vaṁsakkaḷīrova asajjamāno,"
    },
    {
      "id": "snp1.3:4.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:5.1",
      "pali": "“Migo araññamhi yathā abaddho,"
    },
    {
      "id": "snp1.3:5.2",
      "pali": "Yenicchakaṁ gacchati gocarāya;"
    },
    {
      "id": "snp1.3:5.3",
      "pali": "Viññū naro seritaṁ pekkhamāno,"
    },
    {
      "id": "snp1.3:5.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:6.1",
      "pali": "“Āmantanā hoti sahāyamajjhe,"
    },
    {
      "id": "snp1.3:6.2",
      "pali": "Vāse ṭhāne gamane cārikāya;"
    },
    {
      "id": "snp1.3:6.3",
      "pali": "Anabhijjhitaṁ seritaṁ pekkhamāno,"
    },
    {
      "id": "snp1.3:6.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:7.1",
      "pali": "“Khiḍḍā ratī hoti sahāyamajjhe,"
    },
    {
      "id": "snp1.3:7.2",
      "pali": "Puttesu ca vipulaṁ hoti pemaṁ;"
    },
    {
      "id": "snp1.3:7.3",
      "pali": "Piyavippayogaṁ vijigucchamāno,"
    },
    {
      "id": "snp1.3:7.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:8.1",
      "pali": "“Cātuddiso appaṭigho ca hoti,"
    },
    {
      "id": "snp1.3:8.2",
      "pali": "Santussamāno itarītarena;"
    },
    {
      "id": "snp1.3:8.3",
      "pali": "Parissayānaṁ sahitā achambhī,"
    },
    {
      "id": "snp1.3:8.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:9.1",
      "pali": "“Dussaṅgahā pabbajitāpi eke,"
    },
    {
      "id": "snp1.3:9.2",
      "pali": "Atho gahaṭṭhā gharamāvasantā;"
    },
    {
      "id": "snp1.3:9.3",
      "pali": "Appossukko paraputtesu hutvā,"
    },
    {
      "id": "snp1.3:9.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:10.1",
      "pali": "“Oropayitvā gihibyañjanāni,"
    },
    {
      "id": "snp1.3:10.2",
      "pali": "Sañchinnapatto yathā koviḷāro;"
    },
    {
      "id": "snp1.3:10.3",
      "pali": "Chetvāna vīro gihibandhanāni,"
    },
    {
      "id": "snp1.3:10.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:11.1",
      "pali": "“Sace labhetha nipakaṁ sahāyaṁ,"
    },
    {
      "id": "snp1.3:11.2",
      "pali": "Saddhiṁ caraṁ sādhuvihāridhīraṁ;"
    },
    {
      "id": "snp1.3:11.3",
      "pali": "Abhibhuyya sabbāni parissayāni,"
    },
    {
      "id": "snp1.3:11.4",
      "pali": "Careyya tenattamano satīmā”."
    },
    {
      "id": "snp1.3:12.1",
      "pali": "“No ce labhetha nipakaṁ sahāyaṁ,"
    },
    {
      "id": "snp1.3:12.2",
      "pali": "Saddhiṁ caraṁ sādhuvihāridhīraṁ;"
    },
    {
      "id": "snp1.3:12.3",
      "pali": "Rājāva raṭṭhaṁ vijitaṁ pahāya,"
    },
    {
      "id": "snp1.3:12.4",
      "pali": "Eko care mātaṅgaraññeva nāgo”."
    },
    {
      "id": "snp1.3:13.1",
      "pali": "“Addhā pasaṁsāma sahāyasampadaṁ,"
    },
    {
      "id": "snp1.3:13.2",
      "pali": "Seṭṭhā samā sevitabbā sahāyā;"
    },
    {
      "id": "snp1.3:13.3",
      "pali": "Ete aladdhā anavajjabhojī,"
    },
    {
      "id": "snp1.3:13.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:14.1",
      "pali": "“Disvā suvaṇṇassa pabhassarāni,"
    },
    {
      "id": "snp1.3:14.2",
      "pali": "Kammāraputtena suniṭṭhitāni;"
    },
    {
      "id": "snp1.3:14.3",
      "pali": "Saṅghaṭṭamānāni duve bhujasmiṁ,"
    },
    {
      "id": "snp1.3:14.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:15.1",
      "pali": "“Evaṁ dutīyena sahā mamassa,"
    },
    {
      "id": "snp1.3:15.2",
      "pali": "Vācābhilāpo abhisajjanā vā;"
    },
    {
      "id": "snp1.3:15.3",
      "pali": "Etaṁ bhayaṁ āyatiṁ pekkhamāno,"
    },
    {
      "id": "snp1.3:15.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:16.1",
      "pali": "“Kāmā hi citrā madhurā manoramā,"
    },
    {
      "id": "snp1.3:16.2",
      "pali": "Virūparūpena mathenti cittaṁ;"
    },
    {
      "id": "snp1.3:16.3",
      "pali": "Ādīnavaṁ kāmaguṇesu disvā,"
    },
    {
      "id": "snp1.3:16.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:17.1",
      "pali": "“Ītī ca gaṇḍo ca upaddavo ca,"
    },
    {
      "id": "snp1.3:17.2",
      "pali": "Rogo ca sallañca bhayañca metaṁ;"
    },
    {
      "id": "snp1.3:17.3",
      "pali": "Etaṁ bhayaṁ kāmaguṇesu disvā,"
    },
    {
      "id": "snp1.3:17.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:18.1",
      "pali": "“Sītañca uṇhañca khudaṁ pipāsaṁ,"
    },
    {
      "id": "snp1.3:18.2",
      "pali": "Vātātape ḍaṁsasarīsape ca;"
    },
    {
      "id": "snp1.3:18.3",
      "pali": "Sabbānipetāni abhisambhavitvā,"
    },
    {
      "id": "snp1.3:18.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:19.1",
      "pali": "“Nāgova yūthāni vivajjayitvā,"
    },
    {
      "id": "snp1.3:19.2",
      "pali": "Sañjātakhandho padumī uḷāro;"
    },
    {
      "id": "snp1.3:19.3",
      "pali": "Yathābhirantaṁ viharaṁ araññe,"
    },
    {
      "id": "snp1.3:19.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:20.1",
      "pali": "“Aṭṭhānataṁ saṅgaṇikāratassa,"
    },
    {
      "id": "snp1.3:20.2",
      "pali": "Yaṁ phassaye sāmayikaṁ vimuttiṁ;"
    },
    {
      "id": "snp1.3:20.3",
      "pali": "Ādiccabandhussa vaco nisamma,"
    },
    {
      "id": "snp1.3:20.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:21.1",
      "pali": "“Diṭṭhīvisūkāni upātivatto,"
    },
    {
      "id": "snp1.3:21.2",
      "pali": "Patto niyāmaṁ paṭiladdhamaggo;"
    },
    {
      "id": "snp1.3:21.3",
      "pali": "Uppannañāṇomhi anaññaneyyo,"
    },
    {
      "id": "snp1.3:21.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:22.1",
      "pali": "“Nillolupo nikkuho nippipāso,"
    },
    {
      "id": "snp1.3:22.2",
      "pali": "Nimmakkho niddhantakasāvamoho;"
    },
    {
      "id": "snp1.3:22.3",
      "pali": "Nirāsayo sabbaloke bhavitvā,"
    },
    {
      "id": "snp1.3:22.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:23.1",
      "pali": "“Pāpaṁ sahāyaṁ parivajjayetha,"
    },
    {
      "id": "snp1.3:23.2",
      "pali": "Anatthadassiṁ visame niviṭṭhaṁ;"
    },
    {
      "id": "snp1.3:23.3",
      "pali": "Sayaṁ na seve pasutaṁ pamattaṁ,"
    },
    {
      "id": "snp1.3:23.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:24.1",
      "pali": "“Bahussutaṁ dhammadharaṁ bhajetha,"
    },
    {
      "id": "snp1.3:24.2",
      "pali": "Mittaṁ uḷāraṁ paṭibhānavantaṁ;"
    },
    {
      "id": "snp1.3:24.3",
      "pali": "Aññāya atthāni vineyya kaṅkhaṁ,"
    },
    {
      "id": "snp1.3:24.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:25.1",
      "pali": "“Khiḍḍaṁ ratiṁ kāmasukhañca loke,"
    },
    {
      "id": "snp1.3:25.2",
      "pali": "Analaṅkaritvā anapekkhamāno;"
    },
    {
      "id": "snp1.3:25.3",
      "pali": "Vibhūsanaṭṭhānā virato saccavādī,"
    },
    {
      "id": "snp1.3:25.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:26.1",
      "pali": "“Puttañca dāraṁ pitarañca mātaraṁ,"
    },
    {
      "id": "snp1.3:26.2",
      "pali": "Dhanāni dhaññāni ca bandhavāni;"
    },
    {
      "id": "snp1.3:26.3",
      "pali": "Hitvāna kāmāni yathodhikāni,"
    },
    {
      "id": "snp1.3:26.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:27.1",
      "pali": "“Saṅgo eso parittamettha sokhyaṁ,"
    },
    {
      "id": "snp1.3:27.2",
      "pali": "Appassādo dukkhamettha bhiyyo;"
    },
    {
      "id": "snp1.3:27.3",
      "pali": "Gaḷo eso iti ñatvā matīmā,"
    },
    {
      "id": "snp1.3:27.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:28.1",
      "pali": "“Sandālayitvāna saṁyojanāni,"
    },
    {
      "id": "snp1.3:28.2",
      "pali": "Jālaṁva bhetvā salilambucārī;"
    },
    {
      "id": "snp1.3:28.3",
      "pali": "Aggīva daḍḍhaṁ anivattamāno,"
    },
    {
      "id": "snp1.3:28.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:29.1",
      "pali": "“Okkhittacakkhu na ca pādalolo,"
    },
    {
      "id": "snp1.3:29.2",
      "pali": "Guttindriyo rakkhitamānasāno;"
    },
    {
      "id": "snp1.3:29.3",
      "pali": "Anavassuto apariḍayhamāno,"
    },
    {
      "id": "snp1.3:29.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:30.1",
      "pali": "“Ohārayitvā gihibyañjanāni,"
    },
    {
      "id": "snp1.3:30.2",
      "pali": "Sañchannapatto yathā pārichatto;"
    },
    {
      "id": "snp1.3:30.3",
      "pali": "Kāsāyavattho abhinikkhamitvā,"
    },
    {
      "id": "snp1.3:30.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:31.1",
      "pali": "“Rasesu gedhaṁ akaraṁ alolo,"
    },
    {
      "id": "snp1.3:31.2",
      "pali": "Anaññaposī sapadānacārī;"
    },
    {
      "id": "snp1.3:31.3",
      "pali": "Kule kule appaṭibaddhacitto,"
    },
    {
      "id": "snp1.3:31.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:32.1",
      "pali": "“Pahāya pañcāvaraṇāni cetaso,"
    },
    {
      "id": "snp1.3:32.2",
      "pali": "Upakkilese byapanujja sabbe;"
    },
    {
      "id": "snp1.3:32.3",
      "pali": "Anissito chetva sinehadosaṁ,"
    },
    {
      "id": "snp1.3:32.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:33.1",
      "pali": "“Vipiṭṭhikatvāna sukhaṁ dukhañca,"
    },
    {
      "id": "snp1.3:33.2",
      "pali": "Pubbeva ca somanassadomanassaṁ;"
    },
    {
      "id": "snp1.3:33.3",
      "pali": "Laddhānupekkhaṁ samathaṁ visuddhaṁ,"
    },
    {
      "id": "snp1.3:33.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:34.1",
      "pali": "“Āraddhaviriyo paramatthapattiyā,"
    },
    {
      "id": "snp1.3:34.2",
      "pali": "Alīnacitto akusītavutti;"
    },
    {
      "id": "snp1.3:34.3",
      "pali": "Daḷhanikkamo thāmabalūpapanno,"
    },
    {
      "id": "snp1.3:34.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:35.1",
      "pali": "“Paṭisallānaṁ jhānamariñcamāno,"
    },
    {
      "id": "snp1.3:35.2",
      "pali": "Dhammesu niccaṁ anudhammacārī;"
    },
    {
      "id": "snp1.3:35.3",
      "pali": "Ādīnavaṁ sammasitā bhavesu,"
    },
    {
      "id": "snp1.3:35.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:36.1",
      "pali": "“Taṇhakkhayaṁ patthayamappamatto,"
    },
    {
      "id": "snp1.3:36.2",
      "pali": "Aneḷamūgo sutavā satīmā;"
    },
    {
      "id": "snp1.3:36.3",
      "pali": "Saṅkhātadhammo niyato padhānavā,"
    },
    {
      "id": "snp1.3:36.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:37.1",
      "pali": "“Sīhova saddesu asantasanto,"
    },
    {
      "id": "snp1.3:37.2",
      "pali": "Vātova jālamhi asajjamāno;"
    },
    {
      "id": "snp1.3:37.3",
      "pali": "Padumaṁva toyena alippamāno,"
    },
    {
      "id": "snp1.3:37.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:38.1",
      "pali": "“Sīho yathā dāṭhabalī pasayha,"
    },
    {
      "id": "snp1.3:38.2",
      "pali": "Rājā migānaṁ abhibhuyya cārī;"
    },
    {
      "id": "snp1.3:38.3",
      "pali": "Sevetha pantāni senāsanāni,"
    },
    {
      "id": "snp1.3:38.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:39.1",
      "pali": "“Mettaṁ upekkhaṁ karuṇaṁ vimuttiṁ,"
    },
    {
      "id": "snp1.3:39.2",
      "pali": "Āsevamāno muditañca kāle;"
    },
    {
      "id": "snp1.3:39.3",
      "pali": "Sabbena lokena avirujjhamāno,"
    },
    {
      "id": "snp1.3:39.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:40.1",
      "pali": "“Rāgañca dosañca pahāya mohaṁ,"
    },
    {
      "id": "snp1.3:40.2",
      "pali": "Sandālayitvāna saṁyojanāni;"
    },
    {
      "id": "snp1.3:40.3",
      "pali": "Asantasaṁ jīvitasaṅkhayamhi,"
    },
    {
      "id": "snp1.3:40.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:41.1",
      "pali": "“Bhajanti sevanti ca kāraṇatthā,"
    },
    {
      "id": "snp1.3:41.2",
      "pali": "Nikkāraṇā dullabhā ajja mittā;"
    },
    {
      "id": "snp1.3:41.3",
      "pali": "Attaṭṭhapaññā asucī manussā,"
    },
    {
      "id": "snp1.3:41.4",
      "pali": "Eko care khaggavisāṇakappo”."
    },
    {
      "id": "snp1.3:41.5",
      "pali": "Khaggavisāṇasuttaṁ tatiyaṁ."
    }
  ]
}
