{
  "uid": "sn2.28",
  "title": "Nandivisālasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.28:1.1",
      "pali": "Ekamantaṁ ṭhito kho nandivisālo devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.28:2.1",
      "pali": "“Catucakkaṁ navadvāraṁ,"
    },
    {
      "id": "sn2.28:2.2",
      "pali": "puṇṇaṁ lobhena saṁyutaṁ;"
    },
    {
      "id": "sn2.28:2.3",
      "pali": "Paṅkajātaṁ mahāvīra,"
    },
    {
      "id": "sn2.28:2.4",
      "pali": "kathaṁ yātrā bhavissatī”ti."
    },
    {
      "id": "sn2.28:3.1",
      "pali": "“Chetvā naddhiṁ varattañca,"
    },
    {
      "id": "sn2.28:3.2",
      "pali": "icchālobhañca pāpakaṁ;"
    },
    {
      "id": "sn2.28:3.3",
      "pali": "Samūlaṁ taṇhamabbuyha,"
    },
    {
      "id": "sn2.28:3.4",
      "pali": "evaṁ yātrā bhavissatī”ti."
    }
  ]
}
