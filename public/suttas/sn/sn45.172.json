{
  "uid": "sn45.172",
  "title": "Yogasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.172:1.1",
      "pali": "“Cattārome, bhikkhave, yogā."
    },
    {
      "id": "sn45.172:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn45.172:1.3",
      "pali": "Kāmayogo, bhavayogo, diṭṭhiyogo avijjāyogo—"
    },
    {
      "id": "sn45.172:1.4",
      "pali": "ime kho, bhikkhave, cattāro yogā."
    },
    {
      "id": "sn45.172:1.5",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ yogānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.172:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
