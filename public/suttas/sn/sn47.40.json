{
  "uid": "sn47.40",
  "title": "Vibhaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.40:1.1",
      "pali": "“Satipaṭṭhānañca vo, bhikkhave, desessāmi satipaṭṭhānabhāvanañca satipaṭṭhānabhāvanāgāminiñca paṭipadaṁ."
    },
    {
      "id": "sn47.40:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn47.40:1.3",
      "pali": "Katamañca, bhikkhave, satipaṭṭhānaṁ?"
    },
    {
      "id": "sn47.40:1.4",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.40:1.5",
      "pali": "vedanāsu vedanānupassī viharati …pe…"
    },
    {
      "id": "sn47.40:1.6",
      "pali": "citte cittānupassī viharati …pe…"
    },
    {
      "id": "sn47.40:1.7",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.40:1.8",
      "pali": "Idaṁ vuccati, bhikkhave, satipaṭṭhānaṁ."
    },
    {
      "id": "sn47.40:2.1",
      "pali": "Katamā ca, bhikkhave, satipaṭṭhānabhāvanā?"
    },
    {
      "id": "sn47.40:2.2",
      "pali": "Idha, bhikkhave, bhikkhu samudayadhammānupassī kāyasmiṁ viharati, vayadhammānupassī kāyasmiṁ viharati, samudayavayadhammānupassī kāyasmiṁ viharati, ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.40:2.3",
      "pali": "Samudayadhammānupassī vedanāsu viharati …pe…"
    },
    {
      "id": "sn47.40:2.4",
      "pali": "samudayadhammānupassī citte viharati …pe…"
    },
    {
      "id": "sn47.40:2.5",
      "pali": "samudayadhammānupassī dhammesu viharati, vayadhammānupassī dhammesu viharati, samudayavayadhammānupassī dhammesu viharati, ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.40:2.6",
      "pali": "Ayaṁ vuccati, bhikkhave, satipaṭṭhānabhāvanā."
    },
    {
      "id": "sn47.40:3.1",
      "pali": "Katamā ca, bhikkhave, satipaṭṭhānabhāvanāgāminī paṭipadā?"
    },
    {
      "id": "sn47.40:3.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn47.40:3.3",
      "pali": "sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi."
    },
    {
      "id": "sn47.40:3.4",
      "pali": "Ayaṁ vuccati, bhikkhave, satipaṭṭhānabhāvanāgāminī paṭipadā”ti."
    },
    {
      "id": "sn47.40:3.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn47.40:3.6",
      "pali": "Ananussutavaggo catuttho."
    },
    {
      "id": "sn47.40:4.1",
      "pali": "Ananussutaṁ virāgo,"
    },
    {
      "id": "sn47.40:4.2",
      "pali": "viraddho bhāvanā sati;"
    },
    {
      "id": "sn47.40:4.3",
      "pali": "Aññā chandaṁ pariññāya,"
    },
    {
      "id": "sn47.40:4.4",
      "pali": "bhāvanā vibhaṅgena cāti."
    }
  ]
}
