{
  "uid": "sn22.34",
  "title": "Dutiyanatumhākasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.34:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.34:1.2",
      "pali": "“Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.34:1.3",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.34:1.4",
      "pali": "Kiñca, bhikkhave, na tumhākaṁ?"
    },
    {
      "id": "sn22.34:1.5",
      "pali": "Rūpaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.34:1.6",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.34:1.7",
      "pali": "Vedanā na tumhākaṁ …"
    },
    {
      "id": "sn22.34:1.8",
      "pali": "saññā na tumhākaṁ …"
    },
    {
      "id": "sn22.34:1.9",
      "pali": "saṅkhārā na tumhākaṁ …"
    },
    {
      "id": "sn22.34:1.10",
      "pali": "viññāṇaṁ na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn22.34:1.11",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn22.34:1.12",
      "pali": "Yaṁ, bhikkhave, na tumhākaṁ taṁ pajahatha."
    },
    {
      "id": "sn22.34:1.13",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissatī”ti."
    },
    {
      "id": "sn22.34:1.14",
      "pali": "Dutiyaṁ."
    }
  ]
}
