{
  "uid": "sn22.150",
  "title": "Ajjhattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.150:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.150:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya uppajjati ajjhattaṁ sukhadukkhan”ti?"
    },
    {
      "id": "sn22.150:1.3",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.150:1.4",
      "pali": "“rūpe kho, bhikkhave, sati rūpaṁ upādāya uppajjati ajjhattaṁ sukhadukkhaṁ."
    },
    {
      "id": "sn22.150:1.5",
      "pali": "Vedanāya sati …pe…"
    },
    {
      "id": "sn22.150:1.6",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn22.150:1.7",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn22.150:1.8",
      "pali": "viññāṇe sati viññāṇaṁ upādāya uppajjati ajjhattaṁ sukhadukkhaṁ."
    },
    {
      "id": "sn22.150:1.9",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.150:1.10",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.150:1.11",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.12",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.150:1.13",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.14",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya uppajjeyya ajjhattaṁ sukhadukkhan”ti?"
    },
    {
      "id": "sn22.150:1.15",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.16",
      "pali": "“Vedanā …pe…"
    },
    {
      "id": "sn22.150:1.17",
      "pali": "saññā …"
    },
    {
      "id": "sn22.150:1.18",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.150:1.19",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.150:1.20",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.21",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn22.150:1.22",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.23",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, api nu taṁ anupādāya uppajjeyya ajjhattaṁ sukhadukkhan”ti?"
    },
    {
      "id": "sn22.150:1.24",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.150:1.25",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.150:1.26",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.150:1.27",
      "pali": "Paṭhamaṁ."
    }
  ]
}
