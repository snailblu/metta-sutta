{
  "uid": "sn51.23",
  "title": "Bhikkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.23:1.1",
      "pali": "“Cattārome, bhikkhave, iddhipādā."
    },
    {
      "id": "sn51.23:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn51.23:1.3",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.23:1.4",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.23:1.5",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.23:1.6",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.23:1.7",
      "pali": "ime kho, bhikkhave, cattāro iddhipādā."
    },
    {
      "id": "sn51.23:1.8",
      "pali": "Imesaṁ kho, bhikkhave, catunnaṁ iddhipādānaṁ bhāvitattā bahulīkatattā bhikkhu āsavānaṁ khayā anāsavaṁ cetovimuttiṁ paññāvimuttiṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti."
    },
    {
      "id": "sn51.23:1.9",
      "pali": "Tatiyaṁ."
    }
  ]
}
