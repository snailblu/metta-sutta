{
  "uid": "sn35.227",
  "title": "Bāhirāyatanaanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.227:1.1",
      "pali": "“Rūpā, bhikkhave, anattā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā anattā."
    },
    {
      "id": "sn35.227:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.227:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn35.227:1.4",
      "pali": "Saṭṭhipeyyālo samatto."
    },
    {
      "id": "sn35.227:2.1",
      "pali": "Chandenaṭṭhārasa honti,"
    },
    {
      "id": "sn35.227:2.2",
      "pali": "atītena ca dve nava;"
    },
    {
      "id": "sn35.227:2.3",
      "pali": "Yadaniccāṭṭhārasa vuttā,"
    },
    {
      "id": "sn35.227:2.4",
      "pali": "tayo ajjhattabāhirā;"
    },
    {
      "id": "sn35.227:2.5",
      "pali": "Peyyālo saṭṭhiko vutto,"
    },
    {
      "id": "sn35.227:2.6",
      "pali": "buddhenādiccabandhunāti."
    },
    {
      "id": "sn35.227:2.7",
      "pali": "Suttantāni saṭṭhi."
    }
  ]
}
