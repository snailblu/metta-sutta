{
  "uid": "sn11.8",
  "title": "Verocanaasurindasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.8:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.8:1.2",
      "pali": "Tena kho pana samayena bhagavā divāvihāragato hoti paṭisallīno."
    },
    {
      "id": "sn11.8:1.3",
      "pali": "Atha kho sakko ca devānamindo verocano ca asurindo yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā paccekaṁ dvārabāhaṁ nissāya aṭṭhaṁsu."
    },
    {
      "id": "sn11.8:1.4",
      "pali": "Atha kho verocano asurindo bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn11.8:2.1",
      "pali": "“Vāyametheva puriso,"
    },
    {
      "id": "sn11.8:2.2",
      "pali": "yāva atthassa nipphadā;"
    },
    {
      "id": "sn11.8:2.3",
      "pali": "Nipphannasobhano attho,"
    },
    {
      "id": "sn11.8:2.4",
      "pali": "verocanavaco idan”ti."
    },
    {
      "id": "sn11.8:3.1",
      "pali": "“Vāyametheva puriso,"
    },
    {
      "id": "sn11.8:3.2",
      "pali": "yāva atthassa nipphadā;"
    },
    {
      "id": "sn11.8:3.3",
      "pali": "Nipphannasobhano attho,"
    },
    {
      "id": "sn11.8:3.4",
      "pali": "khantyā bhiyyo na vijjatī”ti."
    },
    {
      "id": "sn11.8:4.1",
      "pali": "“Sabbe sattā atthajātā,"
    },
    {
      "id": "sn11.8:4.2",
      "pali": "tattha tattha yathārahaṁ;"
    },
    {
      "id": "sn11.8:4.3",
      "pali": "Saṁyogaparamā tveva,"
    },
    {
      "id": "sn11.8:4.4",
      "pali": "sambhogā sabbapāṇinaṁ;"
    },
    {
      "id": "sn11.8:4.5",
      "pali": "Nipphannasobhano attho,"
    },
    {
      "id": "sn11.8:4.6",
      "pali": "verocanavaco idan”ti."
    },
    {
      "id": "sn11.8:5.1",
      "pali": "“Sabbe sattā atthajātā,"
    },
    {
      "id": "sn11.8:5.2",
      "pali": "tattha tattha yathārahaṁ;"
    },
    {
      "id": "sn11.8:5.3",
      "pali": "Saṁyogaparamā tveva,"
    },
    {
      "id": "sn11.8:5.4",
      "pali": "sambhogā sabbapāṇinaṁ;"
    },
    {
      "id": "sn11.8:5.5",
      "pali": "Nipphannasobhano attho,"
    },
    {
      "id": "sn11.8:5.6",
      "pali": "khantyā bhiyyo na vijjatī”ti."
    }
  ]
}
