{
  "uid": "sn35.187",
  "title": "Ajjhattānāgatāniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.187:1.1",
      "pali": "“Cakkhu, bhikkhave, aniccaṁ anāgataṁ …pe… jivhā aniccā anāgatā …pe… mano anicco anāgato."
    },
    {
      "id": "sn35.187:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.187:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
