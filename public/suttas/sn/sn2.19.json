{
  "uid": "sn2.19",
  "title": "Uttarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.19:1.1",
      "pali": "Rājagahanidānaṁ."
    },
    {
      "id": "sn2.19:1.2",
      "pali": "Ekamantaṁ ṭhito kho uttaro devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.19:2.1",
      "pali": "“Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "sn2.19:2.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "sn2.19:2.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn2.19:2.4",
      "pali": "Puññāni kayirātha sukhāvahānī”ti."
    },
    {
      "id": "sn2.19:3.1",
      "pali": "“Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "sn2.19:3.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "sn2.19:3.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn2.19:3.4",
      "pali": "Lokāmisaṁ pajahe santipekkho”ti."
    }
  ]
}
