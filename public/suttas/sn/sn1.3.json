{
  "uid": "sn1.3",
  "title": "Upanīyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn1.3:1.2",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn1.3:2.1",
      "pali": "“Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "sn1.3:2.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "sn1.3:2.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn1.3:2.4",
      "pali": "Puññāni kayirātha sukhāvahānī”ti."
    },
    {
      "id": "sn1.3:3.1",
      "pali": "“Upanīyati jīvitamappamāyu,"
    },
    {
      "id": "sn1.3:3.2",
      "pali": "Jarūpanītassa na santi tāṇā;"
    },
    {
      "id": "sn1.3:3.3",
      "pali": "Etaṁ bhayaṁ maraṇe pekkhamāno,"
    },
    {
      "id": "sn1.3:3.4",
      "pali": "Lokāmisaṁ pajahe santipekkho”ti."
    }
  ]
}
