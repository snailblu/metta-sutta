{
  "uid": "sn45.168",
  "title": "Nīghasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.168:1.1",
      "pali": "“Tayome, bhikkhave, nīghā."
    },
    {
      "id": "sn45.168:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "sn45.168:1.3",
      "pali": "Rāgo nīgho, doso nīgho, moho nīgho—"
    },
    {
      "id": "sn45.168:1.4",
      "pali": "ime kho, bhikkhave, tayo nīghā."
    },
    {
      "id": "sn45.168:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ nīghānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.168:1.6",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
