{
  "uid": "sn18.2",
  "title": "Rūpasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.2:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.2:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.2:1.3",
      "pali": "rūpā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.2:1.4",
      "pali": "“Aniccā, bhante” …pe…"
    },
    {
      "id": "sn18.2:1.5",
      "pali": "saddā …"
    },
    {
      "id": "sn18.2:1.6",
      "pali": "gandhā …"
    },
    {
      "id": "sn18.2:1.7",
      "pali": "rasā …"
    },
    {
      "id": "sn18.2:1.8",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn18.2:1.9",
      "pali": "dhammā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.2:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.2:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpesupi nibbindati … saddesupi nibbindati … gandhesupi nibbindati … rasesupi nibbindati … phoṭṭhabbesupi nibbindati … dhammesupi nibbindati;"
    },
    {
      "id": "sn18.2:1.12",
      "pali": "nibbindaṁ virajjati …pe…"
    },
    {
      "id": "sn18.2:1.13",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.2:1.14",
      "pali": "Dutiyaṁ."
    }
  ]
}
