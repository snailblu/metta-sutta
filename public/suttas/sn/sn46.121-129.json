{
  "uid": "sn46.121-129",
  "title": "Oghādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.121-129:1.1",
      "pali": "“Cattārome, bhikkhave, oghā."
    },
    {
      "id": "sn46.121-129:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn46.121-129:1.3",
      "pali": "Kāmogho, bhavogho, diṭṭhogho, avijjogho”ti."
    },
    {
      "id": "sn46.121-129:1.4",
      "pali": "vitthāretabbaṁ."
    }
  ]
}
