{
  "uid": "sn23.12",
  "title": "Māradhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.12:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.12:1.3",
      "pali": "“‘māradhammo, māradhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.12:1.4",
      "pali": "Katamo nu kho, bhante, māradhammo”ti?"
    },
    {
      "id": "sn23.12:1.5",
      "pali": "“Rūpaṁ kho, rādha, māradhammo, vedanā māradhammo, saññā māradhammo, saṅkhārā māradhammo, viññāṇaṁ māradhammo."
    },
    {
      "id": "sn23.12:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.12:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.12:1.8",
      "pali": "Dutiyaṁ."
    }
  ]
}
