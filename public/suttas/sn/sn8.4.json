{
  "uid": "sn8.4",
  "title": "Ānandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.4:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā ānando sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn8.4:1.2",
      "pali": "Atha kho āyasmā ānando pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisi āyasmatā vaṅgīsena pacchāsamaṇena."
    },
    {
      "id": "sn8.4:1.3",
      "pali": "Tena kho pana samayena āyasmato vaṅgīsassa anabhirati uppannā hoti, rāgo cittaṁ anuddhaṁseti."
    },
    {
      "id": "sn8.4:1.4",
      "pali": "Atha kho āyasmā vaṅgīso āyasmantaṁ ānandaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn8.4:2.1",
      "pali": "“Kāmarāgena ḍayhāmi,"
    },
    {
      "id": "sn8.4:2.2",
      "pali": "cittaṁ me pariḍayhati;"
    },
    {
      "id": "sn8.4:2.3",
      "pali": "Sādhu nibbāpanaṁ brūhi,"
    },
    {
      "id": "sn8.4:2.4",
      "pali": "anukampāya gotamā”ti."
    },
    {
      "id": "sn8.4:3.1",
      "pali": "“Saññāya vipariyesā,"
    },
    {
      "id": "sn8.4:3.2",
      "pali": "cittaṁ te pariḍayhati;"
    },
    {
      "id": "sn8.4:3.3",
      "pali": "Nimittaṁ parivajjehi,"
    },
    {
      "id": "sn8.4:3.4",
      "pali": "subhaṁ rāgūpasaṁhitaṁ."
    },
    {
      "id": "sn8.4:4.1",
      "pali": "Saṅkhāre parato passa,"
    },
    {
      "id": "sn8.4:4.2",
      "pali": "dukkhato mā ca attato;"
    },
    {
      "id": "sn8.4:4.3",
      "pali": "Nibbāpehi mahārāgaṁ,"
    },
    {
      "id": "sn8.4:4.4",
      "pali": "mā ḍayhittho punappunaṁ."
    },
    {
      "id": "sn8.4:5.1",
      "pali": "Asubhāya cittaṁ bhāvehi,"
    },
    {
      "id": "sn8.4:5.2",
      "pali": "ekaggaṁ susamāhitaṁ;"
    },
    {
      "id": "sn8.4:5.3",
      "pali": "Sati kāyagatā tyatthu,"
    },
    {
      "id": "sn8.4:5.4",
      "pali": "nibbidābahulo bhava."
    },
    {
      "id": "sn8.4:6.1",
      "pali": "Animittañca bhāvehi,"
    },
    {
      "id": "sn8.4:6.2",
      "pali": "mānānusayamujjaha;"
    },
    {
      "id": "sn8.4:6.3",
      "pali": "Tato mānābhisamayā,"
    },
    {
      "id": "sn8.4:6.4",
      "pali": "upasanto carissasī”ti."
    }
  ]
}
