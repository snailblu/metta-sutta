{
  "uid": "sn34.35-40",
  "title": "Kallitamūlakaārammaṇasuttādichakka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.35-40:1.1",
      "pali": "Sāvatthinidānaṁ …"
    },
    {
      "id": "sn34.35-40:1.2",
      "pali": "“samādhismiṁ kallitakusalo hoti, na samādhismiṁ ārammaṇakusalo …"
    },
    {
      "id": "sn34.35-40:1.3",
      "pali": "samādhismiṁ ārammaṇakusalo hoti, na samādhismiṁ kallitakusalo …"
    },
    {
      "id": "sn34.35-40:1.4",
      "pali": "neva samādhismiṁ kallitakusalo hoti, na ca samādhismiṁ ārammaṇakusalo …"
    },
    {
      "id": "sn34.35-40:1.5",
      "pali": "samādhismiṁ kallitakusalo ca hoti, samādhismiṁ ārammaṇakusalo ca."
    },
    {
      "id": "sn34.35-40:1.6",
      "pali": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe…"
    },
    {
      "id": "sn34.35-40:1.7",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.35-40:1.8",
      "pali": "Pañcatiṁsatimaṁ."
    },
    {
      "id": "sn34.35-40:1.9",
      "pali": "(Purimamūlakāni viya yāva cattālīsamā kallitamūlakasappāyakārīsuttā cha suttāni pūretabbāni.)"
    },
    {
      "id": "sn34.35-40:1.10",
      "pali": "(Kallitamūlakaṁ.)"
    }
  ]
}
