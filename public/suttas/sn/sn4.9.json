{
  "uid": "sn4.9",
  "title": "Paṭhamaāyusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.9:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.9:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn4.9:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn4.9:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn4.9:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn4.9:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn4.9:2.1",
      "pali": "“Appamidaṁ, bhikkhave, manussānaṁ āyu."
    },
    {
      "id": "sn4.9:2.2",
      "pali": "Gamanīyo samparāyo, kattabbaṁ kusalaṁ, caritabbaṁ brahmacariyaṁ."
    },
    {
      "id": "sn4.9:2.3",
      "pali": "Natthi jātassa amaraṇaṁ."
    },
    {
      "id": "sn4.9:2.4",
      "pali": "Yo, bhikkhave, ciraṁ jīvati, so vassasataṁ appaṁ vā bhiyyo”ti."
    },
    {
      "id": "sn4.9:3.1",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.9:4.1",
      "pali": "“Dīghamāyu manussānaṁ,"
    },
    {
      "id": "sn4.9:4.2",
      "pali": "na naṁ hīḷe suporiso;"
    },
    {
      "id": "sn4.9:4.3",
      "pali": "Careyya khīramattova,"
    },
    {
      "id": "sn4.9:4.4",
      "pali": "natthi maccussa āgamo”ti."
    },
    {
      "id": "sn4.9:5.1",
      "pali": "“Appamāyu manussānaṁ,"
    },
    {
      "id": "sn4.9:5.2",
      "pali": "hīḷeyya naṁ suporiso;"
    },
    {
      "id": "sn4.9:5.3",
      "pali": "Careyyādittasīsova,"
    },
    {
      "id": "sn4.9:5.4",
      "pali": "natthi maccussa nāgamo”ti."
    },
    {
      "id": "sn4.9:6.1",
      "pali": "Atha kho māro …pe… tatthevantaradhāyīti."
    }
  ]
}
