{
  "uid": "sn3.1",
  "title": "Daharasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn3.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn3.1:1.3",
      "pali": "Atha kho rājā pasenadi kosalo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn3.1:1.4",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.1:1.5",
      "pali": "“bhavampi no gotamo anuttaraṁ sammāsambodhiṁ abhisambuddhoti paṭijānātī”ti?"
    },
    {
      "id": "sn3.1:1.6",
      "pali": "“Yañhi taṁ, mahārāja, sammā vadamāno vadeyya ‘anuttaraṁ sammāsambodhiṁ abhisambuddho’ti, mameva taṁ sammā vadamāno vadeyya."
    },
    {
      "id": "sn3.1:1.7",
      "pali": "Ahañhi, mahārāja, anuttaraṁ sammāsambodhiṁ abhisambuddho”ti."
    },
    {
      "id": "sn3.1:2.1",
      "pali": "“Yepi te, bho gotama, samaṇabrāhmaṇā saṅghino gaṇino gaṇācariyā ñātā yasassino titthakarā sādhusammatā bahujanassa, seyyathidaṁ—"
    },
    {
      "id": "sn3.1:2.2",
      "pali": "pūraṇo kassapo, makkhali gosālo, nigaṇṭho nāṭaputto, sañcayo belaṭṭhaputto, pakudho kaccāyano, ajito kesakambalo;"
    },
    {
      "id": "sn3.1:2.3",
      "pali": "tepi mayā ‘anuttaraṁ sammāsambodhiṁ abhisambuddhoti paṭijānāthā’ti puṭṭhā samānā anuttaraṁ sammāsambodhiṁ abhisambuddhoti na paṭijānanti."
    },
    {
      "id": "sn3.1:2.4",
      "pali": "Kiṁ pana bhavaṁ gotamo daharo ceva jātiyā navo ca pabbajjāyā”ti?"
    },
    {
      "id": "sn3.1:3.1",
      "pali": "“Cattāro kho me, mahārāja, daharāti na uññātabbā, daharāti na paribhotabbā."
    },
    {
      "id": "sn3.1:3.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn3.1:3.3",
      "pali": "Khattiyo kho, mahārāja, daharoti na uññātabbo, daharoti na paribhotabbo."
    },
    {
      "id": "sn3.1:3.4",
      "pali": "Urago kho, mahārāja, daharoti na uññātabbo, daharoti na paribhotabbo."
    },
    {
      "id": "sn3.1:3.5",
      "pali": "Aggi kho, mahārāja, daharoti na uññātabbo, daharoti na paribhotabbo."
    },
    {
      "id": "sn3.1:3.6",
      "pali": "Bhikkhu, kho, mahārāja, daharoti na uññātabbo, daharoti na paribhotabbo."
    },
    {
      "id": "sn3.1:3.7",
      "pali": "Ime kho, mahārāja, cattāro daharāti na uññātabbā, daharāti na paribhotabbā”ti."
    },
    {
      "id": "sn3.1:4.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn3.1:4.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn3.1:5.1",
      "pali": "“Khattiyaṁ jātisampannaṁ,"
    },
    {
      "id": "sn3.1:5.2",
      "pali": "abhijātaṁ yasassinaṁ;"
    },
    {
      "id": "sn3.1:5.3",
      "pali": "Daharoti nāvajāneyya,"
    },
    {
      "id": "sn3.1:5.4",
      "pali": "na naṁ paribhave naro."
    },
    {
      "id": "sn3.1:6.1",
      "pali": "Ṭhānañhi so manujindo,"
    },
    {
      "id": "sn3.1:6.2",
      "pali": "rajjaṁ laddhāna khattiyo;"
    },
    {
      "id": "sn3.1:6.3",
      "pali": "So kuddho rājadaṇḍena,"
    },
    {
      "id": "sn3.1:6.4",
      "pali": "tasmiṁ pakkamate bhusaṁ;"
    },
    {
      "id": "sn3.1:6.5",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "sn3.1:6.6",
      "pali": "rakkhaṁ jīvitamattano."
    },
    {
      "id": "sn3.1:7.1",
      "pali": "Gāme vā yadi vā raññe,"
    },
    {
      "id": "sn3.1:7.2",
      "pali": "yattha passe bhujaṅgamaṁ;"
    },
    {
      "id": "sn3.1:7.3",
      "pali": "Daharoti nāvajāneyya,"
    },
    {
      "id": "sn3.1:7.4",
      "pali": "na naṁ paribhave naro."
    },
    {
      "id": "sn3.1:8.1",
      "pali": "Uccāvacehi vaṇṇehi,"
    },
    {
      "id": "sn3.1:8.2",
      "pali": "urago carati tejasī;"
    },
    {
      "id": "sn3.1:8.3",
      "pali": "So āsajja ḍaṁse bālaṁ,"
    },
    {
      "id": "sn3.1:8.4",
      "pali": "naraṁ nāriñca ekadā;"
    },
    {
      "id": "sn3.1:8.5",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "sn3.1:8.6",
      "pali": "rakkhaṁ jīvitamattano."
    },
    {
      "id": "sn3.1:9.1",
      "pali": "Pahūtabhakkhaṁ jālinaṁ,"
    },
    {
      "id": "sn3.1:9.2",
      "pali": "pāvakaṁ kaṇhavattaniṁ;"
    },
    {
      "id": "sn3.1:9.3",
      "pali": "Daharoti nāvajāneyya,"
    },
    {
      "id": "sn3.1:9.4",
      "pali": "na naṁ paribhave naro."
    },
    {
      "id": "sn3.1:10.1",
      "pali": "Laddhā hi so upādānaṁ,"
    },
    {
      "id": "sn3.1:10.2",
      "pali": "mahā hutvāna pāvako;"
    },
    {
      "id": "sn3.1:10.3",
      "pali": "So āsajja ḍahe bālaṁ,"
    },
    {
      "id": "sn3.1:10.4",
      "pali": "naraṁ nāriñca ekadā;"
    },
    {
      "id": "sn3.1:10.5",
      "pali": "Tasmā taṁ parivajjeyya,"
    },
    {
      "id": "sn3.1:10.6",
      "pali": "rakkhaṁ jīvitamattano."
    },
    {
      "id": "sn3.1:11.1",
      "pali": "Vanaṁ yadaggi ḍahati,"
    },
    {
      "id": "sn3.1:11.2",
      "pali": "pāvako kaṇhavattanī;"
    },
    {
      "id": "sn3.1:11.3",
      "pali": "Jāyanti tattha pārohā,"
    },
    {
      "id": "sn3.1:11.4",
      "pali": "ahorattānamaccaye."
    },
    {
      "id": "sn3.1:12.1",
      "pali": "Yañca kho sīlasampanno,"
    },
    {
      "id": "sn3.1:12.2",
      "pali": "bhikkhu ḍahati tejasā;"
    },
    {
      "id": "sn3.1:12.3",
      "pali": "Na tassa puttā pasavo,"
    },
    {
      "id": "sn3.1:12.4",
      "pali": "dāyādā vindare dhanaṁ;"
    },
    {
      "id": "sn3.1:12.5",
      "pali": "Anapaccā adāyādā,"
    },
    {
      "id": "sn3.1:12.6",
      "pali": "tālāvatthū bhavanti te."
    },
    {
      "id": "sn3.1:13.1",
      "pali": "Tasmā hi paṇḍito poso,"
    },
    {
      "id": "sn3.1:13.2",
      "pali": "sampassaṁ atthamattano;"
    },
    {
      "id": "sn3.1:13.3",
      "pali": "Bhujaṅgamaṁ pāvakañca,"
    },
    {
      "id": "sn3.1:13.4",
      "pali": "khattiyañca yasassinaṁ;"
    },
    {
      "id": "sn3.1:13.5",
      "pali": "Bhikkhuñca sīlasampannaṁ,"
    },
    {
      "id": "sn3.1:13.6",
      "pali": "sammadeva samācare”ti."
    },
    {
      "id": "sn3.1:14.1",
      "pali": "Evaṁ vutte, rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.1:14.2",
      "pali": "“abhikkantaṁ, bhante, abhikkantaṁ, bhante."
    },
    {
      "id": "sn3.1:14.3",
      "pali": "Seyyathāpi, bhante, nikkujjitaṁ vā ukkujjeyya, paṭicchannaṁ vā vivareyya, mūḷhassa vā maggaṁ ācikkheyya, andhakāre vā telapajjotaṁ dhāreyya: ‘cakkhumanto rūpāni dakkhantī’ti; evamevaṁ bhagavatā anekapariyāyena dhammo pakāsito."
    },
    {
      "id": "sn3.1:14.4",
      "pali": "Esāhaṁ, bhante, bhagavantaṁ saraṇaṁ gacchāmi dhammañca bhikkhusaṅghañca."
    },
    {
      "id": "sn3.1:14.5",
      "pali": "Upāsakaṁ maṁ, bhante, bhagavā dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
