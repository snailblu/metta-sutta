{
  "uid": "sn50.89-98",
  "title": "Punaesanādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn50.89-98:1.1",
      "pali": "(Evaṁ esanāpāḷi vitthāretabbā—rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ.)"
    },
    {
      "id": "sn50.89-98:1.2",
      "pali": "Esanāvaggo navamo."
    },
    {
      "id": "sn50.89-98:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn50.89-98:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn50.89-98:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn50.89-98:2.4",
      "pali": "Vedanā taṇhā tasinā cāti."
    }
  ]
}
