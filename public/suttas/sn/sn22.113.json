{
  "uid": "sn22.113",
  "title": "Avijjāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.113:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.113:1.2",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā tenupasaṅkami …pe…"
    },
    {
      "id": "sn22.113:1.3",
      "pali": "ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.113:1.4",
      "pali": "“‘avijjā, avijjā’ti, bhante, vuccati."
    },
    {
      "id": "sn22.113:1.5",
      "pali": "Katamā nu kho, bhante, avijjā;"
    },
    {
      "id": "sn22.113:1.6",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.113:1.7",
      "pali": "“Idha, bhikkhu, assutavā puthujjano rūpaṁ nappajānāti, rūpasamudayaṁ nappajānāti, rūpanirodhaṁ nappajānāti, rūpanirodhagāminiṁ paṭipadaṁ nappajānāti;"
    },
    {
      "id": "sn22.113:1.8",
      "pali": "vedanaṁ nappajānāti …"
    },
    {
      "id": "sn22.113:1.9",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.113:1.10",
      "pali": "saṅkhāre nappajānāti …pe…"
    },
    {
      "id": "sn22.113:1.11",
      "pali": "viññāṇanirodhagāminiṁ paṭipadaṁ nappajānāti."
    },
    {
      "id": "sn22.113:1.12",
      "pali": "Ayaṁ vuccati, bhikkhu, avijjā;"
    },
    {
      "id": "sn22.113:1.13",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.113:1.14",
      "pali": "Paṭhamaṁ."
    }
  ]
}
