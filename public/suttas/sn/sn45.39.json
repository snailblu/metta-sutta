{
  "uid": "sn45.39",
  "title": "Paṭhamabrahmacariyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.39:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.39:1.2",
      "pali": "“Brahmacariyañca vo, bhikkhave, desessāmi, brahmacariyaphalāni ca."
    },
    {
      "id": "sn45.39:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.39:1.4",
      "pali": "Katamañca, bhikkhave, brahmacariyaṁ?"
    },
    {
      "id": "sn45.39:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.39:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.39:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, brahmacariyaṁ."
    },
    {
      "id": "sn45.39:1.8",
      "pali": "Katamāni ca, bhikkhave, brahmacariyaphalāni?"
    },
    {
      "id": "sn45.39:1.9",
      "pali": "Sotāpattiphalaṁ, sakadāgāmiphalaṁ, anāgāmiphalaṁ, arahattaphalaṁ—"
    },
    {
      "id": "sn45.39:1.10",
      "pali": "imāni vuccanti, bhikkhave, brahmacariyaphalānī”ti."
    },
    {
      "id": "sn45.39:1.11",
      "pali": "Navamaṁ."
    }
  ]
}
