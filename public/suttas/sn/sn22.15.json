{
  "uid": "sn22.15",
  "title": "Yadaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.15:1.2",
      "pali": "“Rūpaṁ, bhikkhave, aniccaṁ."
    },
    {
      "id": "sn22.15:1.3",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.15:1.4",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.15:1.5",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.15:1.6",
      "pali": "Vedanā aniccā."
    },
    {
      "id": "sn22.15:1.7",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.15:1.8",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.15:1.9",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.15:1.10",
      "pali": "Saññā aniccā …pe…"
    },
    {
      "id": "sn22.15:1.11",
      "pali": "saṅkhārā aniccā …"
    },
    {
      "id": "sn22.15:1.12",
      "pali": "viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn22.15:1.13",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ;"
    },
    {
      "id": "sn22.15:1.14",
      "pali": "yaṁ dukkhaṁ tadanattā;"
    },
    {
      "id": "sn22.15:1.15",
      "pali": "yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn22.15:1.16",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.15:1.17",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.15:1.18",
      "pali": "Catutthaṁ."
    }
  ]
}
