{
  "uid": "sn11.18",
  "title": "Gahaṭṭhavandanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.18:1.1",
      "pali": "Sāvatthiyaṁ."
    },
    {
      "id": "sn11.18:1.2",
      "pali": "Tatra …pe… etadavoca:"
    },
    {
      "id": "sn11.18:1.3",
      "pali": "“bhūtapubbaṁ, bhikkhave, sakko devānamindo mātaliṁ saṅgāhakaṁ āmantesi:"
    },
    {
      "id": "sn11.18:1.4",
      "pali": "‘yojehi, samma mātali, sahassayuttaṁ ājaññarathaṁ. Uyyānabhūmiṁ gacchāma subhūmiṁ dassanāyā’ti."
    },
    {
      "id": "sn11.18:1.5",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, mātali saṅgāhako sakkassa devānamindassa paṭissutvā sahassayuttaṁ ājaññarathaṁ yojetvā sakkassa devānamindassa paṭivedesi:"
    },
    {
      "id": "sn11.18:1.6",
      "pali": "‘yutto kho te, mārisa, sahassayutto ājaññaratho."
    },
    {
      "id": "sn11.18:1.7",
      "pali": "Yassadāni kālaṁ maññasī’ti."
    },
    {
      "id": "sn11.18:1.8",
      "pali": "Atha kho, bhikkhave, sakko devānamindo vejayantapāsādā orohanto añjaliṁ katvā sudaṁ puthuddisā namassati."
    },
    {
      "id": "sn11.18:1.9",
      "pali": "Atha kho, bhikkhave, mātali saṅgāhako sakkaṁ devānamindaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.18:2.1",
      "pali": "‘Taṁ namassanti tevijjā,"
    },
    {
      "id": "sn11.18:2.2",
      "pali": "sabbe bhummā ca khattiyā;"
    },
    {
      "id": "sn11.18:2.3",
      "pali": "Cattāro ca mahārājā,"
    },
    {
      "id": "sn11.18:2.4",
      "pali": "tidasā ca yasassino;"
    },
    {
      "id": "sn11.18:2.5",
      "pali": "Atha ko nāma so yakkho,"
    },
    {
      "id": "sn11.18:2.6",
      "pali": "yaṁ tvaṁ sakka namassasī’ti."
    },
    {
      "id": "sn11.18:3.1",
      "pali": "‘Maṁ namassanti tevijjā,"
    },
    {
      "id": "sn11.18:3.2",
      "pali": "sabbe bhummā ca khattiyā;"
    },
    {
      "id": "sn11.18:3.3",
      "pali": "Cattāro ca mahārājā,"
    },
    {
      "id": "sn11.18:3.4",
      "pali": "tidasā ca yasassino."
    },
    {
      "id": "sn11.18:4.1",
      "pali": "Ahañca sīlasampanne,"
    },
    {
      "id": "sn11.18:4.2",
      "pali": "cirarattasamāhite;"
    },
    {
      "id": "sn11.18:4.3",
      "pali": "Sammāpabbajite vande,"
    },
    {
      "id": "sn11.18:4.4",
      "pali": "brahmacariyaparāyane."
    },
    {
      "id": "sn11.18:5.1",
      "pali": "Ye gahaṭṭhā puññakarā,"
    },
    {
      "id": "sn11.18:5.2",
      "pali": "sīlavanto upāsakā;"
    },
    {
      "id": "sn11.18:5.3",
      "pali": "Dhammena dāraṁ posenti,"
    },
    {
      "id": "sn11.18:5.4",
      "pali": "te namassāmi mātalī’ti."
    },
    {
      "id": "sn11.18:6.1",
      "pali": "‘Seṭṭhā hi kira lokasmiṁ,"
    },
    {
      "id": "sn11.18:6.2",
      "pali": "ye tvaṁ sakka namassasi;"
    },
    {
      "id": "sn11.18:6.3",
      "pali": "Ahampi te namassāmi,"
    },
    {
      "id": "sn11.18:6.4",
      "pali": "ye namassasi vāsavā’ti."
    },
    {
      "id": "sn11.18:7.1",
      "pali": "Idaṁ vatvāna maghavā,"
    },
    {
      "id": "sn11.18:7.2",
      "pali": "devarājā sujampati;"
    },
    {
      "id": "sn11.18:7.3",
      "pali": "Puthuddisā namassitvā,"
    },
    {
      "id": "sn11.18:7.4",
      "pali": "pamukho rathamāruhī”ti."
    }
  ]
}
