{
  "uid": "sn13.5",
  "title": "Pathavīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn13.5:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn13.5:1.2",
      "pali": "“Seyyathāpi, bhikkhave, puriso mahāpathaviyā satta kolaṭṭhimattiyo guḷikā upanikkhipeyya."
    },
    {
      "id": "sn13.5:1.3",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn13.5:1.4",
      "pali": "katamaṁ nu kho bahutaraṁ, yā vā satta kolaṭṭhimattiyo guḷikā upanikkhittā yā vā mahāpathavī”ti?"
    },
    {
      "id": "sn13.5:2.1",
      "pali": "“Etadeva, bhante, bahutaraṁ, yadidaṁ mahāpathavī;"
    },
    {
      "id": "sn13.5:2.2",
      "pali": "appamattikā satta kolaṭṭhimattiyo guḷikā upanikkhittā."
    },
    {
      "id": "sn13.5:2.3",
      "pali": "Neva satimaṁ kalaṁ upenti na sahassimaṁ kalaṁ upenti na satasahassimaṁ kalaṁ upenti mahāpathaviṁ upanidhāya satta kolaṭṭhimattiyo guḷikā upanikkhittā”ti."
    },
    {
      "id": "sn13.5:2.4",
      "pali": "“Evameva kho, bhikkhave …pe…"
    },
    {
      "id": "sn13.5:2.5",
      "pali": "dhammacakkhupaṭilābho”ti."
    },
    {
      "id": "sn13.5:2.6",
      "pali": "Pañcamaṁ."
    }
  ]
}
