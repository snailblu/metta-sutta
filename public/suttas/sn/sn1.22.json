{
  "uid": "sn1.22",
  "title": "Phusatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.22:1.1",
      "pali": "“Nāphusantaṁ phusati ca,"
    },
    {
      "id": "sn1.22:1.2",
      "pali": "phusantañca tato phuse;"
    },
    {
      "id": "sn1.22:1.3",
      "pali": "Tasmā phusantaṁ phusati,"
    },
    {
      "id": "sn1.22:1.4",
      "pali": "appaduṭṭhapadosinan”ti."
    },
    {
      "id": "sn1.22:2.1",
      "pali": "“Yo appaduṭṭhassa narassa dussati,"
    },
    {
      "id": "sn1.22:2.2",
      "pali": "Suddhassa posassa anaṅgaṇassa;"
    },
    {
      "id": "sn1.22:2.3",
      "pali": "Tameva bālaṁ pacceti pāpaṁ,"
    },
    {
      "id": "sn1.22:2.4",
      "pali": "Sukhumo rajo paṭivātaṁva khitto”ti."
    }
  ]
}
