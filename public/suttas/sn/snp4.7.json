{
  "uid": "snp4.7",
  "title": "Tissametteyyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp4.7:1.1",
      "pali": "“Methunamanuyuttassa,"
    },
    {
      "id": "snp4.7:1.2",
      "pali": "(iccāyasmā tisso metteyyo)"
    },
    {
      "id": "snp4.7:1.3",
      "pali": "Vighātaṁ brūhi mārisa;"
    },
    {
      "id": "snp4.7:1.4",
      "pali": "Sutvāna tava sāsanaṁ,"
    },
    {
      "id": "snp4.7:1.5",
      "pali": "Viveke sikkhissāmase”."
    },
    {
      "id": "snp4.7:2.1",
      "pali": "“Methunamanuyuttassa,"
    },
    {
      "id": "snp4.7:2.2",
      "pali": "(metteyyāti bhagavā)"
    },
    {
      "id": "snp4.7:2.3",
      "pali": "Mussate vāpi sāsanaṁ;"
    },
    {
      "id": "snp4.7:2.4",
      "pali": "Micchā ca paṭipajjati,"
    },
    {
      "id": "snp4.7:2.5",
      "pali": "Etaṁ tasmiṁ anāriyaṁ."
    },
    {
      "id": "snp4.7:3.1",
      "pali": "Eko pubbe caritvāna,"
    },
    {
      "id": "snp4.7:3.2",
      "pali": "methunaṁ yo nisevati;"
    },
    {
      "id": "snp4.7:3.3",
      "pali": "Yānaṁ bhantaṁva taṁ loke,"
    },
    {
      "id": "snp4.7:3.4",
      "pali": "hīnamāhu puthujjanaṁ."
    },
    {
      "id": "snp4.7:4.1",
      "pali": "Yaso kitti ca yā pubbe,"
    },
    {
      "id": "snp4.7:4.2",
      "pali": "hāyate vāpi tassa sā;"
    },
    {
      "id": "snp4.7:4.3",
      "pali": "Etampi disvā sikkhetha,"
    },
    {
      "id": "snp4.7:4.4",
      "pali": "methunaṁ vippahātave."
    },
    {
      "id": "snp4.7:5.1",
      "pali": "Saṅkappehi pareto so,"
    },
    {
      "id": "snp4.7:5.2",
      "pali": "kapaṇo viya jhāyati;"
    },
    {
      "id": "snp4.7:5.3",
      "pali": "Sutvā paresaṁ nigghosaṁ,"
    },
    {
      "id": "snp4.7:5.4",
      "pali": "maṅku hoti tathāvidho."
    },
    {
      "id": "snp4.7:6.1",
      "pali": "Atha satthāni kurute,"
    },
    {
      "id": "snp4.7:6.2",
      "pali": "paravādehi codito;"
    },
    {
      "id": "snp4.7:6.3",
      "pali": "Esa khvassa mahāgedho,"
    },
    {
      "id": "snp4.7:6.4",
      "pali": "mosavajjaṁ pagāhati."
    },
    {
      "id": "snp4.7:7.1",
      "pali": "Paṇḍitoti samaññāto,"
    },
    {
      "id": "snp4.7:7.2",
      "pali": "ekacariyaṁ adhiṭṭhito;"
    },
    {
      "id": "snp4.7:7.3",
      "pali": "Athāpi methune yutto,"
    },
    {
      "id": "snp4.7:7.4",
      "pali": "mandova parikissati."
    },
    {
      "id": "snp4.7:8.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp4.7:8.2",
      "pali": "Muni pubbāpare idha;"
    },
    {
      "id": "snp4.7:8.3",
      "pali": "Ekacariyaṁ daḷhaṁ kayirā,"
    },
    {
      "id": "snp4.7:8.4",
      "pali": "Na nisevetha methunaṁ."
    },
    {
      "id": "snp4.7:9.1",
      "pali": "Vivekaññeva sikkhetha,"
    },
    {
      "id": "snp4.7:9.2",
      "pali": "etaṁ ariyānamuttamaṁ;"
    },
    {
      "id": "snp4.7:9.3",
      "pali": "Na tena seṭṭho maññetha,"
    },
    {
      "id": "snp4.7:9.4",
      "pali": "sa ve nibbānasantike."
    },
    {
      "id": "snp4.7:10.1",
      "pali": "Rittassa munino carato,"
    },
    {
      "id": "snp4.7:10.2",
      "pali": "Kāmesu anapekkhino;"
    },
    {
      "id": "snp4.7:10.3",
      "pali": "Oghatiṇṇassa pihayanti,"
    },
    {
      "id": "snp4.7:10.4",
      "pali": "Kāmesu gadhitā pajā”ti."
    },
    {
      "id": "snp4.7:10.5",
      "pali": "Tissametteyyasuttaṁ sattamaṁ."
    }
  ]
}
