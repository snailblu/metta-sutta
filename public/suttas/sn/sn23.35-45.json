{
  "uid": "sn23.35-45",
  "title": "sn23.35-45",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.35:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.35:1.2",
      "pali": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ rādhaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn23.35:1.3",
      "pali": "“yo kho, rādha, māro; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo."
    },
    {
      "id": "sn23.35:1.4",
      "pali": "Ko ca, rādha, māro?"
    },
    {
      "id": "sn23.35:1.5",
      "pali": "Rūpaṁ kho, rādha, māro; tatra te chando pahātabbo …pe…"
    },
    {
      "id": "sn23.35:1.6",
      "pali": "viññāṇaṁ māro; tatra te chando pahātabbo …pe…"
    },
    {
      "id": "sn23.35:1.7",
      "pali": "yo kho, rādha, māro; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo”ti."
    },
    {
      "id": "sn23.36:1.1",
      "pali": "“Yo kho, rādha, māradhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo …pe…."
    },
    {
      "id": "sn23.37:1.1",
      "pali": "“Yaṁ kho, rādha, aniccaṁ …pe…."
    },
    {
      "id": "sn23.38:1.1",
      "pali": "“Yo kho, rādha, aniccadhammo …pe…."
    },
    {
      "id": "sn23.39:1.1",
      "pali": "“Yaṁ kho, rādha, dukkhaṁ …pe…."
    },
    {
      "id": "sn23.40:1.1",
      "pali": "“Yo kho, rādha, dukkhadhammo …pe…."
    },
    {
      "id": "sn23.41:1.1",
      "pali": "“Yo kho, rādha, anattā …pe…."
    },
    {
      "id": "sn23.42:1.1",
      "pali": "“Yo kho, rādha, anattadhammo …pe…."
    },
    {
      "id": "sn23.43:1.1",
      "pali": "“Yo kho, rādha, khayadhammo …pe…."
    },
    {
      "id": "sn23.44:1.1",
      "pali": "“Yo kho, rādha, vayadhammo …pe…."
    },
    {
      "id": "sn23.45:1.1",
      "pali": "“Yo kho, rādha, samudayadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo …pe…."
    }
  ]
}
