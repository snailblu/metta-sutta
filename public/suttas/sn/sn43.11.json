{
  "uid": "sn43.11",
  "title": "Maggaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.11:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.11:1.2",
      "pali": "Ariyo aṭṭhaṅgiko maggo."
    },
    {
      "id": "sn43.11:1.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.11:1.4",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā asaṅkhataṁ, desito asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.11:1.5",
      "pali": "Yaṁ, bhikkhave, satthārā karaṇīyaṁ sāvakānaṁ hitesinā anukampakena anukampaṁ upādāya kataṁ vo taṁ mayā."
    },
    {
      "id": "sn43.11:1.6",
      "pali": "Etāni, bhikkhave, rukkhamūlāni, etāni suññāgārāni. Jhāyatha, bhikkhave, mā pamādattha; mā pacchā vippaṭisārino ahuvattha. Ayaṁ vo amhākaṁ anusāsanī”ti."
    },
    {
      "id": "sn43.11:1.7",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn43.11:1.8",
      "pali": "Asaṅkhatasaṁyuttassa paṭhamo vaggo."
    },
    {
      "id": "sn43.11:2.1",
      "pali": "Kāyo samatho savitakko,"
    },
    {
      "id": "sn43.11:2.2",
      "pali": "suññato satipaṭṭhānā;"
    },
    {
      "id": "sn43.11:2.3",
      "pali": "Sammappadhānā iddhipādā,"
    },
    {
      "id": "sn43.11:2.4",
      "pali": "indriyabalabojjhaṅgā;"
    },
    {
      "id": "sn43.11:2.5",
      "pali": "Maggena ekādasamaṁ,"
    },
    {
      "id": "sn43.11:2.6",
      "pali": "Tassuddānaṁ pavuccati."
    }
  ]
}
