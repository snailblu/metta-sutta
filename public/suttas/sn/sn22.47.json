{
  "uid": "sn22.47",
  "title": "Samanupassanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.47:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.47:1.2",
      "pali": "“Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā anekavihitaṁ attānaṁ samanupassamānā samanupassanti, sabbete pañcupādānakkhandhe samanupassanti, etesaṁ vā aññataraṁ."
    },
    {
      "id": "sn22.47:1.3",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.47:1.4",
      "pali": "Idha, bhikkhave, assutavā puthujjano ariyānaṁ adassāvī ariyadhammassa akovido ariyadhamme avinīto, sappurisānaṁ adassāvī sappurisadhammassa akovido sappurisadhamme avinīto"
    },
    {
      "id": "sn22.47:1.5",
      "pali": "rūpaṁ attato samanupassati, rūpavantaṁ vā attānaṁ; attani vā rūpaṁ, rūpasmiṁ vā attānaṁ."
    },
    {
      "id": "sn22.47:1.6",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.47:1.7",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.47:1.8",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.47:1.9",
      "pali": "viññāṇaṁ attato samanupassati, viññāṇavantaṁ vā attānaṁ; attani vā viññāṇaṁ, viññāṇasmiṁ vā attānaṁ."
    },
    {
      "id": "sn22.47:2.1",
      "pali": "Iti ayañceva samanupassanā ‘asmī’ti cassa avigataṁ hoti."
    },
    {
      "id": "sn22.47:2.2",
      "pali": "‘Asmī’ti kho pana, bhikkhave, avigate pañcannaṁ indriyānaṁ avakkanti hoti—"
    },
    {
      "id": "sn22.47:2.3",
      "pali": "cakkhundriyassa sotindriyassa ghānindriyassa jivhindriyassa kāyindriyassa."
    },
    {
      "id": "sn22.47:2.4",
      "pali": "Atthi, bhikkhave, mano, atthi dhammā, atthi avijjādhātu."
    },
    {
      "id": "sn22.47:2.5",
      "pali": "Avijjāsamphassajena, bhikkhave, vedayitena phuṭṭhassa assutavato puthujjanassa ‘asmī’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.6",
      "pali": "‘ayamahamasmī’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.7",
      "pali": "‘bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.8",
      "pali": "‘na bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.9",
      "pali": "‘rūpī bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.10",
      "pali": "‘arūpī bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.11",
      "pali": "‘saññī bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.12",
      "pali": "‘asaññī bhavissan’tipissa hoti;"
    },
    {
      "id": "sn22.47:2.13",
      "pali": "‘nevasaññīnāsaññī bhavissan’tipissa hoti."
    },
    {
      "id": "sn22.47:3.1",
      "pali": "Tiṭṭhanteva kho, bhikkhave, tattheva pañcindriyāni."
    },
    {
      "id": "sn22.47:3.2",
      "pali": "Athettha sutavato ariyasāvakassa avijjā pahīyati, vijjā uppajjati."
    },
    {
      "id": "sn22.47:3.3",
      "pali": "Tassa avijjāvirāgā vijjuppādā ‘asmī’tipissa na hoti;"
    },
    {
      "id": "sn22.47:3.4",
      "pali": "‘ayamahamasmī’tipissa na hoti;"
    },
    {
      "id": "sn22.47:3.5",
      "pali": "‘bhavissan’ti …"
    },
    {
      "id": "sn22.47:3.6",
      "pali": "‘na bhavissan’ti …"
    },
    {
      "id": "sn22.47:3.7",
      "pali": "rūpī …"
    },
    {
      "id": "sn22.47:3.8",
      "pali": "arūpī …"
    },
    {
      "id": "sn22.47:3.9",
      "pali": "saññī …"
    },
    {
      "id": "sn22.47:3.10",
      "pali": "asaññī …"
    },
    {
      "id": "sn22.47:3.11",
      "pali": "‘nevasaññīnāsaññī bhavissan’tipissa na hotī”ti."
    },
    {
      "id": "sn22.47:3.12",
      "pali": "Pañcamaṁ."
    }
  ]
}
