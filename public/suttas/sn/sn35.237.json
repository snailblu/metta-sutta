{
  "uid": "sn35.237",
  "title": "Dutiyahatthapādopamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.237:1.1",
      "pali": "“Hatthesu, bhikkhave, sati ādānanikkhepanaṁ hoti;"
    },
    {
      "id": "sn35.237:1.2",
      "pali": "pādesu sati abhikkamapaṭikkamo hoti;"
    },
    {
      "id": "sn35.237:1.3",
      "pali": "pabbesu sati samiñjanapasāraṇaṁ hoti;"
    },
    {
      "id": "sn35.237:1.4",
      "pali": "kucchismiṁ sati jighacchā pipāsā hoti."
    },
    {
      "id": "sn35.237:1.5",
      "pali": "Evameva kho, bhikkhave, cakkhusmiṁ sati cakkhusamphassapaccayā uppajjati ajjhattaṁ sukhaṁ dukkhaṁ …pe…"
    },
    {
      "id": "sn35.237:1.6",
      "pali": "jivhāya sati …pe…"
    },
    {
      "id": "sn35.237:1.7",
      "pali": "manasmiṁ sati manosamphassapaccayā uppajjati ajjhattaṁ sukhaṁ dukkhaṁ …pe…."
    },
    {
      "id": "sn35.237:2.1",
      "pali": "Hatthesu, bhikkhave, asati ādānanikkhepanaṁ na hoti;"
    },
    {
      "id": "sn35.237:2.2",
      "pali": "pādesu asati abhikkamapaṭikkamo na hoti;"
    },
    {
      "id": "sn35.237:2.3",
      "pali": "pabbesu asati samiñjanapasāraṇaṁ na hoti;"
    },
    {
      "id": "sn35.237:2.4",
      "pali": "kucchismiṁ asati jighacchā pipāsā na hoti."
    },
    {
      "id": "sn35.237:2.5",
      "pali": "Evameva kho, bhikkhave, cakkhusmiṁ asati cakkhusamphassapaccayā nuppajjati ajjhattaṁ sukhaṁ dukkhaṁ …pe…"
    },
    {
      "id": "sn35.237:2.6",
      "pali": "jivhāya asati jivhāsamphassapaccayā nuppajjati …pe…"
    },
    {
      "id": "sn35.237:2.7",
      "pali": "manasmiṁ asati manosamphassapaccayā nuppajjati ajjhattaṁ sukhaṁ dukkhan”ti."
    },
    {
      "id": "sn35.237:2.8",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.237:2.9",
      "pali": "Samuddavaggo tatiyo."
    },
    {
      "id": "sn35.237:3.1",
      "pali": "Dve samuddā bāḷisiko,"
    },
    {
      "id": "sn35.237:3.2",
      "pali": "khīrarukkhena koṭṭhiko;"
    },
    {
      "id": "sn35.237:3.3",
      "pali": "Kāmabhū udāyī ceva,"
    },
    {
      "id": "sn35.237:3.4",
      "pali": "ādittena ca aṭṭhamaṁ;"
    },
    {
      "id": "sn35.237:3.5",
      "pali": "Hatthapādūpamā dveti,"
    },
    {
      "id": "sn35.237:3.6",
      "pali": "vaggo tena pavuccatīti."
    }
  ]
}
