{
  "uid": "sn22.139",
  "title": "Tatiyaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.139:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.139:1.2",
      "pali": "“Yaṁ, bhikkhave, aniccaṁ; tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.139:1.3",
      "pali": "Kiñca, bhikkhave, aniccaṁ?"
    },
    {
      "id": "sn22.139:1.4",
      "pali": "Rūpaṁ, bhikkhave, aniccaṁ, tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.139:1.5",
      "pali": "Vedanā aniccā …"
    },
    {
      "id": "sn22.139:1.6",
      "pali": "saññā …"
    },
    {
      "id": "sn22.139:1.7",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.139:1.8",
      "pali": "viññāṇaṁ aniccaṁ; tatra vo chandarāgo pahātabbo."
    },
    {
      "id": "sn22.139:1.9",
      "pali": "Yaṁ, bhikkhave, aniccaṁ; tatra vo chandarāgo pahātabbo”ti."
    },
    {
      "id": "sn22.139:1.10",
      "pali": "Catutthaṁ."
    }
  ]
}
