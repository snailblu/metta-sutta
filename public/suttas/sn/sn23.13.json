{
  "uid": "sn23.13",
  "title": "Aniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.13:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.13:1.3",
      "pali": "“‘aniccaṁ, aniccan’ti, bhante, vuccati."
    },
    {
      "id": "sn23.13:1.4",
      "pali": "Katamaṁ nu kho, bhante, aniccan”ti?"
    },
    {
      "id": "sn23.13:1.5",
      "pali": "“Rūpaṁ kho, rādha, aniccaṁ, vedanā aniccā, saññā aniccā, saṅkhārā aniccā, viññāṇaṁ aniccaṁ."
    },
    {
      "id": "sn23.13:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.13:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.13:1.8",
      "pali": "Tatiyaṁ."
    }
  ]
}
