{
  "uid": "sn12.12",
  "title": "Moḷiyaphaggunasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.12:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.12:1.2",
      "pali": "“Cattārome, bhikkhave, āhārā bhūtānaṁ vā sattānaṁ ṭhitiyā sambhavesīnaṁ vā anuggahāya."
    },
    {
      "id": "sn12.12:1.3",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn12.12:1.4",
      "pali": "Kabaḷīkāro āhāro oḷāriko vā sukhumo vā, phasso dutiyo, manosañcetanā tatiyā, viññāṇaṁ catutthaṁ."
    },
    {
      "id": "sn12.12:1.5",
      "pali": "Ime kho, bhikkhave, cattāro āhārā bhūtānaṁ vā sattānaṁ ṭhitiyā sambhavesīnaṁ vā anuggahāyā”ti."
    },
    {
      "id": "sn12.12:2.1",
      "pali": "Evaṁ vutte, āyasmā moḷiyaphagguno bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.12:2.2",
      "pali": "“ko nu kho, bhante, viññāṇāhāraṁ āhāretī”ti?"
    },
    {
      "id": "sn12.12:2.3",
      "pali": "“No kallo pañho”ti bhagavā avoca:"
    },
    {
      "id": "sn12.12:2.4",
      "pali": "“‘āhāretī’ti ahaṁ na vadāmi."
    },
    {
      "id": "sn12.12:2.5",
      "pali": "‘Āhāretī’ti cāhaṁ vadeyyaṁ, tatrassa kallo pañho:"
    },
    {
      "id": "sn12.12:2.6",
      "pali": "‘ko nu kho, bhante, āhāretī’ti?"
    },
    {
      "id": "sn12.12:2.7",
      "pali": "Evañcāhaṁ na vadāmi."
    },
    {
      "id": "sn12.12:2.8",
      "pali": "Evaṁ maṁ avadantaṁ yo evaṁ puccheyya:"
    },
    {
      "id": "sn12.12:2.9",
      "pali": "‘kissa nu kho, bhante, viññāṇāhāro’ti, esa kallo pañho."
    },
    {
      "id": "sn12.12:2.10",
      "pali": "Tatra kallaṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn12.12:2.11",
      "pali": "‘viññāṇāhāro āyatiṁ punabbhavābhinibbattiyā paccayo, tasmiṁ bhūte sati saḷāyatanaṁ, saḷāyatanapaccayā phasso’”ti."
    },
    {
      "id": "sn12.12:3.1",
      "pali": "“Ko nu kho, bhante, phusatī”ti?"
    },
    {
      "id": "sn12.12:3.2",
      "pali": "“No kallo pañho”ti bhagavā avoca:"
    },
    {
      "id": "sn12.12:3.3",
      "pali": "“‘phusatī’ti ahaṁ na vadāmi."
    },
    {
      "id": "sn12.12:3.4",
      "pali": "‘Phusatī’ti cāhaṁ vadeyyaṁ, tatrassa kallo pañho:"
    },
    {
      "id": "sn12.12:3.5",
      "pali": "‘ko nu kho, bhante, phusatī’ti?"
    },
    {
      "id": "sn12.12:3.6",
      "pali": "Evañcāhaṁ na vadāmi."
    },
    {
      "id": "sn12.12:3.7",
      "pali": "Evaṁ maṁ avadantaṁ yo evaṁ puccheyya:"
    },
    {
      "id": "sn12.12:3.8",
      "pali": "‘kiṁpaccayā nu kho, bhante, phasso’ti, esa kallo pañho."
    },
    {
      "id": "sn12.12:3.9",
      "pali": "Tatra kallaṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn12.12:3.10",
      "pali": "‘saḷāyatanapaccayā phasso, phassapaccayā vedanā’”ti."
    },
    {
      "id": "sn12.12:4.1",
      "pali": "“Ko nu kho, bhante, vedayatī”ti?"
    },
    {
      "id": "sn12.12:4.2",
      "pali": "“No kallo pañho”ti bhagavā avoca:"
    },
    {
      "id": "sn12.12:4.3",
      "pali": "“‘vedayatī’ti ahaṁ na vadāmi."
    },
    {
      "id": "sn12.12:4.4",
      "pali": "‘Vedayatī’ti cāhaṁ vadeyyaṁ, tatrassa kallo pañho:"
    },
    {
      "id": "sn12.12:4.5",
      "pali": "‘ko nu kho, bhante, vedayatī’ti?"
    },
    {
      "id": "sn12.12:4.6",
      "pali": "Evañcāhaṁ na vadāmi."
    },
    {
      "id": "sn12.12:4.7",
      "pali": "Evaṁ maṁ avadantaṁ yo evaṁ puccheyya:"
    },
    {
      "id": "sn12.12:4.8",
      "pali": "‘kiṁpaccayā nu kho, bhante, vedanā’ti, esa kallo pañho."
    },
    {
      "id": "sn12.12:4.9",
      "pali": "Tatra kallaṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn12.12:4.10",
      "pali": "‘phassapaccayā vedanā, vedanāpaccayā taṇhā’”ti."
    },
    {
      "id": "sn12.12:5.1",
      "pali": "“Ko nu kho, bhante, tasatī”ti?"
    },
    {
      "id": "sn12.12:5.2",
      "pali": "“No kallo pañho”ti bhagavā avoca:"
    },
    {
      "id": "sn12.12:5.3",
      "pali": "“‘tasatī’ti ahaṁ na vadāmi."
    },
    {
      "id": "sn12.12:5.4",
      "pali": "‘Tasatī’ti cāhaṁ vadeyyaṁ, tatrassa kallo pañho:"
    },
    {
      "id": "sn12.12:5.5",
      "pali": "‘ko nu kho, bhante, tasatī’ti?"
    },
    {
      "id": "sn12.12:5.6",
      "pali": "Evañcāhaṁ na vadāmi."
    },
    {
      "id": "sn12.12:5.7",
      "pali": "Evaṁ maṁ avadantaṁ yo evaṁ puccheyya:"
    },
    {
      "id": "sn12.12:5.8",
      "pali": "‘kiṁpaccayā nu kho, bhante, taṇhā’ti, esa kallo pañho."
    },
    {
      "id": "sn12.12:5.9",
      "pali": "Tatra kallaṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn12.12:5.10",
      "pali": "‘vedanāpaccayā taṇhā, taṇhāpaccayā upādānan’”ti."
    },
    {
      "id": "sn12.12:6.1",
      "pali": "“Ko nu kho, bhante, upādiyatī”ti?"
    },
    {
      "id": "sn12.12:6.2",
      "pali": "“No kallo pañho”ti bhagavā avoca:"
    },
    {
      "id": "sn12.12:6.3",
      "pali": "“‘upādiyatī’ti ahaṁ na vadāmi."
    },
    {
      "id": "sn12.12:6.4",
      "pali": "‘Upādiyatī’ti cāhaṁ vadeyyaṁ, tatrassa kallo pañho:"
    },
    {
      "id": "sn12.12:6.5",
      "pali": "‘ko nu kho, bhante, upādiyatī’ti?"
    },
    {
      "id": "sn12.12:6.6",
      "pali": "Evañcāhaṁ na vadāmi."
    },
    {
      "id": "sn12.12:6.7",
      "pali": "Evaṁ maṁ avadantaṁ yo evaṁ puccheyya:"
    },
    {
      "id": "sn12.12:6.8",
      "pali": "‘kiṁpaccayā nu kho, bhante, upādānan’ti, esa kallo pañho."
    },
    {
      "id": "sn12.12:6.9",
      "pali": "Tatra kallaṁ veyyākaraṇaṁ:"
    },
    {
      "id": "sn12.12:6.10",
      "pali": "‘taṇhāpaccayā upādānaṁ;"
    },
    {
      "id": "sn12.12:6.11",
      "pali": "upādānapaccayā bhavo’ti …pe…"
    },
    {
      "id": "sn12.12:6.12",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.12:7.1",
      "pali": "Channaṁ tveva, phagguna, phassāyatanānaṁ asesavirāganirodhā phassanirodho;"
    },
    {
      "id": "sn12.12:7.2",
      "pali": "phassanirodhā vedanānirodho;"
    },
    {
      "id": "sn12.12:7.3",
      "pali": "vedanānirodhā taṇhānirodho;"
    },
    {
      "id": "sn12.12:7.4",
      "pali": "taṇhānirodhā upādānanirodho;"
    },
    {
      "id": "sn12.12:7.5",
      "pali": "upādānanirodhā bhavanirodho;"
    },
    {
      "id": "sn12.12:7.6",
      "pali": "bhavanirodhā jātinirodho;"
    },
    {
      "id": "sn12.12:7.7",
      "pali": "jātinirodhā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā nirujjhanti."
    },
    {
      "id": "sn12.12:7.8",
      "pali": "Evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.12:7.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
