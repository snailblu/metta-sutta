{
  "uid": "sn22.40",
  "title": "Dutiyaanudhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.40:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.40:1.2",
      "pali": "“Dhammānudhammappaṭipannassa, bhikkhave, bhikkhuno ayamanudhammo hoti yaṁ rūpe aniccānupassī vihareyya …pe…"
    },
    {
      "id": "sn22.40:1.3",
      "pali": "‘parimuccati dukkhasmā’ti vadāmī”ti."
    },
    {
      "id": "sn22.40:1.4",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
