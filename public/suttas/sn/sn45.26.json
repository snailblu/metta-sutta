{
  "uid": "sn45.26",
  "title": "Dutiyaasappurisasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.26:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.26:1.2",
      "pali": "“Asappurisañca vo, bhikkhave, desessāmi, asappurisena asappurisatarañca."
    },
    {
      "id": "sn45.26:1.3",
      "pali": "Sappurisañca vo, bhikkhave, desessāmi sappurisena sappurisatarañca."
    },
    {
      "id": "sn45.26:1.4",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.26:1.5",
      "pali": "Katamo ca, bhikkhave, asappuriso?"
    },
    {
      "id": "sn45.26:1.6",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāsamādhi—"
    },
    {
      "id": "sn45.26:1.7",
      "pali": "ayaṁ vuccati, bhikkhave, asappuriso."
    },
    {
      "id": "sn45.26:2.1",
      "pali": "Katamo ca, bhikkhave, asappurisena asappurisataro?"
    },
    {
      "id": "sn45.26:2.2",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāsamādhi, micchāñāṇī, micchāvimutti—"
    },
    {
      "id": "sn45.26:2.3",
      "pali": "ayaṁ vuccati, bhikkhave, asappurisena asappurisataro."
    },
    {
      "id": "sn45.26:3.1",
      "pali": "Katamo ca, bhikkhave, sappuriso?"
    },
    {
      "id": "sn45.26:3.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāsamādhi—"
    },
    {
      "id": "sn45.26:3.3",
      "pali": "ayaṁ vuccati, bhikkhave, sappuriso."
    },
    {
      "id": "sn45.26:4.1",
      "pali": "Katamo ca, bhikkhave, sappurisena sappurisataro?"
    },
    {
      "id": "sn45.26:4.2",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāsamādhi, sammāñāṇī, sammāvimutti—"
    },
    {
      "id": "sn45.26:4.3",
      "pali": "ayaṁ vuccati, bhikkhave, sappurisena sappurisataro”ti."
    },
    {
      "id": "sn45.26:4.4",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
