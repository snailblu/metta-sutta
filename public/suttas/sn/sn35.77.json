{
  "uid": "sn35.77",
  "title": "Rādhadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.77:1.1",
      "pali": "“Yaṁ kho, rādha, dukkhaṁ tatra te chando pahātabbo."
    },
    {
      "id": "sn35.77:1.2",
      "pali": "Kiñca, rādha, dukkhaṁ?"
    },
    {
      "id": "sn35.77:1.3",
      "pali": "Cakkhu kho, rādha, dukkhaṁ. Tatra te chando pahātabbo."
    },
    {
      "id": "sn35.77:1.4",
      "pali": "Rūpā …"
    },
    {
      "id": "sn35.77:1.5",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.77:1.6",
      "pali": "cakkhusamphasso …"
    },
    {
      "id": "sn35.77:1.7",
      "pali": "yampidaṁ cakkhusamphassa …pe… adukkhamasukhaṁ vā tampi dukkhaṁ. Tatra te chando pahātabbo …pe…"
    },
    {
      "id": "sn35.77:1.8",
      "pali": "mano dukkho …"
    },
    {
      "id": "sn35.77:1.9",
      "pali": "dhammā …"
    },
    {
      "id": "sn35.77:1.10",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.77:1.11",
      "pali": "manosamphasso …"
    },
    {
      "id": "sn35.77:1.12",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi dukkhaṁ. Tatra te chando pahātabbo."
    },
    {
      "id": "sn35.77:1.13",
      "pali": "Yaṁ kho, rādha, dukkhaṁ tatra te chando pahātabbo”ti."
    },
    {
      "id": "sn35.77:1.14",
      "pali": "Catutthaṁ."
    }
  ]
}
