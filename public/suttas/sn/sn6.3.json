{
  "uid": "sn6.3",
  "title": "Brahmadevasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn6.3:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn6.3:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn6.3:1.3",
      "pali": "Tena kho pana samayena aññatarissā brāhmaṇiyā brahmadevo nāma putto bhagavato santike agārasmā anagāriyaṁ pabbajito hoti."
    },
    {
      "id": "sn6.3:2.1",
      "pali": "Atha kho āyasmā brahmadevo eko vūpakaṭṭho appamatto ātāpī pahitatto viharanto nacirasseva—yassatthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti, tadanuttaraṁ—brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja vihāsi."
    },
    {
      "id": "sn6.3:2.2",
      "pali": "“Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā”ti abbhaññāsi."
    },
    {
      "id": "sn6.3:2.3",
      "pali": "Aññataro ca panāyasmā brahmadevo arahataṁ ahosi."
    },
    {
      "id": "sn6.3:3.1",
      "pali": "Atha kho āyasmā brahmadevo pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisi."
    },
    {
      "id": "sn6.3:3.2",
      "pali": "Sāvatthiyaṁ sapadānaṁ piṇḍāya caramāno yena sakamātu nivesanaṁ tenupasaṅkami."
    },
    {
      "id": "sn6.3:3.3",
      "pali": "Tena kho pana samayena āyasmato brahmadevassa mātā brāhmaṇī brahmuno āhutiṁ niccaṁ paggaṇhāti."
    },
    {
      "id": "sn6.3:3.4",
      "pali": "Atha kho brahmuno sahampatissa etadahosi:"
    },
    {
      "id": "sn6.3:3.5",
      "pali": "“ayaṁ kho āyasmato brahmadevassa mātā brāhmaṇī brahmuno āhutiṁ niccaṁ paggaṇhāti."
    },
    {
      "id": "sn6.3:3.6",
      "pali": "Yannūnāhaṁ taṁ upasaṅkamitvā saṁvejeyyan”ti."
    },
    {
      "id": "sn6.3:3.7",
      "pali": "Atha kho brahmā sahampati—seyyathāpi nāma balavā puriso samiñjitaṁ vā bāhaṁ pasāreyya, pasāritaṁ vā bāhaṁ samiñjeyya; evameva—brahmaloke antarahito āyasmato brahmadevassa mātu nivesane pāturahosi."
    },
    {
      "id": "sn6.3:3.8",
      "pali": "Atha kho brahmā sahampati vehāsaṁ ṭhito āyasmato brahmadevassa mātaraṁ brāhmaṇiṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn6.3:4.1",
      "pali": "“Dūre ito brāhmaṇi brahmaloko,"
    },
    {
      "id": "sn6.3:4.2",
      "pali": "Yassāhutiṁ paggaṇhāsi niccaṁ;"
    },
    {
      "id": "sn6.3:4.3",
      "pali": "Netādiso brāhmaṇi brahmabhakkho,"
    },
    {
      "id": "sn6.3:4.4",
      "pali": "Kiṁ jappasi brahmapathaṁ ajānaṁ."
    },
    {
      "id": "sn6.3:5.1",
      "pali": "Eso hi te brāhmaṇi brahmadevo,"
    },
    {
      "id": "sn6.3:5.2",
      "pali": "Nirūpadhiko atidevapatto;"
    },
    {
      "id": "sn6.3:5.3",
      "pali": "Akiñcano bhikkhu anaññaposī,"
    },
    {
      "id": "sn6.3:5.4",
      "pali": "Yo te so piṇḍāya gharaṁ paviṭṭho."
    },
    {
      "id": "sn6.3:6.1",
      "pali": "Āhuneyyo vedagu bhāvitatto,"
    },
    {
      "id": "sn6.3:6.2",
      "pali": "Narānaṁ devānañca dakkhiṇeyyo;"
    },
    {
      "id": "sn6.3:6.3",
      "pali": "Bāhitvā pāpāni anūpalitto,"
    },
    {
      "id": "sn6.3:6.4",
      "pali": "Ghāsesanaṁ iriyati sītibhūto."
    },
    {
      "id": "sn6.3:7.1",
      "pali": "Na tassa pacchā na puratthamatthi,"
    },
    {
      "id": "sn6.3:7.2",
      "pali": "Santo vidhūmo anigho nirāso;"
    },
    {
      "id": "sn6.3:7.3",
      "pali": "Nikkhittadaṇḍo tasathāvaresu,"
    },
    {
      "id": "sn6.3:7.4",
      "pali": "So tyāhutiṁ bhuñjatu aggapiṇḍaṁ."
    },
    {
      "id": "sn6.3:8.1",
      "pali": "Visenibhūto upasantacitto,"
    },
    {
      "id": "sn6.3:8.2",
      "pali": "Nāgova danto carati anejo;"
    },
    {
      "id": "sn6.3:8.3",
      "pali": "Bhikkhu susīlo suvimuttacitto,"
    },
    {
      "id": "sn6.3:8.4",
      "pali": "So tyāhutiṁ bhuñjatu aggapiṇḍaṁ."
    },
    {
      "id": "sn6.3:9.1",
      "pali": "Tasmiṁ pasannā avikampamānā,"
    },
    {
      "id": "sn6.3:9.2",
      "pali": "Patiṭṭhapehi dakkhiṇaṁ dakkhiṇeyye;"
    },
    {
      "id": "sn6.3:9.3",
      "pali": "Karohi puññaṁ sukhamāyatikaṁ,"
    },
    {
      "id": "sn6.3:9.4",
      "pali": "Disvā muniṁ brāhmaṇi oghatiṇṇanti."
    },
    {
      "id": "sn6.3:10.1",
      "pali": "Tasmiṁ pasannā avikampamānā,"
    },
    {
      "id": "sn6.3:10.2",
      "pali": "Patiṭṭhapesi dakkhiṇaṁ dakkhiṇeyye;"
    },
    {
      "id": "sn6.3:10.3",
      "pali": "Akāsi puññaṁ sukhamāyatikaṁ,"
    },
    {
      "id": "sn6.3:10.4",
      "pali": "Disvā muniṁ brāhmaṇī oghatiṇṇan”ti."
    }
  ]
}
