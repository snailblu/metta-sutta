{
  "uid": "sn22.151",
  "title": "Etaṁmamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.151:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.151:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa:"
    },
    {
      "id": "sn22.151:1.3",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’ti samanupassatī”ti?"
    },
    {
      "id": "sn22.151:1.4",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.151:1.5",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa …pe…"
    },
    {
      "id": "sn22.151:1.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa:"
    },
    {
      "id": "sn22.151:1.7",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’ti samanupassati."
    },
    {
      "id": "sn22.151:1.8",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.151:1.9",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.151:1.10",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn22.151:1.11",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya etaṁ mama, esohamasmi, eso me attāti samanupasseyyāti?"
    },
    {
      "id": "sn22.151:1.12",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.151:1.13",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn22.151:1.14",
      "pali": "saññā …"
    },
    {
      "id": "sn22.151:1.15",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.151:1.16",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.151:1.17",
      "pali": "“Aniccaṁ, bhante” …pe…"
    },
    {
      "id": "sn22.151:1.18",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya etaṁ mama, esohamasmi, eso me attāti samanupasseyyāti?"
    },
    {
      "id": "sn22.151:1.19",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.151:1.20",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.151:1.21",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.151:1.22",
      "pali": "Dutiyaṁ."
    }
  ]
}
