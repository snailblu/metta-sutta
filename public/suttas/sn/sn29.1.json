{
  "uid": "sn29.1",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn29.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn29.1:1.2",
      "pali": "“Catasso imā, bhikkhave, nāgayoniyo."
    },
    {
      "id": "sn29.1:1.3",
      "pali": "Katamā catasso?"
    },
    {
      "id": "sn29.1:1.4",
      "pali": "Aṇḍajā nāgā, jalābujā nāgā, saṁsedajā nāgā, opapātikā nāgā—"
    },
    {
      "id": "sn29.1:1.5",
      "pali": "imā kho, bhikkhave, catasso nāgayoniyo”ti."
    },
    {
      "id": "sn29.1:1.6",
      "pali": "Paṭhamaṁ."
    }
  ]
}
