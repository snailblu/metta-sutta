{
  "uid": "sn10.1",
  "title": "Indakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn10.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati indakūṭe pabbate, indakassa yakkhassa bhavane."
    },
    {
      "id": "sn10.1:1.3",
      "pali": "Atha kho indako yakkho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn10.1:2.1",
      "pali": "“Rūpaṁ na jīvanti vadanti buddhā,"
    },
    {
      "id": "sn10.1:2.2",
      "pali": "Kathaṁ nvayaṁ vindatimaṁ sarīraṁ;"
    },
    {
      "id": "sn10.1:2.3",
      "pali": "Kutassa aṭṭhīyakapiṇḍameti,"
    },
    {
      "id": "sn10.1:2.4",
      "pali": "Kathaṁ nvayaṁ sajjati gabbharasmin”ti."
    },
    {
      "id": "sn10.1:3.1",
      "pali": "“Paṭhamaṁ kalalaṁ hoti,"
    },
    {
      "id": "sn10.1:3.2",
      "pali": "kalalā hoti abbudaṁ;"
    },
    {
      "id": "sn10.1:3.3",
      "pali": "Abbudā jāyate pesi,"
    },
    {
      "id": "sn10.1:3.4",
      "pali": "pesi nibbattatī ghano;"
    },
    {
      "id": "sn10.1:3.5",
      "pali": "Ghanā pasākhā jāyanti,"
    },
    {
      "id": "sn10.1:3.6",
      "pali": "kesā lomā nakhāpi ca."
    },
    {
      "id": "sn10.1:4.1",
      "pali": "Yañcassa bhuñjatī mātā,"
    },
    {
      "id": "sn10.1:4.2",
      "pali": "annaṁ pānañca bhojanaṁ;"
    },
    {
      "id": "sn10.1:4.3",
      "pali": "Tena so tattha yāpeti,"
    },
    {
      "id": "sn10.1:4.4",
      "pali": "mātukucchigato naro”ti."
    }
  ]
}
