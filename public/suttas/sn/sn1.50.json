{
  "uid": "sn1.50",
  "title": "Ghaṭīkārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.50:1.1",
      "pali": "“Avihaṁ upapannāse,"
    },
    {
      "id": "sn1.50:1.2",
      "pali": "vimuttā satta bhikkhavo;"
    },
    {
      "id": "sn1.50:1.3",
      "pali": "Rāgadosaparikkhīṇā,"
    },
    {
      "id": "sn1.50:1.4",
      "pali": "tiṇṇā loke visattikan”ti."
    },
    {
      "id": "sn1.50:2.1",
      "pali": "“Ke ca te ataruṁ paṅkaṁ,"
    },
    {
      "id": "sn1.50:2.2",
      "pali": "maccudheyyaṁ suduttaraṁ;"
    },
    {
      "id": "sn1.50:2.3",
      "pali": "Ke hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "sn1.50:2.4",
      "pali": "dibbayogaṁ upaccagun”ti."
    },
    {
      "id": "sn1.50:3.1",
      "pali": "“Upako palagaṇḍo ca,"
    },
    {
      "id": "sn1.50:3.2",
      "pali": "pukkusāti ca te tayo;"
    },
    {
      "id": "sn1.50:3.3",
      "pali": "Bhaddiyo khaṇḍadevo ca,"
    },
    {
      "id": "sn1.50:3.4",
      "pali": "bāhuraggi ca siṅgiyo;"
    },
    {
      "id": "sn1.50:3.5",
      "pali": "Te hitvā mānusaṁ dehaṁ,"
    },
    {
      "id": "sn1.50:3.6",
      "pali": "dibbayogaṁ upaccagun”ti."
    },
    {
      "id": "sn1.50:4.1",
      "pali": "“Kusalī bhāsasī tesaṁ,"
    },
    {
      "id": "sn1.50:4.2",
      "pali": "mārapāsappahāyinaṁ;"
    },
    {
      "id": "sn1.50:4.3",
      "pali": "Kassa te dhammamaññāya,"
    },
    {
      "id": "sn1.50:4.4",
      "pali": "acchiduṁ bhavabandhanan”ti."
    },
    {
      "id": "sn1.50:5.1",
      "pali": "“Na aññatra bhagavatā,"
    },
    {
      "id": "sn1.50:5.2",
      "pali": "nāññatra tava sāsanā;"
    },
    {
      "id": "sn1.50:5.3",
      "pali": "Yassa te dhammamaññāya,"
    },
    {
      "id": "sn1.50:5.4",
      "pali": "acchiduṁ bhavabandhanaṁ."
    },
    {
      "id": "sn1.50:6.1",
      "pali": "Yattha nāmañca rūpañca,"
    },
    {
      "id": "sn1.50:6.2",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "sn1.50:6.3",
      "pali": "Taṁ te dhammaṁ idhaññāya,"
    },
    {
      "id": "sn1.50:6.4",
      "pali": "acchiduṁ bhavabandhanan”ti."
    },
    {
      "id": "sn1.50:7.1",
      "pali": "“Gambhīraṁ bhāsasī vācaṁ,"
    },
    {
      "id": "sn1.50:7.2",
      "pali": "dubbijānaṁ sudubbudhaṁ;"
    },
    {
      "id": "sn1.50:7.3",
      "pali": "Kassa tvaṁ dhammamaññāya,"
    },
    {
      "id": "sn1.50:7.4",
      "pali": "vācaṁ bhāsasi īdisan”ti."
    },
    {
      "id": "sn1.50:8.1",
      "pali": "“Kumbhakāro pure āsiṁ,"
    },
    {
      "id": "sn1.50:8.2",
      "pali": "vekaḷiṅge ghaṭīkaro;"
    },
    {
      "id": "sn1.50:8.3",
      "pali": "Mātāpettibharo āsiṁ,"
    },
    {
      "id": "sn1.50:8.4",
      "pali": "kassapassa upāsako."
    },
    {
      "id": "sn1.50:9.1",
      "pali": "Virato methunā dhammā,"
    },
    {
      "id": "sn1.50:9.2",
      "pali": "brahmacārī nirāmiso;"
    },
    {
      "id": "sn1.50:9.3",
      "pali": "Ahuvā te sagāmeyyo,"
    },
    {
      "id": "sn1.50:9.4",
      "pali": "ahuvā te pure sakhā."
    },
    {
      "id": "sn1.50:10.1",
      "pali": "Sohamete pajānāmi,"
    },
    {
      "id": "sn1.50:10.2",
      "pali": "vimutte satta bhikkhavo;"
    },
    {
      "id": "sn1.50:10.3",
      "pali": "Rāgadosaparikkhīṇe,"
    },
    {
      "id": "sn1.50:10.4",
      "pali": "tiṇṇe loke visattikan”ti."
    },
    {
      "id": "sn1.50:11.1",
      "pali": "“Evametaṁ tadā āsi,"
    },
    {
      "id": "sn1.50:11.2",
      "pali": "yathā bhāsasi bhaggava;"
    },
    {
      "id": "sn1.50:11.3",
      "pali": "Kumbhakāro pure āsi,"
    },
    {
      "id": "sn1.50:11.4",
      "pali": "vekaḷiṅge ghaṭīkaro;"
    },
    {
      "id": "sn1.50:11.5",
      "pali": "Mātāpettibharo āsi,"
    },
    {
      "id": "sn1.50:11.6",
      "pali": "kassapassa upāsako."
    },
    {
      "id": "sn1.50:12.1",
      "pali": "Virato methunā dhammā,"
    },
    {
      "id": "sn1.50:12.2",
      "pali": "brahmacārī nirāmiso;"
    },
    {
      "id": "sn1.50:12.3",
      "pali": "Ahuvā me sagāmeyyo,"
    },
    {
      "id": "sn1.50:12.4",
      "pali": "ahuvā me pure sakhā”ti."
    },
    {
      "id": "sn1.50:13.1",
      "pali": "“Evametaṁ purāṇānaṁ,"
    },
    {
      "id": "sn1.50:13.2",
      "pali": "sahāyānaṁ ahu saṅgamo;"
    },
    {
      "id": "sn1.50:13.3",
      "pali": "Ubhinnaṁ bhāvitattānaṁ,"
    },
    {
      "id": "sn1.50:13.4",
      "pali": "sarīrantimadhārinan”ti."
    },
    {
      "id": "sn1.50:13.5",
      "pali": "Ādittavaggo pañcamo."
    },
    {
      "id": "sn1.50:14.1",
      "pali": "Ādittaṁ kiṁdadaṁ annaṁ,"
    },
    {
      "id": "sn1.50:14.2",
      "pali": "ekamūlaanomiyaṁ;"
    },
    {
      "id": "sn1.50:14.3",
      "pali": "Accharāvanaropajetaṁ,"
    },
    {
      "id": "sn1.50:14.4",
      "pali": "maccharena ghaṭīkaroti."
    }
  ]
}
