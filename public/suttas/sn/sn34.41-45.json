{
  "uid": "sn34.41-45",
  "title": "Ārammaṇamūlakagocarasuttādipañcaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.41-45:1.1",
      "pali": "Sāvatthinidānaṁ …"
    },
    {
      "id": "sn34.41-45:1.2",
      "pali": "“samādhismiṁ ārammaṇakusalo hoti, na samādhismiṁ gocarakusalo …"
    },
    {
      "id": "sn34.41-45:1.3",
      "pali": "samādhismiṁ gocarakusalo hoti, na samādhismiṁ ārammaṇakusalo …"
    },
    {
      "id": "sn34.41-45:1.4",
      "pali": "neva samādhismiṁ ārammaṇakusalo hoti, na ca samādhismiṁ gocarakusalo …"
    },
    {
      "id": "sn34.41-45:1.5",
      "pali": "samādhismiṁ ārammaṇakusalo ca hoti, samādhismiṁ gocarakusalo ca."
    },
    {
      "id": "sn34.41-45:1.6",
      "pali": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe…"
    },
    {
      "id": "sn34.41-45:1.7",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.41-45:1.8",
      "pali": "Ekacattālīsamaṁ."
    },
    {
      "id": "sn34.41-45:1.9",
      "pali": "(Purimamūlakāni viya yāva pañcacattālīsamā ārammaṇamūlakasappāyakārīsuttā pañca suttāni pūretabbāni.)"
    },
    {
      "id": "sn34.41-45:1.10",
      "pali": "(Ārammaṇamūlakaṁ.)"
    }
  ]
}
