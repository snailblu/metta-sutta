{
  "uid": "sn19.11",
  "title": "Sasīsakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.11:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn19.11:1.2",
      "pali": "ekaṁ samayaṁ rājagahe veḷuvane."
    },
    {
      "id": "sn19.11:1.3",
      "pali": "“Idhāhaṁ, āvuso, gijjhakūṭā pabbatā orohanto addasaṁ purisaṁ gūthakūpe sasīsakaṁ nimuggaṁ …pe…"
    },
    {
      "id": "sn19.11:1.4",
      "pali": "eso, bhikkhave, satto imasmiṁyeva rājagahe pāradāriko ahosi …pe…."
    },
    {
      "id": "sn19.11:1.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
