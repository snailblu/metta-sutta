{
  "uid": "sn35.150",
  "title": "Nibbānasappāyapaṭipadāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.150:1.1",
      "pali": "“Nibbānasappāyaṁ vo, bhikkhave, paṭipadaṁ desessāmi."
    },
    {
      "id": "sn35.150:1.2",
      "pali": "Taṁ suṇātha …pe…"
    },
    {
      "id": "sn35.150:1.3",
      "pali": "katamā ca sā, bhikkhave, nibbānasappāyā paṭipadā?"
    },
    {
      "id": "sn35.150:1.4",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn35.150:1.5",
      "pali": "cakkhu niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.150:2.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.150:3.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.150:4.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.150:5.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.150:5.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.150:6.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.150:7.1",
      "pali": "“Rūpā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn35.150:8.1",
      "pali": "“Aniccā, bhante”."
    },
    {
      "id": "sn35.150:9.1",
      "pali": "“Cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.150:9.2",
      "pali": "cakkhusamphasso …pe…"
    },
    {
      "id": "sn35.150:9.3",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.150:10.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.150:11.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.150:12.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.150:13.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.150:13.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.150:14.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.150:15.1",
      "pali": "“Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako cakkhusmimpi nibbindati, rūpesupi nibbindati, cakkhuviññāṇepi nibbindati, cakkhusamphassepi nibbindati …pe…"
    },
    {
      "id": "sn35.150:15.2",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati."
    },
    {
      "id": "sn35.150:15.3",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati …pe…"
    },
    {
      "id": "sn35.150:15.4",
      "pali": "nāparaṁ itthattāyāti pajānāti."
    },
    {
      "id": "sn35.150:15.5",
      "pali": "Ayaṁ kho sā, bhikkhave, nibbānasappāyā paṭipadā”ti."
    },
    {
      "id": "sn35.150:15.6",
      "pali": "Pañcamaṁ."
    }
  ]
}
