{
  "uid": "sn35.226",
  "title": "Bāhirāyatanadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.226:1.1",
      "pali": "“Rūpā, bhikkhave, dukkhā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā dukkhā."
    },
    {
      "id": "sn35.226:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.226:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
