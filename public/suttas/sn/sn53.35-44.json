{
  "uid": "sn53.35-44",
  "title": "Esanāvagga",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn53.35-44:1.1",
      "pali": "(Esanāvaggo vitthāretabbo.)"
    },
    {
      "id": "sn53.35-44:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn53.35-44:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn53.35-44:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn53.35-44:2.4",
      "pali": "Vedanā taṇhā tasinā cāti."
    }
  ]
}
