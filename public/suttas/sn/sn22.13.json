{
  "uid": "sn22.13",
  "title": "Dukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.13:1.2",
      "pali": "“Rūpaṁ, bhikkhave, dukkhaṁ, vedanā dukkhā, saññā dukkhā, saṅkhārā dukkhā, viññāṇaṁ dukkhaṁ."
    },
    {
      "id": "sn22.13:1.3",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.13:1.4",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.13:1.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
