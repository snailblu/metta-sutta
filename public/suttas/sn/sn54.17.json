  "title": "Saṁyojanappahānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn54.17:1.1",
      "pali": "“Ānāpānassatisamādhi, bhikkhave, bhāvito bahulīkato saṁyojanappahānāya saṁvattati …pe…."
