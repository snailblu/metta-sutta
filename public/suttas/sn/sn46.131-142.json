{
  "uid": "sn46.131-142",
  "title": "Punagaṅgānadīādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.131-142:1.1",
      "pali": "…pe…"
    },
    {
      "id": "sn46.131-142:1.2",
      "pali": "vaggo cuddasamo."
    },
    {
      "id": "sn46.131-142:2.1",
      "pali": "Cha pācīnato ninnā,"
    },
    {
      "id": "sn46.131-142:2.2",
      "pali": "cha ninnā ca samuddato;"
    },
    {
      "id": "sn46.131-142:2.3",
      "pali": "Dvete cha dvādasa honti,"
    },
    {
      "id": "sn46.131-142:2.4",
      "pali": "vaggo tena pavuccatīti."
    },
    {
      "id": "sn46.131-142:3.1",
      "pali": "(Bojjhaṅgasaṁyuttassa gaṅgāpeyyālaṁ rāgavasena vitthāretabbaṁ.)"
    }
  ]
}
