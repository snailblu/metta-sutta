{
  "uid": "sn11.1",
  "title": "Suvīrasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn11.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn11.1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn11.1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn11.1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn11.1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn11.1:2.1",
      "pali": "“Bhūtapubbaṁ, bhikkhave, asurā deve abhiyaṁsu."
    },
    {
      "id": "sn11.1:2.2",
      "pali": "Atha kho, bhikkhave, sakko devānamindo suvīraṁ devaputtaṁ āmantesi:"
    },
    {
      "id": "sn11.1:2.3",
      "pali": "‘ete, tāta suvīra, asurā deve abhiyanti."
    },
    {
      "id": "sn11.1:2.4",
      "pali": "Gaccha, tāta suvīra, asure paccuyyāhī’ti."
    },
    {
      "id": "sn11.1:2.5",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, suvīro devaputto sakkassa devānamindassa paṭissutvā pamādaṁ āpādesi."
    },
    {
      "id": "sn11.1:2.6",
      "pali": "Dutiyampi kho, bhikkhave, sakko devānamindo suvīraṁ devaputtaṁ āmantesi:"
    },
    {
      "id": "sn11.1:2.7",
      "pali": "‘ete, tāta suvīra, asurā deve abhiyanti."
    },
    {
      "id": "sn11.1:2.8",
      "pali": "Gaccha, tāta suvīra, asure paccuyyāhī’ti."
    },
    {
      "id": "sn11.1:2.9",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, suvīro devaputto sakkassa devānamindassa paṭissutvā dutiyampi pamādaṁ āpādesi."
    },
    {
      "id": "sn11.1:2.10",
      "pali": "Tatiyampi kho, bhikkhave, sakko devānamindo suvīraṁ devaputtaṁ āmantesi:"
    },
    {
      "id": "sn11.1:2.11",
      "pali": "‘ete, tāta suvīra, asurā deve abhiyanti."
    },
    {
      "id": "sn11.1:2.12",
      "pali": "Gaccha, tāta suvīra, asure paccuyyāhī’ti."
    },
    {
      "id": "sn11.1:2.13",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, suvīro devaputto sakkassa devānamindassa paṭissutvā tatiyampi pamādaṁ āpādesi."
    },
    {
      "id": "sn11.1:2.14",
      "pali": "Atha kho, bhikkhave, sakko devānamindo suvīraṁ devaputtaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.1:3.1",
      "pali": "‘Anuṭṭhahaṁ avāyāmaṁ,"
    },
    {
      "id": "sn11.1:3.2",
      "pali": "sukhaṁ yatrādhigacchati;"
    },
    {
      "id": "sn11.1:3.3",
      "pali": "Suvīra tattha gacchāhi,"
    },
    {
      "id": "sn11.1:3.4",
      "pali": "mañca tattheva pāpayā’ti."
    },
    {
      "id": "sn11.1:4.1",
      "pali": "‘Alasvassa anuṭṭhātā,"
    },
    {
      "id": "sn11.1:4.2",
      "pali": "na ca kiccāni kāraye;"
    },
    {
      "id": "sn11.1:4.3",
      "pali": "Sabbakāmasamiddhassa,"
    },
    {
      "id": "sn11.1:4.4",
      "pali": "taṁ me sakka varaṁ disā’ti."
    },
    {
      "id": "sn11.1:5.1",
      "pali": "‘Yatthālaso anuṭṭhātā,"
    },
    {
      "id": "sn11.1:5.2",
      "pali": "accantaṁ sukhamedhati;"
    },
    {
      "id": "sn11.1:5.3",
      "pali": "Suvīra tattha gacchāhi,"
    },
    {
      "id": "sn11.1:5.4",
      "pali": "mañca tattheva pāpayā’ti."
    },
    {
      "id": "sn11.1:6.1",
      "pali": "‘Akammunā devaseṭṭha,"
    },
    {
      "id": "sn11.1:6.2",
      "pali": "sakka vindemu yaṁ sukhaṁ;"
    },
    {
      "id": "sn11.1:6.3",
      "pali": "Asokaṁ anupāyāsaṁ,"
    },
    {
      "id": "sn11.1:6.4",
      "pali": "taṁ me sakka varaṁ disā’ti."
    },
    {
      "id": "sn11.1:7.1",
      "pali": "‘Sace atthi akammena,"
    },
    {
      "id": "sn11.1:7.2",
      "pali": "koci kvaci na jīvati;"
    },
    {
      "id": "sn11.1:7.3",
      "pali": "Nibbānassa hi so maggo,"
    },
    {
      "id": "sn11.1:7.4",
      "pali": "suvīra tattha gacchāhi;"
    },
    {
      "id": "sn11.1:7.5",
      "pali": "Mañca tattheva pāpayā’ti."
    },
    {
      "id": "sn11.1:8.1",
      "pali": "So hi nāma, bhikkhave, sakko devānamindo sakaṁ puññaphalaṁ upajīvamāno devānaṁ tāvatiṁsānaṁ issariyādhipaccaṁ rajjaṁ kārento uṭṭhānavīriyassa vaṇṇavādī bhavissati."
    },
    {
      "id": "sn11.1:8.2",
      "pali": "Idha kho taṁ, bhikkhave, sobhetha, yaṁ tumhe evaṁ svākkhāte dhammavinaye pabbajitā samānā uṭṭhaheyyātha ghaṭeyyātha vāyameyyātha appattassa pattiyā anadhigatassa adhigamāya, asacchikatassa sacchikiriyāyā”ti."
    }
  ]
}
