{
  "uid": "sn35.23",
  "title": "Sabbasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.23:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn35.23:1.2",
      "pali": "“Sabbaṁ vo, bhikkhave, desessāmi."
    },
    {
      "id": "sn35.23:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.23:1.4",
      "pali": "Kiñca, bhikkhave, sabbaṁ?"
    },
    {
      "id": "sn35.23:1.5",
      "pali": "Cakkhuñceva rūpā ca, sotañca saddā ca, ghānañca gandhā ca, jivhā ca rasā ca, kāyo ca phoṭṭhabbā ca, mano ca dhammā ca—"
    },
    {
      "id": "sn35.23:1.6",
      "pali": "idaṁ vuccati, bhikkhave, sabbaṁ."
    },
    {
      "id": "sn35.23:1.7",
      "pali": "Yo, bhikkhave, evaṁ vadeyya:"
    },
    {
      "id": "sn35.23:1.8",
      "pali": "‘ahametaṁ sabbaṁ paccakkhāya aññaṁ sabbaṁ paññāpessāmī’ti, tassa vācāvatthukamevassa;"
    },
    {
      "id": "sn35.23:1.9",
      "pali": "puṭṭho ca na sampāyeyya, uttariñca vighātaṁ āpajjeyya."
    },
    {
      "id": "sn35.23:1.10",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn35.23:1.11",
      "pali": "Yathā taṁ, bhikkhave, avisayasmin”ti."
    },
    {
      "id": "sn35.23:1.12",
      "pali": "Paṭhamaṁ."
    }
  ]
}
