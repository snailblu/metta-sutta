{
  "uid": "sn22.27",
  "title": "Dutiyaassādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.27:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.27:1.2",
      "pali": "“Rūpassāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.3",
      "pali": "Yo rūpassa assādo tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.4",
      "pali": "Yāvatā rūpassa assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn22.27:1.5",
      "pali": "Rūpassāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.6",
      "pali": "Yo rūpassa ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.7",
      "pali": "Yāvatā rūpassa ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn22.27:1.8",
      "pali": "Rūpassāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.9",
      "pali": "Yaṁ rūpassa nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.10",
      "pali": "Yāvatā rūpassa nissaraṇaṁ paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn22.27:1.11",
      "pali": "Vedanāyāhaṁ, bhikkhave …"
    },
    {
      "id": "sn22.27:1.12",
      "pali": "saññāyāhaṁ, bhikkhave …"
    },
    {
      "id": "sn22.27:1.13",
      "pali": "saṅkhārānāhaṁ, bhikkhave …"
    },
    {
      "id": "sn22.27:1.14",
      "pali": "viññāṇassāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.15",
      "pali": "Yo viññāṇassa assādo tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.16",
      "pali": "Yāvatā viññāṇassa assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn22.27:1.17",
      "pali": "Viññāṇassāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.18",
      "pali": "Yo viññāṇassa ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.19",
      "pali": "Yāvatā viññāṇassa ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn22.27:1.20",
      "pali": "Viññāṇassāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn22.27:1.21",
      "pali": "Yaṁ viññāṇassa nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn22.27:1.22",
      "pali": "Yāvatā viññāṇassa nissaraṇaṁ paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn22.27:1.23",
      "pali": "Yāvakīvañcāhaṁ, bhikkhave, imesaṁ pañcannaṁ upādānakkhandhānaṁ assādañca assādato ādīnavañca ādīnavato nissaraṇañca nissaraṇato yathābhūtaṁ nābbhaññāsiṁ …pe…"
    },
    {
      "id": "sn22.27:1.24",
      "pali": "abbhaññāsiṁ."
    },
    {
      "id": "sn22.27:1.25",
      "pali": "Ñāṇañca pana me dassanaṁ udapādi:"
    },
    {
      "id": "sn22.27:1.26",
      "pali": "‘akuppā me vimutti; ayamantimā jāti; natthi dāni punabbhavo’”ti."
    },
    {
      "id": "sn22.27:1.27",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
