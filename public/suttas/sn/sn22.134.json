{
  "uid": "sn22.134",
  "title": "Dutiyakoṭṭhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.134:1.1",
      "pali": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe…"
    },
    {
      "id": "sn22.134:1.2",
      "pali": "“‘avijjā, avijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.134:1.3",
      "pali": "Katamā nu kho, āvuso, avijjā;"
    },
    {
      "id": "sn22.134:1.4",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.134:2.1",
      "pali": "“Idhāvuso, assutavā puthujjano rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.134:2.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.134:2.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.134:2.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.134:2.5",
      "pali": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.134:2.6",
      "pali": "Ayaṁ vuccatāvuso, avijjā;"
    },
    {
      "id": "sn22.134:2.7",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.134:3.1",
      "pali": "Evaṁ vutte, āyasmā sāriputto āyasmantaṁ mahākoṭṭhikaṁ etadavoca:"
    },
    {
      "id": "sn22.134:3.2",
      "pali": "“‘vijjā, vijjā’ti, āvuso koṭṭhika, vuccati."
    },
    {
      "id": "sn22.134:3.3",
      "pali": "Katamā nu kho, āvuso, vijjā;"
    },
    {
      "id": "sn22.134:3.4",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.134:4.1",
      "pali": "“Idhāvuso, sutavā ariyasāvako rūpassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.134:4.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.134:4.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.134:4.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.134:4.5",
      "pali": "viññāṇassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.134:4.6",
      "pali": "Ayaṁ vuccatāvuso, vijjā;"
    },
    {
      "id": "sn22.134:4.7",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.134:4.8",
      "pali": "Navamaṁ."
    }
  ]
}
