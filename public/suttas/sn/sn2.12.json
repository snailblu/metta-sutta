{
  "uid": "sn2.12",
  "title": "Veṇḍusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.12:1.1",
      "pali": "Ekamantaṁ ṭhito kho veṇḍu devaputto bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.12:2.1",
      "pali": "“Sukhitāva te manujā,"
    },
    {
      "id": "sn2.12:2.2",
      "pali": "sugataṁ payirupāsiya;"
    },
    {
      "id": "sn2.12:2.3",
      "pali": "Yuñjaṁ gotamasāsane,"
    },
    {
      "id": "sn2.12:2.4",
      "pali": "appamattā nu sikkhare”ti."
    },
    {
      "id": "sn2.12:3.1",
      "pali": "“Ye me pavutte siṭṭhipade,"
    },
    {
      "id": "sn2.12:3.2",
      "pali": "(veṇḍūti bhagavā)"
    },
    {
      "id": "sn2.12:3.3",
      "pali": "Anusikkhanti jhāyino;"
    },
    {
      "id": "sn2.12:3.4",
      "pali": "Kāle te appamajjantā,"
    },
    {
      "id": "sn2.12:3.5",
      "pali": "Na maccuvasagā siyun”ti."
    }
  ]
}
