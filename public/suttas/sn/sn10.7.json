{
  "uid": "sn10.7",
  "title": "Punabbasusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.7:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn10.7:1.2",
      "pali": "Tena kho pana samayena bhagavā bhikkhū nibbānapaṭisaṁyuttāya dhammiyā kathāya sandasseti samādapeti samuttejeti sampahaṁseti."
    },
    {
      "id": "sn10.7:1.3",
      "pali": "Te ca bhikkhū aṭṭhiṁ katvā manasi katvā sabbacetasā samannāharitvā ohitasotā dhammaṁ suṇanti."
    },
    {
      "id": "sn10.7:1.4",
      "pali": "Atha kho punabbasumātā yakkhinī puttake evaṁ tosesi:"
    },
    {
      "id": "sn10.7:2.1",
      "pali": "“Tuṇhī uttarike hohi,"
    },
    {
      "id": "sn10.7:2.2",
      "pali": "tuṇhī hohi punabbasu;"
    },
    {
      "id": "sn10.7:2.3",
      "pali": "Yāvāhaṁ buddhaseṭṭhassa,"
    },
    {
      "id": "sn10.7:2.4",
      "pali": "dhammaṁ sossāmi satthuno."
    },
    {
      "id": "sn10.7:3.1",
      "pali": "Nibbānaṁ bhagavā āha,"
    },
    {
      "id": "sn10.7:3.2",
      "pali": "sabbaganthappamocanaṁ;"
    },
    {
      "id": "sn10.7:3.3",
      "pali": "Ativelā ca me hoti,"
    },
    {
      "id": "sn10.7:3.4",
      "pali": "asmiṁ dhamme piyāyanā."
    },
    {
      "id": "sn10.7:4.1",
      "pali": "Piyo loke sako putto,"
    },
    {
      "id": "sn10.7:4.2",
      "pali": "piyo loke sako pati;"
    },
    {
      "id": "sn10.7:4.3",
      "pali": "Tato piyatarā mayhaṁ,"
    },
    {
      "id": "sn10.7:4.4",
      "pali": "assa dhammassa magganā."
    },
    {
      "id": "sn10.7:5.1",
      "pali": "Na hi putto pati vāpi,"
    },
    {
      "id": "sn10.7:5.2",
      "pali": "piyo dukkhā pamocaye;"
    },
    {
      "id": "sn10.7:5.3",
      "pali": "Yathā saddhammassavanaṁ,"
    },
    {
      "id": "sn10.7:5.4",
      "pali": "dukkhā moceti pāṇinaṁ."
    },
    {
      "id": "sn10.7:6.1",
      "pali": "Loke dukkhaparetasmiṁ,"
    },
    {
      "id": "sn10.7:6.2",
      "pali": "Jarāmaraṇasaṁyute;"
    },
    {
      "id": "sn10.7:6.3",
      "pali": "Jarāmaraṇamokkhāya,"
    },
    {
      "id": "sn10.7:6.4",
      "pali": "Yaṁ dhammaṁ abhisambudhaṁ;"
    },
    {
      "id": "sn10.7:6.5",
      "pali": "Taṁ dhammaṁ sotumicchāmi,"
    },
    {
      "id": "sn10.7:6.6",
      "pali": "Tuṇhī hohi punabbasū”ti."
    },
    {
      "id": "sn10.7:7.1",
      "pali": "“Ammā na byāharissāmi,"
    },
    {
      "id": "sn10.7:7.2",
      "pali": "tuṇhībhūtāyamuttarā;"
    },
    {
      "id": "sn10.7:7.3",
      "pali": "Dhammameva nisāmehi,"
    },
    {
      "id": "sn10.7:7.4",
      "pali": "saddhammassavanaṁ sukhaṁ;"
    },
    {
      "id": "sn10.7:7.5",
      "pali": "Saddhammassa anaññāya,"
    },
    {
      "id": "sn10.7:7.6",
      "pali": "ammā dukkhaṁ carāmase."
    },
    {
      "id": "sn10.7:8.1",
      "pali": "Esa devamanussānaṁ,"
    },
    {
      "id": "sn10.7:8.2",
      "pali": "sammūḷhānaṁ pabhaṅkaro;"
    },
    {
      "id": "sn10.7:8.3",
      "pali": "Buddho antimasārīro,"
    },
    {
      "id": "sn10.7:8.4",
      "pali": "dhammaṁ deseti cakkhumā”ti."
    },
    {
      "id": "sn10.7:9.1",
      "pali": "“Sādhu kho paṇḍito nāma,"
    },
    {
      "id": "sn10.7:9.2",
      "pali": "putto jāto uresayo;"
    },
    {
      "id": "sn10.7:9.3",
      "pali": "Putto me buddhaseṭṭhassa,"
    },
    {
      "id": "sn10.7:9.4",
      "pali": "dhammaṁ suddhaṁ piyāyati."
    },
    {
      "id": "sn10.7:10.1",
      "pali": "Punabbasu sukhī hohi,"
    },
    {
      "id": "sn10.7:10.2",
      "pali": "ajjāhamhi samuggatā;"
    },
    {
      "id": "sn10.7:10.3",
      "pali": "Diṭṭhāni ariyasaccāni,"
    },
    {
      "id": "sn10.7:10.4",
      "pali": "uttarāpi suṇātu me”ti."
    }
  ]
}
