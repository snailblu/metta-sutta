{
  "uid": "snp5.6",
  "title": "Dhotakamāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.6:1.1",
      "pali": "“Pucchāmi taṁ bhagavā brūhi metaṁ,"
    },
    {
      "id": "snp5.6:1.2",
      "pali": "(iccāyasmā dhotako)"
    },
    {
      "id": "snp5.6:1.3",
      "pali": "Vācābhikaṅkhāmi mahesi tuyhaṁ;"
    },
    {
      "id": "snp5.6:1.4",
      "pali": "Tava sutvāna nigghosaṁ,"
    },
    {
      "id": "snp5.6:1.5",
      "pali": "Sikkhe nibbānamattano”."
    },
    {
      "id": "snp5.6:2.1",
      "pali": "“Tenahātappaṁ karohi,"
    },
    {
      "id": "snp5.6:2.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "snp5.6:2.3",
      "pali": "Idheva nipako sato;"
    },
    {
      "id": "snp5.6:2.4",
      "pali": "Ito sutvāna nigghosaṁ,"
    },
    {
      "id": "snp5.6:2.5",
      "pali": "Sikkhe nibbānamattano”."
    },
    {
      "id": "snp5.6:3.1",
      "pali": "“Passāmahaṁ devamanussaloke,"
    },
    {
      "id": "snp5.6:3.2",
      "pali": "Akiñcanaṁ brāhmaṇamiriyamānaṁ;"
    },
    {
      "id": "snp5.6:3.3",
      "pali": "Taṁ taṁ namassāmi samantacakkhu,"
    },
    {
      "id": "snp5.6:3.4",
      "pali": "Pamuñca maṁ sakka kathaṅkathāhi”."
    },
    {
      "id": "snp5.6:4.1",
      "pali": "“Nāhaṁ sahissāmi pamocanāya,"
    },
    {
      "id": "snp5.6:4.2",
      "pali": "Kathaṅkathiṁ dhotaka kañci loke;"
    },
    {
      "id": "snp5.6:4.3",
      "pali": "Dhammañca seṭṭhaṁ abhijānamāno,"
    },
    {
      "id": "snp5.6:4.4",
      "pali": "Evaṁ tuvaṁ oghamimaṁ taresi”."
    },
    {
      "id": "snp5.6:5.1",
      "pali": "“Anusāsa brahme karuṇāyamāno,"
    },
    {
      "id": "snp5.6:5.2",
      "pali": "Vivekadhammaṁ yamahaṁ vijaññaṁ;"
    },
    {
      "id": "snp5.6:5.3",
      "pali": "Yathāhaṁ ākāsova abyāpajjamāno,"
    },
    {
      "id": "snp5.6:5.4",
      "pali": "Idheva santo asito careyyaṁ”."
    },
    {
      "id": "snp5.6:6.1",
      "pali": "“Kittayissāmi te santiṁ,"
    },
    {
      "id": "snp5.6:6.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "snp5.6:6.3",
      "pali": "Diṭṭhe dhamme anītihaṁ;"
    },
    {
      "id": "snp5.6:6.4",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "snp5.6:6.5",
      "pali": "Tare loke visattikaṁ”."
    },
    {
      "id": "snp5.6:7.1",
      "pali": "“Tañcāhaṁ abhinandāmi,"
    },
    {
      "id": "snp5.6:7.2",
      "pali": "mahesi santimuttamaṁ;"
    },
    {
      "id": "snp5.6:7.3",
      "pali": "Yaṁ viditvā sato caraṁ,"
    },
    {
      "id": "snp5.6:7.4",
      "pali": "tare loke visattikaṁ”."
    },
    {
      "id": "snp5.6:8.1",
      "pali": "“Yaṁ kiñci sampajānāsi,"
    },
    {
      "id": "snp5.6:8.2",
      "pali": "(dhotakāti bhagavā)"
    },
    {
      "id": "snp5.6:8.3",
      "pali": "Uddhaṁ adho tiriyañcāpi majjhe;"
    },
    {
      "id": "snp5.6:8.4",
      "pali": "Etaṁ viditvā saṅgoti loke,"
    },
    {
      "id": "snp5.6:8.5",
      "pali": "Bhavābhavāya mākāsi taṇhan”ti."
    },
    {
      "id": "snp5.6:8.6",
      "pali": "Dhotakamāṇavapucchā pañcamī."
    }
  ]
}
