{
  "uid": "sn45.12",
  "title": "Dutiyavihārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.12:1.2",
      "pali": "“Icchāmahaṁ, bhikkhave, temāsaṁ paṭisallīyituṁ."
    },
    {
      "id": "sn45.12:1.3",
      "pali": "Namhi kenaci upasaṅkamitabbo, aññatra ekena piṇḍapātanīhārakenā”ti."
    },
    {
      "id": "sn45.12:1.4",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paṭissutvā nāssudha koci bhagavantaṁ upasaṅkamati, aññatra ekena piṇḍapātanīhārakena."
    },
    {
      "id": "sn45.12:2.1",
      "pali": "Atha kho bhagavā tassa temāsassa accayena paṭisallānā vuṭṭhito bhikkhū āmantesi:"
    },
    {
      "id": "sn45.12:2.2",
      "pali": "“yena svāhaṁ, bhikkhave, vihārena paṭhamābhisambuddho viharāmi, tassa padesena vihāsiṁ."
    },
    {
      "id": "sn45.12:2.3",
      "pali": "So evaṁ pajānāmi:"
    },
    {
      "id": "sn45.12:2.4",
      "pali": "‘micchādiṭṭhipaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.5",
      "pali": "micchādiṭṭhivūpasamapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.6",
      "pali": "sammādiṭṭhipaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.7",
      "pali": "sammādiṭṭhivūpasamapaccayāpi vedayitaṁ …pe…"
    },
    {
      "id": "sn45.12:2.8",
      "pali": "micchāsamādhipaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.9",
      "pali": "micchāsamādhivūpasamapaccayāpi vedayitaṁ, sammāsamādhipaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.10",
      "pali": "sammāsamādhivūpasamapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.11",
      "pali": "chandapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.12",
      "pali": "chandavūpasamapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.13",
      "pali": "vitakkapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.14",
      "pali": "vitakkavūpasamapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.15",
      "pali": "saññāpaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.16",
      "pali": "saññāvūpasamapaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.17",
      "pali": "chando ca avūpasanto hoti, vitakko ca avūpasanto hoti, saññā ca avūpasantā hoti, tappaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.18",
      "pali": "chando ca vūpasanto hoti, vitakko ca vūpasanto hoti, saññā ca vūpasantā hoti, tappaccayāpi vedayitaṁ;"
    },
    {
      "id": "sn45.12:2.19",
      "pali": "appattassa pattiyā atthi āyāmaṁ, tasmimpi ṭhāne anuppatte tappaccayāpi vedayitan’”ti."
    },
    {
      "id": "sn45.12:2.20",
      "pali": "Dutiyaṁ."
    }
  ]
}
