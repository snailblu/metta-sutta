{
  "uid": "sn23.14",
  "title": "Aniccadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.14:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.14:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.14:1.3",
      "pali": "“‘aniccadhammo, aniccadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.14:1.4",
      "pali": "Katamo nu kho, bhante, aniccadhammo”ti?"
    },
    {
      "id": "sn23.14:1.5",
      "pali": "“Rūpaṁ kho, rādha, aniccadhammo, vedanā aniccadhammo, saññā aniccadhammo, saṅkhārā aniccadhammo, viññāṇaṁ aniccadhammo."
    },
    {
      "id": "sn23.14:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.14:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.14:1.8",
      "pali": "Catutthaṁ."
    }
  ]
}
