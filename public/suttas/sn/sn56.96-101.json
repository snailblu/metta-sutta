{
  "uid": "sn56.96-101",
  "title": "Chedanādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn56.96-101:1.1",
      "pali": "… “Evameva kho, bhikkhave, appakā te sattā ye chedanavadhabandhanaviparāmosaālopasahasākārā paṭiviratā; atha kho eteva bahutarā sattā ye chedanavadhabandhanaviparāmosaālopasahasākārā appaṭiviratā."
    },
    {
      "id": "sn56.96-101:1.2",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn56.96-101:1.3",
      "pali": "Adiṭṭhattā bhikkhave, catunnaṁ ariyasaccānaṁ."
    },
    {
      "id": "sn56.96-101:1.4",
      "pali": "Katamesaṁ catunnaṁ?"
    },
    {
      "id": "sn56.96-101:1.5",
      "pali": "Dukkhassa ariyasaccassa …pe… dukkhanirodhagāminiyā paṭipadāya ariyasaccassa."
    },
    {
      "id": "sn56.96-101:2.1",
      "pali": "Tasmātiha, bhikkhave, ‘idaṁ dukkhan’ti yogo karaṇīyo …pe… ‘ayaṁ dukkhanirodhagāminī paṭipadā’ti yogo karaṇīyo”ti."
    },
    {
      "id": "sn56.96-101:2.2",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn56.96-101:2.3",
      "pali": "Catutthaāmakadhaññapeyyālavaggo dasamo."
    },
    {
      "id": "sn56.96-101:3.1",
      "pali": "Khettaṁ kāyaṁ dūteyyañca,"
    },
    {
      "id": "sn56.96-101:3.2",
      "pali": "tulākūṭaṁ ukkoṭanaṁ;"
    },
    {
      "id": "sn56.96-101:3.3",
      "pali": "Chedanaṁ vadhabandhanaṁ,"
    },
    {
      "id": "sn56.96-101:3.4",
      "pali": "viparālopaṁ sāhasanti."
    }
  ]
}
