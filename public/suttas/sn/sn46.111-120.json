{
  "uid": "sn46.111-120",
  "title": "Esanādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.111-120:1.1",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn46.111-120:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn46.111-120:1.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā”ti vitthāretabbaṁ."
    },
    {
      "id": "sn46.111-120:1.4",
      "pali": "Esanāvaggo dvādasamo."
    },
    {
      "id": "sn46.111-120:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn46.111-120:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn46.111-120:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn46.111-120:2.4",
      "pali": "Vedanā taṇhā tasināya cāti."
    },
    {
      "id": "sn46.111-120:3.1",
      "pali": "(Bojjhaṅgasaṁyuttassa esanāpeyyālaṁ vivekanissitato vitthāretabbaṁ.)"
    }
  ]
}
