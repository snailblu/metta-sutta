{
  "uid": "sn45.36",
  "title": "Dutiyasāmaññasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.36:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.36:1.2",
      "pali": "“Sāmaññañca vo, bhikkhave, desessāmi, sāmaññatthañca."
    },
    {
      "id": "sn45.36:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.36:1.4",
      "pali": "Katamañca kho, bhikkhave, sāmaññaṁ?"
    },
    {
      "id": "sn45.36:1.5",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn45.36:1.6",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.36:1.7",
      "pali": "Idaṁ vuccati, bhikkhave, sāmaññaṁ."
    },
    {
      "id": "sn45.36:1.8",
      "pali": "Katamo ca, bhikkhave, sāmaññattho?"
    },
    {
      "id": "sn45.36:1.9",
      "pali": "Yo kho, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn45.36:1.10",
      "pali": "ayaṁ vuccati, bhikkhave, sāmaññattho”ti."
    },
    {
      "id": "sn45.36:1.11",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
