{
  "uid": "sn35.20",
  "title": "Dutiyābhinandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.20:1.1",
      "pali": "“Yo, bhikkhave, rūpe abhinandati, dukkhaṁ so abhinandati."
    },
    {
      "id": "sn35.20:1.2",
      "pali": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn35.20:1.3",
      "pali": "Yo sadde …pe…"
    },
    {
      "id": "sn35.20:1.4",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.20:1.5",
      "pali": "rase …"
    },
    {
      "id": "sn35.20:1.6",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.20:1.7",
      "pali": "dhamme abhinandati, dukkhaṁ so abhinandati."
    },
    {
      "id": "sn35.20:1.8",
      "pali": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn35.20:2.1",
      "pali": "“Yo ca kho, bhikkhave, rūpe nābhinandati, dukkhaṁ so nābhinandati."
    },
    {
      "id": "sn35.20:2.2",
      "pali": "Yo dukkhaṁ nābhinandati, ‘aparimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn35.20:2.3",
      "pali": "Yo sadde …pe…"
    },
    {
      "id": "sn35.20:2.4",
      "pali": "gandhe …"
    },
    {
      "id": "sn35.20:2.5",
      "pali": "rase …"
    },
    {
      "id": "sn35.20:2.6",
      "pali": "phoṭṭhabbe …"
    },
    {
      "id": "sn35.20:2.7",
      "pali": "dhamme nābhinandati, dukkhaṁ so nābhinandati."
    },
    {
      "id": "sn35.20:2.8",
      "pali": "Yo dukkhaṁ nābhinandati, ‘aparimutto so dukkhasmā’ti vadāmi.”"
    },
    {
      "id": "sn35.20:2.9",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
