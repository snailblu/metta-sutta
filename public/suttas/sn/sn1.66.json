{
  "uid": "sn1.66",
  "title": "Attahatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.66:1.1",
      "pali": "“Kenassubbhāhato loko,"
    },
    {
      "id": "sn1.66:1.2",
      "pali": "kenassu parivārito;"
    },
    {
      "id": "sn1.66:1.3",
      "pali": "Kena sallena otiṇṇo,"
    },
    {
      "id": "sn1.66:1.4",
      "pali": "kissa dhūpāyito sadā”ti."
    },
    {
      "id": "sn1.66:2.1",
      "pali": "“Maccunābbhāhato loko,"
    },
    {
      "id": "sn1.66:2.2",
      "pali": "jarāya parivārito;"
    },
    {
      "id": "sn1.66:2.3",
      "pali": "Taṇhāsallena otiṇṇo,"
    },
    {
      "id": "sn1.66:2.4",
      "pali": "icchādhūpāyito sadā”ti."
    }
  ]
}
