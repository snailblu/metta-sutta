{
  "uid": "sn38.16",
  "title": "Dukkarapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.16:1.1",
      "pali": "“Kiṁ nu kho, āvuso sāriputta, imasmiṁ dhammavinaye dukkaran”ti?"
    },
    {
      "id": "sn38.16:1.2",
      "pali": "“Pabbajjā kho, āvuso, imasmiṁ dhammavinaye dukkarā”ti."
    },
    {
      "id": "sn38.16:1.3",
      "pali": "“Pabbajitena panāvuso, kiṁ dukkaran”ti?"
    },
    {
      "id": "sn38.16:1.4",
      "pali": "“Pabbajitena kho, āvuso, abhirati dukkarā”ti."
    },
    {
      "id": "sn38.16:1.5",
      "pali": "“Abhiratena panāvuso, kiṁ dukkaran”ti?"
    },
    {
      "id": "sn38.16:1.6",
      "pali": "“Abhiratena kho, āvuso, dhammānudhammappaṭipatti dukkarā”ti."
    },
    {
      "id": "sn38.16:1.7",
      "pali": "“Kīvaciraṁ panāvuso, dhammānudhammappaṭipanno bhikkhu arahaṁ assā”ti?"
    },
    {
      "id": "sn38.16:1.8",
      "pali": "“Naciraṁ, āvuso”ti."
    },
    {
      "id": "sn38.16:1.9",
      "pali": "Soḷasamaṁ."
    },
    {
      "id": "sn38.16:1.10",
      "pali": "Jambukhādakasaṁyuttaṁ samattaṁ."
    },
    {
      "id": "sn38.16:2.1",
      "pali": "Nibbānaṁ arahattañca,"
    },
    {
      "id": "sn38.16:2.2",
      "pali": "dhammavādī kimatthiyaṁ;"
    },
    {
      "id": "sn38.16:2.3",
      "pali": "Assāso paramassāso,"
    },
    {
      "id": "sn38.16:2.4",
      "pali": "vedanā āsavāvijjā;"
    },
    {
      "id": "sn38.16:2.5",
      "pali": "Taṇhā oghā upādānaṁ,"
    },
    {
      "id": "sn38.16:2.6",
      "pali": "bhavo dukkhañca sakkāyo."
    },
    {
      "id": "sn38.16:2.7",
      "pali": "Imasmiṁ dhammavinaye dukkaranti."
    }
  ]
}
