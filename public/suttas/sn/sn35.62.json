{
  "uid": "sn35.62",
  "title": "Dutiyasabbupādānapariyādānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.62:1.1",
      "pali": "“Sabbupādānapariyādānāya vo, bhikkhave, dhammaṁ desessāmi."
    },
    {
      "id": "sn35.62:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.62:1.3",
      "pali": "Katamo ca, bhikkhave, sabbupādānapariyādānāya dhammo?"
    },
    {
      "id": "sn35.62:2.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn35.62:2.2",
      "pali": "cakkhu niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.62:3.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.62:4.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.62:5.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.62:6.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.62:6.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.62:7.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.62:8.1",
      "pali": "“Rūpā …pe…"
    },
    {
      "id": "sn35.62:8.2",
      "pali": "cakkhuviññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.62:9.1",
      "pali": "“Aniccaṁ, bhante” …pe…."
    },
    {
      "id": "sn35.62:10.1",
      "pali": "“Cakkhusamphasso nicco vā anicco vā”ti?"
    },
    {
      "id": "sn35.62:11.1",
      "pali": "“Anicco, bhante” …pe…."
    },
    {
      "id": "sn35.62:12.1",
      "pali": "“Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.62:13.1",
      "pali": "“Aniccaṁ, bhante” …pe…."
    },
    {
      "id": "sn35.62:14.1",
      "pali": "“Sotaṁ …"
    },
    {
      "id": "sn35.62:14.2",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn35.62:14.3",
      "pali": "jivhā …"
    },
    {
      "id": "sn35.62:14.4",
      "pali": "kāyo …"
    },
    {
      "id": "sn35.62:14.5",
      "pali": "mano …"
    },
    {
      "id": "sn35.62:14.6",
      "pali": "dhammā …"
    },
    {
      "id": "sn35.62:14.7",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.62:14.8",
      "pali": "manosamphasso …"
    },
    {
      "id": "sn35.62:14.9",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā, tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn35.62:15.1",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn35.62:16.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "sn35.62:17.1",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "sn35.62:18.1",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "sn35.62:18.2",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "sn35.62:19.1",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.62:20.1",
      "pali": "“Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako cakkhusmimpi nibbindati, rūpesupi nibbindati, cakkhuviññāṇepi nibbindati, cakkhusamphassepi nibbindati."
    },
    {
      "id": "sn35.62:20.2",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati …pe…"
    },
    {
      "id": "sn35.62:20.3",
      "pali": "jivhāyapi nibbindati, rasesupi nibbindati, jivhāviññāṇepi nibbindati, jivhāsamphassepi nibbindati, yampidaṁ jivhāsamphassapaccayā uppajjati …pe…"
    },
    {
      "id": "sn35.62:20.4",
      "pali": "manasmimpi nibbindati, dhammesupi nibbindati, manoviññāṇepi nibbindati, manosamphassepi nibbindati."
    },
    {
      "id": "sn35.62:20.5",
      "pali": "Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tasmimpi nibbindati."
    },
    {
      "id": "sn35.62:20.6",
      "pali": "Nibbindaṁ virajjati; virāgā vimuccati; vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "sn35.62:20.7",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānāti."
    },
    {
      "id": "sn35.62:20.8",
      "pali": "Ayaṁ kho, bhikkhave, sabbupādānapariyādānāya dhammo”ti."
    },
    {
      "id": "sn35.62:20.9",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.62:20.10",
      "pali": "Avijjāvaggo paṭhamo."
    },
    {
      "id": "sn35.62:21.1",
      "pali": "Avijjā saṁyojanā dve,"
    },
    {
      "id": "sn35.62:21.2",
      "pali": "āsavena duve vuttā;"
    },
    {
      "id": "sn35.62:21.3",
      "pali": "Anusayā apare dve,"
    },
    {
      "id": "sn35.62:21.4",
      "pali": "pariññā dve pariyādinnaṁ;"
    },
    {
      "id": "sn35.62:21.5",
      "pali": "Vaggo tena pavuccatīti."
    }
  ]
}
