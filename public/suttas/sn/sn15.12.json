{
  "uid": "sn15.12",
  "title": "Sukhitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.12:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn15.12:1.2",
      "pali": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.12:1.3",
      "pali": "yaṁ, bhikkhave, passeyyātha sukhitaṁ susajjitaṁ, niṭṭhamettha gantabbaṁ:"
    },
    {
      "id": "sn15.12:1.4",
      "pali": "‘amhehipi evarūpaṁ paccanubhūtaṁ iminā dīghena addhunā’ti."
    },
    {
      "id": "sn15.12:1.5",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn15.12:1.6",
      "pali": "Anamataggoyaṁ, bhikkhave, saṁsāro."
    },
    {
      "id": "sn15.12:1.7",
      "pali": "Pubbā koṭi na paññāyati …pe…"
    },
    {
      "id": "sn15.12:1.8",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.12:1.9",
      "pali": "Dutiyaṁ."
    }
  ]
}
