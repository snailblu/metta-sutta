{
  "uid": "sn35.102",
  "title": "Dutiyanatumhākasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.102:1.1",
      "pali": "“Yaṁ, bhikkhave, na tumhākaṁ taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.2",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.102:1.3",
      "pali": "Kiñca, bhikkhave, na tumhākaṁ?"
    },
    {
      "id": "sn35.102:1.4",
      "pali": "Cakkhu, bhikkhave, na tumhākaṁ."
    },
    {
      "id": "sn35.102:1.5",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.6",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.102:1.7",
      "pali": "Rūpā na tumhākaṁ."
    },
    {
      "id": "sn35.102:1.8",
      "pali": "Te pajahatha."
    },
    {
      "id": "sn35.102:1.9",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.102:1.10",
      "pali": "Cakkhuviññāṇaṁ na tumhākaṁ."
    },
    {
      "id": "sn35.102:1.11",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.12",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.102:1.13",
      "pali": "Cakkhusamphasso na tumhākaṁ."
    },
    {
      "id": "sn35.102:1.14",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.15",
      "pali": "So vo pahīno hitāya sukhāya bhavissati …pe…"
    },
    {
      "id": "sn35.102:1.16",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi na tumhākaṁ."
    },
    {
      "id": "sn35.102:1.17",
      "pali": "Taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.18",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.102:1.19",
      "pali": "Yampi, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn35.102:1.20",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissatī”ti."
    },
    {
      "id": "sn35.102:1.21",
      "pali": "Navamaṁ."
    }
  ]
}
