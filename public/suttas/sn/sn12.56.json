{
  "uid": "sn12.56",
  "title": "Dutiyamahārukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.56:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.56:1.2",
      "pali": "“Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.56:1.3",
      "pali": "Tassa yāni ceva mūlāni adhogamāni, yāni ca tiriyaṅgamāni, sabbāni tāni uddhaṁ ojaṁ abhiharanti."
    },
    {
      "id": "sn12.56:1.4",
      "pali": "Evañhi so, bhikkhave, mahārukkho tadāhāro tadupādāno ciraṁ dīghamaddhānaṁ tiṭṭheyya."
    },
    {
      "id": "sn12.56:1.5",
      "pali": "Evameva kho, bhikkhave, upādāniyesu dhammesu assādānupassino viharato taṇhā pavaḍḍhati."
    },
    {
      "id": "sn12.56:1.6",
      "pali": "Taṇhāpaccayā upādānaṁ …pe…"
    },
    {
      "id": "sn12.56:1.7",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.56:2.1",
      "pali": "Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.56:2.2",
      "pali": "Atha puriso āgaccheyya kuddālapiṭakaṁ ādāya."
    },
    {
      "id": "sn12.56:2.3",
      "pali": "So taṁ rukkhaṁ mūle chindeyya, mūle chetvā palikhaṇeyya, palikhaṇitvā mūlāni uddhareyya …pe…"
    },
    {
      "id": "sn12.56:2.4",
      "pali": "nadiyā vā sīghasotāya pavāheyya."
    },
    {
      "id": "sn12.56:2.5",
      "pali": "Evañhi so, bhikkhave, mahārukkho ucchinnamūlo assa tālāvatthukato anabhāvaṅkato āyatiṁ anuppādadhammo."
    },
    {
      "id": "sn12.56:2.6",
      "pali": "Evameva kho, bhikkhave, upādāniyesu dhammesu ādīnavānupassino viharato taṇhā nirujjhati."
    },
    {
      "id": "sn12.56:2.7",
      "pali": "Taṇhānirodhā upādānanirodho …pe…"
    },
    {
      "id": "sn12.56:2.8",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.56:2.9",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
