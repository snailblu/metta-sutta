{
  "uid": "sn23.46",
  "title": "Nirodhadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.46:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.46:1.2",
      "pali": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ rādhaṁ bhagavā etadavoca:"
    },
    {
      "id": "sn23.46:1.3",
      "pali": "“yo kho, rādha, nirodhadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo."
    },
    {
      "id": "sn23.46:1.4",
      "pali": "Ko ca, rādha, nirodhadhammo?"
    },
    {
      "id": "sn23.46:1.5",
      "pali": "Rūpaṁ kho, rādha, nirodhadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo."
    },
    {
      "id": "sn23.46:1.6",
      "pali": "Vedanā …pe…"
    },
    {
      "id": "sn23.46:1.7",
      "pali": "saññā …pe…"
    },
    {
      "id": "sn23.46:1.8",
      "pali": "saṅkhārā …pe…"
    },
    {
      "id": "sn23.46:1.9",
      "pali": "viññāṇaṁ nirodhadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo."
    },
    {
      "id": "sn23.46:1.10",
      "pali": "Yo kho, rādha, nirodhadhammo; tatra te chando pahātabbo, rāgo pahātabbo, chandarāgo pahātabbo”ti."
    },
    {
      "id": "sn23.46:1.11",
      "pali": "Upanisinnavaggo catuttho."
    },
    {
      "id": "sn23.46:2.1",
      "pali": "Māro ca māradhammo ca,"
    },
    {
      "id": "sn23.46:2.2",
      "pali": "Aniccena apare duve;"
    },
    {
      "id": "sn23.46:2.3",
      "pali": "Dukkhena ca duve vuttā,"
    },
    {
      "id": "sn23.46:2.4",
      "pali": "Anattena tatheva ca;"
    },
    {
      "id": "sn23.46:2.5",
      "pali": "Khayavayasamudayaṁ,"
    },
    {
      "id": "sn23.46:2.6",
      "pali": "Nirodhadhammena dvādasāti."
    },
    {
      "id": "sn23.46:2.7",
      "pali": "Rādhasaṁyuttaṁ samattaṁ."
    }
  ]
}
