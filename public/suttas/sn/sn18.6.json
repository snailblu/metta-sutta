{
  "uid": "sn18.6",
  "title": "Saññāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.6:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.6:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.6:1.3",
      "pali": "rūpasaññā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.6:1.4",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.6:1.5",
      "pali": "“saddasaññā …pe…"
    },
    {
      "id": "sn18.6:1.6",
      "pali": "gandhasaññā …"
    },
    {
      "id": "sn18.6:1.7",
      "pali": "rasasaññā …"
    },
    {
      "id": "sn18.6:1.8",
      "pali": "phoṭṭhabbasaññā …"
    },
    {
      "id": "sn18.6:1.9",
      "pali": "dhammasaññā niccā vā aniccā vā”ti?"
    },
    {
      "id": "sn18.6:1.10",
      "pali": "“Aniccā, bhante” …"
    },
    {
      "id": "sn18.6:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako rūpasaññāyapi nibbindati …pe… saddasaññāyapi nibbindati … gandhasaññāyapi nibbindati … rasasaññāyapi nibbindati … phoṭṭhabbasaññāyapi nibbindati … dhammasaññāyapi nibbindati …pe…"
    },
    {
      "id": "sn18.6:1.12",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.6:1.13",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
