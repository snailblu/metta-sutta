{
  "uid": "sn8.5",
  "title": "Subhāsitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.5:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn8.5:1.2",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn8.5:1.3",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn8.5:1.4",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn8.5:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn8.5:2.1",
      "pali": "“Catūhi, bhikkhave, aṅgehi samannāgatā vācā subhāsitā hoti, no dubbhāsitā; anavajjā ca ananuvajjā ca viññūnaṁ."
    },
    {
      "id": "sn8.5:2.2",
      "pali": "Katamehi catūhi?"
    },
    {
      "id": "sn8.5:2.3",
      "pali": "Idha, bhikkhave, bhikkhu subhāsitaṁyeva bhāsati no dubbhāsitaṁ, dhammaṁyeva bhāsati no adhammaṁ, piyaṁyeva bhāsati no appiyaṁ, saccaṁyeva bhāsati no alikaṁ."
    },
    {
      "id": "sn8.5:2.4",
      "pali": "Imehi kho, bhikkhave, catūhi aṅgehi samannāgatā vācā subhāsitā hoti, no dubbhāsitā, anavajjā ca ananuvajjā ca viññūnan”ti."
    },
    {
      "id": "sn8.5:2.5",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn8.5:2.6",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn8.5:3.1",
      "pali": "“Subhāsitaṁ uttamamāhu santo,"
    },
    {
      "id": "sn8.5:3.2",
      "pali": "Dhammaṁ bhaṇe nādhammaṁ taṁ dutiyaṁ;"
    },
    {
      "id": "sn8.5:3.3",
      "pali": "Piyaṁ bhaṇe nāppiyaṁ taṁ tatiyaṁ,"
    },
    {
      "id": "sn8.5:3.4",
      "pali": "Saccaṁ bhaṇe nālikaṁ taṁ catutthan”ti."
    },
    {
      "id": "sn8.5:4.1",
      "pali": "Atha kho āyasmā vaṅgīso uṭṭhāyāsanā ekaṁsaṁ uttarāsaṅgaṁ karitvā yena bhagavā tenañjaliṁ paṇāmetvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn8.5:4.2",
      "pali": "“paṭibhāti maṁ, bhagavā, paṭibhāti maṁ, sugatā”ti."
    },
    {
      "id": "sn8.5:4.3",
      "pali": "“Paṭibhātu taṁ, vaṅgīsā”ti bhagavā avoca."
    },
    {
      "id": "sn8.5:4.4",
      "pali": "Atha kho āyasmā vaṅgīso bhagavantaṁ sammukhā sāruppāhi gāthāhi abhitthavi:"
    },
    {
      "id": "sn8.5:5.1",
      "pali": "“Tameva vācaṁ bhāseyya,"
    },
    {
      "id": "sn8.5:5.2",
      "pali": "yāyattānaṁ na tāpaye;"
    },
    {
      "id": "sn8.5:5.3",
      "pali": "Pare ca na vihiṁseyya,"
    },
    {
      "id": "sn8.5:5.4",
      "pali": "sā ve vācā subhāsitā."
    },
    {
      "id": "sn8.5:6.1",
      "pali": "Piyavācaṁva bhāseyya,"
    },
    {
      "id": "sn8.5:6.2",
      "pali": "yā vācā paṭinanditā;"
    },
    {
      "id": "sn8.5:6.3",
      "pali": "Yaṁ anādāya pāpāni,"
    },
    {
      "id": "sn8.5:6.4",
      "pali": "paresaṁ bhāsate piyaṁ."
    },
    {
      "id": "sn8.5:7.1",
      "pali": "Saccaṁ ve amatā vācā,"
    },
    {
      "id": "sn8.5:7.2",
      "pali": "esa dhammo sanantano;"
    },
    {
      "id": "sn8.5:7.3",
      "pali": "Sacce atthe ca dhamme ca,"
    },
    {
      "id": "sn8.5:7.4",
      "pali": "āhu santo patiṭṭhitā."
    },
    {
      "id": "sn8.5:8.1",
      "pali": "Yaṁ buddho bhāsate vācaṁ,"
    },
    {
      "id": "sn8.5:8.2",
      "pali": "khemaṁ nibbānapattiyā;"
    },
    {
      "id": "sn8.5:8.3",
      "pali": "Dukkhassantakiriyāya,"
    },
    {
      "id": "sn8.5:8.4",
      "pali": "sā ve vācānamuttamā”ti."
    }
  ]
}
