{
  "uid": "sn24.70",
  "title": "Adukkhamasukhīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.70:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.70:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.70:1.3",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.70:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…."
    },
    {
      "id": "sn24.70:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.70:2.2",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.70:2.3",
      "pali": "“Vedanāya sati …pe…"
    },
    {
      "id": "sn24.70:2.4",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.70:2.5",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.70:2.6",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.70:2.7",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’ti."
    },
    {
      "id": "sn24.70:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn24.70:3.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.70:3.3",
      "pali": "“Aniccaṁ, bhante” …pe… vipariṇāmadhammaṁ,"
    },
    {
      "id": "sn24.70:3.4",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.70:3.5",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.70:3.6",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.70:3.7",
      "pali": "“Iti kho, bhikkhave, yadaniccaṁ taṁ dukkhaṁ."
    },
    {
      "id": "sn24.70:3.8",
      "pali": "Tasmiṁ sati, tadupādāya evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.70:3.9",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.70:3.10",
      "pali": "“Vedanā …pe…"
    },
    {
      "id": "sn24.70:3.11",
      "pali": "saññā …"
    },
    {
      "id": "sn24.70:3.12",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.70:3.13",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.70:3.14",
      "pali": "“Aniccaṁ, bhante” …pe… vipariṇāmadhammaṁ,"
    },
    {
      "id": "sn24.70:3.15",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.70:3.16",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.70:3.17",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.70:3.18",
      "pali": "“Iti kho, bhikkhave, yadaniccaṁ taṁ dukkhaṁ."
    },
    {
      "id": "sn24.70:3.19",
      "pali": "Tasmiṁ sati, tadupādāya evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.70:3.20",
      "pali": "‘adukkhamasukhī attā hoti arogo paraṁ maraṇā’”ti."
    },
    {
      "id": "sn24.70:3.21",
      "pali": "Chabbīsatimaṁ."
    },
    {
      "id": "sn24.70:3.22",
      "pali": "Tatiyapeyyālo."
    }
  ]
}
