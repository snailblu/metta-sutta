{
  "uid": "sn1.80",
  "title": "Pajjotasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.80:1.1",
      "pali": "“Kiṁsu lokasmi pajjoto,"
    },
    {
      "id": "sn1.80:1.2",
      "pali": "kiṁsu lokasmi jāgaro;"
    },
    {
      "id": "sn1.80:1.3",
      "pali": "Kiṁsu kamme sajīvānaṁ,"
    },
    {
      "id": "sn1.80:1.4",
      "pali": "kimassa iriyāpatho."
    },
    {
      "id": "sn1.80:2.1",
      "pali": "Kiṁsu alasaṁ analasañca,"
    },
    {
      "id": "sn1.80:2.2",
      "pali": "Mātā puttaṁva posati;"
    },
    {
      "id": "sn1.80:2.3",
      "pali": "Kiṁ bhūtā upajīvanti,"
    },
    {
      "id": "sn1.80:2.4",
      "pali": "Ye pāṇā pathavissitā”ti."
    },
    {
      "id": "sn1.80:3.1",
      "pali": "“Paññā lokasmi pajjoto,"
    },
    {
      "id": "sn1.80:3.2",
      "pali": "sati lokasmi jāgaro;"
    },
    {
      "id": "sn1.80:3.3",
      "pali": "Gāvo kamme sajīvānaṁ,"
    },
    {
      "id": "sn1.80:3.4",
      "pali": "sītassa iriyāpatho."
    },
    {
      "id": "sn1.80:4.1",
      "pali": "Vuṭṭhi alasaṁ analasañca,"
    },
    {
      "id": "sn1.80:4.2",
      "pali": "Mātā puttaṁva posati;"
    },
    {
      "id": "sn1.80:4.3",
      "pali": "Vuṭṭhiṁ bhūtā upajīvanti,"
    },
    {
      "id": "sn1.80:4.4",
      "pali": "Ye pāṇā pathavissitā”ti."
    }
  ]
}
