{
  "uid": "sn24.14",
  "title": "Aññaṁjīvaṁaññaṁsarīraṁsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.14:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.14:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.14:1.3",
      "pali": "‘aññaṁ jīvaṁ aññaṁ sarīran’”ti?"
    },
    {
      "id": "sn24.14:1.4",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.14:1.5",
      "pali": "niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.14:1.6",
      "pali": "Cuddasamaṁ."
    }
  ]
}
