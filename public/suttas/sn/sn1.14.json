{
  "uid": "sn1.14",
  "title": "Khattiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.14:1.1",
      "pali": "“Khattiyo dvipadaṁ seṭṭho,"
    },
    {
      "id": "sn1.14:1.2",
      "pali": "balībaddo catuppadaṁ;"
    },
    {
      "id": "sn1.14:1.3",
      "pali": "Komārī seṭṭhā bhariyānaṁ,"
    },
    {
      "id": "sn1.14:1.4",
      "pali": "yo ca puttāna pubbajo”ti."
    },
    {
      "id": "sn1.14:2.1",
      "pali": "“Sambuddho dvipadaṁ seṭṭho,"
    },
    {
      "id": "sn1.14:2.2",
      "pali": "ājānīyo catuppadaṁ;"
    },
    {
      "id": "sn1.14:2.3",
      "pali": "Sussūsā seṭṭhā bhariyānaṁ,"
    },
    {
      "id": "sn1.14:2.4",
      "pali": "yo ca puttānamassavo”ti."
    }
  ]
}
