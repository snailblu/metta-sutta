{
  "uid": "sn46.22",
  "title": "Bojjhaṅgadesanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.22:1.1",
      "pali": "“Satta vo, bhikkhave, bojjhaṅge desessāmi;"
    },
    {
      "id": "sn46.22:1.2",
      "pali": "taṁ suṇātha."
    },
    {
      "id": "sn46.22:1.3",
      "pali": "Katame ca, bhikkhave, satta bojjhaṅgā?"
    },
    {
      "id": "sn46.22:1.4",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.22:1.5",
      "pali": "ime kho, bhikkhave, satta bojjhaṅgā”ti."
    },
    {
      "id": "sn46.22:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
