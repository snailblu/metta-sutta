{
  "uid": "sn45.21",
  "title": "Micchattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.21:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.21:1.2",
      "pali": "“Micchattañca vo, bhikkhave, desessāmi, sammattañca."
    },
    {
      "id": "sn45.21:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.21:1.4",
      "pali": "Katamañca, bhikkhave, micchattaṁ?"
    },
    {
      "id": "sn45.21:1.5",
      "pali": "Seyyathidaṁ—micchādiṭṭhi …pe… micchāsamādhi."
    },
    {
      "id": "sn45.21:1.6",
      "pali": "Idaṁ vuccati, bhikkhave, micchattaṁ."
    },
    {
      "id": "sn45.21:1.7",
      "pali": "Katamañca, bhikkhave, sammattaṁ?"
    },
    {
      "id": "sn45.21:1.8",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn45.21:1.9",
      "pali": "Idaṁ vuccati, bhikkhave, sammattan”ti."
    },
    {
      "id": "sn45.21:1.10",
      "pali": "Paṭhamaṁ."
    }
  ]
}
