{
  "uid": "sn35.207-209",
  "title": "Ajjhattātītādiyaṁdukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.207-209:1.1",
      "pali": "“Cakkhu, bhikkhave, dukkhaṁ atītaṁ anāgataṁ paccuppannaṁ."
    },
    {
      "id": "sn35.207-209:1.2",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.207-209:1.3",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ …pe…"
    },
    {
      "id": "sn35.207-209:1.4",
      "pali": "jivhā dukkhā …pe…"
    },
    {
      "id": "sn35.207-209:1.5",
      "pali": "mano dukkho atīto anāgato paccuppanno."
    },
    {
      "id": "sn35.207-209:1.6",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.207-209:1.7",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.207-209:1.8",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.207-209:1.9",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
