{
  "uid": "sn34.53-54",
  "title": "sn34.53-54",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.53:1.1",
      "pali": "Sāvatthinidānaṁ …"
    },
    {
      "id": "sn34.53:1.2",
      "pali": "“samādhismiṁ sakkaccakārī hoti, na samādhismiṁ sātaccakārī …"
    },
    {
      "id": "sn34.53:1.3",
      "pali": "samādhismiṁ sātaccakārī hoti, na samādhismiṁ sakkaccakārī …"
    },
    {
      "id": "sn34.53:1.4",
      "pali": "neva samādhismiṁ sakkaccakārī hoti, na ca samādhismiṁ sātaccakārī …"
    },
    {
      "id": "sn34.53:1.5",
      "pali": "samādhismiṁ sakkaccakārī ca hoti, samādhismiṁ sātaccakārī ca."
    },
    {
      "id": "sn34.53:1.6",
      "pali": "Tatra, bhikkhave, yvāyaṁ …pe…"
    },
    {
      "id": "sn34.53:1.7",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.53:1.8",
      "pali": "Tepaññāsamaṁ."
    },
    {
      "id": "sn34.54:1.1",
      "pali": "“Samādhismiṁ sakkaccakārī hoti, na samādhismiṁ sappāyakārī …pe…."
    },
    {
      "id": "sn34.54:1.2",
      "pali": "Catupaññāsamaṁ."
    }
  ]
}
