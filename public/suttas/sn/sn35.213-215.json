{
  "uid": "sn35.213-215",
  "title": "Bāhirātītādiyadaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.213-215:1.1",
      "pali": "“Rūpā, bhikkhave, aniccā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.213-215:1.2",
      "pali": "Yadaniccaṁ, taṁ dukkhaṁ."
    },
    {
      "id": "sn35.213-215:1.3",
      "pali": "Yaṁ dukkhaṁ, tadanattā."
    },
    {
      "id": "sn35.213-215:1.4",
      "pali": "Yadanattā, taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.213-215:1.5",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.213-215:1.6",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.213-215:1.7",
      "pali": "rasā …"
    },
    {
      "id": "sn35.213-215:1.8",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.213-215:1.9",
      "pali": "dhammā aniccā atītā anāgatā paccuppannā."
    },
    {
      "id": "sn35.213-215:1.10",
      "pali": "Yadaniccaṁ taṁ dukkhaṁ."
    },
    {
      "id": "sn35.213-215:1.11",
      "pali": "Yaṁ dukkhaṁ tadanattā."
    },
    {
      "id": "sn35.213-215:1.12",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.213-215:1.13",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.213-215:1.14",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
