{
  "uid": "sn5.8",
  "title": "Sīsupacālāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn5.8:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn5.8:1.2",
      "pali": "Atha kho sīsupacālā bhikkhunī pubbaṇhasamayaṁ nivāsetvā …pe…"
    },
    {
      "id": "sn5.8:1.3",
      "pali": "aññatarasmiṁ rukkhamūle divāvihāraṁ nisīdi."
    },
    {
      "id": "sn5.8:1.4",
      "pali": "Atha kho māro pāpimā yena sīsupacālā bhikkhunī tenupasaṅkami; upasaṅkamitvā sīsupacālaṁ bhikkhuniṁ etadavoca:"
    },
    {
      "id": "sn5.8:1.5",
      "pali": "“kassa nu tvaṁ, bhikkhuni, pāsaṇḍaṁ rocesī”ti?"
    },
    {
      "id": "sn5.8:1.6",
      "pali": "“Na khvāhaṁ, āvuso, kassaci pāsaṇḍaṁ rocemī”ti."
    },
    {
      "id": "sn5.8:2.1",
      "pali": "“Kaṁ nu uddissa muṇḍāsi,"
    },
    {
      "id": "sn5.8:2.2",
      "pali": "Samaṇī viya dissasi;"
    },
    {
      "id": "sn5.8:2.3",
      "pali": "Na ca rocesi pāsaṇḍaṁ,"
    },
    {
      "id": "sn5.8:2.4",
      "pali": "Kimiva carasi momūhā”ti."
    },
    {
      "id": "sn5.8:3.1",
      "pali": "“Ito bahiddhā pāsaṇḍā,"
    },
    {
      "id": "sn5.8:3.2",
      "pali": "diṭṭhīsu pasīdanti te;"
    },
    {
      "id": "sn5.8:3.3",
      "pali": "Na tesaṁ dhammaṁ rocemi,"
    },
    {
      "id": "sn5.8:3.4",
      "pali": "te dhammassa akovidā."
    },
    {
      "id": "sn5.8:4.1",
      "pali": "Atthi sakyakule jāto,"
    },
    {
      "id": "sn5.8:4.2",
      "pali": "buddho appaṭipuggalo;"
    },
    {
      "id": "sn5.8:4.3",
      "pali": "Sabbābhibhū māranudo,"
    },
    {
      "id": "sn5.8:4.4",
      "pali": "sabbatthamaparājito."
    },
    {
      "id": "sn5.8:5.1",
      "pali": "Sabbattha mutto asito,"
    },
    {
      "id": "sn5.8:5.2",
      "pali": "sabbaṁ passati cakkhumā;"
    },
    {
      "id": "sn5.8:5.3",
      "pali": "Sabbakammakkhayaṁ patto,"
    },
    {
      "id": "sn5.8:5.4",
      "pali": "vimutto upadhisaṅkhaye;"
    },
    {
      "id": "sn5.8:5.5",
      "pali": "So mayhaṁ bhagavā satthā,"
    },
    {
      "id": "sn5.8:5.6",
      "pali": "tassa rocemi sāsanan”ti."
    },
    {
      "id": "sn5.8:6.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ sīsupacālā bhikkhunī”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
