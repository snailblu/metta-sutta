{
  "uid": "sn29.21-50",
  "title": "Jalābujādidānūpakārasuttattiṁsaka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn29.21-50:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn29.21-50:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn29.21-50:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā jalābujānaṁ nāgānaṁ …pe…"
    },
    {
      "id": "sn29.21-50:1.4",
      "pali": "saṁsedajānaṁ nāgānaṁ …pe…"
    },
    {
      "id": "sn29.21-50:1.5",
      "pali": "opapātikānaṁ nāgānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn29.21-50:2.1",
      "pali": "“Idha, bhikkhu, ekacco kāyena dvayakārī hoti, vācāya dvayakārī, manasā dvayakārī."
    },
    {
      "id": "sn29.21-50:2.2",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn29.21-50:2.3",
      "pali": "‘opapātikā nāgā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn29.21-50:2.4",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn29.21-50:2.5",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā opapātikānaṁ nāgānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn29.21-50:2.6",
      "pali": "So annaṁ deti …pe…"
    },
    {
      "id": "sn29.21-50:2.7",
      "pali": "pānaṁ deti …pe…"
    },
    {
      "id": "sn29.21-50:2.8",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn29.21-50:2.9",
      "pali": "So kāyassa bhedā paraṁ maraṇā opapātikānaṁ nāgānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn29.21-50:2.10",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā opapātikānaṁ nāgānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn29.21-50:3.1",
      "pali": "(Iminā peyyālena dasa dasa suttantā kātabbā."
    },
    {
      "id": "sn29.21-50:3.2",
      "pali": "Evaṁ catūsu yonīsu cattālīsaṁ veyyākaraṇā honti."
    },
    {
      "id": "sn29.21-50:3.3",
      "pali": "Purimehi pana dasahi suttantehi saha honti paṇṇāsasuttantāti.)"
    },
    {
      "id": "sn29.21-50:3.4",
      "pali": "Nāgavaggo paṭhamo."
    },
    {
      "id": "sn29.21-50:4.1",
      "pali": "Suddhikaṁ paṇītataraṁ,"
    },
    {
      "id": "sn29.21-50:4.2",
      "pali": "caturo ca uposathā;"
    },
    {
      "id": "sn29.21-50:4.3",
      "pali": "Tassa sutaṁ caturo ca,"
    },
    {
      "id": "sn29.21-50:4.4",
      "pali": "dānūpakārā ca tālīsaṁ;"
    },
    {
      "id": "sn29.21-50:4.5",
      "pali": "Paṇṇāsa piṇḍato suttā,"
    },
    {
      "id": "sn29.21-50:4.6",
      "pali": "nāgamhi suppakāsitāti."
    },
    {
      "id": "sn29.21-50:4.7",
      "pali": "Nāgasaṁyuttaṁ samattaṁ."
    }
  ]
}
