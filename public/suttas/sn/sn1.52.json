{
  "uid": "sn1.52",
  "title": "Ajarasāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.52:1.1",
      "pali": "“Kiṁsu ajarasā sādhu,"
    },
    {
      "id": "sn1.52:1.2",
      "pali": "kiṁsu sādhu adhiṭṭhitaṁ;"
    },
    {
      "id": "sn1.52:1.3",
      "pali": "Kiṁsu narānaṁ ratanaṁ,"
    },
    {
      "id": "sn1.52:1.4",
      "pali": "kiṁsu corehyahāriyan”ti."
    },
    {
      "id": "sn1.52:2.1",
      "pali": "“Sīlaṁ ajarasā sādhu,"
    },
    {
      "id": "sn1.52:2.2",
      "pali": "saddhā sādhu adhiṭṭhitā;"
    },
    {
      "id": "sn1.52:2.3",
      "pali": "Paññā narānaṁ ratanaṁ,"
    },
    {
      "id": "sn1.52:2.4",
      "pali": "puññaṁ corehyahāriyan”ti."
    }
  ]
}
