{
  "uid": "sn48.105-114",
  "title": "Esanāvagga",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.105-114:1.1",
      "pali": "(Esanāvaggo vitthāretabbo.)"
    },
    {
      "id": "sn48.105-114:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn48.105-114:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn48.105-114:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn48.105-114:2.4",
      "pali": "Vedanā taṇhā tasinā cāti."
    }
  ]
}
