{
  "uid": "sn9.12",
  "title": "Majjhanhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.12:1.1",
      "pali": "Ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.12:1.2",
      "pali": "Atha kho tasmiṁ vanasaṇḍe adhivatthā devatā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā tassa bhikkhuno santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn9.12:2.1",
      "pali": "“Ṭhite majjhanhike kāle,"
    },
    {
      "id": "sn9.12:2.2",
      "pali": "sannisīvesu pakkhisu;"
    },
    {
      "id": "sn9.12:2.3",
      "pali": "Saṇateva brahāraññaṁ,"
    },
    {
      "id": "sn9.12:2.4",
      "pali": "taṁ bhayaṁ paṭibhāti maṁ."
    },
    {
      "id": "sn9.12:3.1",
      "pali": "Ṭhite majjhanhike kāle,"
    },
    {
      "id": "sn9.12:3.2",
      "pali": "sannisīvesu pakkhisu;"
    },
    {
      "id": "sn9.12:3.3",
      "pali": "Saṇateva brahāraññaṁ,"
    },
    {
      "id": "sn9.12:3.4",
      "pali": "sā rati paṭibhāti man”ti."
    }
  ]
}
