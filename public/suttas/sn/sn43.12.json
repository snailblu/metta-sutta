{
  "uid": "sn43.12",
  "title": "Asaṅkhatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.12:1.1",
      "pali": "“Asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.12:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.12:1.3",
      "pali": "Katamañca, bhikkhave, asaṅkhataṁ?"
    },
    {
      "id": "sn43.12:1.4",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn43.12:1.5",
      "pali": "idaṁ vuccati, bhikkhave, asaṅkhataṁ."
    },
    {
      "id": "sn43.12:1.6",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:1.7",
      "pali": "Samatho."
    },
    {
      "id": "sn43.12:1.8",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.12:1.9",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā asaṅkhataṁ, desito asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.12:1.10",
      "pali": "Yaṁ, bhikkhave, satthārā karaṇīyaṁ sāvakānaṁ hitesinā anukampakena anukampaṁ upādāya, kataṁ vo taṁ mayā."
    },
    {
      "id": "sn43.12:1.11",
      "pali": "Etāni, bhikkhave, rukkhamūlāni, etāni suññāgārāni. Jhāyatha, bhikkhave, mā pamādattha; mā pacchā vippaṭisārino ahuvattha. Ayaṁ vo amhākaṁ anusāsanīti."
    },
    {
      "id": "sn43.12:2.1",
      "pali": "Asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.12:2.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.12:2.3",
      "pali": "Katamañca, bhikkhave, asaṅkhataṁ?"
    },
    {
      "id": "sn43.12:2.4",
      "pali": "Yo, bhikkhave, rāgakkhayo dosakkhayo mohakkhayo—"
    },
    {
      "id": "sn43.12:2.5",
      "pali": "idaṁ vuccati, bhikkhave, asaṅkhataṁ."
    },
    {
      "id": "sn43.12:2.6",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:2.7",
      "pali": "Vipassanā."
    },
    {
      "id": "sn43.12:2.8",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.12:2.9",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā asaṅkhataṁ …pe…"
    },
    {
      "id": "sn43.12:2.10",
      "pali": "ayaṁ vo amhākaṁ anusāsanīti."
    },
    {
      "id": "sn43.12:3.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:3.2",
      "pali": "Savitakko savicāro samādhi."
    },
    {
      "id": "sn43.12:3.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:3.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:3.5",
      "pali": "Avitakko vicāramatto samādhi."
    },
    {
      "id": "sn43.12:3.6",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:3.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:3.8",
      "pali": "Avitakko avicāro samādhi. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:4.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:4.2",
      "pali": "Suññato samādhi."
    },
    {
      "id": "sn43.12:4.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:4.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:4.5",
      "pali": "Animitto samādhi."
    },
    {
      "id": "sn43.12:4.6",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:4.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:4.8",
      "pali": "Appaṇihito samādhi. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:5.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:5.2",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn43.12:5.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:5.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:5.5",
      "pali": "Idha, bhikkhave, bhikkhu vedanāsu vedanānupassī viharati …pe…"
    },
    {
      "id": "sn43.12:5.6",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:5.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:5.8",
      "pali": "Idha, bhikkhave, bhikkhu citte cittānupassī viharati …pe…"
    },
    {
      "id": "sn43.12:5.9",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:5.10",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:5.11",
      "pali": "Idha, bhikkhave, bhikkhu dhammesu dhammānupassī viharati …pe… ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:6.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:6.2",
      "pali": "Idha, bhikkhave, bhikkhu anuppannānaṁ pāpakānaṁ akusalānaṁ dhammānaṁ anuppādāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "sn43.12:6.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:6.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:6.5",
      "pali": "Idha, bhikkhave, bhikkhu uppannānaṁ pāpakānaṁ akusalānaṁ dhammānaṁ pahānāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "sn43.12:6.6",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:6.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:6.8",
      "pali": "Idha, bhikkhave, bhikkhu anuppannānaṁ kusalānaṁ dhammānaṁ uppādāya chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati."
    },
    {
      "id": "sn43.12:6.9",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:6.10",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:6.11",
      "pali": "Idha, bhikkhave, bhikkhu uppannānaṁ kusalānaṁ dhammānaṁ ṭhitiyā asammosāya bhiyyobhāvāya vepullāya bhāvanāya pāripūriyā chandaṁ janeti vāyamati vīriyaṁ ārabhati cittaṁ paggaṇhāti padahati. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:7.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:7.2",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn43.12:7.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:7.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:7.5",
      "pali": "Idha, bhikkhave, bhikkhu vīriyasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn43.12:7.6",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:7.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:7.8",
      "pali": "Idha, bhikkhave, bhikkhu cittasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti."
    },
    {
      "id": "sn43.12:7.9",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:7.10",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:7.11",
      "pali": "Idha, bhikkhave, bhikkhu vīmaṁsasamādhipadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:8.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:8.2",
      "pali": "Idha, bhikkhave, bhikkhu saddhindriyaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn43.12:8.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:8.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:8.5",
      "pali": "Idha, bhikkhave, bhikkhu vīriyindriyaṁ bhāveti vivekanissitaṁ …pe…"
    },
    {
      "id": "sn43.12:8.6",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:8.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:8.8",
      "pali": "Idha, bhikkhave, bhikkhu satindriyaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:8.9",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:8.10",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:8.11",
      "pali": "Idha, bhikkhave, bhikkhu samādhindriyaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:8.12",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:8.13",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:8.14",
      "pali": "Idha, bhikkhave, bhikkhu paññindriyaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:9.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:9.2",
      "pali": "Idha, bhikkhave, bhikkhu saddhābalaṁ bhāveti vivekanissitaṁ …pe…"
    },
    {
      "id": "sn43.12:9.3",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:9.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:9.5",
      "pali": "Idha, bhikkhave, bhikkhu vīriyabalaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:9.6",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:9.7",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:9.8",
      "pali": "Idha, bhikkhave, bhikkhu satibalaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:9.9",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:9.10",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:9.11",
      "pali": "Idha, bhikkhave, bhikkhu samādhibalaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:9.12",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:9.13",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:9.14",
      "pali": "Idha, bhikkhave, bhikkhu paññābalaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:10.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:10.2",
      "pali": "Idha, bhikkhave, bhikkhu satisambojjhaṅgaṁ bhāveti vivekanissitaṁ …pe…"
    },
    {
      "id": "sn43.12:10.3",
      "pali": "ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:10.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:10.5",
      "pali": "Idha, bhikkhave, bhikkhu dhammavicayasambojjhaṅgaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:10.6",
      "pali": "vīriyasambojjhaṅgaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:10.7",
      "pali": "pītisambojjhaṅgaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:10.8",
      "pali": "passaddhisambojjhaṅgaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:10.9",
      "pali": "samādhisambojjhaṅgaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:10.10",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.12:11.1",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:11.2",
      "pali": "Idha, bhikkhave, bhikkhu sammādiṭṭhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn43.12:11.3",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…"
    },
    {
      "id": "sn43.12:11.4",
      "pali": "katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:11.5",
      "pali": "Idha, bhikkhave, bhikkhu sammāsaṅkappaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.6",
      "pali": "sammāvācaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.7",
      "pali": "sammākammantaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.8",
      "pali": "sammāājīvaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.9",
      "pali": "sammāvāyāmaṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.10",
      "pali": "sammāsatiṁ bhāveti …pe…"
    },
    {
      "id": "sn43.12:11.11",
      "pali": "asaṅkhatañca vo, bhikkhave, desessāmi asaṅkhatagāmiñca maggaṁ."
    },
    {
      "id": "sn43.12:11.12",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn43.12:11.13",
      "pali": "Katamañca, bhikkhave, asaṅkhataṁ …pe…?"
    },
    {
      "id": "sn43.12:11.14",
      "pali": "Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.12:11.15",
      "pali": "Idha, bhikkhave, bhikkhu sammāsamādhiṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ."
    },
    {
      "id": "sn43.12:11.16",
      "pali": "Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.12:11.17",
      "pali": "Iti kho, bhikkhave, desitaṁ vo mayā asaṅkhataṁ, desito asaṅkhatagāmimaggo."
    },
    {
      "id": "sn43.12:11.18",
      "pali": "Yaṁ, bhikkhave, satthārā karaṇīyaṁ sāvakānaṁ hitesinā anukampakena anukampaṁ upādāya, kataṁ vo taṁ mayā."
    },
    {
      "id": "sn43.12:11.19",
      "pali": "Etāni, bhikkhave, rukkhamūlāni, etāni suññāgārāni. Jhāyatha, bhikkhave, mā pamādattha; mā pacchā vippaṭisārino ahuvattha. Ayaṁ vo amhākaṁ anusāsanī”ti."
    },
    {
      "id": "sn43.12:11.20",
      "pali": "Paṭhamaṁ."
    }
  ]
}
