{
  "uid": "sn1.65",
  "title": "Bandhanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.65:1.1",
      "pali": "“Kiṁsu sambandhano loko,"
    },
    {
      "id": "sn1.65:1.2",
      "pali": "kiṁsu tassa vicāraṇaṁ;"
    },
    {
      "id": "sn1.65:1.3",
      "pali": "Kissassu vippahānena,"
    },
    {
      "id": "sn1.65:1.4",
      "pali": "sabbaṁ chindati bandhanan”ti."
    },
    {
      "id": "sn1.65:2.1",
      "pali": "“Nandīsambandhano loko,"
    },
    {
      "id": "sn1.65:2.2",
      "pali": "vitakkassa vicāraṇaṁ;"
    },
    {
      "id": "sn1.65:2.3",
      "pali": "Taṇhāya vippahānena,"
    },
    {
      "id": "sn1.65:2.4",
      "pali": "sabbaṁ chindati bandhanan”ti."
    }
  ]
}
