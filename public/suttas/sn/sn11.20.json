{
  "uid": "sn11.20",
  "title": "Saṅghavandanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.20:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.20:1.2",
      "pali": "Tatra kho …pe… etadavoca:"
    },
    {
      "id": "sn11.20:1.3",
      "pali": "“bhūtapubbaṁ, bhikkhave, sakko devānamindo mātaliṁ saṅgāhakaṁ āmantesi:"
    },
    {
      "id": "sn11.20:1.4",
      "pali": "‘yojehi, samma mātali, sahassayuttaṁ ājaññarathaṁ, uyyānabhūmiṁ gacchāma subhūmiṁ dassanāyā’ti."
    },
    {
      "id": "sn11.20:1.5",
      "pali": "‘Evaṁ, bhaddantavā’ti kho, bhikkhave, mātali saṅgāhako sakkassa devānamindassa paṭissutvā, sahassayuttaṁ ājaññarathaṁ yojetvā sakkassa devānamindassa paṭivedesi:"
    },
    {
      "id": "sn11.20:1.6",
      "pali": "‘yutto kho te, mārisa, sahassayutto ājaññaratho,"
    },
    {
      "id": "sn11.20:1.7",
      "pali": "yassadāni kālaṁ maññasī’ti."
    },
    {
      "id": "sn11.20:1.8",
      "pali": "Atha kho, bhikkhave, sakko devānamindo vejayantapāsādā orohanto añjaliṁ katvā sudaṁ bhikkhusaṅghaṁ namassati."
    },
    {
      "id": "sn11.20:1.9",
      "pali": "Atha kho, bhikkhave, mātali saṅgāhako sakkaṁ devānamindaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.20:2.1",
      "pali": "‘Tañhi ete namasseyyuṁ,"
    },
    {
      "id": "sn11.20:2.2",
      "pali": "pūtidehasayā narā;"
    },
    {
      "id": "sn11.20:2.3",
      "pali": "Nimuggā kuṇapamhete,"
    },
    {
      "id": "sn11.20:2.4",
      "pali": "khuppipāsasamappitā."
    },
    {
      "id": "sn11.20:3.1",
      "pali": "Kiṁ nu tesaṁ pihayasi,"
    },
    {
      "id": "sn11.20:3.2",
      "pali": "anāgārāna vāsava;"
    },
    {
      "id": "sn11.20:3.3",
      "pali": "Ācāraṁ isinaṁ brūhi,"
    },
    {
      "id": "sn11.20:3.4",
      "pali": "taṁ suṇoma vaco tavā’ti."
    },
    {
      "id": "sn11.20:4.1",
      "pali": "‘Etaṁ tesaṁ pihayāmi,"
    },
    {
      "id": "sn11.20:4.2",
      "pali": "anāgārāna mātali;"
    },
    {
      "id": "sn11.20:4.3",
      "pali": "Yamhā gāmā pakkamanti,"
    },
    {
      "id": "sn11.20:4.4",
      "pali": "anapekkhā vajanti te."
    },
    {
      "id": "sn11.20:5.1",
      "pali": "Na tesaṁ koṭṭhe openti,"
    },
    {
      "id": "sn11.20:5.2",
      "pali": "na kumbhi na kaḷopiyaṁ;"
    },
    {
      "id": "sn11.20:5.3",
      "pali": "Paraniṭṭhitamesānā,"
    },
    {
      "id": "sn11.20:5.4",
      "pali": "tena yāpenti subbatā."
    },
    {
      "id": "sn11.20:6.1",
      "pali": "Sumantamantino dhīrā,"
    },
    {
      "id": "sn11.20:6.2",
      "pali": "tuṇhībhūtā samañcarā;"
    },
    {
      "id": "sn11.20:6.3",
      "pali": "Devā viruddhā asurehi,"
    },
    {
      "id": "sn11.20:6.4",
      "pali": "puthu maccā ca mātali."
    },
    {
      "id": "sn11.20:7.1",
      "pali": "Aviruddhā viruddhesu,"
    },
    {
      "id": "sn11.20:7.2",
      "pali": "attadaṇḍesu nibbutā;"
    },
    {
      "id": "sn11.20:7.3",
      "pali": "Sādānesu anādānā,"
    },
    {
      "id": "sn11.20:7.4",
      "pali": "te namassāmi mātalī’ti."
    },
    {
      "id": "sn11.20:8.1",
      "pali": "‘Seṭṭhā hi kira lokasmiṁ,"
    },
    {
      "id": "sn11.20:8.2",
      "pali": "ye tvaṁ sakka namassasi;"
    },
    {
      "id": "sn11.20:8.3",
      "pali": "Ahampi te namassāmi,"
    },
    {
      "id": "sn11.20:8.4",
      "pali": "ye namassasi vāsavā’”ti."
    },
    {
      "id": "sn11.20:9.1",
      "pali": "Idaṁ vatvāna maghavā,"
    },
    {
      "id": "sn11.20:9.2",
      "pali": "devarājā sujampati;"
    },
    {
      "id": "sn11.20:9.3",
      "pali": "Bhikkhusaṅghaṁ namassitvā,"
    },
    {
      "id": "sn11.20:9.4",
      "pali": "pamukho rathamāruhīti."
    },
    {
      "id": "sn11.20:9.5",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn11.20:10.1",
      "pali": "Devā pana tayo vuttā,"
    },
    {
      "id": "sn11.20:10.2",
      "pali": "daliddañca rāmaṇeyyakaṁ;"
    },
    {
      "id": "sn11.20:10.3",
      "pali": "Yajamānañca vandanā,"
    },
    {
      "id": "sn11.20:10.4",
      "pali": "tayo sakkanamassanāti."
    }
  ]
}
