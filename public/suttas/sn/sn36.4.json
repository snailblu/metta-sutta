{
  "uid": "sn36.4",
  "title": "Pātālasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.4:1.1",
      "pali": "“Assutavā, bhikkhave, puthujjano yaṁ vācaṁ bhāsati:"
    },
    {
      "id": "sn36.4:1.2",
      "pali": "‘atthi mahāsamudde pātālo’ti."
    },
    {
      "id": "sn36.4:1.3",
      "pali": "Taṁ kho panetaṁ, bhikkhave, assutavā puthujjano asantaṁ avijjamānaṁ evaṁ vācaṁ bhāsati:"
    },
    {
      "id": "sn36.4:1.4",
      "pali": "‘atthi mahāsamudde pātālo’ti."
    },
    {
      "id": "sn36.4:1.5",
      "pali": "Sārīrikānaṁ kho etaṁ, bhikkhave, dukkhānaṁ vedanānaṁ adhivacanaṁ yadidaṁ ‘pātālo’ti."
    },
    {
      "id": "sn36.4:1.6",
      "pali": "Assutavā, bhikkhave, puthujjano sārīrikāya dukkhāya vedanāya phuṭṭho samāno socati kilamati paridevati urattāḷiṁ kandati sammohaṁ āpajjati."
    },
    {
      "id": "sn36.4:1.7",
      "pali": "Ayaṁ vuccati, bhikkhave, ‘assutavā puthujjano pātāle na paccuṭṭhāsi, gādhañca nājjhagā’."
    },
    {
      "id": "sn36.4:1.8",
      "pali": "Sutavā ca kho, bhikkhave, ariyasāvako sārīrikāya dukkhāya vedanāya phuṭṭho samāno neva socati, na kilamati, na paridevati, na urattāḷiṁ kandati, na sammohaṁ āpajjati."
    },
    {
      "id": "sn36.4:1.9",
      "pali": "Ayaṁ vuccati, bhikkhave, ‘sutavā ariyasāvako pātāle paccuṭṭhāsi, gādhañca ajjhagā’ti."
    },
    {
      "id": "sn36.4:2.1",
      "pali": "Yo etā nādhivāseti,"
    },
    {
      "id": "sn36.4:2.2",
      "pali": "uppannā vedanā dukhā;"
    },
    {
      "id": "sn36.4:2.3",
      "pali": "Sārīrikā pāṇaharā,"
    },
    {
      "id": "sn36.4:2.4",
      "pali": "yāhi phuṭṭho pavedhati."
    },
    {
      "id": "sn36.4:3.1",
      "pali": "Akkandati parodati,"
    },
    {
      "id": "sn36.4:3.2",
      "pali": "dubbalo appathāmako;"
    },
    {
      "id": "sn36.4:3.3",
      "pali": "Na so pātāle paccuṭṭhāsi,"
    },
    {
      "id": "sn36.4:3.4",
      "pali": "atho gādhampi nājjhagā."
    },
    {
      "id": "sn36.4:4.1",
      "pali": "Yo cetā adhivāseti,"
    },
    {
      "id": "sn36.4:4.2",
      "pali": "uppannā vedanā dukhā;"
    },
    {
      "id": "sn36.4:4.3",
      "pali": "Sārīrikā pāṇaharā,"
    },
    {
      "id": "sn36.4:4.4",
      "pali": "yāhi phuṭṭho na vedhati;"
    },
    {
      "id": "sn36.4:4.5",
      "pali": "Sa ve pātāle paccuṭṭhāsi,"
    },
    {
      "id": "sn36.4:4.6",
      "pali": "atho gādhampi ajjhagā”ti."
    },
    {
      "id": "sn36.4:4.7",
      "pali": "Catutthaṁ."
    }
  ]
}
