{
  "uid": "sn10.5",
  "title": "Sānusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.5:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn10.5:1.2",
      "pali": "Tena kho pana samayena aññatarissā upāsikāya sānu nāma putto yakkhena gahito hoti."
    },
    {
      "id": "sn10.5:1.3",
      "pali": "Atha kho sā upāsikā paridevamānā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn10.5:2.1",
      "pali": "“Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "sn10.5:2.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "sn10.5:2.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "sn10.5:2.4",
      "pali": "aṭṭhaṅgasusamāgataṁ."
    },
    {
      "id": "sn10.5:3.1",
      "pali": "Uposathaṁ upavasanti,"
    },
    {
      "id": "sn10.5:3.2",
      "pali": "brahmacariyaṁ caranti ye;"
    },
    {
      "id": "sn10.5:3.3",
      "pali": "Na tehi yakkhā kīḷanti,"
    },
    {
      "id": "sn10.5:3.4",
      "pali": "iti me arahataṁ sutaṁ;"
    },
    {
      "id": "sn10.5:3.5",
      "pali": "Sā dāni ajja passāmi,"
    },
    {
      "id": "sn10.5:3.6",
      "pali": "yakkhā kīḷanti sānunā”ti."
    },
    {
      "id": "sn10.5:4.1",
      "pali": "“Cātuddasiṁ pañcadasiṁ,"
    },
    {
      "id": "sn10.5:4.2",
      "pali": "yā ca pakkhassa aṭṭhamī;"
    },
    {
      "id": "sn10.5:4.3",
      "pali": "Pāṭihāriyapakkhañca,"
    },
    {
      "id": "sn10.5:4.4",
      "pali": "aṭṭhaṅgasusamāgataṁ;"
    },
    {
      "id": "sn10.5:5.1",
      "pali": "Uposathaṁ upavasanti,"
    },
    {
      "id": "sn10.5:5.2",
      "pali": "brahmacariyaṁ caranti ye."
    },
    {
      "id": "sn10.5:5.3",
      "pali": "Na tehi yakkhā kīḷanti,"
    },
    {
      "id": "sn10.5:5.4",
      "pali": "sāhu te arahataṁ sutaṁ;"
    },
    {
      "id": "sn10.5:6.1",
      "pali": "Sānuṁ pabuddhaṁ vajjāsi,"
    },
    {
      "id": "sn10.5:6.2",
      "pali": "yakkhānaṁ vacanaṁ idaṁ;"
    },
    {
      "id": "sn10.5:6.3",
      "pali": "Mākāsi pāpakaṁ kammaṁ,"
    },
    {
      "id": "sn10.5:6.4",
      "pali": "āvi vā yadi vā raho."
    },
    {
      "id": "sn10.5:7.1",
      "pali": "Sace ca pāpakaṁ kammaṁ,"
    },
    {
      "id": "sn10.5:7.2",
      "pali": "karissasi karosi vā;"
    },
    {
      "id": "sn10.5:7.3",
      "pali": "Na te dukkhā pamutyatthi,"
    },
    {
      "id": "sn10.5:7.4",
      "pali": "uppaccāpi palāyato”ti."
    },
    {
      "id": "sn10.5:8.1",
      "pali": "“Mataṁ vā amma rodanti,"
    },
    {
      "id": "sn10.5:8.2",
      "pali": "yo vā jīvaṁ na dissati;"
    },
    {
      "id": "sn10.5:8.3",
      "pali": "Jīvantaṁ amma passantī,"
    },
    {
      "id": "sn10.5:8.4",
      "pali": "kasmā maṁ amma rodasī”ti."
    },
    {
      "id": "sn10.5:9.1",
      "pali": "“Mataṁ vā putta rodanti,"
    },
    {
      "id": "sn10.5:9.2",
      "pali": "yo vā jīvaṁ na dissati;"
    },
    {
      "id": "sn10.5:9.3",
      "pali": "Yo ca kāme cajitvāna,"
    },
    {
      "id": "sn10.5:9.4",
      "pali": "punarāgacchate idha;"
    },
    {
      "id": "sn10.5:9.5",
      "pali": "Taṁ vāpi putta rodanti,"
    },
    {
      "id": "sn10.5:9.6",
      "pali": "puna jīvaṁ mato hi so."
    },
    {
      "id": "sn10.5:10.1",
      "pali": "Kukkuḷā ubbhato tāta,"
    },
    {
      "id": "sn10.5:10.2",
      "pali": "kukkuḷaṁ patitumicchasi;"
    },
    {
      "id": "sn10.5:10.3",
      "pali": "Narakā ubbhato tāta,"
    },
    {
      "id": "sn10.5:10.4",
      "pali": "narakaṁ patitumicchasi."
    },
    {
      "id": "sn10.5:11.1",
      "pali": "Abhidhāvatha bhaddante,"
    },
    {
      "id": "sn10.5:11.2",
      "pali": "kassa ujjhāpayāmase;"
    },
    {
      "id": "sn10.5:11.3",
      "pali": "Ādittā nīhataṁ bhaṇḍaṁ,"
    },
    {
      "id": "sn10.5:11.4",
      "pali": "puna ḍayhitumicchasī”ti."
    }
  ]
}
