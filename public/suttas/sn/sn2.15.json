{
  "uid": "sn2.15",
  "title": "Candanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.15:1.1",
      "pali": "Ekamantaṁ ṭhito kho candano devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.15:2.1",
      "pali": "“Kathaṁsu tarati oghaṁ,"
    },
    {
      "id": "sn2.15:2.2",
      "pali": "rattindivamatandito;"
    },
    {
      "id": "sn2.15:2.3",
      "pali": "Appatiṭṭhe anālambe,"
    },
    {
      "id": "sn2.15:2.4",
      "pali": "ko gambhīre na sīdatī”ti."
    },
    {
      "id": "sn2.15:3.1",
      "pali": "“Sabbadā sīlasampanno,"
    },
    {
      "id": "sn2.15:3.2",
      "pali": "Paññavā susamāhito;"
    },
    {
      "id": "sn2.15:3.3",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "sn2.15:3.4",
      "pali": "Oghaṁ tarati duttaraṁ."
    },
    {
      "id": "sn2.15:4.1",
      "pali": "Virato kāmasaññāya,"
    },
    {
      "id": "sn2.15:4.2",
      "pali": "rūpasaṁyojanātigo;"
    },
    {
      "id": "sn2.15:4.3",
      "pali": "Nandīrāgaparikkhīṇo,"
    },
    {
      "id": "sn2.15:4.4",
      "pali": "so gambhīre na sīdatī”ti."
    }
  ]
}
