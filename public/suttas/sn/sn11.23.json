{
  "uid": "sn11.23",
  "title": "Sambarimāyāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.23:1.1",
      "pali": "Sāvatthiyaṁ …pe…"
    },
    {
      "id": "sn11.23:1.2",
      "pali": "bhagavā etadavoca:"
    },
    {
      "id": "sn11.23:1.3",
      "pali": "“bhūtapubbaṁ, bhikkhave, vepacitti asurindo ābādhiko ahosi dukkhito bāḷhagilāno."
    },
    {
      "id": "sn11.23:1.4",
      "pali": "Atha kho, bhikkhave, sakko devānamindo yena vepacitti asurindo tenupasaṅkami gilānapucchako."
    },
    {
      "id": "sn11.23:1.5",
      "pali": "Addasā kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn11.23:1.6",
      "pali": "Disvāna sakkaṁ devānamindaṁ etadavoca:"
    },
    {
      "id": "sn11.23:1.7",
      "pali": "‘tikiccha maṁ, devānamindā’ti."
    },
    {
      "id": "sn11.23:1.8",
      "pali": "‘Vācehi maṁ, vepacitti, sambarimāyan’ti."
    },
    {
      "id": "sn11.23:1.9",
      "pali": "‘Na tāvāhaṁ vācemi, yāvāhaṁ, mārisa, asure paṭipucchāmī’ti."
    },
    {
      "id": "sn11.23:1.10",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo asure paṭipucchi:"
    },
    {
      "id": "sn11.23:1.11",
      "pali": "‘vācemahaṁ, mārisā, sakkaṁ devānamindaṁ sambarimāyan’ti?"
    },
    {
      "id": "sn11.23:1.12",
      "pali": "‘Mā kho tvaṁ, mārisa, vācesi sakkaṁ devānamindaṁ sambarimāyan’ti."
    },
    {
      "id": "sn11.23:1.13",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkaṁ devānamindaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn11.23:2.1",
      "pali": "‘Māyāvī maghavā sakka,"
    },
    {
      "id": "sn11.23:2.2",
      "pali": "devarāja sujampati;"
    },
    {
      "id": "sn11.23:2.3",
      "pali": "Upeti nirayaṁ ghoraṁ,"
    },
    {
      "id": "sn11.23:2.4",
      "pali": "sambarova sataṁ saman’”ti."
    }
  ]
}
