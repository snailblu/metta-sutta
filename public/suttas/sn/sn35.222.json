{
  "uid": "sn35.222",
  "title": "Ajjhattāyatanaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.222:1.1",
      "pali": "“Cakkhu, bhikkhave, aniccaṁ …pe… jivhā aniccā …pe… mano anicco."
    },
    {
      "id": "sn35.222:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.222:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
