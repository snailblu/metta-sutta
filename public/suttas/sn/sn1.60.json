{
  "uid": "sn1.60",
  "title": "Kavisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.60:1.1",
      "pali": "“Kiṁsu nidānaṁ gāthānaṁ,"
    },
    {
      "id": "sn1.60:1.2",
      "pali": "kiṁsu tāsaṁ viyañjanaṁ;"
    },
    {
      "id": "sn1.60:1.3",
      "pali": "Kiṁsu sannissitā gāthā,"
    },
    {
      "id": "sn1.60:1.4",
      "pali": "kiṁsu gāthānamāsayo”ti."
    },
    {
      "id": "sn1.60:2.1",
      "pali": "“Chando nidānaṁ gāthānaṁ,"
    },
    {
      "id": "sn1.60:2.2",
      "pali": "akkharā tāsaṁ viyañjanaṁ;"
    },
    {
      "id": "sn1.60:2.3",
      "pali": "Nāmasannissitā gāthā,"
    },
    {
      "id": "sn1.60:2.4",
      "pali": "kavi gāthānamāsayo”ti."
    },
    {
      "id": "sn1.60:2.5",
      "pali": "Jarāvaggo chaṭṭho."
    },
    {
      "id": "sn1.60:3.1",
      "pali": "Jarā ajarasā mittaṁ,"
    },
    {
      "id": "sn1.60:3.2",
      "pali": "vatthu tīṇi janāni ca;"
    },
    {
      "id": "sn1.60:3.3",
      "pali": "Uppatho ca dutiyo ca,"
    },
    {
      "id": "sn1.60:3.4",
      "pali": "kavinā pūrito vaggoti."
    }
  ]
}
