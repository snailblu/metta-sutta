{
  "uid": "sn11.7",
  "title": "Nadubbhiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.7:1.1",
      "pali": "Sāvatthiyaṁ."
    },
    {
      "id": "sn11.7:1.2",
      "pali": "“Bhūtapubbaṁ, bhikkhave, sakkassa devānamindassa rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "sn11.7:1.3",
      "pali": "‘yopi me assa supaccatthiko tassapāhaṁ na dubbheyyan’ti."
    },
    {
      "id": "sn11.7:1.4",
      "pali": "Atha kho, bhikkhave, vepacitti asurindo sakkassa devānamindassa cetasā cetoparivitakkamaññāya yena sakko devānamindo tenupasaṅkami."
    },
    {
      "id": "sn11.7:1.5",
      "pali": "Addasā kho, bhikkhave, sakko devānamindo vepacittiṁ asurindaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn11.7:1.6",
      "pali": "Disvāna vepacittiṁ asurindaṁ etadavoca:"
    },
    {
      "id": "sn11.7:1.7",
      "pali": "‘tiṭṭha, vepacitti, gahitosī’ti."
    },
    {
      "id": "sn11.7:2.1",
      "pali": "‘Yadeva te, mārisa, pubbe cittaṁ, tadeva tvaṁ mā pajahāsī’ti."
    },
    {
      "id": "sn11.7:3.1",
      "pali": "‘Sapassu ca me, vepacitti, adubbhāyā’ti."
    },
    {
      "id": "sn11.7:4.1",
      "pali": "‘Yaṁ musā bhaṇato pāpaṁ,"
    },
    {
      "id": "sn11.7:4.2",
      "pali": "Yaṁ pāpaṁ ariyūpavādino;"
    },
    {
      "id": "sn11.7:4.3",
      "pali": "Mittadduno ca yaṁ pāpaṁ,"
    },
    {
      "id": "sn11.7:4.4",
      "pali": "Yaṁ pāpaṁ akataññuno;"
    },
    {
      "id": "sn11.7:4.5",
      "pali": "Tameva pāpaṁ phusatu,"
    },
    {
      "id": "sn11.7:4.6",
      "pali": "Yo te dubbhe sujampatī’”ti."
    }
  ]
}
