{
  "uid": "sn38.8",
  "title": "Āsavapañhāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn38.8:1.1",
      "pali": "“‘Āsavo, āsavo’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn38.8:1.2",
      "pali": "Katamo nu kho, āvuso, āsavo”ti?"
    },
    {
      "id": "sn38.8:1.3",
      "pali": "“Tayo me, āvuso, āsavā."
    },
    {
      "id": "sn38.8:1.4",
      "pali": "Kāmāsavo, bhavāsavo, avijjāsavo—"
    },
    {
      "id": "sn38.8:1.5",
      "pali": "ime kho, āvuso, tayo āsavā”ti."
    },
    {
      "id": "sn38.8:1.6",
      "pali": "“Atthi panāvuso, maggo atthi paṭipadā etesaṁ āsavānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.8:1.7",
      "pali": "“Atthi kho, āvuso, maggo atthi paṭipadā etesaṁ āsavānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.8:1.8",
      "pali": "“Katamo panāvuso, maggo katamā paṭipadā etesaṁ āsavānaṁ pahānāyā”ti?"
    },
    {
      "id": "sn38.8:1.9",
      "pali": "“Ayameva kho, āvuso, ariyo aṭṭhaṅgiko maggo etesaṁ āsavānaṁ pahānāya, seyyathidaṁ—"
    },
    {
      "id": "sn38.8:1.10",
      "pali": "sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn38.8:1.11",
      "pali": "Ayaṁ kho, āvuso, maggo ayaṁ paṭipadā, etesaṁ āsavānaṁ pahānāyā”ti."
    },
    {
      "id": "sn38.8:1.12",
      "pali": "“Bhaddako, āvuso, maggo bhaddikā paṭipadā, etesaṁ āsavānaṁ pahānāya."
    },
    {
      "id": "sn38.8:1.13",
      "pali": "Alañca panāvuso sāriputta, appamādāyā”ti."
    },
    {
      "id": "sn38.8:1.14",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
