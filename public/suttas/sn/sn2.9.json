{
  "uid": "sn2.9",
  "title": "Candimasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn2.9:1.2",
      "pali": "Tena kho pana samayena candimā devaputto rāhunā asurindena gahito hoti."
    },
    {
      "id": "sn2.9:1.3",
      "pali": "Atha kho candimā devaputto bhagavantaṁ anussaramāno tāyaṁ velāyaṁ imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn2.9:2.1",
      "pali": "“Namo te buddha vīratthu,"
    },
    {
      "id": "sn2.9:2.2",
      "pali": "vippamuttosi sabbadhi;"
    },
    {
      "id": "sn2.9:2.3",
      "pali": "Sambādhapaṭipannosmi,"
    },
    {
      "id": "sn2.9:2.4",
      "pali": "tassa me saraṇaṁ bhavā”ti."
    },
    {
      "id": "sn2.9:3.1",
      "pali": "Atha kho bhagavā candimaṁ devaputtaṁ ārabbha rāhuṁ asurindaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.9:4.1",
      "pali": "“Tathāgataṁ arahantaṁ,"
    },
    {
      "id": "sn2.9:4.2",
      "pali": "candimā saraṇaṁ gato;"
    },
    {
      "id": "sn2.9:4.3",
      "pali": "Rāhu candaṁ pamuñcassu,"
    },
    {
      "id": "sn2.9:4.4",
      "pali": "buddhā lokānukampakā”ti."
    },
    {
      "id": "sn2.9:5.1",
      "pali": "Atha kho rāhu asurindo candimaṁ devaputtaṁ muñcitvā taramānarūpo yena vepacitti asurindo tenupasaṅkami; upasaṅkamitvā saṁviggo lomahaṭṭhajāto ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn2.9:5.2",
      "pali": "Ekamantaṁ ṭhitaṁ kho rāhuṁ asurindaṁ vepacitti asurindo gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.9:6.1",
      "pali": "“Kiṁ nu santaramānova,"
    },
    {
      "id": "sn2.9:6.2",
      "pali": "rāhu candaṁ pamuñcasi;"
    },
    {
      "id": "sn2.9:6.3",
      "pali": "Saṁviggarūpo āgamma,"
    },
    {
      "id": "sn2.9:6.4",
      "pali": "kiṁ nu bhītova tiṭṭhasī”ti."
    },
    {
      "id": "sn2.9:7.1",
      "pali": "“Sattadhā me phale muddhā,"
    },
    {
      "id": "sn2.9:7.2",
      "pali": "jīvanto na sukhaṁ labhe;"
    },
    {
      "id": "sn2.9:7.3",
      "pali": "Buddhagāthābhigītomhi,"
    },
    {
      "id": "sn2.9:7.4",
      "pali": "no ce muñceyya candiman”ti."
    }
  ]
}
