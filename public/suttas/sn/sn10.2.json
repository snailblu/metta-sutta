{
  "uid": "sn10.2",
  "title": "Sakkanāmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.2:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati gijjhakūṭe pabbate."
    },
    {
      "id": "sn10.2:1.2",
      "pali": "Atha kho sakkanāmako yakkho yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn10.2:2.1",
      "pali": "“Sabbaganthappahīnassa,"
    },
    {
      "id": "sn10.2:2.2",
      "pali": "vippamuttassa te sato;"
    },
    {
      "id": "sn10.2:2.3",
      "pali": "Samaṇassa na taṁ sādhu,"
    },
    {
      "id": "sn10.2:2.4",
      "pali": "yadaññamanusāsasī”ti."
    },
    {
      "id": "sn10.2:3.1",
      "pali": "“Yena kenaci vaṇṇena,"
    },
    {
      "id": "sn10.2:3.2",
      "pali": "saṁvāso sakka jāyati;"
    },
    {
      "id": "sn10.2:3.3",
      "pali": "Na taṁ arahati sappañño,"
    },
    {
      "id": "sn10.2:3.4",
      "pali": "manasā anukampituṁ."
    },
    {
      "id": "sn10.2:4.1",
      "pali": "Manasā ce pasannena,"
    },
    {
      "id": "sn10.2:4.2",
      "pali": "yadaññamanusāsati;"
    },
    {
      "id": "sn10.2:4.3",
      "pali": "Na tena hoti saṁyutto,"
    },
    {
      "id": "sn10.2:4.4",
      "pali": "yānukampā anuddayā”ti."
    }
  ]
}
