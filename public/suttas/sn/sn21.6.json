{
  "uid": "sn21.6",
  "title": "Lakuṇḍakabhaddiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn21.6:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn21.6:1.2",
      "pali": "Atha kho āyasmā lakuṇḍakabhaddiyo yena bhagavā tenupasaṅkami."
    },
    {
      "id": "sn21.6:1.3",
      "pali": "Addasā kho bhagavā āyasmantaṁ lakuṇḍakabhaddiyaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn21.6:1.4",
      "pali": "Disvāna bhikkhū āmantesi:"
    },
    {
      "id": "sn21.6:1.5",
      "pali": "“passatha no tumhe, bhikkhave, etaṁ bhikkhuṁ āgacchantaṁ dubbaṇṇaṁ duddasikaṁ okoṭimakaṁ bhikkhūnaṁ paribhūtarūpan”ti?"
    },
    {
      "id": "sn21.6:1.6",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "sn21.6:1.7",
      "pali": "“Eso kho, bhikkhave, bhikkhu mahiddhiko mahānubhāvo, na ca sā samāpatti sulabharūpā yā tena bhikkhunā asamāpannapubbā."
    },
    {
      "id": "sn21.6:1.8",
      "pali": "Yassa catthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti, tadanuttaraṁ brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti."
    },
    {
      "id": "sn21.6:1.9",
      "pali": "Idamavoca bhagavā …pe…"
    },
    {
      "id": "sn21.6:1.10",
      "pali": "satthā:"
    },
    {
      "id": "sn21.6:2.1",
      "pali": "“Haṁsā koñcā mayūrā ca,"
    },
    {
      "id": "sn21.6:2.2",
      "pali": "hatthayo pasadā migā;"
    },
    {
      "id": "sn21.6:2.3",
      "pali": "Sabbe sīhassa bhāyanti,"
    },
    {
      "id": "sn21.6:2.4",
      "pali": "natthi kāyasmiṁ tulyatā."
    },
    {
      "id": "sn21.6:3.1",
      "pali": "Evameva manussesu,"
    },
    {
      "id": "sn21.6:3.2",
      "pali": "daharo cepi paññavā;"
    },
    {
      "id": "sn21.6:3.3",
      "pali": "So hi tattha mahā hoti,"
    },
    {
      "id": "sn21.6:3.4",
      "pali": "neva bālo sarīravā”ti."
    },
    {
      "id": "sn21.6:3.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
