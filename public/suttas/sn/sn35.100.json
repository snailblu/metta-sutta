{
  "uid": "sn35.100",
  "title": "Paṭisallānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.100:1.1",
      "pali": "“Paṭisallāne, bhikkhave, yogamāpajjatha."
    },
    {
      "id": "sn35.100:1.2",
      "pali": "Paṭisallīno, bhikkhave, bhikkhu yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.100:1.3",
      "pali": "Kiñca yathābhūtaṁ pajānāti?"
    },
    {
      "id": "sn35.100:1.4",
      "pali": "‘Cakkhu aniccan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.100:1.5",
      "pali": "‘rūpā aniccā’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.100:1.6",
      "pali": "‘cakkhuviññāṇaṁ aniccan’ti yathābhūtaṁ pajānāti;"
    },
    {
      "id": "sn35.100:1.7",
      "pali": "‘cakkhusamphasso anicco’ti yathābhūtaṁ pajānāti …pe…"
    },
    {
      "id": "sn35.100:1.8",
      "pali": "‘yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi aniccan’ti yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn35.100:1.9",
      "pali": "Paṭisallāne, bhikkhave, yogamāpajjatha."
    },
    {
      "id": "sn35.100:1.10",
      "pali": "Paṭisallīno, bhikkhave, bhikkhu yathābhūtaṁ pajānātī”ti."
    },
    {
      "id": "sn35.100:1.11",
      "pali": "Sattamaṁ."
    }
  ]
}
