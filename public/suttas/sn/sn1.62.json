{
  "uid": "sn1.62",
  "title": "Cittasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.62:1.1",
      "pali": "“Kenassu nīyati loko,"
    },
    {
      "id": "sn1.62:1.2",
      "pali": "kenassu parikassati;"
    },
    {
      "id": "sn1.62:1.3",
      "pali": "Kissassu ekadhammassa,"
    },
    {
      "id": "sn1.62:1.4",
      "pali": "sabbeva vasamanvagū”ti."
    },
    {
      "id": "sn1.62:2.1",
      "pali": "“Cittena nīyati loko,"
    },
    {
      "id": "sn1.62:2.2",
      "pali": "cittena parikassati;"
    },
    {
      "id": "sn1.62:2.3",
      "pali": "Cittassa ekadhammassa,"
    },
    {
      "id": "sn1.62:2.4",
      "pali": "sabbeva vasamanvagū”ti."
    }
  ]
}
