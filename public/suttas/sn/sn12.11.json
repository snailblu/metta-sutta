{
  "uid": "sn12.11",
  "title": "Āhārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.11:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn12.11:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme …"
    },
    {
      "id": "sn12.11:1.3",
      "pali": "“cattārome, bhikkhave, āhārā bhūtānaṁ vā sattānaṁ ṭhitiyā sambhavesīnaṁ vā anuggahāya."
    },
    {
      "id": "sn12.11:1.4",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn12.11:1.5",
      "pali": "Kabaḷīkāro āhāro oḷāriko vā sukhumo vā, phasso dutiyo, manosañcetanā tatiyā, viññāṇaṁ catutthaṁ."
    },
    {
      "id": "sn12.11:1.6",
      "pali": "Ime kho, bhikkhave, cattāro āhārā bhūtānaṁ vā sattānaṁ ṭhitiyā sambhavesīnaṁ vā anuggahāya."
    },
    {
      "id": "sn12.11:2.1",
      "pali": "Ime, bhikkhave, cattāro āhārā kiṁnidānā kiṁsamudayā kiṁjātikā kiṁpabhavā?"
    },
    {
      "id": "sn12.11:2.2",
      "pali": "Ime cattāro āhārā taṇhānidānā taṇhāsamudayā taṇhājātikā taṇhāpabhavā."
    },
    {
      "id": "sn12.11:2.3",
      "pali": "Taṇhā cāyaṁ, bhikkhave, kiṁnidānā kiṁsamudayā kiṁjātikā kiṁpabhavā?"
    },
    {
      "id": "sn12.11:2.4",
      "pali": "Taṇhā vedanānidānā vedanāsamudayā vedanājātikā vedanāpabhavā."
    },
    {
      "id": "sn12.11:2.5",
      "pali": "Vedanā cāyaṁ, bhikkhave, kiṁnidānā kiṁsamudayā kiṁjātikā kiṁpabhavā?"
    },
    {
      "id": "sn12.11:2.6",
      "pali": "Vedanā phassanidānā phassasamudayā phassajātikā phassapabhavā."
    },
    {
      "id": "sn12.11:2.7",
      "pali": "Phasso cāyaṁ, bhikkhave, kiṁnidāno kiṁsamudayo kiṁjātiko kiṁpabhavo?"
    },
    {
      "id": "sn12.11:2.8",
      "pali": "Phasso saḷāyatananidāno saḷāyatanasamudayo saḷāyatanajātiko saḷāyatanapabhavo."
    },
    {
      "id": "sn12.11:2.9",
      "pali": "Saḷāyatanañcidaṁ, bhikkhave, kiṁnidānaṁ kiṁsamudayaṁ kiṁjātikaṁ kiṁpabhavaṁ?"
    },
    {
      "id": "sn12.11:2.10",
      "pali": "Saḷāyatanaṁ nāmarūpanidānaṁ nāmarūpasamudayaṁ nāmarūpajātikaṁ nāmarūpapabhavaṁ."
    },
    {
      "id": "sn12.11:2.11",
      "pali": "Nāmarūpañcidaṁ, bhikkhave, kiṁnidānaṁ kiṁsamudayaṁ kiṁjātikaṁ kiṁpabhavaṁ?"
    },
    {
      "id": "sn12.11:2.12",
      "pali": "Nāmarūpaṁ viññāṇanidānaṁ viññāṇasamudayaṁ viññāṇajātikaṁ viññāṇapabhavaṁ."
    },
    {
      "id": "sn12.11:2.13",
      "pali": "Viññāṇañcidaṁ, bhikkhave, kiṁnidānaṁ kiṁsamudayaṁ kiṁjātikaṁ kiṁpabhavaṁ?"
    },
    {
      "id": "sn12.11:2.14",
      "pali": "Viññāṇaṁ saṅkhāranidānaṁ saṅkhārasamudayaṁ saṅkhārajātikaṁ saṅkhārapabhavaṁ."
    },
    {
      "id": "sn12.11:2.15",
      "pali": "Saṅkhārā cime, bhikkhave, kiṁnidānā kiṁsamudayā kiṁjātikā kiṁpabhavā?"
    },
    {
      "id": "sn12.11:2.16",
      "pali": "Saṅkhārā avijjānidānā avijjāsamudayā avijjājātikā avijjāpabhavā."
    },
    {
      "id": "sn12.11:3.1",
      "pali": "Iti kho, bhikkhave, avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.11:3.2",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.11:3.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.11:3.4",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.11:3.5",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.11:3.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.11:3.7",
      "pali": "Paṭhamaṁ."
    }
  ]
}
