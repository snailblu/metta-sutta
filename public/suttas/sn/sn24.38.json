{
  "uid": "sn24.38",
  "title": "Arūpīattāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.38:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.38:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.38:1.3",
      "pali": "‘arūpī attā hoti arogo paraṁ maraṇā’”ti?"
    },
    {
      "id": "sn24.38:1.4",
      "pali": "(Peyyālo.)"
    },
    {
      "id": "sn24.38:1.5",
      "pali": "Vīsatimaṁ."
    }
  ]
}
