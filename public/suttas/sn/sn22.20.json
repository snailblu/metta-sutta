{
  "uid": "sn22.20",
  "title": "Sahetuanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.20:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.20:1.2",
      "pali": "“Rūpaṁ, bhikkhave, anattā."
    },
    {
      "id": "sn22.20:1.3",
      "pali": "Yopi hetu yopi paccayo rūpassa uppādāya, sopi anattā."
    },
    {
      "id": "sn22.20:1.4",
      "pali": "Anattasambhūtaṁ, bhikkhave, rūpaṁ kuto attā bhavissati."
    },
    {
      "id": "sn22.20:1.5",
      "pali": "Vedanā anattā …"
    },
    {
      "id": "sn22.20:1.6",
      "pali": "saññā anattā …"
    },
    {
      "id": "sn22.20:1.7",
      "pali": "saṅkhārā anattā …"
    },
    {
      "id": "sn22.20:1.8",
      "pali": "viññāṇaṁ anattā."
    },
    {
      "id": "sn22.20:1.9",
      "pali": "Yopi hetu yopi paccayo viññāṇassa uppādāya, sopi anattā."
    },
    {
      "id": "sn22.20:1.10",
      "pali": "Anattasambhūtaṁ, bhikkhave, viññāṇaṁ kuto attā bhavissati."
    },
    {
      "id": "sn22.20:1.11",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.20:1.12",
      "pali": "nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "sn22.20:1.13",
      "pali": "Navamaṁ."
    }
  ]
}
