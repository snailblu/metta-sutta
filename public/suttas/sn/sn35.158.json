{
  "uid": "sn35.158",
  "title": "Ajjhattaaniccanandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.158:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, yoniso manasi karotha, cakkhāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn35.158:1.2",
      "pali": "Cakkhuṁ, bhikkhave, bhikkhu yoniso manasikaronto, cakkhāniccatañca yathābhūtaṁ samanupassanto cakkhusmimpi nibbindati."
    },
    {
      "id": "sn35.158:1.3",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.158:1.4",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.158:1.5",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn35.158:1.6",
      "pali": "Sotaṁ, bhikkhave, yoniso manasi karotha …"
    },
    {
      "id": "sn35.158:1.7",
      "pali": "ghānaṁ …"
    },
    {
      "id": "sn35.158:1.8",
      "pali": "jivhaṁ, bhikkhave, yoniso manasi karotha, jivhāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn35.158:1.9",
      "pali": "Jivhaṁ, bhikkhave, bhikkhu yoniso manasikaronto, jivhāniccatañca yathābhūtaṁ samanupassanto jivhāyapi nibbindati."
    },
    {
      "id": "sn35.158:1.10",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.158:1.11",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.158:1.12",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn35.158:1.13",
      "pali": "Kāyaṁ …"
    },
    {
      "id": "sn35.158:1.14",
      "pali": "manaṁ, bhikkhave, yoniso manasi karotha, manāniccatañca yathābhūtaṁ samanupassatha."
    },
    {
      "id": "sn35.158:1.15",
      "pali": "Manaṁ, bhikkhave, bhikkhu yoniso manasikaronto, manāniccatañca yathābhūtaṁ samanupassanto manasmimpi nibbindati."
    },
    {
      "id": "sn35.158:1.16",
      "pali": "Nandikkhayā rāgakkhayo;"
    },
    {
      "id": "sn35.158:1.17",
      "pali": "rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn35.158:1.18",
      "pali": "Nandirāgakkhayā cittaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn35.158:1.19",
      "pali": "Tatiyaṁ."
    }
  ]
}
