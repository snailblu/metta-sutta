{
  "uid": "sn35.94",
  "title": "Adantaaguttasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.94:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn35.94:1.2",
      "pali": "“Chayime, bhikkhave, phassāyatanā adantā aguttā arakkhitā asaṁvutā dukkhādhivāhā honti."
    },
    {
      "id": "sn35.94:1.3",
      "pali": "Katame cha?"
    },
    {
      "id": "sn35.94:1.4",
      "pali": "Cakkhu, bhikkhave, phassāyatanaṁ adantaṁ aguttaṁ arakkhitaṁ asaṁvutaṁ dukkhādhivāhaṁ hoti …pe…"
    },
    {
      "id": "sn35.94:1.5",
      "pali": "jivhā, bhikkhave, phassāyatanaṁ adantaṁ aguttaṁ arakkhitaṁ asaṁvutaṁ dukkhādhivāhaṁ hoti …pe…"
    },
    {
      "id": "sn35.94:1.6",
      "pali": "mano, bhikkhave, phassāyatanaṁ adantaṁ aguttaṁ arakkhitaṁ asaṁvutaṁ dukkhādhivāhaṁ hoti."
    },
    {
      "id": "sn35.94:1.7",
      "pali": "Ime kho, bhikkhave, cha phassāyatanā adantā aguttā arakkhitā asaṁvutā dukkhādhivāhā honti”."
    },
    {
      "id": "sn35.94:2.1",
      "pali": "Chayime, bhikkhave, phassāyatanā sudantā suguttā surakkhitā susaṁvutā sukhādhivāhā honti."
    },
    {
      "id": "sn35.94:2.2",
      "pali": "Katame cha?"
    },
    {
      "id": "sn35.94:2.3",
      "pali": "Cakkhu, bhikkhave, phassāyatanaṁ sudantaṁ suguttaṁ surakkhitaṁ susaṁvutaṁ sukhādhivāhaṁ hoti …pe…"
    },
    {
      "id": "sn35.94:2.4",
      "pali": "jivhā, bhikkhave, phassāyatanaṁ sudantaṁ suguttaṁ surakkhitaṁ susaṁvutaṁ sukhādhivāhaṁ hoti …pe…"
    },
    {
      "id": "sn35.94:2.5",
      "pali": "mano, bhikkhave, phassāyatanaṁ sudantaṁ suguttaṁ surakkhitaṁ susaṁvutaṁ sukhādhivāhaṁ hoti."
    },
    {
      "id": "sn35.94:2.6",
      "pali": "Ime kho, bhikkhave, cha phassāyatanā sudantā suguttā surakkhitā susaṁvutā sukhādhivāhā hontī”ti."
    },
    {
      "id": "sn35.94:2.7",
      "pali": "Idamavoca bhagavā …pe…"
    },
    {
      "id": "sn35.94:2.8",
      "pali": "etadavoca satthā:"
    },
    {
      "id": "sn35.94:3.1",
      "pali": "“Saḷeva phassāyatanāni bhikkhavo,"
    },
    {
      "id": "sn35.94:3.2",
      "pali": "Asaṁvuto yattha dukkhaṁ nigacchati;"
    },
    {
      "id": "sn35.94:3.3",
      "pali": "Tesañca ye saṁvaraṇaṁ avedisuṁ,"
    },
    {
      "id": "sn35.94:3.4",
      "pali": "Saddhādutiyā viharantānavassutā."
    },
    {
      "id": "sn35.94:4.1",
      "pali": "Disvāna rūpāni manoramāni,"
    },
    {
      "id": "sn35.94:4.2",
      "pali": "Athopi disvāna amanoramāni;"
    },
    {
      "id": "sn35.94:4.3",
      "pali": "Manorame rāgapathaṁ vinodaye,"
    },
    {
      "id": "sn35.94:4.4",
      "pali": "Na cāppiyaṁ meti manaṁ padosaye."
    },
    {
      "id": "sn35.94:5.1",
      "pali": "Saddañca sutvā dubhayaṁ piyāppiyaṁ,"
    },
    {
      "id": "sn35.94:5.2",
      "pali": "Piyamhi sadde na samucchito siyā;"
    },
    {
      "id": "sn35.94:5.3",
      "pali": "Athoppiye dosagataṁ vinodaye,"
    },
    {
      "id": "sn35.94:5.4",
      "pali": "Na cāppiyaṁ meti manaṁ padosaye."
    },
    {
      "id": "sn35.94:6.1",
      "pali": "Gandhañca ghatvā surabhiṁ manoramaṁ,"
    },
    {
      "id": "sn35.94:6.2",
      "pali": "Athopi ghatvā asuciṁ akantiyaṁ;"
    },
    {
      "id": "sn35.94:6.3",
      "pali": "Akantiyasmiṁ paṭighaṁ vinodaye,"
    },
    {
      "id": "sn35.94:6.4",
      "pali": "Chandānunīto na ca kantiye siyā."
    },
    {
      "id": "sn35.94:7.1",
      "pali": "Rasañca bhotvāna asāditañca sāduṁ,"
    },
    {
      "id": "sn35.94:7.2",
      "pali": "Athopi bhotvāna asādumekadā;"
    },
    {
      "id": "sn35.94:7.3",
      "pali": "Sāduṁ rasaṁ nājjhosāya bhuñje,"
    },
    {
      "id": "sn35.94:7.4",
      "pali": "Virodhamāsādusu nopadaṁsaye."
    },
    {
      "id": "sn35.94:8.1",
      "pali": "Phassena phuṭṭho na sukhena majje,"
    },
    {
      "id": "sn35.94:8.2",
      "pali": "Dukkhena phuṭṭhopi na sampavedhe;"
    },
    {
      "id": "sn35.94:8.3",
      "pali": "Phassadvayaṁ sukhadukkhe upekkhe,"
    },
    {
      "id": "sn35.94:8.4",
      "pali": "Anānuruddho aviruddha kenaci."
    },
    {
      "id": "sn35.94:9.1",
      "pali": "Papañcasaññā itarītarā narā,"
    },
    {
      "id": "sn35.94:9.2",
      "pali": "Papañcayantā upayanti saññino;"
    },
    {
      "id": "sn35.94:9.3",
      "pali": "Manomayaṁ gehasitañca sabbaṁ,"
    },
    {
      "id": "sn35.94:9.4",
      "pali": "Panujja nekkhammasitaṁ irīyati."
    },
    {
      "id": "sn35.94:10.1",
      "pali": "Evaṁ mano chassu yadā subhāvito,"
    },
    {
      "id": "sn35.94:10.2",
      "pali": "Phuṭṭhassa cittaṁ na vikampate kvaci;"
    },
    {
      "id": "sn35.94:10.3",
      "pali": "Te rāgadose abhibhuyya bhikkhavo,"
    },
    {
      "id": "sn35.94:10.4",
      "pali": "Bhavattha jātimaraṇassa pāragā”ti."
    },
    {
      "id": "sn35.94:10.5",
      "pali": "Paṭhamaṁ."
    }
  ]
}
