{
  "uid": "sn1.16",
  "title": "Niddātandīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.16:1.1",
      "pali": "“Niddā tandī vijambhitā,"
    },
    {
      "id": "sn1.16:1.2",
      "pali": "Aratī bhattasammado;"
    },
    {
      "id": "sn1.16:1.3",
      "pali": "Etena nappakāsati,"
    },
    {
      "id": "sn1.16:1.4",
      "pali": "Ariyamaggo idha pāṇinan”ti."
    },
    {
      "id": "sn1.16:2.1",
      "pali": "“Niddaṁ tandiṁ vijambhitaṁ,"
    },
    {
      "id": "sn1.16:2.2",
      "pali": "Aratiṁ bhattasammadaṁ;"
    },
    {
      "id": "sn1.16:2.3",
      "pali": "Vīriyena naṁ paṇāmetvā,"
    },
    {
      "id": "sn1.16:2.4",
      "pali": "Ariyamaggo visujjhatī”ti."
    }
  ]
}
