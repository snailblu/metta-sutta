{
  "uid": "sn7.8",
  "title": "Aggikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.8:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati veḷuvane kalandakanivāpe."
    },
    {
      "id": "sn7.8:1.2",
      "pali": "Tena kho pana samayena aggikabhāradvājassa brāhmaṇassa sappinā pāyaso sannihito hoti:"
    },
    {
      "id": "sn7.8:1.3",
      "pali": "“aggiṁ juhissāmi, aggihuttaṁ paricarissāmī”ti."
    },
    {
      "id": "sn7.8:2.1",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya rājagahaṁ piṇḍāya pāvisi."
    },
    {
      "id": "sn7.8:2.2",
      "pali": "Rājagahe sapadānaṁ piṇḍāya caramāno yena aggikabhāradvājassa brāhmaṇassa nivesanaṁ tenupasaṅkami; upasaṅkamitvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn7.8:2.3",
      "pali": "Addasā kho aggikabhāradvājo brāhmaṇo bhagavantaṁ piṇḍāya ṭhitaṁ."
    },
    {
      "id": "sn7.8:2.4",
      "pali": "Disvāna bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.8:3.1",
      "pali": "“Tīhi vijjāhi sampanno,"
    },
    {
      "id": "sn7.8:3.2",
      "pali": "jātimā sutavā bahū;"
    },
    {
      "id": "sn7.8:3.3",
      "pali": "Vijjācaraṇasampanno,"
    },
    {
      "id": "sn7.8:3.4",
      "pali": "somaṁ bhuñjeyya pāyasan”ti."
    },
    {
      "id": "sn7.8:4.1",
      "pali": "“Bahumpi palapaṁ jappaṁ,"
    },
    {
      "id": "sn7.8:4.2",
      "pali": "na jaccā hoti brāhmaṇo;"
    },
    {
      "id": "sn7.8:4.3",
      "pali": "Antokasambu saṅkiliṭṭho,"
    },
    {
      "id": "sn7.8:4.4",
      "pali": "kuhanāparivārito."
    },
    {
      "id": "sn7.8:5.1",
      "pali": "Pubbenivāsaṁ yo vedī,"
    },
    {
      "id": "sn7.8:5.2",
      "pali": "saggāpāyañca passati;"
    },
    {
      "id": "sn7.8:5.3",
      "pali": "Atho jātikkhayaṁ patto,"
    },
    {
      "id": "sn7.8:5.4",
      "pali": "abhiññāvosito muni."
    },
    {
      "id": "sn7.8:6.1",
      "pali": "Etāhi tīhi vijjāhi,"
    },
    {
      "id": "sn7.8:6.2",
      "pali": "tevijjo hoti brāhmaṇo;"
    },
    {
      "id": "sn7.8:6.3",
      "pali": "Vijjācaraṇasampanno,"
    },
    {
      "id": "sn7.8:6.4",
      "pali": "somaṁ bhuñjeyya pāyasan”ti."
    },
    {
      "id": "sn7.8:7.1",
      "pali": "“Bhuñjatu bhavaṁ gotamo."
    },
    {
      "id": "sn7.8:7.2",
      "pali": "Brāhmaṇo bhavan”ti."
    },
    {
      "id": "sn7.8:8.1",
      "pali": "“Gāthābhigītaṁ me abhojaneyyaṁ,"
    },
    {
      "id": "sn7.8:8.2",
      "pali": "Sampassataṁ brāhmaṇa nesa dhammo;"
    },
    {
      "id": "sn7.8:8.3",
      "pali": "Gāthābhigītaṁ panudanti buddhā,"
    },
    {
      "id": "sn7.8:8.4",
      "pali": "Dhamme sati brāhmaṇa vuttiresā."
    },
    {
      "id": "sn7.8:9.1",
      "pali": "Aññena ca kevalinaṁ mahesiṁ,"
    },
    {
      "id": "sn7.8:9.2",
      "pali": "Khīṇāsavaṁ kukkuccavūpasantaṁ;"
    },
    {
      "id": "sn7.8:9.3",
      "pali": "Annena pānena upaṭṭhahassu,"
    },
    {
      "id": "sn7.8:9.4",
      "pali": "Khettañhi taṁ puññapekkhassa hotī”ti."
    },
    {
      "id": "sn7.8:10.1",
      "pali": "Evaṁ vutte, aggikabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.8:10.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.8:10.3",
      "pali": "aññataro ca panāyasmā aggikabhāradvājo arahataṁ ahosīti."
    }
  ]
}
