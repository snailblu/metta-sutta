{
  "uid": "sn1.18",
  "title": "Hirīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.18:1.1",
      "pali": "“Hirīnisedho puriso,"
    },
    {
      "id": "sn1.18:1.2",
      "pali": "koci lokasmiṁ vijjati;"
    },
    {
      "id": "sn1.18:1.3",
      "pali": "Yo nindaṁ apabodhati,"
    },
    {
      "id": "sn1.18:1.4",
      "pali": "asso bhadro kasāmivā”ti."
    },
    {
      "id": "sn1.18:2.1",
      "pali": "“Hirīnisedhā tanuyā,"
    },
    {
      "id": "sn1.18:2.2",
      "pali": "ye caranti sadā satā;"
    },
    {
      "id": "sn1.18:2.3",
      "pali": "Antaṁ dukkhassa pappuyya,"
    },
    {
      "id": "sn1.18:2.4",
      "pali": "caranti visame saman”ti."
    }
  ]
}
