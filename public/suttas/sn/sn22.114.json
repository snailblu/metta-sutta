{
  "uid": "sn22.114",
  "title": "Vijjāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.114:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.114:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.114:1.3",
      "pali": "“‘vijjā, vijjā’ti, bhante, vuccati."
    },
    {
      "id": "sn22.114:1.4",
      "pali": "Katamā nu kho, bhante, vijjā;"
    },
    {
      "id": "sn22.114:1.5",
      "pali": "kittāvatā ca vijjāgato hotī”ti?"
    },
    {
      "id": "sn22.114:1.6",
      "pali": "“Idha, bhikkhu, sutavā ariyasāvako rūpaṁ pajānāti, rūpasamudayaṁ … rūpanirodhaṁ … rūpanirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn22.114:1.7",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.114:1.8",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.114:1.9",
      "pali": "saṅkhāre pajānāti …pe…"
    },
    {
      "id": "sn22.114:1.10",
      "pali": "viññāṇanirodhagāminiṁ paṭipadaṁ pajānāti."
    },
    {
      "id": "sn22.114:1.11",
      "pali": "Ayaṁ vuccati, bhikkhu, vijjā;"
    },
    {
      "id": "sn22.114:1.12",
      "pali": "ettāvatā ca vijjāgato hotī”ti."
    },
    {
      "id": "sn22.114:1.13",
      "pali": "Dutiyaṁ."
    }
  ]
}
