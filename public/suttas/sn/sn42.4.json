{
  "uid": "sn42.4",
  "title": "Hatthārohasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn42.4:1.1",
      "pali": "Atha kho hatthāroho gāmaṇi yena bhagavā tenupasaṅkami; upasaṅkamitvā …pe…"
    },
    {
      "id": "sn42.4:1.2",
      "pali": "ajjatagge pāṇupetaṁ saraṇaṁ gatanti."
    },
    {
      "id": "sn42.4:1.3",
      "pali": "Catutthaṁ."
    }
  ]
}
