{
  "uid": "sn22.64",
  "title": "Maññamānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.64:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.64:1.2",
      "pali": "Atha kho aññataro bhikkhu …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.64:1.3",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu …pe… ātāpī pahitatto vihareyyan”ti."
    },
    {
      "id": "sn22.64:1.4",
      "pali": "“Maññamāno kho, bhikkhu, baddho mārassa;"
    },
    {
      "id": "sn22.64:1.5",
      "pali": "amaññamāno mutto pāpimato”ti."
    },
    {
      "id": "sn22.64:1.6",
      "pali": "“Aññātaṁ, bhagavā, aññātaṁ, sugatā”ti."
    },
    {
      "id": "sn22.64:2.1",
      "pali": "“Yathā kathaṁ pana tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsī”ti?"
    },
    {
      "id": "sn22.64:2.2",
      "pali": "“Rūpaṁ kho, bhante, maññamāno baddho mārassa;"
    },
    {
      "id": "sn22.64:2.3",
      "pali": "amaññamāno mutto pāpimato."
    },
    {
      "id": "sn22.64:2.4",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.64:2.5",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.64:2.6",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.64:2.7",
      "pali": "viññāṇaṁ maññamāno baddho mārassa;"
    },
    {
      "id": "sn22.64:2.8",
      "pali": "amaññamāno mutto pāpimato."
    },
    {
      "id": "sn22.64:2.9",
      "pali": "Imassa khvāhaṁ, bhante, bhagavatā saṅkhittena bhāsitassa evaṁ vitthārena atthaṁ ājānāmī”ti."
    },
    {
      "id": "sn22.64:3.1",
      "pali": "“Sādhu sādhu, bhikkhu."
    },
    {
      "id": "sn22.64:3.2",
      "pali": "Sādhu kho tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsi."
    },
    {
      "id": "sn22.64:3.3",
      "pali": "Rūpaṁ kho, bhikkhu, maññamāno baddho mārassa;"
    },
    {
      "id": "sn22.64:3.4",
      "pali": "amaññamāno mutto pāpimato."
    },
    {
      "id": "sn22.64:3.5",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.64:3.6",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.64:3.7",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.64:3.8",
      "pali": "viññāṇaṁ maññamāno baddho mārassa;"
    },
    {
      "id": "sn22.64:3.9",
      "pali": "amaññamāno mutto pāpimato."
    },
    {
      "id": "sn22.64:3.10",
      "pali": "Imassa kho, bhikkhu, mayā saṅkhittena bhāsitassa evaṁ vitthārena attho daṭṭhabbo”ti …pe…"
    },
    {
      "id": "sn22.64:3.11",
      "pali": "aññataro ca pana so bhikkhu arahataṁ ahosīti."
    },
    {
      "id": "sn22.64:3.12",
      "pali": "Dutiyaṁ."
    }
  ]
}
