{
  "uid": "sn35.7",
  "title": "Ajjhattāniccātītānāgatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.7:1.1",
      "pali": "“Cakkhuṁ, bhikkhave, aniccaṁ atītānāgataṁ;"
    },
    {
      "id": "sn35.7:1.2",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn35.7:1.3",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ cakkhusmiṁ anapekkho hoti;"
    },
    {
      "id": "sn35.7:1.4",
      "pali": "anāgataṁ cakkhuṁ nābhinandati;"
    },
    {
      "id": "sn35.7:1.5",
      "pali": "paccuppannassa cakkhussa nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn35.7:1.6",
      "pali": "Sotaṁ aniccaṁ …"
    },
    {
      "id": "sn35.7:1.7",
      "pali": "ghānaṁ aniccaṁ …"
    },
    {
      "id": "sn35.7:1.8",
      "pali": "jivhā aniccā atītānāgatā;"
    },
    {
      "id": "sn35.7:1.9",
      "pali": "ko pana vādo paccuppannāya."
    },
    {
      "id": "sn35.7:1.10",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītāya jivhāya anapekkho hoti;"
    },
    {
      "id": "sn35.7:1.11",
      "pali": "anāgataṁ jivhaṁ nābhinandati;"
    },
    {
      "id": "sn35.7:1.12",
      "pali": "paccuppannāya jivhāya nibbidāya virāgāya nirodhāya paṭipanno hoti."
    },
    {
      "id": "sn35.7:1.13",
      "pali": "Kāyo anicco …pe…"
    },
    {
      "id": "sn35.7:1.14",
      "pali": "mano anicco atītānāgato;"
    },
    {
      "id": "sn35.7:1.15",
      "pali": "ko pana vādo paccuppannassa."
    },
    {
      "id": "sn35.7:1.16",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako atītasmiṁ manasmiṁ anapekkho hoti;"
    },
    {
      "id": "sn35.7:1.17",
      "pali": "anāgataṁ manaṁ nābhinandati;"
    },
    {
      "id": "sn35.7:1.18",
      "pali": "paccuppannassa manassa nibbidāya virāgāya nirodhāya paṭipanno hotī”ti."
    },
    {
      "id": "sn35.7:1.19",
      "pali": "Sattamaṁ."
    }
  ]
}
