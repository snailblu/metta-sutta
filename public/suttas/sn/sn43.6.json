{
  "uid": "sn43.6",
  "title": "Sammappadhānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.6:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.6:1.2",
      "pali": "Cattāro sammappadhānā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.6:1.3",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
