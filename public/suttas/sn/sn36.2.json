{
  "uid": "sn36.2",
  "title": "Sukhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.2:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn36.2:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn36.2:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn36.2:1.4",
      "pali": "imā kho, bhikkhave, tisso vedanāti."
    },
    {
      "id": "sn36.2:2.1",
      "pali": "Sukhaṁ vā yadi vā dukkhaṁ,"
    },
    {
      "id": "sn36.2:2.2",
      "pali": "adukkhamasukhaṁ saha;"
    },
    {
      "id": "sn36.2:2.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "sn36.2:2.4",
      "pali": "yaṁ kiñci atthi veditaṁ."
    },
    {
      "id": "sn36.2:3.1",
      "pali": "Etaṁ dukkhanti ñatvāna,"
    },
    {
      "id": "sn36.2:3.2",
      "pali": "mosadhammaṁ palokinaṁ;"
    },
    {
      "id": "sn36.2:3.3",
      "pali": "Phussa phussa vayaṁ passaṁ,"
    },
    {
      "id": "sn36.2:3.4",
      "pali": "evaṁ tattha virajjatī”ti."
    },
    {
      "id": "sn36.2:3.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
