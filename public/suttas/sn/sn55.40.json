{
  "uid": "sn55.40",
  "title": "Nandiyasakkasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.40:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sakkesu viharati kapilavatthusmiṁ nigrodhārāme."
    },
    {
      "id": "sn55.40:1.2",
      "pali": "Atha kho nandiyo sakko yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho nandiyo sakko bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn55.40:1.3",
      "pali": "“yasseva nu kho, bhante, ariyasāvakassa cattāri sotāpattiyaṅgāni sabbena sabbaṁ sabbathā sabbaṁ natthi sveva nu kho, bhante, ariyasāvako pamādavihārī”ti."
    },
    {
      "id": "sn55.40:2.1",
      "pali": "“‘Yassa kho, nandiya, cattāri sotāpattiyaṅgāni sabbena sabbaṁ sabbathā sabbaṁ natthi tamahaṁ bāhiro puthujjanapakkhe ṭhito’ti vadāmi."
    },
    {
      "id": "sn55.40:2.2",
      "pali": "Api ca, nandiya, yathā ariyasāvako pamādavihārī ceva hoti, appamādavihārī ca"
    },
    {
      "id": "sn55.40:2.3",
      "pali": "taṁ suṇāhi, sādhukaṁ manasi karohi; bhāsissāmī”ti."
    },
    {
      "id": "sn55.40:2.4",
      "pali": "“Evaṁ, bhante”ti kho nandiyo sakko bhagavato paccassosi."
    },
    {
      "id": "sn55.40:2.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn55.40:3.1",
      "pali": "“Kathañca, nandiya, ariyasāvako pamādavihārī hoti?"
    },
    {
      "id": "sn55.40:3.2",
      "pali": "Idha, nandiya, ariyasāvako buddhe aveccappasādena samannāgato hoti—"
    },
    {
      "id": "sn55.40:3.3",
      "pali": "itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavāti."
    },
    {
      "id": "sn55.40:3.4",
      "pali": "So tena buddhe aveccappasādena santuṭṭho na uttari vāyamati divā pavivekāya, rattiṁ paṭisallānāya."
    },
    {
      "id": "sn55.40:3.5",
      "pali": "Tassa evaṁ pamattassa viharato pāmojjaṁ na hoti."
    },
    {
      "id": "sn55.40:3.6",
      "pali": "Pāmojje asati, pīti na hoti."
    },
    {
      "id": "sn55.40:3.7",
      "pali": "Pītiyā asati, passaddhi na hoti."
    },
    {
      "id": "sn55.40:3.8",
      "pali": "Passaddhiyā asati, dukkhaṁ viharati."
    },
    {
      "id": "sn55.40:3.9",
      "pali": "Dukkhino cittaṁ na samādhiyati."
    },
    {
      "id": "sn55.40:3.10",
      "pali": "Asamāhite citte dhammā na pātubhavanti."
    },
    {
      "id": "sn55.40:3.11",
      "pali": "Dhammānaṁ apātubhāvā pamādavihārītveva saṅkhyaṁ gacchati."
    },
    {
      "id": "sn55.40:4.1",
      "pali": "Puna caparaṁ, nandiya, ariyasāvako dhamme …pe…"
    },
    {
      "id": "sn55.40:4.2",
      "pali": "saṅghe …pe…"
    },
    {
      "id": "sn55.40:4.3",
      "pali": "ariyakantehi sīlehi samannāgato hoti akhaṇḍehi …pe… samādhisaṁvattanikehi."
    },
    {
      "id": "sn55.40:4.4",
      "pali": "So tehi ariyakantehi sīlehi santuṭṭho na uttari vāyamati divā pavivekāya rattiṁ paṭisallānāya."
    },
    {
      "id": "sn55.40:4.5",
      "pali": "Tassa evaṁ pamattassa viharato pāmojjaṁ na hoti."
    },
    {
      "id": "sn55.40:4.6",
      "pali": "Pāmojje asati, pīti na hoti."
    },
    {
      "id": "sn55.40:4.7",
      "pali": "Pītiyā asati, passaddhi na hoti."
    },
    {
      "id": "sn55.40:4.8",
      "pali": "Passaddhiyā asati, dukkhaṁ viharati."
    },
    {
      "id": "sn55.40:4.9",
      "pali": "Dukkhino cittaṁ na samādhiyati."
    },
    {
      "id": "sn55.40:4.10",
      "pali": "Asamāhite citte dhammā na pātubhavanti."
    },
    {
      "id": "sn55.40:4.11",
      "pali": "Dhammānaṁ apātubhāvā pamādavihārītveva saṅkhyaṁ gacchati."
    },
    {
      "id": "sn55.40:4.12",
      "pali": "Evaṁ kho, nandiya, ariyasāvako pamādavihārī hoti."
    },
    {
      "id": "sn55.40:5.1",
      "pali": "Kathañca, nandiya, ariyasāvako appamādavihārī hoti?"
    },
    {
      "id": "sn55.40:5.2",
      "pali": "Idha, nandiya, ariyasāvako buddhe aveccappasādena samannāgato hoti—"
    },
    {
      "id": "sn55.40:5.3",
      "pali": "itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavāti."
    },
    {
      "id": "sn55.40:5.4",
      "pali": "So tena buddhe aveccappasādena asantuṭṭho uttari vāyamati divā pavivekāya rattiṁ paṭisallānāya."
    },
    {
      "id": "sn55.40:5.5",
      "pali": "Tassa evaṁ appamattassa viharato pāmojjaṁ jāyati."
    },
    {
      "id": "sn55.40:5.6",
      "pali": "Pamuditassa pīti jāyati."
    },
    {
      "id": "sn55.40:5.7",
      "pali": "Pītimanassa kāyo passambhati."
    },
    {
      "id": "sn55.40:5.8",
      "pali": "Passaddhakāyo sukhaṁ vediyati."
    },
    {
      "id": "sn55.40:5.9",
      "pali": "Sukhino cittaṁ samādhiyati."
    },
    {
      "id": "sn55.40:5.10",
      "pali": "Samāhite citte dhammā pātubhavanti."
    },
    {
      "id": "sn55.40:5.11",
      "pali": "Dhammānaṁ pātubhāvā appamādavihārītveva saṅkhyaṁ gacchati."
    },
    {
      "id": "sn55.40:6.1",
      "pali": "Puna caparaṁ, nandiya, ariyasāvako dhamme …pe…"
    },
    {
      "id": "sn55.40:6.2",
      "pali": "saṅghe …pe…"
    },
    {
      "id": "sn55.40:6.3",
      "pali": "ariyakantehi sīlehi samannāgato hoti akhaṇḍehi …pe… samādhisaṁvattanikehi."
    },
    {
      "id": "sn55.40:6.4",
      "pali": "So tehi ariyakantehi sīlehi asantuṭṭho uttari vāyamati divā pavivekāya rattiṁ paṭisallānāya."
    },
    {
      "id": "sn55.40:6.5",
      "pali": "Tassa evaṁ appamattassa viharato pāmojjaṁ jāyati."
    },
    {
      "id": "sn55.40:6.6",
      "pali": "Pamuditassa pīti jāyati."
    },
    {
      "id": "sn55.40:6.7",
      "pali": "Pītimanassa kāyo passambhati."
    },
    {
      "id": "sn55.40:6.8",
      "pali": "Passaddhakāyo sukhaṁ vediyati."
    },
    {
      "id": "sn55.40:6.9",
      "pali": "Sukhino cittaṁ samādhiyati."
    },
    {
      "id": "sn55.40:6.10",
      "pali": "Samāhite citte dhammā pātubhavanti."
    },
    {
      "id": "sn55.40:6.11",
      "pali": "Dhammānaṁ pātubhāvā appamādavihārītveva saṅkhyaṁ gacchati."
    },
    {
      "id": "sn55.40:6.12",
      "pali": "Evaṁ kho, nandiya, ariyasāvako appamādavihārī hotī”ti."
    },
    {
      "id": "sn55.40:6.13",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn55.40:6.14",
      "pali": "Puññābhisandavaggo catuttho."
    },
    {
      "id": "sn55.40:7.1",
      "pali": "Abhisandā tayo vuttā,"
    },
    {
      "id": "sn55.40:7.2",
      "pali": "duve devapadāni ca;"
    },
    {
      "id": "sn55.40:7.3",
      "pali": "Sabhāgataṁ mahānāmo,"
    },
    {
      "id": "sn55.40:7.4",
      "pali": "vassaṁ kāḷī ca nandiyāti."
    }
  ]
}
