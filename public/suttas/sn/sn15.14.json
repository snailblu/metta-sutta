{
  "uid": "sn15.14",
  "title": "Mātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.14:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn15.14:1.2",
      "pali": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.14:1.3",
      "pali": "na so, bhikkhave, satto sulabharūpo yo namātābhūtapubbo iminā dīghena addhunā."
    },
    {
      "id": "sn15.14:1.4",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn15.14:1.5",
      "pali": "Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.14:1.6",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.14:1.7",
      "pali": "Catutthaṁ."
    }
  ]
}
