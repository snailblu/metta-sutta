{
  "uid": "sn19.19",
  "title": "Pāpasikkhamānasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn19.19:1.1",
      "pali": "“Addasaṁ sikkhamānaṁ vehāsaṁ gacchantiṁ."
    },
    {
      "id": "sn19.19:1.2",
      "pali": "Tassā saṅghāṭipi ādittā …pe…"
    },
    {
      "id": "sn19.19:1.3",
      "pali": "pāpasikkhamānā ahosi …pe…."
    },
    {
      "id": "sn19.19:1.4",
      "pali": "Navamaṁ."
    }
  ]
}
