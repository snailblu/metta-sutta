{
  "uid": "snp2.9",
  "title": "Kiṁsīlasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp2.9:1.1",
      "pali": "“Kiṁsīlo kiṁsamācāro,"
    },
    {
      "id": "snp2.9:1.2",
      "pali": "kāni kammāni brūhayaṁ;"
    },
    {
      "id": "snp2.9:1.3",
      "pali": "Naro sammā niviṭṭhassa,"
    },
    {
      "id": "snp2.9:1.4",
      "pali": "uttamatthañca pāpuṇe”."
    },
    {
      "id": "snp2.9:2.1",
      "pali": "“Vuḍḍhāpacāyī anusūyako siyā,"
    },
    {
      "id": "snp2.9:2.2",
      "pali": "Kālaññū cassa garūnaṁ dassanāya;"
    },
    {
      "id": "snp2.9:2.3",
      "pali": "Dhammiṁ kathaṁ erayitaṁ khaṇaññū,"
    },
    {
      "id": "snp2.9:2.4",
      "pali": "Suṇeyya sakkacca subhāsitāni."
    },
    {
      "id": "snp2.9:3.1",
      "pali": "Kālena gacche garūnaṁ sakāsaṁ,"
    },
    {
      "id": "snp2.9:3.2",
      "pali": "Thambhaṁ niraṅkatvā nivātavutti;"
    },
    {
      "id": "snp2.9:3.3",
      "pali": "Atthaṁ dhammaṁ saṁyamaṁ brahmacariyaṁ,"
    },
    {
      "id": "snp2.9:3.4",
      "pali": "Anussare ceva samācare ca."
    },
    {
      "id": "snp2.9:4.1",
      "pali": "Dhammārāmo dhammarato,"
    },
    {
      "id": "snp2.9:4.2",
      "pali": "Dhamme ṭhito dhammavinicchayaññū;"
    },
    {
      "id": "snp2.9:4.3",
      "pali": "Nevācare dhammasandosavādaṁ,"
    },
    {
      "id": "snp2.9:4.4",
      "pali": "Tacchehi nīyetha subhāsitehi."
    },
    {
      "id": "snp2.9:5.1",
      "pali": "Hassaṁ jappaṁ paridevaṁ padosaṁ,"
    },
    {
      "id": "snp2.9:5.2",
      "pali": "Māyākataṁ kuhanaṁ giddhi mānaṁ;"
    },
    {
      "id": "snp2.9:5.3",
      "pali": "Sārambhaṁ kakkasaṁ kasāvañca mucchaṁ,"
    },
    {
      "id": "snp2.9:5.4",
      "pali": "Hitvā care vītamado ṭhitatto."
    },
    {
      "id": "snp2.9:6.1",
      "pali": "Viññātasārāni subhāsitāni,"
    },
    {
      "id": "snp2.9:6.2",
      "pali": "Sutañca viññātasamādhisāraṁ;"
    },
    {
      "id": "snp2.9:6.3",
      "pali": "Na tassa paññā ca sutañca vaḍḍhati,"
    },
    {
      "id": "snp2.9:6.4",
      "pali": "Yo sāhaso hoti naro pamatto."
    },
    {
      "id": "snp2.9:7.1",
      "pali": "Dhamme ca ye ariyapavedite ratā,"
    },
    {
      "id": "snp2.9:7.2",
      "pali": "Anuttarā te vacasā manasā kammunā ca;"
    },
    {
      "id": "snp2.9:7.3",
      "pali": "Te santisoraccasamādhisaṇṭhitā,"
    },
    {
      "id": "snp2.9:7.4",
      "pali": "Sutassa paññāya ca sāramajjhagū”ti."
    },
    {
      "id": "snp2.9:7.5",
      "pali": "Kiṁsīlasuttaṁ navamaṁ."
    }
  ]
}
