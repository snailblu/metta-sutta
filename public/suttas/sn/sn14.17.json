{
  "uid": "sn14.17",
  "title": "Assaddhasaṁsandanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.17:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.17:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.17:1.3",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.4",
      "pali": "ahirikā ahirikehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.5",
      "pali": "anottappino anottappīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.6",
      "pali": "appassutā appassutehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.7",
      "pali": "kusītā kusītehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.8",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:1.9",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.17:2.1",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.17:2.2",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.3",
      "pali": "ahirikā ahirikehi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.4",
      "pali": "anottappino anottappīhi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.5",
      "pali": "appassutā appassutehi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.6",
      "pali": "kusītā kusītehi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.7",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandiṁsu samiṁsu;"
    },
    {
      "id": "sn14.17:2.8",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandiṁsu samiṁsu."
    },
    {
      "id": "sn14.17:3.1",
      "pali": "Anāgatampi kho, bhikkhave, addhānaṁ dhātusova sattā saṁsandissanti samessanti."
    },
    {
      "id": "sn14.17:3.2",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandissanti samessanti;"
    },
    {
      "id": "sn14.17:3.3",
      "pali": "ahirikā ahirikehi saddhiṁ saṁsandissanti samessanti;"
    },
    {
      "id": "sn14.17:3.4",
      "pali": "anottappino anottappīhi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:3.5",
      "pali": "appassutā appassutehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:3.6",
      "pali": "kusītā kusītehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:3.7",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:3.8",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandissanti samessanti."
    },
    {
      "id": "sn14.17:4.1",
      "pali": "Etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.17:4.2",
      "pali": "Assaddhā assaddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:4.3",
      "pali": "ahirikā ahirikehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:4.4",
      "pali": "anottappino anottappīhi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:4.5",
      "pali": "appassutā appassutehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:4.6",
      "pali": "kusītā kusītehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:4.7",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:4.8",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.17:5.1",
      "pali": "Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.17:5.2",
      "pali": "Saddhā saddhehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.3",
      "pali": "hirimanā hirimanehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.4",
      "pali": "ottappino ottappīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.5",
      "pali": "bahussutā bahussutehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.6",
      "pali": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.7",
      "pali": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.17:5.8",
      "pali": "paññavanto paññavantehi saddhiṁ saṁsandanti samenti."
    },
    {
      "id": "sn14.17:5.9",
      "pali": "Atītampi kho, bhikkhave, addhānaṁ …pe…"
    },
    {
      "id": "sn14.17:5.10",
      "pali": "anāgatampi kho, bhikkhave …pe…"
    },
    {
      "id": "sn14.17:5.11",
      "pali": "etarahipi kho, bhikkhave, paccuppannaṁ addhānaṁ dhātusova sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.17:5.12",
      "pali": "Saddhā saddhehi saddhiṁ …pe…"
    },
    {
      "id": "sn14.17:5.13",
      "pali": "paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti."
    },
    {
      "id": "sn14.17:5.14",
      "pali": "Sattamaṁ."
    }
  ]
}
