{
  "uid": "sn36.30",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.30:1.1",
      "pali": "“Tisso imā, bhikkhave, vedanā."
    },
    {
      "id": "sn36.30:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn36.30:1.3",
      "pali": "Sukhā vedanā, dukkhā vedanā, adukkhamasukhā vedanā—"
    },
    {
      "id": "sn36.30:1.4",
      "pali": "imā kho, bhikkhave, tisso vedanā”ti."
    },
    {
      "id": "sn36.30:1.5",
      "pali": "Dasamaṁ."
    }
  ]
}
