{
  "uid": "sn27.9",
  "title": "Dhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.9:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.9:1.2",
      "pali": "“Yo, bhikkhave, pathavīdhātuyā chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.9:1.3",
      "pali": "Yo āpodhātuyā …"
    },
    {
      "id": "sn27.9:1.4",
      "pali": "yo tejodhātuyā …"
    },
    {
      "id": "sn27.9:1.5",
      "pali": "yo vāyodhātuyā …"
    },
    {
      "id": "sn27.9:1.6",
      "pali": "yo ākāsadhātuyā …"
    },
    {
      "id": "sn27.9:1.7",
      "pali": "yo viññāṇadhātuyā chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.9:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti."
    },
    {
      "id": "sn27.9:1.9",
      "pali": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.9:1.10",
      "pali": "Navamaṁ."
    }
  ]
}
