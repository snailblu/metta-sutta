{
  "uid": "sn2.17",
  "title": "Subrahmasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn2.17:1.1",
      "pali": "Ekamantaṁ ṭhito kho subrahmā devaputto bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn2.17:2.1",
      "pali": "“Niccaṁ utrastamidaṁ cittaṁ,"
    },
    {
      "id": "sn2.17:2.2",
      "pali": "niccaṁ ubbiggamidaṁ mano;"
    },
    {
      "id": "sn2.17:2.3",
      "pali": "Anuppannesu kicchesu,"
    },
    {
      "id": "sn2.17:2.4",
      "pali": "atho uppatitesu ca;"
    },
    {
      "id": "sn2.17:2.5",
      "pali": "Sace atthi anutrastaṁ,"
    },
    {
      "id": "sn2.17:2.6",
      "pali": "taṁ me akkhāhi pucchito”ti."
    },
    {
      "id": "sn2.17:3.1",
      "pali": "“Nāññatra bojjhā tapasā,"
    },
    {
      "id": "sn2.17:3.2",
      "pali": "nāññatrindriyasaṁvarā;"
    },
    {
      "id": "sn2.17:3.3",
      "pali": "Nāññatra sabbanissaggā,"
    },
    {
      "id": "sn2.17:3.4",
      "pali": "sotthiṁ passāmi pāṇinan”ti."
    },
    {
      "id": "sn2.17:4.1",
      "pali": "Idamavoca …pe…"
    },
    {
      "id": "sn2.17:4.2",
      "pali": "tatthevantaradhāyīti."
    }
  ]
}
