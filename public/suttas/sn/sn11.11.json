{
  "uid": "sn11.11",
  "title": "Vatapadasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.11:1.1",
      "pali": "Sāvatthiyaṁ."
    },
    {
      "id": "sn11.11:1.2",
      "pali": "“Sakkassa, bhikkhave, devānamindassa pubbe manussabhūtassa satta vatapadāni samattāni samādinnāni ahesuṁ, yesaṁ samādinnattā sakko sakkattaṁ ajjhagā."
    },
    {
      "id": "sn11.11:1.3",
      "pali": "Katamāni satta vatapadāni?"
    },
    {
      "id": "sn11.11:1.4",
      "pali": "Yāvajīvaṁ mātāpettibharo assaṁ,"
    },
    {
      "id": "sn11.11:1.5",
      "pali": "yāvajīvaṁ kule jeṭṭhāpacāyī assaṁ,"
    },
    {
      "id": "sn11.11:1.6",
      "pali": "yāvajīvaṁ saṇhavāco assaṁ,"
    },
    {
      "id": "sn11.11:1.7",
      "pali": "yāvajīvaṁ apisuṇavāco assaṁ,"
    },
    {
      "id": "sn11.11:1.8",
      "pali": "yāvajīvaṁ vigatamalamaccherena cetasā agāraṁ ajjhāvaseyyaṁ muttacāgo payatapāṇi vossaggarato yācayogo dānasaṁvibhāgarato,"
    },
    {
      "id": "sn11.11:1.9",
      "pali": "yāvajīvaṁ saccavāco assaṁ,"
    },
    {
      "id": "sn11.11:1.10",
      "pali": "yāvajīvaṁ akkodhano assaṁ—sacepi me kodho uppajjeyya, khippameva naṁ paṭivineyyanti."
    },
    {
      "id": "sn11.11:1.11",
      "pali": "Sakkassa, bhikkhave, devānamindassa pubbe manussabhūtassa imāni satta vatapadāni samattāni samādinnāni ahesuṁ, yesaṁ samādinnattā sakko sakkattaṁ ajjhagāti."
    },
    {
      "id": "sn11.11:2.1",
      "pali": "Mātāpettibharaṁ jantuṁ,"
    },
    {
      "id": "sn11.11:2.2",
      "pali": "kule jeṭṭhāpacāyinaṁ;"
    },
    {
      "id": "sn11.11:2.3",
      "pali": "Saṇhaṁ sakhilasambhāsaṁ,"
    },
    {
      "id": "sn11.11:2.4",
      "pali": "pesuṇeyyappahāyinaṁ."
    },
    {
      "id": "sn11.11:3.1",
      "pali": "Maccheravinaye yuttaṁ,"
    },
    {
      "id": "sn11.11:3.2",
      "pali": "saccaṁ kodhābhibhuṁ naraṁ;"
    },
    {
      "id": "sn11.11:3.3",
      "pali": "Taṁ ve devā tāvatiṁsā,"
    },
    {
      "id": "sn11.11:3.4",
      "pali": "āhu sappuriso itī”ti."
    }
  ]
}
