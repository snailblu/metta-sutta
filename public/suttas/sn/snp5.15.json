{
  "uid": "snp5.15",
  "title": "Posālamāṇavapucchā",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp5.15:1.1",
      "pali": "“Yo atītaṁ ādisati,"
    },
    {
      "id": "snp5.15:1.2",
      "pali": "(iccāyasmā posālo)"
    },
    {
      "id": "snp5.15:1.3",
      "pali": "Anejo chinnasaṁsayo;"
    },
    {
      "id": "snp5.15:1.4",
      "pali": "Pāraguṁ sabbadhammānaṁ,"
    },
    {
      "id": "snp5.15:1.5",
      "pali": "Atthi pañhena āgamaṁ."
    },
    {
      "id": "snp5.15:2.1",
      "pali": "Vibhūtarūpasaññissa,"
    },
    {
      "id": "snp5.15:2.2",
      "pali": "sabbakāyappahāyino;"
    },
    {
      "id": "snp5.15:2.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "snp5.15:2.4",
      "pali": "natthi kiñcīti passato;"
    },
    {
      "id": "snp5.15:2.5",
      "pali": "Ñāṇaṁ sakkānupucchāmi,"
    },
    {
      "id": "snp5.15:2.6",
      "pali": "kathaṁ neyyo tathāvidho”."
    },
    {
      "id": "snp5.15:3.1",
      "pali": "“Viññāṇaṭṭhitiyo sabbā,"
    },
    {
      "id": "snp5.15:3.2",
      "pali": "(posālāti bhagavā)"
    },
    {
      "id": "snp5.15:3.3",
      "pali": "Abhijānaṁ tathāgato;"
    },
    {
      "id": "snp5.15:3.4",
      "pali": "Tiṭṭhantamenaṁ jānāti,"
    },
    {
      "id": "snp5.15:3.5",
      "pali": "Vimuttaṁ tapparāyaṇaṁ."
    },
    {
      "id": "snp5.15:4.1",
      "pali": "Ākiñcaññasambhavaṁ ñatvā,"
    },
    {
      "id": "snp5.15:4.2",
      "pali": "Nandī saṁyojanaṁ iti;"
    },
    {
      "id": "snp5.15:4.3",
      "pali": "Evametaṁ abhiññāya,"
    },
    {
      "id": "snp5.15:4.4",
      "pali": "Tato tattha vipassati;"
    },
    {
      "id": "snp5.15:4.5",
      "pali": "Etaṁ ñāṇaṁ tathaṁ tassa,"
    },
    {
      "id": "snp5.15:4.6",
      "pali": "Brāhmaṇassa vusīmato”ti."
    },
    {
      "id": "snp5.15:4.7",
      "pali": "Posālamāṇavapucchā cuddasamā."
    }
  ]
}
