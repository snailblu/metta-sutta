{
  "uid": "sn22.155",
  "title": "Sakkāyadiṭṭhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.155:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.155:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa sakkāyadiṭṭhi uppajjatī”ti?"
    },
    {
      "id": "sn22.155:1.3",
      "pali": "Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn22.155:1.4",
      "pali": "“rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa sakkāyadiṭṭhi uppajjati."
    },
    {
      "id": "sn22.155:1.5",
      "pali": "Vedanāya sati …"
    },
    {
      "id": "sn22.155:1.6",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn22.155:1.7",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn22.155:1.8",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa sakkāyadiṭṭhi uppajjati."
    },
    {
      "id": "sn22.155:1.9",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn22.155:1.10",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.155:1.11",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.155:1.12",
      "pali": "“Yaṁ panāniccaṁ …pe…"
    },
    {
      "id": "sn22.155:1.13",
      "pali": "api nu taṁ anupādāya sakkāyadiṭṭhi uppajjeyyā”ti?"
    },
    {
      "id": "sn22.155:1.14",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.155:1.15",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn22.155:1.16",
      "pali": "saññā …"
    },
    {
      "id": "sn22.155:1.17",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.155:1.18",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn22.155:1.19",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "sn22.155:1.20",
      "pali": "“Yaṁ panāniccaṁ …pe…"
    },
    {
      "id": "sn22.155:1.21",
      "pali": "api nu taṁ anupādāya sakkāyadiṭṭhi uppajjeyyā”ti?"
    },
    {
      "id": "sn22.155:1.22",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn22.155:1.23",
      "pali": "“Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.155:1.24",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn22.155:1.25",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
