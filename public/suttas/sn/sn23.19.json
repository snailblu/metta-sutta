{
  "uid": "sn23.19",
  "title": "Khayadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.19:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.19:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.19:1.3",
      "pali": "“‘khayadhammo, khayadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.19:1.4",
      "pali": "Katamo nu kho, bhante, khayadhammo”ti?"
    },
    {
      "id": "sn23.19:1.5",
      "pali": "“Rūpaṁ kho, rādha, khayadhammo, vedanā khayadhammo, saññā khayadhammo, saṅkhārā khayadhammo, viññāṇaṁ khayadhammo."
    },
    {
      "id": "sn23.19:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.19:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.19:1.8",
      "pali": "Navamaṁ."
    }
  ]
}
