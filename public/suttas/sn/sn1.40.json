{
  "uid": "sn1.40",
  "title": "Dutiyapajjunnadhītusuttaṁ",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.40:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn1.40:1.2",
      "pali": "ekaṁ samayaṁ bhagavā vesāliyaṁ viharati mahāvane kūṭāgārasālāyaṁ."
    },
    {
      "id": "sn1.40:1.3",
      "pali": "Atha kho cūḷakokanadā pajjunnassa dhītā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ mahāvanaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn1.40:1.4",
      "pali": "Ekamantaṁ ṭhitā kho sā devatā cūḷakokanadā pajjunnassa dhītā bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn1.40:2.1",
      "pali": "“Idhāgamā vijjupabhāsavaṇṇā,"
    },
    {
      "id": "sn1.40:2.2",
      "pali": "Kokanadā pajjunnassa dhītā;"
    },
    {
      "id": "sn1.40:2.3",
      "pali": "Buddhañca dhammañca namassamānā,"
    },
    {
      "id": "sn1.40:2.4",
      "pali": "Gāthācimā atthavatī abhāsi."
    },
    {
      "id": "sn1.40:3.1",
      "pali": "Bahunāpi kho taṁ vibhajeyyaṁ,"
    },
    {
      "id": "sn1.40:3.2",
      "pali": "Pariyāyena tādiso dhammo;"
    },
    {
      "id": "sn1.40:3.3",
      "pali": "Saṅkhittamatthaṁ lapayissāmi,"
    },
    {
      "id": "sn1.40:3.4",
      "pali": "Yāvatā me manasā pariyattaṁ."
    },
    {
      "id": "sn1.40:4.1",
      "pali": "Pāpaṁ na kayirā vacasā manasā,"
    },
    {
      "id": "sn1.40:4.2",
      "pali": "Kāyena vā kiñcana sabbaloke;"
    },
    {
      "id": "sn1.40:4.3",
      "pali": "Kāme pahāya satimā sampajāno,"
    },
    {
      "id": "sn1.40:4.4",
      "pali": "Dukkhaṁ na sevetha anatthasaṁhitan”ti."
    },
    {
      "id": "sn1.40:4.5",
      "pali": "Satullapakāyikavaggo catuttho."
    },
    {
      "id": "sn1.40:5.1",
      "pali": "Sabbhimaccharinā sādhu,"
    },
    {
      "id": "sn1.40:5.2",
      "pali": "na santujjhānasaññino;"
    },
    {
      "id": "sn1.40:5.3",
      "pali": "Saddhā samayo sakalikaṁ,"
    },
    {
      "id": "sn1.40:5.4",
      "pali": "ubho pajjunnadhītaroti."
    }
  ]
}
