{
  "uid": "sn7.12",
  "title": "Udayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.12:1.2",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya yena udayassa brāhmaṇassa nivesanaṁ tenupasaṅkami."
    },
    {
      "id": "sn7.12:1.3",
      "pali": "Atha kho udayo brāhmaṇo bhagavato pattaṁ odanena pūresi."
    },
    {
      "id": "sn7.12:1.4",
      "pali": "Dutiyampi kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya yena udayassa brāhmaṇassa nivesanaṁ tenupasaṅkami …pe…"
    },
    {
      "id": "sn7.12:1.5",
      "pali": "tatiyampi kho udayo brāhmaṇo bhagavato pattaṁ odanena pūretvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.12:1.6",
      "pali": "“pakaṭṭhakoyaṁ samaṇo gotamo punappunaṁ āgacchatī”ti."
    },
    {
      "id": "sn7.12:2.1",
      "pali": "“Punappunañceva vapanti bījaṁ,"
    },
    {
      "id": "sn7.12:2.2",
      "pali": "Punappunaṁ vassati devarājā;"
    },
    {
      "id": "sn7.12:2.3",
      "pali": "Punappunaṁ khettaṁ kasanti kassakā,"
    },
    {
      "id": "sn7.12:2.4",
      "pali": "Punappunaṁ dhaññamupeti raṭṭhaṁ."
    },
    {
      "id": "sn7.12:3.1",
      "pali": "Punappunaṁ yācakā yācayanti,"
    },
    {
      "id": "sn7.12:3.2",
      "pali": "Punappunaṁ dānapatī dadanti;"
    },
    {
      "id": "sn7.12:3.3",
      "pali": "Punappunaṁ dānapatī daditvā,"
    },
    {
      "id": "sn7.12:3.4",
      "pali": "Punappunaṁ saggamupenti ṭhānaṁ."
    },
    {
      "id": "sn7.12:4.1",
      "pali": "Punappunaṁ khīranikā duhanti,"
    },
    {
      "id": "sn7.12:4.2",
      "pali": "Punappunaṁ vaccho upeti mātaraṁ;"
    },
    {
      "id": "sn7.12:4.3",
      "pali": "Punappunaṁ kilamati phandati ca,"
    },
    {
      "id": "sn7.12:4.4",
      "pali": "Punappunaṁ gabbhamupeti mando."
    },
    {
      "id": "sn7.12:5.1",
      "pali": "Punappunaṁ jāyati mīyati ca,"
    },
    {
      "id": "sn7.12:5.2",
      "pali": "Punappunaṁ sivathikaṁ haranti;"
    },
    {
      "id": "sn7.12:5.3",
      "pali": "Maggañca laddhā apunabbhavāya,"
    },
    {
      "id": "sn7.12:5.4",
      "pali": "Na punappunaṁ jāyati bhūripañño”ti."
    },
    {
      "id": "sn7.12:6.1",
      "pali": "Evaṁ vutte, udayo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.12:6.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.12:6.3",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
