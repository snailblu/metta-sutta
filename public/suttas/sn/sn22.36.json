{
  "uid": "sn22.36",
  "title": "Dutiyaaññatarabhikkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.36:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.36:1.2",
      "pali": "Atha kho aññataro bhikkhu yena bhagavā …pe… ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn22.36:1.3",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu yamahaṁ bhagavato dhammaṁ sutvā eko vūpakaṭṭho appamatto ātāpī pahitatto vihareyyan”ti."
    },
    {
      "id": "sn22.36:1.4",
      "pali": "“Yaṁ kho, bhikkhu, anuseti taṁ anumīyati;"
    },
    {
      "id": "sn22.36:1.5",
      "pali": "yaṁ anumīyati tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:1.6",
      "pali": "Yaṁ nānuseti na taṁ anumīyati;"
    },
    {
      "id": "sn22.36:1.7",
      "pali": "yaṁ nānumīyati na tena saṅkhaṁ gacchatī”ti."
    },
    {
      "id": "sn22.36:1.8",
      "pali": "“Aññātaṁ, bhagavā, aññātaṁ, sugatā”ti."
    },
    {
      "id": "sn22.36:2.1",
      "pali": "“Yathā kathaṁ pana tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsī”ti?"
    },
    {
      "id": "sn22.36:2.2",
      "pali": "“Rūpañce, bhante, anuseti taṁ anumīyati;"
    },
    {
      "id": "sn22.36:2.3",
      "pali": "yaṁ anumīyati tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:2.4",
      "pali": "Vedanañce anuseti …"
    },
    {
      "id": "sn22.36:2.5",
      "pali": "saññañce anuseti …"
    },
    {
      "id": "sn22.36:2.6",
      "pali": "saṅkhāre ce anuseti …"
    },
    {
      "id": "sn22.36:2.7",
      "pali": "viññāṇañce anuseti taṁ anumīyati;"
    },
    {
      "id": "sn22.36:2.8",
      "pali": "yaṁ anumīyati tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:2.9",
      "pali": "Rūpañce, bhante, nānuseti na taṁ anumīyati;"
    },
    {
      "id": "sn22.36:2.10",
      "pali": "yaṁ nānumīyati na tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:2.11",
      "pali": "Vedanañce nānuseti …"
    },
    {
      "id": "sn22.36:2.12",
      "pali": "saññañce nānuseti …"
    },
    {
      "id": "sn22.36:2.13",
      "pali": "saṅkhāre ce nānuseti …"
    },
    {
      "id": "sn22.36:2.14",
      "pali": "viññāṇañce nānuseti na taṁ anumīyati;"
    },
    {
      "id": "sn22.36:2.15",
      "pali": "yaṁ nānumīyati na tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:2.16",
      "pali": "Imassa khvāhaṁ, bhante, bhagavatā saṅkhittena bhāsitassa evaṁ vitthārena atthaṁ ājānāmī”ti."
    },
    {
      "id": "sn22.36:3.1",
      "pali": "“Sādhu sādhu, bhikkhu."
    },
    {
      "id": "sn22.36:3.2",
      "pali": "Sādhu kho tvaṁ, bhikkhu, mayā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāsi."
    },
    {
      "id": "sn22.36:3.3",
      "pali": "Rūpañce, bhikkhu, anuseti taṁ anumīyati;"
    },
    {
      "id": "sn22.36:3.4",
      "pali": "yaṁ anumīyati tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:3.5",
      "pali": "Vedanañce, bhikkhu …"
    },
    {
      "id": "sn22.36:3.6",
      "pali": "saññañce, bhikkhu …"
    },
    {
      "id": "sn22.36:3.7",
      "pali": "saṅkhāre ce, bhikkhu …"
    },
    {
      "id": "sn22.36:3.8",
      "pali": "viññāṇañce, bhikkhu, anuseti taṁ anumīyati;"
    },
    {
      "id": "sn22.36:3.9",
      "pali": "yaṁ anumīyati tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:3.10",
      "pali": "Rūpañce, bhikkhu, nānuseti na taṁ anumīyati;"
    },
    {
      "id": "sn22.36:3.11",
      "pali": "yaṁ nānumīyati na tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:3.12",
      "pali": "Vedanañce nānuseti …"
    },
    {
      "id": "sn22.36:3.13",
      "pali": "saññañce nānuseti …"
    },
    {
      "id": "sn22.36:3.14",
      "pali": "saṅkhāre ce nānuseti …"
    },
    {
      "id": "sn22.36:3.15",
      "pali": "viññāṇañce nānuseti na taṁ anumīyati;"
    },
    {
      "id": "sn22.36:3.16",
      "pali": "yaṁ nānumīyati na tena saṅkhaṁ gacchati."
    },
    {
      "id": "sn22.36:3.17",
      "pali": "Imassa kho, bhikkhu, mayā saṅkhittena bhāsitassa evaṁ vitthārena attho daṭṭhabbo”ti …pe…"
    },
    {
      "id": "sn22.36:3.18",
      "pali": "aññataro ca pana so bhikkhu arahataṁ ahosīti."
    },
    {
      "id": "sn22.36:3.19",
      "pali": "Catutthaṁ."
    }
  ]
}
