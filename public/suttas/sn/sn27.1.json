{
  "uid": "sn27.1",
  "title": "Cakkhusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.1:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.1:1.2",
      "pali": "“Yo, bhikkhave, cakkhusmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.3",
      "pali": "Yo sotasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.4",
      "pali": "Yo ghānasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.5",
      "pali": "Yo jivhāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.6",
      "pali": "Yo kāyasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.7",
      "pali": "Yo manasmiṁ chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.1:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno imesu chasu ṭhānesu cetaso upakkileso pahīno hoti, nekkhammaninnañcassa cittaṁ hoti."
    },
    {
      "id": "sn27.1:1.9",
      "pali": "Nekkhammaparibhāvitaṁ cittaṁ kammaniyaṁ khāyati, abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.1:1.10",
      "pali": "Paṭhamaṁ."
    }
  ]
}
