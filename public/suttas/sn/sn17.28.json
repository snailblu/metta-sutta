{
  "uid": "sn17.28",
  "title": "Chavisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.28:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.28:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko."
    },
    {
      "id": "sn17.28:1.3",
      "pali": "Lābhasakkārasiloko, bhikkhave, chaviṁ chindati, chaviṁ chetvā cammaṁ chindati, cammaṁ chetvā maṁsaṁ chindati, maṁsaṁ chetvā nhāruṁ chindati, nhāruṁ chetvā aṭṭhiṁ chindati, aṭṭhiṁ chetvā aṭṭhimiñjaṁ āhacca tiṭṭhati."
    },
    {
      "id": "sn17.28:1.4",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.28:1.5",
      "pali": "evañhi vo bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.28:1.6",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
