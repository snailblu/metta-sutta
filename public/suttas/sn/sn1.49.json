{
  "uid": "sn1.49",
  "title": "Maccharisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.49:1.1",
      "pali": "“Yedha maccharino loke,"
    },
    {
      "id": "sn1.49:1.2",
      "pali": "kadariyā paribhāsakā;"
    },
    {
      "id": "sn1.49:1.3",
      "pali": "Aññesaṁ dadamānānaṁ,"
    },
    {
      "id": "sn1.49:1.4",
      "pali": "antarāyakarā narā."
    },
    {
      "id": "sn1.49:2.1",
      "pali": "Kīdiso tesaṁ vipāko,"
    },
    {
      "id": "sn1.49:2.2",
      "pali": "samparāyo ca kīdiso;"
    },
    {
      "id": "sn1.49:2.3",
      "pali": "Bhagavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "sn1.49:2.4",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "sn1.49:3.1",
      "pali": "“Yedha maccharino loke,"
    },
    {
      "id": "sn1.49:3.2",
      "pali": "kadariyā paribhāsakā;"
    },
    {
      "id": "sn1.49:3.3",
      "pali": "Aññesaṁ dadamānānaṁ,"
    },
    {
      "id": "sn1.49:3.4",
      "pali": "antarāyakarā narā."
    },
    {
      "id": "sn1.49:4.1",
      "pali": "Nirayaṁ tiracchānayoniṁ,"
    },
    {
      "id": "sn1.49:4.2",
      "pali": "yamalokaṁ upapajjare;"
    },
    {
      "id": "sn1.49:4.3",
      "pali": "Sace enti manussattaṁ,"
    },
    {
      "id": "sn1.49:4.4",
      "pali": "dalidde jāyare kule."
    },
    {
      "id": "sn1.49:5.1",
      "pali": "Coḷaṁ piṇḍo ratī khiḍḍā,"
    },
    {
      "id": "sn1.49:5.2",
      "pali": "yattha kicchena labbhati;"
    },
    {
      "id": "sn1.49:5.3",
      "pali": "Parato āsīsare bālā,"
    },
    {
      "id": "sn1.49:5.4",
      "pali": "tampi tesaṁ na labbhati;"
    },
    {
      "id": "sn1.49:5.5",
      "pali": "Diṭṭhe dhammesa vipāko,"
    },
    {
      "id": "sn1.49:5.6",
      "pali": "samparāye ca duggatī”ti."
    },
    {
      "id": "sn1.49:6.1",
      "pali": "“Itihetaṁ vijānāma,"
    },
    {
      "id": "sn1.49:6.2",
      "pali": "aññaṁ pucchāma gotama;"
    },
    {
      "id": "sn1.49:6.3",
      "pali": "Yedha laddhā manussattaṁ,"
    },
    {
      "id": "sn1.49:6.4",
      "pali": "vadaññū vītamaccharā."
    },
    {
      "id": "sn1.49:7.1",
      "pali": "Buddhe pasannā dhamme ca,"
    },
    {
      "id": "sn1.49:7.2",
      "pali": "saṅghe ca tibbagāravā;"
    },
    {
      "id": "sn1.49:7.3",
      "pali": "Kīdiso tesaṁ vipāko,"
    },
    {
      "id": "sn1.49:7.4",
      "pali": "samparāyo ca kīdiso;"
    },
    {
      "id": "sn1.49:7.5",
      "pali": "Bhagavantaṁ puṭṭhumāgamma,"
    },
    {
      "id": "sn1.49:7.6",
      "pali": "kathaṁ jānemu taṁ mayan”ti."
    },
    {
      "id": "sn1.49:8.1",
      "pali": "“Yedha laddhā manussattaṁ,"
    },
    {
      "id": "sn1.49:8.2",
      "pali": "vadaññū vītamaccharā;"
    },
    {
      "id": "sn1.49:8.3",
      "pali": "Buddhe pasannā dhamme ca,"
    },
    {
      "id": "sn1.49:8.4",
      "pali": "saṅghe ca tibbagāravā;"
    },
    {
      "id": "sn1.49:8.5",
      "pali": "Ete saggā pakāsanti,"
    },
    {
      "id": "sn1.49:8.6",
      "pali": "yattha te upapajjare."
    },
    {
      "id": "sn1.49:9.1",
      "pali": "Sace enti manussattaṁ,"
    },
    {
      "id": "sn1.49:9.2",
      "pali": "aḍḍhe ājāyare kule;"
    },
    {
      "id": "sn1.49:9.3",
      "pali": "Coḷaṁ piṇḍo ratī khiḍḍā,"
    },
    {
      "id": "sn1.49:9.4",
      "pali": "yatthākicchena labbhati."
    },
    {
      "id": "sn1.49:10.1",
      "pali": "Parasambhatesu bhogesu,"
    },
    {
      "id": "sn1.49:10.2",
      "pali": "vasavattīva modare;"
    },
    {
      "id": "sn1.49:10.3",
      "pali": "Diṭṭhe dhammesa vipāko,"
    },
    {
      "id": "sn1.49:10.4",
      "pali": "samparāye ca suggatī”ti."
    }
  ]
}
