{
  "uid": "sn22.121",
  "title": "Upādāniyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.121:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.121:1.2",
      "pali": "“Upādāniye ca, bhikkhave, dhamme desessāmi upādānañca."
    },
    {
      "id": "sn22.121:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.121:1.4",
      "pali": "Katame ca, bhikkhave, upādāniyā dhammā, katamaṁ upādānaṁ?"
    },
    {
      "id": "sn22.121:1.5",
      "pali": "Rūpaṁ, bhikkhave, upādāniyo dhammo,"
    },
    {
      "id": "sn22.121:1.6",
      "pali": "yo tattha chandarāgo, taṁ tattha upādānaṁ."
    },
    {
      "id": "sn22.121:1.7",
      "pali": "Vedanā …pe…"
    },
    {
      "id": "sn22.121:1.8",
      "pali": "saññā …"
    },
    {
      "id": "sn22.121:1.9",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.121:1.10",
      "pali": "viññāṇaṁ upādāniyo dhammo;"
    },
    {
      "id": "sn22.121:1.11",
      "pali": "yo tattha chandarāgo, taṁ tattha upādānaṁ."
    },
    {
      "id": "sn22.121:1.12",
      "pali": "Ime vuccanti, bhikkhave, upādāniyā dhammā, idaṁ upādānan”ti."
    },
    {
      "id": "sn22.121:1.13",
      "pali": "Navamaṁ."
    }
  ]
}
