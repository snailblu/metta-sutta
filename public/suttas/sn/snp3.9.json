{
  "uid": "snp3.9",
  "title": "Vāseṭṭhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp3.9:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp3.9:1.2",
      "pali": "ekaṁ samayaṁ bhagavā icchānaṅgale viharati icchānaṅgalavanasaṇḍe."
    },
    {
      "id": "snp3.9:1.3",
      "pali": "Tena kho pana samayena sambahulā abhiññātā abhiññātā brāhmaṇamahāsālā icchānaṅgale paṭivasanti, seyyathidaṁ—"
    },
    {
      "id": "snp3.9:1.4",
      "pali": "caṅkī brāhmaṇo, tārukkho brāhmaṇo, pokkharasāti brāhmaṇo, jāṇussoṇi brāhmaṇo, todeyyo brāhmaṇo, aññe ca abhiññātā abhiññātā brāhmaṇamahāsālā."
    },
    {
      "id": "snp3.9:1.5",
      "pali": "Atha kho vāseṭṭhabhāradvājānaṁ māṇavānaṁ jaṅghāvihāraṁ anucaṅkamantānaṁ anuvicarantānaṁ ayamantarākathā udapādi:"
    },
    {
      "id": "snp3.9:1.6",
      "pali": "“kathaṁ, bho, brāhmaṇo hotī”ti?"
    },
    {
      "id": "snp3.9:2.1",
      "pali": "Bhāradvājo māṇavo evamāha:"
    },
    {
      "id": "snp3.9:2.2",
      "pali": "“yato kho, bho, ubhato sujāto hoti mātito ca pitito ca saṁsuddhagahaṇiko yāva sattamā pitāmahayugā akkhitto anupakkuṭṭho jātivādena,"
    },
    {
      "id": "snp3.9:2.3",
      "pali": "ettāvatā kho bho brāhmaṇo hotī”ti."
    },
    {
      "id": "snp3.9:3.1",
      "pali": "Vāseṭṭho māṇavo evamāha:"
    },
    {
      "id": "snp3.9:3.2",
      "pali": "“yato kho, bho, sīlavā ca hoti vatasampanno ca,"
    },
    {
      "id": "snp3.9:3.3",
      "pali": "ettāvatā kho, bho, brāhmaṇo hotī”ti."
    },
    {
      "id": "snp3.9:3.4",
      "pali": "Neva kho asakkhi bhāradvājo māṇavo vāseṭṭhaṁ māṇavaṁ saññāpetuṁ, na pana asakkhi vāseṭṭho māṇavo bhāradvājaṁ māṇavaṁ saññāpetuṁ."
    },
    {
      "id": "snp3.9:4.1",
      "pali": "Atha kho vāseṭṭho māṇavo bhāradvājaṁ māṇavaṁ āmantesi:"
    },
    {
      "id": "snp3.9:4.2",
      "pali": "“ayaṁ kho, bho bhāradvāja, samaṇo gotamo sakyaputto sakyakulā pabbajito icchānaṅgale viharati icchānaṅgalavanasaṇḍe;"
    },
    {
      "id": "snp3.9:4.3",
      "pali": "taṁ kho pana bhavantaṁ gotamaṁ evaṁ kalyāṇo kittisaddo abbhuggato:"
    },
    {
      "id": "snp3.9:4.4",
      "pali": "‘itipi …pe… buddho bhagavā’ti."
    },
    {
      "id": "snp3.9:4.5",
      "pali": "Āyāma, bho bhāradvāja, yena samaṇo gotamo tenupasaṅkamissāma; upasaṅkamitvā samaṇaṁ gotamaṁ etamatthaṁ pucchissāma."
    },
    {
      "id": "snp3.9:4.6",
      "pali": "Yathā no samaṇo gotamo byākarissati tathā naṁ dhāressāmā”ti."
    },
    {
      "id": "snp3.9:4.7",
      "pali": "“Evaṁ, bho”ti kho bhāradvājo māṇavo vāseṭṭhassa māṇavassa paccassosi."
    },
    {
      "id": "snp3.9:5.1",
      "pali": "Atha kho vāseṭṭhabhāradvājā māṇavā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavatā saddhiṁ sammodiṁsu."
    },
    {
      "id": "snp3.9:5.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdiṁsu."
    },
    {
      "id": "snp3.9:5.3",
      "pali": "Ekamantaṁ nisinno kho vāseṭṭho māṇavo bhagavantaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "snp3.9:6.1",
      "pali": "“Anuññātapaṭiññātā,"
    },
    {
      "id": "snp3.9:6.2",
      "pali": "tevijjā mayamasmubho;"
    },
    {
      "id": "snp3.9:6.3",
      "pali": "Ahaṁ pokkharasātissa,"
    },
    {
      "id": "snp3.9:6.4",
      "pali": "tārukkhassāyaṁ māṇavo."
    },
    {
      "id": "snp3.9:7.1",
      "pali": "Tevijjānaṁ yadakkhātaṁ,"
    },
    {
      "id": "snp3.9:7.2",
      "pali": "Tatra kevalinosmase;"
    },
    {
      "id": "snp3.9:7.3",
      "pali": "Padakasma veyyākaraṇā,"
    },
    {
      "id": "snp3.9:7.4",
      "pali": "Jappe ācariyasādisā."
    },
    {
      "id": "snp3.9:8.1",
      "pali": "Tesaṁ no jātivādasmiṁ,"
    },
    {
      "id": "snp3.9:8.2",
      "pali": "vivādo atthi gotama;"
    },
    {
      "id": "snp3.9:8.3",
      "pali": "Jātiyā brāhmaṇo hoti,"
    },
    {
      "id": "snp3.9:8.4",
      "pali": "bhāradvājo iti bhāsati;"
    },
    {
      "id": "snp3.9:8.5",
      "pali": "Ahañca kammunā brūmi,"
    },
    {
      "id": "snp3.9:8.6",
      "pali": "evaṁ jānāhi cakkhuma."
    },
    {
      "id": "snp3.9:9.1",
      "pali": "Te na sakkoma saññāpetuṁ,"
    },
    {
      "id": "snp3.9:9.2",
      "pali": "aññamaññaṁ mayaṁ ubho;"
    },
    {
      "id": "snp3.9:9.3",
      "pali": "Bhavantaṁ puṭṭhumāgamhā,"
    },
    {
      "id": "snp3.9:9.4",
      "pali": "sambuddhaṁ iti vissutaṁ."
    },
    {
      "id": "snp3.9:10.1",
      "pali": "Candaṁ yathā khayātītaṁ,"
    },
    {
      "id": "snp3.9:10.2",
      "pali": "pecca pañjalikā janā;"
    },
    {
      "id": "snp3.9:10.3",
      "pali": "Vandamānā namassanti,"
    },
    {
      "id": "snp3.9:10.4",
      "pali": "evaṁ lokasmi gotamaṁ."
    },
    {
      "id": "snp3.9:11.1",
      "pali": "Cakkhuṁ loke samuppannaṁ,"
    },
    {
      "id": "snp3.9:11.2",
      "pali": "mayaṁ pucchāma gotamaṁ;"
    },
    {
      "id": "snp3.9:11.3",
      "pali": "Jātiyā brāhmaṇo hoti,"
    },
    {
      "id": "snp3.9:11.4",
      "pali": "udāhu bhavati kammunā;"
    },
    {
      "id": "snp3.9:11.5",
      "pali": "Ajānataṁ no pabrūhi,"
    },
    {
      "id": "snp3.9:11.6",
      "pali": "yathā jānemu brāhmaṇaṁ”."
    },
    {
      "id": "snp3.9:12.1",
      "pali": "“Tesaṁ vo ahaṁ byakkhissaṁ,"
    },
    {
      "id": "snp3.9:12.2",
      "pali": "(vāseṭṭhāti bhagavā)"
    },
    {
      "id": "snp3.9:12.3",
      "pali": "Anupubbaṁ yathātathaṁ;"
    },
    {
      "id": "snp3.9:12.4",
      "pali": "Jātivibhaṅgaṁ pāṇānaṁ,"
    },
    {
      "id": "snp3.9:12.5",
      "pali": "Aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:13.1",
      "pali": "Tiṇarukkhepi jānātha,"
    },
    {
      "id": "snp3.9:13.2",
      "pali": "na cāpi paṭijānare;"
    },
    {
      "id": "snp3.9:13.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:13.4",
      "pali": "aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:14.1",
      "pali": "Tato kīṭe paṭaṅge ca,"
    },
    {
      "id": "snp3.9:14.2",
      "pali": "yāva kunthakipillike;"
    },
    {
      "id": "snp3.9:14.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:14.4",
      "pali": "aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:15.1",
      "pali": "Catuppadepi jānātha,"
    },
    {
      "id": "snp3.9:15.2",
      "pali": "Khuddake ca mahallake;"
    },
    {
      "id": "snp3.9:15.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:15.4",
      "pali": "Aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:16.1",
      "pali": "Pādūdarepi jānātha,"
    },
    {
      "id": "snp3.9:16.2",
      "pali": "Urage dīghapiṭṭhike;"
    },
    {
      "id": "snp3.9:16.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:16.4",
      "pali": "Aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:17.1",
      "pali": "Tato macchepi jānātha,"
    },
    {
      "id": "snp3.9:17.2",
      "pali": "Odake vārigocare;"
    },
    {
      "id": "snp3.9:17.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:17.4",
      "pali": "Aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:18.1",
      "pali": "Tato pakkhīpi jānātha,"
    },
    {
      "id": "snp3.9:18.2",
      "pali": "Pattayāne vihaṅgame;"
    },
    {
      "id": "snp3.9:18.3",
      "pali": "Liṅgaṁ jātimayaṁ tesaṁ,"
    },
    {
      "id": "snp3.9:18.4",
      "pali": "Aññamaññā hi jātiyo."
    },
    {
      "id": "snp3.9:19.1",
      "pali": "Yathā etāsu jātīsu,"
    },
    {
      "id": "snp3.9:19.2",
      "pali": "Liṅgaṁ jātimayaṁ puthu;"
    },
    {
      "id": "snp3.9:19.3",
      "pali": "Evaṁ natthi manussesu,"
    },
    {
      "id": "snp3.9:19.4",
      "pali": "Liṅgaṁ jātimayaṁ puthu."
    },
    {
      "id": "snp3.9:20.1",
      "pali": "Na kesehi na sīsena,"
    },
    {
      "id": "snp3.9:20.2",
      "pali": "Na kaṇṇehi na akkhibhi;"
    },
    {
      "id": "snp3.9:20.3",
      "pali": "Na mukhena na nāsāya,"
    },
    {
      "id": "snp3.9:20.4",
      "pali": "Na oṭṭhehi bhamūhi vā."
    },
    {
      "id": "snp3.9:21.1",
      "pali": "Na gīvāya na aṁsehi,"
    },
    {
      "id": "snp3.9:21.2",
      "pali": "Na udarena na piṭṭhiyā;"
    },
    {
      "id": "snp3.9:21.3",
      "pali": "Na soṇiyā na urasā,"
    },
    {
      "id": "snp3.9:21.4",
      "pali": "Na sambādhe na methune."
    },
    {
      "id": "snp3.9:22.1",
      "pali": "Na hatthehi na pādehi,"
    },
    {
      "id": "snp3.9:22.2",
      "pali": "Nāṅgulīhi nakhehi vā;"
    },
    {
      "id": "snp3.9:22.3",
      "pali": "Na jaṅghāhi na ūrūhi,"
    },
    {
      "id": "snp3.9:22.4",
      "pali": "Na vaṇṇena sarena vā;"
    },
    {
      "id": "snp3.9:22.5",
      "pali": "Liṅgaṁ jātimayaṁ neva,"
    },
    {
      "id": "snp3.9:22.6",
      "pali": "Yathā aññāsu jātisu."
    },
    {
      "id": "snp3.9:23.1",
      "pali": "Paccattañca sarīresu,"
    },
    {
      "id": "snp3.9:23.2",
      "pali": "Manussesvetaṁ na vijjati;"
    },
    {
      "id": "snp3.9:23.3",
      "pali": "Vokārañca manussesu,"
    },
    {
      "id": "snp3.9:23.4",
      "pali": "Samaññāya pavuccati."
    },
    {
      "id": "snp3.9:24.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:24.2",
      "pali": "Gorakkhaṁ upajīvati;"
    },
    {
      "id": "snp3.9:24.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:24.4",
      "pali": "Kassako so na brāhmaṇo."
    },
    {
      "id": "snp3.9:25.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:25.2",
      "pali": "Puthusippena jīvati;"
    },
    {
      "id": "snp3.9:25.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:25.4",
      "pali": "Sippiko so na brāhmaṇo."
    },
    {
      "id": "snp3.9:26.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:26.2",
      "pali": "Vohāraṁ upajīvati;"
    },
    {
      "id": "snp3.9:26.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:26.4",
      "pali": "Vāṇijo so na brāhmaṇo."
    },
    {
      "id": "snp3.9:27.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:27.2",
      "pali": "Parapessena jīvati;"
    },
    {
      "id": "snp3.9:27.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:27.4",
      "pali": "Pessiko so na brāhmaṇo."
    },
    {
      "id": "snp3.9:28.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:28.2",
      "pali": "Adinnaṁ upajīvati;"
    },
    {
      "id": "snp3.9:28.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:28.4",
      "pali": "Coro eso na brāhmaṇo."
    },
    {
      "id": "snp3.9:29.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:29.2",
      "pali": "Issatthaṁ upajīvati;"
    },
    {
      "id": "snp3.9:29.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:29.4",
      "pali": "Yodhājīvo na brāhmaṇo."
    },
    {
      "id": "snp3.9:30.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:30.2",
      "pali": "Porohiccena jīvati;"
    },
    {
      "id": "snp3.9:30.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:30.4",
      "pali": "Yājako eso na brāhmaṇo."
    },
    {
      "id": "snp3.9:31.1",
      "pali": "Yo hi koci manussesu,"
    },
    {
      "id": "snp3.9:31.2",
      "pali": "Gāmaṁ raṭṭhañca bhuñjati;"
    },
    {
      "id": "snp3.9:31.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:31.4",
      "pali": "Rājā eso na brāhmaṇo."
    },
    {
      "id": "snp3.9:32.1",
      "pali": "Na cāhaṁ brāhmaṇaṁ brūmi,"
    },
    {
      "id": "snp3.9:32.2",
      "pali": "Yonijaṁ mattisambhavaṁ;"
    },
    {
      "id": "snp3.9:32.3",
      "pali": "Bhovādi nāma so hoti,"
    },
    {
      "id": "snp3.9:32.4",
      "pali": "Sace hoti sakiñcano;"
    },
    {
      "id": "snp3.9:32.5",
      "pali": "Akiñcanaṁ anādānaṁ,"
    },
    {
      "id": "snp3.9:32.6",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:33.1",
      "pali": "Sabbasaṁyojanaṁ chetvā,"
    },
    {
      "id": "snp3.9:33.2",
      "pali": "Yo ve na paritassati;"
    },
    {
      "id": "snp3.9:33.3",
      "pali": "Saṅgātigaṁ visaṁyuttaṁ,"
    },
    {
      "id": "snp3.9:33.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:34.1",
      "pali": "Chetvā naddhiṁ varattañca,"
    },
    {
      "id": "snp3.9:34.2",
      "pali": "Sandānaṁ sahanukkamaṁ;"
    },
    {
      "id": "snp3.9:34.3",
      "pali": "Ukkhittapalighaṁ buddhaṁ,"
    },
    {
      "id": "snp3.9:34.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:35.1",
      "pali": "Akkosaṁ vadhabandhañca,"
    },
    {
      "id": "snp3.9:35.2",
      "pali": "Aduṭṭho yo titikkhati;"
    },
    {
      "id": "snp3.9:35.3",
      "pali": "Khantībalaṁ balānīkaṁ,"
    },
    {
      "id": "snp3.9:35.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:36.1",
      "pali": "Akkodhanaṁ vatavantaṁ,"
    },
    {
      "id": "snp3.9:36.2",
      "pali": "Sīlavantaṁ anussadaṁ;"
    },
    {
      "id": "snp3.9:36.3",
      "pali": "Dantaṁ antimasārīraṁ,"
    },
    {
      "id": "snp3.9:36.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:37.1",
      "pali": "Vāri pokkharapatteva,"
    },
    {
      "id": "snp3.9:37.2",
      "pali": "Āraggeriva sāsapo;"
    },
    {
      "id": "snp3.9:37.3",
      "pali": "Yo na limpati kāmesu,"
    },
    {
      "id": "snp3.9:37.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:38.1",
      "pali": "Yo dukkhassa pajānāti,"
    },
    {
      "id": "snp3.9:38.2",
      "pali": "Idheva khayamattano;"
    },
    {
      "id": "snp3.9:38.3",
      "pali": "Pannabhāraṁ visaṁyuttaṁ,"
    },
    {
      "id": "snp3.9:38.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:39.1",
      "pali": "Gambhīrapaññaṁ medhāviṁ,"
    },
    {
      "id": "snp3.9:39.2",
      "pali": "Maggāmaggassa kovidaṁ;"
    },
    {
      "id": "snp3.9:39.3",
      "pali": "Uttamatthamanuppattaṁ,"
    },
    {
      "id": "snp3.9:39.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:40.1",
      "pali": "Asaṁsaṭṭhaṁ gahaṭṭhehi,"
    },
    {
      "id": "snp3.9:40.2",
      "pali": "Anāgārehi cūbhayaṁ;"
    },
    {
      "id": "snp3.9:40.3",
      "pali": "Anokasārimappicchaṁ,"
    },
    {
      "id": "snp3.9:40.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:41.1",
      "pali": "Nidhāya daṇḍaṁ bhūtesu,"
    },
    {
      "id": "snp3.9:41.2",
      "pali": "Tasesu thāvaresu ca;"
    },
    {
      "id": "snp3.9:41.3",
      "pali": "Yo na hanti na ghāteti,"
    },
    {
      "id": "snp3.9:41.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:42.1",
      "pali": "Aviruddhaṁ viruddhesu,"
    },
    {
      "id": "snp3.9:42.2",
      "pali": "Attadaṇḍesu nibbutaṁ;"
    },
    {
      "id": "snp3.9:42.3",
      "pali": "Sādānesu anādānaṁ,"
    },
    {
      "id": "snp3.9:42.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:43.1",
      "pali": "Yassa rāgo ca doso ca,"
    },
    {
      "id": "snp3.9:43.2",
      "pali": "Māno makkho ca pātito;"
    },
    {
      "id": "snp3.9:43.3",
      "pali": "Sāsaporiva āraggā,"
    },
    {
      "id": "snp3.9:43.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:44.1",
      "pali": "Akakkasaṁ viññāpaniṁ,"
    },
    {
      "id": "snp3.9:44.2",
      "pali": "Giraṁ saccamudīraye;"
    },
    {
      "id": "snp3.9:44.3",
      "pali": "Yāya nābhisaje kañci,"
    },
    {
      "id": "snp3.9:44.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:45.1",
      "pali": "Yodha dīghaṁ va rassaṁ vā,"
    },
    {
      "id": "snp3.9:45.2",
      "pali": "Aṇuṁ thūlaṁ subhāsubhaṁ;"
    },
    {
      "id": "snp3.9:45.3",
      "pali": "Loke adinnaṁ nādiyati,"
    },
    {
      "id": "snp3.9:45.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:46.1",
      "pali": "Āsā yassa na vijjanti,"
    },
    {
      "id": "snp3.9:46.2",
      "pali": "Asmiṁ loke paramhi ca;"
    },
    {
      "id": "snp3.9:46.3",
      "pali": "Nirāsāsaṁ visaṁyuttaṁ,"
    },
    {
      "id": "snp3.9:46.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:47.1",
      "pali": "Yassālayā na vijjanti,"
    },
    {
      "id": "snp3.9:47.2",
      "pali": "Aññāya akathaṅkathī;"
    },
    {
      "id": "snp3.9:47.3",
      "pali": "Amatogadhamanuppattaṁ,"
    },
    {
      "id": "snp3.9:47.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:48.1",
      "pali": "Yodha puññañca pāpañca,"
    },
    {
      "id": "snp3.9:48.2",
      "pali": "Ubho saṅgamupaccagā;"
    },
    {
      "id": "snp3.9:48.3",
      "pali": "Asokaṁ virajaṁ suddhaṁ,"
    },
    {
      "id": "snp3.9:48.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:49.1",
      "pali": "Candaṁva vimalaṁ suddhaṁ,"
    },
    {
      "id": "snp3.9:49.2",
      "pali": "Vippasannamanāvilaṁ;"
    },
    {
      "id": "snp3.9:49.3",
      "pali": "Nandībhavaparikkhīṇaṁ,"
    },
    {
      "id": "snp3.9:49.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:50.1",
      "pali": "Yomaṁ palipathaṁ duggaṁ,"
    },
    {
      "id": "snp3.9:50.2",
      "pali": "Saṁsāraṁ mohamaccagā;"
    },
    {
      "id": "snp3.9:50.3",
      "pali": "Tiṇṇo pāraṅgato jhāyī,"
    },
    {
      "id": "snp3.9:50.4",
      "pali": "Anejo akathaṅkathī;"
    },
    {
      "id": "snp3.9:50.5",
      "pali": "Anupādāya nibbuto,"
    },
    {
      "id": "snp3.9:50.6",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:51.1",
      "pali": "Yodha kāme pahantvāna,"
    },
    {
      "id": "snp3.9:51.2",
      "pali": "Anāgāro paribbaje;"
    },
    {
      "id": "snp3.9:51.3",
      "pali": "Kāmabhavaparikkhīṇaṁ,"
    },
    {
      "id": "snp3.9:51.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:52.1",
      "pali": "Yodha taṇhaṁ pahantvāna,"
    },
    {
      "id": "snp3.9:52.2",
      "pali": "Anāgāro paribbaje;"
    },
    {
      "id": "snp3.9:52.3",
      "pali": "Taṇhābhavaparikkhīṇaṁ,"
    },
    {
      "id": "snp3.9:52.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:53.1",
      "pali": "Hitvā mānusakaṁ yogaṁ,"
    },
    {
      "id": "snp3.9:53.2",
      "pali": "Dibbaṁ yogaṁ upaccagā;"
    },
    {
      "id": "snp3.9:53.3",
      "pali": "Sabbayogavisaṁyuttaṁ,"
    },
    {
      "id": "snp3.9:53.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:54.1",
      "pali": "Hitvā ratiñca aratiṁ,"
    },
    {
      "id": "snp3.9:54.2",
      "pali": "Sītibhūtaṁ nirūpadhiṁ;"
    },
    {
      "id": "snp3.9:54.3",
      "pali": "Sabbalokābhibhuṁ vīraṁ,"
    },
    {
      "id": "snp3.9:54.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:55.1",
      "pali": "Cutiṁ yo vedi sattānaṁ,"
    },
    {
      "id": "snp3.9:55.2",
      "pali": "Upapattiñca sabbaso;"
    },
    {
      "id": "snp3.9:55.3",
      "pali": "Asattaṁ sugataṁ buddhaṁ,"
    },
    {
      "id": "snp3.9:55.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:56.1",
      "pali": "Yassa gatiṁ na jānanti,"
    },
    {
      "id": "snp3.9:56.2",
      "pali": "Devā gandhabbamānusā;"
    },
    {
      "id": "snp3.9:56.3",
      "pali": "Khīṇāsavaṁ arahantaṁ,"
    },
    {
      "id": "snp3.9:56.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:57.1",
      "pali": "Yassa pure ca pacchā ca,"
    },
    {
      "id": "snp3.9:57.2",
      "pali": "Majjhe ca natthi kiñcanaṁ;"
    },
    {
      "id": "snp3.9:57.3",
      "pali": "Akiñcanaṁ anādānaṁ,"
    },
    {
      "id": "snp3.9:57.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:58.1",
      "pali": "Usabhaṁ pavaraṁ vīraṁ,"
    },
    {
      "id": "snp3.9:58.2",
      "pali": "Mahesiṁ vijitāvinaṁ;"
    },
    {
      "id": "snp3.9:58.3",
      "pali": "Anejaṁ nhātakaṁ buddhaṁ,"
    },
    {
      "id": "snp3.9:58.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:59.1",
      "pali": "Pubbenivāsaṁ yo vedi,"
    },
    {
      "id": "snp3.9:59.2",
      "pali": "Saggāpāyañca passati;"
    },
    {
      "id": "snp3.9:59.3",
      "pali": "Atho jātikkhayaṁ patto,"
    },
    {
      "id": "snp3.9:59.4",
      "pali": "Tamahaṁ brūmi brāhmaṇaṁ."
    },
    {
      "id": "snp3.9:60.1",
      "pali": "Samaññā hesā lokasmiṁ,"
    },
    {
      "id": "snp3.9:60.2",
      "pali": "Nāmagottaṁ pakappitaṁ;"
    },
    {
      "id": "snp3.9:60.3",
      "pali": "Sammuccā samudāgataṁ,"
    },
    {
      "id": "snp3.9:60.4",
      "pali": "Tattha tattha pakappitaṁ."
    },
    {
      "id": "snp3.9:61.1",
      "pali": "Dīgharattamanusayitaṁ,"
    },
    {
      "id": "snp3.9:61.2",
      "pali": "Diṭṭhigatamajānataṁ;"
    },
    {
      "id": "snp3.9:61.3",
      "pali": "Ajānantā no pabruvanti,"
    },
    {
      "id": "snp3.9:61.4",
      "pali": "Jātiyā hoti brāhmaṇo."
    },
    {
      "id": "snp3.9:62.1",
      "pali": "Na jaccā brāhmaṇo hoti,"
    },
    {
      "id": "snp3.9:62.2",
      "pali": "Na jaccā hoti abrāhmaṇo;"
    },
    {
      "id": "snp3.9:62.3",
      "pali": "Kammunā brāhmaṇo hoti,"
    },
    {
      "id": "snp3.9:62.4",
      "pali": "Kammunā hoti abrāhmaṇo."
    },
    {
      "id": "snp3.9:63.1",
      "pali": "Kassako kammunā hoti,"
    },
    {
      "id": "snp3.9:63.2",
      "pali": "Sippiko hoti kammunā;"
    },
    {
      "id": "snp3.9:63.3",
      "pali": "Vāṇijo kammunā hoti,"
    },
    {
      "id": "snp3.9:63.4",
      "pali": "Pessiko hoti kammunā."
    },
    {
      "id": "snp3.9:64.1",
      "pali": "Coropi kammunā hoti,"
    },
    {
      "id": "snp3.9:64.2",
      "pali": "Yodhājīvopi kammunā;"
    },
    {
      "id": "snp3.9:64.3",
      "pali": "Yājako kammunā hoti,"
    },
    {
      "id": "snp3.9:64.4",
      "pali": "Rājāpi hoti kammunā."
    },
    {
      "id": "snp3.9:65.1",
      "pali": "Evametaṁ yathābhūtaṁ,"
    },
    {
      "id": "snp3.9:65.2",
      "pali": "Kammaṁ passanti paṇḍitā;"
    },
    {
      "id": "snp3.9:65.3",
      "pali": "Paṭiccasamuppādadassā,"
    },
    {
      "id": "snp3.9:65.4",
      "pali": "Kammavipākakovidā."
    },
    {
      "id": "snp3.9:66.1",
      "pali": "Kammunā vattati loko,"
    },
    {
      "id": "snp3.9:66.2",
      "pali": "Kammunā vattati pajā;"
    },
    {
      "id": "snp3.9:66.3",
      "pali": "Kammanibandhanā sattā,"
    },
    {
      "id": "snp3.9:66.4",
      "pali": "Rathassāṇīva yāyato."
    },
    {
      "id": "snp3.9:67.1",
      "pali": "Tapena brahmacariyena,"
    },
    {
      "id": "snp3.9:67.2",
      "pali": "Saṁyamena damena ca;"
    },
    {
      "id": "snp3.9:67.3",
      "pali": "Etena brāhmaṇo hoti,"
    },
    {
      "id": "snp3.9:67.4",
      "pali": "Etaṁ brāhmaṇamuttamaṁ."
    },
    {
      "id": "snp3.9:68.1",
      "pali": "Tīhi vijjāhi sampanno,"
    },
    {
      "id": "snp3.9:68.2",
      "pali": "santo khīṇapunabbhavo;"
    },
    {
      "id": "snp3.9:68.3",
      "pali": "Evaṁ vāseṭṭha jānāhi,"
    },
    {
      "id": "snp3.9:68.4",
      "pali": "brahmā sakko vijānatan”ti."
    },
    {
      "id": "snp3.9:69.1",
      "pali": "Evaṁ vutte, vāseṭṭhabhāradvājā māṇavā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "snp3.9:69.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "snp3.9:69.3",
      "pali": "upāsake no bhavaṁ gotamo dhāretu ajjatagge pāṇupete saraṇaṁ gate”ti."
    },
    {
      "id": "snp3.9:69.4",
      "pali": "Vāseṭṭhasuttaṁ navamaṁ."
    }
  ]
}
