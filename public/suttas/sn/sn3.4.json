{
  "uid": "sn3.4",
  "title": "Piyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn3.4:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn3.4:1.2",
      "pali": "Ekamantaṁ nisinno kho rājā pasenadi kosalo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn3.4:1.3",
      "pali": "“idha mayhaṁ, bhante, rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "sn3.4:1.4",
      "pali": "‘kesaṁ nu kho piyo attā, kesaṁ appiyo attā’ti?"
    },
    {
      "id": "sn3.4:1.5",
      "pali": "Tassa mayhaṁ, bhante, etadahosi:"
    },
    {
      "id": "sn3.4:1.6",
      "pali": "‘ye ca kho keci kāyena duccaritaṁ caranti, vācāya duccaritaṁ caranti, manasā duccaritaṁ caranti;"
    },
    {
      "id": "sn3.4:1.7",
      "pali": "tesaṁ appiyo attā."
    },
    {
      "id": "sn3.4:1.8",
      "pali": "Kiñcāpi te evaṁ vadeyyuṁ:"
    },
    {
      "id": "sn3.4:1.9",
      "pali": "“piyo no attā”ti, atha kho tesaṁ appiyo attā’."
    },
    {
      "id": "sn3.4:1.10",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.4:1.11",
      "pali": "Yañhi appiyo appiyassa kareyya, taṁ te attanāva attano karonti;"
    },
    {
      "id": "sn3.4:1.12",
      "pali": "tasmā tesaṁ appiyo attā."
    },
    {
      "id": "sn3.4:1.13",
      "pali": "Ye ca kho keci kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti;"
    },
    {
      "id": "sn3.4:1.14",
      "pali": "tesaṁ piyo attā."
    },
    {
      "id": "sn3.4:1.15",
      "pali": "Kiñcāpi te evaṁ vadeyyuṁ:"
    },
    {
      "id": "sn3.4:1.16",
      "pali": "‘appiyo no attā’ti; atha kho tesaṁ piyo attā."
    },
    {
      "id": "sn3.4:1.17",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.4:1.18",
      "pali": "Yañhi piyo piyassa kareyya, taṁ te attanāva attano karonti;"
    },
    {
      "id": "sn3.4:1.19",
      "pali": "tasmā tesaṁ piyo attā”ti."
    },
    {
      "id": "sn3.4:2.1",
      "pali": "“Evametaṁ, mahārāja, evametaṁ, mahārāja."
    },
    {
      "id": "sn3.4:2.2",
      "pali": "Ye hi keci, mahārāja, kāyena duccaritaṁ caranti, vācāya duccaritaṁ caranti, manasā duccaritaṁ caranti;"
    },
    {
      "id": "sn3.4:2.3",
      "pali": "tasmā tesaṁ appiyo attā."
    },
    {
      "id": "sn3.4:2.4",
      "pali": "Kiñcāpi te evaṁ vadeyyuṁ:"
    },
    {
      "id": "sn3.4:2.5",
      "pali": "‘piyo no attā’ti, atha kho tesaṁ appiyo attā."
    },
    {
      "id": "sn3.4:2.6",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.4:2.7",
      "pali": "Yañhi, mahārāja, appiyo appiyassa kareyya, taṁ te attanāva attano karonti;"
    },
    {
      "id": "sn3.4:2.8",
      "pali": "tasmā tesaṁ appiyo attā."
    },
    {
      "id": "sn3.4:2.9",
      "pali": "Ye ca kho keci, mahārāja, kāyena sucaritaṁ caranti, vācāya sucaritaṁ caranti, manasā sucaritaṁ caranti;"
    },
    {
      "id": "sn3.4:2.10",
      "pali": "tesaṁ piyo attā."
    },
    {
      "id": "sn3.4:2.11",
      "pali": "Kiñcāpi te evaṁ vadeyyuṁ:"
    },
    {
      "id": "sn3.4:2.12",
      "pali": "‘appiyo no attā’ti;"
    },
    {
      "id": "sn3.4:2.13",
      "pali": "atha kho tesaṁ piyo attā."
    },
    {
      "id": "sn3.4:2.14",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn3.4:2.15",
      "pali": "Yañhi, mahārāja, piyo piyassa kareyya, taṁ te attanāva attano karonti;"
    },
    {
      "id": "sn3.4:2.16",
      "pali": "tasmā tesaṁ piyo attā”ti."
    },
    {
      "id": "sn3.4:2.17",
      "pali": "Idamavoca …pe…"
    },
    {
      "id": "sn3.4:3.1",
      "pali": "“Attānañce piyaṁ jaññā,"
    },
    {
      "id": "sn3.4:3.2",
      "pali": "na naṁ pāpena saṁyuje;"
    },
    {
      "id": "sn3.4:3.3",
      "pali": "Na hi taṁ sulabhaṁ hoti,"
    },
    {
      "id": "sn3.4:3.4",
      "pali": "sukhaṁ dukkaṭakārinā."
    },
    {
      "id": "sn3.4:4.1",
      "pali": "Antakenādhipannassa,"
    },
    {
      "id": "sn3.4:4.2",
      "pali": "jahato mānusaṁ bhavaṁ;"
    },
    {
      "id": "sn3.4:4.3",
      "pali": "Kiñhi tassa sakaṁ hoti,"
    },
    {
      "id": "sn3.4:4.4",
      "pali": "kiñca ādāya gacchati;"
    },
    {
      "id": "sn3.4:4.5",
      "pali": "Kiñcassa anugaṁ hoti,"
    },
    {
      "id": "sn3.4:4.6",
      "pali": "chāyāva anapāyinī."
    },
    {
      "id": "sn3.4:5.1",
      "pali": "Ubho puññañca pāpañca,"
    },
    {
      "id": "sn3.4:5.2",
      "pali": "yaṁ macco kurute idha;"
    },
    {
      "id": "sn3.4:5.3",
      "pali": "Tañhi tassa sakaṁ hoti,"
    },
    {
      "id": "sn3.4:5.4",
      "pali": "taṁva ādāya gacchati;"
    },
    {
      "id": "sn3.4:5.5",
      "pali": "Taṁvassa anugaṁ hoti,"
    },
    {
      "id": "sn3.4:5.6",
      "pali": "chāyāva anapāyinī."
    },
    {
      "id": "sn3.4:6.1",
      "pali": "Tasmā kareyya kalyāṇaṁ,"
    },
    {
      "id": "sn3.4:6.2",
      "pali": "nicayaṁ samparāyikaṁ;"
    },
    {
      "id": "sn3.4:6.3",
      "pali": "Puññāni paralokasmiṁ,"
    },
    {
      "id": "sn3.4:6.4",
      "pali": "patiṭṭhā honti pāṇinan”ti."
    }
  ]
}
