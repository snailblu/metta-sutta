{
  "uid": "sn18.4",
  "title": "Samphassasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.4:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.4:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.4:1.3",
      "pali": "cakkhusamphasso nicco vā anicco vā”ti?"
    },
    {
      "id": "sn18.4:1.4",
      "pali": "“Anicco, bhante” …"
    },
    {
      "id": "sn18.4:1.5",
      "pali": "“sotasamphasso …pe…"
    },
    {
      "id": "sn18.4:1.6",
      "pali": "ghānasamphasso …"
    },
    {
      "id": "sn18.4:1.7",
      "pali": "jivhāsamphasso …"
    },
    {
      "id": "sn18.4:1.8",
      "pali": "kāyasamphasso …"
    },
    {
      "id": "sn18.4:1.9",
      "pali": "manosamphasso nicco vā anicco vā”ti?"
    },
    {
      "id": "sn18.4:1.10",
      "pali": "“Anicco, bhante” …"
    },
    {
      "id": "sn18.4:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusamphassasmimpi nibbindati …pe… sotasamphassasmimpi nibbindati … ghānasamphassasmimpi nibbindati … jivhāsamphassasmimpi nibbindati … kāyasamphassasmimpi nibbindati … manosamphassasmimpi nibbindati;"
    },
    {
      "id": "sn18.4:1.12",
      "pali": "nibbindaṁ virajjati …pe…"
    },
    {
      "id": "sn18.4:1.13",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.4:1.14",
      "pali": "Catutthaṁ."
    }
  ]
}
