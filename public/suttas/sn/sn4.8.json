{
  "uid": "sn4.8",
  "title": "Nandatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.8:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.8:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn4.8:1.3",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavato santike imaṁ gāthaṁ abhāsi:"
    },
    {
      "id": "sn4.8:2.1",
      "pali": "“Nandati puttehi puttimā,"
    },
    {
      "id": "sn4.8:2.2",
      "pali": "Gomā gobhi tatheva nandati;"
    },
    {
      "id": "sn4.8:2.3",
      "pali": "Upadhīhi narassa nandanā,"
    },
    {
      "id": "sn4.8:2.4",
      "pali": "Na hi so nandati yo nirūpadhī”ti."
    },
    {
      "id": "sn4.8:3.1",
      "pali": "“Socati puttehi puttimā,"
    },
    {
      "id": "sn4.8:3.2",
      "pali": "Gomā gobhi tatheva socati;"
    },
    {
      "id": "sn4.8:3.3",
      "pali": "Upadhīhi narassa socanā,"
    },
    {
      "id": "sn4.8:3.4",
      "pali": "Na hi so socati yo nirūpadhī”ti."
    },
    {
      "id": "sn4.8:4.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
