{
  "uid": "sn7.16",
  "title": "Paccanīkasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.16:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.16:1.2",
      "pali": "Tena kho pana samayena paccanīkasāto nāma brāhmaṇo sāvatthiyaṁ paṭivasati."
    },
    {
      "id": "sn7.16:1.3",
      "pali": "Atha kho paccanīkasātassa brāhmaṇassa etadahosi:"
    },
    {
      "id": "sn7.16:1.4",
      "pali": "“yannūnāhaṁ yena samaṇo gotamo tenupasaṅkameyyaṁ."
    },
    {
      "id": "sn7.16:1.5",
      "pali": "Yaṁ yadeva samaṇo gotamo bhāsissati taṁ tadevassāhaṁ paccanīkāssan”ti."
    },
    {
      "id": "sn7.16:1.6",
      "pali": "Tena kho pana samayena bhagavā abbhokāse caṅkamati."
    },
    {
      "id": "sn7.16:1.7",
      "pali": "Atha kho paccanīkasāto brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ caṅkamantaṁ etadavoca:"
    },
    {
      "id": "sn7.16:1.8",
      "pali": "“bhaṇa samaṇadhamman”ti."
    },
    {
      "id": "sn7.16:2.1",
      "pali": "“Na paccanīkasātena,"
    },
    {
      "id": "sn7.16:2.2",
      "pali": "suvijānaṁ subhāsitaṁ;"
    },
    {
      "id": "sn7.16:2.3",
      "pali": "Upakkiliṭṭhacittena,"
    },
    {
      "id": "sn7.16:2.4",
      "pali": "sārambhabahulena ca."
    },
    {
      "id": "sn7.16:3.1",
      "pali": "Yo ca vineyya sārambhaṁ,"
    },
    {
      "id": "sn7.16:3.2",
      "pali": "appasādañca cetaso;"
    },
    {
      "id": "sn7.16:3.3",
      "pali": "Āghātaṁ paṭinissajja,"
    },
    {
      "id": "sn7.16:3.4",
      "pali": "sa ve jaññā subhāsitan”ti."
    },
    {
      "id": "sn7.16:4.1",
      "pali": "Evaṁ vutte, paccanīkasāto brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.16:4.2",
      "pali": "“abhikkantaṁ, bho gotama, abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.16:4.3",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
