{
  "uid": "sn8.1",
  "title": "Nikkhantasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn8.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn8.1:1.2",
      "pali": "ekaṁ samayaṁ āyasmā vaṅgīso āḷaviyaṁ viharati aggāḷave cetiye āyasmatā nigrodhakappena upajjhāyena saddhiṁ."
    },
    {
      "id": "sn8.1:1.3",
      "pali": "Tena kho pana samayena āyasmā vaṅgīso navako hoti acirapabbajito ohiyyako vihārapālo."
    },
    {
      "id": "sn8.1:1.4",
      "pali": "Atha kho sambahulā itthiyo samalaṅkaritvā yena aggāḷavako ārāmo tenupasaṅkamiṁsu vihārapekkhikāyo."
    },
    {
      "id": "sn8.1:1.5",
      "pali": "Atha kho āyasmato vaṅgīsassa tā itthiyo disvā anabhirati uppajjati, rāgo cittaṁ anuddhaṁseti."
    },
    {
      "id": "sn8.1:1.6",
      "pali": "Atha kho āyasmato vaṅgīsassa etadahosi:"
    },
    {
      "id": "sn8.1:1.7",
      "pali": "“alābhā vata me, na vata me lābhā; dulladdhaṁ vata me, na vata me suladdhaṁ;"
    },
    {
      "id": "sn8.1:1.8",
      "pali": "yassa me anabhirati uppannā, rāgo cittaṁ anuddhaṁseti, taṁ kutettha labbhā, yaṁ me paro anabhiratiṁ vinodetvā abhiratiṁ uppādeyya."
    },
    {
      "id": "sn8.1:1.9",
      "pali": "Yannūnāhaṁ attanāva attano anabhiratiṁ vinodetvā abhiratiṁ uppādeyyan”ti."
    },
    {
      "id": "sn8.1:1.10",
      "pali": "Atha kho āyasmā vaṅgīso attanāva attano anabhiratiṁ vinodetvā abhiratiṁ uppādetvā tāyaṁ velāyaṁ imā gāthāyo abhāsi:"
    },
    {
      "id": "sn8.1:2.1",
      "pali": "“Nikkhantaṁ vata maṁ santaṁ,"
    },
    {
      "id": "sn8.1:2.2",
      "pali": "agārasmānagāriyaṁ;"
    },
    {
      "id": "sn8.1:2.3",
      "pali": "Vitakkā upadhāvanti,"
    },
    {
      "id": "sn8.1:2.4",
      "pali": "pagabbhā kaṇhato ime."
    },
    {
      "id": "sn8.1:3.1",
      "pali": "Uggaputtā mahissāsā,"
    },
    {
      "id": "sn8.1:3.2",
      "pali": "sikkhitā daḷhadhammino;"
    },
    {
      "id": "sn8.1:3.3",
      "pali": "Samantā parikireyyuṁ,"
    },
    {
      "id": "sn8.1:3.4",
      "pali": "sahassaṁ apalāyinaṁ."
    },
    {
      "id": "sn8.1:4.1",
      "pali": "Sacepi etato bhiyyo,"
    },
    {
      "id": "sn8.1:4.2",
      "pali": "āgamissanti itthiyo;"
    },
    {
      "id": "sn8.1:4.3",
      "pali": "Neva maṁ byādhayissanti,"
    },
    {
      "id": "sn8.1:4.4",
      "pali": "dhamme samhi patiṭṭhitaṁ."
    },
    {
      "id": "sn8.1:5.1",
      "pali": "Sakkhī hi me sutaṁ etaṁ,"
    },
    {
      "id": "sn8.1:5.2",
      "pali": "buddhassādiccabandhuno;"
    },
    {
      "id": "sn8.1:5.3",
      "pali": "Nibbānagamanaṁ maggaṁ,"
    },
    {
      "id": "sn8.1:5.4",
      "pali": "tattha me nirato mano."
    },
    {
      "id": "sn8.1:6.1",
      "pali": "Evañce maṁ viharantaṁ,"
    },
    {
      "id": "sn8.1:6.2",
      "pali": "pāpima upagacchasi;"
    },
    {
      "id": "sn8.1:6.3",
      "pali": "Tathā maccu karissāmi,"
    },
    {
      "id": "sn8.1:6.4",
      "pali": "na me maggampi dakkhasī”ti."
    }
  ]
}
