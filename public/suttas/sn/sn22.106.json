{
  "uid": "sn22.106",
  "title": "Pariññeyyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.106:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.106:1.2",
      "pali": "“Pariññeyye ca, bhikkhave, dhamme desessāmi pariññañca pariññātāviñca puggalaṁ."
    },
    {
      "id": "sn22.106:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.106:1.4",
      "pali": "Katame ca, bhikkhave, pariññeyyā dhammā?"
    },
    {
      "id": "sn22.106:1.5",
      "pali": "Rūpaṁ, bhikkhave, pariññeyyo dhammo."
    },
    {
      "id": "sn22.106:1.6",
      "pali": "Vedanā …pe…"
    },
    {
      "id": "sn22.106:1.7",
      "pali": "saññā …"
    },
    {
      "id": "sn22.106:1.8",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.106:1.9",
      "pali": "viññāṇaṁ pariññeyyo dhammo."
    },
    {
      "id": "sn22.106:1.10",
      "pali": "Ime vuccanti, bhikkhave, pariññeyyā dhammā."
    },
    {
      "id": "sn22.106:1.11",
      "pali": "Katamā ca, bhikkhave, pariññā?"
    },
    {
      "id": "sn22.106:1.12",
      "pali": "Rāgakkhayo, dosakkhayo, mohakkhayo—"
    },
    {
      "id": "sn22.106:1.13",
      "pali": "ayaṁ vuccati, bhikkhave, pariññā."
    },
    {
      "id": "sn22.106:1.14",
      "pali": "Katamo ca, bhikkhave, pariññātāvī puggalo?"
    },
    {
      "id": "sn22.106:1.15",
      "pali": "Arahātissa vacanīyaṁ."
    },
    {
      "id": "sn22.106:1.16",
      "pali": "Yvāyaṁ āyasmā evaṁnāmo evaṅgotto—"
    },
    {
      "id": "sn22.106:1.17",
      "pali": "ayaṁ vuccati, bhikkhave, pariññātāvī puggalo”ti."
    },
    {
      "id": "sn22.106:1.18",
      "pali": "Catutthaṁ."
    }
  ]
}
