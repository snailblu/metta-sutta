{
  "uid": "sn30.17-46",
  "title": "Jalābujadānūpakārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn30.17-46:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn30.17-46:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn30.17-46:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā jalābujānaṁ supaṇṇānaṁ …pe…"
    },
    {
      "id": "sn30.17-46:1.4",
      "pali": "saṁsedajānaṁ supaṇṇānaṁ …pe…"
    },
    {
      "id": "sn30.17-46:1.5",
      "pali": "opapātikānaṁ supaṇṇānaṁ sahabyataṁ upapajjatī”ti?"
    },
    {
      "id": "sn30.17-46:1.6",
      "pali": "“Idha, bhikkhu, ekacco kāyena dvayakārī hoti, vācāya dvayakārī, manasā dvayakārī."
    },
    {
      "id": "sn30.17-46:1.7",
      "pali": "Tassa sutaṁ hoti:"
    },
    {
      "id": "sn30.17-46:1.8",
      "pali": "‘opapātikā supaṇṇā dīghāyukā vaṇṇavanto sukhabahulā’ti."
    },
    {
      "id": "sn30.17-46:1.9",
      "pali": "Tassa evaṁ hoti:"
    },
    {
      "id": "sn30.17-46:1.10",
      "pali": "‘aho vatāhaṁ kāyassa bhedā paraṁ maraṇā opapātikānaṁ supaṇṇānaṁ sahabyataṁ upapajjeyyan’ti."
    },
    {
      "id": "sn30.17-46:1.11",
      "pali": "So annaṁ deti …pe…"
    },
    {
      "id": "sn30.17-46:1.12",
      "pali": "pānaṁ deti …pe…"
    },
    {
      "id": "sn30.17-46:1.13",
      "pali": "padīpeyyaṁ deti."
    },
    {
      "id": "sn30.17-46:1.14",
      "pali": "So kāyassa bhedā paraṁ maraṇā opapātikānaṁ supaṇṇānaṁ sahabyataṁ upapajjati."
    },
    {
      "id": "sn30.17-46:1.15",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yena midhekacco kāyassa bhedā paraṁ maraṇā opapātikānaṁ supaṇṇānaṁ sahabyataṁ upapajjatī”ti."
    },
    {
      "id": "sn30.17-46:1.16",
      "pali": "Chacattālīsamaṁ."
    },
    {
      "id": "sn30.17-46:1.17",
      "pali": "(Evaṁ piṇḍakena chacattālīsaṁ suttantā honti.)"
    },
    {
      "id": "sn30.17-46:1.18",
      "pali": "Supaṇṇavaggo paṭhamo."
    },
    {
      "id": "sn30.17-46:2.1",
      "pali": "Suddhikaṁ haranti ceva,"
    },
    {
      "id": "sn30.17-46:2.2",
      "pali": "dvayakārī ca caturo;"
    },
    {
      "id": "sn30.17-46:2.3",
      "pali": "Dānūpakārā tālīsaṁ,"
    },
    {
      "id": "sn30.17-46:2.4",
      "pali": "supaṇṇe suppakāsitāti."
    },
    {
      "id": "sn30.17-46:2.5",
      "pali": "Supaṇṇasaṁyuttaṁ samattaṁ."
    }
  ]
}
