{
  "uid": "sn45.104-108",
  "title": "sn45.104-108",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.104:1.1",
      "pali": "“Seyyathāpi, bhikkhave, yamunā nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā;"
    },
    {
      "id": "sn45.104:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhu …pe…"
    },
    {
      "id": "sn45.104:1.3",
      "pali": "dutiyaṁ."
    },
    {
      "id": "sn45.105:1.1",
      "pali": "“Seyyathāpi, bhikkhave, aciravatī nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā;"
    },
    {
      "id": "sn45.105:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhu …pe…"
    },
    {
      "id": "sn45.105:1.3",
      "pali": "tatiyaṁ."
    },
    {
      "id": "sn45.106:1.1",
      "pali": "“Seyyathāpi, bhikkhave, sarabhū nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā;"
    },
    {
      "id": "sn45.106:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhu …pe…"
    },
    {
      "id": "sn45.106:1.3",
      "pali": "catutthaṁ."
    },
    {
      "id": "sn45.107:1.1",
      "pali": "“Seyyathāpi, bhikkhave, mahī nadī pācīnaninnā pācīnapoṇā pācīnapabbhārā;"
    },
    {
      "id": "sn45.107:1.2",
      "pali": "evameva kho, bhikkhave, bhikkhu …pe…"
    },
    {
      "id": "sn45.107:1.3",
      "pali": "pañcamaṁ."
    },
    {
      "id": "sn45.108:1.1",
      "pali": "“Seyyathāpi, bhikkhave, yā kācimā mahānadiyo, seyyathidaṁ—"
    },
    {
      "id": "sn45.108:1.2",
      "pali": "gaṅgā, yamunā, aciravatī, sarabhū, mahī, sabbā tā pācīnaninnā pācīnapoṇā pācīnapabbhārā;"
    },
    {
      "id": "sn45.108:1.3",
      "pali": "evameva kho, bhikkhave, bhikkhu …pe…"
    },
    {
      "id": "sn45.108:1.4",
      "pali": "chaṭṭhaṁ."
    }
  ]
}
