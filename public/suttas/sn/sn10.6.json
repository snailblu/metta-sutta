{
  "uid": "sn10.6",
  "title": "Piyaṅkarasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn10.6:1.1",
      "pali": "Ekaṁ samayaṁ āyasmā anuruddho sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "sn10.6:1.2",
      "pali": "Tena kho pana samayena āyasmā anuruddho rattiyā paccūsasamayaṁ paccuṭṭhāya dhammapadāni bhāsati."
    },
    {
      "id": "sn10.6:1.3",
      "pali": "Atha kho piyaṅkaramātā yakkhinī puttakaṁ evaṁ tosesi:"
    },
    {
      "id": "sn10.6:2.1",
      "pali": "“Mā saddaṁ kari piyaṅkara,"
    },
    {
      "id": "sn10.6:2.2",
      "pali": "Bhikkhu dhammapadāni bhāsati;"
    },
    {
      "id": "sn10.6:2.3",
      "pali": "Api ca dhammapadaṁ vijāniya,"
    },
    {
      "id": "sn10.6:2.4",
      "pali": "Paṭipajjema hitāya no siyā."
    },
    {
      "id": "sn10.6:3.1",
      "pali": "Pāṇesu ca saṁyamāmase,"
    },
    {
      "id": "sn10.6:3.2",
      "pali": "Sampajānamusā na bhaṇāmase;"
    },
    {
      "id": "sn10.6:3.3",
      "pali": "Sikkhema susīlyamattano,"
    },
    {
      "id": "sn10.6:3.4",
      "pali": "Api muccema pisācayoniyā”ti."
    }
  ]
}
