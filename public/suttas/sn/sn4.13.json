{
  "uid": "sn4.13",
  "title": "Sakalikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.13:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.13:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati maddakucchismiṁ migadāye."
    },
    {
      "id": "sn4.13:1.3",
      "pali": "Tena kho pana samayena bhagavato pādo sakalikāya khato hoti,"
    },
    {
      "id": "sn4.13:1.4",
      "pali": "bhusā sudaṁ bhagavato vedanā vattanti sārīrikā dukkhā tibbā kharā kaṭukā asātā amanāpā."
    },
    {
      "id": "sn4.13:1.5",
      "pali": "Tā sudaṁ bhagavā sato sampajāno adhivāseti avihaññamāno."
    },
    {
      "id": "sn4.13:1.6",
      "pali": "Atha kho bhagavā catugguṇaṁ saṅghāṭiṁ paññapetvā dakkhiṇena passena sīhaseyyaṁ kappesi pāde pādaṁ accādhāya sato sampajāno."
    },
    {
      "id": "sn4.13:1.7",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.13:2.1",
      "pali": "“Mandiyā nu kho sesi udāhu kāveyyamatto,"
    },
    {
      "id": "sn4.13:2.2",
      "pali": "Atthā nu te sampacurā na santi;"
    },
    {
      "id": "sn4.13:2.3",
      "pali": "Eko vivitte sayanāsanamhi,"
    },
    {
      "id": "sn4.13:2.4",
      "pali": "Niddāmukho kimidaṁ soppase vā”ti."
    },
    {
      "id": "sn4.13:3.1",
      "pali": "“Na mandiyā sayāmi nāpi kāveyyamatto,"
    },
    {
      "id": "sn4.13:3.2",
      "pali": "Atthaṁ sameccāhamapetasoko;"
    },
    {
      "id": "sn4.13:3.3",
      "pali": "Eko vivitte sayanāsanamhi,"
    },
    {
      "id": "sn4.13:3.4",
      "pali": "Sayāmahaṁ sabbabhūtānukampī."
    },
    {
      "id": "sn4.13:4.1",
      "pali": "Yesampi sallaṁ urasi paviṭṭhaṁ,"
    },
    {
      "id": "sn4.13:4.2",
      "pali": "Muhuṁ muhuṁ hadayaṁ vedhamānaṁ;"
    },
    {
      "id": "sn4.13:4.3",
      "pali": "Tepīdha soppaṁ labhare sasallā,"
    },
    {
      "id": "sn4.13:4.4",
      "pali": "Tasmā ahaṁ na supe vītasallo."
    },
    {
      "id": "sn4.13:5.1",
      "pali": "Jaggaṁ na saṅke napi bhemi sottuṁ,"
    },
    {
      "id": "sn4.13:5.2",
      "pali": "Rattindivā nānutapanti māmaṁ;"
    },
    {
      "id": "sn4.13:5.3",
      "pali": "Hāniṁ na passāmi kuhiñci loke,"
    },
    {
      "id": "sn4.13:5.4",
      "pali": "Tasmā supe sabbabhūtānukampī”ti."
    },
    {
      "id": "sn4.13:6.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
