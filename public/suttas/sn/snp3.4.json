{
  "uid": "snp3.4",
  "title": "Pūraḷāsa (sundarikabhāradvāja) sutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp3.4:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp3.4:1.2",
      "pali": "ekaṁ samayaṁ bhagavā kosalesu viharati sundarikāya nadiyā tīre."
    },
    {
      "id": "snp3.4:1.3",
      "pali": "Tena kho pana samayena sundarikabhāradvājo brāhmaṇo sundarikāya nadiyā tīre aggiṁ juhati, aggihuttaṁ paricarati."
    },
    {
      "id": "snp3.4:1.4",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo aggiṁ juhitvā aggihuttaṁ paricaritvā uṭṭhāyāsanā samantā catuddisā anuvilokesi:"
    },
    {
      "id": "snp3.4:1.5",
      "pali": "“ko nu kho imaṁ habyasesaṁ bhuñjeyyā”ti?"
    },
    {
      "id": "snp3.4:1.6",
      "pali": "Addasā kho sundarikabhāradvājo brāhmaṇo bhagavantaṁ avidūre aññatarasmiṁ rukkhamūle sasīsaṁ pārutaṁ nisinnaṁ;"
    },
    {
      "id": "snp3.4:1.7",
      "pali": "disvāna vāmena hatthena habyasesaṁ gahetvā dakkhiṇena hatthena kamaṇḍaluṁ gahetvā yena bhagavā tenupasaṅkami."
    },
    {
      "id": "snp3.4:2.1",
      "pali": "Atha kho bhagavā sundarikabhāradvājassa brāhmaṇassa padasaddena sīsaṁ vivari."
    },
    {
      "id": "snp3.4:2.2",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo: “muṇḍo ayaṁ bhavaṁ, muṇḍako ayaṁ bhavan”ti tatova puna nivattitukāmo ahosi."
    },
    {
      "id": "snp3.4:2.3",
      "pali": "Atha kho sundarikabhāradvājassa brāhmaṇassa etadahosi:"
    },
    {
      "id": "snp3.4:2.4",
      "pali": "“muṇḍāpi hi idhekacce brāhmaṇā bhavanti, yannūnāhaṁ upasaṅkamitvā jātiṁ puccheyyan”ti."
    },
    {
      "id": "snp3.4:2.5",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.4:2.6",
      "pali": "“kiṁjacco bhavan”ti?"
    },
    {
      "id": "snp3.4:3.1",
      "pali": "Atha kho bhagavā sundarikabhāradvājaṁ brāhmaṇaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "snp3.4:4.1",
      "pali": "“Na brāhmaṇo nomhi na rājaputto,"
    },
    {
      "id": "snp3.4:4.2",
      "pali": "Na vessāyano uda koci nomhi;"
    },
    {
      "id": "snp3.4:4.3",
      "pali": "Gottaṁ pariññāya puthujjanānaṁ,"
    },
    {
      "id": "snp3.4:4.4",
      "pali": "Akiñcano manta carāmi loke."
    },
    {
      "id": "snp3.4:5.1",
      "pali": "Saṅghāṭivāsī agaho carāmi,"
    },
    {
      "id": "snp3.4:5.2",
      "pali": "Nivuttakeso abhinibbutatto;"
    },
    {
      "id": "snp3.4:5.3",
      "pali": "Alippamāno idha māṇavehi,"
    },
    {
      "id": "snp3.4:5.4",
      "pali": "Akallaṁ maṁ brāhmaṇa pucchasi gottapañhaṁ”."
    },
    {
      "id": "snp3.4:6.1",
      "pali": "“Pucchanti ve bho brāhmaṇā brāhmaṇebhi,"
    },
    {
      "id": "snp3.4:6.2",
      "pali": "Saha brāhmaṇo no bhavan”ti."
    },
    {
      "id": "snp3.4:7.1",
      "pali": "“Brāhmaṇo hi ce tvaṁ brūsi,"
    },
    {
      "id": "snp3.4:7.2",
      "pali": "Mañca brūsi abrāhmaṇaṁ;"
    },
    {
      "id": "snp3.4:7.3",
      "pali": "Taṁ taṁ sāvittiṁ pucchāmi,"
    },
    {
      "id": "snp3.4:7.4",
      "pali": "Tipadaṁ catuvīsatakkharaṁ”."
    },
    {
      "id": "snp3.4:8.1",
      "pali": "“Kiṁ nissitā isayo manujā,"
    },
    {
      "id": "snp3.4:8.2",
      "pali": "Khattiyā brāhmaṇā devatānaṁ;"
    },
    {
      "id": "snp3.4:8.3",
      "pali": "Yaññamakappayiṁsu puthū idha loke”."
    },
    {
      "id": "snp3.4:9.1",
      "pali": "“Yadantagū vedagū yaññakāle,"
    },
    {
      "id": "snp3.4:9.2",
      "pali": "Yassāhutiṁ labhe tassijjheti brūmi”."
    },
    {
      "id": "snp3.4:10.1",
      "pali": "“Addhā hi tassa hutamijjhe,"
    },
    {
      "id": "snp3.4:10.2",
      "pali": "(iti brāhmaṇo)"
    },
    {
      "id": "snp3.4:10.3",
      "pali": "Yaṁ tādisaṁ vedagumaddasāma;"
    },
    {
      "id": "snp3.4:10.4",
      "pali": "Tumhādisānañhi adassanena,"
    },
    {
      "id": "snp3.4:10.5",
      "pali": "Añño jano bhuñjati pūraḷāsaṁ”."
    },
    {
      "id": "snp3.4:11.1",
      "pali": "“Tasmātiha tvaṁ brāhmaṇa atthena,"
    },
    {
      "id": "snp3.4:11.2",
      "pali": "Atthiko upasaṅkamma puccha;"
    },
    {
      "id": "snp3.4:11.3",
      "pali": "Santaṁ vidhūmaṁ anīghaṁ nirāsaṁ,"
    },
    {
      "id": "snp3.4:11.4",
      "pali": "Appevidha abhivinde sumedhaṁ”."
    },
    {
      "id": "snp3.4:12.1",
      "pali": "“Yaññe ratohaṁ bho gotama,"
    },
    {
      "id": "snp3.4:12.2",
      "pali": "Yaññaṁ yiṭṭhukāmo nāhaṁ pajānāmi;"
    },
    {
      "id": "snp3.4:12.3",
      "pali": "Anusāsatu maṁ bhavaṁ,"
    },
    {
      "id": "snp3.4:12.4",
      "pali": "Yattha hutaṁ ijjhate brūhi me taṁ”."
    },
    {
      "id": "snp3.4:13.1",
      "pali": "“Tena hi tvaṁ, brāhmaṇa, odahassu sotaṁ; dhammaṁ te desessāmi—"
    },
    {
      "id": "snp3.4:14.1",
      "pali": "Mā jātiṁ pucchī caraṇañca puccha,"
    },
    {
      "id": "snp3.4:14.2",
      "pali": "Kaṭṭhā have jāyati jātavedo;"
    },
    {
      "id": "snp3.4:14.3",
      "pali": "Nīcākulīnopi munī dhitīmā,"
    },
    {
      "id": "snp3.4:14.4",
      "pali": "Ājāniyo hoti hirīnisedho."
    },
    {
      "id": "snp3.4:15.1",
      "pali": "Saccena danto damasā upeto,"
    },
    {
      "id": "snp3.4:15.2",
      "pali": "Vedantagū vūsitabrahmacariyo;"
    },
    {
      "id": "snp3.4:15.3",
      "pali": "Kālena tamhi habyaṁ pavecche,"
    },
    {
      "id": "snp3.4:15.4",
      "pali": "Yo brāhmaṇo puññapekkho yajetha."
    },
    {
      "id": "snp3.4:16.1",
      "pali": "Ye kāme hitvā agahā caranti,"
    },
    {
      "id": "snp3.4:16.2",
      "pali": "Susaññatattā tasaraṁva ujjuṁ;"
    },
    {
      "id": "snp3.4:16.3",
      "pali": "Kālena tesu habyaṁ pavecche,"
    },
    {
      "id": "snp3.4:16.4",
      "pali": "Yo brāhmaṇo puññapekkho yajetha."
    },
    {
      "id": "snp3.4:17.1",
      "pali": "Ye vītarāgā susamāhitindriyā,"
    },
    {
      "id": "snp3.4:17.2",
      "pali": "Candova rāhuggahaṇā pamuttā;"
    },
    {
      "id": "snp3.4:17.3",
      "pali": "Kālena tesu habyaṁ pavecche,"
    },
    {
      "id": "snp3.4:17.4",
      "pali": "Yo brāhmaṇo puññapekkho yajetha."
    },
    {
      "id": "snp3.4:18.1",
      "pali": "Asajjamānā vicaranti loke,"
    },
    {
      "id": "snp3.4:18.2",
      "pali": "Sadā satā hitvā mamāyitāni;"
    },
    {
      "id": "snp3.4:18.3",
      "pali": "Kālena tesu habyaṁ pavecche,"
    },
    {
      "id": "snp3.4:18.4",
      "pali": "Yo brāhmaṇo puññapekkho yajetha."
    },
    {
      "id": "snp3.4:19.1",
      "pali": "Yo kāme hitvā abhibhuyyacārī,"
    },
    {
      "id": "snp3.4:19.2",
      "pali": "Yo vedi jātīmaraṇassa antaṁ;"
    },
    {
      "id": "snp3.4:19.3",
      "pali": "Parinibbuto udakarahadova sīto,"
    },
    {
      "id": "snp3.4:19.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:20.1",
      "pali": "Samo samehi visamehi dūre,"
    },
    {
      "id": "snp3.4:20.2",
      "pali": "Tathāgato hoti anantapañño;"
    },
    {
      "id": "snp3.4:20.3",
      "pali": "Anūpalitto idha vā huraṁ vā,"
    },
    {
      "id": "snp3.4:20.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:21.1",
      "pali": "Yamhi na māyā vasati na māno,"
    },
    {
      "id": "snp3.4:21.2",
      "pali": "Yo vītalobho amamo nirāso;"
    },
    {
      "id": "snp3.4:21.3",
      "pali": "Paṇunnakodho abhinibbutatto,"
    },
    {
      "id": "snp3.4:21.4",
      "pali": "Yo brāhmaṇo sokamalaṁ ahāsi;"
    },
    {
      "id": "snp3.4:21.5",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:22.1",
      "pali": "Nivesanaṁ yo manaso ahāsi,"
    },
    {
      "id": "snp3.4:22.2",
      "pali": "Pariggahā yassa na santi keci;"
    },
    {
      "id": "snp3.4:22.3",
      "pali": "Anupādiyāno idha vā huraṁ vā,"
    },
    {
      "id": "snp3.4:22.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:23.1",
      "pali": "Samāhito yo udatāri oghaṁ,"
    },
    {
      "id": "snp3.4:23.2",
      "pali": "Dhammaṁ caññāsi paramāya diṭṭhiyā;"
    },
    {
      "id": "snp3.4:23.3",
      "pali": "Khīṇāsavo antimadehadhārī,"
    },
    {
      "id": "snp3.4:23.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:24.1",
      "pali": "Bhavāsavā yassa vacī kharā ca,"
    },
    {
      "id": "snp3.4:24.2",
      "pali": "Vidhūpitā atthagatā na santi;"
    },
    {
      "id": "snp3.4:24.3",
      "pali": "Sa vedagū sabbadhi vippamutto,"
    },
    {
      "id": "snp3.4:24.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:25.1",
      "pali": "Saṅgātigo yassa na santi saṅgā,"
    },
    {
      "id": "snp3.4:25.2",
      "pali": "Yo mānasattesu amānasatto;"
    },
    {
      "id": "snp3.4:25.3",
      "pali": "Dukkhaṁ pariññāya sakhettavatthuṁ,"
    },
    {
      "id": "snp3.4:25.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:26.1",
      "pali": "Āsaṁ anissāya vivekadassī,"
    },
    {
      "id": "snp3.4:26.2",
      "pali": "Paravediyaṁ diṭṭhimupātivatto;"
    },
    {
      "id": "snp3.4:26.3",
      "pali": "Ārammaṇā yassa na santi keci,"
    },
    {
      "id": "snp3.4:26.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:27.1",
      "pali": "Paroparā yassa samecca dhammā,"
    },
    {
      "id": "snp3.4:27.2",
      "pali": "Vidhūpitā atthagatā na santi;"
    },
    {
      "id": "snp3.4:27.3",
      "pali": "Santo upādānakhaye vimutto,"
    },
    {
      "id": "snp3.4:27.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:28.1",
      "pali": "Saṁyojanaṁ jātikhayantadassī,"
    },
    {
      "id": "snp3.4:28.2",
      "pali": "Yopānudi rāgapathaṁ asesaṁ;"
    },
    {
      "id": "snp3.4:28.3",
      "pali": "Suddho nidoso vimalo akāco,"
    },
    {
      "id": "snp3.4:28.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:29.1",
      "pali": "Yo attano attānaṁ nānupassati,"
    },
    {
      "id": "snp3.4:29.2",
      "pali": "Samāhito ujjugato ṭhitatto;"
    },
    {
      "id": "snp3.4:29.3",
      "pali": "Sa ve anejo akhilo akaṅkho,"
    },
    {
      "id": "snp3.4:29.4",
      "pali": "Tathāgato arahati pūraḷāsaṁ."
    },
    {
      "id": "snp3.4:30.1",
      "pali": "Mohantarā yassa na santi keci,"
    },
    {
      "id": "snp3.4:30.2",
      "pali": "Sabbesu dhammesu ca ñāṇadassī;"
    },
    {
      "id": "snp3.4:30.3",
      "pali": "Sarīrañca antimaṁ dhāreti,"
    },
    {
      "id": "snp3.4:30.4",
      "pali": "Patto ca sambodhimanuttaraṁ sivaṁ;"
    },
    {
      "id": "snp3.4:30.5",
      "pali": "Ettāvatā yakkhassa suddhi,"
    },
    {
      "id": "snp3.4:30.6",
      "pali": "Tathāgato arahati pūraḷāsaṁ”."
    },
    {
      "id": "snp3.4:31.1",
      "pali": "“Hutañca mayhaṁ hutamatthu saccaṁ,"
    },
    {
      "id": "snp3.4:31.2",
      "pali": "Yaṁ tādisaṁ vedagunaṁ alatthaṁ;"
    },
    {
      "id": "snp3.4:31.3",
      "pali": "Brahmā hi sakkhi paṭigaṇhātu me bhagavā,"
    },
    {
      "id": "snp3.4:31.4",
      "pali": "Bhuñjatu me bhagavā pūraḷāsaṁ”."
    },
    {
      "id": "snp3.4:32.1",
      "pali": "“Gāthābhigītaṁ me abhojaneyyaṁ,"
    },
    {
      "id": "snp3.4:32.2",
      "pali": "Sampassataṁ brāhmaṇa nesa dhammo;"
    },
    {
      "id": "snp3.4:32.3",
      "pali": "Gāthābhigītaṁ panudanti buddhā,"
    },
    {
      "id": "snp3.4:32.4",
      "pali": "Dhamme satī brāhmaṇa vuttiresā."
    },
    {
      "id": "snp3.4:33.1",
      "pali": "Aññena ca kevalinaṁ mahesiṁ,"
    },
    {
      "id": "snp3.4:33.2",
      "pali": "Khīṇāsavaṁ kukkuccavūpasantaṁ;"
    },
    {
      "id": "snp3.4:33.3",
      "pali": "Annena pānena upaṭṭhahassu,"
    },
    {
      "id": "snp3.4:33.4",
      "pali": "Khettañhi taṁ puññapekkhassa hoti”."
    },
    {
      "id": "snp3.4:34.1",
      "pali": "“Sādhāhaṁ bhagavā tathā vijaññaṁ,"
    },
    {
      "id": "snp3.4:34.2",
      "pali": "Yo dakkhiṇaṁ bhuñjeyya mādisassa;"
    },
    {
      "id": "snp3.4:34.3",
      "pali": "Yaṁ yaññakāle pariyesamāno,"
    },
    {
      "id": "snp3.4:34.4",
      "pali": "Pappuyya tava sāsanaṁ”."
    },
    {
      "id": "snp3.4:35.1",
      "pali": "“Sārambhā yassa vigatā,"
    },
    {
      "id": "snp3.4:35.2",
      "pali": "Cittaṁ yassa anāvilaṁ;"
    },
    {
      "id": "snp3.4:35.3",
      "pali": "Vippamutto ca kāmehi,"
    },
    {
      "id": "snp3.4:35.4",
      "pali": "Thinaṁ yassa panūditaṁ."
    },
    {
      "id": "snp3.4:36.1",
      "pali": "Sīmantānaṁ vinetāraṁ,"
    },
    {
      "id": "snp3.4:36.2",
      "pali": "Jātimaraṇakovidaṁ;"
    },
    {
      "id": "snp3.4:36.3",
      "pali": "Muniṁ moneyyasampannaṁ,"
    },
    {
      "id": "snp3.4:36.4",
      "pali": "Tādisaṁ yaññamāgataṁ."
    },
    {
      "id": "snp3.4:37.1",
      "pali": "Bhakuṭiṁ vinayitvāna,"
    },
    {
      "id": "snp3.4:37.2",
      "pali": "Pañjalikā namassatha;"
    },
    {
      "id": "snp3.4:37.3",
      "pali": "Pūjetha annapānena,"
    },
    {
      "id": "snp3.4:37.4",
      "pali": "Evaṁ ijjhanti dakkhiṇā”."
    },
    {
      "id": "snp3.4:38.1",
      "pali": "“Buddho bhavaṁ arahati pūraḷāsaṁ,"
    },
    {
      "id": "snp3.4:38.2",
      "pali": "Puññakhettamanuttaraṁ;"
    },
    {
      "id": "snp3.4:38.3",
      "pali": "Āyāgo sabbalokassa,"
    },
    {
      "id": "snp3.4:38.4",
      "pali": "Bhoto dinnaṁ mahapphalan”ti."
    },
    {
      "id": "snp3.4:39.1",
      "pali": "Atha kho sundarikabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "snp3.4:39.2",
      "pali": "“abhikkantaṁ, bho gotama, abhikkantaṁ, bho gotama."
    },
    {
      "id": "snp3.4:39.3",
      "pali": "Seyyathāpi, bho gotama, nikkujjitaṁ vā ukkujjeyya, paṭicchannaṁ vā vivareyya, mūḷhassa vā maggaṁ ācikkheyya, andhakāre vā telapajjotaṁ dhāreyya: ‘cakkhumanto rūpāni dakkhantī’ti; evamevaṁ bhotā gotamena anekapariyāyena dhammo pakāsito."
    },
    {
      "id": "snp3.4:39.4",
      "pali": "Esāhaṁ bhavantaṁ gotamaṁ saraṇaṁ gacchāmi dhammañca bhikkhusaṅghañca."
    },
    {
      "id": "snp3.4:39.5",
      "pali": "Labheyyāhaṁ bhoto gotamassa santike pabbajjaṁ, labheyyaṁ upasampadan”ti."
    },
    {
      "id": "snp3.4:39.6",
      "pali": "Alattha kho sundarikabhāradvājo brāhmaṇo …pe…"
    },
    {
      "id": "snp3.4:39.7",
      "pali": "arahataṁ ahosīti."
    },
    {
      "id": "snp3.4:39.8",
      "pali": "Sundarikabhāradvājasuttaṁ catutthaṁ."
    }
  ]
}
