{
  "uid": "sn7.7",
  "title": "Suddhikasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.7:1.2",
      "pali": "Atha kho suddhikabhāradvājo brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.7:1.3",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi."
    },
    {
      "id": "sn7.7:1.4",
      "pali": "Ekamantaṁ nisinno kho suddhikabhāradvājo brāhmaṇo bhagavato santike imaṁ gāthaṁ ajjhabhāsi:"
    },
    {
      "id": "sn7.7:2.1",
      "pali": "“Na brāhmaṇo sujjhati koci,"
    },
    {
      "id": "sn7.7:2.2",
      "pali": "Loke sīlavāpi tapokaraṁ;"
    },
    {
      "id": "sn7.7:2.3",
      "pali": "Vijjācaraṇasampanno,"
    },
    {
      "id": "sn7.7:2.4",
      "pali": "So sujjhati na aññā itarā pajā”ti."
    },
    {
      "id": "sn7.7:3.1",
      "pali": "“Bahumpi palapaṁ jappaṁ,"
    },
    {
      "id": "sn7.7:3.2",
      "pali": "na jaccā hoti brāhmaṇo;"
    },
    {
      "id": "sn7.7:3.3",
      "pali": "Antokasambu saṅkiliṭṭho,"
    },
    {
      "id": "sn7.7:3.4",
      "pali": "kuhanaṁ upanissito."
    },
    {
      "id": "sn7.7:4.1",
      "pali": "Khattiyo brāhmaṇo vesso,"
    },
    {
      "id": "sn7.7:4.2",
      "pali": "Suddo caṇḍālapukkuso;"
    },
    {
      "id": "sn7.7:4.3",
      "pali": "Āraddhavīriyo pahitatto,"
    },
    {
      "id": "sn7.7:4.4",
      "pali": "Niccaṁ daḷhaparakkamo;"
    },
    {
      "id": "sn7.7:4.5",
      "pali": "Pappoti paramaṁ suddhiṁ,"
    },
    {
      "id": "sn7.7:4.6",
      "pali": "Evaṁ jānāhi brāhmaṇā”ti."
    },
    {
      "id": "sn7.7:5.1",
      "pali": "Evaṁ vutte, suddhikabhāradvājo brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.7:5.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.7:5.3",
      "pali": "aññataro ca panāyasmā bhāradvājo arahataṁ ahosīti."
    }
  ]
}
