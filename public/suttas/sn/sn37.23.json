{
  "uid": "sn37.23",
  "title": "Upaṭṭhitassatisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn37.23:1.1",
      "pali": "“Upaṭṭhitassati ca hoti, paññavā ca hoti …pe…"
    },
    {
      "id": "sn37.23:1.2",
      "pali": "imehi kho, anuruddha, pañcahi dhammehi samannāgato mātugāmo kāyassa bhedā paraṁ maraṇā sugatiṁ saggaṁ lokaṁ upapajjatī”ti."
    },
    {
      "id": "sn37.23:1.3",
      "pali": "Navamaṁ."
    },
    {
      "id": "sn37.23:2.1",
      "pali": "Ime aṭṭha suttantasaṅkhepā."
    }
  ]
}
