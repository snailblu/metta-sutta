{
  "uid": "snp3.1",
  "title": "Pabbajjāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp3.1:1.1",
      "pali": "“Pabbajjaṁ kittayissāmi,"
    },
    {
      "id": "snp3.1:1.2",
      "pali": "yathā pabbaji cakkhumā;"
    },
    {
      "id": "snp3.1:1.3",
      "pali": "Yathā vīmaṁsamāno so,"
    },
    {
      "id": "snp3.1:1.4",
      "pali": "pabbajjaṁ samarocayi."
    },
    {
      "id": "snp3.1:2.1",
      "pali": "Sambādhoyaṁ gharāvāso,"
    },
    {
      "id": "snp3.1:2.2",
      "pali": "rajassāyatanaṁ iti;"
    },
    {
      "id": "snp3.1:2.3",
      "pali": "Abbhokāsova pabbajjā,"
    },
    {
      "id": "snp3.1:2.4",
      "pali": "iti disvāna pabbaji."
    },
    {
      "id": "snp3.1:3.1",
      "pali": "Pabbajitvāna kāyena,"
    },
    {
      "id": "snp3.1:3.2",
      "pali": "pāpakammaṁ vivajjayi;"
    },
    {
      "id": "snp3.1:3.3",
      "pali": "Vacīduccaritaṁ hitvā,"
    },
    {
      "id": "snp3.1:3.4",
      "pali": "ājīvaṁ parisodhayi."
    },
    {
      "id": "snp3.1:4.1",
      "pali": "Agamā rājagahaṁ buddho,"
    },
    {
      "id": "snp3.1:4.2",
      "pali": "magadhānaṁ giribbajaṁ;"
    },
    {
      "id": "snp3.1:4.3",
      "pali": "Piṇḍāya abhihāresi,"
    },
    {
      "id": "snp3.1:4.4",
      "pali": "ākiṇṇavaralakkhaṇo”."
    },
    {
      "id": "snp3.1:5.1",
      "pali": "Tamaddasā bimbisāro,"
    },
    {
      "id": "snp3.1:5.2",
      "pali": "pāsādasmiṁ patiṭṭhito;"
    },
    {
      "id": "snp3.1:5.3",
      "pali": "Disvā lakkhaṇasampannaṁ,"
    },
    {
      "id": "snp3.1:5.4",
      "pali": "imamatthaṁ abhāsatha."
    },
    {
      "id": "snp3.1:6.1",
      "pali": "“Imaṁ bhonto nisāmetha,"
    },
    {
      "id": "snp3.1:6.2",
      "pali": "abhirūpo brahā suci;"
    },
    {
      "id": "snp3.1:6.3",
      "pali": "Caraṇena ca sampanno,"
    },
    {
      "id": "snp3.1:6.4",
      "pali": "yugamattañca pekkhati."
    },
    {
      "id": "snp3.1:7.1",
      "pali": "Okkhittacakkhu satimā,"
    },
    {
      "id": "snp3.1:7.2",
      "pali": "nāyaṁ nīcakulāmiva;"
    },
    {
      "id": "snp3.1:7.3",
      "pali": "Rājadūtābhidhāvantu,"
    },
    {
      "id": "snp3.1:7.4",
      "pali": "kuhiṁ bhikkhu gamissati”."
    },
    {
      "id": "snp3.1:8.1",
      "pali": "Te pesitā rājadūtā,"
    },
    {
      "id": "snp3.1:8.2",
      "pali": "piṭṭhito anubandhisuṁ;"
    },
    {
      "id": "snp3.1:8.3",
      "pali": "Kuhiṁ gamissati bhikkhu,"
    },
    {
      "id": "snp3.1:8.4",
      "pali": "kattha vāso bhavissati."
    },
    {
      "id": "snp3.1:9.1",
      "pali": "Sapadānaṁ caramāno,"
    },
    {
      "id": "snp3.1:9.2",
      "pali": "guttadvāro susaṁvuto;"
    },
    {
      "id": "snp3.1:9.3",
      "pali": "Khippaṁ pattaṁ apūresi,"
    },
    {
      "id": "snp3.1:9.4",
      "pali": "sampajāno paṭissato."
    },
    {
      "id": "snp3.1:10.1",
      "pali": "Piṇḍacāraṁ caritvāna,"
    },
    {
      "id": "snp3.1:10.2",
      "pali": "Nikkhamma nagarā muni;"
    },
    {
      "id": "snp3.1:10.3",
      "pali": "Paṇḍavaṁ abhihāresi,"
    },
    {
      "id": "snp3.1:10.4",
      "pali": "Ettha vāso bhavissati."
    },
    {
      "id": "snp3.1:11.1",
      "pali": "Disvāna vāsūpagataṁ,"
    },
    {
      "id": "snp3.1:11.2",
      "pali": "Tayo dūtā upāvisuṁ;"
    },
    {
      "id": "snp3.1:11.3",
      "pali": "Tesu ekova āgantvā,"
    },
    {
      "id": "snp3.1:11.4",
      "pali": "Rājino paṭivedayi."
    },
    {
      "id": "snp3.1:12.1",
      "pali": "“Esa bhikkhu mahārāja,"
    },
    {
      "id": "snp3.1:12.2",
      "pali": "Paṇḍavassa puratthato;"
    },
    {
      "id": "snp3.1:12.3",
      "pali": "Nisinno byagghusabhova,"
    },
    {
      "id": "snp3.1:12.4",
      "pali": "Sīhova girigabbhare”."
    },
    {
      "id": "snp3.1:13.1",
      "pali": "Sutvāna dūtavacanaṁ,"
    },
    {
      "id": "snp3.1:13.2",
      "pali": "Bhaddayānena khattiyo;"
    },
    {
      "id": "snp3.1:13.3",
      "pali": "Taramānarūpo niyyāsi,"
    },
    {
      "id": "snp3.1:13.4",
      "pali": "Yena paṇḍavapabbato."
    },
    {
      "id": "snp3.1:14.1",
      "pali": "Sa yānabhūmiṁ yāyitvā,"
    },
    {
      "id": "snp3.1:14.2",
      "pali": "Yānā oruyha khattiyo;"
    },
    {
      "id": "snp3.1:14.3",
      "pali": "Pattiko upasaṅkamma,"
    },
    {
      "id": "snp3.1:14.4",
      "pali": "Āsajja naṁ upāvisi."
    },
    {
      "id": "snp3.1:15.1",
      "pali": "Nisajja rājā sammodi,"
    },
    {
      "id": "snp3.1:15.2",
      "pali": "Kathaṁ sāraṇīyaṁ tato;"
    },
    {
      "id": "snp3.1:15.3",
      "pali": "Kathaṁ so vītisāretvā,"
    },
    {
      "id": "snp3.1:15.4",
      "pali": "Imamatthaṁ abhāsatha."
    },
    {
      "id": "snp3.1:16.1",
      "pali": "“Yuvā ca daharo cāsi,"
    },
    {
      "id": "snp3.1:16.2",
      "pali": "Paṭhamuppattiko susu;"
    },
    {
      "id": "snp3.1:16.3",
      "pali": "Vaṇṇārohena sampanno,"
    },
    {
      "id": "snp3.1:16.4",
      "pali": "Jātimā viya khattiyo."
    },
    {
      "id": "snp3.1:17.1",
      "pali": "Sobhayanto anīkaggaṁ,"
    },
    {
      "id": "snp3.1:17.2",
      "pali": "Nāgasaṅghapurakkhato;"
    },
    {
      "id": "snp3.1:17.3",
      "pali": "Dadāmi bhoge bhuñjassu,"
    },
    {
      "id": "snp3.1:17.4",
      "pali": "Jātiṁ akkhāhi pucchito”."
    },
    {
      "id": "snp3.1:18.1",
      "pali": "“Ujuṁ janapado rāja,"
    },
    {
      "id": "snp3.1:18.2",
      "pali": "Himavantassa passato;"
    },
    {
      "id": "snp3.1:18.3",
      "pali": "Dhanaviriyena sampanno,"
    },
    {
      "id": "snp3.1:18.4",
      "pali": "Kosalesu niketino."
    },
    {
      "id": "snp3.1:19.1",
      "pali": "Ādiccā nāma gottena,"
    },
    {
      "id": "snp3.1:19.2",
      "pali": "Sākiyā nāma jātiyā;"
    },
    {
      "id": "snp3.1:19.3",
      "pali": "Tamhā kulā pabbajitomhi,"
    },
    {
      "id": "snp3.1:19.4",
      "pali": "Na kāme abhipatthayaṁ."
    },
    {
      "id": "snp3.1:20.1",
      "pali": "Kāmesvādīnavaṁ disvā,"
    },
    {
      "id": "snp3.1:20.2",
      "pali": "Nekkhammaṁ daṭṭhu khemato;"
    },
    {
      "id": "snp3.1:20.3",
      "pali": "Padhānāya gamissāmi,"
    },
    {
      "id": "snp3.1:20.4",
      "pali": "Ettha me rañjatī mano”ti."
    },
    {
      "id": "snp3.1:20.5",
      "pali": "Pabbajjāsuttaṁ paṭhamaṁ."
    }
  ]
}
