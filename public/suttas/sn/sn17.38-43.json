{
  "uid": "sn17.38-43",
  "title": "Pitusuttādichakka",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.38-43:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.38-43:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko kaṭuko pharuso antarāyiko anuttarassa yogakkhemassa adhigamāya."
    },
    {
      "id": "sn17.38-43:1.3",
      "pali": "Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ evaṁ cetasā ceto paricca pajānāmi:"
    },
    {
      "id": "sn17.38-43:1.4",
      "pali": "‘na cāyamāyasmā pitupi hetu …pe…"
    },
    {
      "id": "sn17.38-43:1.5",
      "pali": "(vitthāretabbaṁ) …"
    },
    {
      "id": "sn17.38-43:1.6",
      "pali": "bhātupi hetu …"
    },
    {
      "id": "sn17.38-43:1.7",
      "pali": "bhaginiyāpi hetu …"
    },
    {
      "id": "sn17.38-43:1.8",
      "pali": "puttassapi hetu …"
    },
    {
      "id": "sn17.38-43:1.9",
      "pali": "dhītuyāpi hetu …"
    },
    {
      "id": "sn17.38-43:1.10",
      "pali": "pajāpatiyāpi hetu sampajānamusā bhāseyyā’ti."
    },
    {
      "id": "sn17.38-43:1.11",
      "pali": "Tamenaṁ passāmi aparena samayena lābhasakkārasilokena abhibhūtaṁ pariyādiṇṇacittaṁ sampajānamusā bhāsantaṁ."
    },
    {
      "id": "sn17.38-43:1.12",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko kaṭuko pharuso antarāyiko anuttarassa yogakkhemassa adhigamāya."
    },
    {
      "id": "sn17.38-43:1.13",
      "pali": "Tasmātiha, bhikkhave, evaṁ sikkhitabbaṁ:"
    },
    {
      "id": "sn17.38-43:1.14",
      "pali": "‘uppannaṁ lābhasakkārasilokaṁ pajahissāma, na ca no uppanno lābhasakkārasiloko cittaṁ pariyādāya ṭhassatī’ti."
    },
    {
      "id": "sn17.38-43:1.15",
      "pali": "Evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.38-43:1.16",
      "pali": "Terasamaṁ."
    },
    {
      "id": "sn17.38-43:1.17",
      "pali": "Catuttho vaggo."
    },
    {
      "id": "sn17.38-43:2.1",
      "pali": "Bhindi mūlaṁ duve dhammā,"
    },
    {
      "id": "sn17.38-43:2.2",
      "pali": "pakkantaṁ ratha mātari;"
    },
    {
      "id": "sn17.38-43:2.3",
      "pali": "Pitā bhātā ca bhaginī,"
    },
    {
      "id": "sn17.38-43:2.4",
      "pali": "putto dhītā pajāpatīti."
    },
    {
      "id": "sn17.38-43:2.5",
      "pali": "Lābhasakkārasaṁyuttaṁ samattaṁ."
    }
  ]
}
