{
  "uid": "sn21.5",
  "title": "Sujātasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn21.5:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn21.5:1.2",
      "pali": "Atha kho āyasmā sujāto yena bhagavā tenupasaṅkami."
    },
    {
      "id": "sn21.5:1.3",
      "pali": "Addasā kho bhagavā āyasmantaṁ sujātaṁ dūratova āgacchantaṁ."
    },
    {
      "id": "sn21.5:1.4",
      "pali": "Disvāna bhikkhū āmantesi:"
    },
    {
      "id": "sn21.5:1.5",
      "pali": "“ubhayenevāyaṁ, bhikkhave, kulaputto sobhati—"
    },
    {
      "id": "sn21.5:1.6",
      "pali": "yañca abhirūpo dassanīyo pāsādiko paramāya vaṇṇapokkharatāya samannāgato, yassa catthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti tadanuttaraṁ brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja viharatī”ti."
    },
    {
      "id": "sn21.5:1.7",
      "pali": "Idamavoca bhagavā …pe…"
    },
    {
      "id": "sn21.5:1.8",
      "pali": "satthā:"
    },
    {
      "id": "sn21.5:2.1",
      "pali": "“Sobhati vatāyaṁ bhikkhu,"
    },
    {
      "id": "sn21.5:2.2",
      "pali": "ujubhūtena cetasā;"
    },
    {
      "id": "sn21.5:2.3",
      "pali": "Vippayutto visaṁyutto,"
    },
    {
      "id": "sn21.5:2.4",
      "pali": "anupādāya nibbuto;"
    },
    {
      "id": "sn21.5:2.5",
      "pali": "Dhāreti antimaṁ dehaṁ,"
    },
    {
      "id": "sn21.5:2.6",
      "pali": "jetvā māraṁ savāhinin”ti."
    },
    {
      "id": "sn21.5:2.7",
      "pali": "Pañcamaṁ."
    }
  ]
}
