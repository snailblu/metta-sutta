{
  "uid": "sn18.3",
  "title": "Viññāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn18.3:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn18.3:1.2",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "sn18.3:1.3",
      "pali": "cakkhuviññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.3:1.4",
      "pali": "“Aniccaṁ, bhante” …"
    },
    {
      "id": "sn18.3:1.5",
      "pali": "“sotaviññāṇaṁ …pe…"
    },
    {
      "id": "sn18.3:1.6",
      "pali": "ghānaviññāṇaṁ …"
    },
    {
      "id": "sn18.3:1.7",
      "pali": "jivhāviññāṇaṁ …"
    },
    {
      "id": "sn18.3:1.8",
      "pali": "kāyaviññāṇaṁ …"
    },
    {
      "id": "sn18.3:1.9",
      "pali": "manoviññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn18.3:1.10",
      "pali": "“Aniccaṁ, bhante” …"
    },
    {
      "id": "sn18.3:1.11",
      "pali": "“evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhuviññāṇasmimpi nibbindati …pe… sotaviññāṇasmimpi nibbindati … ghānaviññāṇasmimpi nibbindati … jivhāviññāṇasmimpi nibbindati … kāyaviññāṇasmimpi nibbindati … manoviññāṇasmimpi nibbindati;"
    },
    {
      "id": "sn18.3:1.12",
      "pali": "nibbindaṁ virajjati …pe…"
    },
    {
      "id": "sn18.3:1.13",
      "pali": "pajānātī”ti."
    },
    {
      "id": "sn18.3:1.14",
      "pali": "Tatiyaṁ."
    }
  ]
}
