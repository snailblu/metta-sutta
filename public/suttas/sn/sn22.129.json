{
  "uid": "sn22.129",
  "title": "Assādasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.129:1.1",
      "pali": "Bārāṇasiyaṁ viharanti isipatane migadāye …pe…"
    },
    {
      "id": "sn22.129:1.2",
      "pali": "ekamantaṁ nisinno kho āyasmā mahākoṭṭhiko āyasmantaṁ sāriputtaṁ etadavoca:"
    },
    {
      "id": "sn22.129:1.3",
      "pali": "“‘avijjā, avijjā’ti, āvuso sāriputta, vuccati."
    },
    {
      "id": "sn22.129:1.4",
      "pali": "Katamā nu kho, āvuso, avijjā;"
    },
    {
      "id": "sn22.129:1.5",
      "pali": "kittāvatā ca avijjāgato hotī”ti?"
    },
    {
      "id": "sn22.129:2.1",
      "pali": "“Idhāvuso assutavā puthujjano rūpassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.129:2.2",
      "pali": "Vedanāya …pe…"
    },
    {
      "id": "sn22.129:2.3",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.129:2.4",
      "pali": "saṅkhārānaṁ …"
    },
    {
      "id": "sn22.129:2.5",
      "pali": "viññāṇassa assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānāti."
    },
    {
      "id": "sn22.129:2.6",
      "pali": "Ayaṁ vuccatāvuso, avijjā;"
    },
    {
      "id": "sn22.129:2.7",
      "pali": "ettāvatā ca avijjāgato hotī”ti."
    },
    {
      "id": "sn22.129:2.8",
      "pali": "Catutthaṁ."
    }
  ]
}
