{
  "uid": "sn22.29",
  "title": "Abhinandanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.29:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.29:1.2",
      "pali": "“Yo, bhikkhave, rūpaṁ abhinandati, dukkhaṁ so abhinandati."
    },
    {
      "id": "sn22.29:1.3",
      "pali": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn22.29:1.4",
      "pali": "Yo vedanaṁ abhinandati …"
    },
    {
      "id": "sn22.29:1.5",
      "pali": "yo saññaṁ abhinandati …"
    },
    {
      "id": "sn22.29:1.6",
      "pali": "yo saṅkhāre abhinandati …"
    },
    {
      "id": "sn22.29:1.7",
      "pali": "yo viññāṇaṁ abhinandati, dukkhaṁ so abhinandati."
    },
    {
      "id": "sn22.29:1.8",
      "pali": "Yo dukkhaṁ abhinandati, ‘aparimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn22.29:1.9",
      "pali": "Yo ca kho, bhikkhave, rūpaṁ nābhinandati, dukkhaṁ so nābhinandati."
    },
    {
      "id": "sn22.29:1.10",
      "pali": "Yo dukkhaṁ nābhinandati, ‘parimutto so dukkhasmā’ti vadāmi."
    },
    {
      "id": "sn22.29:1.11",
      "pali": "Yo vedanaṁ nābhinandati …"
    },
    {
      "id": "sn22.29:1.12",
      "pali": "yo saññaṁ nābhinandati …"
    },
    {
      "id": "sn22.29:1.13",
      "pali": "yo saṅkhāre nābhinandati …"
    },
    {
      "id": "sn22.29:1.14",
      "pali": "yo viññāṇaṁ nābhinandati, dukkhaṁ so nābhinandati."
    },
    {
      "id": "sn22.29:1.15",
      "pali": "Yo dukkhaṁ nābhinandati, ‘parimutto so dukkhasmā’ti vadāmī”ti."
    },
    {
      "id": "sn22.29:1.16",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
