{
  "uid": "sn4.1",
  "title": "Tapokammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre ajapālanigrodhamūle paṭhamābhisambuddho."
    },
    {
      "id": "sn4.1:1.3",
      "pali": "Atha kho bhagavato rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "sn4.1:1.4",
      "pali": "“mutto vatamhi tāya dukkarakārikāya."
    },
    {
      "id": "sn4.1:1.5",
      "pali": "Sādhu mutto vatamhi tāya anatthasaṁhitāya dukkarakārikāya."
    },
    {
      "id": "sn4.1:1.6",
      "pali": "Sādhu vatamhi mutto bodhiṁ samajjhagan”ti."
    },
    {
      "id": "sn4.1:2.1",
      "pali": "Atha kho māro pāpimā bhagavato cetasā cetoparivitakkamaññāya yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.1:3.1",
      "pali": "“Tapokammā apakkamma,"
    },
    {
      "id": "sn4.1:3.2",
      "pali": "yena sujjhanti māṇavā;"
    },
    {
      "id": "sn4.1:3.3",
      "pali": "Asuddho maññasi suddho,"
    },
    {
      "id": "sn4.1:3.4",
      "pali": "suddhimaggā aparaddho”ti."
    },
    {
      "id": "sn4.1:4.1",
      "pali": "Atha kho bhagavā “māro ayaṁ pāpimā” iti viditvā māraṁ pāpimantaṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn4.1:5.1",
      "pali": "“Anatthasaṁhitaṁ ñatvā,"
    },
    {
      "id": "sn4.1:5.2",
      "pali": "yaṁ kiñci amaraṁ tapaṁ;"
    },
    {
      "id": "sn4.1:5.3",
      "pali": "Sabbaṁ natthāvahaṁ hoti,"
    },
    {
      "id": "sn4.1:5.4",
      "pali": "phiyārittaṁva dhammani."
    },
    {
      "id": "sn4.1:6.1",
      "pali": "Sīlaṁ samādhi paññañca,"
    },
    {
      "id": "sn4.1:6.2",
      "pali": "Maggaṁ bodhāya bhāvayaṁ;"
    },
    {
      "id": "sn4.1:6.3",
      "pali": "Pattosmi paramaṁ suddhiṁ,"
    },
    {
      "id": "sn4.1:6.4",
      "pali": "Nihato tvamasi antakā”ti."
    },
    {
      "id": "sn4.1:7.1",
      "pali": "Atha kho māro pāpimā “jānāti maṁ bhagavā, jānāti maṁ sugato”ti, dukkhī dummano tatthevantaradhāyīti."
    }
  ]
}
