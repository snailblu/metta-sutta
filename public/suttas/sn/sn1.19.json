{
  "uid": "sn1.19",
  "title": "Kuṭikāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.19:1.1",
      "pali": "“Kacci te kuṭikā natthi,"
    },
    {
      "id": "sn1.19:1.2",
      "pali": "kacci natthi kulāvakā;"
    },
    {
      "id": "sn1.19:1.3",
      "pali": "Kacci santānakā natthi,"
    },
    {
      "id": "sn1.19:1.4",
      "pali": "kacci muttosi bandhanā”ti."
    },
    {
      "id": "sn1.19:2.1",
      "pali": "“Taggha me kuṭikā natthi,"
    },
    {
      "id": "sn1.19:2.2",
      "pali": "taggha natthi kulāvakā;"
    },
    {
      "id": "sn1.19:2.3",
      "pali": "Taggha santānakā natthi,"
    },
    {
      "id": "sn1.19:2.4",
      "pali": "taggha muttomhi bandhanā”ti."
    },
    {
      "id": "sn1.19:3.1",
      "pali": "“Kintāhaṁ kuṭikaṁ brūmi,"
    },
    {
      "id": "sn1.19:3.2",
      "pali": "kiṁ te brūmi kulāvakaṁ;"
    },
    {
      "id": "sn1.19:3.3",
      "pali": "Kiṁ te santānakaṁ brūmi,"
    },
    {
      "id": "sn1.19:3.4",
      "pali": "kintāhaṁ brūmi bandhanan”ti."
    },
    {
      "id": "sn1.19:4.1",
      "pali": "“Mātaraṁ kuṭikaṁ brūsi,"
    },
    {
      "id": "sn1.19:4.2",
      "pali": "bhariyaṁ brūsi kulāvakaṁ;"
    },
    {
      "id": "sn1.19:4.3",
      "pali": "Putte santānake brūsi,"
    },
    {
      "id": "sn1.19:4.4",
      "pali": "taṇhaṁ me brūsi bandhanan”ti."
    },
    {
      "id": "sn1.19:5.1",
      "pali": "“Sāhu te kuṭikā natthi,"
    },
    {
      "id": "sn1.19:5.2",
      "pali": "sāhu natthi kulāvakā;"
    },
    {
      "id": "sn1.19:5.3",
      "pali": "Sāhu santānakā natthi,"
    },
    {
      "id": "sn1.19:5.4",
      "pali": "sāhu muttosi bandhanā”ti."
    }
  ]
}
