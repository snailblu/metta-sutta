{
  "uid": "sn1.67",
  "title": "Uḍḍitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.67:1.1",
      "pali": "“Kenassu uḍḍito loko,"
    },
    {
      "id": "sn1.67:1.2",
      "pali": "kenassu parivārito;"
    },
    {
      "id": "sn1.67:1.3",
      "pali": "Kenassu pihito loko,"
    },
    {
      "id": "sn1.67:1.4",
      "pali": "kismiṁ loko patiṭṭhito”ti."
    },
    {
      "id": "sn1.67:2.1",
      "pali": "“Taṇhāya uḍḍito loko,"
    },
    {
      "id": "sn1.67:2.2",
      "pali": "jarāya parivārito;"
    },
    {
      "id": "sn1.67:2.3",
      "pali": "Maccunā pihito loko,"
    },
    {
      "id": "sn1.67:2.4",
      "pali": "dukkhe loko patiṭṭhito”ti."
    }
  ]
}
