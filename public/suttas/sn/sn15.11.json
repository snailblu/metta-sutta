{
  "uid": "sn15.11",
  "title": "Duggatasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.11:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati."
    },
    {
      "id": "sn15.11:1.2",
      "pali": "Tatra kho …pe…"
    },
    {
      "id": "sn15.11:1.3",
      "pali": "“Anamataggoyaṁ, bhikkhave, saṁsāro."
    },
    {
      "id": "sn15.11:1.4",
      "pali": "Pubbā koṭi na paññāyati avijjānīvaraṇānaṁ sattānaṁ taṇhāsaṁyojanānaṁ sandhāvataṁ saṁsarataṁ."
    },
    {
      "id": "sn15.11:1.5",
      "pali": "Yaṁ, bhikkhave, passeyyātha duggataṁ durūpetaṁ niṭṭhamettha gantabbaṁ:"
    },
    {
      "id": "sn15.11:1.6",
      "pali": "‘amhehipi evarūpaṁ paccanubhūtaṁ iminā dīghena addhunā’ti."
    },
    {
      "id": "sn15.11:1.7",
      "pali": "Taṁ kissa hetu …pe…"
    },
    {
      "id": "sn15.11:1.8",
      "pali": "yāvañcidaṁ, bhikkhave, alameva sabbasaṅkhāresu nibbindituṁ alaṁ virajjituṁ alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.11:1.9",
      "pali": "Paṭhamaṁ."
    }
  ]
}
