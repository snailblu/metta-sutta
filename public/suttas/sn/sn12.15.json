{
  "uid": "sn12.15",
  "title": "Kaccānagottasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.15:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.15:1.2",
      "pali": "Atha kho āyasmā kaccānagotto yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā kaccānagotto bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn12.15:1.3",
      "pali": "“‘sammādiṭṭhi sammādiṭṭhī’ti, bhante, vuccati."
    },
    {
      "id": "sn12.15:1.4",
      "pali": "Kittāvatā nu kho, bhante, sammādiṭṭhi hotī”ti?"
    },
    {
      "id": "sn12.15:2.1",
      "pali": "“Dvayanissito khvāyaṁ, kaccāna, loko yebhuyyena—atthitañceva natthitañca."
    },
    {
      "id": "sn12.15:2.2",
      "pali": "Lokasamudayaṁ kho, kaccāna, yathābhūtaṁ sammappaññāya passato yā loke natthitā sā na hoti."
    },
    {
      "id": "sn12.15:2.3",
      "pali": "Lokanirodhaṁ kho, kaccāna, yathābhūtaṁ sammappaññāya passato yā loke atthitā sā na hoti."
    },
    {
      "id": "sn12.15:2.4",
      "pali": "Upayupādānābhinivesavinibandho khvāyaṁ, kaccāna, loko yebhuyyena."
    },
    {
      "id": "sn12.15:2.5",
      "pali": "Tañcāyaṁ upayupādānaṁ cetaso adhiṭṭhānaṁ abhinivesānusayaṁ na upeti na upādiyati nādhiṭṭhāti: ‘attā me’ti."
    },
    {
      "id": "sn12.15:2.6",
      "pali": "‘Dukkhameva uppajjamānaṁ uppajjati, dukkhaṁ nirujjhamānaṁ nirujjhatī’ti na kaṅkhati na vicikicchati aparapaccayā ñāṇamevassa ettha hoti."
    },
    {
      "id": "sn12.15:2.7",
      "pali": "Ettāvatā kho, kaccāna, sammādiṭṭhi hoti."
    },
    {
      "id": "sn12.15:3.1",
      "pali": "‘Sabbamatthī’ti kho, kaccāna, ayameko anto."
    },
    {
      "id": "sn12.15:3.2",
      "pali": "‘Sabbaṁ natthī’ti ayaṁ dutiyo anto."
    },
    {
      "id": "sn12.15:3.3",
      "pali": "Ete te, kaccāna, ubho ante anupagamma majjhena tathāgato dhammaṁ deseti:"
    },
    {
      "id": "sn12.15:3.4",
      "pali": "‘avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.15:3.5",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.15:3.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.15:3.7",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.15:3.8",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.15:3.9",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī’”ti."
    },
    {
      "id": "sn12.15:3.10",
      "pali": "Pañcamaṁ."
    }
  ]
}
