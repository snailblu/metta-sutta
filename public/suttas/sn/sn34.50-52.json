{
  "uid": "sn34.50-52",
  "title": "sn34.50-52",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn34.50:1.1",
      "pali": "Sāvatthinidānaṁ …"
    },
    {
      "id": "sn34.50:1.2",
      "pali": "“samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sakkaccakārī …"
    },
    {
      "id": "sn34.50:1.3",
      "pali": "samādhismiṁ sakkaccakārī hoti, na samādhismiṁ abhinīhārakusalo …"
    },
    {
      "id": "sn34.50:1.4",
      "pali": "neva samādhismiṁ abhinīhārakusalo hoti, na ca samādhismiṁ sakkaccakārī …"
    },
    {
      "id": "sn34.50:1.5",
      "pali": "samādhismiṁ abhinīhārakusalo ca hoti, samādhismiṁ sakkaccakārī ca."
    },
    {
      "id": "sn34.50:1.6",
      "pali": "Tatra, bhikkhave, yvāyaṁ jhāyī …pe…"
    },
    {
      "id": "sn34.50:1.7",
      "pali": "uttamo ca pavaro cā”ti."
    },
    {
      "id": "sn34.50:1.8",
      "pali": "Paññāsamaṁ."
    },
    {
      "id": "sn34.51:1.1",
      "pali": "“Samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sātaccakārī …pe…."
    },
    {
      "id": "sn34.51:1.2",
      "pali": "Ekapaññāsamaṁ."
    },
    {
      "id": "sn34.52:1.1",
      "pali": "“Samādhismiṁ abhinīhārakusalo hoti, na samādhismiṁ sappāyakārī …pe…."
    },
    {
      "id": "sn34.52:1.2",
      "pali": "Dvepaññāsamaṁ."
    },
    {
      "id": "sn34.52:1.3",
      "pali": "(Abhinīhāramūlakaṁ.)"
    }
  ]
}
