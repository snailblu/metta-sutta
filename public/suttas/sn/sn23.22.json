{
  "uid": "sn23.22",
  "title": "Nirodhadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.22:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.22:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.22:1.3",
      "pali": "“‘nirodhadhammo, nirodhadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.22:1.4",
      "pali": "Katamo nu kho, bhante, nirodhadhammo”ti?"
    },
    {
      "id": "sn23.22:1.5",
      "pali": "“Rūpaṁ kho, rādha, nirodhadhammo, vedanā nirodhadhammo, saññā nirodhadhammo, saṅkhārā nirodhadhammo, viññāṇaṁ nirodhadhammo."
    },
    {
      "id": "sn23.22:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.22:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.22:1.8",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn23.22:1.9",
      "pali": "Dutiyamāravaggo."
    },
    {
      "id": "sn23.22:2.1",
      "pali": "Māro ca māradhammo ca,"
    },
    {
      "id": "sn23.22:2.2",
      "pali": "Aniccena apare duve;"
    },
    {
      "id": "sn23.22:2.3",
      "pali": "Dukkhena ca duve vuttā,"
    },
    {
      "id": "sn23.22:2.4",
      "pali": "Anattena tatheva ca;"
    },
    {
      "id": "sn23.22:2.5",
      "pali": "Khayavayasamudayaṁ,"
    },
    {
      "id": "sn23.22:2.6",
      "pali": "Nirodhadhammena dvādasāti."
    }
  ]
}
