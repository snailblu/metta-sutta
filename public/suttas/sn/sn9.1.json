{
  "uid": "sn9.1",
  "title": "Vivekasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn9.1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn9.1:1.2",
      "pali": "ekaṁ samayaṁ aññataro bhikkhu kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn9.1:1.3",
      "pali": "Tena kho pana samayena so bhikkhu divāvihāragato pāpake akusale vitakke vitakketi gehanissite."
    },
    {
      "id": "sn9.1:1.4",
      "pali": "Atha kho yā tasmiṁ vanasaṇḍe adhivatthā devatā tassa bhikkhuno anukampikā atthakāmā taṁ bhikkhuṁ saṁvejetukāmā yena so bhikkhu tenupasaṅkami; upasaṅkamitvā taṁ bhikkhuṁ gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn9.1:2.1",
      "pali": "“Vivekakāmosi vanaṁ paviṭṭho,"
    },
    {
      "id": "sn9.1:2.2",
      "pali": "Atha te mano niccharatī bahiddhā;"
    },
    {
      "id": "sn9.1:2.3",
      "pali": "Jano janasmiṁ vinayassu chandaṁ,"
    },
    {
      "id": "sn9.1:2.4",
      "pali": "Tato sukhī hohisi vītarāgo."
    },
    {
      "id": "sn9.1:3.1",
      "pali": "Aratiṁ pajahāsi sato,"
    },
    {
      "id": "sn9.1:3.2",
      "pali": "Bhavāsi sataṁ taṁ sārayāmase;"
    },
    {
      "id": "sn9.1:3.3",
      "pali": "Pātālarajo hi duttaro,"
    },
    {
      "id": "sn9.1:3.4",
      "pali": "Mā taṁ kāmarajo avāhari."
    },
    {
      "id": "sn9.1:4.1",
      "pali": "Sakuṇo yathā paṁsukunthito,"
    },
    {
      "id": "sn9.1:4.2",
      "pali": "Vidhunaṁ pātayati sitaṁ rajaṁ;"
    },
    {
      "id": "sn9.1:4.3",
      "pali": "Evaṁ bhikkhu padhānavā satimā,"
    },
    {
      "id": "sn9.1:4.4",
      "pali": "Vidhunaṁ pātayati sitaṁ rajan”ti."
    },
    {
      "id": "sn9.1:5.1",
      "pali": "Atha kho so bhikkhu tāya devatāya saṁvejito saṁvegamāpādīti."
    }
  ]
}
