{
  "uid": "snp3.12",
  "title": "Dvayatānupassanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp3.12:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "snp3.12:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati pubbārāme migāramātupāsāde."
    },
    {
      "id": "snp3.12:1.3",
      "pali": "Tena kho pana samayena bhagavā tadahuposathe pannarase puṇṇāya puṇṇamāya rattiyā bhikkhusaṅghaparivuto abbhokāse nisinno hoti."
    },
    {
      "id": "snp3.12:1.4",
      "pali": "Atha kho bhagavā tuṇhībhūtaṁ tuṇhībhūtaṁ bhikkhusaṅghaṁ anuviloketvā bhikkhū āmantesi:"
    },
    {
      "id": "snp3.12:2.1",
      "pali": "“‘Ye te, bhikkhave, kusalā dhammā ariyā niyyānikā sambodhagāmino, tesaṁ vo, bhikkhave, kusalānaṁ dhammānaṁ ariyānaṁ niyyānikānaṁ sambodhagāmīnaṁ kā upanisā savanāyā’ti, iti ce, bhikkhave, pucchitāro assu, te evamassu vacanīyā:"
    },
    {
      "id": "snp3.12:2.2",
      "pali": "‘yāvadeva dvayatānaṁ dhammānaṁ yathābhūtaṁ ñāṇāyā’ti."
    },
    {
      "id": "snp3.12:2.3",
      "pali": "Kiñca dvayataṁ vadetha?"
    },
    {
      "id": "snp3.12:3.1",
      "pali": "Idaṁ dukkhaṁ, ayaṁ dukkhasamudayoti ayamekānupassanā."
    },
    {
      "id": "snp3.12:3.2",
      "pali": "Ayaṁ dukkhanirodho, ayaṁ dukkhanirodhagāminī paṭipadāti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:3.3",
      "pali": "Evaṁ sammā dvayatānupassino kho, bhikkhave, bhikkhuno appamattassa ātāpino pahitattassa viharato dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "snp3.12:3.4",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitā”ti."
    },
    {
      "id": "snp3.12:4.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "snp3.12:4.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:5.1",
      "pali": "“Ye dukkhaṁ nappajānanti,"
    },
    {
      "id": "snp3.12:5.2",
      "pali": "atho dukkhassa sambhavaṁ;"
    },
    {
      "id": "snp3.12:5.3",
      "pali": "Yattha ca sabbaso dukkhaṁ,"
    },
    {
      "id": "snp3.12:5.4",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "snp3.12:5.5",
      "pali": "Tañca maggaṁ na jānanti,"
    },
    {
      "id": "snp3.12:5.6",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "snp3.12:6.1",
      "pali": "Cetovimuttihīnā te,"
    },
    {
      "id": "snp3.12:6.2",
      "pali": "Atho paññāvimuttiyā;"
    },
    {
      "id": "snp3.12:6.3",
      "pali": "Abhabbā te antakiriyāya,"
    },
    {
      "id": "snp3.12:6.4",
      "pali": "Te ve jātijarūpagā."
    },
    {
      "id": "snp3.12:7.1",
      "pali": "Ye ca dukkhaṁ pajānanti,"
    },
    {
      "id": "snp3.12:7.2",
      "pali": "atho dukkhassa sambhavaṁ;"
    },
    {
      "id": "snp3.12:7.3",
      "pali": "Yattha ca sabbaso dukkhaṁ,"
    },
    {
      "id": "snp3.12:7.4",
      "pali": "asesaṁ uparujjhati;"
    },
    {
      "id": "snp3.12:7.5",
      "pali": "Tañca maggaṁ pajānanti,"
    },
    {
      "id": "snp3.12:7.6",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "snp3.12:8.1",
      "pali": "Cetovimuttisampannā,"
    },
    {
      "id": "snp3.12:8.2",
      "pali": "Atho paññāvimuttiyā;"
    },
    {
      "id": "snp3.12:8.3",
      "pali": "Bhabbā te antakiriyāya,"
    },
    {
      "id": "snp3.12:8.4",
      "pali": "Na te jātijarūpagāti."
    },
    {
      "id": "snp3.12:9.1",
      "pali": "‘Siyā aññenapi pariyāyena sammā dvayatānupassanā’ti, iti ce, bhikkhave, pucchitāro assu;"
    },
    {
      "id": "snp3.12:9.2",
      "pali": "‘siyā’tissu vacanīyā."
    },
    {
      "id": "snp3.12:9.3",
      "pali": "Kathañca siyā?"
    },
    {
      "id": "snp3.12:9.4",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ upadhipaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:9.5",
      "pali": "Upadhīnaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:9.6",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:9.7",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:10.1",
      "pali": "“Upadhinidānā pabhavanti dukkhā,"
    },
    {
      "id": "snp3.12:10.2",
      "pali": "Ye keci lokasmimanekarūpā;"
    },
    {
      "id": "snp3.12:10.3",
      "pali": "Yo ve avidvā upadhiṁ karoti,"
    },
    {
      "id": "snp3.12:10.4",
      "pali": "Punappunaṁ dukkhamupeti mando;"
    },
    {
      "id": "snp3.12:10.5",
      "pali": "Tasmā pajānaṁ upadhiṁ na kayirā,"
    },
    {
      "id": "snp3.12:10.6",
      "pali": "Dukkhassa jātippabhavānupassīti."
    },
    {
      "id": "snp3.12:11.1",
      "pali": "‘Siyā aññenapi pariyāyena sammā dvayatānupassanā’ti, iti ce, bhikkhave, pucchitāro assu;"
    },
    {
      "id": "snp3.12:11.2",
      "pali": "‘siyā’tissu vacanīyā."
    },
    {
      "id": "snp3.12:11.3",
      "pali": "Kathañca siyā?"
    },
    {
      "id": "snp3.12:11.4",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ avijjāpaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:11.5",
      "pali": "Avijjāya tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:11.6",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:11.7",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:12.1",
      "pali": "“Jātimaraṇasaṁsāraṁ,"
    },
    {
      "id": "snp3.12:12.2",
      "pali": "ye vajanti punappunaṁ;"
    },
    {
      "id": "snp3.12:12.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "snp3.12:12.4",
      "pali": "avijjāyeva sā gati."
    },
    {
      "id": "snp3.12:13.1",
      "pali": "Avijjā hāyaṁ mahāmoho,"
    },
    {
      "id": "snp3.12:13.2",
      "pali": "Yenidaṁ saṁsitaṁ ciraṁ;"
    },
    {
      "id": "snp3.12:13.3",
      "pali": "Vijjāgatā ca ye sattā,"
    },
    {
      "id": "snp3.12:13.4",
      "pali": "Na te gacchanti punabbhavanti."
    },
    {
      "id": "snp3.12:14.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:14.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:14.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ saṅkhārapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:14.4",
      "pali": "Saṅkhārānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:14.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:14.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:15.1",
      "pali": "“Yaṁ kiñci dukkhaṁ sambhoti,"
    },
    {
      "id": "snp3.12:15.2",
      "pali": "sabbaṁ saṅkhārapaccayā;"
    },
    {
      "id": "snp3.12:15.3",
      "pali": "Saṅkhārānaṁ nirodhena,"
    },
    {
      "id": "snp3.12:15.4",
      "pali": "natthi dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:16.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:16.2",
      "pali": "dukkhaṁ saṅkhārapaccayā;"
    },
    {
      "id": "snp3.12:16.3",
      "pali": "Sabbasaṅkhārasamathā,"
    },
    {
      "id": "snp3.12:16.4",
      "pali": "saññānaṁ uparodhanā;"
    },
    {
      "id": "snp3.12:16.5",
      "pali": "Evaṁ dukkhakkhayo hoti,"
    },
    {
      "id": "snp3.12:16.6",
      "pali": "etaṁ ñatvā yathātathaṁ."
    },
    {
      "id": "snp3.12:17.1",
      "pali": "Sammaddasā vedaguno,"
    },
    {
      "id": "snp3.12:17.2",
      "pali": "Sammadaññāya paṇḍitā;"
    },
    {
      "id": "snp3.12:17.3",
      "pali": "Abhibhuyya mārasaṁyogaṁ,"
    },
    {
      "id": "snp3.12:17.4",
      "pali": "Na gacchanti punabbhavanti."
    },
    {
      "id": "snp3.12:18.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:18.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:18.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ viññāṇapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:18.4",
      "pali": "Viññāṇassa tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:18.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:18.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:19.1",
      "pali": "“Yaṁ kiñci dukkhaṁ sambhoti,"
    },
    {
      "id": "snp3.12:19.2",
      "pali": "Sabbaṁ viññāṇapaccayā;"
    },
    {
      "id": "snp3.12:19.3",
      "pali": "Viññāṇassa nirodhena,"
    },
    {
      "id": "snp3.12:19.4",
      "pali": "Natthi dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:20.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:20.2",
      "pali": "Dukkhaṁ viññāṇapaccayā;"
    },
    {
      "id": "snp3.12:20.3",
      "pali": "Viññāṇūpasamā bhikkhu,"
    },
    {
      "id": "snp3.12:20.4",
      "pali": "Nicchāto parinibbutoti."
    },
    {
      "id": "snp3.12:21.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:21.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:21.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ phassapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:21.4",
      "pali": "Phassassa tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:21.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:21.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:22.1",
      "pali": "“Tesaṁ phassaparetānaṁ,"
    },
    {
      "id": "snp3.12:22.2",
      "pali": "Bhavasotānusārinaṁ;"
    },
    {
      "id": "snp3.12:22.3",
      "pali": "Kummaggapaṭipannānaṁ,"
    },
    {
      "id": "snp3.12:22.4",
      "pali": "Ārā saṁyojanakkhayo."
    },
    {
      "id": "snp3.12:23.1",
      "pali": "Ye ca phassaṁ pariññāya,"
    },
    {
      "id": "snp3.12:23.2",
      "pali": "Aññāyupasame ratā;"
    },
    {
      "id": "snp3.12:23.3",
      "pali": "Te ve phassābhisamayā,"
    },
    {
      "id": "snp3.12:23.4",
      "pali": "Nicchātā parinibbutāti."
    },
    {
      "id": "snp3.12:24.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:24.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:24.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ vedanāpaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:24.4",
      "pali": "Vedanānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:24.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:24.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:25.1",
      "pali": "“Sukhaṁ vā yadi vā dukkhaṁ,"
    },
    {
      "id": "snp3.12:25.2",
      "pali": "Adukkhamasukhaṁ saha;"
    },
    {
      "id": "snp3.12:25.3",
      "pali": "Ajjhattañca bahiddhā ca,"
    },
    {
      "id": "snp3.12:25.4",
      "pali": "Yaṁ kiñci atthi veditaṁ."
    },
    {
      "id": "snp3.12:26.1",
      "pali": "Etaṁ dukkhanti ñatvāna,"
    },
    {
      "id": "snp3.12:26.2",
      "pali": "Mosadhammaṁ palokinaṁ;"
    },
    {
      "id": "snp3.12:26.3",
      "pali": "Phussa phussa vayaṁ passaṁ,"
    },
    {
      "id": "snp3.12:26.4",
      "pali": "Evaṁ tattha vijānati;"
    },
    {
      "id": "snp3.12:26.5",
      "pali": "Vedanānaṁ khayā bhikkhu,"
    },
    {
      "id": "snp3.12:26.6",
      "pali": "Nicchāto parinibbutoti."
    },
    {
      "id": "snp3.12:27.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:27.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:27.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ taṇhāpaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:27.4",
      "pali": "Taṇhāya tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:27.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:27.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:28.1",
      "pali": "“Taṇhādutiyo puriso,"
    },
    {
      "id": "snp3.12:28.2",
      "pali": "Dīghamaddhāna saṁsaraṁ;"
    },
    {
      "id": "snp3.12:28.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "snp3.12:28.4",
      "pali": "Saṁsāraṁ nātivattati."
    },
    {
      "id": "snp3.12:29.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:29.2",
      "pali": "Taṇhaṁ dukkhassa sambhavaṁ;"
    },
    {
      "id": "snp3.12:29.3",
      "pali": "Vītataṇho anādāno,"
    },
    {
      "id": "snp3.12:29.4",
      "pali": "Sato bhikkhu paribbajeti."
    },
    {
      "id": "snp3.12:30.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:30.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:30.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ upādānapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:30.4",
      "pali": "Upādānānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:30.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:30.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:31.1",
      "pali": "“Upādānapaccayā bhavo,"
    },
    {
      "id": "snp3.12:31.2",
      "pali": "Bhūto dukkhaṁ nigacchati;"
    },
    {
      "id": "snp3.12:31.3",
      "pali": "Jātassa maraṇaṁ hoti,"
    },
    {
      "id": "snp3.12:31.4",
      "pali": "Eso dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:32.1",
      "pali": "Tasmā upādānakkhayā,"
    },
    {
      "id": "snp3.12:32.2",
      "pali": "Sammadaññāya paṇḍitā;"
    },
    {
      "id": "snp3.12:32.3",
      "pali": "Jātikkhayaṁ abhiññāya,"
    },
    {
      "id": "snp3.12:32.4",
      "pali": "Na gacchanti punabbhavanti."
    },
    {
      "id": "snp3.12:33.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:33.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:33.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ ārambhapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:33.4",
      "pali": "Ārambhānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:33.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:33.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:34.1",
      "pali": "“Yaṁ kiñci dukkhaṁ sambhoti,"
    },
    {
      "id": "snp3.12:34.2",
      "pali": "Sabbaṁ ārambhapaccayā;"
    },
    {
      "id": "snp3.12:34.3",
      "pali": "Ārambhānaṁ nirodhena,"
    },
    {
      "id": "snp3.12:34.4",
      "pali": "Natthi dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:35.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:35.2",
      "pali": "Dukkhaṁ ārambhapaccayā;"
    },
    {
      "id": "snp3.12:35.3",
      "pali": "Sabbārambhaṁ paṭinissajja,"
    },
    {
      "id": "snp3.12:35.4",
      "pali": "Anārambhe vimuttino."
    },
    {
      "id": "snp3.12:36.1",
      "pali": "Ucchinnabhavataṇhassa,"
    },
    {
      "id": "snp3.12:36.2",
      "pali": "Santacittassa bhikkhuno;"
    },
    {
      "id": "snp3.12:36.3",
      "pali": "Vikkhīṇo jātisaṁsāro,"
    },
    {
      "id": "snp3.12:36.4",
      "pali": "Natthi tassa punabbhavoti."
    },
    {
      "id": "snp3.12:37.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:37.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:37.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ āhārapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:37.4",
      "pali": "Āhārānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:37.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:37.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:38.1",
      "pali": "“Yaṁ kiñci dukkhaṁ sambhoti,"
    },
    {
      "id": "snp3.12:38.2",
      "pali": "Sabbaṁ āhārapaccayā;"
    },
    {
      "id": "snp3.12:38.3",
      "pali": "Āhārānaṁ nirodhena,"
    },
    {
      "id": "snp3.12:38.4",
      "pali": "Natthi dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:39.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:39.2",
      "pali": "Dukkhaṁ āhārapaccayā;"
    },
    {
      "id": "snp3.12:39.3",
      "pali": "Sabbāhāraṁ pariññāya,"
    },
    {
      "id": "snp3.12:39.4",
      "pali": "Sabbāhāramanissito."
    },
    {
      "id": "snp3.12:40.1",
      "pali": "Ārogyaṁ sammadaññāya,"
    },
    {
      "id": "snp3.12:40.2",
      "pali": "Āsavānaṁ parikkhayā;"
    },
    {
      "id": "snp3.12:40.3",
      "pali": "Saṅkhāya sevī dhammaṭṭho,"
    },
    {
      "id": "snp3.12:40.4",
      "pali": "Saṅkhyaṁ nopeti vedagūti."
    },
    {
      "id": "snp3.12:41.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:41.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:41.3",
      "pali": "Yaṁ kiñci dukkhaṁ sambhoti sabbaṁ iñjitapaccayāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:41.4",
      "pali": "Iñjitānaṁ tveva asesavirāganirodhā natthi dukkhassa sambhavoti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:41.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:41.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:42.1",
      "pali": "“Yaṁ kiñci dukkhaṁ sambhoti,"
    },
    {
      "id": "snp3.12:42.2",
      "pali": "Sabbaṁ iñjitapaccayā;"
    },
    {
      "id": "snp3.12:42.3",
      "pali": "Iñjitānaṁ nirodhena,"
    },
    {
      "id": "snp3.12:42.4",
      "pali": "Natthi dukkhassa sambhavo."
    },
    {
      "id": "snp3.12:43.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:43.2",
      "pali": "Dukkhaṁ iñjitapaccayā;"
    },
    {
      "id": "snp3.12:43.3",
      "pali": "Tasmā hi ejaṁ vossajja,"
    },
    {
      "id": "snp3.12:43.4",
      "pali": "Saṅkhāre uparundhiya;"
    },
    {
      "id": "snp3.12:43.5",
      "pali": "Anejo anupādāno,"
    },
    {
      "id": "snp3.12:43.6",
      "pali": "Sato bhikkhu paribbajeti."
    },
    {
      "id": "snp3.12:44.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:44.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:44.3",
      "pali": "Nissitassa calitaṁ hotīti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:44.4",
      "pali": "Anissito na calatīti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:44.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:44.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:45.1",
      "pali": "“Anissito na calati,"
    },
    {
      "id": "snp3.12:45.2",
      "pali": "Nissito ca upādiyaṁ;"
    },
    {
      "id": "snp3.12:45.3",
      "pali": "Itthabhāvaññathābhāvaṁ,"
    },
    {
      "id": "snp3.12:45.4",
      "pali": "Saṁsāraṁ nātivattati."
    },
    {
      "id": "snp3.12:46.1",
      "pali": "Etamādīnavaṁ ñatvā,"
    },
    {
      "id": "snp3.12:46.2",
      "pali": "Nissayesu mahabbhayaṁ;"
    },
    {
      "id": "snp3.12:46.3",
      "pali": "Anissito anupādāno,"
    },
    {
      "id": "snp3.12:46.4",
      "pali": "Sato bhikkhu paribbajeti."
    },
    {
      "id": "snp3.12:47.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:47.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:47.3",
      "pali": "Rūpehi, bhikkhave, arūpā santatarāti, ayamekānupassanā."
    },
    {
      "id": "snp3.12:47.4",
      "pali": "Arūpehi nirodho santataroti, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:47.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:47.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:48.1",
      "pali": "“Ye ca rūpūpagā sattā,"
    },
    {
      "id": "snp3.12:48.2",
      "pali": "Ye ca arūpaṭṭhāyino;"
    },
    {
      "id": "snp3.12:48.3",
      "pali": "Nirodhaṁ appajānantā,"
    },
    {
      "id": "snp3.12:48.4",
      "pali": "Āgantāro punabbhavaṁ."
    },
    {
      "id": "snp3.12:49.1",
      "pali": "Ye ca rūpe pariññāya,"
    },
    {
      "id": "snp3.12:49.2",
      "pali": "Arūpesu asaṇṭhitā;"
    },
    {
      "id": "snp3.12:49.3",
      "pali": "Nirodhe ye vimuccanti,"
    },
    {
      "id": "snp3.12:49.4",
      "pali": "Te janā maccuhāyinoti."
    },
    {
      "id": "snp3.12:50.1",
      "pali": "‘Siyā aññenapi …pe…"
    },
    {
      "id": "snp3.12:50.2",
      "pali": "kathañca siyā?"
    },
    {
      "id": "snp3.12:50.3",
      "pali": "Yaṁ, bhikkhave, sadevakassa lokassa samārakassa sabrahmakassa sassamaṇabrāhmaṇiyā pajāya sadevamanussāya idaṁ saccanti upanijjhāyitaṁ tadamariyānaṁ etaṁ musāti yathābhūtaṁ sammappaññāya sudiṭṭhaṁ, ayamekānupassanā."
    },
    {
      "id": "snp3.12:50.4",
      "pali": "Yaṁ, bhikkhave, sadevakassa …pe… sadevamanussāya idaṁ musāti upanijjhāyitaṁ, tadamariyānaṁ etaṁ saccanti yathābhūtaṁ sammappaññāya sudiṭṭhaṁ, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:50.5",
      "pali": "Evaṁ sammā …pe…"
    },
    {
      "id": "snp3.12:50.6",
      "pali": "athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:51.1",
      "pali": "“Anattani attamāniṁ,"
    },
    {
      "id": "snp3.12:51.2",
      "pali": "Passa lokaṁ sadevakaṁ;"
    },
    {
      "id": "snp3.12:51.3",
      "pali": "Niviṭṭhaṁ nāmarūpasmiṁ,"
    },
    {
      "id": "snp3.12:51.4",
      "pali": "Idaṁ saccanti maññati."
    },
    {
      "id": "snp3.12:52.1",
      "pali": "Yena yena hi maññanti,"
    },
    {
      "id": "snp3.12:52.2",
      "pali": "Tato taṁ hoti aññathā;"
    },
    {
      "id": "snp3.12:52.3",
      "pali": "Tañhi tassa musā hoti,"
    },
    {
      "id": "snp3.12:52.4",
      "pali": "Mosadhammañhi ittaraṁ."
    },
    {
      "id": "snp3.12:53.1",
      "pali": "Amosadhammaṁ nibbānaṁ,"
    },
    {
      "id": "snp3.12:53.2",
      "pali": "Tadariyā saccato vidū;"
    },
    {
      "id": "snp3.12:53.3",
      "pali": "Te ve saccābhisamayā,"
    },
    {
      "id": "snp3.12:53.4",
      "pali": "Nicchātā parinibbutāti."
    },
    {
      "id": "snp3.12:54.1",
      "pali": "‘Siyā aññenapi pariyāyena sammā dvayatānupassanā’ti, iti ce, bhikkhave, pucchitāro assu;"
    },
    {
      "id": "snp3.12:54.2",
      "pali": "‘siyā’tissu vacanīyā."
    },
    {
      "id": "snp3.12:54.3",
      "pali": "Kathañca siyā?"
    },
    {
      "id": "snp3.12:54.4",
      "pali": "Yaṁ, bhikkhave, sadevakassa lokassa samārakassa sabrahmakassa sassamaṇabrāhmaṇiyā pajāya sadevamanussāya idaṁ sukhanti upanijjhāyitaṁ, tadamariyānaṁ etaṁ dukkhanti yathābhūtaṁ sammappaññāya sudiṭṭhaṁ, ayamekānupassanā."
    },
    {
      "id": "snp3.12:54.5",
      "pali": "Yaṁ, bhikkhave, sadevakassa …pe… sadevamanussāya idaṁ dukkhanti upanijjhāyitaṁ tadamariyānaṁ etaṁ sukhanti yathābhūtaṁ sammappaññāya sudiṭṭhaṁ, ayaṁ dutiyānupassanā."
    },
    {
      "id": "snp3.12:54.6",
      "pali": "Evaṁ sammā dvayatānupassino kho, bhikkhave, bhikkhuno appamattassa ātāpino pahitattassa viharato dvinnaṁ phalānaṁ aññataraṁ phalaṁ pāṭikaṅkhaṁ—"
    },
    {
      "id": "snp3.12:54.7",
      "pali": "diṭṭheva dhamme aññā, sati vā upādisese anāgāmitāti."
    },
    {
      "id": "snp3.12:54.8",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "snp3.12:54.9",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "snp3.12:55.1",
      "pali": "“Rūpā saddā rasā gandhā,"
    },
    {
      "id": "snp3.12:55.2",
      "pali": "Phassā dhammā ca kevalā;"
    },
    {
      "id": "snp3.12:55.3",
      "pali": "Iṭṭhā kantā manāpā ca,"
    },
    {
      "id": "snp3.12:55.4",
      "pali": "Yāvatatthīti vuccati."
    },
    {
      "id": "snp3.12:56.1",
      "pali": "Sadevakassa lokassa,"
    },
    {
      "id": "snp3.12:56.2",
      "pali": "Ete vo sukhasammatā;"
    },
    {
      "id": "snp3.12:56.3",
      "pali": "Yattha cete nirujjhanti,"
    },
    {
      "id": "snp3.12:56.4",
      "pali": "Taṁ nesaṁ dukkhasammataṁ."
    },
    {
      "id": "snp3.12:57.1",
      "pali": "Sukhanti diṭṭhamariyehi,"
    },
    {
      "id": "snp3.12:57.2",
      "pali": "Sakkāyassuparodhanaṁ;"
    },
    {
      "id": "snp3.12:57.3",
      "pali": "Paccanīkamidaṁ hoti,"
    },
    {
      "id": "snp3.12:57.4",
      "pali": "Sabbalokena passataṁ."
    },
    {
      "id": "snp3.12:58.1",
      "pali": "Yaṁ pare sukhato āhu,"
    },
    {
      "id": "snp3.12:58.2",
      "pali": "Tadariyā āhu dukkhato;"
    },
    {
      "id": "snp3.12:58.3",
      "pali": "Yaṁ pare dukkhato āhu,"
    },
    {
      "id": "snp3.12:58.4",
      "pali": "Tadariyā sukhato vidū."
    },
    {
      "id": "snp3.12:59.1",
      "pali": "Passa dhammaṁ durājānaṁ,"
    },
    {
      "id": "snp3.12:59.2",
      "pali": "Sampamūḷhetthaviddasu;"
    },
    {
      "id": "snp3.12:59.3",
      "pali": "Nivutānaṁ tamo hoti,"
    },
    {
      "id": "snp3.12:59.4",
      "pali": "Andhakāro apassataṁ."
    },
    {
      "id": "snp3.12:60.1",
      "pali": "Satañca vivaṭaṁ hoti,"
    },
    {
      "id": "snp3.12:60.2",
      "pali": "Āloko passatāmiva;"
    },
    {
      "id": "snp3.12:60.3",
      "pali": "Santike na vijānanti,"
    },
    {
      "id": "snp3.12:60.4",
      "pali": "Magā dhammassa kovidā."
    },
    {
      "id": "snp3.12:61.1",
      "pali": "Bhavarāgaparetehi,"
    },
    {
      "id": "snp3.12:61.2",
      "pali": "Bhavasotānusāribhi;"
    },
    {
      "id": "snp3.12:61.3",
      "pali": "Māradheyyānupannehi,"
    },
    {
      "id": "snp3.12:61.4",
      "pali": "Nāyaṁ dhammo susambudho."
    },
    {
      "id": "snp3.12:62.1",
      "pali": "Ko nu aññatra mariyehi,"
    },
    {
      "id": "snp3.12:62.2",
      "pali": "Padaṁ sambuddhumarahati;"
    },
    {
      "id": "snp3.12:62.3",
      "pali": "Yaṁ padaṁ sammadaññāya,"
    },
    {
      "id": "snp3.12:62.4",
      "pali": "Parinibbanti anāsavā”ti."
    },
    {
      "id": "snp3.12:63.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "snp3.12:63.2",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "snp3.12:63.3",
      "pali": "Imasmiñca pana veyyākaraṇasmiṁ bhaññamāne saṭṭhimattānaṁ bhikkhūnaṁ anupādāya āsavehi cittāni vimucciṁsūti."
    },
    {
      "id": "snp3.12:63.4",
      "pali": "Dvayatānupassanāsuttaṁ dvādasamaṁ."
    },
    {
      "id": "snp3.12:64.1",
      "pali": "Saccaṁ upadhi avijjā ca,"
    },
    {
      "id": "snp3.12:64.2",
      "pali": "saṅkhāre viññāṇapañcamaṁ;"
    },
    {
      "id": "snp3.12:64.3",
      "pali": "Phassavedaniyā taṇhā,"
    },
    {
      "id": "snp3.12:64.4",
      "pali": "upādānārambhaāhārā;"
    },
    {
      "id": "snp3.12:64.5",
      "pali": "Iñjitaṁ calitaṁ rūpaṁ,"
    },
    {
      "id": "snp3.12:64.6",
      "pali": "saccaṁ dukkhena soḷasāti."
    },
    {
      "id": "snp3.12:64.7",
      "pali": "Mahāvaggo tatiyo."
    },
    {
      "id": "snp3.12:65.1",
      "pali": "Pabbajjā ca padhānañca,"
    },
    {
      "id": "snp3.12:65.2",
      "pali": "subhāsitañca sundari;"
    },
    {
      "id": "snp3.12:65.3",
      "pali": "Māghasuttaṁ sabhiyo ca,"
    },
    {
      "id": "snp3.12:65.4",
      "pali": "selo sallañca vuccati."
    },
    {
      "id": "snp3.12:66.1",
      "pali": "Vāseṭṭho cāpi kokāli,"
    },
    {
      "id": "snp3.12:66.2",
      "pali": "Nālako dvayatānupassanā;"
    },
    {
      "id": "snp3.12:66.3",
      "pali": "Dvādasetāni suttāni,"
    },
    {
      "id": "snp3.12:66.4",
      "pali": "Mahāvaggoti vuccatīti."
    }
  ]
}
