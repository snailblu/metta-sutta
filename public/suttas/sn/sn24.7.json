{
  "uid": "sn24.7",
  "title": "Hetusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn24.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn24.7:1.2",
      "pali": "“Kismiṁ nu kho, bhikkhave, sati, kiṁ upādāya, kiṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.7:1.3",
      "pali": "‘natthi hetu, natthi paccayo sattānaṁ saṅkilesāya."
    },
    {
      "id": "sn24.7:1.4",
      "pali": "Ahetū appaccayā sattā saṅkilissanti."
    },
    {
      "id": "sn24.7:1.5",
      "pali": "Natthi hetu, natthi paccayo sattānaṁ visuddhiyā."
    },
    {
      "id": "sn24.7:1.6",
      "pali": "Ahetū appaccayā sattā visujjhanti."
    },
    {
      "id": "sn24.7:1.7",
      "pali": "Natthi balaṁ natthi vīriyaṁ natthi purisathāmo natthi purisaparakkamo."
    },
    {
      "id": "sn24.7:1.8",
      "pali": "Sabbe sattā sabbe pāṇā sabbe bhūtā sabbe jīvā avasā abalā avīriyā niyatisaṅgatibhāvapariṇatā chasvevābhijātīsu sukhadukkhaṁ paṭisaṁvedentī’”ti?"
    },
    {
      "id": "sn24.7:1.9",
      "pali": "“Bhagavaṁmūlakā no, bhante, dhammā …pe…"
    },
    {
      "id": "sn24.7:2.1",
      "pali": "“Rūpe kho, bhikkhave, sati, rūpaṁ upādāya, rūpaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.7:2.2",
      "pali": "‘natthi hetu, natthi paccayo …pe…"
    },
    {
      "id": "sn24.7:2.3",
      "pali": "sukhadukkhaṁ paṭisaṁvedentī’ti."
    },
    {
      "id": "sn24.7:2.4",
      "pali": "Vedanāya sati …pe…"
    },
    {
      "id": "sn24.7:2.5",
      "pali": "saññāya sati …"
    },
    {
      "id": "sn24.7:2.6",
      "pali": "saṅkhāresu sati …"
    },
    {
      "id": "sn24.7:2.7",
      "pali": "viññāṇe sati, viññāṇaṁ upādāya, viññāṇaṁ abhinivissa evaṁ diṭṭhi uppajjati:"
    },
    {
      "id": "sn24.7:2.8",
      "pali": "‘natthi hetu, natthi paccayo …pe…"
    },
    {
      "id": "sn24.7:2.9",
      "pali": "sukhadukkhaṁ paṭisaṁvedentī’ti."
    },
    {
      "id": "sn24.7:3.1",
      "pali": "Taṁ kiṁ maññatha, bhikkhave,"
    },
    {
      "id": "sn24.7:3.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.7:3.3",
      "pali": "“Aniccaṁ, bhante …pe…"
    },
    {
      "id": "sn24.7:3.4",
      "pali": "vipariṇāmadhammaṁ, api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.7:3.5",
      "pali": "‘natthi hetu, natthi paccayo …pe…"
    },
    {
      "id": "sn24.7:3.6",
      "pali": "sukhadukkhaṁ paṭisaṁvedentī’”ti?"
    },
    {
      "id": "sn24.7:3.7",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.7:3.8",
      "pali": "“Vedanā …"
    },
    {
      "id": "sn24.7:3.9",
      "pali": "saññā …"
    },
    {
      "id": "sn24.7:3.10",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn24.7:3.11",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.7:3.12",
      "pali": "“Aniccaṁ, bhante …pe…"
    },
    {
      "id": "sn24.7:3.13",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.7:3.14",
      "pali": "‘natthi hetu, natthi paccayo …pe…"
    },
    {
      "id": "sn24.7:3.15",
      "pali": "sukhadukkhaṁ paṭisaṁvedentī’”ti?"
    },
    {
      "id": "sn24.7:3.16",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.7:3.17",
      "pali": "“Yampidaṁ diṭṭhaṁ sutaṁ mutaṁ viññātaṁ pattaṁ pariyesitaṁ anuvicaritaṁ manasā tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "sn24.7:3.18",
      "pali": "“Aniccaṁ, bhante …pe…"
    },
    {
      "id": "sn24.7:3.19",
      "pali": "api nu taṁ anupādāya evaṁ diṭṭhi uppajjeyya:"
    },
    {
      "id": "sn24.7:3.20",
      "pali": "‘natthi hetu natthi paccayo …pe…"
    },
    {
      "id": "sn24.7:3.21",
      "pali": "sukhadukkhaṁ paṭisaṁvedentī’”ti?"
    },
    {
      "id": "sn24.7:3.22",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn24.7:4.1",
      "pali": "“Yato kho, bhikkhave, ariyasāvakassa imesu ca ṭhānesu kaṅkhā pahīnā hoti, dukkhepissa kaṅkhā pahīnā hoti …pe… dukkhanirodhagāminiyā paṭipadāyapissa kaṅkhā pahīnā hoti—"
    },
    {
      "id": "sn24.7:4.2",
      "pali": "ayaṁ vuccati, bhikkhave, ariyasāvako sotāpanno avinipātadhammo niyato sambodhiparāyano”ti."
    },
    {
      "id": "sn24.7:4.3",
      "pali": "Sattamaṁ."
    }
  ]
}
