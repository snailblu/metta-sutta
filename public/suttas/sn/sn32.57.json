{
  "uid": "sn32.57",
  "title": "Vassavalāhakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn32.57:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn32.57:1.2",
      "pali": "Ekamantaṁ nisinno kho so bhikkhu bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn32.57:1.3",
      "pali": "“ko nu kho, bhante, hetu, ko paccayo, yenekadā devo vassatī”ti?"
    },
    {
      "id": "sn32.57:1.4",
      "pali": "“Santi, bhikkhu, vassavalāhakā nāma devā."
    },
    {
      "id": "sn32.57:1.5",
      "pali": "Tesaṁ yadā evaṁ hoti:"
    },
    {
      "id": "sn32.57:1.6",
      "pali": "‘yannūna mayaṁ sakāya ratiyā vaseyyāmā’ti, tesaṁ taṁ cetopaṇidhimanvāya devo vassati."
    },
    {
      "id": "sn32.57:1.7",
      "pali": "Ayaṁ kho, bhikkhu, hetu, ayaṁ paccayo, yenekadā devo vassatī”ti."
    },
    {
      "id": "sn32.57:1.8",
      "pali": "Sattapaññāsamaṁ."
    },
    {
      "id": "sn32.57:1.9",
      "pali": "Sattapaññāsasuttantaṁ niṭṭhitaṁ."
    },
    {
      "id": "sn32.57:1.10",
      "pali": "Valāhakavaggo paṭhamo."
    },
    {
      "id": "sn32.57:2.1",
      "pali": "Suddhikaṁ sucaritañca,"
    },
    {
      "id": "sn32.57:2.2",
      "pali": "dānūpakārapaññāsaṁ;"
    },
    {
      "id": "sn32.57:2.3",
      "pali": "Sītaṁ uṇhañca abbhañca,"
    },
    {
      "id": "sn32.57:2.4",
      "pali": "vātavassavalāhakāti."
    },
    {
      "id": "sn32.57:2.5",
      "pali": "Valāhakasaṁyuttaṁ samattaṁ."
    }
  ]
}
