{
  "uid": "sn46.153-164",
  "title": "Punabalādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.153-164:1.1",
      "pali": "…pe…"
    },
    {
      "id": "sn46.153-164:1.2",
      "pali": "Soḷasamo."
    },
    {
      "id": "sn46.153-164:2.1",
      "pali": "Balaṁ bījañca nāgo ca,"
    },
    {
      "id": "sn46.153-164:2.2",
      "pali": "rukkho kumbhena sūkiyā;"
    },
    {
      "id": "sn46.153-164:2.3",
      "pali": "Ākāsena ca dve meghā,"
    },
    {
      "id": "sn46.153-164:2.4",
      "pali": "nāvā āgantukā nadīti."
    },
    {
      "id": "sn46.153-164:3.1",
      "pali": "(Bojjhaṅgasaṁyuttassa balakaraṇīyavaggo rāgavasena vitthāretabbo.)"
    }
  ]
}
