{
  "uid": "sn40.11",
  "title": "Candanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn40.11:1.1",
      "pali": "Atha kho candano devaputto …pe…."
    },
    {
      "id": "sn40.11:2.1",
      "pali": "Atha kho suyāmo devaputto …pe…."
    },
    {
      "id": "sn40.11:3.1",
      "pali": "Atha kho santusito devaputto …pe…."
    },
    {
      "id": "sn40.11:4.1",
      "pali": "Atha kho sunimmito devaputto …pe…."
    },
    {
      "id": "sn40.11:5.1",
      "pali": "Atha kho vasavatti devaputto …pe…."
    },
    {
      "id": "sn40.11:6.1",
      "pali": "(Yathā sakkasuttaṁ tathā ime pañca peyyālā vitthāretabbā.)"
    },
    {
      "id": "sn40.11:6.2",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn40.11:6.3",
      "pali": "Moggallānavaggo paṭhamo."
    },
    {
      "id": "sn40.11:7.1",
      "pali": "Savitakkāvitakkañca,"
    },
    {
      "id": "sn40.11:7.2",
      "pali": "sukhena ca upekkhako;"
    },
    {
      "id": "sn40.11:7.3",
      "pali": "Ākāsañceva viññāṇaṁ,"
    },
    {
      "id": "sn40.11:7.4",
      "pali": "ākiñcaṁ nevasaññinā;"
    },
    {
      "id": "sn40.11:7.5",
      "pali": "Animitto ca sakko ca,"
    },
    {
      "id": "sn40.11:7.6",
      "pali": "candanekādasena cāti."
    },
    {
      "id": "sn40.11:7.7",
      "pali": "Moggallānasaṁyuttaṁ samattaṁ."
    }
  ]
}
