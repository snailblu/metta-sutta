{
  "uid": "sn53.13-22",
  "title": "Appamādavagga",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn53.13-22:1.1",
      "pali": "(Appamādavaggo vitthāretabbo.)"
    },
    {
      "id": "sn53.13-22:2.1",
      "pali": "Tathāgataṁ padaṁ kūṭaṁ,"
    },
    {
      "id": "sn53.13-22:2.2",
      "pali": "mūlaṁ sāro ca vassikaṁ;"
    },
    {
      "id": "sn53.13-22:2.3",
      "pali": "Rājā candimasūriyā,"
    },
    {
      "id": "sn53.13-22:2.4",
      "pali": "vatthena dasamaṁ padanti."
    }
  ]
}
