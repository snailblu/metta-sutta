{
  "uid": "sn7.15",
  "title": "Mānatthaddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.15:1.2",
      "pali": "Tena kho pana samayena mānatthaddho nāma brāhmaṇo sāvatthiyaṁ paṭivasati."
    },
    {
      "id": "sn7.15:1.3",
      "pali": "So neva mātaraṁ abhivādeti, na pitaraṁ abhivādeti, na ācariyaṁ abhivādeti, na jeṭṭhabhātaraṁ abhivādeti."
    },
    {
      "id": "sn7.15:1.4",
      "pali": "Tena kho pana samayena bhagavā mahatiyā parisāya parivuto dhammaṁ deseti."
    },
    {
      "id": "sn7.15:1.5",
      "pali": "Atha kho mānatthaddhassa brāhmaṇassa etadahosi:"
    },
    {
      "id": "sn7.15:1.6",
      "pali": "“ayaṁ kho samaṇo gotamo mahatiyā parisāya parivuto dhammaṁ deseti."
    },
    {
      "id": "sn7.15:1.7",
      "pali": "Yannūnāhaṁ yena samaṇo gotamo tenupasaṅkameyyaṁ."
    },
    {
      "id": "sn7.15:1.8",
      "pali": "Sace maṁ samaṇo gotamo ālapissati, ahampi taṁ ālapissāmi."
    },
    {
      "id": "sn7.15:1.9",
      "pali": "No ce maṁ samaṇo gotamo ālapissati, ahampi nālapissāmī”ti."
    },
    {
      "id": "sn7.15:1.10",
      "pali": "Atha kho mānatthaddho brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā tuṇhībhūto ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn7.15:1.11",
      "pali": "Atha kho bhagavā taṁ nālapi."
    },
    {
      "id": "sn7.15:1.12",
      "pali": "Atha kho mānatthaddho brāhmaṇo:"
    },
    {
      "id": "sn7.15:1.13",
      "pali": "“nāyaṁ samaṇo gotamo kiñci jānātī”ti tatova puna nivattitukāmo ahosi."
    },
    {
      "id": "sn7.15:1.14",
      "pali": "Atha kho bhagavā mānatthaddhassa brāhmaṇassa cetasā cetoparivitakkamaññāya mānatthaddhaṁ brāhmaṇaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.15:2.1",
      "pali": "“Na mānaṁ brāhmaṇa sādhu,"
    },
    {
      "id": "sn7.15:2.2",
      "pali": "atthikassīdha brāhmaṇa;"
    },
    {
      "id": "sn7.15:2.3",
      "pali": "Yena atthena āgacchi,"
    },
    {
      "id": "sn7.15:2.4",
      "pali": "tamevamanubrūhaye”ti."
    },
    {
      "id": "sn7.15:3.1",
      "pali": "Atha kho mānatthaddho brāhmaṇo:"
    },
    {
      "id": "sn7.15:3.2",
      "pali": "“cittaṁ me samaṇo gotamo jānātī”ti tattheva bhagavato pādesu sirasā nipatitvā bhagavato pādāni mukhena ca paricumbati pāṇīhi ca parisambāhati, nāmañca sāveti:"
    },
    {
      "id": "sn7.15:3.3",
      "pali": "“mānatthaddhāhaṁ, bho gotama, mānatthaddhāhaṁ, bho gotamā”ti."
    },
    {
      "id": "sn7.15:3.4",
      "pali": "Atha kho sā parisā abbhutavittajātā ahosi:"
    },
    {
      "id": "sn7.15:3.5",
      "pali": "“acchariyaṁ vata bho, abbhutaṁ vata bho."
    },
    {
      "id": "sn7.15:3.6",
      "pali": "Ayañhi mānatthaddho brāhmaṇo neva mātaraṁ abhivādeti, na pitaraṁ abhivādeti, na ācariyaṁ abhivādeti, na jeṭṭhabhātaraṁ abhivādeti;"
    },
    {
      "id": "sn7.15:3.7",
      "pali": "atha ca pana samaṇe gotame evarūpaṁ paramanipaccakāraṁ karotī”ti."
    },
    {
      "id": "sn7.15:3.8",
      "pali": "Atha kho bhagavā mānatthaddhaṁ brāhmaṇaṁ etadavoca:"
    },
    {
      "id": "sn7.15:3.9",
      "pali": "“alaṁ, brāhmaṇa, uṭṭhehi, sake āsane nisīda."
    },
    {
      "id": "sn7.15:3.10",
      "pali": "Yato te mayi cittaṁ pasannan”ti."
    },
    {
      "id": "sn7.15:3.11",
      "pali": "Atha kho mānatthaddho brāhmaṇo sake āsane nisīditvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.15:4.1",
      "pali": "“Kesu na mānaṁ kayirātha,"
    },
    {
      "id": "sn7.15:4.2",
      "pali": "kesu cassa sagāravo;"
    },
    {
      "id": "sn7.15:4.3",
      "pali": "Kyassa apacitā assu,"
    },
    {
      "id": "sn7.15:4.4",
      "pali": "kyassu sādhu supūjitā”ti."
    },
    {
      "id": "sn7.15:5.1",
      "pali": "“Mātari pitari cāpi,"
    },
    {
      "id": "sn7.15:5.2",
      "pali": "atho jeṭṭhamhi bhātari;"
    },
    {
      "id": "sn7.15:5.3",
      "pali": "Ācariye catutthamhi,"
    },
    {
      "id": "sn7.15:5.4",
      "pali": "tesu na mānaṁ kayirātha;"
    },
    {
      "id": "sn7.15:5.5",
      "pali": "Tesu assa sagāravo,"
    },
    {
      "id": "sn7.15:5.6",
      "pali": "tyassa apacitā assu;"
    },
    {
      "id": "sn7.15:5.7",
      "pali": "Tyassu sādhu supūjitā."
    },
    {
      "id": "sn7.15:6.1",
      "pali": "Arahante sītībhūte,"
    },
    {
      "id": "sn7.15:6.2",
      "pali": "katakicce anāsave;"
    },
    {
      "id": "sn7.15:6.3",
      "pali": "Nihacca mānaṁ athaddho,"
    },
    {
      "id": "sn7.15:6.4",
      "pali": "te namasse anuttare”ti."
    },
    {
      "id": "sn7.15:7.1",
      "pali": "Evaṁ vutte, mānatthaddho brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.15:7.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.15:7.3",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
