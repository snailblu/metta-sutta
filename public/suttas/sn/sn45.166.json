{
  "uid": "sn45.166",
  "title": "Khilasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.166:1.1",
      "pali": "“Tayome, bhikkhave, khilā."
    },
    {
      "id": "sn45.166:1.2",
      "pali": "Katame tayo?"
    },
    {
      "id": "sn45.166:1.3",
      "pali": "Rāgo khilo, doso khilo, moho khilo—"
    },
    {
      "id": "sn45.166:1.4",
      "pali": "ime kho, bhikkhave, tayo khilā."
    },
    {
      "id": "sn45.166:1.5",
      "pali": "Imesaṁ kho, bhikkhave, tiṇṇannaṁ khilānaṁ abhiññāya pariññāya parikkhayāya pahānāya …pe… ayaṁ ariyo aṭṭhaṅgiko maggo bhāvetabbo”ti."
    },
    {
      "id": "sn45.166:1.6",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
