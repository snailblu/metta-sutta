{
  "uid": "sn22.141",
  "title": "Dutiyadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.141:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.141:1.2",
      "pali": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo rāgo pahātabbo …pe…"
    },
    {
      "id": "sn22.141:1.3",
      "pali": "yaṁ, bhikkhave, dukkhaṁ; tatra vo rāgo pahātabbo”ti."
    },
    {
      "id": "sn22.141:1.4",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
