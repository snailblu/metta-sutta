{
  "uid": "sn1.57",
  "title": "Tatiyajanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn1.57:1.1",
      "pali": "“Kiṁsu janeti purisaṁ,"
    },
    {
      "id": "sn1.57:1.2",
      "pali": "kiṁsu tassa vidhāvati;"
    },
    {
      "id": "sn1.57:1.3",
      "pali": "Kiṁsu saṁsāramāpādi,"
    },
    {
      "id": "sn1.57:1.4",
      "pali": "kiṁsu tassa parāyanan”ti."
    },
    {
      "id": "sn1.57:2.1",
      "pali": "“Taṇhā janeti purisaṁ,"
    },
    {
      "id": "sn1.57:2.2",
      "pali": "cittamassa vidhāvati;"
    },
    {
      "id": "sn1.57:2.3",
      "pali": "Satto saṁsāramāpādi,"
    },
    {
      "id": "sn1.57:2.4",
      "pali": "kammaṁ tassa parāyanan”ti."
    }
  ]
}
