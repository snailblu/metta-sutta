{
  "uid": "sn6.13",
  "title": "Andhakavindasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn6.13:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā māgadhesu viharati andhakavinde."
    },
    {
      "id": "sn6.13:1.2",
      "pali": "Tena kho pana samayena bhagavā rattandhakāratimisāyaṁ abbhokāse nisinno hoti, devo ca ekamekaṁ phusāyati."
    },
    {
      "id": "sn6.13:1.3",
      "pali": "Atha kho brahmā sahampati abhikkantāya rattiyā abhikkantavaṇṇo kevalakappaṁ andhakavindaṁ obhāsetvā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn6.13:1.4",
      "pali": "Ekamantaṁ ṭhito kho brahmā sahampati bhagavato santike imā gāthāyo abhāsi:"
    },
    {
      "id": "sn6.13:2.1",
      "pali": "“Sevetha pantāni senāsanāni,"
    },
    {
      "id": "sn6.13:2.2",
      "pali": "Careyya saṁyojanavippamokkhā;"
    },
    {
      "id": "sn6.13:2.3",
      "pali": "Sace ratiṁ nādhigaccheyya tattha,"
    },
    {
      "id": "sn6.13:2.4",
      "pali": "Saṅghe vase rakkhitatto satīmā."
    },
    {
      "id": "sn6.13:3.1",
      "pali": "Kulākulaṁ piṇḍikāya caranto,"
    },
    {
      "id": "sn6.13:3.2",
      "pali": "Indriyagutto nipako satimā;"
    },
    {
      "id": "sn6.13:3.3",
      "pali": "Sevetha pantāni senāsanāni,"
    },
    {
      "id": "sn6.13:3.4",
      "pali": "Bhayā pamutto abhaye vimutto."
    },
    {
      "id": "sn6.13:4.1",
      "pali": "Yattha bheravā sarīsapā,"
    },
    {
      "id": "sn6.13:4.2",
      "pali": "Vijju sañcarati thanayati devo;"
    },
    {
      "id": "sn6.13:4.3",
      "pali": "Andhakāratimisāya rattiyā,"
    },
    {
      "id": "sn6.13:4.4",
      "pali": "Nisīdi tattha bhikkhu vigatalomahaṁso."
    },
    {
      "id": "sn6.13:5.1",
      "pali": "Idañhi jātu me diṭṭhaṁ,"
    },
    {
      "id": "sn6.13:5.2",
      "pali": "nayidaṁ itihītihaṁ;"
    },
    {
      "id": "sn6.13:5.3",
      "pali": "Ekasmiṁ brahmacariyasmiṁ,"
    },
    {
      "id": "sn6.13:5.4",
      "pali": "sahassaṁ maccuhāyinaṁ."
    },
    {
      "id": "sn6.13:6.1",
      "pali": "Bhiyyo pañcasatā sekkhā,"
    },
    {
      "id": "sn6.13:6.2",
      "pali": "dasā ca dasadhā dasa;"
    },
    {
      "id": "sn6.13:6.3",
      "pali": "Sabbe sotasamāpannā,"
    },
    {
      "id": "sn6.13:6.4",
      "pali": "atiracchānagāmino."
    },
    {
      "id": "sn6.13:7.1",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "sn6.13:7.2",
      "pali": "puññabhāgāti me mano;"
    },
    {
      "id": "sn6.13:7.3",
      "pali": "Saṅkhātuṁ nopi sakkomi,"
    },
    {
      "id": "sn6.13:7.4",
      "pali": "musāvādassa ottapan”ti."
    }
  ]
}
