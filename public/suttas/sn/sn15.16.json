{
  "uid": "sn15.16",
  "title": "Bhātusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.16:1.1",
      "pali": "Sāvatthiyaṁ viharati …pe…"
    },
    {
      "id": "sn15.16:1.2",
      "pali": "“na so, bhikkhave, satto sulabharūpo yo nabhātābhūtapubbo …pe…"
    },
    {
      "id": "sn15.16:1.3",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.16:1.4",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
