{
  "uid": "sn46.25",
  "title": "Aparihāniyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.25:1.1",
      "pali": "“Satta vo, bhikkhave, aparihāniye dhamme desessāmi;"
    },
    {
      "id": "sn46.25:1.2",
      "pali": "taṁ suṇātha."
    },
    {
      "id": "sn46.25:1.3",
      "pali": "Katame ca, bhikkhave, satta aparihāniyā dhammā?"
    },
    {
      "id": "sn46.25:1.4",
      "pali": "Yadidaṁ—"
    },
    {
      "id": "sn46.25:1.5",
      "pali": "satta bojjhaṅgā."
    },
    {
      "id": "sn46.25:1.6",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.25:1.7",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.25:1.8",
      "pali": "ime kho, bhikkhave, satta aparihāniyā dhammā”ti."
    },
    {
      "id": "sn46.25:1.9",
      "pali": "Pañcamaṁ."
    }
  ]
}
