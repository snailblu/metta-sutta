{
  "uid": "sn17.7",
  "title": "Diddhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.7:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.7:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… adhigamāya."
    },
    {
      "id": "sn17.7:1.3",
      "pali": "Kaṁ, bhikkhave, diddhagatena visallena sallena vijjhatu, sekhaṁ appattamānasaṁ lābhasakkārasiloko anupāpuṇātu."
    },
    {
      "id": "sn17.7:2.1",
      "pali": "Sallanti kho, bhikkhave, lābhasakkārasilokassetaṁ adhivacanaṁ."
    },
    {
      "id": "sn17.7:2.2",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.7:2.3",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.7:2.4",
      "pali": "Sattamaṁ."
    }
  ]
}
