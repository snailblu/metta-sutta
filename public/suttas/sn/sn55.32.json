{
  "uid": "sn55.32",
  "title": "Dutiyapuññābhisandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.32:1.1",
      "pali": "“Cattārome, bhikkhave, puññābhisandā kusalābhisandā sukhassāhārā."
    },
    {
      "id": "sn55.32:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn55.32:1.3",
      "pali": "Idha, bhikkhave, ariyasāvako buddhe aveccappasādena samannāgato hoti—"
    },
    {
      "id": "sn55.32:1.4",
      "pali": "itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavāti."
    },
    {
      "id": "sn55.32:1.5",
      "pali": "Ayaṁ paṭhamo puññābhisando kusalābhisando sukhassāhāro."
    },
    {
      "id": "sn55.32:2.1",
      "pali": "Puna caparaṁ, bhikkhave, ariyasāvako dhamme …pe…"
    },
    {
      "id": "sn55.32:2.2",
      "pali": "saṅghe …pe…."
    },
    {
      "id": "sn55.32:3.1",
      "pali": "Puna caparaṁ, bhikkhave, ariyasāvako vigatamalamaccherena cetasā agāraṁ ajjhāvasati muttacāgo payatapāṇi vossaggarato yācayogo dānasaṁvibhāgarato."
    },
    {
      "id": "sn55.32:3.2",
      "pali": "Ayaṁ catuttho puññābhisando kusalābhisando sukhassāhāro."
    },
    {
      "id": "sn55.32:3.3",
      "pali": "Ime kho, bhikkhave, cattāro puññābhisandā kusalābhisandā sukhassāhārā”ti."
    },
    {
      "id": "sn55.32:3.4",
      "pali": "Dutiyaṁ."
    }
  ]
}
