{
  "uid": "sn46.130",
  "title": "Uddhambhāgiyasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.130:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn46.130:1.2",
      "pali": "“Pañcimāni, bhikkhave, uddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn46.130:1.3",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn46.130:1.4",
      "pali": "Rūparāgo, arūparāgo, māno, uddhaccaṁ, avijjā—"
    },
    {
      "id": "sn46.130:1.5",
      "pali": "imāni kho, bhikkhave, pañcuddhambhāgiyāni saṁyojanāni."
    },
    {
      "id": "sn46.130:1.6",
      "pali": "Imesaṁ kho, bhikkhave, pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya satta bojjhaṅgā bhāvetabbā."
    },
    {
      "id": "sn46.130:1.7",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.130:1.8",
      "pali": "Idha, bhikkhave, bhikkhu satisambojjhaṅgaṁ bhāveti vivekanissitaṁ virāganissitaṁ nirodhanissitaṁ vossaggapariṇāmiṁ …pe…"
    },
    {
      "id": "sn46.130:1.9",
      "pali": "upekkhāsambojjhaṅgaṁ bhāveti rāgavinayapariyosānaṁ dosavinayapariyosānaṁ mohavinayapariyosānaṁ …"
    },
    {
      "id": "sn46.130:1.10",
      "pali": "amatogadhaṁ amataparāyanaṁ amatapariyosānaṁ …"
    },
    {
      "id": "sn46.130:1.11",
      "pali": "nibbānaninnaṁ nibbānapoṇaṁ nibbānapabbhāraṁ."
    },
    {
      "id": "sn46.130:1.12",
      "pali": "Imesaṁ kho, bhikkhave, bhikkhu pañcannaṁ uddhambhāgiyānaṁ saṁyojanānaṁ abhiññāya pariññāya parikkhayāya pahānāya ime satta bojjhaṅgā bhāvetabbā”ti."
    },
    {
      "id": "sn46.130:1.13",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn46.130:1.14",
      "pali": "Oghavaggo terasamo."
    },
    {
      "id": "sn46.130:2.1",
      "pali": "Ogho yogo upādānaṁ,"
    },
    {
      "id": "sn46.130:2.2",
      "pali": "Ganthā anusayena ca;"
    },
    {
      "id": "sn46.130:2.3",
      "pali": "Kāmaguṇā nīvaraṇā,"
    },
    {
      "id": "sn46.130:2.4",
      "pali": "Khandhā oruddhambhāgiyānīti."
    }
  ]
}
