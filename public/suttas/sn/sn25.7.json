{
  "uid": "sn25.7",
  "title": "Rūpasañcetanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn25.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn25.7:1.2",
      "pali": "“Rūpasañcetanā, bhikkhave, aniccā vipariṇāmī aññathābhāvī;"
    },
    {
      "id": "sn25.7:1.3",
      "pali": "saddasañcetanā …"
    },
    {
      "id": "sn25.7:1.4",
      "pali": "gandhasañcetanā …"
    },
    {
      "id": "sn25.7:1.5",
      "pali": "rasasañcetanā …"
    },
    {
      "id": "sn25.7:1.6",
      "pali": "phoṭṭhabbasañcetanā …"
    },
    {
      "id": "sn25.7:1.7",
      "pali": "dhammasañcetanā aniccā vipariṇāmī aññathābhāvī."
    },
    {
      "id": "sn25.7:1.8",
      "pali": "Yo, bhikkhave, ime dhamme evaṁ saddahati adhimuccati, ayaṁ vuccati ‘saddhānusārī …pe…"
    },
    {
      "id": "sn25.7:1.9",
      "pali": "sambodhiparāyano’”ti."
    },
    {
      "id": "sn25.7:1.10",
      "pali": "Sattamaṁ."
    }
  ]
}
