{
  "uid": "sn37.26",
  "title": "Pasayhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn37.26:1.1",
      "pali": "“Pañcimāni, bhikkhave, mātugāmassa balāni."
    },
    {
      "id": "sn37.26:1.2",
      "pali": "Katamāni pañca?"
    },
    {
      "id": "sn37.26:1.3",
      "pali": "Rūpabalaṁ, bhogabalaṁ, ñātibalaṁ, puttabalaṁ, sīlabalaṁ—"
    },
    {
      "id": "sn37.26:1.4",
      "pali": "imāni kho, bhikkhave, pañca mātugāmassa balāni."
    },
    {
      "id": "sn37.26:1.5",
      "pali": "Imehi kho, bhikkhave, pañcahi balehi samannāgato mātugāmo sāmikaṁ pasayha agāraṁ ajjhāvasatī”ti."
    },
    {
      "id": "sn37.26:1.6",
      "pali": "Dutiyaṁ."
    }
  ]
}
