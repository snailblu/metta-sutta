{
  "uid": "sn28.7",
  "title": "Ākiñcaññāyatanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn28.7:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn28.7:1.2",
      "pali": "Atha kho āyasmā sāriputto …pe…"
    },
    {
      "id": "sn28.7:1.3",
      "pali": "“idhāhaṁ, āvuso, sabbaso viññāṇañcāyatanaṁ samatikkamma, natthi kiñcīti ākiñcaññāyatanaṁ upasampajja viharāmi …pe…"
    },
    {
      "id": "sn28.7:1.4",
      "pali": "vuṭṭhitoti vā”ti."
    },
    {
      "id": "sn28.7:1.5",
      "pali": "Sattamaṁ."
    }
  ]
}
