{
  "uid": "sn47.42",
  "title": "Samudayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.42:1.1",
      "pali": "“Catunnaṁ, bhikkhave, satipaṭṭhānānaṁ samudayañca atthaṅgamañca desessāmi."
    },
    {
      "id": "sn47.42:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn47.42:1.3",
      "pali": "Ko ca, bhikkhave, kāyassa samudayo?"
    },
    {
      "id": "sn47.42:1.4",
      "pali": "Āhārasamudayā kāyassa samudayo;"
    },
    {
      "id": "sn47.42:1.5",
      "pali": "āhāranirodhā kāyassa atthaṅgamo."
    },
    {
      "id": "sn47.42:1.6",
      "pali": "Phassasamudayā vedanānaṁ samudayo;"
    },
    {
      "id": "sn47.42:1.7",
      "pali": "phassanirodhā vedanānaṁ atthaṅgamo."
    },
    {
      "id": "sn47.42:1.8",
      "pali": "Nāmarūpasamudayā cittassa samudayo;"
    },
    {
      "id": "sn47.42:1.9",
      "pali": "nāmarūpanirodhā cittassa atthaṅgamo."
    },
    {
      "id": "sn47.42:1.10",
      "pali": "Manasikārasamudayā dhammānaṁ samudayo;"
    },
    {
      "id": "sn47.42:1.11",
      "pali": "manasikāranirodhā dhammānaṁ atthaṅgamo”ti."
    },
    {
      "id": "sn47.42:1.12",
      "pali": "Dutiyaṁ."
    }
  ]
}
