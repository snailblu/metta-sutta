{
  "uid": "sn22.5",
  "title": "Samādhisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.5:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn22.5:1.2",
      "pali": "…pe… sāvatthiyaṁ …"
    },
    {
      "id": "sn22.5:1.3",
      "pali": "tatra kho …pe… etadavoca:"
    },
    {
      "id": "sn22.5:1.4",
      "pali": "“samādhiṁ, bhikkhave, bhāvetha;"
    },
    {
      "id": "sn22.5:1.5",
      "pali": "samāhito, bhikkhave, bhikkhu yathābhūtaṁ pajānāti."
    },
    {
      "id": "sn22.5:1.6",
      "pali": "Kiñca yathābhūtaṁ pajānāti?"
    },
    {
      "id": "sn22.5:1.7",
      "pali": "Rūpassa samudayañca atthaṅgamañca, vedanāya samudayañca atthaṅgamañca, saññāya samudayañca atthaṅgamañca, saṅkhārānaṁ samudayañca atthaṅgamañca, viññāṇassa samudayañca atthaṅgamañca."
    },
    {
      "id": "sn22.5:2.1",
      "pali": "Ko ca, bhikkhave, rūpassa samudayo, ko vedanāya samudayo, ko saññāya samudayo, ko saṅkhārānaṁ samudayo, ko viññāṇassa samudayo?"
    },
    {
      "id": "sn22.5:2.2",
      "pali": "Idha, bhikkhave, bhikkhu abhinandati abhivadati ajjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:3.1",
      "pali": "Kiñca abhinandati abhivadati ajjhosāya tiṭṭhati?"
    },
    {
      "id": "sn22.5:3.2",
      "pali": "Rūpaṁ abhinandati abhivadati ajjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:3.3",
      "pali": "Tassa rūpaṁ abhinandato abhivadato ajjhosāya tiṭṭhato uppajjati nandī."
    },
    {
      "id": "sn22.5:3.4",
      "pali": "Yā rūpe nandī tadupādānaṁ."
    },
    {
      "id": "sn22.5:3.5",
      "pali": "Tassupādānapaccayā bhavo;"
    },
    {
      "id": "sn22.5:3.6",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn22.5:3.7",
      "pali": "jātipaccayā jarāmaraṇaṁ sokaparidevadukkhadomanassupāyāsā sambhavanti."
    },
    {
      "id": "sn22.5:3.8",
      "pali": "Evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn22.5:4.1",
      "pali": "Vedanaṁ abhinandati …pe…"
    },
    {
      "id": "sn22.5:4.2",
      "pali": "saññaṁ abhinandati …"
    },
    {
      "id": "sn22.5:4.3",
      "pali": "saṅkhāre abhinandati …"
    },
    {
      "id": "sn22.5:4.4",
      "pali": "viññāṇaṁ abhinandati abhivadati ajjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:4.5",
      "pali": "Tassa viññāṇaṁ abhinandato abhivadato ajjhosāya tiṭṭhato uppajjati nandī."
    },
    {
      "id": "sn22.5:4.6",
      "pali": "Yā viññāṇe nandī tadupādānaṁ."
    },
    {
      "id": "sn22.5:4.7",
      "pali": "Tassupādānapaccayā bhavo;"
    },
    {
      "id": "sn22.5:4.8",
      "pali": "bhavapaccayā jāti;"
    },
    {
      "id": "sn22.5:4.9",
      "pali": "jātipaccayā …pe…"
    },
    {
      "id": "sn22.5:4.10",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn22.5:5.1",
      "pali": "Ayaṁ, bhikkhave, rūpassa samudayo;"
    },
    {
      "id": "sn22.5:5.2",
      "pali": "ayaṁ vedanāya samudayo;"
    },
    {
      "id": "sn22.5:5.3",
      "pali": "ayaṁ saññāya samudayo;"
    },
    {
      "id": "sn22.5:5.4",
      "pali": "ayaṁ saṅkhārānaṁ samudayo;"
    },
    {
      "id": "sn22.5:5.5",
      "pali": "ayaṁ viññāṇassa samudayo."
    },
    {
      "id": "sn22.5:6.1",
      "pali": "Ko ca, bhikkhave, rūpassa atthaṅgamo, ko vedanāya …"
    },
    {
      "id": "sn22.5:6.2",
      "pali": "ko saññāya …"
    },
    {
      "id": "sn22.5:6.3",
      "pali": "ko saṅkhārānaṁ …"
    },
    {
      "id": "sn22.5:6.4",
      "pali": "ko viññāṇassa atthaṅgamo?"
    },
    {
      "id": "sn22.5:7.1",
      "pali": "Idha, bhikkhave, nābhinandati nābhivadati nājjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:8.1",
      "pali": "Kiñca nābhinandati nābhivadati nājjhosāya tiṭṭhati?"
    },
    {
      "id": "sn22.5:8.2",
      "pali": "Rūpaṁ nābhinandati nābhivadati nājjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:8.3",
      "pali": "Tassa rūpaṁ anabhinandato anabhivadato anajjhosāya tiṭṭhato yā rūpe nandī sā nirujjhati."
    },
    {
      "id": "sn22.5:8.4",
      "pali": "Tassa nandīnirodhā upādānanirodho;"
    },
    {
      "id": "sn22.5:8.5",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn22.5:8.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn22.5:9.1",
      "pali": "Vedanaṁ nābhinandati nābhivadati nājjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:9.2",
      "pali": "Tassa vedanaṁ anabhinandato anabhivadato anajjhosāya tiṭṭhato yā vedanāya nandī sā nirujjhati."
    },
    {
      "id": "sn22.5:9.3",
      "pali": "Tassa nandīnirodhā upādānanirodho;"
    },
    {
      "id": "sn22.5:9.4",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn22.5:9.5",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn22.5:10.1",
      "pali": "Saññaṁ nābhinandati …pe…"
    },
    {
      "id": "sn22.5:10.2",
      "pali": "saṅkhāre nābhinandati nābhivadati nājjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:10.3",
      "pali": "Tassa saṅkhāre anabhinandato anabhivadato anajjhosāya tiṭṭhato yā saṅkhāresu nandī sā nirujjhati."
    },
    {
      "id": "sn22.5:10.4",
      "pali": "Tassa nandīnirodhā upādānanirodho;"
    },
    {
      "id": "sn22.5:10.5",
      "pali": "upādānanirodhā bhavanirodho …pe…"
    },
    {
      "id": "sn22.5:10.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn22.5:11.1",
      "pali": "Viññāṇaṁ nābhinandati nābhivadati nājjhosāya tiṭṭhati."
    },
    {
      "id": "sn22.5:11.2",
      "pali": "Tassa viññāṇaṁ anabhinandato anabhivadato anajjhosāya tiṭṭhato yā viññāṇe nandī sā nirujjhati."
    },
    {
      "id": "sn22.5:11.3",
      "pali": "Tassa nandīnirodhā upādānanirodho …pe…"
    },
    {
      "id": "sn22.5:11.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn22.5:12.1",
      "pali": "Ayaṁ, bhikkhave, rūpassa atthaṅgamo, ayaṁ vedanāya atthaṅgamo, ayaṁ saññāya atthaṅgamo, ayaṁ saṅkhārānaṁ atthaṅgamo, ayaṁ viññāṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn22.5:12.2",
      "pali": "Pañcamaṁ."
    }
  ]
}
