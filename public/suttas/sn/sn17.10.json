{
  "uid": "sn17.10",
  "title": "Sagāthakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.10:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.10:1.2",
      "pali": "“Dāruṇo, bhikkhave, lābhasakkārasiloko …pe… adhigamāya."
    },
    {
      "id": "sn17.10:1.3",
      "pali": "Idhāhaṁ, bhikkhave, ekaccaṁ puggalaṁ passāmi sakkārena abhibhūtaṁ pariyādiṇṇacittaṁ, kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapannaṁ."
    },
    {
      "id": "sn17.10:1.4",
      "pali": "Idha panāhaṁ, bhikkhave, ekaccaṁ puggalaṁ passāmi asakkārena abhibhūtaṁ pariyādiṇṇacittaṁ, kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapannaṁ."
    },
    {
      "id": "sn17.10:1.5",
      "pali": "Idha panāhaṁ, bhikkhave, ekaccaṁ puggalaṁ passāmi sakkārena ca asakkārena ca tadubhayena abhibhūtaṁ pariyādiṇṇacittaṁ, kāyassa bhedā paraṁ maraṇā apāyaṁ duggatiṁ vinipātaṁ nirayaṁ upapannaṁ."
    },
    {
      "id": "sn17.10:1.6",
      "pali": "Evaṁ dāruṇo kho, bhikkhave, lābhasakkārasiloko …pe…"
    },
    {
      "id": "sn17.10:1.7",
      "pali": "evañhi vo, bhikkhave, sikkhitabban”ti."
    },
    {
      "id": "sn17.10:2.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn17.10:2.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn17.10:3.1",
      "pali": "“Yassa sakkariyamānassa,"
    },
    {
      "id": "sn17.10:3.2",
      "pali": "asakkārena cūbhayaṁ;"
    },
    {
      "id": "sn17.10:3.3",
      "pali": "Samādhi na vikampati,"
    },
    {
      "id": "sn17.10:3.4",
      "pali": "appamāṇavihārino."
    },
    {
      "id": "sn17.10:4.1",
      "pali": "Taṁ jhāyinaṁ sātatikaṁ,"
    },
    {
      "id": "sn17.10:4.2",
      "pali": "sukhumaṁ diṭṭhivipassakaṁ;"
    },
    {
      "id": "sn17.10:4.3",
      "pali": "Upādānakkhayārāmaṁ,"
    },
    {
      "id": "sn17.10:4.4",
      "pali": "āhu sappuriso itī”ti."
    },
    {
      "id": "sn17.10:4.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn17.10:4.6",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn17.10:5.1",
      "pali": "Dāruṇo baḷisaṁ kummaṁ,"
    },
    {
      "id": "sn17.10:5.2",
      "pali": "dīghalomi ca mīḷhakaṁ;"
    },
    {
      "id": "sn17.10:5.3",
      "pali": "Asani diddhaṁ siṅgālaṁ,"
    },
    {
      "id": "sn17.10:5.4",
      "pali": "verambhena sagāthakanti."
    }
  ]
}
