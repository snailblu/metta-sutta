{
  "uid": "sn7.18",
  "title": "Kaṭṭhahārasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.18:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā kosalesu viharati aññatarasmiṁ vanasaṇḍe."
    },
    {
      "id": "sn7.18:1.2",
      "pali": "Tena kho pana samayena aññatarassa bhāradvājagottassa brāhmaṇassa sambahulā antevāsikā kaṭṭhahārakā māṇavakā yena vanasaṇḍo tenupasaṅkamiṁsu; upasaṅkamitvā addasaṁsu bhagavantaṁ tasmiṁ vanasaṇḍe nisinnaṁ pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā. Disvāna yena bhāradvājagotto brāhmaṇo tenupasaṅkamiṁsu; upasaṅkamitvā bhāradvājagottaṁ brāhmaṇaṁ etadavocuṁ:"
    },
    {
      "id": "sn7.18:1.3",
      "pali": "“yagghe bhavaṁ jāneyyāsi."
    },
    {
      "id": "sn7.18:1.4",
      "pali": "Asukasmiṁ vanasaṇḍe samaṇo nisinno pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā”."
    },
    {
      "id": "sn7.18:1.5",
      "pali": "Atha kho bhāradvājagotto brāhmaṇo tehi māṇavakehi saddhiṁ yena so vanasaṇḍo tenupasaṅkami."
    },
    {
      "id": "sn7.18:1.6",
      "pali": "Addasā kho bhagavantaṁ tasmiṁ vanasaṇḍe nisinnaṁ pallaṅkaṁ ābhujitvā ujuṁ kāyaṁ paṇidhāya parimukhaṁ satiṁ upaṭṭhapetvā."
    },
    {
      "id": "sn7.18:1.7",
      "pali": "Disvāna yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.18:2.1",
      "pali": "“Gambhīrarūpe bahubherave vane,"
    },
    {
      "id": "sn7.18:2.2",
      "pali": "Suññaṁ araññaṁ vijanaṁ vigāhiya;"
    },
    {
      "id": "sn7.18:2.3",
      "pali": "Aniñjamānena ṭhitena vaggunā,"
    },
    {
      "id": "sn7.18:2.4",
      "pali": "Sucārurūpaṁ vata bhikkhu jhāyasi."
    },
    {
      "id": "sn7.18:3.1",
      "pali": "Na yattha gītaṁ napi yattha vāditaṁ,"
    },
    {
      "id": "sn7.18:3.2",
      "pali": "Eko araññe vanavassito muni;"
    },
    {
      "id": "sn7.18:3.3",
      "pali": "Accherarūpaṁ paṭibhāti maṁ idaṁ,"
    },
    {
      "id": "sn7.18:3.4",
      "pali": "Yadekako pītimano vane vase."
    },
    {
      "id": "sn7.18:4.1",
      "pali": "Maññāmahaṁ lokādhipatisahabyataṁ,"
    },
    {
      "id": "sn7.18:4.2",
      "pali": "Ākaṅkhamāno tidivaṁ anuttaraṁ;"
    },
    {
      "id": "sn7.18:4.3",
      "pali": "Kasmā bhavaṁ vijanamaraññamassito,"
    },
    {
      "id": "sn7.18:4.4",
      "pali": "Tapo idha kubbasi brahmapattiyā”ti."
    },
    {
      "id": "sn7.18:5.1",
      "pali": "“Yā kāci kaṅkhā abhinandanā vā,"
    },
    {
      "id": "sn7.18:5.2",
      "pali": "Anekadhātūsu puthū sadāsitā;"
    },
    {
      "id": "sn7.18:5.3",
      "pali": "Aññāṇamūlappabhavā pajappitā,"
    },
    {
      "id": "sn7.18:5.4",
      "pali": "Sabbā mayā byantikatā samūlikā."
    },
    {
      "id": "sn7.18:6.1",
      "pali": "Svāhaṁ akaṅkho asito anūpayo,"
    },
    {
      "id": "sn7.18:6.2",
      "pali": "Sabbesu dhammesu visuddhadassano;"
    },
    {
      "id": "sn7.18:6.3",
      "pali": "Pappuyya sambodhimanuttaraṁ sivaṁ,"
    },
    {
      "id": "sn7.18:6.4",
      "pali": "Jhāyāmahaṁ brahma raho visārado”ti."
    },
    {
      "id": "sn7.18:7.1",
      "pali": "Evaṁ vutte, bhāradvājagotto brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.18:7.2",
      "pali": "“abhikkantaṁ, bho gotama, abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.18:7.3",
      "pali": "ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
