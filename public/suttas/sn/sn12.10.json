{
  "uid": "sn12.10",
  "title": "Gotamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.10:1.1",
      "pali": "“Pubbeva me, bhikkhave, sambodhā anabhisambuddhassa bodhisattasseva sato etadahosi:"
    },
    {
      "id": "sn12.10:1.2",
      "pali": "‘kicchaṁ vatāyaṁ loko āpanno jāyati ca jīyati ca mīyati ca cavati ca upapajjati ca."
    },
    {
      "id": "sn12.10:1.3",
      "pali": "Atha ca panimassa dukkhassa nissaraṇaṁ nappajānāti jarāmaraṇassa."
    },
    {
      "id": "sn12.10:1.4",
      "pali": "Kudāssu nāma imassa dukkhassa nissaraṇaṁ paññāyissati jarāmaraṇassā’ti?"
    },
    {
      "id": "sn12.10:2.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.10:2.2",
      "pali": "‘kimhi nu kho sati jarāmaraṇaṁ hoti, kiṁpaccayā jarāmaraṇan’ti?"
    },
    {
      "id": "sn12.10:2.3",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.10:2.4",
      "pali": "‘jātiyā kho sati jarāmaraṇaṁ hoti, jātipaccayā jarāmaraṇan’ti."
    },
    {
      "id": "sn12.10:3.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.10:3.2",
      "pali": "‘kimhi nu kho sati jāti hoti …pe…"
    },
    {
      "id": "sn12.10:3.3",
      "pali": "bhavo …"
    },
    {
      "id": "sn12.10:3.4",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.10:3.5",
      "pali": "taṇhā …"
    },
    {
      "id": "sn12.10:3.6",
      "pali": "vedanā …"
    },
    {
      "id": "sn12.10:3.7",
      "pali": "phasso …"
    },
    {
      "id": "sn12.10:3.8",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.10:3.9",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.10:3.10",
      "pali": "viññāṇaṁ …"
    },
    {
      "id": "sn12.10:3.11",
      "pali": "saṅkhārā honti, kiṁpaccayā saṅkhārā’ti?"
    },
    {
      "id": "sn12.10:3.12",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.10:3.13",
      "pali": "‘avijjāya kho sati saṅkhārā honti, avijjāpaccayā saṅkhārā’ti."
    },
    {
      "id": "sn12.10:4.1",
      "pali": "Iti hidaṁ avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.10:4.2",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.10:4.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.10:4.4",
      "pali": "‘Samudayo, samudayo’ti kho me, bhikkhave, pubbe ananussutesu dhammesu cakkhuṁ udapādi, ñāṇaṁ udapādi, paññā udapādi, vijjā udapādi, āloko udapādi."
    },
    {
      "id": "sn12.10:5.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.10:5.2",
      "pali": "‘kimhi nu kho asati jarāmaraṇaṁ na hoti, kissa nirodhā jarāmaraṇanirodho’ti?"
    },
    {
      "id": "sn12.10:5.3",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.10:5.4",
      "pali": "‘jātiyā kho asati jarāmaraṇaṁ na hoti, jātinirodhā jarāmaraṇanirodho’ti."
    },
    {
      "id": "sn12.10:6.1",
      "pali": "Tassa mayhaṁ, bhikkhave, etadahosi:"
    },
    {
      "id": "sn12.10:6.2",
      "pali": "‘kimhi nu kho asati jāti na hoti …pe…"
    },
    {
      "id": "sn12.10:6.3",
      "pali": "bhavo …"
    },
    {
      "id": "sn12.10:6.4",
      "pali": "upādānaṁ …"
    },
    {
      "id": "sn12.10:6.5",
      "pali": "taṇhā …"
    },
    {
      "id": "sn12.10:6.6",
      "pali": "vedanā …"
    },
    {
      "id": "sn12.10:6.7",
      "pali": "phasso …"
    },
    {
      "id": "sn12.10:6.8",
      "pali": "saḷāyatanaṁ …"
    },
    {
      "id": "sn12.10:6.9",
      "pali": "nāmarūpaṁ …"
    },
    {
      "id": "sn12.10:6.10",
      "pali": "viññāṇaṁ …"
    },
    {
      "id": "sn12.10:6.11",
      "pali": "saṅkhārā na honti, kissa nirodhā saṅkhāranirodho’ti?"
    },
    {
      "id": "sn12.10:6.12",
      "pali": "Tassa mayhaṁ, bhikkhave, yoniso manasikārā ahu paññāya abhisamayo:"
    },
    {
      "id": "sn12.10:6.13",
      "pali": "‘avijjāya kho asati saṅkhārā na honti, avijjānirodhā saṅkhāranirodho’ti."
    },
    {
      "id": "sn12.10:7.1",
      "pali": "Iti hidaṁ avijjānirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.10:7.2",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.10:7.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.10:7.4",
      "pali": "‘Nirodho, nirodho’ti kho me, bhikkhave, pubbe ananussutesu dhammesu cakkhuṁ udapādi, ñāṇaṁ udapādi, paññā udapādi, vijjā udapādi, āloko udapādī”ti."
    },
    {
      "id": "sn12.10:7.5",
      "pali": "Dasamo."
    },
    {
      "id": "sn12.10:7.6",
      "pali": "Buddhavaggo paṭhamo."
    },
    {
      "id": "sn12.10:8.1",
      "pali": "Desanā vibhaṅgapaṭipadā ca,"
    },
    {
      "id": "sn12.10:8.2",
      "pali": "Vipassī sikhī ca vessabhū;"
    },
    {
      "id": "sn12.10:8.3",
      "pali": "Kakusandho koṇāgamano kassapo,"
    },
    {
      "id": "sn12.10:8.4",
      "pali": "Mahāsakyamuni ca gotamoti."
    }
  ]
}
