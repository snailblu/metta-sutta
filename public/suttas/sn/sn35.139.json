{
  "uid": "sn35.139",
  "title": "Dutiyanatumhākasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.139:1.1",
      "pali": "“Yaṁ, bhikkhave, na tumhākaṁ, taṁ pajahatha."
    },
    {
      "id": "sn35.139:1.2",
      "pali": "Taṁ vo pahīnaṁ hitāya sukhāya bhavissati."
    },
    {
      "id": "sn35.139:1.3",
      "pali": "Kiñca, bhikkhave, na tumhākaṁ?"
    },
    {
      "id": "sn35.139:1.4",
      "pali": "Rūpā, bhikkhave, na tumhākaṁ;"
    },
    {
      "id": "sn35.139:1.5",
      "pali": "te pajahatha. Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.139:1.6",
      "pali": "Saddā …"
    },
    {
      "id": "sn35.139:1.7",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.139:1.8",
      "pali": "rasā …"
    },
    {
      "id": "sn35.139:1.9",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.139:1.10",
      "pali": "dhammā na tumhākaṁ; te pajahatha."
    },
    {
      "id": "sn35.139:1.11",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissanti."
    },
    {
      "id": "sn35.139:1.12",
      "pali": "Seyyathāpi, bhikkhave, yaṁ imasmiṁ jetavane tiṇakaṭṭha …pe…"
    },
    {
      "id": "sn35.139:1.13",
      "pali": "evameva kho, bhikkhave, rūpā na tumhākaṁ; te pajahatha."
    },
    {
      "id": "sn35.139:1.14",
      "pali": "Te vo pahīnā hitāya sukhāya bhavissantī”ti …."
    },
    {
      "id": "sn35.139:1.15",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
