{
  "uid": "sn7.13",
  "title": "Devahitasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn7.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn7.13:1.2",
      "pali": "Tena kho pana samayena bhagavā vātehābādhiko hoti;"
    },
    {
      "id": "sn7.13:1.3",
      "pali": "āyasmā ca upavāṇo bhagavato upaṭṭhāko hoti."
    },
    {
      "id": "sn7.13:1.4",
      "pali": "Atha kho bhagavā āyasmantaṁ upavāṇaṁ āmantesi:"
    },
    {
      "id": "sn7.13:1.5",
      "pali": "“iṅgha me tvaṁ, upavāṇa, uṇhodakaṁ jānāhī”ti."
    },
    {
      "id": "sn7.13:1.6",
      "pali": "“Evaṁ, bhante”ti kho āyasmā upavāṇo bhagavato paṭissutvā nivāsetvā pattacīvaramādāya yena devahitassa brāhmaṇassa nivesanaṁ tenupasaṅkami; upasaṅkamitvā tuṇhībhūto ekamantaṁ aṭṭhāsi."
    },
    {
      "id": "sn7.13:1.7",
      "pali": "Addasā kho devahito brāhmaṇo āyasmantaṁ upavāṇaṁ tuṇhībhūtaṁ ekamantaṁ ṭhitaṁ."
    },
    {
      "id": "sn7.13:1.8",
      "pali": "Disvāna āyasmantaṁ upavāṇaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.13:2.1",
      "pali": "“Tuṇhībhūto bhavaṁ tiṭṭhaṁ,"
    },
    {
      "id": "sn7.13:2.2",
      "pali": "muṇḍo saṅghāṭipāruto;"
    },
    {
      "id": "sn7.13:2.3",
      "pali": "Kiṁ patthayāno kiṁ esaṁ,"
    },
    {
      "id": "sn7.13:2.4",
      "pali": "kiṁ nu yācitumāgato”ti."
    },
    {
      "id": "sn7.13:3.1",
      "pali": "“Arahaṁ sugato loke,"
    },
    {
      "id": "sn7.13:3.2",
      "pali": "vātehābādhiko muni;"
    },
    {
      "id": "sn7.13:3.3",
      "pali": "Sace uṇhodakaṁ atthi,"
    },
    {
      "id": "sn7.13:3.4",
      "pali": "munino dehi brāhmaṇa."
    },
    {
      "id": "sn7.13:4.1",
      "pali": "Pūjito pūjaneyyānaṁ,"
    },
    {
      "id": "sn7.13:4.2",
      "pali": "sakkareyyāna sakkato;"
    },
    {
      "id": "sn7.13:4.3",
      "pali": "Apacito apaceyyānaṁ,"
    },
    {
      "id": "sn7.13:4.4",
      "pali": "tassa icchāmi hātave”ti."
    },
    {
      "id": "sn7.13:5.1",
      "pali": "Atha kho devahito brāhmaṇo uṇhodakassa kājaṁ purisena gāhāpetvā phāṇitassa ca puṭaṁ āyasmato upavāṇassa pādāsi."
    },
    {
      "id": "sn7.13:5.2",
      "pali": "Atha kho āyasmā upavāṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ uṇhodakena nhāpetvā uṇhodakena phāṇitaṁ āloletvā bhagavato pādāsi."
    },
    {
      "id": "sn7.13:5.3",
      "pali": "Atha kho bhagavato ābādho paṭippassambhi."
    },
    {
      "id": "sn7.13:6.1",
      "pali": "Atha kho devahito brāhmaṇo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavatā saddhiṁ sammodi."
    },
    {
      "id": "sn7.13:6.2",
      "pali": "Sammodanīyaṁ kathaṁ sāraṇīyaṁ vītisāretvā ekamantaṁ nisīdi."
    },
    {
      "id": "sn7.13:6.3",
      "pali": "Ekamantaṁ nisinno kho devahito brāhmaṇo bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn7.13:7.1",
      "pali": "“Kattha dajjā deyyadhammaṁ,"
    },
    {
      "id": "sn7.13:7.2",
      "pali": "kattha dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "sn7.13:7.3",
      "pali": "Kathañhi yajamānassa,"
    },
    {
      "id": "sn7.13:7.4",
      "pali": "kathaṁ ijjhati dakkhiṇā”ti."
    },
    {
      "id": "sn7.13:8.1",
      "pali": "“Pubbenivāsaṁ yo vedī,"
    },
    {
      "id": "sn7.13:8.2",
      "pali": "saggāpāyañca passati;"
    },
    {
      "id": "sn7.13:8.3",
      "pali": "Atho jātikkhayaṁ patto,"
    },
    {
      "id": "sn7.13:8.4",
      "pali": "abhiññāvosito muni."
    },
    {
      "id": "sn7.13:9.1",
      "pali": "Ettha dajjā deyyadhammaṁ,"
    },
    {
      "id": "sn7.13:9.2",
      "pali": "ettha dinnaṁ mahapphalaṁ;"
    },
    {
      "id": "sn7.13:9.3",
      "pali": "Evañhi yajamānassa,"
    },
    {
      "id": "sn7.13:9.4",
      "pali": "evaṁ ijjhati dakkhiṇā”ti."
    },
    {
      "id": "sn7.13:10.1",
      "pali": "Evaṁ vutte, devahito brāhmaṇo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn7.13:10.2",
      "pali": "“abhikkantaṁ, bho gotama …pe…"
    },
    {
      "id": "sn7.13:10.3",
      "pali": "upāsakaṁ maṁ bhavaṁ gotamo dhāretu ajjatagge pāṇupetaṁ saraṇaṁ gatan”ti."
    }
  ]
}
