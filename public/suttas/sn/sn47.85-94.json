{
  "uid": "sn47.85-94",
  "title": "Esanādisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.85-94:1.1",
      "pali": "“Tisso imā, bhikkhave, esanā."
    },
    {
      "id": "sn47.85-94:1.2",
      "pali": "Katamā tisso?"
    },
    {
      "id": "sn47.85-94:1.3",
      "pali": "Kāmesanā, bhavesanā, brahmacariyesanā”ti"
    },
    {
      "id": "sn47.85-94:1.4",
      "pali": "vitthāretabbaṁ."
    },
    {
      "id": "sn47.85-94:1.5",
      "pali": "Esanāvaggo navamo."
    },
    {
      "id": "sn47.85-94:2.1",
      "pali": "Esanā vidhā āsavo,"
    },
    {
      "id": "sn47.85-94:2.2",
      "pali": "Bhavo ca dukkhatā tisso;"
    },
    {
      "id": "sn47.85-94:2.3",
      "pali": "Khilaṁ malañca nīgho ca,"
    },
    {
      "id": "sn47.85-94:2.4",
      "pali": "Vedanā taṇhā tasināya cāti."
    }
  ]
}
