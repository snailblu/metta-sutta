{
  "uid": "sn46.17",
  "title": "Pāraṅgamasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn46.17:1.1",
      "pali": "“Sattime, bhikkhave, bojjhaṅgā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattanti."
    },
    {
      "id": "sn46.17:1.2",
      "pali": "Katame satta?"
    },
    {
      "id": "sn46.17:1.3",
      "pali": "Satisambojjhaṅgo …pe… upekkhāsambojjhaṅgo—"
    },
    {
      "id": "sn46.17:1.4",
      "pali": "ime kho, bhikkhave, satta bojjhaṅgā bhāvitā bahulīkatā apārā pāraṁ gamanāya saṁvattantīti."
    },
    {
      "id": "sn46.17:2.1",
      "pali": "Appakā te manussesu,"
    },
    {
      "id": "sn46.17:2.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "sn46.17:2.3",
      "pali": "Athāyaṁ itarā pajā,"
    },
    {
      "id": "sn46.17:2.4",
      "pali": "tīramevānudhāvati."
    },
    {
      "id": "sn46.17:3.1",
      "pali": "Ye ca kho sammadakkhāte,"
    },
    {
      "id": "sn46.17:3.2",
      "pali": "dhamme dhammānuvattino;"
    },
    {
      "id": "sn46.17:3.3",
      "pali": "Te janā pāramessanti,"
    },
    {
      "id": "sn46.17:3.4",
      "pali": "maccudheyyaṁ suduttaraṁ."
    },
    {
      "id": "sn46.17:4.1",
      "pali": "Kaṇhaṁ dhammaṁ vippahāya,"
    },
    {
      "id": "sn46.17:4.2",
      "pali": "sukkaṁ bhāvetha paṇḍito;"
    },
    {
      "id": "sn46.17:4.3",
      "pali": "Okā anokamāgamma,"
    },
    {
      "id": "sn46.17:4.4",
      "pali": "viveke yattha dūramaṁ."
    },
    {
      "id": "sn46.17:5.1",
      "pali": "Tatrābhiratimiccheyya,"
    },
    {
      "id": "sn46.17:5.2",
      "pali": "hitvā kāme akiñcano;"
    },
    {
      "id": "sn46.17:5.3",
      "pali": "Pariyodapeyya attānaṁ,"
    },
    {
      "id": "sn46.17:5.4",
      "pali": "cittaklesehi paṇḍito."
    },
    {
      "id": "sn46.17:6.1",
      "pali": "Yesaṁ sambodhiyaṅgesu,"
    },
    {
      "id": "sn46.17:6.2",
      "pali": "sammā cittaṁ subhāvitaṁ;"
    },
    {
      "id": "sn46.17:6.3",
      "pali": "Ādānappaṭinissagge,"
    },
    {
      "id": "sn46.17:6.4",
      "pali": "anupādāya ye ratā;"
    },
    {
      "id": "sn46.17:6.5",
      "pali": "Khīṇāsavā jutimanto,"
    },
    {
      "id": "sn46.17:6.6",
      "pali": "te loke parinibbutā”ti."
    },
    {
      "id": "sn46.17:6.7",
      "pali": "Sattamaṁ."
    }
  ]
}
