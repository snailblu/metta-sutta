{
  "uid": "sn17.26",
  "title": "Dutiyasamaṇabrāhmaṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn17.26:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn17.26:1.2",
      "pali": "“Ye hi keci, bhikkhave, samaṇā vā brāhmaṇā vā lābhasakkārasilokassa samudayañca atthaṅgamañca assādañca ādīnavañca nissaraṇañca yathābhūtaṁ nappajānanti …pe…"
    },
    {
      "id": "sn17.26:1.3",
      "pali": "pajānanti …pe…"
    },
    {
      "id": "sn17.26:1.4",
      "pali": "sayaṁ abhiññā sacchikatvā upasampajja viharantī”ti."
    },
    {
      "id": "sn17.26:1.5",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
