{
  "uid": "sn23.21",
  "title": "Samudayadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.21:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.21:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.21:1.3",
      "pali": "“‘samudayadhammo, samudayadhammo’ti, bhante, vuccati."
    },
    {
      "id": "sn23.21:1.4",
      "pali": "Katamo nu kho, bhante, samudayadhammo”ti?"
    },
    {
      "id": "sn23.21:1.5",
      "pali": "“Rūpaṁ kho, rādha, samudayadhammo, vedanā samudayadhammo, saññā samudayadhammo, saṅkhārā samudayadhammo, viññāṇaṁ samudayadhammo."
    },
    {
      "id": "sn23.21:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.21:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.21:1.8",
      "pali": "Ekādasamaṁ."
    }
  ]
}
