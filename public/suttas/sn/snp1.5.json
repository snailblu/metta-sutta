{
  "uid": "snp1.5",
  "title": "Cundasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "snp1.5:1.1",
      "pali": "“Pucchāmi muniṁ pahūtapaññaṁ,"
    },
    {
      "id": "snp1.5:1.2",
      "pali": "(iti cundo kammāraputto)"
    },
    {
      "id": "snp1.5:1.3",
      "pali": "Buddhaṁ dhammassāmiṁ vītataṇhaṁ;"
    },
    {
      "id": "snp1.5:1.4",
      "pali": "Dvipaduttamaṁ sārathīnaṁ pavaraṁ,"
    },
    {
      "id": "snp1.5:1.5",
      "pali": "Kati loke samaṇā tadiṅgha brūhi”."
    },
    {
      "id": "snp1.5:2.1",
      "pali": "“Caturo samaṇā na pañcamatthi,"
    },
    {
      "id": "snp1.5:2.2",
      "pali": "(cundāti bhagavā)"
    },
    {
      "id": "snp1.5:2.3",
      "pali": "Te te āvikaromi sakkhipuṭṭho;"
    },
    {
      "id": "snp1.5:2.4",
      "pali": "Maggajino maggadesako ca,"
    },
    {
      "id": "snp1.5:2.5",
      "pali": "Magge jīvati yo ca maggadūsī”."
    },
    {
      "id": "snp1.5:3.1",
      "pali": "“Kaṁ maggajinaṁ vadanti buddhā,"
    },
    {
      "id": "snp1.5:3.2",
      "pali": "(iti cundo kammāraputto)"
    },
    {
      "id": "snp1.5:3.3",
      "pali": "Maggakkhāyī kathaṁ atulyo hoti;"
    },
    {
      "id": "snp1.5:3.4",
      "pali": "Magge jīvati me brūhi puṭṭho,"
    },
    {
      "id": "snp1.5:3.5",
      "pali": "Atha me āvikarohi maggadūsiṁ”."
    },
    {
      "id": "snp1.5:4.1",
      "pali": "“Yo tiṇṇakathaṅkatho visallo,"
    },
    {
      "id": "snp1.5:4.2",
      "pali": "Nibbānābhirato anānugiddho;"
    },
    {
      "id": "snp1.5:4.3",
      "pali": "Lokassa sadevakassa netā,"
    },
    {
      "id": "snp1.5:4.4",
      "pali": "Tādiṁ maggajinaṁ vadanti buddhā."
    },
    {
      "id": "snp1.5:5.1",
      "pali": "Paramaṁ paramanti yodha ñatvā,"
    },
    {
      "id": "snp1.5:5.2",
      "pali": "Akkhāti vibhajate idheva dhammaṁ;"
    },
    {
      "id": "snp1.5:5.3",
      "pali": "Taṁ kaṅkhachidaṁ muniṁ anejaṁ,"
    },
    {
      "id": "snp1.5:5.4",
      "pali": "Dutiyaṁ bhikkhunamāhu maggadesiṁ."
    },
    {
      "id": "snp1.5:6.1",
      "pali": "Yo dhammapade sudesite,"
    },
    {
      "id": "snp1.5:6.2",
      "pali": "Magge jīvati saññato satīmā;"
    },
    {
      "id": "snp1.5:6.3",
      "pali": "Anavajjapadāni sevamāno,"
    },
    {
      "id": "snp1.5:6.4",
      "pali": "Tatiyaṁ bhikkhunamāhu maggajīviṁ."
    },
    {
      "id": "snp1.5:7.1",
      "pali": "Chadanaṁ katvāna subbatānaṁ,"
    },
    {
      "id": "snp1.5:7.2",
      "pali": "Pakkhandī kuladūsako pagabbho;"
    },
    {
      "id": "snp1.5:7.3",
      "pali": "Māyāvī asaññato palāpo,"
    },
    {
      "id": "snp1.5:7.4",
      "pali": "Patirūpena caraṁ sa maggadūsī."
    },
    {
      "id": "snp1.5:8.1",
      "pali": "Ete ca paṭivijjhi yo gahaṭṭho,"
    },
    {
      "id": "snp1.5:8.2",
      "pali": "Sutavā ariyasāvako sapañño;"
    },
    {
      "id": "snp1.5:8.3",
      "pali": "Sabbe netādisāti ñatvā,"
    },
    {
      "id": "snp1.5:8.4",
      "pali": "Iti disvā na hāpeti tassa saddhā;"
    },
    {
      "id": "snp1.5:8.5",
      "pali": "Kathaṁ hi duṭṭhena asampaduṭṭhaṁ,"
    },
    {
      "id": "snp1.5:8.6",
      "pali": "Suddhaṁ asuddhena samaṁ kareyyā”ti."
    },
    {
      "id": "snp1.5:8.7",
      "pali": "Cundasuttaṁ pañcamaṁ."
    }
  ]
}
