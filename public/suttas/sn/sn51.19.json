{
  "uid": "sn51.19",
  "title": "Iddhādidesanāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn51.19:1.1",
      "pali": "“Iddhiṁ vo, bhikkhave, desessāmi iddhipādañca iddhipādabhāvanañca iddhipādabhāvanāgāminiñca paṭipadaṁ."
    },
    {
      "id": "sn51.19:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn51.19:2.1",
      "pali": "Katamā ca, bhikkhave, iddhi?"
    },
    {
      "id": "sn51.19:2.2",
      "pali": "Idha, bhikkhave, bhikkhu anekavihitaṁ iddhividhaṁ paccanubhoti—ekopi hutvā bahudhā hoti, bahudhāpi hutvā eko hoti …pe… yāva brahmalokāpi kāyena vasaṁ vatteti—"
    },
    {
      "id": "sn51.19:2.3",
      "pali": "ayaṁ vuccati, bhikkhave, iddhi."
    },
    {
      "id": "sn51.19:3.1",
      "pali": "Katamo ca, bhikkhave, iddhipādo?"
    },
    {
      "id": "sn51.19:3.2",
      "pali": "Yo so, bhikkhave, maggo yā paṭipadā iddhilābhāya iddhipaṭilābhāya saṁvattati—"
    },
    {
      "id": "sn51.19:3.3",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādo."
    },
    {
      "id": "sn51.19:4.1",
      "pali": "Katamā ca, bhikkhave, iddhipādabhāvanā?"
    },
    {
      "id": "sn51.19:4.2",
      "pali": "Idha, bhikkhave, bhikkhu chandasamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti,"
    },
    {
      "id": "sn51.19:4.3",
      "pali": "vīriyasamādhi …pe…"
    },
    {
      "id": "sn51.19:4.4",
      "pali": "cittasamādhi …"
    },
    {
      "id": "sn51.19:4.5",
      "pali": "vīmaṁsāsamādhippadhānasaṅkhārasamannāgataṁ iddhipādaṁ bhāveti—"
    },
    {
      "id": "sn51.19:4.6",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādabhāvanā."
    },
    {
      "id": "sn51.19:5.1",
      "pali": "Katamā ca, bhikkhave, iddhipādabhāvanāgāminī paṭipadā?"
    },
    {
      "id": "sn51.19:5.2",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "sn51.19:5.3",
      "pali": "sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhi—"
    },
    {
      "id": "sn51.19:5.4",
      "pali": "ayaṁ vuccati, bhikkhave, iddhipādabhāvanāgāminī paṭipadā”ti."
    },
    {
      "id": "sn51.19:5.5",
      "pali": "Navamaṁ."
    }
  ]
}
