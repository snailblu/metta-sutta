{
  "uid": "sn48.25",
  "title": "Suddhakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn48.25:1.1",
      "pali": "“Chayimāni, bhikkhave, indriyāni."
    },
    {
      "id": "sn48.25:1.2",
      "pali": "Katamāni cha?"
    },
    {
      "id": "sn48.25:1.3",
      "pali": "Cakkhundriyaṁ, sotindriyaṁ, ghānindriyaṁ, jivhindriyaṁ, kāyindriyaṁ, manindriyaṁ—"
    },
    {
      "id": "sn48.25:1.4",
      "pali": "imāni kho, bhikkhave, cha indriyānī”ti."
    },
    {
      "id": "sn48.25:1.5",
      "pali": "Pañcamaṁ."
    }
  ]
}
