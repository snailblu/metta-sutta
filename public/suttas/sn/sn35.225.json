{
  "uid": "sn35.225",
  "title": "Bāhirāyatanaaniccasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.225:1.1",
      "pali": "“Rūpā, bhikkhave, aniccā. Saddā … gandhā … rasā … phoṭṭhabbā … dhammā aniccā."
    },
    {
      "id": "sn35.225:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.225:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
