{
  "uid": "sn22.32",
  "title": "Pabhaṅgusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.32:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.32:1.2",
      "pali": "“Pabhaṅguñca, bhikkhave, desessāmi appabhaṅguñca."
    },
    {
      "id": "sn22.32:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.32:1.4",
      "pali": "Kiñca, bhikkhave, pabhaṅgu, kiṁ appabhaṅgu?"
    },
    {
      "id": "sn22.32:1.5",
      "pali": "Rūpaṁ, bhikkhave, pabhaṅgu."
    },
    {
      "id": "sn22.32:1.6",
      "pali": "Yo tassa nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu."
    },
    {
      "id": "sn22.32:1.7",
      "pali": "Vedanā pabhaṅgu."
    },
    {
      "id": "sn22.32:1.8",
      "pali": "Yo tassā nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu."
    },
    {
      "id": "sn22.32:1.9",
      "pali": "Saññā pabhaṅgu …"
    },
    {
      "id": "sn22.32:1.10",
      "pali": "saṅkhārā pabhaṅgu."
    },
    {
      "id": "sn22.32:1.11",
      "pali": "Yo tesaṁ nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgu."
    },
    {
      "id": "sn22.32:1.12",
      "pali": "Viññāṇaṁ pabhaṅgu."
    },
    {
      "id": "sn22.32:1.13",
      "pali": "Yo tassa nirodho vūpasamo atthaṅgamo, idaṁ appabhaṅgū”ti."
    },
    {
      "id": "sn22.32:1.14",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn22.32:1.15",
      "pali": "Bhāravaggo tatiyo."
    },
    {
      "id": "sn22.32:2.1",
      "pali": "Bhāraṁ pariññaṁ abhijānaṁ,"
    },
    {
      "id": "sn22.32:2.2",
      "pali": "chandarāgaṁ catutthakaṁ;"
    },
    {
      "id": "sn22.32:2.3",
      "pali": "Assādā ca tayo vuttā,"
    },
    {
      "id": "sn22.32:2.4",
      "pali": "abhinandanamaṭṭhamaṁ;"
    },
    {
      "id": "sn22.32:2.5",
      "pali": "Uppādaṁ aghamūlañca,"
    },
    {
      "id": "sn22.32:2.6",
      "pali": "ekādasamo pabhaṅgūti."
    }
  ]
}
