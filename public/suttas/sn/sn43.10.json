{
  "uid": "sn43.10",
  "title": "Bojjhaṅgasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn43.10:1.1",
      "pali": "“Katamo ca, bhikkhave, asaṅkhatagāmimaggo?"
    },
    {
      "id": "sn43.10:1.2",
      "pali": "Satta bojjhaṅgā. Ayaṁ vuccati, bhikkhave, asaṅkhatagāmimaggo …pe…."
    },
    {
      "id": "sn43.10:1.3",
      "pali": "Dasamaṁ."
    }
  ]
}
