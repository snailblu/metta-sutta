{
  "uid": "sn35.78",
  "title": "Rādhaanattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.78:1.1",
      "pali": "“Yo kho, rādha, anattā tatra te chando pahātabbo."
    },
    {
      "id": "sn35.78:1.2",
      "pali": "Ko ca, rādha, anattā?"
    },
    {
      "id": "sn35.78:1.3",
      "pali": "Cakkhu kho, rādha, anattā. Tatra te chando pahātabbo."
    },
    {
      "id": "sn35.78:1.4",
      "pali": "Rūpā …"
    },
    {
      "id": "sn35.78:1.5",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.78:1.6",
      "pali": "cakkhusamphasso …"
    },
    {
      "id": "sn35.78:1.7",
      "pali": "yampidaṁ cakkhusamphassapaccayā …pe…"
    },
    {
      "id": "sn35.78:1.8",
      "pali": "mano anattā …"
    },
    {
      "id": "sn35.78:1.9",
      "pali": "dhammā …"
    },
    {
      "id": "sn35.78:1.10",
      "pali": "manoviññāṇaṁ …"
    },
    {
      "id": "sn35.78:1.11",
      "pali": "manosamphasso …"
    },
    {
      "id": "sn35.78:1.12",
      "pali": "yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi anattā. Tatra te chando pahātabbo."
    },
    {
      "id": "sn35.78:1.13",
      "pali": "Yo kho, rādha, anattā tatra te chando pahātabbo”ti."
    },
    {
      "id": "sn35.78:1.14",
      "pali": "Pañcamaṁ."
    }
  ]
}
