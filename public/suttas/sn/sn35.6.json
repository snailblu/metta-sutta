{
  "uid": "sn35.6",
  "title": "Bāhirānattasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.6:1.1",
      "pali": "“Rūpā, bhikkhave, anattā."
    },
    {
      "id": "sn35.6:1.2",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.6:1.3",
      "pali": "Saddā …pe…"
    },
    {
      "id": "sn35.6:1.4",
      "pali": "gandhā …"
    },
    {
      "id": "sn35.6:1.5",
      "pali": "rasā …"
    },
    {
      "id": "sn35.6:1.6",
      "pali": "phoṭṭhabbā …"
    },
    {
      "id": "sn35.6:1.7",
      "pali": "dhammā anattā."
    },
    {
      "id": "sn35.6:1.8",
      "pali": "Yadanattā taṁ ‘netaṁ mama, nesohamasmi, na meso attā’ti evametaṁ yathābhūtaṁ sammappaññāya daṭṭhabbaṁ."
    },
    {
      "id": "sn35.6:1.9",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.6:1.10",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn35.6:1.11",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
