{
  "uid": "sn35.97",
  "title": "Pamādavihārīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.97:1.1",
      "pali": "“Pamādavihāriñca vo, bhikkhave, desessāmi appamādavihāriñca."
    },
    {
      "id": "sn35.97:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.97:1.3",
      "pali": "Kathañca, bhikkhave, pamādavihārī hoti?"
    },
    {
      "id": "sn35.97:1.4",
      "pali": "Cakkhundriyaṁ asaṁvutassa, bhikkhave, viharato cittaṁ byāsiñcati cakkhuviññeyyesu rūpesu."
    },
    {
      "id": "sn35.97:1.5",
      "pali": "tassa byāsittacittassa pāmojjaṁ na hoti."
    },
    {
      "id": "sn35.97:1.6",
      "pali": "Pāmojje asati pīti na hoti."
    },
    {
      "id": "sn35.97:1.7",
      "pali": "Pītiyā asati passaddhi na hoti."
    },
    {
      "id": "sn35.97:1.8",
      "pali": "Passaddhiyā asati dukkhaṁ hoti."
    },
    {
      "id": "sn35.97:1.9",
      "pali": "Dukkhino cittaṁ na samādhiyati."
    },
    {
      "id": "sn35.97:1.10",
      "pali": "Asamāhite citte dhammā na pātubhavanti."
    },
    {
      "id": "sn35.97:1.11",
      "pali": "Dhammānaṁ apātubhāvā pamādavihārītveva saṅkhaṁ gacchati …pe…"
    },
    {
      "id": "sn35.97:1.12",
      "pali": "jivhindriyaṁ asaṁvutassa, bhikkhave, viharato cittaṁ byāsiñcati jivhāviññeyyesu rasesu,"
    },
    {
      "id": "sn35.97:1.13",
      "pali": "tassa byāsittacittassa …pe…"
    },
    {
      "id": "sn35.97:1.14",
      "pali": "pamādavihārītveva saṅkhaṁ gacchati …pe…"
    },
    {
      "id": "sn35.97:1.15",
      "pali": "manindriyaṁ asaṁvutassa, bhikkhave, viharato cittaṁ byāsiñcati manoviññeyyesu dhammesu,"
    },
    {
      "id": "sn35.97:1.16",
      "pali": "tassa byāsittacittassa pāmojjaṁ na hoti."
    },
    {
      "id": "sn35.97:1.17",
      "pali": "Pāmojje asati pīti na hoti."
    },
    {
      "id": "sn35.97:1.18",
      "pali": "Pītiyā asati passaddhi na hoti."
    },
    {
      "id": "sn35.97:1.19",
      "pali": "Passaddhiyā asati dukkhaṁ hoti."
    },
    {
      "id": "sn35.97:1.20",
      "pali": "Dukkhino cittaṁ na samādhiyati."
    },
    {
      "id": "sn35.97:1.21",
      "pali": "Asamāhite citte dhammā na pātubhavanti."
    },
    {
      "id": "sn35.97:1.22",
      "pali": "Dhammānaṁ apātubhāvā pamādavihārītveva saṅkhaṁ gacchati."
    },
    {
      "id": "sn35.97:1.23",
      "pali": "Evaṁ kho, bhikkhave, pamādavihārī hoti."
    },
    {
      "id": "sn35.97:2.1",
      "pali": "Kathañca, bhikkhave, appamādavihārī hoti?"
    },
    {
      "id": "sn35.97:2.2",
      "pali": "Cakkhundriyaṁ saṁvutassa, bhikkhave, viharato cittaṁ na byāsiñcati cakkhuviññeyyesu rūpesu,"
    },
    {
      "id": "sn35.97:2.3",
      "pali": "tassa abyāsittacittassa pāmojjaṁ jāyati."
    },
    {
      "id": "sn35.97:2.4",
      "pali": "Pamuditassa pīti jāyati."
    },
    {
      "id": "sn35.97:2.5",
      "pali": "Pītimanassa kāyo passambhati."
    },
    {
      "id": "sn35.97:2.6",
      "pali": "Passaddhakāyo sukhaṁ viharati."
    },
    {
      "id": "sn35.97:2.7",
      "pali": "Sukhino cittaṁ samādhiyati."
    },
    {
      "id": "sn35.97:2.8",
      "pali": "Samāhite citte dhammā pātubhavanti."
    },
    {
      "id": "sn35.97:2.9",
      "pali": "Dhammānaṁ pātubhāvā appamādavihārītveva saṅkhaṁ gacchati …pe…"
    },
    {
      "id": "sn35.97:2.10",
      "pali": "jivhindriyaṁ saṁvutassa, bhikkhave, viharato cittaṁ na byāsiñcati …pe…"
    },
    {
      "id": "sn35.97:2.11",
      "pali": "appamādavihārītveva saṅkhaṁ gacchati."
    },
    {
      "id": "sn35.97:2.12",
      "pali": "Manindriyaṁ saṁvutassa, bhikkhave, viharato cittaṁ na byāsiñcati, manoviññeyyesu dhammesu,"
    },
    {
      "id": "sn35.97:2.13",
      "pali": "tassa abyāsittacittassa pāmojjaṁ jāyati."
    },
    {
      "id": "sn35.97:2.14",
      "pali": "Pamuditassa pīti jāyati."
    },
    {
      "id": "sn35.97:2.15",
      "pali": "Pītimanassa kāyo passambhati."
    },
    {
      "id": "sn35.97:2.16",
      "pali": "Passaddhakāyo sukhaṁ viharati."
    },
    {
      "id": "sn35.97:2.17",
      "pali": "Sukhino cittaṁ samādhiyati."
    },
    {
      "id": "sn35.97:2.18",
      "pali": "Samāhite citte dhammā pātubhavanti."
    },
    {
      "id": "sn35.97:2.19",
      "pali": "Dhammānaṁ pātubhāvā appamādavihārītveva saṅkhaṁ gacchati."
    },
    {
      "id": "sn35.97:2.20",
      "pali": "Evaṁ kho, bhikkhave, appamādavihārī hotī”ti."
    },
    {
      "id": "sn35.97:2.21",
      "pali": "Catutthaṁ."
    }
  ]
}
