{
  "uid": "sn4.25",
  "title": "Māradhītusutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.25:1.1",
      "pali": "Atha kho māro pāpimā bhagavato santike imā nibbejanīyā gāthāyo abhāsitvā tamhā ṭhānā apakkamma bhagavato avidūre pathaviyaṁ pallaṅkena nisīdi tuṇhībhūto maṅkubhūto pattakkhandho adhomukho pajjhāyanto appaṭibhāno kaṭṭhena bhūmiṁ vilikhanto."
    },
    {
      "id": "sn4.25:1.2",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro yena māro pāpimā tenupasaṅkamiṁsu; upasaṅkamitvā māraṁ pāpimantaṁ gāthāya ajjhabhāsiṁsu:"
    },
    {
      "id": "sn4.25:2.1",
      "pali": "“Kenāsi dummano tāta,"
    },
    {
      "id": "sn4.25:2.2",
      "pali": "purisaṁ kaṁ nu socasi;"
    },
    {
      "id": "sn4.25:2.3",
      "pali": "Mayaṁ taṁ rāgapāsena,"
    },
    {
      "id": "sn4.25:2.4",
      "pali": "āraññamiva kuñjaraṁ;"
    },
    {
      "id": "sn4.25:2.5",
      "pali": "Bandhitvā ānayissāma,"
    },
    {
      "id": "sn4.25:2.6",
      "pali": "vasago te bhavissatī”ti."
    },
    {
      "id": "sn4.25:3.1",
      "pali": "“Arahaṁ sugato loke,"
    },
    {
      "id": "sn4.25:3.2",
      "pali": "na rāgena suvānayo;"
    },
    {
      "id": "sn4.25:3.3",
      "pali": "Māradheyyaṁ atikkanto,"
    },
    {
      "id": "sn4.25:3.4",
      "pali": "tasmā socāmahaṁ bhusan”ti."
    },
    {
      "id": "sn4.25:4.1",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn4.25:4.2",
      "pali": "“pāde te, samaṇa, paricāremā”ti."
    },
    {
      "id": "sn4.25:4.3",
      "pali": "Atha kho bhagavā na manasākāsi, yathā taṁ anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:5.1",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro ekamantaṁ apakkamma evaṁ samacintesuṁ:"
    },
    {
      "id": "sn4.25:5.2",
      "pali": "“uccāvacā kho purisānaṁ adhippāyā."
    },
    {
      "id": "sn4.25:5.3",
      "pali": "Yannūna mayaṁ ekasataṁ ekasataṁ kumārivaṇṇasataṁ abhinimmineyyāmā”ti."
    },
    {
      "id": "sn4.25:5.4",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro ekasataṁ ekasataṁ kumārivaṇṇasataṁ abhinimminitvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn4.25:5.5",
      "pali": "“pāde te, samaṇa, paricāremā”ti."
    },
    {
      "id": "sn4.25:5.6",
      "pali": "Tampi bhagavā na manasākāsi, yathā taṁ anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:6.1",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro ekamantaṁ apakkamma evaṁ samacintesuṁ:"
    },
    {
      "id": "sn4.25:6.2",
      "pali": "“uccāvacā kho purisānaṁ adhippāyā."
    },
    {
      "id": "sn4.25:6.3",
      "pali": "Yannūna mayaṁ ekasataṁ ekasataṁ avijātavaṇṇasataṁ abhinimmineyyāmā”ti."
    },
    {
      "id": "sn4.25:6.4",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro ekasataṁ ekasataṁ avijātavaṇṇasataṁ abhinimminitvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn4.25:6.5",
      "pali": "“pāde te, samaṇa, paricāremā”ti."
    },
    {
      "id": "sn4.25:6.6",
      "pali": "Tampi bhagavā na manasākāsi, yathā taṁ anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:7.1",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:7.2",
      "pali": "yannūna mayaṁ ekasataṁ ekasataṁ sakiṁ vijātavaṇṇasataṁ abhinimmineyyāmāti."
    },
    {
      "id": "sn4.25:7.3",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:7.4",
      "pali": "sakiṁ vijātavaṇṇasataṁ abhinimminitvā yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā bhagavantaṁ etadavocuṁ:"
    },
    {
      "id": "sn4.25:7.5",
      "pali": "“pāde te, samaṇa, paricāremā”ti."
    },
    {
      "id": "sn4.25:7.6",
      "pali": "Tampi bhagavā na manasākāsi, yathā taṁ anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:8.1",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:8.2",
      "pali": "yannūna mayaṁ ekasataṁ ekasataṁ duvijātavaṇṇasataṁ abhinimmineyyāmāti."
    },
    {
      "id": "sn4.25:8.3",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:8.4",
      "pali": "duvijātavaṇṇasataṁ abhinimminitvā yena bhagavā …pe…"
    },
    {
      "id": "sn4.25:8.5",
      "pali": "yathā taṁ anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:8.6",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:8.7",
      "pali": "majjhimitthivaṇṇasataṁ abhinimmineyyāmā”ti."
    },
    {
      "id": "sn4.25:8.8",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:8.9",
      "pali": "majjhimitthivaṇṇasataṁ abhinimminitvā …pe…"
    },
    {
      "id": "sn4.25:8.10",
      "pali": "anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:9.1",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:9.2",
      "pali": "mahitthivaṇṇasataṁ abhinimmineyyāmāti."
    },
    {
      "id": "sn4.25:9.3",
      "pali": "Atha kho taṇhā ca …pe…"
    },
    {
      "id": "sn4.25:9.4",
      "pali": "mahitthivaṇṇasataṁ abhinimminitvā yena bhagavā …pe…"
    },
    {
      "id": "sn4.25:9.5",
      "pali": "anuttare upadhisaṅkhaye vimutto."
    },
    {
      "id": "sn4.25:9.6",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro ekamantaṁ apakkamma etadavocuṁ:"
    },
    {
      "id": "sn4.25:9.7",
      "pali": "“saccaṁ kira no pitā avoca:"
    },
    {
      "id": "sn4.25:10.1",
      "pali": "‘Arahaṁ sugato loke,"
    },
    {
      "id": "sn4.25:10.2",
      "pali": "na rāgena suvānayo;"
    },
    {
      "id": "sn4.25:10.3",
      "pali": "Māradheyyaṁ atikkanto,"
    },
    {
      "id": "sn4.25:10.4",
      "pali": "tasmā socāmahaṁ bhusan’ti."
    },
    {
      "id": "sn4.25:11.1",
      "pali": "Yañhi mayaṁ samaṇaṁ vā brāhmaṇaṁ vā avītarāgaṁ iminā upakkamena upakkameyyāma hadayaṁ vāssa phaleyya, uṇhaṁ lohitaṁ vā mukhato uggaccheyya, ummādaṁ vā pāpuṇeyya cittakkhepaṁ vā."
    },
    {
      "id": "sn4.25:11.2",
      "pali": "Seyyathā vā pana naḷo harito luto ussussati visussati milāyati;"
    },
    {
      "id": "sn4.25:11.3",
      "pali": "evameva ussusseyya visusseyya milāyeyyā”ti."
    },
    {
      "id": "sn4.25:12.1",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro yena bhagavā tenupasaṅkamiṁsu; upasaṅkamitvā ekamantaṁ aṭṭhaṁsu."
    },
    {
      "id": "sn4.25:12.2",
      "pali": "Ekamantaṁ ṭhitā kho taṇhā māradhītā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.25:13.1",
      "pali": "“Sokāvatiṇṇo nu vanamhi jhāyasi,"
    },
    {
      "id": "sn4.25:13.2",
      "pali": "Vittaṁ nu jīno uda patthayāno;"
    },
    {
      "id": "sn4.25:13.3",
      "pali": "Āguṁ nu gāmasmimakāsi kiñci,"
    },
    {
      "id": "sn4.25:13.4",
      "pali": "Kasmā janena na karosi sakkhiṁ;"
    },
    {
      "id": "sn4.25:13.5",
      "pali": "Sakkhī na sampajjati kenaci te”ti."
    },
    {
      "id": "sn4.25:14.1",
      "pali": "“Atthassa pattiṁ hadayassa santiṁ,"
    },
    {
      "id": "sn4.25:14.2",
      "pali": "Jetvāna senaṁ piyasātarūpaṁ;"
    },
    {
      "id": "sn4.25:14.3",
      "pali": "Ekohaṁ jhāyaṁ sukhamanubodhiṁ,"
    },
    {
      "id": "sn4.25:14.4",
      "pali": "Tasmā janena na karomi sakkhiṁ;"
    },
    {
      "id": "sn4.25:14.5",
      "pali": "Sakkhī na sampajjati kenaci me”ti."
    },
    {
      "id": "sn4.25:15.1",
      "pali": "Atha kho arati māradhītā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.25:16.1",
      "pali": "“Kathaṁvihārībahulodha bhikkhu,"
    },
    {
      "id": "sn4.25:16.2",
      "pali": "Pañcoghatiṇṇo atarīdha chaṭṭhaṁ;"
    },
    {
      "id": "sn4.25:16.3",
      "pali": "Kathaṁ jhāyiṁ bahulaṁ kāmasaññā,"
    },
    {
      "id": "sn4.25:16.4",
      "pali": "Paribāhirā honti aladdha yo tan”ti."
    },
    {
      "id": "sn4.25:17.1",
      "pali": "“Passaddhakāyo suvimuttacitto,"
    },
    {
      "id": "sn4.25:17.2",
      "pali": "Asaṅkharāno satimā anoko;"
    },
    {
      "id": "sn4.25:17.3",
      "pali": "Aññāya dhammaṁ avitakkajhāyī,"
    },
    {
      "id": "sn4.25:17.4",
      "pali": "Na kuppati na sarati na thino."
    },
    {
      "id": "sn4.25:18.1",
      "pali": "Evaṁvihārībahulodha bhikkhu,"
    },
    {
      "id": "sn4.25:18.2",
      "pali": "Pañcoghatiṇṇo atarīdha chaṭṭhaṁ;"
    },
    {
      "id": "sn4.25:18.3",
      "pali": "Evaṁ jhāyiṁ bahulaṁ kāmasaññā,"
    },
    {
      "id": "sn4.25:18.4",
      "pali": "Paribāhirā honti aladdha yo tan”ti."
    },
    {
      "id": "sn4.25:19.1",
      "pali": "Atha kho ragā māradhītā bhagavato santike gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.25:20.1",
      "pali": "“Acchejja taṇhaṁ gaṇasaṅghacārī,"
    },
    {
      "id": "sn4.25:20.2",
      "pali": "Addhā carissanti bahū ca saddhā;"
    },
    {
      "id": "sn4.25:20.3",
      "pali": "Bahuṁ vatāyaṁ janataṁ anoko,"
    },
    {
      "id": "sn4.25:20.4",
      "pali": "Acchejja nessati maccurājassa pāran”ti."
    },
    {
      "id": "sn4.25:21.1",
      "pali": "“Nayanti ve mahāvīrā,"
    },
    {
      "id": "sn4.25:21.2",
      "pali": "saddhammena tathāgatā;"
    },
    {
      "id": "sn4.25:21.3",
      "pali": "Dhammena nayamānānaṁ,"
    },
    {
      "id": "sn4.25:21.4",
      "pali": "kā usūyā vijānatan”ti."
    },
    {
      "id": "sn4.25:22.1",
      "pali": "Atha kho taṇhā ca arati ca ragā ca māradhītaro yena māro pāpimā tenupasaṅkamiṁsu."
    },
    {
      "id": "sn4.25:22.2",
      "pali": "Addasā kho māro pāpimā taṇhañca aratiñca ragañca māradhītaro dūratova āgacchantiyo."
    },
    {
      "id": "sn4.25:22.3",
      "pali": "Disvāna gāthāhi ajjhabhāsi:"
    },
    {
      "id": "sn4.25:23.1",
      "pali": "“Bālā kumudanāḷehi,"
    },
    {
      "id": "sn4.25:23.2",
      "pali": "pabbataṁ abhimatthatha;"
    },
    {
      "id": "sn4.25:23.3",
      "pali": "Giriṁ nakhena khanatha,"
    },
    {
      "id": "sn4.25:23.4",
      "pali": "ayo dantehi khādatha."
    },
    {
      "id": "sn4.25:24.1",
      "pali": "Selaṁva sirasūhacca,"
    },
    {
      "id": "sn4.25:24.2",
      "pali": "pātāle gādhamesatha;"
    },
    {
      "id": "sn4.25:24.3",
      "pali": "Khāṇuṁva urasāsajja,"
    },
    {
      "id": "sn4.25:24.4",
      "pali": "nibbijjāpetha gotamā”ti."
    },
    {
      "id": "sn4.25:25.1",
      "pali": "“Daddallamānā āgañchuṁ,"
    },
    {
      "id": "sn4.25:25.2",
      "pali": "taṇhā ca aratī ragā;"
    },
    {
      "id": "sn4.25:25.3",
      "pali": "Tā tattha panudī satthā,"
    },
    {
      "id": "sn4.25:25.4",
      "pali": "tūlaṁ bhaṭṭhaṁva māluto”ti."
    },
    {
      "id": "sn4.25:25.5",
      "pali": "Tatiyo vaggo."
    },
    {
      "id": "sn4.25:26.1",
      "pali": "Sambahulā samiddhi ca,"
    },
    {
      "id": "sn4.25:26.2",
      "pali": "Godhikaṁ sattavassāni;"
    },
    {
      "id": "sn4.25:26.3",
      "pali": "Dhītaraṁ desitaṁ buddha,"
    },
    {
      "id": "sn4.25:26.4",
      "pali": "Seṭṭhena imaṁ mārapañcakanti."
    },
    {
      "id": "sn4.25:26.5",
      "pali": "Mārasaṁyuttaṁ samattaṁ."
    }
  ]
}
