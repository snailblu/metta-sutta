{
  "uid": "sn22.83",
  "title": "Ānandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.83:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.83:1.2",
      "pali": "Tatra kho āyasmā ānando bhikkhū āmantesi:"
    },
    {
      "id": "sn22.83:1.3",
      "pali": "“āvuso bhikkhave”ti."
    },
    {
      "id": "sn22.83:1.4",
      "pali": "“Āvuso”ti kho te bhikkhū āyasmato ānandassa paccassosuṁ."
    },
    {
      "id": "sn22.83:1.5",
      "pali": "Āyasmā ānando etadavoca:"
    },
    {
      "id": "sn22.83:2.1",
      "pali": "“Puṇṇo nāma, āvuso, āyasmā mantāṇiputto amhākaṁ navakānaṁ sataṁ bahūpakāro hoti."
    },
    {
      "id": "sn22.83:2.2",
      "pali": "So amhe iminā ovādena ovadati:"
    },
    {
      "id": "sn22.83:2.3",
      "pali": "‘upādāya, āvuso ānanda, asmīti hoti, no anupādāya."
    },
    {
      "id": "sn22.83:2.4",
      "pali": "Kiñca upādāya asmīti hoti, no anupādāya?"
    },
    {
      "id": "sn22.83:2.5",
      "pali": "Rūpaṁ upādāya asmīti hoti, no anupādāya."
    },
    {
      "id": "sn22.83:2.6",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.83:2.7",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.83:2.8",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.83:2.9",
      "pali": "viññāṇaṁ upādāya asmīti hoti, no anupādāya."
    },
    {
      "id": "sn22.83:3.1",
      "pali": "Seyyathāpi, āvuso ānanda, itthī vā puriso vā daharo yuvā maṇḍanakajātiko ādāse vā parisuddhe pariyodāte acche vā udakapatte sakaṁ mukhanimittaṁ paccavekkhamāno upādāya passeyya, no anupādāya;"
    },
    {
      "id": "sn22.83:3.2",
      "pali": "evameva kho, āvuso ānanda, rūpaṁ upādāya asmīti hoti, no anupādāya."
    },
    {
      "id": "sn22.83:3.3",
      "pali": "Vedanaṁ …"
    },
    {
      "id": "sn22.83:3.4",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.83:3.5",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.83:3.6",
      "pali": "viññāṇaṁ upādāya asmīti hoti, no anupādāya."
    },
    {
      "id": "sn22.83:4.1",
      "pali": "Taṁ kiṁ maññasi, āvuso ānanda,"
    },
    {
      "id": "sn22.83:4.2",
      "pali": "rūpaṁ niccaṁ vā aniccaṁ vā’ti?"
    },
    {
      "id": "sn22.83:4.3",
      "pali": "‘Aniccaṁ, āvuso’."
    },
    {
      "id": "sn22.83:4.4",
      "pali": "‘Vedanā …"
    },
    {
      "id": "sn22.83:4.5",
      "pali": "saññā …"
    },
    {
      "id": "sn22.83:4.6",
      "pali": "saṅkhārā …"
    },
    {
      "id": "sn22.83:4.7",
      "pali": "viññāṇaṁ niccaṁ vā aniccaṁ vā’ti?"
    },
    {
      "id": "sn22.83:4.8",
      "pali": "‘Aniccaṁ, āvuso’ …pe…."
    },
    {
      "id": "sn22.83:4.9",
      "pali": "Tasmātiha …pe…"
    },
    {
      "id": "sn22.83:4.10",
      "pali": "evaṁ passaṁ …pe…"
    },
    {
      "id": "sn22.83:4.11",
      "pali": "nāparaṁ itthattāyāti pajānātīti."
    },
    {
      "id": "sn22.83:4.12",
      "pali": "Puṇṇo nāma, āvuso, āyasmā mantāṇiputto amhākaṁ navakānaṁ sataṁ bahūpakāro hoti."
    },
    {
      "id": "sn22.83:4.13",
      "pali": "So amhe iminā ovādena ovadati."
    },
    {
      "id": "sn22.83:4.14",
      "pali": "Idañca pana me āyasmato puṇṇassa mantāṇiputtassa dhammadesanaṁ sutvā dhammo abhisamito”ti."
    },
    {
      "id": "sn22.83:4.15",
      "pali": "Paṭhamaṁ."
    }
  ]
}
