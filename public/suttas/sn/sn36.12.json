{
  "uid": "sn36.12",
  "title": "Paṭhamaākāsasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn36.12:1.1",
      "pali": "“Seyyathāpi, bhikkhave, ākāse vividhā vātā vāyanti."
    },
    {
      "id": "sn36.12:1.2",
      "pali": "Puratthimāpi vātā vāyanti, pacchimāpi vātā vāyanti, uttarāpi vātā vāyanti, dakkhiṇāpi vātā vāyanti, sarajāpi vātā vāyanti, arajāpi vātā vāyanti, sītāpi vātā vāyanti, uṇhāpi vātā vāyanti, parittāpi vātā vāyanti, adhimattāpi vātā vāyanti."
    },
    {
      "id": "sn36.12:1.3",
      "pali": "Evameva kho, bhikkhave, imasmiṁ kāyasmiṁ vividhā vedanā uppajjanti, sukhāpi vedanā uppajjati, dukkhāpi vedanā uppajjati, adukkhamasukhāpi vedanā uppajjatīti."
    },
    {
      "id": "sn36.12:2.1",
      "pali": "Yathāpi vātā ākāse,"
    },
    {
      "id": "sn36.12:2.2",
      "pali": "vāyanti vividhā puthū;"
    },
    {
      "id": "sn36.12:2.3",
      "pali": "Puratthimā pacchimā cāpi,"
    },
    {
      "id": "sn36.12:2.4",
      "pali": "uttarā atha dakkhiṇā."
    },
    {
      "id": "sn36.12:3.1",
      "pali": "Sarajā arajā capi,"
    },
    {
      "id": "sn36.12:3.2",
      "pali": "sītā uṇhā ca ekadā;"
    },
    {
      "id": "sn36.12:3.3",
      "pali": "Adhimattā parittā ca,"
    },
    {
      "id": "sn36.12:3.4",
      "pali": "puthū vāyanti mālutā."
    },
    {
      "id": "sn36.12:4.1",
      "pali": "Tathevimasmiṁ kāyasmiṁ,"
    },
    {
      "id": "sn36.12:4.2",
      "pali": "samuppajjanti vedanā;"
    },
    {
      "id": "sn36.12:4.3",
      "pali": "Sukhadukkhasamuppatti,"
    },
    {
      "id": "sn36.12:4.4",
      "pali": "adukkhamasukhā ca yā."
    },
    {
      "id": "sn36.12:5.1",
      "pali": "Yato ca bhikkhu ātāpī,"
    },
    {
      "id": "sn36.12:5.2",
      "pali": "sampajaññaṁ na riñcati;"
    },
    {
      "id": "sn36.12:5.3",
      "pali": "Tato so vedanā sabbā,"
    },
    {
      "id": "sn36.12:5.4",
      "pali": "parijānāti paṇḍito."
    },
    {
      "id": "sn36.12:6.1",
      "pali": "So vedanā pariññāya,"
    },
    {
      "id": "sn36.12:6.2",
      "pali": "diṭṭhe dhamme anāsavo;"
    },
    {
      "id": "sn36.12:6.3",
      "pali": "Kāyassa bhedā dhammaṭṭho,"
    },
    {
      "id": "sn36.12:6.4",
      "pali": "saṅkhyaṁ nopeti vedagū”ti."
    },
    {
      "id": "sn36.12:6.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
