    },
    {
      "id": "sn35.95:23.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "sn35.95:24.1",
      "pali": "Na so rajjati rūpesu,"
    },
    {
      "id": "sn35.95:24.2",
      "pali": "rūpaṁ disvā paṭissato;"
    },
    {
      "id": "sn35.95:24.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "sn35.95:24.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:25.1",
      "pali": "Yathāssa passato rūpaṁ,"
    },
    {
      "id": "sn35.95:25.2",
      "pali": "sevato cāpi vedanaṁ;"
    },
    {
      "id": "sn35.95:25.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "sn35.95:25.4",
      "pali": "evaṁ so caratī sato;"
    },
    {
      "id": "sn35.95:25.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:25.6",
      "pali": "santike nibbāna vuccati."
    },
    {
      "id": "sn35.95:26.1",
      "pali": "Na so rajjati saddesu,"
    },
    {
      "id": "sn35.95:26.2",
      "pali": "saddaṁ sutvā paṭissato;"
    },
    {
      "id": "sn35.95:26.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "sn35.95:26.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:27.1",
      "pali": "Yathāssa suṇato saddaṁ,"
    },
    {
      "id": "sn35.95:27.2",
