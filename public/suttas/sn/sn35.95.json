{
  "uid": "sn35.95",
  "title": "Mālukyaputtasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.95:1.1",
      "pali": "Atha kho āyasmā mālukyaputto yena bhagavā tenupasaṅkami …pe… ekamantaṁ nisinno kho āyasmā mālukyaputto bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn35.95:1.2",
      "pali": "“sādhu me, bhante, bhagavā saṅkhittena dhammaṁ desetu, yamahaṁ bhagavato dhammaṁ sutvā eko vūpakaṭṭho appamatto ātāpī pahitatto vihareyyan”ti."
    },
    {
      "id": "sn35.95:2.1",
      "pali": "“Ettha dāni, mālukyaputta, kiṁ dahare bhikkhū vakkhāma."
    },
    {
      "id": "sn35.95:2.2",
      "pali": "Yatra hi nāma tvaṁ, bhikkhu, jiṇṇo vuddho mahallako addhagato vayoanuppatto saṅkhittena ovādaṁ yācasī”ti."
    },
    {
      "id": "sn35.95:3.1",
      "pali": "“Kiñcāpāhaṁ, bhante, jiṇṇo vuddho mahallako addhagato vayoanuppatto."
    },
    {
      "id": "sn35.95:3.2",
      "pali": "Desetu me, bhante, bhagavā saṅkhittena dhammaṁ, desetu sugato saṅkhittena dhammaṁ, appeva nāmāhaṁ bhagavato bhāsitassa atthaṁ ājāneyyaṁ. Appeva nāmāhaṁ bhagavato bhāsitassa dāyādo assan”ti."
    },
    {
      "id": "sn35.95:4.1",
      "pali": "“Taṁ kiṁ maññasi, mālukyaputta,"
    },
    {
      "id": "sn35.95:4.2",
      "pali": "ye te cakkhuviññeyyā rūpā adiṭṭhā adiṭṭhapubbā, na ca passasi, na ca te hoti passeyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:4.3",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:5.1",
      "pali": "“Ye te sotaviññeyyā saddā assutā assutapubbā, na ca suṇāsi, na ca te hoti suṇeyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:5.2",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:6.1",
      "pali": "“Ye te ghānaviññeyyā gandhā aghāyitā aghāyitapubbā, na ca ghāyasi, na ca te hoti ghāyeyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:6.2",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:7.1",
      "pali": "“Ye te jivhāviññeyyā rasā asāyitā asāyitapubbā, na ca sāyasi, na ca te hoti sāyeyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:7.2",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:8.1",
      "pali": "“Ye te kāyaviññeyyā phoṭṭhabbā asamphuṭṭhā asamphuṭṭhapubbā, na ca phusasi, na ca te hoti phuseyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:8.2",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:9.1",
      "pali": "“Ye te manoviññeyyā dhammā aviññātā aviññātapubbā, na ca vijānāsi, na ca te hoti vijāneyyanti? Atthi te tattha chando vā rāgo vā pemaṁ vā”ti?"
    },
    {
      "id": "sn35.95:9.2",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "sn35.95:10.1",
      "pali": "“Ettha ca te, mālukyaputta, diṭṭhasutamutaviññātabbesu dhammesu diṭṭhe diṭṭhamattaṁ bhavissati, sute sutamattaṁ bhavissati, mute mutamattaṁ bhavissati, viññāte viññātamattaṁ bhavissati."
    },
    {
      "id": "sn35.95:10.2",
      "pali": "Yato kho te, mālukyaputta, diṭṭhasutamutaviññātabbesu dhammesu diṭṭhe diṭṭhamattaṁ bhavissati, sute sutamattaṁ bhavissati, mute mutamattaṁ bhavissati, viññāte viññātamattaṁ bhavissati;"
    },
    {
      "id": "sn35.95:10.3",
      "pali": "tato tvaṁ, mālukyaputta, na tena."
    },
    {
      "id": "sn35.95:10.4",
      "pali": "Yato tvaṁ, mālukyaputta, na tena;"
    },
    {
      "id": "sn35.95:10.5",
      "pali": "tato tvaṁ, mālukyaputta, na tattha."
    },
    {
      "id": "sn35.95:10.6",
      "pali": "Yato tvaṁ, mālukyaputta, na tattha;"
    },
    {
      "id": "sn35.95:10.7",
      "pali": "tato tvaṁ, mālukyaputta, nevidha, na huraṁ, na ubhayamantarena."
    },
    {
      "id": "sn35.95:10.8",
      "pali": "Esevanto dukkhassā”ti."
    },
    {
      "id": "sn35.95:11.1",
      "pali": "“Imassa khvāhaṁ, bhante, bhagavatā saṅkhittena bhāsitassa vitthārena atthaṁ ājānāmi:"
    },
    {
      "id": "sn35.95:12.1",
      "pali": "‘Rūpaṁ disvā sati muṭṭhā,"
    },
    {
      "id": "sn35.95:12.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "sn35.95:12.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "sn35.95:12.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:13.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "sn35.95:13.2",
      "pali": "anekā rūpasambhavā;"
    },
    {
      "id": "sn35.95:13.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "sn35.95:13.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "sn35.95:13.5",
      "pali": "Evaṁ ācinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:13.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "sn35.95:14.1",
      "pali": "Saddaṁ sutvā sati muṭṭhā,"
    },
    {
      "id": "sn35.95:14.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "sn35.95:14.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "sn35.95:14.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:15.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "sn35.95:15.2",
      "pali": "anekā saddasambhavā;"
    },
    {
      "id": "sn35.95:15.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "sn35.95:15.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "sn35.95:15.5",
      "pali": "Evaṁ ācinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:15.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "sn35.95:16.1",
      "pali": "Gandhaṁ ghatvā sati muṭṭhā,"
    },
    {
      "id": "sn35.95:16.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "sn35.95:16.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "sn35.95:16.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:17.1",
      "pali": "Tassa vaḍḍhanti vedanā,"
    },
    {
      "id": "sn35.95:17.2",
      "pali": "anekā gandhasambhavā;"
    },
    {
      "id": "sn35.95:17.3",
      "pali": "Abhijjhā ca vihesā ca,"
    },
    {
      "id": "sn35.95:17.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "sn35.95:17.5",
      "pali": "Evaṁ ācinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:17.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "sn35.95:18.1",
      "pali": "Rasaṁ bhotvā sati muṭṭhā,"
    },
    {
      "id": "sn35.95:18.2",
      "pali": "Piyaṁ nimittaṁ manasi karoto;"
    },
    {
      "id": "sn35.95:18.3",
      "pali": "Sārattacitto vedeti,"
    },
    {
      "id": "sn35.95:18.4",
      "pali": "Tañca ajjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:19.1",
