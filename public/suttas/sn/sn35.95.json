    },
    {
      "id": "sn35.95:38.7",
      "pali": "…pe…"
    },
    {
      "id": "sn35.95:39.1",
      "pali": "Na so rajjati dhammesu,"
    },
    {
      "id": "sn35.95:39.2",
      "pali": "dhammaṁ ñatvā paṭissato;"
    },
    {
      "id": "sn35.95:39.3",
      "pali": "Virattacitto vedeti,"
    },
    {
      "id": "sn35.95:39.4",
      "pali": "tañca nājjhosa tiṭṭhati."
    },
    {
      "id": "sn35.95:40.1",
      "pali": "Yathāssa vijānato dhammaṁ,"
    },
    {
      "id": "sn35.95:40.2",
      "pali": "Sevato cāpi vedanaṁ;"
    },
    {
      "id": "sn35.95:40.3",
      "pali": "Khīyati nopacīyati,"
    },
    {
      "id": "sn35.95:40.4",
      "pali": "Evaṁ so caratī sato;"
    },
    {
      "id": "sn35.95:40.5",
      "pali": "Evaṁ apacinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:40.6",
      "pali": "Santike nibbāna vuccatī’ti."
    },
    {
      "id": "sn35.95:41.1",
      "pali": "Imassa kho, mālukyaputta, mayā saṅkhittena bhāsitassa evaṁ vitthārena attho daṭṭhabbo”ti."
    },
    {
      "id": "sn35.95:42.1",
      "pali": "Atha kho āyasmā mālukyaputto bhagavato bhāsitaṁ abhinanditvā anumoditvā uṭṭhāyāsanā bhagavantaṁ abhivādetvā padakkhiṇaṁ katvā pakkāmi."
    },
    {
      "id": "sn35.95:42.2",
      "pali": "Atha kho āyasmā mālukyaputto eko vūpakaṭṭho appamatto ātāpī pahitatto viharanto nacirasseva—yassatthāya kulaputtā sammadeva agārasmā anagāriyaṁ pabbajanti, tadanuttaraṁ—brahmacariyapariyosānaṁ diṭṭheva dhamme sayaṁ abhiññā sacchikatvā upasampajja vihāsi."
    },
    {
      "id": "sn35.95:42.3",
      "pali": "“Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā”ti abbhaññāsi."
    },
    {
      "id": "sn35.95:42.4",
      "pali": "Aññataro ca panāyasmā mālukyaputto arahataṁ ahosīti."
    },
    {
      "id": "sn35.95:42.5",
      "pali": "Dutiyaṁ."
    }
  ]
}
