    },
    {
      "id": "sn35.95:19.4",
      "pali": "cittamassūpahaññati;"
    },
    {
      "id": "sn35.95:19.5",
      "pali": "Evaṁ ācinato dukkhaṁ,"
    },
    {
      "id": "sn35.95:19.6",
      "pali": "ārā nibbāna vuccati."
    },
    {
      "id": "sn35.95:20.1",
      "pali": "Phassaṁ phussa sati muṭṭhā,"
