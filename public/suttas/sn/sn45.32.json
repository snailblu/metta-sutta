{
  "uid": "sn45.32",
  "title": "Dutiyapaṭipattisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn45.32:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn45.32:1.2",
      "pali": "“Micchāpaṭipannañca vo, bhikkhave, desessāmi, sammāpaṭipannañca."
    },
    {
      "id": "sn45.32:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn45.32:1.4",
      "pali": "Katamo ca, bhikkhave, micchāpaṭipanno?"
    },
    {
      "id": "sn45.32:1.5",
      "pali": "Idha, bhikkhave, ekacco micchādiṭṭhiko hoti …pe… micchāsamādhi—"
    },
    {
      "id": "sn45.32:1.6",
      "pali": "ayaṁ vuccati, bhikkhave, micchāpaṭipanno."
    },
    {
      "id": "sn45.32:1.7",
      "pali": "Katamo ca, bhikkhave, sammāpaṭipanno?"
    },
    {
      "id": "sn45.32:1.8",
      "pali": "Idha, bhikkhave, ekacco sammādiṭṭhiko hoti …pe… sammāsamādhi—"
    },
    {
      "id": "sn45.32:1.9",
      "pali": "ayaṁ vuccati, bhikkhave, sammāpaṭipanno”ti."
    },
    {
      "id": "sn45.32:1.10",
      "pali": "Dutiyaṁ."
    }
  ]
}
