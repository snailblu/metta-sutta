    },
    {
      "id": "sn33.11:1.2",
      "pali": "“Rūpe kho, vaccha, anabhisamayā …pe… rūpanirodhagāminiyā paṭipadāya anabhisamayā …pe…."
    },
    {
      "id": "sn33.12:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.12:1.2",
      "pali": "“Vedanāya kho, vaccha, anabhisamayā …pe…."
    },
    {
      "id": "sn33.13:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.13:1.2",
      "pali": "“Saññāya kho, vaccha, anabhisamayā …pe…."
