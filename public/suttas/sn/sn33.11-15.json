    {
      "id": "sn33.14:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.14:1.2",
      "pali": "“Saṅkhāresu kho, vaccha, anabhisamayā …pe…."
    },
    {
      "id": "sn33.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn33.15:1.2",
      "pali": "“Viññāṇe kho, vaccha, anabhisamayā …pe…."
    },
    {
