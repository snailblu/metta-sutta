{
  "uid": "sn12.58",
  "title": "Nāmarūpasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.58:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.58:1.2",
      "pali": "“Saṁyojaniyesu, bhikkhave, dhammesu assādānupassino viharato nāmarūpassa avakkanti hoti."
    },
    {
      "id": "sn12.58:1.3",
      "pali": "Nāmarūpapaccayā saḷāyatanaṁ …pe…"
    },
    {
      "id": "sn12.58:1.4",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.58:2.1",
      "pali": "Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.58:2.2",
      "pali": "Tassa yāni ceva mūlāni adhogamāni, yāni ca tiriyaṅgamāni, sabbāni tāni uddhaṁ ojaṁ abhiharanti."
    },
    {
      "id": "sn12.58:2.3",
      "pali": "Evañhi so, bhikkhave, mahārukkho tadāhāro tadupādāno ciraṁ dīghamaddhānaṁ tiṭṭheyya."
    },
    {
      "id": "sn12.58:2.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu assādānupassino viharato nāmarūpassa avakkanti hoti …pe…."
    },
    {
      "id": "sn12.58:3.1",
      "pali": "Saṁyojaniyesu, bhikkhave, dhammesu ādīnavānupassino viharato nāmarūpassa avakkanti na hoti."
    },
    {
      "id": "sn12.58:3.2",
      "pali": "Nāmarūpanirodhā saḷāyatananirodho …pe…"
    },
    {
      "id": "sn12.58:3.3",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hoti."
    },
    {
      "id": "sn12.58:4.1",
      "pali": "Seyyathāpi, bhikkhave, mahārukkho."
    },
    {
      "id": "sn12.58:4.2",
      "pali": "Atha puriso āgaccheyya kuddālapiṭakaṁ ādāya …pe…"
    },
    {
      "id": "sn12.58:4.3",
      "pali": "āyatiṁ anuppādadhammo."
    },
    {
      "id": "sn12.58:4.4",
      "pali": "Evameva kho, bhikkhave, saṁyojaniyesu dhammesu ādīnavānupassino viharato nāmarūpassa avakkanti na hoti."
    },
    {
      "id": "sn12.58:4.5",
      "pali": "Nāmarūpanirodhā saḷāyatananirodho …pe…"
    },
    {
      "id": "sn12.58:4.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī”ti."
    },
    {
      "id": "sn12.58:4.7",
      "pali": "Aṭṭhamaṁ."
    }
  ]
}
