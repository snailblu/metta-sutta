{
  "uid": "sn55.43",
  "title": "Tatiyaabhisandasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.43:1.1",
      "pali": "“Cattārome, bhikkhave, puññābhisandā, kusalābhisandā, sukhassāhārā."
    },
    {
      "id": "sn55.43:1.2",
      "pali": "Katame cattāro?"
    },
    {
      "id": "sn55.43:1.3",
      "pali": "Idha, bhikkhave, ariyasāvako buddhe aveccappasādena samannāgato hoti—"
    },
    {
      "id": "sn55.43:1.4",
      "pali": "itipi so bhagavā …pe… satthā devamanussānaṁ buddho bhagavāti."
    },
    {
      "id": "sn55.43:1.5",
      "pali": "Ayaṁ paṭhamo puññābhisando, kusalābhisando, sukhassāhāro."
    },
    {
      "id": "sn55.43:2.1",
      "pali": "Puna caparaṁ, bhikkhave, ariyasāvako dhamme …pe…"
    },
    {
      "id": "sn55.43:2.2",
      "pali": "saṅghe …pe…."
    },
    {
      "id": "sn55.43:3.1",
      "pali": "Puna caparaṁ, bhikkhave, ariyasāvako paññavā hoti udayatthagāminiyā paññāya samannāgato ariyāya nibbedhikāya sammā dukkhakkhayagāminiyā."
    },
    {
      "id": "sn55.43:3.2",
      "pali": "Ayaṁ catuttho puññābhisando kusalābhisando sukhassāhāro."
    },
    {
      "id": "sn55.43:3.3",
      "pali": "Ime kho, bhikkhave, cattāro puññābhisandā kusalābhisandā sukhassāhārā."
    },
    {
      "id": "sn55.43:4.1",
      "pali": "Imehi kho, bhikkhave, catūhi puññābhisandehi kusalābhisandehi samannāgatassa ariyasāvakassa na sukaraṁ puññassa pamāṇaṁ gaṇetuṁ:"
    },
    {
      "id": "sn55.43:4.2",
      "pali": "‘ettako puññābhisando, kusalābhisando, sukhassāhāro’ti."
    },
    {
      "id": "sn55.43:4.3",
      "pali": "Atha kho asaṅkhyeyyo appameyyo mahāpuññakkhandhotveva saṅkhyaṁ gacchatī”ti."
    },
    {
      "id": "sn55.43:4.4",
      "pali": "Idamavoca bhagavā …pe…"
    },
    {
      "id": "sn55.43:4.5",
      "pali": "satthā:"
    },
    {
      "id": "sn55.43:5.1",
      "pali": "“Yo puññakāmo kusale patiṭṭhito,"
    },
    {
      "id": "sn55.43:5.2",
      "pali": "Bhāveti maggaṁ amatassa pattiyā;"
    },
    {
      "id": "sn55.43:5.3",
      "pali": "So dhammasārādhigamo khaye rato,"
    },
    {
      "id": "sn55.43:5.4",
      "pali": "Na vedhati maccurājāgamanasmin”ti."
    },
    {
      "id": "sn55.43:5.5",
      "pali": "Tatiyaṁ."
    }
  ]
}
