{
  "uid": "sn23.15",
  "title": "Dukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn23.15:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn23.15:1.2",
      "pali": "Ekamantaṁ nisinno kho āyasmā rādho bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn23.15:1.3",
      "pali": "“‘dukkhaṁ, dukkhan’ti, bhante, vuccati."
    },
    {
      "id": "sn23.15:1.4",
      "pali": "Katamaṁ nu kho, bhante, dukkhan”ti?"
    },
    {
      "id": "sn23.15:1.5",
      "pali": "“Rūpaṁ kho, rādha, dukkhaṁ, vedanā dukkhā, saññā dukkhā, saṅkhārā dukkhā, viññāṇaṁ dukkhaṁ."
    },
    {
      "id": "sn23.15:1.6",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn23.15:1.7",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn23.15:1.8",
      "pali": "Pañcamaṁ."
    }
  ]
}
