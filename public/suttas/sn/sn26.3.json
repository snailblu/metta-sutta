{
  "uid": "sn26.3",
  "title": "Viññāṇasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn26.3:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn26.3:1.2",
      "pali": "“Yo kho, bhikkhave, cakkhuviññāṇassa uppādo ṭhiti …pe…"
    },
    {
      "id": "sn26.3:1.3",
      "pali": "jarāmaraṇassa pātubhāvo …pe…"
    },
    {
      "id": "sn26.3:1.4",
      "pali": "yo manoviññāṇassa uppādo ṭhiti …pe…"
    },
    {
      "id": "sn26.3:1.5",
      "pali": "jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn26.3:1.6",
      "pali": "Yo ca kho, bhikkhave, cakkhuviññāṇassa nirodho …pe…"
    },
    {
      "id": "sn26.3:1.7",
      "pali": "jarāmaraṇassa atthaṅgamo …pe…"
    },
    {
      "id": "sn26.3:1.8",
      "pali": "yo manoviññāṇassa nirodho …pe…"
    },
    {
      "id": "sn26.3:1.9",
      "pali": "jarāmaraṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn26.3:1.10",
      "pali": "Tatiyaṁ."
    }
  ]
}
