{
  "uid": "sn22.140",
  "title": "Dukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.140:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.140:1.2",
      "pali": "“Yaṁ, bhikkhave, dukkhaṁ; tatra vo chando pahātabbo …pe…"
    },
    {
      "id": "sn22.140:1.3",
      "pali": "yaṁ, bhikkhave, dukkhaṁ; tatra vo chando pahātabbo”ti."
    },
    {
      "id": "sn22.140:1.4",
      "pali": "Pañcamaṁ."
    }
  ]
}
