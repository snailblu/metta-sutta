{
  "uid": "sn15.10",
  "title": "Puggalasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn15.10:1.1",
      "pali": "Ekaṁ samayaṁ bhagavā rājagahe viharati gijjhakūṭe pabbate."
    },
    {
      "id": "sn15.10:1.2",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "sn15.10:1.3",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "sn15.10:1.4",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "sn15.10:1.5",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "sn15.10:2.1",
      "pali": "“Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.10:2.2",
      "pali": "ekapuggalassa, bhikkhave, kappaṁ sandhāvato saṁsarato siyā evaṁ mahā aṭṭhikaṅkalo aṭṭhipuñjo aṭṭhirāsi yathāyaṁ vepullo pabbato, sace saṁhārako assa, sambhatañca na vinasseyya."
    },
    {
      "id": "sn15.10:2.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "sn15.10:2.4",
      "pali": "Anamataggoyaṁ, bhikkhave, saṁsāro …pe…"
    },
    {
      "id": "sn15.10:2.5",
      "pali": "alaṁ vimuccitun”ti."
    },
    {
      "id": "sn15.10:3.1",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "sn15.10:3.2",
      "pali": "Idaṁ vatvāna sugato athāparaṁ etadavoca satthā:"
    },
    {
      "id": "sn15.10:4.1",
      "pali": "“Ekassekena kappena,"
    },
    {
      "id": "sn15.10:4.2",
      "pali": "puggalassaṭṭhisañcayo;"
    },
    {
      "id": "sn15.10:4.3",
      "pali": "Siyā pabbatasamo rāsi,"
    },
    {
      "id": "sn15.10:4.4",
      "pali": "iti vuttaṁ mahesinā."
    },
    {
      "id": "sn15.10:5.1",
      "pali": "So kho panāyaṁ akkhāto,"
    },
    {
      "id": "sn15.10:5.2",
      "pali": "vepullo pabbato mahā;"
    },
    {
      "id": "sn15.10:5.3",
      "pali": "Uttaro gijjhakūṭassa,"
    },
    {
      "id": "sn15.10:5.4",
      "pali": "magadhānaṁ giribbaje."
    },
    {
      "id": "sn15.10:6.1",
      "pali": "Yato ca ariyasaccāni,"
    },
    {
      "id": "sn15.10:6.2",
      "pali": "sammappaññāya passati;"
    },
    {
      "id": "sn15.10:6.3",
      "pali": "Dukkhaṁ dukkhasamuppādaṁ,"
    },
    {
      "id": "sn15.10:6.4",
      "pali": "dukkhassa ca atikkamaṁ;"
    },
    {
      "id": "sn15.10:6.5",
      "pali": "Ariyaṁ caṭṭhaṅgikaṁ maggaṁ,"
    },
    {
      "id": "sn15.10:6.6",
      "pali": "dukkhūpasamagāminaṁ."
    },
    {
      "id": "sn15.10:7.1",
      "pali": "Sa sattakkhattuṁparamaṁ,"
    },
    {
      "id": "sn15.10:7.2",
      "pali": "sandhāvitvāna puggalo;"
    },
    {
      "id": "sn15.10:7.3",
      "pali": "Dukkhassantakaro hoti,"
    },
    {
      "id": "sn15.10:7.4",
      "pali": "sabbasaṁyojanakkhayā”ti."
    },
    {
      "id": "sn15.10:7.5",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn15.10:7.6",
      "pali": "Paṭhamo vaggo."
    },
    {
      "id": "sn15.10:8.1",
      "pali": "Tiṇakaṭṭhañca pathavī,"
    },
    {
      "id": "sn15.10:8.2",
      "pali": "assu khīrañca pabbataṁ;"
    },
    {
      "id": "sn15.10:8.3",
      "pali": "Sāsapā sāvakā gaṅgā,"
    },
    {
      "id": "sn15.10:8.4",
      "pali": "daṇḍo ca puggalena cāti."
    }
  ]
}
