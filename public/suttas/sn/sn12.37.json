{
  "uid": "sn12.37",
  "title": "Natumhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn12.37:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn12.37:1.2",
      "pali": "“Nāyaṁ, bhikkhave, kāyo tumhākaṁ napi aññesaṁ."
    },
    {
      "id": "sn12.37:1.3",
      "pali": "Purāṇamidaṁ, bhikkhave, kammaṁ abhisaṅkhataṁ abhisañcetayitaṁ vedaniyaṁ daṭṭhabbaṁ."
    },
    {
      "id": "sn12.37:2.1",
      "pali": "Tatra kho, bhikkhave, sutavā ariyasāvako paṭiccasamuppādaññeva sādhukaṁ yoniso manasi karoti:"
    },
    {
      "id": "sn12.37:2.2",
      "pali": "‘iti imasmiṁ sati idaṁ hoti, imassuppādā idaṁ uppajjati;"
    },
    {
      "id": "sn12.37:2.3",
      "pali": "imasmiṁ asati idaṁ na hoti, imassa nirodhā idaṁ nirujjhati, yadidaṁ—"
    },
    {
      "id": "sn12.37:2.4",
      "pali": "avijjāpaccayā saṅkhārā;"
    },
    {
      "id": "sn12.37:2.5",
      "pali": "saṅkhārapaccayā viññāṇaṁ …pe…"
    },
    {
      "id": "sn12.37:2.6",
      "pali": "evametassa kevalassa dukkhakkhandhassa samudayo hoti."
    },
    {
      "id": "sn12.37:2.7",
      "pali": "Avijjāya tveva asesavirāganirodhā saṅkhāranirodho;"
    },
    {
      "id": "sn12.37:2.8",
      "pali": "saṅkhāranirodhā viññāṇanirodho …pe…"
    },
    {
      "id": "sn12.37:2.9",
      "pali": "evametassa kevalassa dukkhakkhandhassa nirodho hotī’”ti."
    },
    {
      "id": "sn12.37:2.10",
      "pali": "Sattamaṁ."
    }
  ]
}
