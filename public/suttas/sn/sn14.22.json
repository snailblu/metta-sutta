{
  "uid": "sn14.22",
  "title": "Kusītamūlakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn14.22:1.1",
      "pali": "Sāvatthiyaṁ viharati."
    },
    {
      "id": "sn14.22:1.2",
      "pali": "“Dhātusova, bhikkhave, sattā saṁsandanti samenti."
    },
    {
      "id": "sn14.22:1.3",
      "pali": "Kusītā kusītehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.22:1.4",
      "pali": "muṭṭhassatino muṭṭhassatīhi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.22:1.5",
      "pali": "duppaññā duppaññehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.22:1.6",
      "pali": "āraddhavīriyā āraddhavīriyehi saddhiṁ saṁsandanti samenti;"
    },
    {
      "id": "sn14.22:1.7",
      "pali": "upaṭṭhitassatino upaṭṭhitassatīhi saddhiṁ saṁsandanti samenti; paññavanto paññavantehi saddhiṁ saṁsandanti samentī”ti …pe…."
    },
    {
      "id": "sn14.22:1.8",
      "pali": "Dvādasamaṁ."
    },
    {
      "id": "sn14.22:1.9",
      "pali": "(Sabbattha atītānāgatapaccuppannaṁ kātabbaṁ.)"
    },
    {
      "id": "sn14.22:1.10",
      "pali": "Dutiyo vaggo."
    },
    {
      "id": "sn14.22:2.1",
      "pali": "Sattimā sanidānañca,"
    },
    {
      "id": "sn14.22:2.2",
      "pali": "giñjakāvasathena ca;"
    },
    {
      "id": "sn14.22:2.3",
      "pali": "Hīnādhimutti caṅkamaṁ,"
    },
    {
      "id": "sn14.22:2.4",
      "pali": "sagāthā assaddhasattamaṁ."
    },
    {
      "id": "sn14.22:3.1",
      "pali": "Assaddhamūlakā pañca,"
    },
    {
      "id": "sn14.22:3.2",
      "pali": "Cattāro ahirikamūlakā;"
    },
    {
      "id": "sn14.22:3.3",
      "pali": "Anottappamūlakā tīṇi,"
    },
    {
      "id": "sn14.22:3.4",
      "pali": "Duve appassutena ca."
    },
    {
      "id": "sn14.22:4.1",
      "pali": "Kusītaṁ ekakaṁ vuttaṁ,"
    },
    {
      "id": "sn14.22:4.2",
      "pali": "Suttantā tīṇi pañcakā;"
    },
    {
      "id": "sn14.22:4.3",
      "pali": "Bāvīsati vuttā suttā,"
    },
    {
      "id": "sn14.22:4.4",
      "pali": "Dutiyo vaggo pavuccatīti."
    }
  ]
}
