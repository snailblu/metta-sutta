{
  "uid": "sn11.15",
  "title": "Rāmaṇeyyakasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn11.15:1.1",
      "pali": "Sāvatthiyaṁ jetavane."
    },
    {
      "id": "sn11.15:1.2",
      "pali": "Atha kho sakko devānamindo yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhito kho sakko devānamindo bhagavantaṁ etadavoca:"
    },
    {
      "id": "sn11.15:1.3",
      "pali": "“kiṁ nu kho, bhante, bhūmirāmaṇeyyakan”ti?"
    },
    {
      "id": "sn11.15:2.1",
      "pali": "“Ārāmacetyā vanacetyā,"
    },
    {
      "id": "sn11.15:2.2",
      "pali": "pokkharañño sunimmitā;"
    },
    {
      "id": "sn11.15:2.3",
      "pali": "Manussarāmaṇeyyassa,"
    },
    {
      "id": "sn11.15:2.4",
      "pali": "kalaṁ nāgghanti soḷasiṁ."
    },
    {
      "id": "sn11.15:3.1",
      "pali": "Gāme vā yadi vāraññe,"
    },
    {
      "id": "sn11.15:3.2",
      "pali": "Ninne vā yadi vā thale;"
    },
    {
      "id": "sn11.15:3.3",
      "pali": "Yattha arahanto viharanti,"
    },
    {
      "id": "sn11.15:3.4",
      "pali": "Taṁ bhūmirāmaṇeyyakan”ti."
    }
  ]
}
