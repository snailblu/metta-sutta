{
  "uid": "sn26.10",
  "title": "Khandhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn26.10:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn26.10:1.2",
      "pali": "“Yo kho, bhikkhave, rūpassa uppādo ṭhiti abhinibbatti pātubhāvo, dukkhasseso uppādo, rogānaṁ ṭhiti, jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn26.10:1.3",
      "pali": "Yo vedanāya …"
    },
    {
      "id": "sn26.10:1.4",
      "pali": "yo saññāya …"
    },
    {
      "id": "sn26.10:1.5",
      "pali": "yo saṅkhārānaṁ …"
    },
    {
      "id": "sn26.10:1.6",
      "pali": "yo viññāṇassa uppādo ṭhiti abhinibbatti pātubhāvo, dukkhasseso uppādo, rogānaṁ ṭhiti, jarāmaraṇassa pātubhāvo."
    },
    {
      "id": "sn26.10:1.7",
      "pali": "Yo ca kho, bhikkhave, rūpassa nirodho vūpasamo atthaṅgamo, dukkhasseso nirodho, rogānaṁ vūpasamo, jarāmaraṇassa atthaṅgamo."
    },
    {
      "id": "sn26.10:1.8",
      "pali": "Yo vedanāya …"
    },
    {
      "id": "sn26.10:1.9",
      "pali": "yo saññāya …"
    },
    {
      "id": "sn26.10:1.10",
      "pali": "yo saṅkhārānaṁ …"
    },
    {
      "id": "sn26.10:1.11",
      "pali": "yo viññāṇassa nirodho vūpasamo atthaṅgamo, dukkhasseso nirodho, rogānaṁ vūpasamo, jarāmaraṇassa atthaṅgamo”ti."
    },
    {
      "id": "sn26.10:1.12",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn26.10:1.13",
      "pali": "Uppādavaggo paṭhamo."
    },
    {
      "id": "sn26.10:2.1",
      "pali": "Cakkhu rūpañca viññāṇaṁ,"
    },
    {
      "id": "sn26.10:2.2",
      "pali": "phasso ca vedanāya ca;"
    },
    {
      "id": "sn26.10:2.3",
      "pali": "Saññā ca cetanā taṇhā,"
    },
    {
      "id": "sn26.10:2.4",
      "pali": "dhātu khandhena te dasāti."
    },
    {
      "id": "sn26.10:2.5",
      "pali": "Uppādasaṁyuttaṁ samattaṁ."
    }
  ]
}
