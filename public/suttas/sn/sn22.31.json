{
  "uid": "sn22.31",
  "title": "Aghamūlasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.31:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.31:1.2",
      "pali": "“Aghañca, bhikkhave, desessāmi aghamūlañca."
    },
    {
      "id": "sn22.31:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.31:1.4",
      "pali": "Katamañca, bhikkhave, aghaṁ?"
    },
    {
      "id": "sn22.31:1.5",
      "pali": "Rūpaṁ, bhikkhave, aghaṁ, vedanā aghaṁ, saññā aghaṁ, saṅkhārā aghaṁ, viññāṇaṁ aghaṁ."
    },
    {
      "id": "sn22.31:1.6",
      "pali": "Idaṁ vuccati, bhikkhave, aghaṁ."
    },
    {
      "id": "sn22.31:1.7",
      "pali": "Katamañca, bhikkhave, aghamūlaṁ?"
    },
    {
      "id": "sn22.31:1.8",
      "pali": "Yāyaṁ taṇhā ponobhavikā nandīrāgasahagatā tatratatrābhinandinī;"
    },
    {
      "id": "sn22.31:1.9",
      "pali": "Seyyathidaṁ—kāmataṇhā, bhavataṇhā, vibhavataṇhā."
    },
    {
      "id": "sn22.31:1.10",
      "pali": "Idaṁ vuccati, bhikkhave, aghamūlan”ti."
    },
    {
      "id": "sn22.31:1.11",
      "pali": "Dasamaṁ."
    }
  ]
}
