{
  "uid": "sn4.24",
  "title": "Sattavassānubandhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn4.24:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "sn4.24:1.2",
      "pali": "ekaṁ samayaṁ bhagavā uruvelāyaṁ viharati najjā nerañjarāya tīre ajapālanigrodhe."
    },
    {
      "id": "sn4.24:1.3",
      "pali": "Tena kho pana samayena māro pāpimā sattavassāni bhagavantaṁ anubandho hoti otārāpekkho otāraṁ alabhamāno."
    },
    {
      "id": "sn4.24:1.4",
      "pali": "Atha kho māro pāpimā yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ gāthāya ajjhabhāsi:"
    },
    {
      "id": "sn4.24:2.1",
      "pali": "“Sokāvatiṇṇo nu vanamhi jhāyasi,"
    },
    {
      "id": "sn4.24:2.2",
      "pali": "Vittaṁ nu jīno uda patthayāno;"
    },
    {
      "id": "sn4.24:2.3",
      "pali": "Āguṁ nu gāmasmimakāsi kiñci,"
    },
    {
      "id": "sn4.24:2.4",
      "pali": "Kasmā janena na karosi sakkhiṁ;"
    },
    {
      "id": "sn4.24:2.5",
      "pali": "Sakkhī na sampajjati kenaci te”ti."
    },
    {
      "id": "sn4.24:3.1",
      "pali": "“Sokassa mūlaṁ palikhāya sabbaṁ,"
    },
    {
      "id": "sn4.24:3.2",
      "pali": "Anāgu jhāyāmi asocamāno;"
    },
    {
      "id": "sn4.24:3.3",
      "pali": "Chetvāna sabbaṁ bhavalobhajappaṁ,"
    },
    {
      "id": "sn4.24:3.4",
      "pali": "Anāsavo jhāyāmi pamattabandhū”ti."
    },
    {
      "id": "sn4.24:4.1",
      "pali": "“Yaṁ vadanti mama yidanti,"
    },
    {
      "id": "sn4.24:4.2",
      "pali": "ye vadanti mamanti ca;"
    },
    {
      "id": "sn4.24:4.3",
      "pali": "Ettha ce te mano atthi,"
    },
    {
      "id": "sn4.24:4.4",
      "pali": "na me samaṇa mokkhasī”ti."
    },
    {
      "id": "sn4.24:5.1",
      "pali": "“Yaṁ vadanti na taṁ mayhaṁ,"
    },
    {
      "id": "sn4.24:5.2",
      "pali": "ye vadanti na te ahaṁ;"
    },
    {
      "id": "sn4.24:5.3",
      "pali": "Evaṁ pāpima jānāhi,"
    },
    {
      "id": "sn4.24:5.4",
      "pali": "na me maggampi dakkhasī”ti."
    },
    {
      "id": "sn4.24:6.1",
      "pali": "“Sace maggaṁ anubuddhaṁ,"
    },
    {
      "id": "sn4.24:6.2",
      "pali": "khemaṁ amatagāminaṁ;"
    },
    {
      "id": "sn4.24:6.3",
      "pali": "Apehi gaccha tvameveko,"
    },
    {
      "id": "sn4.24:6.4",
      "pali": "kimaññamanusāsasī”ti."
    },
    {
      "id": "sn4.24:7.1",
      "pali": "“Amaccudheyyaṁ pucchanti,"
    },
    {
      "id": "sn4.24:7.2",
      "pali": "ye janā pāragāmino;"
    },
    {
      "id": "sn4.24:7.3",
      "pali": "Tesāhaṁ puṭṭho akkhāmi,"
    },
    {
      "id": "sn4.24:7.4",
      "pali": "yaṁ saccaṁ taṁ nirūpadhin”ti."
    },
    {
      "id": "sn4.24:8.1",
      "pali": "“Seyyathāpi, bhante, gāmassa vā nigamassa vā avidūre pokkharaṇī."
    },
    {
      "id": "sn4.24:8.2",
      "pali": "Tatrassa kakkaṭako."
    },
    {
      "id": "sn4.24:8.3",
      "pali": "Atha kho, bhante, sambahulā kumārakā vā kumārikāyo vā tamhā gāmā vā nigamā vā nikkhamitvā yena sā pokkharaṇī tenupasaṅkameyyuṁ; upasaṅkamitvā taṁ kakkaṭakaṁ udakā uddharitvā thale patiṭṭhapeyyuṁ."
    },
    {
      "id": "sn4.24:8.4",
      "pali": "Yaṁ yadeva hi so, bhante, kakkaṭako aḷaṁ abhininnāmeyya taṁ tadeva te kumārakā vā kumārikāyo vā kaṭṭhena vā kathalāya vā sañchindeyyuṁ sambhañjeyyuṁ sampalibhañjeyyuṁ."
    },
    {
      "id": "sn4.24:8.5",
      "pali": "Evañhi so, bhante, kakkaṭako sabbehi aḷehi sañchinnehi sambhaggehi sampalibhaggehi abhabbo taṁ pokkharaṇiṁ otarituṁ."
    },
    {
      "id": "sn4.24:8.6",
      "pali": "Evameva kho, bhante, yāni kānici visūkāyikāni visevitāni vipphanditāni, sabbāni tāni bhagavatā sañchinnāni sambhaggāni sampalibhaggāni."
    },
    {
      "id": "sn4.24:8.7",
      "pali": "Abhabbo dānāhaṁ, bhante, puna bhagavantaṁ upasaṅkamituṁ yadidaṁ otārāpekkho”ti."
    },
    {
      "id": "sn4.24:8.8",
      "pali": "Atha kho māro pāpimā bhagavato santike imā nibbejanīyā gāthāyo abhāsi:"
    },
    {
      "id": "sn4.24:9.1",
      "pali": "“Medavaṇṇañca pāsāṇaṁ,"
    },
    {
      "id": "sn4.24:9.2",
      "pali": "vāyaso anupariyagā;"
    },
    {
      "id": "sn4.24:9.3",
      "pali": "Apettha muduṁ vindema,"
    },
    {
      "id": "sn4.24:9.4",
      "pali": "api assādanā siyā."
    },
    {
      "id": "sn4.24:10.1",
      "pali": "Aladdhā tattha assādaṁ,"
    },
    {
      "id": "sn4.24:10.2",
      "pali": "vāyasetto apakkame;"
    },
    {
      "id": "sn4.24:10.3",
      "pali": "Kākova selamāsajja,"
    },
    {
      "id": "sn4.24:10.4",
      "pali": "nibbijjāpema gotamā”ti."
    }
  ]
}
