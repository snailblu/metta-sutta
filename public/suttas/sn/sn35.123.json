{
  "uid": "sn35.123",
  "title": "Upādāniyadhammasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.123:1.1",
      "pali": "“Upādāniye ca, bhikkhave, dhamme desessāmi upādānañca."
    },
    {
      "id": "sn35.123:1.2",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn35.123:1.3",
      "pali": "Katame ca, bhikkhave, upādāniyā dhammā, katamañca upādānaṁ?"
    },
    {
      "id": "sn35.123:1.4",
      "pali": "Santi, bhikkhave, cakkhuviññeyyā rūpā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.123:1.5",
      "pali": "Ime vuccanti, bhikkhave, upādāniyā dhammā."
    },
    {
      "id": "sn35.123:1.6",
      "pali": "Yo tattha chandarāgo, taṁ tattha upādānaṁ …pe…"
    },
    {
      "id": "sn35.123:1.7",
      "pali": "santi, bhikkhave, jivhāviññeyyā rasā …pe…"
    },
    {
      "id": "sn35.123:1.8",
      "pali": "santi, bhikkhave, manoviññeyyā dhammā iṭṭhā kantā manāpā piyarūpā kāmūpasaṁhitā rajanīyā."
    },
    {
      "id": "sn35.123:1.9",
      "pali": "Ime vuccanti, bhikkhave, upādāniyā dhammā."
    },
    {
      "id": "sn35.123:1.10",
      "pali": "Yo tattha chandarāgo taṁ tattha upādānan”ti."
    },
    {
      "id": "sn35.123:1.11",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.123:1.12",
      "pali": "Lokakāmaguṇavaggo dutiyo."
    },
    {
      "id": "sn35.123:2.1",
      "pali": "Mārapāsena dve vuttā,"
    },
    {
      "id": "sn35.123:2.2",
      "pali": "lokakāmaguṇena ca;"
    },
    {
      "id": "sn35.123:2.3",
      "pali": "Sakko pañcasikho ceva,"
    },
    {
      "id": "sn35.123:2.4",
      "pali": "sāriputto ca rāhulo;"
    },
    {
      "id": "sn35.123:2.5",
      "pali": "Saṁyojanaṁ upādānaṁ,"
    },
    {
      "id": "sn35.123:2.6",
      "pali": "vaggo tena pavuccatīti."
    }
  ]
}
