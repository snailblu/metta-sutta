{
  "uid": "sn22.51",
  "title": "Nandikkhayasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.51:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.51:1.2",
      "pali": "“Aniccaññeva, bhikkhave, bhikkhu rūpaṁ aniccanti passati. Sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn22.51:1.3",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn22.51:1.4",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.51:1.5",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.51:1.6",
      "pali": "Aniccaññeva, bhikkhave, bhikkhu vedanaṁ aniccanti passati. Sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn22.51:1.7",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn22.51:1.8",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.51:1.9",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.51:1.10",
      "pali": "Aniccaññeva, bhikkhave, bhikkhu saññaṁ aniccanti passati …pe…"
    },
    {
      "id": "sn22.51:1.11",
      "pali": "anicceyeva bhikkhave, bhikkhu saṅkhāre aniccāti passati. Sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn22.51:1.12",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn22.51:1.13",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.51:1.14",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccati."
    },
    {
      "id": "sn22.51:1.15",
      "pali": "Aniccaññeva, bhikkhave, bhikkhu viññāṇaṁ aniccanti passati. Sāssa hoti sammādiṭṭhi."
    },
    {
      "id": "sn22.51:1.16",
      "pali": "Sammā passaṁ nibbindati."
    },
    {
      "id": "sn22.51:1.17",
      "pali": "Nandikkhayā rāgakkhayo, rāgakkhayā nandikkhayo."
    },
    {
      "id": "sn22.51:1.18",
      "pali": "Nandirāgakkhayā cittaṁ vimuttaṁ suvimuttanti vuccatī”ti."
    },
    {
      "id": "sn22.51:1.19",
      "pali": "Navamaṁ."
    }
  ]
}
