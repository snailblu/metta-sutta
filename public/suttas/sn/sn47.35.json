{
  "uid": "sn47.35",
  "title": "Satisutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn47.35:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn47.35:1.2",
      "pali": "“Sato, bhikkhave, bhikkhu vihareyya sampajāno."
    },
    {
      "id": "sn47.35:1.3",
      "pali": "Ayaṁ vo amhākaṁ anusāsanī."
    },
    {
      "id": "sn47.35:2.1",
      "pali": "Kathañca, bhikkhave, bhikkhu sato hoti?"
    },
    {
      "id": "sn47.35:2.2",
      "pali": "Idha, bhikkhave, bhikkhu kāye kāyānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ;"
    },
    {
      "id": "sn47.35:2.3",
      "pali": "vedanāsu …pe…"
    },
    {
      "id": "sn47.35:2.4",
      "pali": "citte …pe…"
    },
    {
      "id": "sn47.35:2.5",
      "pali": "dhammesu dhammānupassī viharati ātāpī sampajāno satimā, vineyya loke abhijjhādomanassaṁ."
    },
    {
      "id": "sn47.35:2.6",
      "pali": "Evaṁ kho, bhikkhave, bhikkhu sato hoti."
    },
    {
      "id": "sn47.35:3.1",
      "pali": "Kathañca, bhikkhave, bhikkhu sampajāno hoti?"
    },
    {
      "id": "sn47.35:3.2",
      "pali": "Idha, bhikkhave, bhikkhuno viditā vedanā uppajjanti, viditā upaṭṭhahanti, viditā abbhatthaṁ gacchanti."
    },
    {
      "id": "sn47.35:3.3",
      "pali": "Viditā vitakkā uppajjanti, viditā upaṭṭhahanti, viditā abbhatthaṁ gacchanti."
    },
    {
      "id": "sn47.35:3.4",
      "pali": "Viditā saññā uppajjanti, viditā upaṭṭhahanti, viditā abbhatthaṁ gacchanti."
    },
    {
      "id": "sn47.35:3.5",
      "pali": "Evaṁ kho, bhikkhave, bhikkhu sampajāno hoti."
    },
    {
      "id": "sn47.35:3.6",
      "pali": "Sato, bhikkhave, bhikkhu vihareyya sampajāno."
    },
    {
      "id": "sn47.35:3.7",
      "pali": "Ayaṁ vo amhākaṁ anusāsanī”ti."
    },
    {
      "id": "sn47.35:3.8",
      "pali": "Pañcamaṁ."
    }
  ]
}
