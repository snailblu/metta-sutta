{
  "uid": "sn22.149",
  "title": "Anattānupassīsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.149:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.149:1.2",
      "pali": "“Saddhāpabbajitassa, bhikkhave, kulaputtassa ayamanudhammo hoti—"
    },
    {
      "id": "sn22.149:1.3",
      "pali": "yaṁ rūpe anattānupassī vihareyya."
    },
    {
      "id": "sn22.149:1.4",
      "pali": "Vedanāya …"
    },
    {
      "id": "sn22.149:1.5",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.149:1.6",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn22.149:1.7",
      "pali": "viññāṇe anattānupassī vihareyya."
    },
    {
      "id": "sn22.149:1.8",
      "pali": "Anattānupassī viharanto, vedanāya …"
    },
    {
      "id": "sn22.149:1.9",
      "pali": "saññāya …"
    },
    {
      "id": "sn22.149:1.10",
      "pali": "saṅkhāresu …"
    },
    {
      "id": "sn22.149:1.11",
      "pali": "viññāṇe anattānupassī viharanto rūpaṁ parijānāti, vedanaṁ …pe…"
    },
    {
      "id": "sn22.149:1.12",
      "pali": "saññaṁ …"
    },
    {
      "id": "sn22.149:1.13",
      "pali": "saṅkhāre …"
    },
    {
      "id": "sn22.149:1.14",
      "pali": "viññāṇaṁ parijānāti."
    },
    {
      "id": "sn22.149:1.15",
      "pali": "So rūpaṁ parijānaṁ vedanaṁ parijānaṁ saññaṁ parijānaṁ saṅkhāre parijānaṁ viññāṇaṁ parijānaṁ parimuccati rūpamhā, parimuccati vedanāya, parimuccati saññāya, parimuccati saṅkhārehi, parimuccati viññāṇamhā, parimuccati jātiyā jarāya maraṇena sokehi paridevehi dukkhehi domanassehi upāyāsehi;"
    },
    {
      "id": "sn22.149:1.16",
      "pali": "‘parimuccati dukkhasmā’ti vadāmī”ti."
    },
    {
      "id": "sn22.149:1.17",
      "pali": "Cuddasamaṁ."
    },
    {
      "id": "sn22.149:1.18",
      "pali": "Kukkuḷavaggo catuttho."
    },
    {
      "id": "sn22.149:2.1",
      "pali": "Kukkuḷā tayo aniccena,"
    },
    {
      "id": "sn22.149:2.2",
      "pali": "dukkhena apare tayo;"
    },
    {
      "id": "sn22.149:2.3",
      "pali": "Anattena tayo vuttā,"
    },
    {
      "id": "sn22.149:2.4",
      "pali": "kulaputtena dve dukāti."
    }
  ]
}
