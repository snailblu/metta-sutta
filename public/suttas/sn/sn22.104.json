{
  "uid": "sn22.104",
  "title": "Dukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn22.104:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn22.104:1.2",
      "pali": "“Dukkhañca vo, bhikkhave, desessāmi dukkhasamudayañca dukkhanirodhañca dukkhanirodhagāminiñca paṭipadaṁ."
    },
    {
      "id": "sn22.104:1.3",
      "pali": "Taṁ suṇātha."
    },
    {
      "id": "sn22.104:1.4",
      "pali": "Katamañca, bhikkhave, dukkhaṁ?"
    },
    {
      "id": "sn22.104:1.5",
      "pali": "Pañcupādānakkhandhātissa vacanīyaṁ."
    },
    {
      "id": "sn22.104:1.6",
      "pali": "Katame pañca?"
    },
    {
      "id": "sn22.104:1.7",
      "pali": "Seyyathidaṁ—rūpupādānakkhandho …pe… viññāṇupādānakkhandho."
    },
    {
      "id": "sn22.104:1.8",
      "pali": "Idaṁ vuccati, bhikkhave, dukkhaṁ."
    },
    {
      "id": "sn22.104:1.9",
      "pali": "Katamo ca, bhikkhave, dukkhasamudayo?"
    },
    {
      "id": "sn22.104:1.10",
      "pali": "Yāyaṁ taṇhā ponobhavikā …pe… vibhavataṇhā—"
    },
    {
      "id": "sn22.104:1.11",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhasamudayo."
    },
    {
      "id": "sn22.104:1.12",
      "pali": "Katamo ca, bhikkhave, dukkhanirodho?"
    },
    {
      "id": "sn22.104:1.13",
      "pali": "Yo tassāyeva taṇhāya asesavirāganirodho cāgo paṭinissaggo mutti anālayo—"
    },
    {
      "id": "sn22.104:1.14",
      "pali": "ayaṁ vuccati, bhikkhave, dukkhanirodho."
    },
    {
      "id": "sn22.104:1.15",
      "pali": "Katamā ca, bhikkhave, dukkhanirodhagāminī paṭipadā?"
    },
    {
      "id": "sn22.104:1.16",
      "pali": "Ayameva ariyo aṭṭhaṅgiko maggo."
    },
    {
      "id": "sn22.104:1.17",
      "pali": "Seyyathidaṁ—sammādiṭṭhi …pe… sammāsamādhi."
    },
    {
      "id": "sn22.104:1.18",
      "pali": "Ayaṁ vuccati, bhikkhave, dukkhanirodhagāminī paṭipadā”ti."
    },
    {
      "id": "sn22.104:1.19",
      "pali": "Dutiyaṁ."
    }
  ]
}
