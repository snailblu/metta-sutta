{
  "uid": "sn35.223",
  "title": "Ajjhattāyatanadukkhasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.223:1.1",
      "pali": "“Cakkhu, bhikkhave, dukkhaṁ …pe… jivhā dukkhā …pe… mano dukkho."
    },
    {
      "id": "sn35.223:1.2",
      "pali": "Evaṁ passaṁ …pe…"
    },
    {
      "id": "sn35.223:1.3",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    }
  ]
}
