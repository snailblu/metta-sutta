{
  "uid": "sn55.61",
  "title": "Paññāvepullasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn55.61:1.1",
      "pali": "“…. Paññāvepullāya … saṁvattantī”ti."
    },
    {
      "id": "sn55.61:1.2",
      "pali": "Ekādasamaṁ."
    },
    {
      "id": "sn55.61:1.3",
      "pali": "Sappaññavaggo chaṭṭho."
    },
    {
      "id": "sn55.61:2.1",
      "pali": "Sagāthakaṁ vassaṁvutthaṁ,"
    },
    {
      "id": "sn55.61:2.2",
      "pali": "dhammadinnañca gilānaṁ;"
    },
    {
      "id": "sn55.61:2.3",
      "pali": "Caturo phalā paṭilābho,"
    },
    {
      "id": "sn55.61:2.4",
      "pali": "vuddhi vepullatāya cāti."
    }
  ]
}
