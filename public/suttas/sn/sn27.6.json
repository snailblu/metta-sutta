{
  "uid": "sn27.6",
  "title": "Saññāsutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn27.6:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn27.6:1.2",
      "pali": "“Yo, bhikkhave, rūpasaññāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.6:1.3",
      "pali": "Yo saddasaññāya …"
    },
    {
      "id": "sn27.6:1.4",
      "pali": "yo gandhasaññāya …"
    },
    {
      "id": "sn27.6:1.5",
      "pali": "yo rasasaññāya …"
    },
    {
      "id": "sn27.6:1.6",
      "pali": "yo phoṭṭhabbasaññāya …"
    },
    {
      "id": "sn27.6:1.7",
      "pali": "yo dhammasaññāya chandarāgo, cittasseso upakkileso."
    },
    {
      "id": "sn27.6:1.8",
      "pali": "Yato kho, bhikkhave, bhikkhuno …pe…"
    },
    {
      "id": "sn27.6:1.9",
      "pali": "abhiññā sacchikaraṇīyesu dhammesū”ti."
    },
    {
      "id": "sn27.6:1.10",
      "pali": "Chaṭṭhaṁ."
    }
  ]
}
