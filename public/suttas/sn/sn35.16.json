{
  "uid": "sn35.16",
  "title": "Dutiyaassādapariyesanasutta",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.16:1.1",
      "pali": "“Rūpānāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.2",
      "pali": "Yo rūpānaṁ assādo tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.3",
      "pali": "Yāvatā rūpānaṁ assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.16:1.4",
      "pali": "Rūpānāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.5",
      "pali": "Yo rūpānaṁ ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.6",
      "pali": "Yāvatā rūpānaṁ ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.16:1.7",
      "pali": "Rūpānāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.8",
      "pali": "Yaṁ rūpānaṁ nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.9",
      "pali": "Yāvatā rūpānaṁ nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn35.16:1.10",
      "pali": "Saddānāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.16:1.11",
      "pali": "gandhānāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.16:1.12",
      "pali": "rasānāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.16:1.13",
      "pali": "phoṭṭhabbānāhaṁ, bhikkhave …"
    },
    {
      "id": "sn35.16:1.14",
      "pali": "dhammānāhaṁ, bhikkhave, assādapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.15",
      "pali": "Yo dhammānaṁ assādo tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.16",
      "pali": "Yāvatā dhammānaṁ assādo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.16:1.17",
      "pali": "Dhammānāhaṁ, bhikkhave, ādīnavapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.18",
      "pali": "Yo dhammānaṁ ādīnavo tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.19",
      "pali": "Yāvatā dhammānaṁ ādīnavo paññāya me so sudiṭṭho."
    },
    {
      "id": "sn35.16:1.20",
      "pali": "Dhammānāhaṁ, bhikkhave, nissaraṇapariyesanaṁ acariṁ."
    },
    {
      "id": "sn35.16:1.21",
      "pali": "Yaṁ dhammānaṁ nissaraṇaṁ tadajjhagamaṁ."
    },
    {
      "id": "sn35.16:1.22",
      "pali": "Yāvatā dhammānaṁ nissaraṇaṁ, paññāya me taṁ sudiṭṭhaṁ."
    },
    {
      "id": "sn35.16:2.1",
      "pali": "Yāvakīvañcāhaṁ, bhikkhave, imesaṁ channaṁ bāhirānaṁ āyatanānaṁ assādañca assādato, ādīnavañca ādīnavato, nissaraṇañca nissaraṇato yathābhūtaṁ nābbhaññāsiṁ …pe… paccaññāsiṁ."
    },
    {
      "id": "sn35.16:2.2",
      "pali": "Ñāṇañca pana me dassanaṁ udapādi:"
    },
    {
      "id": "sn35.16:2.3",
      "pali": "‘akuppā me vimutti, ayamantimā jāti, natthi dāni punabbhavo’”ti."
    },
    {
      "id": "sn35.16:2.4",
      "pali": "Catutthaṁ."
    }
  ]
}
