{
  "uid": "sn35.33-42",
  "title": "sn35.33-42",
  "nikaya": "sn",
  "segments": [
    {
      "id": "sn35.33:1.1",
      "pali": "Sāvatthinidānaṁ."
    },
    {
      "id": "sn35.33:1.2",
      "pali": "Tatra kho …pe…"
    },
    {
      "id": "sn35.33:1.3",
      "pali": "“sabbaṁ, bhikkhave, jātidhammaṁ."
    },
    {
      "id": "sn35.33:1.4",
      "pali": "Kiñca, bhikkhave, sabbaṁ jātidhammaṁ?"
    },
    {
      "id": "sn35.33:1.5",
      "pali": "Cakkhu, bhikkhave, jātidhammaṁ."
    },
    {
      "id": "sn35.33:1.6",
      "pali": "Rūpā …"
    },
    {
      "id": "sn35.33:1.7",
      "pali": "cakkhuviññāṇaṁ …"
    },
    {
      "id": "sn35.33:1.8",
      "pali": "cakkhusamphasso jātidhammo."
    },
    {
      "id": "sn35.33:1.9",
      "pali": "Yampidaṁ cakkhusamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi jātidhammaṁ …pe…"
    },
    {
      "id": "sn35.33:1.10",
      "pali": "jivhā …"
    },
    {
      "id": "sn35.33:1.11",
      "pali": "rasā …"
    },
    {
      "id": "sn35.33:1.12",
      "pali": "jivhāviññāṇaṁ …"
    },
    {
      "id": "sn35.33:1.13",
      "pali": "jivhāsamphasso …"
    },
    {
      "id": "sn35.33:1.14",
      "pali": "yampidaṁ jivhāsamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi jātidhammaṁ."
    },
    {
      "id": "sn35.33:1.15",
      "pali": "Kāyo …pe…"
    },
    {
      "id": "sn35.33:1.16",
      "pali": "mano jātidhammo, dhammā jātidhammā, manoviññāṇaṁ jātidhammaṁ, manosamphasso jātidhammo."
    },
    {
      "id": "sn35.33:1.17",
      "pali": "Yampidaṁ manosamphassapaccayā uppajjati vedayitaṁ sukhaṁ vā dukkhaṁ vā adukkhamasukhaṁ vā tampi jātidhammaṁ."
    },
    {
      "id": "sn35.33:1.18",
      "pali": "Evaṁ passaṁ, bhikkhave, sutavā ariyasāvako cakkhusmimpi nibbindati, rūpesupi … cakkhuviññāṇepi … cakkhusamphassepi …pe…"
    },
    {
      "id": "sn35.33:1.19",
      "pali": "nāparaṁ itthattāyāti pajānātī”ti."
    },
    {
      "id": "sn35.33:1.20",
      "pali": "Paṭhamaṁ."
    },
    {
      "id": "sn35.34:1.1",
      "pali": "“Sabbaṁ, bhikkhave, jarādhammaṁ …"
    },
    {
      "id": "sn35.34:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.34:1.3",
      "pali": "Dutiyaṁ."
    },
    {
      "id": "sn35.35:1.1",
      "pali": "“Sabbaṁ, bhikkhave, byādhidhammaṁ …"
    },
    {
      "id": "sn35.35:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.35:1.3",
      "pali": "Tatiyaṁ."
    },
    {
      "id": "sn35.36:1.1",
      "pali": "“Sabbaṁ, bhikkhave, maraṇadhammaṁ …"
    },
    {
      "id": "sn35.36:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.36:1.3",
      "pali": "Catutthaṁ."
    },
    {
      "id": "sn35.37:1.1",
      "pali": "“Sabbaṁ, bhikkhave, sokadhammaṁ …"
    },
    {
      "id": "sn35.37:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.37:1.3",
      "pali": "Pañcamaṁ."
    },
    {
      "id": "sn35.38:1.1",
      "pali": "“Sabbaṁ, bhikkhave, saṅkilesikadhammaṁ …"
    },
    {
      "id": "sn35.38:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.38:1.3",
      "pali": "Chaṭṭhaṁ."
    },
    {
      "id": "sn35.39:1.1",
      "pali": "“Sabbaṁ, bhikkhave, khayadhammaṁ …"
    },
    {
      "id": "sn35.39:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.39:1.3",
      "pali": "Sattamaṁ."
    },
    {
      "id": "sn35.40:1.1",
      "pali": "“Sabbaṁ, bhikkhave, vayadhammaṁ …"
    },
    {
      "id": "sn35.40:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.40:1.3",
      "pali": "Aṭṭhamaṁ."
    },
    {
      "id": "sn35.41:1.1",
      "pali": "“Sabbaṁ, bhikkhave, samudayadhammaṁ …"
    },
    {
      "id": "sn35.41:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.41:1.3",
      "pali": "Navamaṁ."
    },
    {
      "id": "sn35.42:1.1",
      "pali": "“Sabbaṁ, bhikkhave, nirodhadhammaṁ …"
    },
    {
      "id": "sn35.42:1.2",
      "pali": "saṅkhittaṁ."
    },
    {
      "id": "sn35.42:1.3",
      "pali": "Dasamaṁ."
    },
    {
      "id": "sn35.42:1.4",
      "pali": "Jātidhammavaggo catuttho."
    },
    {
      "id": "sn35.42:2.1",
      "pali": "Jātijarābyādhimaraṇaṁ,"
    },
    {
      "id": "sn35.42:2.2",
      "pali": "Soko ca saṅkilesikaṁ;"
    },
    {
      "id": "sn35.42:2.3",
      "pali": "Khayavayasamudayaṁ,"
    },
    {
      "id": "sn35.42:2.4",
      "pali": "Nirodhadhammena te dasāti."
    }
  ]
