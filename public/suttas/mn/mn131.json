{
  "uid": "mn131",
  "title": "Bhaddekarattasutta",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mn131:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "mn131:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "mn131:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "mn131:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "mn131:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn131:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn131:2.1",
      "pali": "“bhaddekarattassa vo, bhikkhave, uddesañca vibhaṅgañca desessāmi."
    },
    {
      "id": "mn131:2.2",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "mn131:2.3",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn131:2.4",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn131:3.1",
      "pali": "“Atītaṁ nānvāgameyya,"
    },
    {
      "id": "mn131:3.2",
      "pali": "nappaṭikaṅkhe anāgataṁ;"
    },
    {
      "id": "mn131:3.3",
      "pali": "Yadatītaṁ pahīnaṁ taṁ,"
    },
    {
      "id": "mn131:3.4",
      "pali": "appattañca anāgataṁ."
    },
    {
      "id": "mn131:3.5",
      "pali": "Paccuppannañca yo dhammaṁ,"
    },
    {
      "id": "mn131:3.6",
      "pali": "Tattha tattha vipassati;"
    },
    {
      "id": "mn131:3.7",
      "pali": "Asaṁhīraṁ asaṅkuppaṁ,"
    },
    {
      "id": "mn131:3.8",
      "pali": "Taṁ vidvā manubrūhaye."
    },
    {
      "id": "mn131:3.9",
      "pali": "Ajjeva kiccamātappaṁ,"
    },
    {
      "id": "mn131:3.10",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "mn131:3.11",
      "pali": "Na hi no saṅgaraṁ tena,"
    },
    {
      "id": "mn131:3.12",
      "pali": "mahāsenena maccunā."
    },
    {
      "id": "mn131:3.13",
      "pali": "Evaṁvihāriṁ ātāpiṁ,"
    },
    {
      "id": "mn131:3.14",
      "pali": "ahorattamatanditaṁ;"
    },
    {
      "id": "mn131:3.15",
      "pali": "Taṁ ve bhaddekarattoti,"
    },
    {
      "id": "mn131:3.16",
      "pali": "santo ācikkhate muni."
    },
    {
      "id": "mn131:4.1",
      "pali": "Kathañca, bhikkhave, atītaṁ anvāgameti?"
    },
    {
      "id": "mn131:4.2",
      "pali": "‘Evaṁrūpo ahosiṁ atītamaddhānan’ti tattha nandiṁ samanvāneti, ‘evaṁvedano ahosiṁ atītamaddhānan’ti tattha nandiṁ samanvāneti, ‘evaṁsañño ahosiṁ atītamaddhānan’ti tattha nandiṁ samanvāneti, ‘evaṁsaṅkhāro ahosiṁ atītamaddhānan’ti tattha nandiṁ samanvāneti, ‘evaṁviññāṇo ahosiṁ atītamaddhānan’ti tattha nandiṁ samanvāneti—"
    },
    {
      "id": "mn131:4.3",
      "pali": "evaṁ kho, bhikkhave, atītaṁ anvāgameti."
    },
    {
      "id": "mn131:5.1",
      "pali": "Kathañca, bhikkhave, atītaṁ nānvāgameti?"
    },
    {
      "id": "mn131:5.2",
      "pali": "‘Evaṁrūpo ahosiṁ atītamaddhānan’ti tattha nandiṁ na samanvāneti, ‘evaṁvedano ahosiṁ atītamaddhānan’ti tattha nandiṁ na samanvāneti, ‘evaṁsañño ahosiṁ atītamaddhānan’ti tattha nandiṁ na samanvāneti, ‘evaṁsaṅkhāro ahosiṁ atītamaddhānan’ti tattha nandiṁ na samanvāneti, ‘evaṁviññāṇo ahosiṁ atītamaddhānan’ti tattha nandiṁ na samanvāneti—"
    },
    {
      "id": "mn131:5.3",
      "pali": "evaṁ kho, bhikkhave, atītaṁ nānvāgameti."
    },
    {
      "id": "mn131:6.1",
      "pali": "Kathañca, bhikkhave, anāgataṁ paṭikaṅkhati?"
    },
    {
      "id": "mn131:6.2",
      "pali": "‘Evaṁrūpo siyaṁ anāgatamaddhānan’ti tattha nandiṁ samanvāneti, evaṁvedano siyaṁ …pe… evaṁsañño siyaṁ … evaṁsaṅkhāro siyaṁ … evaṁviññāṇo siyaṁ anāgatamaddhānanti tattha nandiṁ samanvāneti—"
    },
    {
      "id": "mn131:6.3",
      "pali": "evaṁ kho, bhikkhave, anāgataṁ paṭikaṅkhati."
    },
    {
      "id": "mn131:7.1",
      "pali": "Kathañca, bhikkhave, anāgataṁ nappaṭikaṅkhati?"
    },
    {
      "id": "mn131:7.2",
      "pali": "‘Evaṁrūpo siyaṁ anāgatamaddhānan’ti tattha nandiṁ na samanvāneti, evaṁvedano siyaṁ … evaṁsañño siyaṁ … evaṁsaṅkhāro siyaṁ … ‘evaṁviññāṇo siyaṁ anāgatamaddhānan’ti tattha nandiṁ na samanvāneti—"
    },
    {
      "id": "mn131:7.3",
      "pali": "evaṁ kho, bhikkhave, anāgataṁ nappaṭikaṅkhati."
    },
    {
      "id": "mn131:8.1",
      "pali": "Kathañca, bhikkhave, paccuppannesu dhammesu saṁhīrati?"
    },
    {
      "id": "mn131:8.2",
      "pali": "Idha, bhikkhave, assutavā puthujjano ariyānaṁ adassāvī ariyadhammassa akovido ariyadhamme avinīto sappurisānaṁ adassāvī sappurisadhammassa akovido sappurisadhamme avinīto"
    },
    {
      "id": "mn131:8.3",
      "pali": "rūpaṁ attato samanupassati, rūpavantaṁ vā attānaṁ, attani vā rūpaṁ, rūpasmiṁ vā attānaṁ;"
    },
    {
      "id": "mn131:8.4",
      "pali": "vedanaṁ …pe…"
    },
    {
      "id": "mn131:8.5",
      "pali": "saññaṁ …"
    },
    {
      "id": "mn131:8.6",
      "pali": "saṅkhāre …"
    },
    {
      "id": "mn131:8.7",
      "pali": "viññāṇaṁ attato samanupassati, viññāṇavantaṁ vā attānaṁ attani vā viññāṇaṁ, viññāṇasmiṁ vā attānaṁ—"
    },
    {
      "id": "mn131:8.8",
      "pali": "evaṁ kho, bhikkhave, paccuppannesu dhammesu saṁhīrati."
    },
    {
      "id": "mn131:9.1",
      "pali": "Kathañca, bhikkhave, paccuppannesu dhammesu na saṁhīrati?"
    },
    {
      "id": "mn131:9.2",
      "pali": "Idha, bhikkhave, sutavā ariyasāvako ariyānaṁ dassāvī ariyadhammassa kovido ariyadhamme suvinīto sappurisānaṁ dassāvī sappurisadhammassa kovido sappurisadhamme suvinīto"
    },
    {
      "id": "mn131:9.3",
      "pali": "na rūpaṁ attato samanupassati, na rūpavantaṁ vā attānaṁ, na attani vā rūpaṁ, na rūpasmiṁ vā attānaṁ;"
    },
    {
      "id": "mn131:9.4",
      "pali": "na vedanaṁ …"
    },
    {
      "id": "mn131:9.5",
      "pali": "na saññaṁ …"
    },
    {
      "id": "mn131:9.6",
      "pali": "na saṅkhāre …"
    },
    {
      "id": "mn131:9.7",
      "pali": "na viññāṇaṁ attato samanupassati, na viññāṇavantaṁ vā attānaṁ, na attani vā viññāṇaṁ, na viññāṇasmiṁ vā attānaṁ—"
    },
    {
      "id": "mn131:9.8",
      "pali": "evaṁ kho, bhikkhave, paccuppannesu dhammesu na saṁhīrati."
    },
    {
      "id": "mn131:10.1",
      "pali": "Atītaṁ nānvāgameyya,"
    },
    {
      "id": "mn131:10.2",
      "pali": "nappaṭikaṅkhe anāgataṁ;"
    },
    {
      "id": "mn131:10.3",
      "pali": "Yadatītaṁ pahīnaṁ taṁ,"
    },
    {
      "id": "mn131:10.4",
      "pali": "appattañca anāgataṁ."
    },
    {
      "id": "mn131:10.5",
      "pali": "Paccuppannañca yo dhammaṁ,"
    },
    {
      "id": "mn131:10.6",
      "pali": "tattha tattha vipassati;"
    },
    {
      "id": "mn131:10.7",
      "pali": "Asaṁhīraṁ asaṅkuppaṁ,"
    },
    {
      "id": "mn131:10.8",
      "pali": "taṁ vidvā manubrūhaye."
    },
    {
      "id": "mn131:10.9",
      "pali": "Ajjeva kiccamātappaṁ,"
    },
    {
      "id": "mn131:10.10",
      "pali": "ko jaññā maraṇaṁ suve;"
    },
    {
      "id": "mn131:10.11",
      "pali": "Na hi no saṅgaraṁ tena,"
    },
    {
      "id": "mn131:10.12",
      "pali": "mahāsenena maccunā."
    },
    {
      "id": "mn131:10.13",
      "pali": "Evaṁvihāriṁ ātāpiṁ,"
    },
    {
      "id": "mn131:10.14",
      "pali": "ahorattamatanditaṁ;"
    },
    {
      "id": "mn131:10.15",
      "pali": "Taṁ ve bhaddekarattoti,"
    },
    {
      "id": "mn131:10.16",
      "pali": "santo ācikkhate munīti."
    },
    {
      "id": "mn131:11.1",
      "pali": "‘Bhaddekarattassa vo, bhikkhave, uddesañca vibhaṅgañca desessāmī’ti—"
    },
    {
      "id": "mn131:11.2",
      "pali": "iti yaṁ taṁ vuttaṁ idametaṁ paṭicca vuttan”ti."
    },
    {
      "id": "mn131:11.3",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "mn131:11.4",
      "pali": "Attamanā te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "mn131:11.5",
      "pali": "Bhaddekarattasuttaṁ niṭṭhitaṁ paṭhamaṁ."
    }
  ]
}
