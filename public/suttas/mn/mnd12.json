{
  "uid": "mnd12",
  "title": "12. Cūḷabyūhasuttaniddesa",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mnd12:1.1",
      "pali": "Atha cūḷabyūhasuttaniddesaṁ vakkhati—"
    },
    {
      "id": "mnd12:2.1",
      "pali": "<b>Sakaṁ sakaṁ diṭṭhiparibbasānā,</b>"
    },
    {
      "id": "mnd12:2.2",
      "pali": "<b>Viggayha nānā kusalā vadanti;</b>"
    },
    {
      "id": "mnd12:2.3",
      "pali": "<b>Yo evaṁ jānāti sa vedi dhammaṁ,</b>"
    },
    {
      "id": "mnd12:2.4",
      "pali": "<b>Idaṁ paṭikkosamakevalī so.</b>"
    },
    {
      "id": "mnd12:3.1",
      "pali": "<b>Sakaṁ sakaṁ diṭṭhiparibbasānā</b>ti."
    },
    {
      "id": "mnd12:3.2",
      "pali": "Santeke samaṇabrāhmaṇā diṭṭhigatikā;"
    },
    {
      "id": "mnd12:3.3",
      "pali": "te dvāsaṭṭhiyā diṭṭhigatānaṁ aññataraññataraṁ diṭṭhigataṁ gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā sakāya sakāya diṭṭhiyā vasanti saṁvasanti āvasanti parivasanti."
    },
    {
      "id": "mnd12:3.4",
      "pali": "Yathā agārikā gharesu vasanti, sāpattikā vā āpattīsu vasanti, sakilesā vā kilesesu vasanti;"
    },
    {
      "id": "mnd12:3.5",
      "pali": "evamevaṁ santeke samaṇabrāhmaṇā diṭṭhigatikā, te dvāsaṭṭhiyā diṭṭhigatānaṁ aññataraññataraṁ diṭṭhigataṁ gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā sakāya sakāya diṭṭhiyā vasanti saṁvasanti āvasanti parivasantīti—"
    },
    {
      "id": "mnd12:3.6",
      "pali": "sakaṁ sakaṁ diṭṭhiparibbasānā."
    },
    {
      "id": "mnd12:4.1",
      "pali": "<b>Viggayha nānā kusalā vadantī</b>ti."
    },
    {
      "id": "mnd12:4.2",
      "pali": "<b>Viggayhā</b>ti gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā nānā vadanti vividhaṁ vadanti aññoññaṁ vadanti puthu vadanti, na ekaṁ vadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:4.3",
      "pali": "<b>Kusalā</b>ti kusalavādā paṇḍitavādā thiravādā ñāyavādā hetuvādā lakkhaṇavādā kāraṇavādā ṭhānavādā sakāya laddhiyāti—"
    },
    {
      "id": "mnd12:4.4",
      "pali": "viggayha nānā kusalā vadanti."
    },
    {
      "id": "mnd12:5.1",
      "pali": "<b>Yo evaṁ jānāti sa vedi dhamman</b>ti."
    },
    {
      "id": "mnd12:5.2",
      "pali": "Yo imaṁ dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ jānāti so dhammaṁ vedi aññāsi apassi paṭivijjhīti—"
    },
    {
      "id": "mnd12:5.3",
      "pali": "yo evaṁ jānāti sa vedi dhammaṁ."
    },
    {
      "id": "mnd12:6.1",
      "pali": "<b>Idaṁ paṭikkosamakevalī so</b>ti."
    },
    {
      "id": "mnd12:6.2",
      "pali": "Yo imaṁ dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ paṭikkosati, akevalī so asamatto so aparipuṇṇo so hīno nihīno omako lāmako chatukko parittoti—"
    },
    {
      "id": "mnd12:6.3",
      "pali": "idaṁ paṭikkosamakevalī so."
    },
    {
      "id": "mnd12:7.1",
      "pali": "Tenāha so nimmito—"
    },
    {
      "id": "mnd12:8.1",
      "pali": "“Sakaṁ sakaṁ diṭṭhiparibbasānā,"
    },
    {
      "id": "mnd12:8.2",
      "pali": "Viggayha nānā kusalā vadanti;"
    },
    {
      "id": "mnd12:8.3",
      "pali": "Yo evaṁ jānāti sa vedi dhammaṁ,"
    },
    {
      "id": "mnd12:8.4",
      "pali": "Idaṁ paṭikkosamakevalī so”ti."
    },
    {
      "id": "mnd12:9.1",
      "pali": "<b>Evampi viggayha vivādayanti,</b>"
    },
    {
      "id": "mnd12:9.2",
      "pali": "<b>Bālo paro akkusaloti cāhu;</b>"
    },
    {
      "id": "mnd12:9.3",
      "pali": "<b>Sacco nu vādo katamo imesaṁ,</b>"
    },
    {
      "id": "mnd12:9.4",
      "pali": "<b>Sabbeva hīme kusalāvadānā.</b>"
    },
    {
      "id": "mnd12:10.1",
      "pali": "<b>Evampi viggayha vivādayantī</b>ti."
    },
    {
      "id": "mnd12:10.2",
      "pali": "Evaṁ gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā vivādayanti, kalahaṁ karonti, bhaṇḍanaṁ karonti, viggahaṁ karonti, vivādaṁ karonti, medhagaṁ karonti—"
    },
    {
      "id": "mnd12:10.3",
      "pali": "“na tvaṁ imaṁ dhammavinayaṁ ājānāsi …pe…"
    },
    {
      "id": "mnd12:10.4",
      "pali": "nibbeṭhehi vā sace pahosī”ti—"
    },
    {
      "id": "mnd12:10.5",
      "pali": "evampi viggayha vivādayanti."
    },
    {
      "id": "mnd12:11.1",
      "pali": "<b>Bālo paro akkusaloti cāhū</b>ti."
    },
    {
      "id": "mnd12:11.2",
      "pali": "Paro bālo hīno nihīno omako lāmako chatukko paritto akusalo avidvā avijjāgato aññāṇī avibhāvī duppaññoti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:11.3",
      "pali": "bālo paro akkusaloti cāhu."
    },
    {
      "id": "mnd12:12.1",
      "pali": "<b>Sacco nu vādo katamo imesan</b>ti."
    },
    {
      "id": "mnd12:12.2",
      "pali": "Imesaṁ samaṇabrāhmaṇānaṁ vādo katamo sacco taccho tatho bhūto yāthāvo aviparītoti—"
    },
    {
      "id": "mnd12:12.3",
      "pali": "sacco nu vādo katamo imesaṁ."
    },
    {
      "id": "mnd12:13.1",
      "pali": "<b>Sabbeva hīme kusalāvadānā</b>ti."
    },
    {
      "id": "mnd12:13.2",
      "pali": "Sabbevime samaṇabrāhmaṇā kusalavādā paṇḍitavādā thiravādā ñāyavādā hetuvādā lakkhaṇavādā kāraṇavādā ṭhānavādā sakāya laddhiyāti—"
    },
    {
      "id": "mnd12:13.3",
      "pali": "sabbeva hīme kusalāvadānā."
    },
    {
      "id": "mnd12:14.1",
      "pali": "Tenāha so nimmito—"
    },
    {
      "id": "mnd12:15.1",
      "pali": "“Evampi viggayha vivādayanti,"
    },
    {
      "id": "mnd12:15.2",
      "pali": "Bālo paro akkusaloti cāhu;"
    },
    {
      "id": "mnd12:15.3",
      "pali": "Sacco nu vādo katamo imesaṁ,"
    },
    {
      "id": "mnd12:15.4",
      "pali": "Sabbeva hīme kusalāvadānā”ti."
    },
    {
      "id": "mnd12:16.1",
      "pali": "<b>Parassa ce dhammamanānujānaṁ,</b>"
    },
    {
      "id": "mnd12:16.2",
      "pali": "<b>Bālomako hoti nihīnapañño;</b>"
    },
    {
      "id": "mnd12:16.3",
      "pali": "<b>Sabbeva bālā sunihīnapaññā,</b>"
    },
    {
      "id": "mnd12:16.4",
      "pali": "<b>Sabbevime diṭṭhiparibbasānā.</b>"
    },
    {
      "id": "mnd12:17.1",
      "pali": "<b>Parassa ce dhammamanānujānan</b>ti."
    },
    {
      "id": "mnd12:17.2",
      "pali": "Parassa dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ anānujānanto anānupassanto anānumananto anānumaññanto anānumodantoti—"
    },
    {
      "id": "mnd12:17.3",
      "pali": "parassa ce dhammamanānujānaṁ."
    },
    {
      "id": "mnd12:18.1",
      "pali": "<b>Bālomako hoti nihīnapañño</b>ti."
    },
    {
      "id": "mnd12:18.2",
      "pali": "Paro bālo hoti hīno nihīno omako lāmako chatukko paritto, hīnapañño nihīnapañño omakapañño lāmakapañño chatukkapañño parittapaññoti—"
    },
    {
      "id": "mnd12:18.3",
      "pali": "bālomako hoti nihīnapañño."
    },
    {
      "id": "mnd12:19.1",
      "pali": "<b>Sabbeva bālā sunihīnapaññā</b>ti."
    },
    {
      "id": "mnd12:19.2",
      "pali": "Sabbevime samaṇabrāhmaṇā bālā hīnā nihīnā omakā lāmakā chatukkā parittā, sabbeva hīnapaññā nihīnapaññā omakapaññā lāmakapaññā chatukkapaññā parittapaññāti—"
    },
    {
      "id": "mnd12:19.3",
      "pali": "sabbeva bālā sunihīnapaññā."
    },
    {
      "id": "mnd12:20.1",
      "pali": "<b>Sabbevime diṭṭhiparibbasānā</b>ti."
    },
    {
      "id": "mnd12:20.2",
      "pali": "Sabbevime samaṇabrāhmaṇā diṭṭhigatikā;"
    },
    {
      "id": "mnd12:20.3",
      "pali": "te dvāsaṭṭhiyā diṭṭhigatānaṁ aññataraññataraṁ diṭṭhigataṁ gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā sakāya sakāya diṭṭhiyā vasanti saṁvasanti āvasanti parivasanti."
    },
    {
      "id": "mnd12:20.4",
      "pali": "Yathā agārikā vā gharesu vasanti, sāpattikā vā āpattīsu vasanti, sakilesā vā kilesesu vasanti;"
    },
    {
      "id": "mnd12:20.5",
      "pali": "evamevaṁ sabbevime samaṇabrāhmaṇā diṭṭhigatikā …pe…"
    },
    {
      "id": "mnd12:20.6",
      "pali": "parivasantīti—"
    },
    {
      "id": "mnd12:20.7",
      "pali": "sabbevime diṭṭhiparibbasānā."
    },
    {
      "id": "mnd12:21.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:22.1",
      "pali": "“Parassa ce dhammamanānujānaṁ,"
    },
    {
      "id": "mnd12:22.2",
      "pali": "Bālomako hoti nihīnapañño;"
    },
    {
      "id": "mnd12:22.3",
      "pali": "Sabbeva bālā sunihīnapaññā,"
    },
    {
      "id": "mnd12:22.4",
      "pali": "Sabbevime diṭṭhiparibbasānā”ti."
    },
    {
      "id": "mnd12:23.1",
      "pali": "<b>Sandiṭṭhiyā ceva navīvadātā,</b>"
    },
    {
      "id": "mnd12:23.2",
      "pali": "<b>Saṁsuddhapaññā kusalā mutīmā;</b>"
    },
    {
      "id": "mnd12:23.3",
      "pali": "<b>Na tesaṁ koci parihīnapañño,</b>"
    },
    {
      "id": "mnd12:23.4",
      "pali": "<b>Diṭṭhī hi tesampi tathā samattā.</b>"
    },
    {
      "id": "mnd12:24.1",
      "pali": "<b>Sandiṭṭhiyā ceva navīvadātā</b>ti."
    },
    {
      "id": "mnd12:24.2",
      "pali": "Sakāya diṭṭhiyā sakāya khantiyā sakāya ruciyā sakāya laddhiyā anavīvadātā avodātā apariyodātā saṅkiliṭṭhā saṅkilesikāti—"
    },
    {
      "id": "mnd12:24.3",
      "pali": "sandiṭṭhiyā ceva navīvadātā."
    },
    {
      "id": "mnd12:25.1",
      "pali": "<b>Saṁsuddhapaññā kusalā mutīmā</b>ti."
    },
    {
      "id": "mnd12:25.2",
      "pali": "Suddhapaññā visuddhapaññā parisuddhapaññā vodātapaññā pariyodātapaññā."
    },
    {
      "id": "mnd12:25.3",
      "pali": "Atha vā suddhadassanā visuddhadassanā parisuddhadassanā vodātadassanā pariyodātadassanāti—"
    },
    {
      "id": "mnd12:25.4",
      "pali": "saṁsuddhapaññā."
    },
    {
      "id": "mnd12:25.5",
      "pali": "<b>Kusalā</b>ti kusalā paṇḍitā paññavanto iddhimanto ñāṇino vibhāvino medhāvinoti—"
    },
    {
      "id": "mnd12:25.6",
      "pali": "saṁsuddhapaññā kusalā."
    },
    {
      "id": "mnd12:25.7",
      "pali": "<b>Mutīmā</b>ti mutimā paṇḍitā paññavanto iddhimanto ñāṇino vibhāvino medhāvinoti—"
    },
    {
      "id": "mnd12:25.8",
      "pali": "saṁsuddhapaññā kusalā mutīmā."
    },
    {
      "id": "mnd12:26.1",
      "pali": "<b>Tesaṁ na koci parihīnapañño</b>ti."
    },
    {
      "id": "mnd12:26.2",
      "pali": "Tesaṁ samaṇabrāhmaṇānaṁ na koci hīnapañño nihīnapañño omakapañño lāmakapañño chatukkapañño parittapañño atthi."
    },
    {
      "id": "mnd12:26.3",
      "pali": "Sabbeva seṭṭhapaññā visiṭṭhapaññā pāmokkhapaññā uttamapaññā pavarapaññāti—"
    },
    {
      "id": "mnd12:26.4",
      "pali": "tesaṁ na koci parihīnapañño."
    },
    {
      "id": "mnd12:27.1",
      "pali": "<b>Diṭṭhī hi tesampi tathā samattā</b>ti."
    },
    {
      "id": "mnd12:27.2",
      "pali": "Tesaṁ samaṇabrāhmaṇānaṁ diṭṭhi tathā samattā samādinnā gahitā parāmaṭṭhā abhiniviṭṭhā ajjhositā adhimuttāti—"
    },
    {
      "id": "mnd12:27.3",
      "pali": "diṭṭhī hi tesampi tathā samattā."
    },
    {
      "id": "mnd12:28.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:29.1",
      "pali": "“Sandiṭṭhiyā ceva navīvadātā,"
    },
    {
      "id": "mnd12:29.2",
      "pali": "Saṁsuddhapaññā kusalā mutīmā;"
    },
    {
      "id": "mnd12:29.3",
      "pali": "Tesaṁ na koci parihīnapañño,"
    },
    {
      "id": "mnd12:29.4",
      "pali": "Diṭṭhī hi tesampi tathā samattā”ti."
    },
    {
      "id": "mnd12:30.1",
      "pali": "<b>Na vāhametaṁ tathiyanti brūmi,</b>"
    },
    {
      "id": "mnd12:30.2",
      "pali": "<b>Yamāhu bālā mithu aññamaññaṁ;</b>"
    },
    {
      "id": "mnd12:30.3",
      "pali": "<b>Sakaṁ sakaṁ diṭṭhimakaṁsu saccaṁ,</b>"
    },
    {
      "id": "mnd12:30.4",
      "pali": "<b>Tasmā hi bāloti paraṁ dahanti.</b>"
    },
    {
      "id": "mnd12:31.1",
      "pali": "<b>Na vāhametaṁ tathiyanti brūmī</b>ti."
    },
    {
      "id": "mnd12:31.2",
      "pali": "<b>Nā</b>ti paṭikkhepo."
    },
    {
      "id": "mnd12:31.3",
      "pali": "<b>Etan</b>ti “dvāsaṭṭhidiṭṭhigatāni nāhaṁ etaṁ tacchaṁ tathaṁ bhūtaṁ yāthāvaṁ aviparītan”ti brūmi ācikkhāmi desemi paññapemi paṭṭhapemi vivarāmi vibhajāmi uttānīkaromi pakāsemīti—"
    },
    {
      "id": "mnd12:31.4",
      "pali": "na vāhametaṁ tathiyanti brūmi."
    },
    {
      "id": "mnd12:32.1",
      "pali": "<b>Yamāhu bālā mithu aññamaññan</b>ti."
    },
    {
      "id": "mnd12:32.2",
      "pali": "<b>Mithū</b>ti dve janā, dve kalahakārakā, dve bhaṇḍanakārakā, dve bhassakārakā, dve vivādakārakā, dve adhikaraṇakārakā, dve vādino, dve sallapakā;"
    },
    {
      "id": "mnd12:32.3",
      "pali": "te aññamaññaṁ bālo hīno nihīno omako lāmako chatukko parittoti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:32.4",
      "pali": "yamāhu bālā mithu aññamaññaṁ."
    },
    {
      "id": "mnd12:33.1",
      "pali": "<b>Sakaṁ sakaṁ diṭṭhimakaṁsu saccan</b>ti."
    },
    {
      "id": "mnd12:33.2",
      "pali": "“Sassato loko, idameva saccaṁ moghamaññan”ti—"
    },
    {
      "id": "mnd12:33.3",
      "pali": "sakaṁ sakaṁ diṭṭhimakaṁsu saccaṁ."
    },
    {
      "id": "mnd12:33.4",
      "pali": "“Asassato loko, idameva saccaṁ moghamaññan”ti …pe…"
    },
    {
      "id": "mnd12:33.5",
      "pali": "“neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti—"
    },
    {
      "id": "mnd12:33.6",
      "pali": "sakaṁ sakaṁ diṭṭhimakaṁsu saccaṁ."
    },
    {
      "id": "mnd12:34.1",
      "pali": "<b>Tasmā hi bāloti paraṁ dahantī</b>ti."
    },
    {
      "id": "mnd12:34.2",
      "pali": "<b>Tasmā</b>ti tasmā taṅkāraṇā taṁhetu tappaccayā taṁnidānā paraṁ bālo hīno nihīno omako lāmako chatukko parittoti dahanti passanti dakkhanti olokenti nijjhāyanti upaparikkhantīti—"
    },
    {
      "id": "mnd12:34.3",
      "pali": "tasmā hi bāloti paraṁ dahanti."
    },
    {
      "id": "mnd12:35.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:36.1",
      "pali": "“Na vāhametaṁ tathiyanti brūmi,"
    },
    {
      "id": "mnd12:36.2",
      "pali": "Yamāhu bālā mithu aññamaññaṁ;"
    },
    {
      "id": "mnd12:36.3",
      "pali": "Sakaṁ sakaṁ diṭṭhimakaṁsu saccaṁ,"
    },
    {
      "id": "mnd12:36.4",
      "pali": "Tasmā hi bāloti paraṁ dahantī”ti."
    },
    {
      "id": "mnd12:37.1",
      "pali": "<b>Yamāhu saccaṁ tathiyanti eke,</b>"
    },
    {
      "id": "mnd12:37.2",
      "pali": "<b>Tamāhu aññepi tucchaṁ musāti;</b>"
    },
    {
      "id": "mnd12:37.3",
      "pali": "<b>Evampi viggayha vivādayanti,</b>"
    },
    {
      "id": "mnd12:37.4",
      "pali": "<b>Kasmā na ekaṁ samaṇā vadanti.</b>"
    },
    {
      "id": "mnd12:38.1",
      "pali": "<b>Yamāhu saccaṁ tathiyanti eke</b>ti."
    },
    {
      "id": "mnd12:38.2",
      "pali": "Yaṁ dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ eke samaṇabrāhmaṇā “idaṁ saccaṁ tacchaṁ tathaṁ bhūtaṁ yāthāvaṁ aviparītan”ti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:38.3",
      "pali": "yamāhu saccaṁ tathiyanti eke."
    },
    {
      "id": "mnd12:39.1",
      "pali": "<b>Tamāhu aññepi tucchaṁ musātī</b>ti."
    },
    {
      "id": "mnd12:39.2",
      "pali": "Tameva dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ eke samaṇabrāhmaṇā “tucchaṁ etaṁ, musā etaṁ, abhūtaṁ etaṁ, alikaṁ etaṁ, ayāthāvaṁ etan”ti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:39.3",
      "pali": "tamāhu aññepi tucchaṁ musāti."
    },
    {
      "id": "mnd12:40.1",
      "pali": "<b>Evampi viggayha vivādayantī</b>ti."
    },
    {
      "id": "mnd12:40.2",
      "pali": "Evaṁ gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā vivādayanti, kalahaṁ karonti, bhaṇḍanaṁ karonti, viggahaṁ karonti, vivādaṁ karonti, medhagaṁ karonti—"
    },
    {
      "id": "mnd12:40.3",
      "pali": "“na tvaṁ imaṁ dhammavinayaṁ ājānāsi …pe…"
    },
    {
      "id": "mnd12:40.4",
      "pali": "nibbeṭhehi vā sace pahosī”ti—"
    },
    {
      "id": "mnd12:40.5",
      "pali": "evampi viggayha vivādayanti."
    },
    {
      "id": "mnd12:41.1",
      "pali": "<b>Kasmā na ekaṁ samaṇā vadantī</b>ti."
    },
    {
      "id": "mnd12:41.2",
      "pali": "<b>Kasmā</b>ti kasmā kiṅkāraṇā kiṁhetu kiṁpaccayā kiṁnidānā kiṁsamudayā kiṁjātikā kiṁpabhavā na ekaṁ vadanti nānā vadanti vividhaṁ vadanti aññoññaṁ vadanti puthu vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:41.3",
      "pali": "kasmā na ekaṁ samaṇā vadanti."
    },
    {
      "id": "mnd12:42.1",
      "pali": "Tenāha so nimmito—"
    },
    {
      "id": "mnd12:43.1",
      "pali": "“Yamāhu saccaṁ tathiyanti eke,"
    },
    {
      "id": "mnd12:43.2",
      "pali": "Tamāhu aññepi tucchaṁ musāti;"
    },
    {
      "id": "mnd12:43.3",
      "pali": "Evampi viggayha vivādayanti,"
    },
    {
      "id": "mnd12:43.4",
      "pali": "Kasmā na ekaṁ samaṇā vadantī”ti."
    },
    {
      "id": "mnd12:44.1",
      "pali": "<b>Ekañhi saccaṁ na dutīyamatthi,</b>"
    },
    {
      "id": "mnd12:44.2",
      "pali": "<b>Yasmiṁ pajā no vivade pajānaṁ;</b>"
    },
    {
      "id": "mnd12:44.3",
      "pali": "<b>Nānā te saccāni sayaṁ thunanti,</b>"
    },
    {
      "id": "mnd12:44.4",
      "pali": "<b>Tasmā na ekaṁ samaṇā vadanti.</b>"
    },
    {
      "id": "mnd12:45.1",
      "pali": "<b>Ekañhi saccaṁ na dutīyamatthī</b>ti."
    },
    {
      "id": "mnd12:45.2",
      "pali": "Ekaṁ saccaṁ vuccati dukkhanirodho nibbānaṁ."
    },
    {
      "id": "mnd12:45.3",
      "pali": "Yo so sabbasaṅkhārasamatho sabbūpadhipaṭinissaggo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "mnd12:45.4",
      "pali": "Atha vā ekaṁ saccaṁ vuccati—"
    },
    {
      "id": "mnd12:45.5",
      "pali": "maggasaccaṁ, niyyānasaccaṁ, dukkhanirodhagāminī paṭipadā, ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "mnd12:45.6",
      "pali": "sammādiṭṭhi, sammāsaṅkappo, sammāvācā, sammākammanto, sammāājīvo, sammāvāyāmo, sammāsati, sammāsamādhīti—"
    },
    {
      "id": "mnd12:45.7",
      "pali": "ekañhi saccaṁ na dutīyamatthi."
    },
    {
      "id": "mnd12:46.1",
      "pali": "<b>Yasmiṁ pajā no vivade pajānan</b>ti."
    },
    {
      "id": "mnd12:46.2",
      "pali": "<b>Yasmin</b>ti yasmiṁ sacce."
    },
    {
      "id": "mnd12:46.3",
      "pali": "<b>Pajā</b>ti sattādhivacanaṁ."
    },
    {
      "id": "mnd12:46.4",
      "pali": "<b>Pajānan</b>ti yaṁ saccaṁ pajānantā ājānantā vijānantā paṭivijānantā paṭivijjhantā na kalahaṁ kareyyuṁ, na bhaṇḍanaṁ kareyyuṁ, na viggahaṁ kareyyuṁ, na vivādaṁ kareyyuṁ, na medhagaṁ kareyyuṁ, kalahaṁ bhaṇḍanaṁ viggahaṁ vivādaṁ medhagaṁ pajaheyyuṁ, vinodeyyuṁ, byantiṁ kareyyuṁ, anabhāvaṁ gameyyunti—"
    },
    {
      "id": "mnd12:46.5",
      "pali": "yasmiṁ pajā no vivade pajānaṁ."
    },
    {
      "id": "mnd12:47.1",
      "pali": "<b>Nānā te saccāni sayaṁ thunantī</b>ti."
    },
    {
      "id": "mnd12:47.2",
      "pali": "Nānā te saccāni sayaṁ thunanti vadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:47.3",
      "pali": "“Sassato loko, idameva saccaṁ moghamaññan”ti sayaṁ thunanti vadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:47.4",
      "pali": "“Asassato loko …pe…"
    },
    {
      "id": "mnd12:47.5",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti sayaṁ thunanti vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:47.6",
      "pali": "nānā te saccāni sayaṁ thunanti."
    },
    {
      "id": "mnd12:48.1",
      "pali": "<b>Tasmā na ekaṁ samaṇā vadantī</b>ti."
    },
    {
      "id": "mnd12:48.2",
      "pali": "<b>Tasmā</b>ti tasmā taṅkāraṇā taṁhetu tappaccayā taṁnidānā na ekaṁ vadanti nānā vadanti vividhaṁ vadanti aññoññaṁ vadanti puthu vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:48.3",
      "pali": "tasmā na ekaṁ samaṇā vadanti."
    },
    {
      "id": "mnd12:49.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:50.1",
      "pali": "“Ekañhi saccaṁ na dutīyamatthi,"
    },
    {
      "id": "mnd12:50.2",
      "pali": "Yasmiṁ pajā no vivade pajānaṁ;"
    },
    {
      "id": "mnd12:50.3",
      "pali": "Nānā te saccāni sayaṁ thunanti,"
    },
    {
      "id": "mnd12:50.4",
      "pali": "Tasmā na ekaṁ samaṇā vadantī”ti."
    },
    {
      "id": "mnd12:51.1",
      "pali": "<b>Kasmā nu saccāni vadanti nānā,</b>"
    },
    {
      "id": "mnd12:51.2",
      "pali": "<b>Pavādiyāse kusalāvadānā;</b>"
    },
    {
      "id": "mnd12:51.3",
      "pali": "<b>Saccāni sutāni bahūni nānā,</b>"
    },
    {
      "id": "mnd12:51.4",
      "pali": "<b>Udāhu te takkamanussaranti.</b>"
    },
    {
      "id": "mnd12:52.1",
      "pali": "<b>Kasmā nu saccāni vadanti nānā</b>ti."
    },
    {
      "id": "mnd12:52.2",
      "pali": "<b>Kasmā</b>ti kasmā kiṅkāraṇā kiṁhetu kiṁpaccayā kiṁnidānā saccāni nānā vadanti, vividhāni vadanti, aññoññāni vadanti, puthūni vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:52.3",
      "pali": "kasmā nu saccāni vadanti nānā."
    },
    {
      "id": "mnd12:53.1",
      "pali": "<b>Pavādiyāse kusalāvadānā</b>ti."
    },
    {
      "id": "mnd12:53.2",
      "pali": "<b>Pavādiyāse</b>ti vippavadantītipi pavādiyāse."
    },
    {
      "id": "mnd12:53.3",
      "pali": "Atha vā sakaṁ sakaṁ diṭṭhigataṁ pavadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:53.4",
      "pali": "“Sassato loko, idameva saccaṁ moghamaññan”ti pavadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:53.5",
      "pali": "“Asassato loko …pe…"
    },
    {
      "id": "mnd12:53.6",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti pavadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:53.7",
      "pali": "<b>Kusalāvadānā</b>ti kusalavādā paṇḍitavādā thiravādā ñāyavādā hetuvādā lakkhaṇavādā kāraṇavādā ṭhānavādā sakāya laddhiyāti—"
    },
    {
      "id": "mnd12:53.8",
      "pali": "pavādiyāse kusalāvadānā."
    },
    {
      "id": "mnd12:54.1",
      "pali": "<b>Saccāni sutāni bahūni nānā</b>ti saccāni sutāni bahukāni nānāni vividhāni aññoññāni puthūnīti—"
    },
    {
      "id": "mnd12:54.2",
      "pali": "saccāni sutāni bahūni nānā."
    },
    {
      "id": "mnd12:55.1",
      "pali": "<b>Udāhu te takkamanussarantī</b>ti udāhu takkena saṅkappena yāyanti nīyanti vuyhanti saṁharīyantīti."
    },
    {
      "id": "mnd12:55.2",
      "pali": "Evampi udāhu te takkamanussaranti."
    },
    {
      "id": "mnd12:55.3",
      "pali": "Atha vā takkapariyāhataṁ vīmaṁsānucaritaṁ sayaṁ paṭibhānaṁ vadanti kathenti bhaṇanti dīpayanti voharantīti."
    },
    {
      "id": "mnd12:55.4",
      "pali": "Evampi udāhu te takkamanussaranti."
    },
    {
      "id": "mnd12:56.1",
      "pali": "Tenāha so nimmito—"
    },
    {
      "id": "mnd12:57.1",
      "pali": "“Kasmā nu saccāni vadanti nānā,"
    },
    {
      "id": "mnd12:57.2",
      "pali": "Pavādiyāse kusalāvadānā;"
    },
    {
      "id": "mnd12:57.3",
      "pali": "Saccāni sutāni bahūni nānā,"
    },
    {
      "id": "mnd12:57.4",
      "pali": "Udāhu te takkamanussarantī”ti."
    },
    {
      "id": "mnd12:58.1",
      "pali": "<b>Na heva saccāni bahūni nānā,</b>"
    },
    {
      "id": "mnd12:58.2",
      "pali": "<b>Aññatra saññāya niccāni loke;</b>"
    },
    {
      "id": "mnd12:58.3",
      "pali": "<b>Takkañca diṭṭhīsu pakappayitvā,</b>"
    },
    {
      "id": "mnd12:58.4",
      "pali": "<b>Saccaṁ musāti dvayadhammamāhu.</b>"
    },
    {
      "id": "mnd12:59.1",
      "pali": "<b>Na heva saccāni bahūni nānā</b>ti na heva saccāni bahukāni nānāni vividhāni aññoññāni puthūnīti—"
    },
    {
      "id": "mnd12:59.2",
      "pali": "na heva saccāni bahūni nānā."
    },
    {
      "id": "mnd12:60.1",
      "pali": "<b>Aññatra saññāya niccāni loke</b>ti aññatra saññāya niccaggāhā ekaññeva saccaṁ loke kathīyati bhaṇīyati dīpīyati voharīyati—"
    },
    {
      "id": "mnd12:60.2",
      "pali": "dukkhanirodho nibbānaṁ."
    },
    {
      "id": "mnd12:60.3",
      "pali": "Yo so sabbasaṅkhārasamatho sabbūpadhipaṭinissaggo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "mnd12:60.4",
      "pali": "Atha vā ekaṁ saccaṁ vuccati maggasaccaṁ, niyyānasaccaṁ, dukkhanirodhagāminī paṭipadā, ariyo aṭṭhaṅgiko maggo, seyyathidaṁ—"
    },
    {
      "id": "mnd12:60.5",
      "pali": "sammādiṭṭhi …pe… sammāsamādhīti—"
    },
    {
      "id": "mnd12:60.6",
      "pali": "aññatra saññāya niccāni loke."
    },
    {
      "id": "mnd12:61.1",
      "pali": "<b>Takkañca diṭṭhīsu pakappayitvā, saccaṁ musāti dvayadhammamāhū</b>ti."
    },
    {
      "id": "mnd12:61.2",
      "pali": "Takkaṁ vitakkaṁ saṅkappaṁ takkayitvā vitakkayitvā saṅkappayitvā diṭṭhigatāni janenti sañjanenti nibbattenti abhinibbattenti."
    },
    {
      "id": "mnd12:61.3",
      "pali": "Diṭṭhigatāni janetvā sañjanetvā nibbattetvā abhinibbattetvā “mayhaṁ saccaṁ tuyhaṁ musā”ti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:61.4",
      "pali": "takkañca diṭṭhīsu pakappayitvā saccaṁ musāti dvayadhammamāhu."
    },
    {
      "id": "mnd12:62.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:63.1",
      "pali": "“Na heva saccāni bahūni nānā,"
    },
    {
      "id": "mnd12:63.2",
      "pali": "Aññatra saññāya niccāni loke;"
    },
    {
      "id": "mnd12:63.3",
      "pali": "Takkañca diṭṭhīsu pakappayitvā,"
    },
    {
      "id": "mnd12:63.4",
      "pali": "Saccaṁ musāti dvayadhammamāhū”ti."
    },
    {
      "id": "mnd12:64.1",
      "pali": "<b>Diṭṭhe sute sīlavate mute vā,</b>"
    },
    {
      "id": "mnd12:64.2",
      "pali": "<b>Ete ca nissāya vimānadassī;</b>"
    },
    {
      "id": "mnd12:64.3",
      "pali": "<b>Vinicchaye ṭhatvā pahassamāno,</b>"
    },
    {
      "id": "mnd12:64.4",
      "pali": "<b>Bālo paro akkusaloti cāha.</b>"
    },
    {
      "id": "mnd12:65.1",
      "pali": "<b>Diṭṭhe sute sīlavate mute vā, ete ca nissāya vimānadassī</b>ti."
    },
    {
      "id": "mnd12:65.2",
      "pali": "Diṭṭhaṁ vā diṭṭhasuddhiṁ vā, sutaṁ vā sutasuddhiṁ vā, sīlaṁ vā sīlasuddhiṁ vā, vataṁ vā vatasuddhiṁ vā, mutaṁ vā mutasuddhiṁ vā nissāya upanissāya gaṇhitvā parāmasitvā abhinivisitvāti—"
    },
    {
      "id": "mnd12:65.3",
      "pali": "diṭṭhe sute sīlavate mute vā."
    },
    {
      "id": "mnd12:65.4",
      "pali": "<b>Ete ca nissāya vimānadassī</b>ti."
    },
    {
      "id": "mnd12:65.5",
      "pali": "Na sammānetītipi vimānadassī."
    },
    {
      "id": "mnd12:65.6",
      "pali": "Atha vā domanassaṁ janetītipi vimānadassīti—"
    },
    {
      "id": "mnd12:65.7",
      "pali": "diṭṭhe sute sīlavate mute vā ete ca nissāya vimānadassī."
    },
    {
      "id": "mnd12:66.1",
      "pali": "<b>Vinicchaye ṭhatvā pahassamāno</b>ti."
    },
    {
      "id": "mnd12:66.2",
      "pali": "Vinicchayā vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd12:66.3",
      "pali": "Diṭṭhivinicchaye vinicchayadiṭṭhiyā ṭhatvā patiṭṭhahitvā gaṇhitvā parāmasitvā abhinivisitvāti—"
    },
    {
      "id": "mnd12:66.4",
      "pali": "vinicchaye ṭhatvā."
    },
    {
      "id": "mnd12:66.5",
      "pali": "<b>Pahassamāno</b>ti tuṭṭho hoti haṭṭho pahaṭṭho attamano paripuṇṇasaṅkappo."
    },
    {
      "id": "mnd12:66.6",
      "pali": "Atha vā dantavidaṁsakaṁ pahassamānoti—"
    },
    {
      "id": "mnd12:66.7",
      "pali": "vinicchaye ṭhatvā pahassamāno."
    },
    {
      "id": "mnd12:67.1",
      "pali": "<b>Bālo paro akkusaloti cāhā</b>ti."
    },
    {
      "id": "mnd12:67.2",
      "pali": "Paro bālo hīno nihīno omako lāmako chatukko paritto akusalo avidvā avijjāgato aññāṇī avibhāvī amedhāvī duppaññoti, evamāha evaṁ katheti evaṁ bhaṇati evaṁ dīpayati evaṁ voharatīti—"
    },
    {
      "id": "mnd12:67.3",
      "pali": "bālo paro akkusaloti cāha."
    },
    {
      "id": "mnd12:68.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:69.1",
      "pali": "“Diṭṭhe sute sīlavate mute vā,"
    },
    {
      "id": "mnd12:69.2",
      "pali": "Ete ca nissāya vimānadassī;"
    },
    {
      "id": "mnd12:69.3",
      "pali": "Vinicchaye ṭhatvā pahassamāno,"
    },
    {
      "id": "mnd12:69.4",
      "pali": "Bālo paro akkusaloti cāhā”ti."
    },
    {
      "id": "mnd12:70.1",
      "pali": "<b>Yeneva bāloti paraṁ dahāti,</b>"
    },
    {
      "id": "mnd12:70.2",
      "pali": "<b>Tenātumānaṁ kusaloti cāha;</b>"
    },
    {
      "id": "mnd12:70.3",
      "pali": "<b>Sayamattanā so kusalāvadāno,</b>"
    },
    {
      "id": "mnd12:70.4",
      "pali": "<b>Aññaṁ vimāneti tadeva pāva.</b>"
    },
    {
      "id": "mnd12:71.1",
      "pali": "<b>Yeneva bāloti paraṁ dahātī</b>ti."
    },
    {
      "id": "mnd12:71.2",
      "pali": "Yeneva hetunā yena paccayena yena kāraṇena yena pabhavena paraṁ bālato hīnato nihīnato omakato lāmakato chatukkato parittato dahati passati dakkhati oloketi nijjhāyati upaparikkhatīti—"
    },
    {
      "id": "mnd12:71.3",
      "pali": "yeneva bāloti paraṁ dahāti."
    },
    {
      "id": "mnd12:72.1",
      "pali": "<b>Tenātumānaṁ kusaloti cāhā</b>ti."
    },
    {
      "id": "mnd12:72.2",
      "pali": "<b>Ātumāno</b> vuccati attā."
    },
    {
      "id": "mnd12:72.3",
      "pali": "Sopi teneva hetunā tena paccayena tena kāraṇena tena pabhavena attānaṁ ahamasmi kusalo paṇḍito paññavā buddhimā ñāṇī vibhāvī medhāvīti—"
    },
    {
      "id": "mnd12:72.4",
      "pali": "tenātumānaṁ kusaloti cāha."
    },
    {
      "id": "mnd12:73.1",
      "pali": "<b>Sayamattanā so kusalāvadāno</b>ti."
    },
    {
      "id": "mnd12:73.2",
      "pali": "Sayameva attānaṁ kusalavādo paṇḍitavādo thiravādo ñāyavādo hetuvādo lakkhaṇavādo kāraṇavādo ṭhānavādo sakāya laddhiyāti—"
    },
    {
      "id": "mnd12:73.3",
      "pali": "sayamattanā so kusalāvadāno."
    },
    {
      "id": "mnd12:74.1",
      "pali": "<b>Aññaṁ vimāneti tadeva pāvā</b>ti."
    },
    {
      "id": "mnd12:74.2",
      "pali": "Na sammānetītipi aññaṁ vimāneti."
    },
    {
      "id": "mnd12:74.3",
      "pali": "Atha vā domanassaṁ janetītipi aññaṁ vimāneti."
    },
    {
      "id": "mnd12:74.4",
      "pali": "<b>Tadeva pāvā</b>ti tadeva taṁ diṭṭhigataṁ pāvadati “itipāyaṁ puggalo micchādiṭṭhiko viparītadassano”ti—"
    },
    {
      "id": "mnd12:74.5",
      "pali": "aññaṁ vimāneti tadeva pāvada."
    },
    {
      "id": "mnd12:75.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:76.1",
      "pali": "“Yeneva bāloti paraṁ dahāti,"
    },
    {
      "id": "mnd12:76.2",
      "pali": "Tenātumānaṁ kusaloti cāha;"
    },
    {
      "id": "mnd12:76.3",
      "pali": "Sayamattanā so kusalāvadāno,"
    },
    {
      "id": "mnd12:76.4",
      "pali": "Aññaṁ vimāneti tadeva pāvā”ti."
    },
    {
      "id": "mnd12:77.1",
      "pali": "<b>Atisāradiṭṭhiyā so samatto,</b>"
    },
    {
      "id": "mnd12:77.2",
      "pali": "<b>Mānena matto paripuṇṇamānī;</b>"
    },
    {
      "id": "mnd12:77.3",
      "pali": "<b>Sayameva sāmaṁ manasābhisitto,</b>"
    },
    {
      "id": "mnd12:77.4",
      "pali": "<b>Diṭṭhī hi sā tassa tathā samattā.</b>"
    },
    {
      "id": "mnd12:78.1",
      "pali": "<b>Atisāradiṭṭhiyā so samatto</b>ti."
    },
    {
      "id": "mnd12:78.2",
      "pali": "Atisāradiṭṭhiyo vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd12:78.3",
      "pali": "Kiṅkāraṇā atisāradiṭṭhiyo vuccanti dvāsaṭṭhi diṭṭhigatāni?"
    },
    {
      "id": "mnd12:78.4",
      "pali": "Sabbā tā diṭṭhiyo kāraṇātikkantā lakkhaṇātikkantā ṭhānātikkantā, taṅkāraṇā atisāradiṭṭhiyo vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd12:78.5",
      "pali": "Sabbepi titthiyā atisāradiṭṭhiyā."
    },
    {
      "id": "mnd12:78.6",
      "pali": "Kiṅkāraṇā sabbepi titthiyā atisāradiṭṭhiyā?"
    },
    {
      "id": "mnd12:78.7",
      "pali": "Te aññamaññaṁ atikkamitvā samatikkamitvā vītivattitvā diṭṭhigatāni janenti sañjanenti nibbattenti abhinibbattenti, taṅkāraṇā sabbepi titthiyā atisāradiṭṭhiyā."
    },
    {
      "id": "mnd12:78.8",
      "pali": "<b>Atisāradiṭṭhiyā so samatto</b>ti."
    },
    {
      "id": "mnd12:78.9",
      "pali": "Atisāradiṭṭhiyā samatto paripuṇṇo anomoti—"
    },
    {
      "id": "mnd12:78.10",
      "pali": "atisāradiṭṭhiyā so samatto."
    },
    {
      "id": "mnd12:79.1",
      "pali": "<b>Mānena matto paripuṇṇamānī</b>ti."
    },
    {
      "id": "mnd12:79.2",
      "pali": "Sakāya diṭṭhiyā diṭṭhimānena matto pamatto ummatto atimattoti—"
    },
    {
      "id": "mnd12:79.3",
      "pali": "mānena matto."
    },
    {
      "id": "mnd12:79.4",
      "pali": "<b>Paripuṇṇamānī</b>ti paripuṇṇamānī samattamānī anomamānīti—"
    },
    {
      "id": "mnd12:79.5",
      "pali": "mānena matto paripuṇṇamānī."
    },
    {
      "id": "mnd12:80.1",
      "pali": "<b>Sayameva sāmaṁ manasābhisitto</b>ti."
    },
    {
      "id": "mnd12:80.2",
      "pali": "Sayameva attānaṁ cittena abhisiñcati “ahamasmi kusalo paṇḍito paññavā buddhimā ñāṇī vibhāvī medhāvī”ti—"
    },
    {
      "id": "mnd12:80.3",
      "pali": "sayameva sāmaṁ manasābhisitto."
    },
    {
      "id": "mnd12:81.1",
      "pali": "<b>Diṭṭhī hi sā tassa tathā samattā</b>ti."
    },
    {
      "id": "mnd12:81.2",
      "pali": "Tassa sā diṭṭhi tathā samattā samādinnā gahitā parāmaṭṭhā abhiniviṭṭhā ajjhositā adhimuttāti—"
    },
    {
      "id": "mnd12:81.3",
      "pali": "diṭṭhī hi sā tassa tathā samattā."
    },
    {
      "id": "mnd12:82.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:83.1",
      "pali": "“Atisāradiṭṭhiyā so samatto,"
    },
    {
      "id": "mnd12:83.2",
      "pali": "Mānena matto paripuṇṇamānī;"
    },
    {
      "id": "mnd12:83.3",
      "pali": "Sayameva sāmaṁ manasābhisitto,"
    },
    {
      "id": "mnd12:83.4",
      "pali": "Diṭṭhī hi sā tassa tathā samattā”ti."
    },
    {
      "id": "mnd12:84.1",
      "pali": "<b>Parassa ce hi vacasā nihīno,</b>"
    },
    {
      "id": "mnd12:84.2",
      "pali": "<b>Tumo sahā hoti nihīnapañño;</b>"
    },
    {
      "id": "mnd12:84.3",
      "pali": "<b>Atha ce sayaṁ vedagū hoti dhīro,</b>"
    },
    {
      "id": "mnd12:84.4",
      "pali": "<b>Na koci bālo samaṇesu atthi.</b>"
    },
    {
      "id": "mnd12:85.1",
      "pali": "<b>Parassa ce hi vacasā nihīno</b>ti parassa ce vācāya vacanena ninditakāraṇā garahitakāraṇā upavaditakāraṇā paro bālo hoti hīno nihīno omako lāmako chatukko parittoti—"
    },
    {
      "id": "mnd12:85.2",
      "pali": "parassa ce hi vacasā nihīno."
    },
    {
      "id": "mnd12:85.3",
      "pali": "<b>Tumo sahā hoti nihīnapañño</b>ti."
    },
    {
      "id": "mnd12:85.4",
      "pali": "Sopi teneva sahā hoti hīnapañño nihīnapañño omakapañño lāmakapañño chatukkapañño parittapaññoti—"
    },
    {
      "id": "mnd12:85.5",
      "pali": "tumo sahā hoti nihīnapañño."
    },
    {
      "id": "mnd12:86.1",
      "pali": "<b>Atha ce sayaṁ vedagū hoti dhīro</b>ti atha ce sayaṁ vedagū hoti dhīro paṇḍito paññavā buddhimā ñāṇī vibhāvī medhāvīti—"
    },
    {
      "id": "mnd12:86.2",
      "pali": "atha ce sayaṁ vedagū hoti dhīro."
    },
    {
      "id": "mnd12:87.1",
      "pali": "<b>Na koci bālo samaṇesu atthī</b>ti."
    },
    {
      "id": "mnd12:87.2",
      "pali": "Samaṇesu na koci bālo hīno nihīno omako lāmako chatukko paritto atthi, sabbeva seṭṭhapaññā visiṭṭhapaññā pāmokkhapaññā uttamapaññā pavarapaññāti—"
    },
    {
      "id": "mnd12:87.3",
      "pali": "na koci bālo samaṇesu atthi."
    },
    {
      "id": "mnd12:88.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:89.1",
      "pali": "“Parassa ce hi vacasā nihīno,"
    },
    {
      "id": "mnd12:89.2",
      "pali": "Tumo sahā hoti nihīnapañño;"
    },
    {
      "id": "mnd12:89.3",
      "pali": "Atha ce sayaṁ vedagū hoti dhīro,"
    },
    {
      "id": "mnd12:89.4",
      "pali": "Na koci bālo samaṇesu atthī”ti."
    },
    {
      "id": "mnd12:90.1",
      "pali": "<b>Aññaṁ ito yābhivadanti dhammaṁ,</b>"
    },
    {
      "id": "mnd12:90.2",
      "pali": "<b>Aparaddhā suddhimakevalī te;</b>"
    },
    {
      "id": "mnd12:90.3",
      "pali": "<b>Evampi titthyā puthuso vadanti,</b>"
    },
    {
      "id": "mnd12:90.4",
      "pali": "<b>Sandiṭṭhirāgena hi tebhirattā.</b>"
    },
    {
      "id": "mnd12:91.1",
      "pali": "<b>Aññaṁ ito yābhivadanti dhammaṁ, aparaddhā suddhimakevalī te</b>ti."
    },
    {
      "id": "mnd12:91.2",
      "pali": "Ito aññaṁ dhammaṁ diṭṭhiṁ paṭipadaṁ maggaṁ ye abhivadanti, te suddhimaggaṁ visuddhimaggaṁ parisuddhimaggaṁ vodātamaggaṁ pariyodātamaggaṁ viraddhā aparaddhā khalitā galitā aññāya aparaddhā akevalī te, asamattā te, aparipuṇṇā te, hīnā nihīnā omakā lāmakā chatukkā parittāti—"
    },
    {
      "id": "mnd12:91.3",
      "pali": "aññaṁ ito yābhivadanti dhammaṁ, aparaddhā suddhimakevalī te."
    },
    {
      "id": "mnd12:92.1",
      "pali": "<b>Evampi titthyā puthuso vadantī</b>ti."
    },
    {
      "id": "mnd12:92.2",
      "pali": "<b>Titthaṁ</b> vuccati diṭṭhigataṁ."
    },
    {
      "id": "mnd12:92.3",
      "pali": "Titthiyā vuccanti diṭṭhigatikā."
    },
    {
      "id": "mnd12:92.4",
      "pali": "Puthudiṭṭhiyā puthudiṭṭhigatāni vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:92.5",
      "pali": "evampi titthyā puthuso vadanti."
    },
    {
      "id": "mnd12:93.1",
      "pali": "<b>Sandiṭṭhirāgena hi tebhirattā</b>ti."
    },
    {
      "id": "mnd12:93.2",
      "pali": "Sakāya diṭṭhiyā diṭṭhirāgena rattā abhirattāti—"
    },
    {
      "id": "mnd12:93.3",
      "pali": "sandiṭṭhirāgena hi tebhirattā."
    },
    {
      "id": "mnd12:94.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:95.1",
      "pali": "“Aññaṁ ito yābhivadanti dhammaṁ,"
    },
    {
      "id": "mnd12:95.2",
      "pali": "Aparaddhā suddhimakevalī te;"
    },
    {
      "id": "mnd12:95.3",
      "pali": "Evampi titthyā puthuso vadanti,"
    },
    {
      "id": "mnd12:95.4",
      "pali": "Sandiṭṭhirāgena hi tebhirattā”ti."
    },
    {
      "id": "mnd12:96.1",
      "pali": "<b>Idheva suddhiṁ iti vādayanti,</b>"
    },
    {
      "id": "mnd12:96.2",
      "pali": "<b>Nāññesu dhammesu visuddhimāhu;</b>"
    },
    {
      "id": "mnd12:96.3",
      "pali": "<b>Evampi titthyā puthuso niviṭṭhā,</b>"
    },
    {
      "id": "mnd12:96.4",
      "pali": "<b>Sakāyane tattha daḷhaṁ vadānā.</b>"
    },
    {
      "id": "mnd12:97.1",
      "pali": "<b>Idheva suddhiṁ iti vādayantī</b>ti."
    },
    {
      "id": "mnd12:97.2",
      "pali": "Idha suddhiṁ visuddhiṁ parisuddhiṁ, muttiṁ vimuttiṁ parimuttiṁ vadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:97.3",
      "pali": "“Sassato loko, idameva saccaṁ moghamaññan”ti idha suddhiṁ visuddhiṁ parisuddhiṁ, muttiṁ vimuttiṁ parimuttiṁ vadanti kathenti bhaṇanti dīpayanti voharanti."
    },
    {
      "id": "mnd12:97.4",
      "pali": "“Asassato loko …pe…"
    },
    {
      "id": "mnd12:97.5",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti idha suddhiṁ visuddhiṁ parisuddhiṁ muttiṁ vimuttiṁ parimuttiṁ vadanti kathenti bhaṇanti dīpayanti voharantīti—"
    },
    {
      "id": "mnd12:97.6",
      "pali": "idheva suddhiṁ iti vādayanti."
    },
    {
      "id": "mnd12:98.1",
      "pali": "<b>Nāññesu dhammesu visuddhimāhū</b>ti."
    },
    {
      "id": "mnd12:98.2",
      "pali": "Attano satthāraṁ dhammakkhānaṁ gaṇaṁ diṭṭhiṁ paṭipadaṁ maggaṁ ṭhapetvā sabbe paravāde khipanti ukkhipanti parikkhipanti."
    },
    {
      "id": "mnd12:98.3",
      "pali": "“So satthā na sabbaññū, dhammo na svākkhāto, gaṇo na suppaṭipanno, diṭṭhi na bhaddikā, paṭipadā na supaññattā, maggo na niyyāniko, natthettha suddhi vā visuddhi vā parisuddhi vā, mutti vā vimutti vā parimutti vā, natthettha sujjhanti vā visujjhanti vā parisujjhanti vā, muccanti vā vimuccanti vā parimuccanti vā hīnā nihīnā omakā lāmakā chatukkā parittā”ti, evamāhaṁsu evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd12:98.4",
      "pali": "nāññesu dhammesu visuddhimāhu."
    },
    {
      "id": "mnd12:99.1",
      "pali": "<b>Evampi titthyā puthuso niviṭṭhā</b>ti."
    },
    {
      "id": "mnd12:99.2",
      "pali": "Titthaṁ vuccati diṭṭhigataṁ."
    },
    {
      "id": "mnd12:99.3",
      "pali": "Titthiyā vuccanti diṭṭhigatikā."
    },
    {
      "id": "mnd12:99.4",
      "pali": "Puthudiṭṭhiyā puthudiṭṭhigatesu niviṭṭhā patiṭṭhitā allīnā upagatā ajjhositā adhimuttāti—"
    },
    {
      "id": "mnd12:99.5",
      "pali": "evampi titthyā puthuso niviṭṭhā."
    },
    {
      "id": "mnd12:100.1",
      "pali": "<b>Sakāyane tattha daḷhaṁ vadānā</b>ti."
    },
    {
      "id": "mnd12:100.2",
      "pali": "Dhammo sakāyanaṁ, diṭṭhi sakāyanaṁ, paṭipadā sakāyanaṁ, maggo sakāyanaṁ, sakāyane daḷhavādā thiravādā balikavādā avaṭṭhitavādāti—"
    },
    {
      "id": "mnd12:100.3",
      "pali": "sakāyane tattha daḷhaṁ vadānā."
    },
    {
      "id": "mnd12:101.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:102.1",
      "pali": "“Idheva suddhiṁ iti vādayanti,"
    },
    {
      "id": "mnd12:102.2",
      "pali": "Nāññesu dhammesu visuddhimāhu;"
    },
    {
      "id": "mnd12:102.3",
      "pali": "Evampi titthyā puthuso niviṭṭhā,"
    },
    {
      "id": "mnd12:102.4",
      "pali": "Sakāyane tattha daḷhaṁ vadānā”ti."
    },
    {
      "id": "mnd12:103.1",
      "pali": "<b>Sakāyane vāpi daḷhaṁ vadāno,</b>"
    },
    {
      "id": "mnd12:103.2",
      "pali": "<b>Kamettha bāloti paraṁ daheyya;</b>"
    },
    {
      "id": "mnd12:103.3",
      "pali": "<b>Sayaṁva so medhagamāvaheyya,</b>"
    },
    {
      "id": "mnd12:103.4",
      "pali": "<b>Paraṁ vadaṁ bālamasuddhidhammaṁ.</b>"
    },
    {
      "id": "mnd12:104.1",
      "pali": "<b>Sakāyane vāpi daḷhaṁ vadāno</b>ti."
    },
    {
      "id": "mnd12:104.2",
      "pali": "Dhammo sakāyanaṁ, diṭṭhi sakāyanaṁ, paṭipadā sakāyanaṁ, maggo sakāyanaṁ, sakāyane daḷhavādo thiravādo balikavādo avaṭṭhitavādoti—"
    },
    {
      "id": "mnd12:104.3",
      "pali": "sakāyane vāpi daḷhaṁ vadāno."
    },
    {
      "id": "mnd12:105.1",
      "pali": "<b>Kamettha bāloti paraṁ daheyyā</b>ti."
    },
    {
      "id": "mnd12:105.2",
      "pali": "<b>Etthā</b>ti sakāya diṭṭhiyā sakāya khantiyā sakāya ruciyā sakāya laddhiyā paraṁ bālato hīnato nihīnato omakato lāmakato chatukkato parittato kaṁ daheyya kaṁ passeyya kaṁ dakkheyya kaṁ olokeyya kaṁ nijjhāyeyya kaṁ upaparikkheyyāti—"
    },
    {
      "id": "mnd12:105.3",
      "pali": "kamettha bāloti paraṁ daheyya."
    },
    {
      "id": "mnd12:106.1",
      "pali": "<b>Sayaṁva so medhagamāvaheyya, paraṁ vadaṁ bālamasuddhidhamman</b>ti."
    },
    {
      "id": "mnd12:106.2",
      "pali": "Paro bālo hīno nihīno omako lāmako chatukko paritto asuddhidhammo avisuddhidhammo aparisuddhidhammo avodātadhammoti—"
    },
    {
      "id": "mnd12:106.3",
      "pali": "evaṁ vadanto evaṁ kathento evaṁ bhaṇanto evaṁ dīpayanto evaṁ voharanto sayameva kalahaṁ bhaṇḍanaṁ viggahaṁ vivādaṁ medhagaṁ āvaheyya samāvaheyya āhareyya samāhareyya ākaḍḍheyya samākaḍḍheyya gaṇheyya parāmaseyya abhiniviseyyāti—"
    },
    {
      "id": "mnd12:106.4",
      "pali": "sayaṁva so medhagamāvaheyya paraṁ vadaṁ bālamasuddhidhammaṁ."
    },
    {
      "id": "mnd12:107.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:108.1",
      "pali": "“Sakāyane vāpi daḷhaṁ vadāno,"
    },
    {
      "id": "mnd12:108.2",
      "pali": "Kamettha bāloti paraṁ daheyya;"
    },
    {
      "id": "mnd12:108.3",
      "pali": "Sayaṁva so medhagamāvaheyya,"
    },
    {
      "id": "mnd12:108.4",
      "pali": "Paraṁ vadaṁ bālamasuddhidhamman”ti."
    },
    {
      "id": "mnd12:109.1",
      "pali": "<b>Vinicchaye ṭhatvā sayaṁ pamāya,</b>"
    },
    {
      "id": "mnd12:109.2",
      "pali": "<b>Uddhaṁsa lokasmiṁ vivādameti;</b>"
    },
    {
      "id": "mnd12:109.3",
      "pali": "<b>Hitvāna sabbāni vinicchayāni,</b>"
    },
    {
      "id": "mnd12:109.4",
      "pali": "<b>Na medhagaṁ kubbati jantu loke.</b>"
    },
    {
      "id": "mnd12:110.1",
      "pali": "<b>Vinicchaye ṭhatvā sayaṁ pamāyā</b>ti."
    },
    {
      "id": "mnd12:110.2",
      "pali": "Vinicchayā vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd12:110.3",
      "pali": "Vinicchayadiṭṭhiyā ṭhatvā patiṭṭhahitvā gaṇhitvā parāmasitvā abhinivisitvāti vinicchaye ṭhatvā."
    },
    {
      "id": "mnd12:110.4",
      "pali": "<b>Sayaṁ pamāyā</b>ti sayaṁ pamāya paminitvā."
    },
    {
      "id": "mnd12:110.5",
      "pali": "“Ayaṁ satthā sabbaññū”ti sayaṁ pamāya paminitvā,"
    },
    {
      "id": "mnd12:110.6",
      "pali": "“ayaṁ dhammo svākkhāto …"
    },
    {
      "id": "mnd12:110.7",
      "pali": "ayaṁ gaṇo suppaṭipanno …"
    },
    {
      "id": "mnd12:110.8",
      "pali": "ayaṁ diṭṭhi bhaddikā …"
    },
    {
      "id": "mnd12:110.9",
      "pali": "ayaṁ paṭipadā supaññattā …"
    },
    {
      "id": "mnd12:110.10",
      "pali": "ayaṁ maggo niyyāniko”ti sayaṁ pamāya paminitvāti—"
    },
    {
      "id": "mnd12:110.11",
      "pali": "vinicchaye ṭhatvā sayaṁ pamāya."
    },
    {
      "id": "mnd12:111.1",
      "pali": "<b>Uddhaṁsa lokasmiṁ vivādametī</b>ti."
    },
    {
      "id": "mnd12:111.2",
      "pali": "Uddhaṁso vuccati anāgataṁ."
    },
    {
      "id": "mnd12:111.3",
      "pali": "Attano vādaṁ uddhaṁ ṭhapetvā sayameva kalahaṁ bhaṇḍanaṁ viggahaṁ vivādaṁ medhagaṁ eti upeti upagacchati gaṇhāti parāmasati abhinivisatīti."
    },
    {
      "id": "mnd12:111.4",
      "pali": "Evampi uddhaṁsa lokasmiṁ vivādameti."
    },
    {
      "id": "mnd12:111.5",
      "pali": "Atha vā aññena uddhaṁ vādena saddhiṁ kalahaṁ karoti bhaṇḍanaṁ karoti viggahaṁ karoti vivādaṁ karoti medhagaṁ karoti—"
    },
    {
      "id": "mnd12:111.6",
      "pali": "“na tvaṁ imaṁ dhammavinayaṁ ājānāsi …pe…"
    },
    {
      "id": "mnd12:111.7",
      "pali": "nibbeṭhehi vā sace pahosī”ti."
    },
    {
      "id": "mnd12:111.8",
      "pali": "Evampi uddhaṁsa lokasmiṁ vivādameti."
    },
    {
      "id": "mnd12:112.1",
      "pali": "<b>Hitvāna sabbāni vinicchayānī</b>ti."
    },
    {
      "id": "mnd12:112.2",
      "pali": "Vinicchayā vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd12:112.3",
      "pali": "Diṭṭhivinicchayā sabbe vinicchaye hitvā cajitvā pariccajitvā jahitvā pajahitvā vinodetvā byantiṁ karitvā anabhāvaṁ gametvāti—"
    },
    {
      "id": "mnd12:112.4",
      "pali": "hitvāna sabbāni vinicchayāni."
    },
    {
      "id": "mnd12:113.1",
      "pali": "<b>Na medhagaṁ kubbati jantu loke</b>ti."
    },
    {
      "id": "mnd12:113.2",
      "pali": "Na kalahaṁ karoti, na bhaṇḍanaṁ karoti, na viggahaṁ karoti, na vivādaṁ karoti, na medhagaṁ karoti."
    },
    {
      "id": "mnd12:113.3",
      "pali": "Vuttañhetaṁ bhagavatā—"
    },
    {
      "id": "mnd12:113.4",
      "pali": "“evaṁ vimuttacitto kho, aggivessana, bhikkhu na kenaci saṁvadati, na kenaci vivadati, yañca loke vuttaṁ tena ca voharati aparāmasan”ti."
    },
    {
      "id": "mnd12:113.5",
      "pali": "<b>Jantū</b>ti satto naro mānavo poso puggalo jīvo jāgu jantu indagu manujo."
    },
    {
      "id": "mnd12:113.6",
      "pali": "<b>Loke</b>ti apāyaloke …pe… āyatanaloketi—"
    },
    {
      "id": "mnd12:113.7",
      "pali": "na medhagaṁ kubbati jantu loketi."
    },
    {
      "id": "mnd12:114.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd12:115.1",
      "pali": "“Vinicchaye ṭhatvā sayaṁ pamāya,"
    },
    {
      "id": "mnd12:115.2",
      "pali": "Uddhaṁsa lokasmiṁ vivādameti;"
    },
    {
      "id": "mnd12:115.3",
      "pali": "Hitvāna sabbāni vinicchayāni,"
    },
    {
      "id": "mnd12:115.4",
      "pali": "Na medhagaṁ kubbati jantu loke”ti."
    },
    {
      "id": "mnd12:116.1",
      "pali": "Cūḷabyūhasuttaniddeso dvādasamo."
    }
  ]
}
