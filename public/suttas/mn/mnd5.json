{
  "uid": "mnd5",
  "title": "5. Paramaṭṭhakasuttaniddesa",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mnd5:1.1",
      "pali": "Atha paramaṭṭhakasuttaniddesaṁ vakkhati—"
    },
    {
      "id": "mnd5:2.1",
      "pali": "<b>Paramanti diṭṭhīsu paribbasāno,</b>"
    },
    {
      "id": "mnd5:2.2",
      "pali": "<b>Yaduttariṁ kurute jantu loke;</b>"
    },
    {
      "id": "mnd5:2.3",
      "pali": "<b>Hīnāti aññe tato sabbamāha,</b>"
    },
    {
      "id": "mnd5:2.4",
      "pali": "<b>Tasmā vivādāni avītivatto.</b>"
    },
    {
      "id": "mnd5:3.1",
      "pali": "<b>Paramanti diṭṭhīsu paribbasāno</b>ti."
    },
    {
      "id": "mnd5:3.2",
      "pali": "Santeke samaṇabrāhmaṇā diṭṭhigatikā."
    },
    {
      "id": "mnd5:3.3",
      "pali": "Te dvāsaṭṭhiyā diṭṭhigatānaṁ aññataraññataraṁ diṭṭhigataṁ “idaṁ paramaṁ aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaran”ti gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā sakāya sakāya diṭṭhiyā vasanti pavasanti āvasanti parivasanti."
    },
    {
      "id": "mnd5:3.4",
      "pali": "Yathā āgārikā vā gharesu vasanti, sāpattikā vā āpattīsu vasanti, sakilesā vā kilesesu vasanti;"
    },
    {
      "id": "mnd5:3.5",
      "pali": "evamevaṁ santeke samaṇabrāhmaṇā diṭṭhigatikā."
    },
    {
      "id": "mnd5:3.6",
      "pali": "Te dvāsaṭṭhiyā diṭṭhigatānaṁ aññataraññataraṁ diṭṭhigataṁ “idaṁ paramaṁ aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaran”ti gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvā sakāya sakāya diṭṭhiyā vasanti pavasanti āvasanti parivasantīti—"
    },
    {
      "id": "mnd5:3.7",
      "pali": "paramanti diṭṭhīsu paribbasāno."
    },
    {
      "id": "mnd5:4.1",
      "pali": "<b>Yaduttariṁ kurute jantu loke</b>ti."
    },
    {
      "id": "mnd5:4.2",
      "pali": "<b>Yadi</b>ti yaṁ."
    },
    {
      "id": "mnd5:4.3",
      "pali": "<b>Uttariṁ kurute</b>ti uttariṁ karoti, aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaraṁ karoti"
    },
    {
      "id": "mnd5:4.4",
      "pali": "“ayaṁ satthā sabbaññū”ti uttariṁ karoti, aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaraṁ karoti."
    },
    {
      "id": "mnd5:4.5",
      "pali": "“Ayaṁ dhammo svākkhāto …,"
    },
    {
      "id": "mnd5:4.6",
      "pali": "ayaṁ gaṇo suppaṭipanno …,"
    },
    {
      "id": "mnd5:4.7",
      "pali": "ayaṁ diṭṭhi bhaddikā …,"
    },
    {
      "id": "mnd5:4.8",
      "pali": "ayaṁ paṭipadā supaññattā …,"
    },
    {
      "id": "mnd5:4.9",
      "pali": "ayaṁ maggo niyyāniko”ti uttariṁ karoti, aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaraṁ karoti nibbatteti abhinibbatteti."
    },
    {
      "id": "mnd5:4.10",
      "pali": "<b>Jantū</b>ti satto naro …pe… manujo."
    },
    {
      "id": "mnd5:4.11",
      "pali": "<b>Loke</b>ti apāyaloke …pe… āyatanaloketi—"
    },
    {
      "id": "mnd5:4.12",
      "pali": "yaduttariṁ kurute jantu loke."
    },
    {
      "id": "mnd5:5.1",
      "pali": "<b>Hīnāti aññe tato sabbamāhā</b>ti attano satthāraṁ dhammakkhānaṁ gaṇaṁ diṭṭhiṁ paṭipadaṁ maggaṁ ṭhapetvā sabbe parappavāde khipati ukkhipati parikkhipati."
    },
    {
      "id": "mnd5:5.2",
      "pali": "“So satthā na sabbaññū ,"
    },
    {
      "id": "mnd5:5.3",
      "pali": "dhammo na svākkhāto ,"
    },
    {
      "id": "mnd5:5.4",
      "pali": "gaṇo na suppaṭipanno ,"
    },
    {
      "id": "mnd5:5.5",
      "pali": "diṭṭhi na bhaddikā ,"
    },
    {
      "id": "mnd5:5.6",
      "pali": "paṭipadā na supaññattā ,"
    },
    {
      "id": "mnd5:5.7",
      "pali": "maggo na niyyāniko ,"
    },
    {
      "id": "mnd5:5.8",
      "pali": "natthettha suddhi vā visuddhi vā parisuddhi vā mutti vā vimutti vā parimutti vā ,"
    },
    {
      "id": "mnd5:5.9",
      "pali": "natthettha sujjhanti vā visujjhanti vā parisujjhanti vā muccanti vā vimuccanti vā parimuccanti vā ,"
    },
    {
      "id": "mnd5:5.10",
      "pali": "hīnā nihīnā omakā lāmakā chatukkā parittā”ti evamāha evaṁ katheti evaṁ bhaṇati evaṁ dīpayati evaṁ voharatīti—"
    },
    {
      "id": "mnd5:5.11",
      "pali": "hīnāti aññe tato sabbamāha."
    },
    {
      "id": "mnd5:6.1",
      "pali": "<b>Tasmā vivādāni avītivatto</b>ti."
    },
    {
      "id": "mnd5:6.2",
      "pali": "<b>Tasmā</b>ti taṅkāraṇā taṁhetu tappaccayā taṁnidānā."
    },
    {
      "id": "mnd5:6.3",
      "pali": "<b>Vivādānī</b>ti diṭṭhikalahāni diṭṭhibhaṇḍanāni diṭṭhiviggahāni diṭṭhivivādāni diṭṭhimedhagāni ca."
    },
    {
      "id": "mnd5:6.4",
      "pali": "<b>Avītivatto</b>ti anatikkanto asamatikkanto avītivattoti—"
    },
    {
      "id": "mnd5:6.5",
      "pali": "tasmā vivādāni avītivatto."
    },
    {
      "id": "mnd5:7.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:8.1",
      "pali": "“Paramanti diṭṭhīsu paribbasāno,"
    },
    {
      "id": "mnd5:8.2",
      "pali": "Yaduttariṁ kurute jantu loke;"
    },
    {
      "id": "mnd5:8.3",
      "pali": "Hīnāti aññe tato sabbamāha,"
    },
    {
      "id": "mnd5:8.4",
      "pali": "Tasmā vivādāni avītivatto”ti."
    },
    {
      "id": "mnd5:9.1",
      "pali": "<b>Yadattanī passati ānisaṁsaṁ,</b>"
    },
    {
      "id": "mnd5:9.2",
      "pali": "<b>Diṭṭhe sute sīlavate mute vā;</b>"
    },
    {
      "id": "mnd5:9.3",
      "pali": "<b>Tadeva so tattha samuggahāya,</b>"
    },
    {
      "id": "mnd5:9.4",
      "pali": "<b>Nihīnato passati sabbamaññaṁ.</b>"
    },
    {
      "id": "mnd5:10.1",
      "pali": "<b>Yadattanī passati ānisaṁsaṁ, diṭṭhe sute sīlavate mute vā</b>ti."
    },
    {
      "id": "mnd5:10.2",
      "pali": "<b>Yadattanī</b>ti yaṁ attani."
    },
    {
      "id": "mnd5:10.3",
      "pali": "<b>Attā</b> vuccati diṭṭhigataṁ."
    },
    {
      "id": "mnd5:10.4",
      "pali": "Attano diṭṭhiyā dve ānisaṁse passati—"
    },
    {
      "id": "mnd5:10.5",
      "pali": "diṭṭhadhammikañca ānisaṁsaṁ, samparāyikañca ānisaṁsaṁ."
    },
    {
      "id": "mnd5:10.6",
      "pali": "Katamo diṭṭhiyā diṭṭhadhammiko ānisaṁso?"
    },
    {
      "id": "mnd5:10.7",
      "pali": "Yaṁdiṭṭhiko satthā hoti, taṁdiṭṭhikā sāvakā honti."
    },
    {
      "id": "mnd5:10.8",
      "pali": "Taṁdiṭṭhikaṁ satthāraṁ sāvakā sakkaronti garuṁ karonti mānenti pūjenti, labhati ca tatonidānaṁ cīvarapiṇḍapātasenāsanagilānapaccayabhesajjaparikkhāraṁ."
    },
    {
      "id": "mnd5:10.9",
      "pali": "Ayaṁ diṭṭhiyā diṭṭhadhammiko ānisaṁso."
    },
    {
      "id": "mnd5:10.10",
      "pali": "Katamo diṭṭhiyā samparāyiko ānisaṁso?"
    },
    {
      "id": "mnd5:10.11",
      "pali": "Ayaṁ diṭṭhi alaṁ nāgattāya vā supaṇṇattāya vā yakkhattāya vā asurattāya vā gandhabbattāya vā mahārājattāya vā indattāya vā brahmattāya vā devattāya vā;"
    },
    {
      "id": "mnd5:10.12",
      "pali": "ayaṁ diṭṭhi alaṁ suddhiyā visuddhiyā parisuddhiyā muttiyā vimuttiyā parimuttiyā;"
    },
    {
      "id": "mnd5:10.13",
      "pali": "imāya diṭṭhiyā sujjhanti visujjhanti parisujjhanti muccanti vimuccanti parimuccanti;"
    },
    {
      "id": "mnd5:10.14",
      "pali": "imāya diṭṭhiyā sujjhissāmi visujjhissāmi parisujjhissāmi muccissāmi vimuccissāmi parimuccissāmi āyatiṁ phalapāṭikaṅkhī hoti."
    },
    {
      "id": "mnd5:10.15",
      "pali": "Ayaṁ diṭṭhiyā samparāyiko ānisaṁso."
    },
    {
      "id": "mnd5:10.16",
      "pali": "Attano diṭṭhiyā ime dve ānisaṁse passati, diṭṭhasuddhiyāpi dve ānisaṁse passati, sutasuddhiyāpi dve ānisaṁse passati, sīlasuddhiyāpi dve ānisaṁse passati, vatasuddhiyāpi dve ānisaṁse passati, mutasuddhiyāpi dve ānisaṁse passati—"
    },
    {
      "id": "mnd5:10.17",
      "pali": "diṭṭhadhammikañca ānisaṁsaṁ samparāyikañca ānisaṁsaṁ."
    },
    {
      "id": "mnd5:10.18",
      "pali": "Katamo mutasuddhiyā diṭṭhadhammiko ānisaṁso?"
    },
    {
      "id": "mnd5:10.19",
      "pali": "Yaṁdiṭṭhiko satthā hoti taṁdiṭṭhikā sāvakā honti …pe…"
    },
    {
      "id": "mnd5:10.20",
      "pali": "ayaṁ mutasuddhiyā diṭṭhadhammiko ānisaṁso."
    },
    {
      "id": "mnd5:10.21",
      "pali": "Katamo mutasuddhiyā samparāyiko ānisaṁso?"
    },
    {
      "id": "mnd5:10.22",
      "pali": "Ayaṁ diṭṭhi alaṁ nāgattāya vā …pe…"
    },
    {
      "id": "mnd5:10.23",
      "pali": "ayaṁ mutasuddhiyā samparāyiko ānisaṁso."
    },
    {
      "id": "mnd5:10.24",
      "pali": "Mutasuddhiyāpi ime dve ānisaṁse passati dakkhati oloketi nijjhāyati upaparikkhatīti—"
    },
    {
      "id": "mnd5:10.25",
      "pali": "yadattanī passati ānisaṁsaṁ diṭṭhe sute sīlavate mute vā."
    },
    {
      "id": "mnd5:11.1",
      "pali": "<b>Tadeva so tattha samuggahāyā</b>ti."
    },
    {
      "id": "mnd5:11.2",
      "pali": "<b>Tadevā</b>ti taṁ diṭṭhigataṁ."
    },
    {
      "id": "mnd5:11.3",
      "pali": "<b>Tatthā</b>ti sakāya diṭṭhiyā sakāya khantiyā sakāya ruciyā sakāya laddhiyā."
    },
    {
      "id": "mnd5:11.4",
      "pali": "<b>Samuggahāyā</b>ti idaṁ paramaṁ aggaṁ seṭṭhaṁ visiṭṭhaṁ pāmokkhaṁ uttamaṁ pavaranti gahetvā uggahetvā gaṇhitvā parāmasitvā abhinivisitvāti—"
    },
    {
      "id": "mnd5:11.5",
      "pali": "tadeva so tattha samuggahāya."
    },
    {
      "id": "mnd5:12.1",
      "pali": "<b>Nihīnato passati sabbamaññan</b>ti."
    },
    {
      "id": "mnd5:12.2",
      "pali": "Aññaṁ satthāraṁ dhammakkhānaṁ gaṇaṁ diṭṭhiṁ paṭipadaṁ maggaṁ hīnato nihīnato omakato lāmakato chatukkato parittato dissati passati dakkhati oloketi nijjhāyati upaparikkhatīti—"
    },
    {
      "id": "mnd5:12.3",
      "pali": "nihīnato passati sabbamaññaṁ."
    },
    {
      "id": "mnd5:13.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:14.1",
      "pali": "“Yadattanī passati ānisaṁsaṁ,"
    },
    {
      "id": "mnd5:14.2",
      "pali": "Diṭṭhe sute sīlavate mute vā;"
    },
    {
      "id": "mnd5:14.3",
      "pali": "Tadeva so tattha samuggahāya,"
    },
    {
      "id": "mnd5:14.4",
      "pali": "Nihīnato passati sabbamaññan”ti."
    },
    {
      "id": "mnd5:15.1",
      "pali": "<b>Taṁ vāpi ganthaṁ kusalā vadanti,</b>"
    },
    {
      "id": "mnd5:15.2",
      "pali": "<b>Yaṁ nissito passati hīnamaññaṁ;</b>"
    },
    {
      "id": "mnd5:15.3",
      "pali": "<b>Tasmā hi diṭṭhaṁ va sutaṁ mutaṁ vā,</b>"
    },
    {
      "id": "mnd5:15.4",
      "pali": "<b>Sīlabbataṁ bhikkhu na nissayeyya.</b>"
    },
    {
      "id": "mnd5:16.1",
      "pali": "<b>Taṁ vāpi ganthaṁ kusalā vadantī</b>ti."
    },
    {
      "id": "mnd5:16.2",
      "pali": "<b>Kusalā</b>ti ye te khandhakusalā dhātukusalā āyatanakusalā paṭiccasamuppādakusalā satipaṭṭhānakusalā sammappadhānakusalā iddhipādakusalā indriyakusalā balakusalā bojjhaṅgakusalā maggakusalā phalakusalā nibbānakusalā, te kusalā evaṁ vadanti—"
    },
    {
      "id": "mnd5:16.3",
      "pali": "“gantho eso, lagganaṁ etaṁ, bandhanaṁ etaṁ, palibodho eso”ti."
    },
    {
      "id": "mnd5:16.4",
      "pali": "Evaṁ vadanti evaṁ kathenti evaṁ bhaṇanti evaṁ dīpayanti evaṁ voharantīti—"
    },
    {
      "id": "mnd5:16.5",
      "pali": "taṁ vāpi ganthaṁ kusalā vadanti."
    },
    {
      "id": "mnd5:17.1",
      "pali": "<b>Yaṁ nissito passati hīnamaññan</b>ti."
    },
    {
      "id": "mnd5:17.2",
      "pali": "<b>Yaṁ nissito</b>ti yaṁ satthāraṁ dhammakkhānaṁ gaṇaṁ diṭṭhiṁ paṭipadaṁ maggaṁ nissito sannissito allīno upagato ajjhosito adhimutto."
    },
    {
      "id": "mnd5:17.3",
      "pali": "<b>Passati hīnamaññan</b>ti aññaṁ satthāraṁ dhammakkhānaṁ gaṇaṁ diṭṭhiṁ paṭipadaṁ maggaṁ hīnato nihīnato omakato lāmakato chatukkato parittato dissati passati dakkhati oloketi nijjhāyati upanijjhāyati upaparikkhatīti—"
    },
    {
      "id": "mnd5:17.4",
      "pali": "yaṁ nissito passati hīnamaññaṁ."
    },
    {
      "id": "mnd5:18.1",
      "pali": "<b>Tasmā hi diṭṭhaṁ va sutaṁ mutaṁ vā, sīlabbataṁ bhikkhu na nissayeyyā</b>ti."
    },
    {
      "id": "mnd5:18.2",
      "pali": "<b>Tasmā</b>ti tasmā taṅkāraṇā taṁhetu tappaccayā taṁnidānā diṭṭhaṁ vā diṭṭhasuddhiṁ vā sutaṁ vā sutasuddhiṁ vā mutaṁ vā mutasuddhiṁ vā sīlaṁ vā sīlasuddhiṁ vā vataṁ vā vatasuddhiṁ vā na nissayeyya na gaṇheyya na parāmaseyya nābhiniveseyyāti—"
    },
    {
      "id": "mnd5:18.3",
      "pali": "tasmā hi diṭṭhaṁ va sutaṁ mutaṁ vā sīlabbataṁ bhikkhu na nissayeyya."
    },
    {
      "id": "mnd5:19.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:20.1",
      "pali": "“Taṁ vāpi ganthaṁ kusalā vadanti,"
    },
    {
      "id": "mnd5:20.2",
      "pali": "Yaṁ nissito passati hīnamaññaṁ;"
    },
    {
      "id": "mnd5:20.3",
      "pali": "Tasmā hi diṭṭhaṁ va sutaṁ mutaṁ vā,"
    },
    {
      "id": "mnd5:20.4",
      "pali": "Sīlabbataṁ bhikkhu na nissayeyyā”ti."
    },
    {
      "id": "mnd5:21.1",
      "pali": "<b>Diṭṭhimpi lokasmiṁ na kappayeyya,</b>"
    },
    {
      "id": "mnd5:21.2",
      "pali": "<b>Ñāṇena vā sīlavatena vāpi;</b>"
    },
    {
      "id": "mnd5:21.3",
      "pali": "<b>Samoti attānamanūpaneyya,</b>"
    },
    {
      "id": "mnd5:21.4",
      "pali": "<b>Hīno na maññetha visesi vāpi.</b>"
    },
    {
      "id": "mnd5:22.1",
      "pali": "<b>Diṭṭhimpi lokasmiṁ na kappayeyya, ñāṇena vā sīlavatena vāpī</b>ti."
    },
    {
      "id": "mnd5:22.2",
      "pali": "Aṭṭhasamāpattiñāṇena vā pañcābhiññāñāṇena vā micchāñāṇena vā, sīlena vā vatena vā sīlabbatena vā, diṭṭhiṁ na kappayeyya na janeyya na sañjaneyya na nibbatteyya na abhinibbatteyya."
    },
    {
      "id": "mnd5:22.3",
      "pali": "<b>Lokasmin</b>ti apāyaloke …pe… āyatanaloketi—"
    },
    {
      "id": "mnd5:22.4",
      "pali": "diṭṭhimpi lokasmiṁ na kappayeyya ñāṇena vā sīlavatena vāpi."
    },
    {
      "id": "mnd5:23.1",
      "pali": "<b>Samoti attānamanūpaneyyā</b>ti."
    },
    {
      "id": "mnd5:23.2",
      "pali": "Sadisohamasmīti attānaṁ na upaneyya jātiyā vā gottena vā kolaputtiyena vā vaṇṇapokkharatāya vā dhanena vā ajjhenena vā kammāyatanena vā sippāyatanena vā vijjāṭṭhānena vā sutena vā paṭibhānena vā aññataraññatarena vā vatthunāti—"
    },
    {
      "id": "mnd5:23.3",
      "pali": "samoti attānamanūpaneyya."
    },
    {
      "id": "mnd5:24.1",
      "pali": "<b>Hīno na maññetha visesi vāpī</b>ti."
    },
    {
      "id": "mnd5:24.2",
      "pali": "Hīnohamasmīti attānaṁ na upaneyya jātiyā vā gottena vā …pe… aññataraññatarena vā vatthunā."
    },
    {
      "id": "mnd5:24.3",
      "pali": "Seyyohamasmīti attānaṁ na upaneyya jātiyā vā gottena vā …pe… aññataraññatarena vā vatthunāti—"
    },
    {
      "id": "mnd5:24.4",
      "pali": "hīno na maññetha visesi vāpi."
    },
    {
      "id": "mnd5:25.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:26.1",
      "pali": "“Diṭṭhimpi lokasmiṁ na kappayeyya,"
    },
    {
      "id": "mnd5:26.2",
      "pali": "Ñāṇena vā sīlavatena vāpi;"
    },
    {
      "id": "mnd5:26.3",
      "pali": "Samoti attānamanūpaneyya,"
    },
    {
      "id": "mnd5:26.4",
      "pali": "Hīno na maññetha visesi vāpī”ti."
    },
    {
      "id": "mnd5:27.1",
      "pali": "<b>Attaṁ pahāya anupādiyāno,</b>"
    },
    {
      "id": "mnd5:27.2",
      "pali": "<b>Ñāṇenapi so nissayaṁ no karoti;</b>"
    },
    {
      "id": "mnd5:27.3",
      "pali": "<b>Sa ve viyattesu na vaggasārī,</b>"
    },
    {
      "id": "mnd5:27.4",
      "pali": "<b>Diṭṭhimpi so na pacceti kiñci.</b>"
    },
    {
      "id": "mnd5:28.1",
      "pali": "<b>Attaṁ pahāya anupādiyāno</b>ti."
    },
    {
      "id": "mnd5:28.2",
      "pali": "<b>Attaṁ pahāyā</b>ti attadiṭṭhiṁ pahāya."
    },
    {
      "id": "mnd5:28.3",
      "pali": "<b>Attaṁ pahāyā</b>ti gāhaṁ pahāya."
    },
    {
      "id": "mnd5:28.4",
      "pali": "<b>Attaṁ pahāyā</b>ti taṇhāvasena diṭṭhivasena gahitaṁ parāmaṭṭhaṁ abhiniviṭṭhaṁ ajjhositaṁ adhimuttaṁ pahāya pajahitvā vinodetvā byantiṁ karitvā anabhāvaṁ gametvāti—"
    },
    {
      "id": "mnd5:28.5",
      "pali": "attaṁ pahāya."
    },
    {
      "id": "mnd5:28.6",
      "pali": "<b>Anupādiyāno</b>ti catūhi upādānehi anupādiyamāno agaṇhamāno aparāmāsamāno anabhinivisamānoti—"
    },
    {
      "id": "mnd5:28.7",
      "pali": "attaṁ pahāya anupādiyāno."
    },
    {
      "id": "mnd5:29.1",
      "pali": "<b>Ñāṇenapi so nissayaṁ no karotī</b>ti aṭṭhasamāpattiñāṇena vā pañcābhiññāñāṇena vā micchāñāṇena vā taṇhānissayaṁ vā diṭṭhinissayaṁ vā na karoti na janeti na sañjaneti na nibbatteti na abhinibbattetīti—"
    },
    {
      "id": "mnd5:29.2",
      "pali": "ñāṇenapi so nissayaṁ no karoti."
    },
    {
      "id": "mnd5:30.1",
      "pali": "<b>Sa ve viyattesu na vaggasārī</b>ti sa ve viyattesu bhinnesu dvejjhāpannesu dveḷhakajātesu nānādiṭṭhikesu nānākhantikesu nānārucikesu nānāladdhikesu nānādiṭṭhinissayaṁ nissitesu chandāgatiṁ gacchantesu dosāgatiṁ gacchantesu mohāgatiṁ gacchantesu bhayāgatiṁ gacchantesu na chandāgatiṁ gacchati na dosāgatiṁ gacchati na mohāgatiṁ gacchati na bhayāgatiṁ gacchati na rāgavasena gacchati na dosavasena gacchati na mohavasena gacchati na mānavasena gacchati na diṭṭhivasena gacchati na uddhaccavasena gacchati na vicikicchāvasena gacchati na anusayavasena gacchati na vaggehi dhammehi yāyati niyyati vuyhati saṁharīyatīti—"
    },
    {
      "id": "mnd5:30.2",
      "pali": "sa ve viyattesu na vaggasārī."
    },
    {
      "id": "mnd5:31.1",
      "pali": "<b>Diṭṭhimpi so na pacceti kiñcī</b>ti."
    },
    {
      "id": "mnd5:31.2",
      "pali": "Tassa dvāsaṭṭhi diṭṭhigatāni pahīnāni samucchinnāni vūpasantāni paṭipassaddhāni abhabbuppattikāni ñāṇagginā daḍḍhāni."
    },
    {
      "id": "mnd5:31.3",
      "pali": "So kiñci diṭṭhigataṁ na pacceti na paccāgacchatīti—"
    },
    {
      "id": "mnd5:31.4",
      "pali": "diṭṭhimpi so na pacceti kiñci."
    },
    {
      "id": "mnd5:32.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:33.1",
      "pali": "“Attaṁ pahāya anupādiyāno,"
    },
    {
      "id": "mnd5:33.2",
      "pali": "Ñāṇenapi so nissayaṁ no karoti;"
    },
    {
      "id": "mnd5:33.3",
      "pali": "Sa ve viyattesu na vaggasārī,"
    },
    {
      "id": "mnd5:33.4",
      "pali": "Diṭṭhimpi so na pacceti kiñcī”ti."
    },
    {
      "id": "mnd5:34.1",
      "pali": "<b>Yassūbhayante paṇidhīdha natthi,</b>"
    },
    {
      "id": "mnd5:34.2",
      "pali": "<b>Bhavābhavāya idha vā huraṁ vā;</b>"
    },
    {
      "id": "mnd5:34.3",
      "pali": "<b>Nivesanā tassa na santi keci,</b>"
    },
    {
      "id": "mnd5:34.4",
      "pali": "<b>Dhammesu niccheyya samuggahītaṁ.</b>"
    },
    {
      "id": "mnd5:35.1",
      "pali": "<b>Yassūbhayante paṇidhīdha natthi, bhavābhavāya idha vā huraṁ vā</b>ti <b>yassā</b>ti arahato khīṇāsavassa."
    },
    {
      "id": "mnd5:35.2",
      "pali": "<b>Anto</b>ti phasso eko anto, phassasamudayo dutiyo anto;"
    },
    {
      "id": "mnd5:35.3",
      "pali": "atīto eko anto, anāgato dutiyo anto;"
    },
    {
      "id": "mnd5:35.4",
      "pali": "sukhā vedanā eko anto, dukkhā vedanā dutiyo anto;"
    },
    {
      "id": "mnd5:35.5",
      "pali": "nāmaṁ eko anto, rūpaṁ dutiyo anto;"
    },
    {
      "id": "mnd5:35.6",
      "pali": "cha ajjhattikāni āyatanāni eko anto, cha bāhirāni āyatanāni dutiyo anto;"
    },
    {
      "id": "mnd5:35.7",
      "pali": "sakkāyo eko anto, sakkāyasamudayo dutiyo anto."
    },
    {
      "id": "mnd5:35.8",
      "pali": "<b>Paṇidhi</b> vuccati taṇhā."
    },
    {
      "id": "mnd5:35.9",
      "pali": "Yo rāgo sārāgo …pe… abhijjhā lobho akusalamūlaṁ."
    },
    {
      "id": "mnd5:36.1",
      "pali": "<b>Bhavābhavāyā</b>ti bhavābhavāya kammabhavāya punabbhavāya kāmabhavāya, kammabhavāya kāmabhavāya punabbhavāya rūpabhavāya, kammabhavāya rūpabhavāya punabbhavāya arūpabhavāya, kammabhavāya arūpabhavāya punabbhavāya punappunabbhavāya punappunagatiyā punappunaupapattiyā punappunapaṭisandhiyā punappunaattabhāvābhinibbattiyā."
    },
    {
      "id": "mnd5:36.2",
      "pali": "<b>Idhā</b>ti sakattabhāvo,"
    },
    {
      "id": "mnd5:36.3",
      "pali": "<b>hurā</b>ti parattabhāvo;"
    },
    {
      "id": "mnd5:36.4",
      "pali": "<b>idhā</b>ti sakarūpavedanāsaññāsaṅkhāraviññāṇaṁ,"
    },
    {
      "id": "mnd5:36.5",
      "pali": "<b>hurā</b>ti pararūpavedanāsaññāsaṅkhāraviññāṇaṁ;"
    },
    {
      "id": "mnd5:36.6",
      "pali": "<b>idhā</b>ti cha ajjhattikāni āyatanāni,"
    },
    {
      "id": "mnd5:36.7",
      "pali": "<b>hurā</b>ti cha bāhirāni āyatanāni;"
    },
    {
      "id": "mnd5:36.8",
      "pali": "<b>idhā</b>ti manussaloko,"
    },
    {
      "id": "mnd5:36.9",
      "pali": "<b>hurā</b>ti devaloko;"
    },
    {
      "id": "mnd5:36.10",
      "pali": "<b>idhā</b>ti kāmadhātu,"
    },
    {
      "id": "mnd5:36.11",
      "pali": "<b>hurā</b>ti rūpadhātu arūpadhātu;"
    },
    {
      "id": "mnd5:36.12",
      "pali": "<b>idhā</b>ti kāmadhātu rūpadhātu."
    },
    {
      "id": "mnd5:36.13",
      "pali": "<b>Hurā</b>ti arūpadhātu."
    },
    {
      "id": "mnd5:36.14",
      "pali": "<b>Yassūbhayante paṇidhīdha natthi bhavābhavāya idha vā huraṁ vā</b>ti."
    },
    {
      "id": "mnd5:36.15",
      "pali": "Yassa ubho ante ca bhavābhavāya ca idha hurañca paṇidhi taṇhā natthi na santi na saṁvijjati nupalabbhati, pahīnā samucchinnā vūpasantā paṭipassaddhā abhabbuppattikā ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "mnd5:36.16",
      "pali": "yassūbhayante paṇidhīdha natthi bhavābhavāya idha vā huraṁ vā."
    },
    {
      "id": "mnd5:37.1",
      "pali": "<b>Nivesanā tassa na santi kecī</b>ti."
    },
    {
      "id": "mnd5:37.2",
      "pali": "<b>Nivesanā</b>ti dve nivesanā—"
    },
    {
      "id": "mnd5:37.3",
      "pali": "taṇhānivesanā ca diṭṭhinivesanā ca …pe…"
    },
    {
      "id": "mnd5:37.4",
      "pali": "ayaṁ taṇhānivesanā …pe…"
    },
    {
      "id": "mnd5:37.5",
      "pali": "ayaṁ diṭṭhinivesanā."
    },
    {
      "id": "mnd5:37.6",
      "pali": "<b>Tassā</b>ti arahato khīṇāsavassa."
    },
    {
      "id": "mnd5:37.7",
      "pali": "<b>Nivesanā tassa na santi kecī</b>ti nivesanā tassa na santi keci natthi na santi na saṁvijjanti nupalabbhanti, pahīnā samucchinnā vūpasantā paṭipassaddhā abhabbuppattikā ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "mnd5:37.8",
      "pali": "nivesanā tassa na santi keci."
    },
    {
      "id": "mnd5:38.1",
      "pali": "<b>Dhammesu niccheyya samuggahītan</b>ti."
    },
    {
      "id": "mnd5:38.2",
      "pali": "<b>Dhammesū</b>ti dvāsaṭṭhiyā diṭṭhigatesu."
    },
    {
      "id": "mnd5:38.3",
      "pali": "<b>Niccheyyā</b>ti nicchinitvā vinicchinitvā vicinitvā pavicinitvā tulayitvā tīrayitvā vibhāvayitvā vibhūtaṁ katvā."
    },
    {
      "id": "mnd5:38.4",
      "pali": "<b>Samuggahītan</b>ti odhiggāho bilaggāho varaggāho koṭṭhāsaggāho uccayaggāho samuccayaggāho, “idaṁ saccaṁ tacchaṁ tathaṁ bhūtaṁ yāthāvaṁ aviparītan”ti gahitaṁ parāmaṭṭhaṁ abhiniviṭṭhaṁ ajjhositaṁ adhimuttaṁ natthi na santi na saṁvijjati nupalabbhati, pahīnaṁ samucchinnaṁ vūpasantaṁ paṭipassaddhaṁ abhabbuppattikaṁ ñāṇagginā daḍḍhanti—"
    },
    {
      "id": "mnd5:38.5",
      "pali": "dhammesu niccheyya samuggahītaṁ."
    },
    {
      "id": "mnd5:39.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:40.1",
      "pali": "“Yassūbhayante paṇidhīdha natthi,"
    },
    {
      "id": "mnd5:40.2",
      "pali": "Bhavābhavāya idha vā huraṁ vā;"
    },
    {
      "id": "mnd5:40.3",
      "pali": "Nivesanā tassa na santi keci,"
    },
    {
      "id": "mnd5:40.4",
      "pali": "Dhammesu niccheyya samuggahītan”ti."
    },
    {
      "id": "mnd5:41.1",
      "pali": "<b>Tassīdha diṭṭhe va sute mute vā,</b>"
    },
    {
      "id": "mnd5:41.2",
      "pali": "<b>Pakappitā natthi aṇūpi saññā;</b>"
    },
    {
      "id": "mnd5:41.3",
      "pali": "<b>Taṁ brāhmaṇaṁ diṭṭhimanādiyānaṁ,</b>"
    },
    {
      "id": "mnd5:41.4",
      "pali": "<b>Kenīdha lokasmiṁ vikappayeyya.</b>"
    },
    {
      "id": "mnd5:42.1",
      "pali": "<b>Tassīdha diṭṭhe va sute mute vā, pakappitā natthi aṇūpi saññā</b>ti."
    },
    {
      "id": "mnd5:42.2",
      "pali": "<b>Tassā</b>ti arahato khīṇāsavassa."
    },
    {
      "id": "mnd5:42.3",
      "pali": "Tassa diṭṭhe vā diṭṭhasuddhiyā vā sute vā sutasuddhiyā vā mute vā mutasuddhiyā vā saññāpubbaṅgamatā saññāvikappayeyyatā saññāviggahena saññāya uṭṭhapitā samuṭṭhapitā kappitā pakappitā saṅkhatā abhisaṅkhatā saṇṭhapitā, diṭṭhi natthi na santi na saṁvijjati nupalabbhati, pahīnā samucchinnā vūpasantā paṭipassaddhā abhabbuppattikā ñāṇagginā daḍḍhāti—"
    },
    {
      "id": "mnd5:42.4",
      "pali": "tassīdha diṭṭhe va sute mute vā pakappitā natthi aṇūpi saññā."
    },
    {
      "id": "mnd5:43.1",
      "pali": "<b>Taṁ brāhmaṇaṁ diṭṭhimanādiyānan</b>ti."
    },
    {
      "id": "mnd5:43.2",
      "pali": "Brāhmaṇoti sattannaṁ dhammānaṁ bāhitattā brāhmaṇo—"
    },
    {
      "id": "mnd5:43.3",
      "pali": "sakkāyadiṭṭhi bāhitā hoti …pe…"
    },
    {
      "id": "mnd5:43.4",
      "pali": "asito tādi pavuccate sa brahmā."
    },
    {
      "id": "mnd5:43.5",
      "pali": "Taṁ brāhmaṇaṁ diṭṭhimanādiyānanti."
    },
    {
      "id": "mnd5:43.6",
      "pali": "Taṁ brāhmaṇaṁ diṭṭhimanādiyantaṁ agaṇhantaṁ aparāmasantaṁ anabhinivesantanti—"
    },
    {
      "id": "mnd5:43.7",
      "pali": "taṁ brāhmaṇaṁ diṭṭhimanādiyānaṁ."
    },
    {
      "id": "mnd5:44.1",
      "pali": "<b>Kenīdha lokasmiṁ vikappayeyyā</b>ti."
    },
    {
      "id": "mnd5:44.2",
      "pali": "<b>Kappā</b>ti dve kappā—"
    },
    {
      "id": "mnd5:44.3",
      "pali": "taṇhākappo ca diṭṭhikappo ca …pe…"
    },
    {
      "id": "mnd5:44.4",
      "pali": "ayaṁ taṇhākappo …pe…"
    },
    {
      "id": "mnd5:44.5",
      "pali": "ayaṁ diṭṭhikappo."
    },
    {
      "id": "mnd5:44.6",
      "pali": "Tassa taṇhākappo pahīno, diṭṭhikappo paṭinissaṭṭho."
    },
    {
      "id": "mnd5:44.7",
      "pali": "Taṇhākappassa pahīnattā, diṭṭhikappassa paṭinissaṭṭhattā kena rāgena kappeyya kena dosena kappeyya kena mohena kappeyya kena mānena kappeyya kāya diṭṭhiyā kappeyya kena uddhaccena kappeyya kāya vicikicchāya kappeyya kehi anusayehi kappeyya—"
    },
    {
      "id": "mnd5:44.8",
      "pali": "rattoti vā duṭṭhoti vā mūḷhoti vā vinibaddhoti vā parāmaṭṭhoti vā vikkhepagatoti vā aniṭṭhaṅgatoti vā thāmagatoti vā."
    },
    {
      "id": "mnd5:44.9",
      "pali": "Te abhisaṅkhārā pahīnā."
    },
    {
      "id": "mnd5:44.10",
      "pali": "Abhisaṅkhārānaṁ pahīnattā gatiyo kena kappeyya—"
    },
    {
      "id": "mnd5:44.11",
      "pali": "nerayikoti vā tiracchānayonikoti vā pettivisayikoti vā manussoti vā devoti vā rūpīti vā arūpīti vā saññīti vā asaññīti vā nevasaññīnāsaññīti vā."
    },
    {
      "id": "mnd5:44.12",
      "pali": "So hetu natthi paccayo natthi kāraṇaṁ natthi, yena kappeyya vikappeyya vikappaṁ āpajjeyya."
    },
    {
      "id": "mnd5:44.13",
      "pali": "<b>Lokasmin</b>ti apāyaloke …pe… āyatanaloketi—"
    },
    {
      "id": "mnd5:44.14",
      "pali": "kenīdha lokasmiṁ vikappayeyya."
    },
    {
      "id": "mnd5:45.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:46.1",
      "pali": "“Tassīdha diṭṭhe va sute mute vā,"
    },
    {
      "id": "mnd5:46.2",
      "pali": "Pakappitā natthi aṇūpi saññā;"
    },
    {
      "id": "mnd5:46.3",
      "pali": "Taṁ brāhmaṇaṁ diṭṭhimanādiyānaṁ,"
    },
    {
      "id": "mnd5:46.4",
      "pali": "Kenīdha lokasmiṁ vikappayeyyā”ti."
    },
    {
      "id": "mnd5:47.1",
      "pali": "<b>Na kappayanti na purekkharonti,</b>"
    },
    {
      "id": "mnd5:47.2",
      "pali": "<b>Dhammāpi tesaṁ na paṭicchitāse;</b>"
    },
    {
      "id": "mnd5:47.3",
      "pali": "<b>Na brāhmaṇo sīlavatena neyyo,</b>"
    },
    {
      "id": "mnd5:47.4",
      "pali": "<b>Pāraṅgato na pacceti tādī.</b>"
    },
    {
      "id": "mnd5:48.1",
      "pali": "<b>Na kappayanti na purekkharontī</b>ti."
    },
    {
      "id": "mnd5:48.2",
      "pali": "<b>Kappā</b>ti dve kappā—"
    },
    {
      "id": "mnd5:48.3",
      "pali": "taṇhākappo ca diṭṭhikappo ca."
    },
    {
      "id": "mnd5:48.4",
      "pali": "Katamo taṇhākappo?"
    },
    {
      "id": "mnd5:48.5",
      "pali": "Yāvatā taṇhāsaṅkhātena sīmakataṁ mariyādikataṁ odhikataṁ pariyantakataṁ pariggahitaṁ mamāyitaṁ—"
    },
    {
      "id": "mnd5:48.6",
      "pali": "idaṁ mamaṁ, etaṁ mamaṁ, ettakaṁ mamaṁ, ettāvatā mamaṁ, mama rūpā saddā gandhā rasā phoṭṭhabbā, attharaṇā pāvuraṇā dāsidāsā ajeḷakā kukkuṭasūkarā hatthigavāssavaḷavā khettaṁ vatthu hiraññaṁ suvaṇṇaṁ gāmanigamarājadhāniyo raṭṭhañca janapado ca koso ca koṭṭhāgārañca, kevalampi mahāpathaviṁ taṇhāvasena mamāyati, yāvatā aṭṭhasatataṇhāvicaritaṁ—"
    },
    {
      "id": "mnd5:48.7",
      "pali": "ayaṁ taṇhākappo."
    },
    {
      "id": "mnd5:48.8",
      "pali": "Katamo diṭṭhikappo?"
    },
    {
      "id": "mnd5:48.9",
      "pali": "Vīsativatthukā sakkāyadiṭṭhi, dasavatthukā micchādiṭṭhi, dasavatthukā antaggāhikādiṭṭhi, yā evarūpā diṭṭhi diṭṭhigataṁ diṭṭhigahanaṁ diṭṭhikantāraṁ diṭṭhivisūkāyikaṁ diṭṭhivipphanditaṁ diṭṭhisaṁyojanaṁ gāho paṭiggāho abhiniveso parāmāso kummaggo micchāpatho micchattaṁ titthāyatanaṁ vipariyesaggāho viparītaggāho vipallāsaggāho micchāgāho, ayāthāvakasmiṁ yāthāvakanti gāho, yāvatā dvāsaṭṭhi diṭṭhigatāni—"
    },
    {
      "id": "mnd5:48.10",
      "pali": "ayaṁ diṭṭhikappo."
    },
    {
      "id": "mnd5:48.11",
      "pali": "Tesaṁ taṇhākappo pahīno, diṭṭhikappo paṭinissaṭṭho."
    },
    {
      "id": "mnd5:48.12",
      "pali": "Taṇhākappassa pahīnattā, diṭṭhikappassa paṭinissaṭṭhattā taṇhākappaṁ vā diṭṭhikappaṁ vā na kappenti na janenti na sañjanenti na nibbattenti na abhinibbattentīti—"
    },
    {
      "id": "mnd5:48.13",
      "pali": "na kappayanti."
    },
    {
      "id": "mnd5:49.1",
      "pali": "<b>Na purekkharontī</b>ti."
    },
    {
      "id": "mnd5:49.2",
      "pali": "<b>Purekkhārā</b>ti dve purekkhārā—"
    },
    {
      "id": "mnd5:49.3",
      "pali": "taṇhāpurekkhāro ca diṭṭhipurekkhāro ca …pe…"
    },
    {
      "id": "mnd5:49.4",
      "pali": "ayaṁ taṇhāpurekkhāro …pe…"
    },
    {
      "id": "mnd5:49.5",
      "pali": "ayaṁ diṭṭhipurekkhāro."
    },
    {
      "id": "mnd5:49.6",
      "pali": "Tesaṁ taṇhāpurekkhāro pahīno, diṭṭhipurekkhāro paṭinissaṭṭho."
    },
    {
      "id": "mnd5:49.7",
      "pali": "Taṇhāpurekkhārassa pahīnattā, diṭṭhipurekkhārassa paṭinissaṭṭhattā na taṇhaṁ vā na diṭṭhiṁ vā purato katvā caranti na taṇhādhajā na taṇhāketū na taṇhādhipateyyā na diṭṭhidhajā na diṭṭhiketū na diṭṭhādhipateyyā."
    },
    {
      "id": "mnd5:49.8",
      "pali": "Na taṇhāya vā na diṭṭhiyā vā parivāretvā carantīti—"
    },
    {
      "id": "mnd5:49.9",
      "pali": "na kappayanti na purekkharonti."
    },
    {
      "id": "mnd5:50.1",
      "pali": "<b>Dhammāpi tesaṁ na paṭicchitāse</b>ti."
    },
    {
      "id": "mnd5:50.2",
      "pali": "<b>Dhammā</b> vuccanti dvāsaṭṭhi diṭṭhigatāni."
    },
    {
      "id": "mnd5:50.3",
      "pali": "<b>Tesan</b>ti tesaṁ arahantānaṁ khīṇāsavānaṁ."
    },
    {
      "id": "mnd5:50.4",
      "pali": "<b>Na paṭicchitāse</b>ti “sassato loko, idameva saccaṁ moghamaññan”ti na paṭicchitāse."
    },
    {
      "id": "mnd5:50.5",
      "pali": "“Asassato loko …"
    },
    {
      "id": "mnd5:50.6",
      "pali": "antavā loko …"
    },
    {
      "id": "mnd5:50.7",
      "pali": "anantavā loko …"
    },
    {
      "id": "mnd5:50.8",
      "pali": "taṁ jīvaṁ taṁ sarīraṁ …"
    },
    {
      "id": "mnd5:50.9",
      "pali": "aññaṁ jīvaṁ aññaṁ sarīraṁ …"
    },
    {
      "id": "mnd5:50.10",
      "pali": "hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "mnd5:50.11",
      "pali": "na hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "mnd5:50.12",
      "pali": "hoti ca na ca hoti tathāgato paraṁ maraṇā …"
    },
    {
      "id": "mnd5:50.13",
      "pali": "neva hoti na na hoti tathāgato paraṁ maraṇā, idameva saccaṁ moghamaññan”ti na paṭicchitāseti—"
    },
    {
      "id": "mnd5:50.14",
      "pali": "dhammāpi tesaṁ na paṭicchitāse."
    },
    {
      "id": "mnd5:51.1",
      "pali": "<b>Na brāhmaṇo sīlavatena neyyo</b>ti."
    },
    {
      "id": "mnd5:51.2",
      "pali": "<b>Nā</b>ti paṭikkhepo."
    },
    {
      "id": "mnd5:51.3",
      "pali": "<b>Brāhmaṇo</b>ti sattannaṁ dhammānaṁ bāhitattā brāhmaṇo—"
    },
    {
      "id": "mnd5:51.4",
      "pali": "sakkāyadiṭṭhi bāhitā hoti …pe…"
    },
    {
      "id": "mnd5:51.5",
      "pali": "asito tādi vuccate sa brahmā."
    },
    {
      "id": "mnd5:51.6",
      "pali": "<b>Na brāhmaṇo sīlavatena neyyo</b>ti."
    },
    {
      "id": "mnd5:51.7",
      "pali": "Brāhmaṇo sīlena vā vatena vā sīlabbatena vā na yāyati na niyyati na vuyhati na saṁharīyatīti—"
    },
    {
      "id": "mnd5:51.8",
      "pali": "na brāhmaṇo sīlavatena neyyo."
    },
    {
      "id": "mnd5:52.1",
      "pali": "<b>Pāraṅgato na pacceti tādī</b>ti."
    },
    {
      "id": "mnd5:52.2",
      "pali": "<b>Pāraṁ</b> vuccati amataṁ nibbānaṁ."
    },
    {
      "id": "mnd5:52.3",
      "pali": "Yo so sabbasaṅkhārasamatho sabbūpadhipaṭinissaggo taṇhakkhayo virāgo nirodho nibbānaṁ."
    },
    {
      "id": "mnd5:52.4",
      "pali": "So pāraṅgato pārappatto antagato antappatto koṭigato koṭippatto (vitthāro) jātimaraṇasaṁsāro, natthi tassa punabbhavoti—"
    },
    {
      "id": "mnd5:52.5",
      "pali": "pāraṅgato."
    },
    {
      "id": "mnd5:52.6",
      "pali": "<b>Na paccetī</b>ti sotāpattimaggena ye kilesā pahīnā, te kilese na puneti na pacceti na paccāgacchati."
    },
    {
      "id": "mnd5:52.7",
      "pali": "Sakadāgāmimaggena ye kilesā pahīnā, te kilese na puneti na pacceti na paccāgacchati."
    },
    {
      "id": "mnd5:52.8",
      "pali": "Anāgāmimaggena ye kilesā pahīnā, te kilese na puneti na pacceti na paccāgacchati."
    },
    {
      "id": "mnd5:52.9",
      "pali": "Arahattamaggena ye kilesā pahīnā, te kilese na puneti na pacceti na paccāgacchatīti—"
    },
    {
      "id": "mnd5:52.10",
      "pali": "pāraṅgato na pacceti."
    },
    {
      "id": "mnd5:52.11",
      "pali": "<b>Tādī</b>ti arahā pañcahākārehi tādī—"
    },
    {
      "id": "mnd5:52.12",
      "pali": "iṭṭhāniṭṭhe tādī, cattāvīti tādī, tiṇṇāvīti tādī, muttāvīti tādī, taṁniddesā tādī."
    },
    {
      "id": "mnd5:53.1",
      "pali": "Kathaṁ arahā iṭṭhāniṭṭhe tādī?"
    },
    {
      "id": "mnd5:53.2",
      "pali": "Arahā lābhepi tādī, alābhepi tādī, yasepi tādī, ayasepi tādī, pasaṁsāyapi tādī, nindāyapi tādī, sukhepi tādī, dukkhepi tādī."
    },
    {
      "id": "mnd5:53.3",
      "pali": "Ekañce bāhaṁ gandhena limpeyyuṁ, ekañce bāhaṁ vāsiyā taccheyyuṁ—"
    },
    {
      "id": "mnd5:53.4",
      "pali": "amusmiṁ natthi rāgo, amusmiṁ natthi paṭighaṁ, anunayapaṭighavippahīno ugghātinighātivītivatto anurodhavirodhasamatikkanto."
    },
    {
      "id": "mnd5:53.5",
      "pali": "Evaṁ arahā iṭṭhāniṭṭhe tādī."
    },
    {
      "id": "mnd5:54.1",
      "pali": "Kathaṁ arahā cattāvīti tādī?"
    },
    {
      "id": "mnd5:54.2",
      "pali": "Arahato rāgo catto vanto mutto pahīno paṭinissaṭṭho."
    },
    {
      "id": "mnd5:54.3",
      "pali": "Doso …"
    },
    {
      "id": "mnd5:54.4",
      "pali": "moho …"
    },
    {
      "id": "mnd5:54.5",
      "pali": "kodho …"
    },
    {
      "id": "mnd5:54.6",
      "pali": "upanāho …"
    },
    {
      "id": "mnd5:54.7",
      "pali": "makkho …"
    },
    {
      "id": "mnd5:54.8",
      "pali": "paḷāso …"
    },
    {
      "id": "mnd5:54.9",
      "pali": "issā …"
    },
    {
      "id": "mnd5:54.10",
      "pali": "macchariyaṁ …"
    },
    {
      "id": "mnd5:54.11",
      "pali": "māyā …"
    },
    {
      "id": "mnd5:54.12",
      "pali": "sāṭheyyaṁ …"
    },
    {
      "id": "mnd5:54.13",
      "pali": "thambho …"
    },
    {
      "id": "mnd5:54.14",
      "pali": "sārambho …"
    },
    {
      "id": "mnd5:54.15",
      "pali": "māno …"
    },
    {
      "id": "mnd5:54.16",
      "pali": "atimāno …"
    },
    {
      "id": "mnd5:54.17",
      "pali": "mado …"
    },
    {
      "id": "mnd5:54.18",
      "pali": "pamādo …"
    },
    {
      "id": "mnd5:54.19",
      "pali": "sabbe kilesā …"
    },
    {
      "id": "mnd5:54.20",
      "pali": "sabbe duccaritā …"
    },
    {
      "id": "mnd5:54.21",
      "pali": "sabbe darathā …"
    },
    {
      "id": "mnd5:54.22",
      "pali": "sabbe pariḷāhā …"
    },
    {
      "id": "mnd5:54.23",
      "pali": "sabbe santāpā …"
    },
    {
      "id": "mnd5:54.24",
      "pali": "sabbākusalābhisaṅkhārā cattā vantā muttā pahīnā paṭinissaṭṭhā."
    },
    {
      "id": "mnd5:54.25",
      "pali": "Evaṁ arahā cattāvīti tādī."
    },
    {
      "id": "mnd5:55.1",
      "pali": "Kathaṁ arahā tiṇṇāvīti tādī?"
    },
    {
      "id": "mnd5:55.2",
      "pali": "Arahā kāmoghaṁ tiṇṇo bhavoghaṁ tiṇṇo diṭṭhoghaṁ tiṇṇo avijjoghaṁ tiṇṇo sabbaṁ saṁsārapathaṁ tiṇṇo uttiṇṇo nittiṇṇo atikkanto samatikkanto vītivatto."
    },
    {
      "id": "mnd5:55.3",
      "pali": "So vuṭṭhavāso ciṇṇacaraṇo jātimaraṇasaṁsāro, natthi tassa punabbhavoti."
    },
    {
      "id": "mnd5:55.4",
      "pali": "Evaṁ arahā tiṇṇāvīti tādī."
    },
    {
      "id": "mnd5:56.1",
      "pali": "Kathaṁ arahā muttāvīti tādī?"
    },
    {
      "id": "mnd5:56.2",
      "pali": "Arahato rāgā cittaṁ muttaṁ vimuttaṁ suvimuttaṁ,"
    },
    {
      "id": "mnd5:56.3",
      "pali": "dosā cittaṁ muttaṁ vimuttaṁ suvimuttaṁ,"
    },
    {
      "id": "mnd5:56.4",
      "pali": "mohā cittaṁ muttaṁ vimuttaṁ suvimuttaṁ,"
    },
    {
      "id": "mnd5:56.5",
      "pali": "kodhā …"
    },
    {
      "id": "mnd5:56.6",
      "pali": "upanāhā …"
    },
    {
      "id": "mnd5:56.7",
      "pali": "makkhā …"
    },
    {
      "id": "mnd5:56.8",
      "pali": "paḷāsā …"
    },
    {
      "id": "mnd5:56.9",
      "pali": "issāya …"
    },
    {
      "id": "mnd5:56.10",
      "pali": "macchariyā …"
    },
    {
      "id": "mnd5:56.11",
      "pali": "māyāya …"
    },
    {
      "id": "mnd5:56.12",
      "pali": "sāṭheyyā …"
    },
    {
      "id": "mnd5:56.13",
      "pali": "thambhā …"
    },
    {
      "id": "mnd5:56.14",
      "pali": "sārambhā …"
    },
    {
      "id": "mnd5:56.15",
      "pali": "mānā …"
    },
    {
      "id": "mnd5:56.16",
      "pali": "atimānā …"
    },
    {
      "id": "mnd5:56.17",
      "pali": "madā …"
    },
    {
      "id": "mnd5:56.18",
      "pali": "pamādā …"
    },
    {
      "id": "mnd5:56.19",
      "pali": "sabbakilesehi …"
    },
    {
      "id": "mnd5:56.20",
      "pali": "sabbaduccaritehi …"
    },
    {
      "id": "mnd5:56.21",
      "pali": "sabbadarathehi …"
    },
    {
      "id": "mnd5:56.22",
      "pali": "sabbapariḷāhehi …"
    },
    {
      "id": "mnd5:56.23",
      "pali": "sabbasantāpehi …"
    },
    {
      "id": "mnd5:56.24",
      "pali": "sabbākusalābhisaṅkhārehi cittaṁ muttaṁ vimuttaṁ suvimuttaṁ."
    },
    {
      "id": "mnd5:56.25",
      "pali": "Evaṁ arahā muttāvīti tādī."
    },
    {
      "id": "mnd5:57.1",
      "pali": "Kathaṁ arahā taṁniddesā tādī?"
    },
    {
      "id": "mnd5:57.2",
      "pali": "Arahā sīle sati sīlavāti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.3",
      "pali": "saddhāya sati saddhoti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.4",
      "pali": "vīriye sati vīriyavāti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.5",
      "pali": "satiyā sati satimāti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.6",
      "pali": "samādhimhi sati samāhitoti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.7",
      "pali": "paññāya sati paññavāti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.8",
      "pali": "vijjāya sati tevijjoti taṁniddesā tādī;"
    },
    {
      "id": "mnd5:57.9",
      "pali": "abhiññāya sati chaḷabhiññoti taṁniddesā tādī."
    },
    {
      "id": "mnd5:57.10",
      "pali": "Evaṁ arahā taṁniddesā tādīti—"
    },
    {
      "id": "mnd5:57.11",
      "pali": "pāraṅgato na pacceti tādī."
    },
    {
      "id": "mnd5:58.1",
      "pali": "Tenāha bhagavā—"
    },
    {
      "id": "mnd5:59.1",
      "pali": "“Na kappayanti na purekkharonti,"
    },
    {
      "id": "mnd5:59.2",
      "pali": "Dhammāpi tesaṁ na paṭicchitāse;"
    },
    {
      "id": "mnd5:59.3",
      "pali": "Na brāhmaṇo sīlavatena neyyo,"
    },
    {
      "id": "mnd5:59.4",
      "pali": "Pāraṅgato na pacceti tādī”ti."
    },
    {
      "id": "mnd5:60.1",
      "pali": "Paramaṭṭhakasuttaniddeso pañcamo."
    }
  ]
}
