{
  "uid": "mn1",
  "title": "Mūlapariyāyasutta",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mn1:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "mn1:1.2",
      "pali": "ekaṁ samayaṁ bhagavā ukkaṭṭhāyaṁ viharati subhagavane sālarājamūle."
    },
    {
      "id": "mn1:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "mn1:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "mn1:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn1:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn1:2.1",
      "pali": "“sabbadhammamūlapariyāyaṁ vo, bhikkhave, desessāmi."
    },
    {
      "id": "mn1:2.2",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "mn1:2.3",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn1:2.4",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn1:3.1",
      "pali": "“Idha, bhikkhave, assutavā puthujjano ariyānaṁ adassāvī ariyadhammassa akovido ariyadhamme avinīto, sappurisānaṁ adassāvī sappurisadhammassa akovido sappurisadhamme avinīto—"
    },
    {
      "id": "mn1:3.2",
      "pali": "pathaviṁ pathavito sañjānāti;"
    },
    {
      "id": "mn1:3.3",
      "pali": "pathaviṁ pathavito saññatvā pathaviṁ maññati, pathaviyā maññati, pathavito maññati, pathaviṁ meti maññati, pathaviṁ abhinandati."
    },
    {
      "id": "mn1:3.4",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:3.5",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:4.1",
      "pali": "Āpaṁ āpato sañjānāti;"
    },
    {
      "id": "mn1:4.2",
      "pali": "āpaṁ āpato saññatvā āpaṁ maññati, āpasmiṁ maññati, āpato maññati, āpaṁ meti maññati, āpaṁ abhinandati."
    },
    {
      "id": "mn1:4.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:4.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:5.1",
      "pali": "Tejaṁ tejato sañjānāti;"
    },
    {
      "id": "mn1:5.2",
      "pali": "tejaṁ tejato saññatvā tejaṁ maññati, tejasmiṁ maññati, tejato maññati, tejaṁ meti maññati, tejaṁ abhinandati."
    },
    {
      "id": "mn1:5.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:5.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:6.1",
      "pali": "Vāyaṁ vāyato sañjānāti;"
    },
    {
      "id": "mn1:6.2",
      "pali": "vāyaṁ vāyato saññatvā vāyaṁ maññati, vāyasmiṁ maññati, vāyato maññati, vāyaṁ meti maññati, vāyaṁ abhinandati."
    },
    {
      "id": "mn1:6.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:6.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:7.1",
      "pali": "Bhūte bhūtato sañjānāti;"
    },
    {
      "id": "mn1:7.2",
      "pali": "bhūte bhūtato saññatvā bhūte maññati, bhūtesu maññati, bhūtato maññati, bhūte meti maññati, bhūte abhinandati."
    },
    {
      "id": "mn1:7.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:7.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:8.1",
      "pali": "Deve devato sañjānāti;"
    },
    {
      "id": "mn1:8.2",
      "pali": "deve devato saññatvā deve maññati, devesu maññati, devato maññati, deve meti maññati, deve abhinandati."
    },
    {
      "id": "mn1:8.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:8.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:9.1",
      "pali": "Pajāpatiṁ pajāpatito sañjānāti;"
    },
    {
      "id": "mn1:9.2",
      "pali": "pajāpatiṁ pajāpatito saññatvā pajāpatiṁ maññati, pajāpatismiṁ maññati, pajāpatito maññati, pajāpatiṁ meti maññati, pajāpatiṁ abhinandati."
    },
    {
      "id": "mn1:9.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:9.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:10.1",
      "pali": "Brahmaṁ brahmato sañjānāti;"
    },
    {
      "id": "mn1:10.2",
      "pali": "brahmaṁ brahmato saññatvā brahmaṁ maññati, brahmasmiṁ maññati, brahmato maññati, brahmaṁ meti maññati, brahmaṁ abhinandati."
    },
    {
      "id": "mn1:10.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:10.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:11.1",
      "pali": "Ābhassare ābhassarato sañjānāti;"
    },
    {
      "id": "mn1:11.2",
      "pali": "ābhassare ābhassarato saññatvā ābhassare maññati, ābhassaresu maññati, ābhassarato maññati, ābhassare meti maññati, ābhassare abhinandati."
    },
    {
      "id": "mn1:11.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:11.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:12.1",
      "pali": "Subhakiṇhe subhakiṇhato sañjānāti;"
    },
    {
      "id": "mn1:12.2",
      "pali": "subhakiṇhe subhakiṇhato saññatvā subhakiṇhe maññati, subhakiṇhesu maññati, subhakiṇhato maññati, subhakiṇhe meti maññati, subhakiṇhe abhinandati."
    },
    {
      "id": "mn1:12.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:12.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:13.1",
      "pali": "Vehapphale vehapphalato sañjānāti;"
    },
    {
      "id": "mn1:13.2",
      "pali": "vehapphale vehapphalato saññatvā vehapphale maññati, vehapphalesu maññati, vehapphalato maññati, vehapphale meti maññati, vehapphale abhinandati."
    },
    {
      "id": "mn1:13.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:13.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:14.1",
      "pali": "Abhibhuṁ abhibhuto sañjānāti;"
    },
    {
      "id": "mn1:14.2",
      "pali": "abhibhuṁ abhibhuto saññatvā abhibhuṁ maññati, abhibhusmiṁ maññati, abhibhuto maññati, abhibhuṁ meti maññati, abhibhuṁ abhinandati."
    },
    {
      "id": "mn1:14.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:14.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:15.1",
      "pali": "Ākāsānañcāyatanaṁ ākāsānañcāyatanato sañjānāti;"
    },
    {
      "id": "mn1:15.2",
      "pali": "ākāsānañcāyatanaṁ ākāsānañcāyatanato saññatvā ākāsānañcāyatanaṁ maññati, ākāsānañcāyatanasmiṁ maññati, ākāsānañcāyatanato maññati, ākāsānañcāyatanaṁ meti maññati, ākāsānañcāyatanaṁ abhinandati."
    },
    {
      "id": "mn1:15.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:15.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:16.1",
      "pali": "Viññāṇañcāyatanaṁ viññāṇañcāyatanato sañjānāti;"
    },
    {
      "id": "mn1:16.2",
      "pali": "viññāṇañcāyatanaṁ viññāṇañcāyatanato saññatvā viññāṇañcāyatanaṁ maññati, viññāṇañcāyatanasmiṁ maññati, viññāṇañcāyatanato maññati, viññāṇañcāyatanaṁ meti maññati, viññāṇañcāyatanaṁ abhinandati."
    },
    {
      "id": "mn1:16.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:16.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:17.1",
      "pali": "Ākiñcaññāyatanaṁ ākiñcaññāyatanato sañjānāti;"
    },
    {
      "id": "mn1:17.2",
      "pali": "ākiñcaññāyatanaṁ ākiñcaññāyatanato saññatvā ākiñcaññāyatanaṁ maññati, ākiñcaññāyatanasmiṁ maññati, ākiñcaññāyatanato maññati, ākiñcaññāyatanaṁ meti maññati, ākiñcaññāyatanaṁ abhinandati."
    },
    {
      "id": "mn1:17.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:17.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:18.1",
      "pali": "Nevasaññānāsaññāyatanaṁ nevasaññānāsaññāyatanato sañjānāti;"
    },
    {
      "id": "mn1:18.2",
      "pali": "nevasaññānāsaññāyatanaṁ nevasaññānāsaññāyatanato saññatvā nevasaññānāsaññāyatanaṁ maññati, nevasaññānāsaññāyatanasmiṁ maññati, nevasaññānāsaññāyatanato maññati, nevasaññānāsaññāyatanaṁ meti maññati, nevasaññānāsaññāyatanaṁ abhinandati."
    },
    {
      "id": "mn1:18.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:18.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:19.1",
      "pali": "Diṭṭhaṁ diṭṭhato sañjānāti;"
    },
    {
      "id": "mn1:19.2",
      "pali": "diṭṭhaṁ diṭṭhato saññatvā diṭṭhaṁ maññati, diṭṭhasmiṁ maññati, diṭṭhato maññati, diṭṭhaṁ meti maññati, diṭṭhaṁ abhinandati."
    },
    {
      "id": "mn1:19.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:19.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:20.1",
      "pali": "Sutaṁ sutato sañjānāti;"
    },
    {
      "id": "mn1:20.2",
      "pali": "sutaṁ sutato saññatvā sutaṁ maññati, sutasmiṁ maññati, sutato maññati, sutaṁ meti maññati, sutaṁ abhinandati."
    },
    {
      "id": "mn1:20.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:20.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:21.1",
      "pali": "Mutaṁ mutato sañjānāti;"
    },
    {
      "id": "mn1:21.2",
      "pali": "mutaṁ mutato saññatvā mutaṁ maññati, mutasmiṁ maññati, mutato maññati, mutaṁ meti maññati, mutaṁ abhinandati."
    },
    {
      "id": "mn1:21.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:21.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:22.1",
      "pali": "Viññātaṁ viññātato sañjānāti;"
    },
    {
      "id": "mn1:22.2",
      "pali": "viññātaṁ viññātato saññatvā viññātaṁ maññati, viññātasmiṁ maññati, viññātato maññati, viññātaṁ meti maññati, viññātaṁ abhinandati."
    },
    {
      "id": "mn1:22.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:22.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:23.1",
      "pali": "Ekattaṁ ekattato sañjānāti;"
    },
    {
      "id": "mn1:23.2",
      "pali": "ekattaṁ ekattato saññatvā ekattaṁ maññati, ekattasmiṁ maññati, ekattato maññati, ekattaṁ meti maññati, ekattaṁ abhinandati."
    },
    {
      "id": "mn1:23.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:23.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:24.1",
      "pali": "Nānattaṁ nānattato sañjānāti;"
    },
    {
      "id": "mn1:24.2",
      "pali": "nānattaṁ nānattato saññatvā nānattaṁ maññati, nānattasmiṁ maññati, nānattato maññati, nānattaṁ meti maññati, nānattaṁ abhinandati."
    },
    {
      "id": "mn1:24.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:24.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:25.1",
      "pali": "Sabbaṁ sabbato sañjānāti;"
    },
    {
      "id": "mn1:25.2",
      "pali": "sabbaṁ sabbato saññatvā sabbaṁ maññati, sabbasmiṁ maññati, sabbato maññati, sabbaṁ meti maññati, sabbaṁ abhinandati."
    },
    {
      "id": "mn1:25.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:25.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:26.1",
      "pali": "Nibbānaṁ nibbānato sañjānāti;"
    },
    {
      "id": "mn1:26.2",
      "pali": "nibbānaṁ nibbānato saññatvā nibbānaṁ maññati, nibbānasmiṁ maññati, nibbānato maññati, nibbānaṁ meti maññati, nibbānaṁ abhinandati."
    },
    {
      "id": "mn1:26.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:26.4",
      "pali": "‘Apariññātaṁ tassā’ti vadāmi."
    },
    {
      "id": "mn1:26.5",
      "pali": "Puthujjanavasena paṭhamanayabhūmiparicchedo niṭṭhito."
    },
    {
      "id": "mn1:27.1",
      "pali": "Yopi so, bhikkhave, bhikkhu sekkho appattamānaso anuttaraṁ yogakkhemaṁ patthayamāno viharati, sopi pathaviṁ pathavito abhijānāti;"
    },
    {
      "id": "mn1:27.2",
      "pali": "pathaviṁ pathavito abhiññāya pathaviṁ mā maññi, pathaviyā mā maññi, pathavito mā maññi, pathaviṁ meti mā maññi, pathaviṁ mābhinandi."
    },
    {
      "id": "mn1:27.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:27.4",
      "pali": "‘Pariññeyyaṁ tassā’ti vadāmi."
