      "id": "mn1:190.1",
      "pali": "viññātaṁ …"
    },
    {
      "id": "mn1:191.1",
      "pali": "ekattaṁ …"
    },
    {
      "id": "mn1:192.1",
      "pali": "nānattaṁ …"
    },
    {
      "id": "mn1:193.1",
      "pali": "sabbaṁ …"
    },
    {
      "id": "mn1:194.1",
      "pali": "nibbānaṁ nibbānato abhijānāti;"
    },
    {
      "id": "mn1:194.2",
      "pali": "nibbānaṁ nibbānato abhiññāya nibbānaṁ na maññati, nibbānasmiṁ na maññati, nibbānato na maññati, nibbānaṁ meti na maññati, nibbānaṁ nābhinandati."
    },
    {
      "id": "mn1:194.3",
      "pali": "Taṁ kissa hetu?"
    },
    {
      "id": "mn1:194.4",
      "pali": "‘Nandī dukkhassa mūlan’ti—"
    },
    {
      "id": "mn1:194.5",
      "pali": "iti viditvā ‘bhavā jāti bhūtassa jarāmaraṇan’ti."
    },
    {
      "id": "mn1:194.6",
      "pali": "Tasmātiha, bhikkhave, ‘tathāgato sabbaso taṇhānaṁ khayā virāgā nirodhā cāgā paṭinissaggā anuttaraṁ sammāsambodhiṁ abhisambuddho’ti vadāmī”ti."
    },
    {
      "id": "mn1:194.7",
      "pali": "Tathāgatavasena aṭṭhamanayabhūmiparicchedo niṭṭhito."
    },
    {
      "id": "mn1:194.8",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "mn1:194.9",
      "pali": "Na te bhikkhū bhagavato bhāsitaṁ abhinandunti."
    },
    {
      "id": "mn1:194.10",
      "pali": "Mūlapariyāyasuttaṁ niṭṭhitaṁ paṭhamaṁ."
    }
  ]
}
