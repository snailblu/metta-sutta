{
  "uid": "mn147",
  "title": "Cūḷarāhulovādasutta",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mn147:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "mn147:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "mn147:1.3",
      "pali": "Atha kho bhagavato rahogatassa paṭisallīnassa evaṁ cetaso parivitakko udapādi:"
    },
    {
      "id": "mn147:1.4",
      "pali": "“paripakkā kho rāhulassa vimuttiparipācanīyā dhammā."
    },
    {
      "id": "mn147:1.5",
      "pali": "Yannūnāhaṁ rāhulaṁ uttariṁ āsavānaṁ khaye vineyyan”ti."
    },
    {
      "id": "mn147:1.6",
      "pali": "Atha kho bhagavā pubbaṇhasamayaṁ nivāsetvā pattacīvaramādāya sāvatthiṁ piṇḍāya pāvisi."
    },
    {
      "id": "mn147:1.7",
      "pali": "Sāvatthiyaṁ piṇḍāya caritvā pacchābhattaṁ piṇḍapātapaṭikkanto āyasmantaṁ rāhulaṁ āmantesi:"
    },
    {
      "id": "mn147:1.8",
      "pali": "“gaṇhāhi, rāhula, nisīdanaṁ;"
    },
    {
      "id": "mn147:1.9",
      "pali": "yena andhavanaṁ tenupasaṅkamissāma divāvihārāyā”ti."
    },
    {
      "id": "mn147:1.10",
      "pali": "“Evaṁ, bhante”ti kho āyasmā rāhulo bhagavato paṭissutvā nisīdanaṁ ādāya bhagavantaṁ piṭṭhito piṭṭhito anubandhi."
    },
    {
      "id": "mn147:2.1",
      "pali": "Tena kho pana samayena anekāni devatāsahassāni bhagavantaṁ anubandhāni honti:"
    },
    {
      "id": "mn147:2.2",
      "pali": "“ajja bhagavā āyasmantaṁ rāhulaṁ uttariṁ āsavānaṁ khaye vinessatī”ti."
    },
    {
      "id": "mn147:2.3",
      "pali": "Atha kho bhagavā andhavanaṁ ajjhogāhetvā aññatarasmiṁ rukkhamūle paññatte āsane nisīdi."
    },
    {
      "id": "mn147:2.4",
      "pali": "Āyasmāpi kho rāhulo bhagavantaṁ abhivādetvā ekamantaṁ nisīdi."
    },
    {
      "id": "mn147:2.5",
      "pali": "Ekamantaṁ nisinnaṁ kho āyasmantaṁ rāhulaṁ bhagavā etadavoca:"
    },
    {
      "id": "mn147:2.6",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "mn147:2.7",
      "pali": "cakkhu niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "mn147:2.8",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "mn147:2.9",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "mn147:2.10",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "mn147:2.11",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "mn147:2.12",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "mn147:2.13",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "mn147:3.1",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "mn147:3.2",
      "pali": "rūpā niccā vā aniccā vā”ti?"
    },
    {
      "id": "mn147:3.3",
      "pali": "“Aniccā, bhante”."
    },
