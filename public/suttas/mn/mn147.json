    },
    {
      "id": "mn147:4-8.37",
      "pali": "“Taṁ kiṁ maññasi, rāhula,"
    },
    {
      "id": "mn147:4-8.38",
      "pali": "yamidaṁ manosamphassapaccayā uppajjati vedanāgataṁ saññāgataṁ saṅkhāragataṁ viññāṇagataṁ, tampi niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.39",
      "pali": "“Aniccaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.40",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.41",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.42",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "mn147:4-8.43",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "mn147:4-8.44",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "mn147:9.1",
      "pali": "“Evaṁ passaṁ, rāhula, sutavā ariyasāvako cakkhusmiṁ nibbindati, rūpesu nibbindati, cakkhuviññāṇe nibbindati, cakkhusamphasse nibbindati, yamidaṁ cakkhusamphassapaccayā uppajjati vedanāgataṁ saññāgataṁ saṅkhāragataṁ viññāṇagataṁ tasmimpi nibbindati."
    },
    {
      "id": "mn147:9.2",
      "pali": "Sotasmiṁ nibbindati, saddesu nibbindati …pe…"
    },
    {
      "id": "mn147:9.3",
      "pali": "ghānasmiṁ nibbindati, gandhesu nibbindati …"
    },
    {
      "id": "mn147:9.4",
      "pali": "jivhāya nibbindati, rasesu nibbindati …"
    },
    {
      "id": "mn147:9.5",
      "pali": "kāyasmiṁ nibbindati, phoṭṭhabbesu nibbindati …"
    },
    {
      "id": "mn147:9.6",
      "pali": "manasmiṁ nibbindati, dhammesu nibbindati, manoviññāṇe nibbindati, manosamphasse nibbindati, yamidaṁ manosamphassapaccayā uppajjati vedanāgataṁ saññāgataṁ saṅkhāragataṁ viññāṇagataṁ tasmimpi nibbindati."
    },
    {
      "id": "mn147:9.7",
      "pali": "Nibbindaṁ virajjati, virāgā vimuccati. Vimuttasmiṁ vimuttamiti ñāṇaṁ hoti."
    },
    {
      "id": "mn147:9.8",
      "pali": "‘Khīṇā jāti, vusitaṁ brahmacariyaṁ, kataṁ karaṇīyaṁ, nāparaṁ itthattāyā’ti pajānātī”ti."
    },
    {
      "id": "mn147:9.9",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "mn147:9.10",
      "pali": "Attamano āyasmā rāhulo bhagavato bhāsitaṁ abhinandīti."
    },
    {
      "id": "mn147:9.11",
      "pali": "Imasmiñca pana veyyākaraṇasmiṁ bhaññamāne āyasmato rāhulassa anupādāya āsavehi cittaṁ vimucci."
    },
    {
      "id": "mn147:9.12",
      "pali": "Tāsañca anekānaṁ devatāsahassānaṁ virajaṁ vītamalaṁ dhammacakkhuṁ udapādi:"
    },
    {
      "id": "mn147:9.13",
      "pali": "“yaṁ kiñci samudayadhammaṁ sabbaṁ taṁ nirodhadhamman”ti."
    },
    {
      "id": "mn147:9.14",
      "pali": "Cūḷarāhulovādasuttaṁ niṭṭhitaṁ pañcamaṁ."
    }
  ]
}
