    },
    {
      "id": "mn147:4-8.1",
      "pali": "“Taṁ kiṁ maññasi rāhula, sotaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.2",
      "pali": "“Aniccaṁ, bhante …pe…"
    },
    {
      "id": "mn147:4-8.3",
      "pali": "ghānaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.4",
      "pali": "“Aniccaṁ, bhante …pe…"
    },
    {
      "id": "mn147:4-8.5",
      "pali": "jivhā niccā vā aniccā vā”ti?"
    },
    {
      "id": "mn147:4-8.6",
      "pali": "“Aniccā, bhante …"
    },
    {
      "id": "mn147:4-8.7",
      "pali": "kāyo nicco vā anicco vā”ti?"
    },
    {
      "id": "mn147:4-8.8",
      "pali": "“Anicco, bhante …"
    },
    {
      "id": "mn147:4-8.9",
      "pali": "mano nicco vā anicco vā”ti?"
    },
    {
      "id": "mn147:4-8.10",
      "pali": "“Anicco, bhante”."
    },
    {
      "id": "mn147:4-8.11",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.12",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.13",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "mn147:4-8.14",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "mn147:4-8.15",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.16",
      "pali": "“Taṁ kiṁ maññasi rāhula, dhammā niccā vā aniccā vā”ti?"
    },
    {
      "id": "mn147:4-8.17",
      "pali": "“Aniccā, bhante”."
    },
    {
      "id": "mn147:4-8.18",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vā taṁ sukhaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.19",
      "pali": "“Dukkhaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.20",
      "pali": "“Yaṁ panāniccaṁ dukkhaṁ vipariṇāmadhammaṁ, kallaṁ nu taṁ samanupassituṁ:"
    },
    {
      "id": "mn147:4-8.21",
      "pali": "‘etaṁ mama, esohamasmi, eso me attā’”ti?"
    },
    {
      "id": "mn147:4-8.22",
      "pali": "“No hetaṁ, bhante”."
    },
    {
      "id": "mn147:4-8.23",
      "pali": "“Taṁ kiṁ maññasi rāhula, manoviññāṇaṁ niccaṁ vā aniccaṁ vā”ti?"
    },
    {
      "id": "mn147:4-8.24",
