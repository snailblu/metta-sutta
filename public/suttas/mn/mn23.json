{
  "uid": "mn23",
  "title": "Vammikasutta",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mn23:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "mn23:1.2",
      "pali": "ekaṁ samayaṁ bhagavā sāvatthiyaṁ viharati jetavane anāthapiṇḍikassa ārāme."
    },
    {
      "id": "mn23:1.3",
      "pali": "Tena kho pana samayena āyasmā kumārakassapo andhavane viharati."
    },
    {
      "id": "mn23:1.4",
      "pali": "Atha kho aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ andhavanaṁ obhāsetvā yenāyasmā kumārakassapo tenupasaṅkami; upasaṅkamitvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhitā kho sā devatā āyasmantaṁ kumārakassapaṁ etadavoca:"
    },
    {
      "id": "mn23:2.1",
      "pali": "“Bhikkhu bhikkhu, ayaṁ vammiko rattiṁ dhūmāyati, divā pajjalati."
    },
    {
      "id": "mn23:2.2",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.3",
      "pali": "‘abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.4",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa laṅgiṁ"
    },
    {
      "id": "mn23:2.5",
      "pali": "‘laṅgī, bhadante’ti."
    },
    {
      "id": "mn23:2.6",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.7",
      "pali": "‘ukkhipa laṅgiṁ;"
    },
    {
      "id": "mn23:2.8",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.9",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa uddhumāyikaṁ."
    },
    {
      "id": "mn23:2.10",
      "pali": "‘Uddhumāyikā, bhadante’ti."
    },
    {
      "id": "mn23:2.11",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.12",
      "pali": "‘ukkhipa uddhumāyikaṁ;"
    },
    {
      "id": "mn23:2.13",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.14",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa dvidhāpathaṁ."
    },
    {
      "id": "mn23:2.15",
      "pali": "‘Dvidhāpatho, bhadante’ti."
    },
    {
      "id": "mn23:2.16",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.17",
      "pali": "‘ukkhipa dvidhāpathaṁ;"
    },
    {
      "id": "mn23:2.18",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.19",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa caṅgavāraṁ."
    },
    {
      "id": "mn23:2.20",
      "pali": "‘Caṅgavāro, bhadante’ti."
    },
    {
      "id": "mn23:2.21",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.22",
      "pali": "‘ukkhipa caṅgavāraṁ;"
    },
    {
      "id": "mn23:2.23",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.24",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa kummaṁ."
    },
    {
      "id": "mn23:2.25",
      "pali": "‘Kummo, bhadante’ti."
    },
    {
      "id": "mn23:2.26",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.27",
      "pali": "‘ukkhipa kummaṁ;"
    },
    {
      "id": "mn23:2.28",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.29",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa asisūnaṁ."
    },
    {
      "id": "mn23:2.30",
      "pali": "‘Asisūnā, bhadante’ti."
    },
    {
      "id": "mn23:2.31",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.32",
      "pali": "‘ukkhipa asisūnaṁ;"
    },
    {
      "id": "mn23:2.33",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.34",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa maṁsapesiṁ."
    },
    {
      "id": "mn23:2.35",
      "pali": "‘Maṁsapesi, bhadante’ti."
    },
    {
      "id": "mn23:2.36",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.37",
      "pali": "‘ukkhipa maṁsapesiṁ;"
    },
    {
      "id": "mn23:2.38",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyā’ti."
    },
    {
      "id": "mn23:2.39",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya addasa nāgaṁ."
    },
    {
      "id": "mn23:2.40",
      "pali": "‘Nāgo, bhadante’ti."
    },
    {
      "id": "mn23:2.41",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:2.42",
      "pali": "‘tiṭṭhatu nāgo, mā nāgaṁ ghaṭṭesi; namo karohi nāgassā’ti."
    },
    {
      "id": "mn23:2.43",
      "pali": "Ime kho tvaṁ, bhikkhu, pañhe bhagavantaṁ upasaṅkamitvā puccheyyāsi, yathā ca te bhagavā byākaroti tathā naṁ dhāreyyāsi."
    },
    {
      "id": "mn23:2.44",
      "pali": "Nāhaṁ taṁ, bhikkhu, passāmi sadevake loke samārake sabrahmake sassamaṇabrāhmaṇiyā pajāya sadevamanussāya, yo imesaṁ pañhānaṁ veyyākaraṇena cittaṁ ārādheyya aññatra tathāgatena vā, tathāgatasāvakena vā, ito vā pana sutvā”ti—"
    },
    {
      "id": "mn23:2.45",
      "pali": "Idamavoca sā devatā."
    },
    {
      "id": "mn23:2.46",
      "pali": "Idaṁ vatvā tatthevantaradhāyi."
    },
    {
      "id": "mn23:3.1",
      "pali": "Atha kho āyasmā kumārakassapo tassā rattiyā accayena yena bhagavā tenupasaṅkami; upasaṅkamitvā bhagavantaṁ abhivādetvā ekamantaṁ nisīdi. Ekamantaṁ nisinno kho āyasmā kumārakassapo bhagavantaṁ etadavoca:"
    },
    {
      "id": "mn23:3.2",
      "pali": "“imaṁ, bhante, rattiṁ aññatarā devatā abhikkantāya rattiyā abhikkantavaṇṇā kevalakappaṁ andhavanaṁ obhāsetvā yenāhaṁ tenupasaṅkami; upasaṅkamitvā ekamantaṁ aṭṭhāsi. Ekamantaṁ ṭhitā kho, bhante, sā devatā maṁ etadavoca:"
    },
    {
      "id": "mn23:3.3",
      "pali": "‘bhikkhu bhikkhu, ayaṁ vammiko rattiṁ dhūmāyati, divā pajjalati."
    },
    {
      "id": "mn23:3.4",
      "pali": "Brāhmaṇo evamāha:"
    },
    {
      "id": "mn23:3.5",
      "pali": "“abhikkhaṇa, sumedha, satthaṁ ādāyā”ti."
    },
    {
      "id": "mn23:3.6",
      "pali": "Abhikkhaṇanto sumedho satthaṁ ādāya …pe…"
    },
    {
      "id": "mn23:3.7",
      "pali": "ito vā pana sutvā’ti."
    },
    {
      "id": "mn23:3.8",
      "pali": "Idamavoca, bhante, sā devatā."
    },
    {
      "id": "mn23:3.9",
      "pali": "Idaṁ vatvā tatthevantaradhāyi."
    },
    {
      "id": "mn23:3.10",
      "pali": "Ko nu kho, bhante, vammiko, kā rattiṁ dhūmāyanā, kā divā pajjalanā, ko brāhmaṇo, ko sumedho, kiṁ satthaṁ, kiṁ abhikkhaṇaṁ, kā laṅgī, kā uddhumāyikā, ko dvidhāpatho, kiṁ caṅgavāraṁ, ko kummo, kā asisūnā, kā maṁsapesi, ko nāgo”ti?"
    },
    {
      "id": "mn23:4.1",
      "pali": "“‘Vammiko’ti kho, bhikkhu, imassetaṁ cātumahābhūtikassa kāyassa adhivacanaṁ, mātāpettikasambhavassa odanakummāsūpacayassa aniccucchādanaparimaddanabhedanaviddhaṁsanadhammassa."
    },
    {
      "id": "mn23:4.2",
      "pali": "Yaṁ kho, bhikkhu, divā kammante ārabbha rattiṁ anuvitakketi anuvicāreti—"
    },
    {
      "id": "mn23:4.3",
      "pali": "ayaṁ rattiṁ dhūmāyanā."
    },
    {
      "id": "mn23:4.4",
      "pali": "Yaṁ kho, bhikkhu, rattiṁ anuvitakketvā anuvicāretvā divā kammante payojeti kāyena vācāya manasā—"
    },
    {
      "id": "mn23:4.5",
      "pali": "ayaṁ divā pajjalanā."
    },
    {
      "id": "mn23:4.6",
      "pali": "‘Brāhmaṇo’ti kho, bhikkhu, tathāgatassetaṁ adhivacanaṁ arahato sammāsambuddhassa."
    },
    {
      "id": "mn23:4.7",
      "pali": "‘Sumedho’ti kho, bhikkhu, sekkhassetaṁ bhikkhuno adhivacanaṁ."
    },
    {
      "id": "mn23:4.8",
      "pali": "‘Satthan’ti kho, bhikkhu, ariyāyetaṁ paññāya adhivacanaṁ."
    },
    {
      "id": "mn23:4.9",
      "pali": "‘Abhikkhaṇan’ti kho, bhikkhu, vīriyārambhassetaṁ adhivacanaṁ."
    },
    {
      "id": "mn23:4.10",
      "pali": "‘Laṅgī’ti kho, bhikkhu, avijjāyetaṁ adhivacanaṁ."
    },
    {
      "id": "mn23:4.11",
      "pali": "Ukkhipa laṅgiṁ, pajaha avijjaṁ;"
    },
    {
      "id": "mn23:4.12",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.13",
      "pali": "‘Uddhumāyikā’ti kho, bhikkhu, kodhūpāyāsassetaṁ adhivacanaṁ."
    },
    {
      "id": "mn23:4.14",
      "pali": "Ukkhipa uddhumāyikaṁ, pajaha kodhūpāyāsaṁ;"
    },
    {
      "id": "mn23:4.15",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.16",
      "pali": "‘Dvidhāpatho’ti kho, bhikkhu, vicikicchāyetaṁ adhivacanaṁ."
    },
    {
      "id": "mn23:4.17",
      "pali": "Ukkhipa dvidhāpathaṁ, pajaha vicikicchaṁ;"
    },
    {
      "id": "mn23:4.18",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.19",
      "pali": "‘Caṅgavāran’ti kho, bhikkhu, pañcannetaṁ nīvaraṇānaṁ adhivacanaṁ, seyyathidaṁ—"
    },
    {
      "id": "mn23:4.20",
      "pali": "kāmacchandanīvaraṇassa, byāpādanīvaraṇassa, thinamiddhanīvaraṇassa, uddhaccakukkuccanīvaraṇassa, vicikicchānīvaraṇassa."
    },
    {
      "id": "mn23:4.21",
      "pali": "Ukkhipa caṅgavāraṁ, pajaha pañca nīvaraṇe;"
    },
    {
      "id": "mn23:4.22",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.23",
      "pali": "‘Kummo’ti kho, bhikkhu, pañcannetaṁ upādānakkhandhānaṁ adhivacanaṁ, seyyathidaṁ—"
    },
    {
      "id": "mn23:4.24",
      "pali": "rūpupādānakkhandhassa, vedanupādānakkhandhassa, saññupādānakkhandhassa, saṅkhārupādānakkhandhassa, viññāṇupādānakkhandhassa."
    },
    {
      "id": "mn23:4.25",
      "pali": "Ukkhipa kummaṁ, pajaha pañcupādānakkhandhe;"
    },
    {
      "id": "mn23:4.26",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.27",
      "pali": "‘Asisūnā’ti kho, bhikkhu, pañcannetaṁ kāmaguṇānaṁ adhivacanaṁ—"
    },
    {
      "id": "mn23:4.28",
      "pali": "cakkhuviññeyyānaṁ rūpānaṁ iṭṭhānaṁ kantānaṁ manāpānaṁ piyarūpānaṁ kāmūpasaṁhitānaṁ rajanīyānaṁ,"
    },
    {
      "id": "mn23:4.29",
      "pali": "sotaviññeyyānaṁ saddānaṁ …pe…"
    },
    {
      "id": "mn23:4.30",
      "pali": "ghānaviññeyyānaṁ gandhānaṁ …pe…"
    },
    {
      "id": "mn23:4.31",
      "pali": "jivhāviññeyyānaṁ rasānaṁ …pe…"
    },
    {
      "id": "mn23:4.32",
      "pali": "kāyaviññeyyānaṁ phoṭṭhabbānaṁ iṭṭhānaṁ kantānaṁ manāpānaṁ piyarūpānaṁ kāmūpasaṁhitānaṁ rajanīyānaṁ."
    },
    {
      "id": "mn23:4.33",
      "pali": "Ukkhipa asisūnaṁ, pajaha pañca kāmaguṇe;"
    },
    {
      "id": "mn23:4.34",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.35",
      "pali": "‘Maṁsapesī’ti kho, bhikkhu, nandīrāgassetaṁ adhivacanaṁ."
    },
    {
      "id": "mn23:4.36",
      "pali": "Ukkhipa maṁsapesiṁ, pajaha nandīrāgaṁ;"
    },
    {
      "id": "mn23:4.37",
      "pali": "abhikkhaṇa, sumedha, satthaṁ ādāyāti ayametassa attho."
    },
    {
      "id": "mn23:4.38",
      "pali": "‘Nāgo’ti kho, bhikkhu, khīṇāsavassetaṁ bhikkhuno adhivacanaṁ."
    },
    {
      "id": "mn23:4.39",
      "pali": "Tiṭṭhatu nāgo, mā nāgaṁ ghaṭṭesi; namo karohi nāgassāti ayametassa attho”ti."
    },
    {
      "id": "mn23:4.40",
      "pali": "Idamavoca bhagavā."
    },
    {
      "id": "mn23:4.41",
      "pali": "Attamano āyasmā kumārakassapo bhagavato bhāsitaṁ abhinandīti."
    },
    {
      "id": "mn23:4.42",
      "pali": "Vammikasuttaṁ niṭṭhitaṁ tatiyaṁ."
    }
  ]
}
