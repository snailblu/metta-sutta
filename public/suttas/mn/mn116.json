{
  "uid": "mn116",
  "title": "Isigilisutta",
  "nikaya": "mn",
  "segments": [
    {
      "id": "mn116:1.1",
      "pali": "Evaṁ me sutaṁ—"
    },
    {
      "id": "mn116:1.2",
      "pali": "ekaṁ samayaṁ bhagavā rājagahe viharati isigilismiṁ pabbate."
    },
    {
      "id": "mn116:1.3",
      "pali": "Tatra kho bhagavā bhikkhū āmantesi:"
    },
    {
      "id": "mn116:1.4",
      "pali": "“bhikkhavo”ti."
    },
    {
      "id": "mn116:1.5",
      "pali": "“Bhadante”ti te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn116:1.6",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn116:2.1",
      "pali": "“Passatha no tumhe, bhikkhave, etaṁ vebhāraṁ pabbatan”ti?"
    },
    {
      "id": "mn116:2.2",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "mn116:2.3",
      "pali": "“Etassapi kho, bhikkhave, vebhārassa pabbatassa aññāva samaññā ahosi aññā paññatti."
    },
    {
      "id": "mn116:2.4",
      "pali": "Passatha no tumhe, bhikkhave, etaṁ paṇḍavaṁ pabbatan”ti?"
    },
    {
      "id": "mn116:2.5",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "mn116:2.6",
      "pali": "“Etassapi kho, bhikkhave, paṇḍavassa pabbatassa aññāva samaññā ahosi aññā paññatti."
    },
    {
      "id": "mn116:2.7",
      "pali": "Passatha no tumhe, bhikkhave, etaṁ vepullaṁ pabbatan”ti?"
    },
    {
      "id": "mn116:2.8",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "mn116:2.9",
      "pali": "“Etassapi kho, bhikkhave, vepullassa pabbatassa aññāva samaññā ahosi aññā paññatti."
    },
    {
      "id": "mn116:2.10",
      "pali": "Passatha no tumhe, bhikkhave, etaṁ gijjhakūṭaṁ pabbatan”ti?"
    },
    {
      "id": "mn116:2.11",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "mn116:2.12",
      "pali": "“Etassapi kho, bhikkhave, gijjhakūṭassa pabbatassa aññāva samaññā ahosi aññā paññatti."
    },
    {
      "id": "mn116:2.13",
      "pali": "Passatha no tumhe, bhikkhave, imaṁ isigiliṁ pabbatan”ti?"
    },
    {
      "id": "mn116:2.14",
      "pali": "“Evaṁ, bhante”."
    },
    {
      "id": "mn116:3.1",
      "pali": "“Imassa kho pana, bhikkhave, isigilissa pabbatassa esāva samaññā ahosi esā paññatti."
    },
    {
      "id": "mn116:3.2",
      "pali": "Bhūtapubbaṁ, bhikkhave, pañca paccekabuddhasatāni imasmiṁ isigilismiṁ pabbate ciranivāsino ahesuṁ."
    },
    {
      "id": "mn116:3.3",
      "pali": "Te imaṁ pabbataṁ pavisantā dissanti, paviṭṭhā na dissanti."
    },
    {
      "id": "mn116:3.4",
      "pali": "Tamenaṁ manussā disvā evamāhaṁsu:"
    },
    {
      "id": "mn116:3.5",
      "pali": "‘ayaṁ pabbato ime isī gilatī’ti;"
    },
    {
      "id": "mn116:3.6",
      "pali": "‘isigili isigili’ tveva samaññā udapādi."
    },
    {
      "id": "mn116:3.7",
      "pali": "Ācikkhissāmi, bhikkhave, paccekabuddhānaṁ nāmāni;"
    },
    {
      "id": "mn116:3.8",
      "pali": "kittayissāmi, bhikkhave, paccekabuddhānaṁ nāmāni;"
    },
    {
      "id": "mn116:3.9",
      "pali": "desessāmi, bhikkhave, paccekabuddhānaṁ nāmāni."
    },
    {
      "id": "mn116:3.10",
      "pali": "Taṁ suṇātha, sādhukaṁ manasi karotha, bhāsissāmī”ti."
    },
    {
      "id": "mn116:3.11",
      "pali": "“Evaṁ, bhante”ti kho te bhikkhū bhagavato paccassosuṁ."
    },
    {
      "id": "mn116:3.12",
      "pali": "Bhagavā etadavoca:"
    },
    {
      "id": "mn116:4.1",
      "pali": "“Ariṭṭho nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.2",
      "pali": "upariṭṭho nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.3",
      "pali": "tagarasikhī nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.4",
      "pali": "yasassī nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.5",
      "pali": "sudassano nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.6",
      "pali": "piyadassī nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.7",
      "pali": "gandhāro nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.8",
      "pali": "piṇḍolo nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.9",
      "pali": "upāsabho nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.10",
      "pali": "nīto nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.11",
      "pali": "tatho nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi,"
    },
    {
      "id": "mn116:4.12",
      "pali": "sutavā nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi;"
    },
    {
      "id": "mn116:4.13",
      "pali": "bhāvitatto nāma, bhikkhave, paccekasambuddho imasmiṁ isigilismiṁ pabbate ciranivāsī ahosi."
    },
    {
      "id": "mn116:5.1",
      "pali": "Ye sattasārā anīghā nirāsā,"
    },
    {
      "id": "mn116:5.2",
      "pali": "Paccekamevajjhagamaṁsu bodhiṁ;"
    },
    {
      "id": "mn116:5.3",
      "pali": "Tesaṁ visallāna naruttamānaṁ,"
    },
    {
      "id": "mn116:5.4",
      "pali": "Nāmāni me kittayato suṇātha."
    },
    {
      "id": "mn116:5.5",
      "pali": "Ariṭṭho upariṭṭho tagarasikhī yasassī,"
    },
    {
      "id": "mn116:5.6",
      "pali": "Sudassano piyadassī ca susambuddho;"
    },
    {
      "id": "mn116:5.7",
      "pali": "Gandhāro piṇḍolo upāsabho ca,"
    },
    {
      "id": "mn116:5.8",
      "pali": "Nīto tatho sutavā bhāvitatto."
    },
    {
      "id": "mn116:6.1",
      "pali": "Sumbho subho matulo aṭṭhamo ca,"
    },
    {
      "id": "mn116:6.2",
      "pali": "Athassumegho anīgho sudāṭho;"
    },
    {
      "id": "mn116:6.3",
      "pali": "Paccekabuddhā bhavanettikhīṇā,"
    },
    {
      "id": "mn116:6.4",
      "pali": "Hiṅgū ca hiṅgo ca mahānubhāvā."
    },
    {
      "id": "mn116:6.5",
      "pali": "Dve jālino munino aṭṭhako ca,"
    },
    {
      "id": "mn116:6.6",
      "pali": "Atha kosallo buddho atho subāhu;"
    },
    {
      "id": "mn116:6.7",
      "pali": "Upanemiso nemiso santacitto,"
    },
    {
      "id": "mn116:6.8",
      "pali": "Sacco tatho virajo paṇḍito ca."
    },
    {
      "id": "mn116:6.9",
      "pali": "Kāḷūpakāḷā vijito jito ca,"
    },
    {
      "id": "mn116:6.10",
      "pali": "Aṅgo ca paṅgo ca guttijito ca;"
    },
    {
      "id": "mn116:6.11",
      "pali": "Passi jahi upadhidukkhamūlaṁ,"
    },
    {
      "id": "mn116:6.12",
      "pali": "Aparājito mārabalaṁ ajesi."
    },
    {
      "id": "mn116:6.13",
      "pali": "Satthā pavattā sarabhaṅgo lomahaṁso,"
    },
    {
      "id": "mn116:6.14",
      "pali": "Uccaṅgamāyo asito anāsavo;"
    },
    {
      "id": "mn116:6.15",
      "pali": "Manomayo mānacchido ca bandhumā,"
    },
    {
      "id": "mn116:6.16",
      "pali": "Tadādhimutto vimalo ca ketumā."
    },
    {
      "id": "mn116:6.17",
      "pali": "Ketumbharāgo ca mātaṅgo ariyo,"
    },
    {
      "id": "mn116:6.18",
      "pali": "Athaccuto accutagāmabyāmako;"
    },
    {
      "id": "mn116:6.19",
      "pali": "Sumaṅgalo dabbilo supatiṭṭhito,"
    },
    {
      "id": "mn116:6.20",
      "pali": "Asayho khemābhirato ca sorato."
    },
    {
      "id": "mn116:6.21",
      "pali": "Durannayo saṅgho athopi ujjayo,"
    },
    {
      "id": "mn116:6.22",
      "pali": "Aparo muni sayho anomanikkamo;"
    },
    {
      "id": "mn116:6.23",
      "pali": "Ānando nando upanando dvādasa,"
    },
    {
      "id": "mn116:6.24",
      "pali": "Bhāradvājo antimadehadhārī."
    },
    {
      "id": "mn116:6.25",
      "pali": "Bodhi mahānāmo athopi uttaro,"
    },
    {
      "id": "mn116:6.26",
      "pali": "Kesī sikhī sundaro dvārabhājo;"
    },
    {
      "id": "mn116:6.27",
      "pali": "Tissūpatissā bhavabandhanacchidā,"
    },
    {
      "id": "mn116:6.28",
      "pali": "Upasikhi taṇhacchido ca sikhari."
    },
    {
      "id": "mn116:6.29",
      "pali": "Buddho ahu maṅgalo vītarāgo,"
    },
    {
      "id": "mn116:6.30",
      "pali": "Usabhacchidā jāliniṁ dukkhamūlaṁ;"
    },
    {
      "id": "mn116:6.31",
      "pali": "Santaṁ padaṁ ajjhagamopanīto,"
    },
    {
      "id": "mn116:6.32",
      "pali": "Uposatho sundaro saccanāmo."
    },
    {
      "id": "mn116:6.33",
      "pali": "Jeto jayanto padumo uppalo ca,"
    },
    {
      "id": "mn116:6.34",
      "pali": "Padumuttaro rakkhito pabbato ca;"
    },
    {
      "id": "mn116:6.35",
      "pali": "Mānatthaddho sobhito vītarāgo,"
    },
    {
      "id": "mn116:6.36",
      "pali": "Kaṇho ca buddho suvimuttacitto."
    },
    {
      "id": "mn116:7.1",
      "pali": "Ete ca aññe ca mahānubhāvā,"
    },
    {
      "id": "mn116:7.2",
      "pali": "Paccekabuddhā bhavanettikhīṇā;"
    },
    {
      "id": "mn116:7.3",
      "pali": "Te sabbasaṅgātigate mahesī,"
    },
    {
      "id": "mn116:7.4",
      "pali": "Parinibbute vandatha appameyye”ti."
    },
    {
      "id": "mn116:7.5",
      "pali": "Isigilisuttaṁ niṭṭhitaṁ chaṭṭhaṁ."
    }
  ]
}
